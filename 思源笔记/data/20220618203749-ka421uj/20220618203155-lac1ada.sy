seParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203410-k0sdafk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203410-k0sdafk","updated":"20220618203410"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"测试是否同步出去了"}]},{"ID":"20220618203411-ykbkwud","Type":"NodeBlockquote","Properties":{"id":"20220618203411-ykbkwud","updated":"20220618203411"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203412-57hcvr1","Type":"NodeParagraph","Properties":{"id":"20220618203412-57hcvr1","updated":"20220618203412"},"Children":[{"Type":"NodeText","Data":"首先进入容器内部，在挂载的volume01中创建一个txt文件","Properties":{"id":""}}]}]},{"ID":"20220618203413-kq3ezqk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203413-kq3ezqk","updated":"20220618203413"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"[root@localhost _data]# docker images\nREPOSITORY            TAG       IMAGE ID       CREATED          SIZE\nxth/centos            1.0       f29f8de2ab58   36 minutes ago   209MB\n\n[root@localhost _data]# docker run -it f29f8de2ab58 /bin/bash\n[root@68f4b296f6d5 /]# ls\nbin  etc   lib\t  lost+found  mnt  proc  run   srv  tmp  var\t   volume02\ndev  home  lib64  media       opt  root  sbin  sys  usr  volume01\n\n[root@68f4b296f6d5 /]# cd volume01\n[root@68f4b296f6d5 volume01]# touch container.txt\n[root@68f4b296f6d5 volume01]# ls\ncontainer.txt\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203414-933nr4e","Type":"NodeBlockquote","Properties":{"id":"20220618203414-933nr4e","updated":"20220618203414"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203415-9s0cmix","Type":"NodeParagraph","Properties":{"id":"20220618203415-9s0cmix","updated":"20220618203415"},"Children":[{"Type":"NodeText","Data":"再进入linux系统中查看容器外是否自动同步了","Properties":{"id":""}}]}]},{"ID":"20220618203416-48e43qk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203416-48e43qk","updated":"20220618203416"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"[root@localhost ~]# docker ps\nCONTAINER ID   IMAGE                 COMMAND        CREATED         STATUS          PORTS                    NAMES\n04346f7010c3   f29f8de2ab58          \"/bin/bash\"    8 minutes ago   Up 8 minutes                             modest_moser\n6b7559c707bd   portainer/portainer   \"/portainer\"   13 days ago     Up 22 minutes   0.0.0.0:8088-\u003e9000/tcp   hardcore_aryabhata\n[root@localhost ~]# docker inspect 04346f7010c3\n\n#注意这里查看的是容器id不是镜像id！\n\n[root@localhost _data]# cd /var/lib/docker/volumes/bf79193bc12a6f1b046783fc63964de8007584a487ec91261b994850e0fcce06/_data\n[root@localhost _data]# ls\ncontainer.txt\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203417-6qvfvg9","Type":"NodeParagraph","Properties":{"id":"20220618203417-6qvfvg9","updated":"20220618203417"},"Children":[{"Type":"NodeText","Data":"成功！！","Properties":{"id":""}}]},{"ID":"20220618203418-qb3enxv","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203418-qb3enxv","updated":"20220618203418"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据卷容器","Properties":{"id":""}}]},{"ID":"20220618203419-5x4bebm","Type":"NodeParagraph","Properties":{"id":"20220618203419-5x4bebm","updated":"20220618203419"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/数据卷容器同步-20220618203734-76mmokv.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203420-llulpd1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203420-llulpd1","updated":"20220618203420"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"1. #启动3个容器，通过我们刚才自己写的镜像启动\n[root@localhost ~]# docker run -it --name docker01 xth/centos:1.0\n[root@1742744be3aa /]# cd volume01/\n[root@1742744be3aa volume01]# ls   \n#可以看到现在volume01是空的\n\n[root@localhost ~]# docker ps\nCONTAINER ID   IMAGE                 COMMAND                  CREATED         STATUS             PORTS                    NAMES\n1742744be3aa   xth/centos:1.0        \"/bin/sh -c /bin/bash\"   5 minutes ago   Up 5 minutes                                docker01\n6b7559c707bd   portainer/portainer   \"/portainer\"             13 days ago     Up About an hour   0.0.0.0:8088-\u003e9000/tcp   hardcore_aryabhata\n[root@localhost ~]# docker run -it --name docker02 --volumes-from docker01 xth/centos:1.0\n[root@2e5165b378a7 /]# ls\nbin  etc   lib\t  lost+found  mnt  proc  run   srv  tmp  var\t   volume02\ndev  home  lib64  media       opt  root  sbin  sys  usr  volume01\n[root@2e5165b378a7 /]# cd volume01/\n[root@2e5165b378a7 volume01]# touch docker01\n\n我们将docker02与docker01进行数据卷同步，相当于子类和父类\n\n[root@1742744be3aa volume01]# ls\ndocker01\n\n#可以看到volume01中已经同步了\n\n2. #现在再链接一个docker03\n[root@localhost ~]# docker run -it --name docker03 --volumes-from docker01 xth/centos:1.0\n[root@13643c5eba86 /]# ls\nbin  etc   lib\t  lost+found  mnt  proc  run   srv  tmp  var\t   volume02\ndev  home  lib64  media       opt  root  sbin  sys  usr  volume01\n[root@13643c5eba86 /]# cd volume01/\n[root@13643c5eba86 volume01]# ls\ndocker01\n#可以看到docker03自动同步了docker01的文件\n[root@13643c5eba86 volume01]# touch docker03\n#我们在docker03中创建一个文件看看docker01中的情况\n\n3. #重新进入关闭的docker01\n[root@localhost ~]# docker ps -a\nCONTAINER ID   IMAGE                 COMMAND                  CREATED             STATUS                        PORTS                    NAMES\n13643c5eba86   xth/centos:1.0        \"/bin/sh -c /bin/bash\"   3 minutes ago       Exited (0) 18 seconds ago                              docker03\n2e5165b378a7   xth/centos:1.0        \"/bin/sh -c /bin/bash\"   16 minutes ago      Up 16 minutes                                          docker02\n1742744be3aa   xth/centos:1.0        \"/bin/sh -c /bin/bash\"   23 minutes ago      Exited (130) 4 minutes ago                             docker01\n#启动容器\n[root@localhost ~]# docker start 1742744be3aa\n1742744be3aa\n#进入容器\n[root@localhost ~]# docker attach 1742744be3aa\n#查看docker01的volume01情况\n[root@1742744be3aa /]# cd volume01/\n[root@1742744be3aa volume01]# ls\ndocker01  docker03\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203421-mnb9j0c","Type":"NodeParagraph","Properties":{"id":"20220618203421-mnb9j0c","updated":"20220618203421"},"Children":[{"Type":"NodeText","Data":"多个mysql实现数据共享","Properties":{"id":""}}]},{"ID":"20220618203422-2jgnlyo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203422-2jgnlyo","updated":"20220618203422"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"[root@localhost ~]# docker run -d -p 3310:3306 -v /home/mysql/conf:/etc/mysql/conf.d -v    /home/mysql/data:/var/lib/mysql -e MYSQL_ROOT_PASSWORD=123456 --name mysql01 mysql:5.7\n\n[root@localhost ~]# docker run -d -p 3310:3306 -e MYSQL_ROOT_PASSWORD=123456 --name mysql02 --volumes-from mysql01 mysql:5.7\n#此时可以实现两个容器数据同步\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203423-7qwkkl9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203423-7qwkkl9","updated":"20220618203423"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"DockerFile","Properties":{"id":""}}]},{"ID":"20220618203424-s4us7t7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203424-s4us7t7","updated":"20220618203424"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"DockerFile介绍"}]},{"ID":"20220618203425-pxoeo6w","Type":"NodeParagraph","Properties":{"id":"20220618203425-pxoeo6w","updated":"20220618203425"},"Children":[{"Type":"NodeText","Data":"Dockerfile就是用来构建docker镜像的构建文本！命令参数脚本","Properties":{"id":""}}]},{"ID":"20220618203426-0xsvrgt","Type":"NodeParagraph","Properties":{"id":"20220618203426-0xsvrgt","updated":"20220618203426"},"Children":[{"Type":"NodeText","Data":"构建步骤:","Properties":{"id":""}}]},{"ID":"20220618203427-3sba1ru","Type":"NodeParagraph","Properties":{"id":"20220618203427-3sba1ru","updated":"20220618203427"},"Children":[{"Type":"NodeText","Data":"1.编写一个dockerfile文件","Properties":{"id":""}}]},{"ID":"20220618203428-dpnuwfk","Type":"NodeParagraph","Properties":{"id":"20220618203428-dpnuwfk","updated":"20220618203428"},"Children":[{"Type":"NodeText","Data":"2.docker build构建为一个镜像","Properties":{"id":""}}]},{"ID":"20220618203429-rbqxedg","Type":"NodeParagraph","Properties":{"id":"20220618203429-rbqxedg","updated":"20220618203429"},"Children":[{"Type":"NodeText","Data":"3.docker run 运行镜像","Properties":{"id":""}}]},{"ID":"20220618203430-fyxqtxj","Type":"NodeParagraph","Properties":{"id":"20220618203430-fyxqtxj","updated":"20220618203430"},"Children":[{"Type":"NodeText","Data":"4.docker push 发布镜像（DockerHub，阿里云镜像仓库）","Properties":{"id":""}}]},{"ID":"20220618203431-owidn6l","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203431-owidn6l","updated":"20220618203431"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"DockerFile构建过程","Properties":{"id":""}}]},{"ID":"20220618203432-apnzi34","Type":"NodeParagraph","Properties":{"id":"20220618203432-apnzi34","updated":"20220618203432"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"基础知识："}]},{"ID":"20220618203433-cy6rfz6","Type":"NodeParagraph","Properties":{"id":"20220618203433-cy6rfz6","updated":"20220618203433"},"Children":[{"Type":"NodeText","Data":"1.每个指令都必须是大写字母","Properties":{"id":""}}]},{"ID":"20220618203434-go6zt8g","Type":"NodeParagraph","Properties":{"id":"20220618203434-go6zt8g","updated":"20220618203434"},"Children":[{"Type":"NodeText","Data":"2.指令从上到下顺序执行","Properties":{"id":""}}]},{"ID":"20220618203435-elqvd6r","Type":"NodeParagraph","Properties":{"id":"20220618203435-elqvd6r","updated":"20220618203435"},"Children":[{"Type":"NodeText","Data":"3.# 表示注释","Properties":{"id":""}}]},{"ID":"20220618203436-l3egy4h","Type":"NodeParagraph","Properties":{"id":"20220618203436-l3egy4h","updated":"20220618203436"},"Children":[{"Type":"NodeText","Data":"4.每一个指令都会创建提交一个新的镜像层，并提交","Properties":{"id":""}}]},{"ID":"20220618203437-tjr5mqm","Type":"NodeParagraph","Properties":{"id":"20220618203437-tjr5mqm","updated":"20220618203437"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/镜像层-20220618203734-d6dbcdn.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203438-jqqibep","Type":"NodeParagraph","Properties":{"id":"20220618203438-jqqibep","updated":"20220618203438"},"Children":[{"Type":"NodeText","Data":"dockerfile是面向开发的，我们以后要发布项目做镜像，就需要编写dockerfile文件，这个文件十分简单！","Properties":{"id":""}}]},{"ID":"20220618203439-ejtto1t","Type":"NodeParagraph","Properties":{"id":"20220618203439-ejtto1t","updated":"20220618203439"},"Children":[{"Type":"NodeText","Data":"步骤：开发， 部署，运维","Properties":{"id":""}}]},{"ID":"20220618203440-6ncnfjw","Type":"NodeParagraph","Properties":{"id":"20220618203440-6ncnfjw","updated":"20220618203440"},"Children":[{"Type":"NodeText","Data":"DockerFile：构建文件，定义了一切的步骤，源代码","Properties":{"id":""}}]},{"ID":"20220618203441-xra0tx3","Type":"NodeParagraph","Properties":{"id":"20220618203441-xra0tx3","updated":"20220618203441"},"Children":[{"Type":"NodeText","Data":"DockerImages：通过DockerFile构建生成的镜像，最终发布和运行的产品","Properties":{"id":""}}]},{"ID":"20220618203442-aostgiz","Type":"NodeParagraph","Properties":{"id":"20220618203442-aostgiz","updated":"20220618203442"},"Children":[{"Type":"NodeText","Data":"Docker容器：容器就是镜像运行起来提供服务器","Properties":{"id":""}}]},{"ID":"20220618203443-2ywxzk3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203443-2ywxzk3","updated":"20220618203443"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"DockerFile指令","Properties":{"id":""}}]},{"ID":"20220618203444-6rhpxq5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203444-6rhpxq5","updated":"20220618203444"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"FROM\t\t\t\t#基础镜像，一切从这里开始构建\nMAINTAINER\t\t\t#镜像是谁写的，姓名+邮箱\nRUN\t\t\t\t\t#镜像构建的时候需要运行的命令\nADD\t\t\t\t\t#比如要搭建一个有tomcat的容器，那么必须要有centos系统和tomcat的压缩包，这个压缩包就是我们要add的\nWORKDIR\t\t\t\t#镜像的工作目录\nVOLUME\t\t\t\t#挂载的目录\nEXPOSE\t\t\t\t#暴露端口配置\nCMD\t\t\t\t\t#指定容器启动时要运行的命令，只有最后一个会生效，可被替代\nENTRYPOINT\t\t\t#指定这个容器启动的时候要运行的命令，可以追加命令\nONBUILD\t\t\t\t#当构建一个被继承DockerFile这个时候就会运行ONBUILD的指令，就是触发指令\nCOPY\t\t\t\t#类似ADD,将我们文件拷贝到目录中\nENV\t\t\t\t\t#构建的时候设置环境变量\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203445-wo0ndmi","Type":"NodeParagraph","Properties":{"id":"20220618203445-wo0ndmi","updated":"20220618203445"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/dockerfile指令-20220618203734-ftztsmk.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203446-7h80pcl","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203446-7h80pcl","updated":"20220618203446"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"实战测试","Properties":{"id":""}}]},{"ID":"20220618203447-3bkaxxa","Type":"NodeParagraph","Properties":{"id":"20220618203447-3bkaxxa","updated":"20220618203447"},"Children":[{"Type":"NodeText","Data":"DockerHub中99%镜像都是从这个基础镜像过来的 FROM scratch，然后配置需要的软件和配置来进行构建","Properties":{"id":""}}]},{"ID":"20220618203448-d1o112v","Type":"NodeBlockquote","Properties":{"id":"20220618203448-d1o112v","updated":"20220618203448"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203449-ty5thm9","Type":"NodeParagraph","Properties":{"id":"20220618203449-ty5thm9","updated":"20220618203449"},"Children":[{"Type":"NodeText","Data":"1.编写dockerfile文件","Properties":{"id":""}}]}]},{"ID":"20220618203450-5a6vz37","Type":"NodeParagraph","Properties":{"id":"20220618203450-5a6vz37","updated":"20220618203450"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/构建dockerfile文件-20220618203734-f9qsye2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203451-6xzsvlp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203451-6xzsvlp","updated":"20220618203451"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"2.通过这个文件构建镜像\ndocker build -f dockerfile文件路径 -t 镜像名:[tag]\n[root@localhost dockerfile]# docker build -f mydockerfile -t mycentos:0.1 .\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203452-45zxc67","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203452-45zxc67","updated":"20220618203452"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"3.列出本地进行的变更历史，可以通过这个指令研究他是怎么做的\ndocker history image的id\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203453-8r97xgf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203453-8r97xgf","updated":"20220618203453"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"CMD和ENTRYPOINT的区别","Properties":{"id":""}}]},{"ID":"20220618203454-4r5i5oi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203454-4r5i5oi","updated":"20220618203454"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"CMD\t\t\t\t\t#指定容器启动时要运行的命令，只有最后一个会生效，可被替代\nENTRYPOINT\t\t\t#指定这个容器启动的时候要运行的命令，可以追加命令\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203455-0rznwc6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203455-0rznwc6","updated":"20220618203455"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"测试CMD","Properties":{"id":""}}]},{"ID":"20220618203456-7koaata","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203456-7koaata","updated":"20220618203456"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 编写 dockerfile 文件\n[root@localhost dockerfile]# vim dockerfile-cmd \nFROM centos\nCMD [\"ls\",\"-a\"]\n\n# 构建镜像  注意有  点..............\n[root@localhost dockerfile]# docker build -f dockerfile-cmd -t cmdtest .\n\n# run运行\nelasticsearch         7.6.2     f29a1ee41030   14 months ago    791MB\n[root@localhost dockerfile]# docker run -it afb165667bc3\n.   .dockerenv\tdev  home  lib64       media  opt   root  sbin\tsys  usr\n..  bin\t\tetc  lib   lost+found  mnt    proc  run   srv\ttmp  var\n\n发现 ls -a 生效了\n\n# 但是如果在命令后面加一个-l就会报错，是因CMD已经替换了[\"ls\",\"-a\"], -l不是命令所以报错\n[root@localhost dockerfile]# docker run afb165667bc3 -l\ndocker: Error response from daemon: OCI runtime create failed: container_linux.go:367: starting container process caused: exec: \"-l\": executable file not found in $PATH: unknown.\n\n# 这样才能起作用\n[root@localhost dockerfile]# docker run afb165667bc3 ls -la\ntotal 0\ndrwxr-xr-x.   1 root root   6 May 31 01:22 .\ndrwxr-xr-x.   1 root root   6 May 31 01:22 ..\n-rwxr-xr-x.   1 root root   0 May 31 01:22 .dockerenv\nlrwxrwxrwx.   1 root root   7 Nov  3  2020 bin -\u003e usr/bin\ndrwxr-xr-x.   5 root root 340 May 31 01:22 dev\ndrwxr-xr-x.   1 root root  66 May 31 01:22 etc\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203457-tbncu1p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203457-tbncu1p","updated":"20220618203457"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"测试ENTRYPOINT","Properties":{"id":""}}]},{"ID":"20220618203458-43f2d34","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203458-43f2d34","updated":"20220618203458"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 1.编写dockerfile文件\n[root@localhost dockerfile]# vim dockerfilr-entrypoint \nFROM centos\nENTRYPOINT [\"ls\",\"-a\"]\n\n# 2.构建镜像\n[root@localhost dockerfile]# docker build -f dockerfilr-entrypoint -t entrypoint .\nSending build context to Docker daemon  4.096kB\nStep 1/2 : FROM centos\n ---\u003e 300e315adb2f\nStep 2/2 : ENTRYPOINT [\"ls\",\"-a\"]\n ---\u003e Running in e6975f71dc51\nRemoving intermediate container e6975f71dc51\n ---\u003e 710c6f6dfc04\nSuccessfully built 710c6f6dfc04\nSuccessfully tagged entrypoint:latest\n\n# 3.比较与CMD的区别——ENTRYPOINT可以直接跟命令\n[root@localhost dockerfile]# docker run 710c6f6dfc04 -l\ntotal 0\ndrwxr-xr-x.   1 root root   6 May 31 01:28 .\ndrwxr-xr-x.   1 root root   6 May 31 01:28 ..\n-rwxr-xr-x.   1 root root   0 May 31 01:28 .dockerenv\nlrwxrwxrwx.   1 root root   7 Nov  3  2020 bin -\u003e usr/bin\ndrwxr-xr-x.   5 root root 340 May 31 01:28 dev\ndrwxr-xr-x.   1 root root  66 May 31 01:28 etc\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203459-j17i6q9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203459-j17i6q9","updated":"20220618203459"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"发布自己的镜像","Properties":{"id":""}}]},{"ID":"20220618203460-mw762hu","Type":"NodeParagraph","Properties":{"id":"20220618203460-mw762hu","updated":"20220618203460"},"Children":[{"Type":"NodeText","Data":"DockerHub","Properties":{"id":""}}]},{"ID":"20220618203461-gnehwb0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203461-gnehwb0","updated":"20220618203461"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 1.登录账号\n[root@localhost dockerfile]# docker login --help\n\nUsage:  docker login [OPTIONS] [SERVER]\n\nLog in to a Docker registry.\nIf no server is specified, the default is defined by the daemon.\n\nOptions:\n  -p, --password string   Password\n      --password-stdin    Take the password from stdin\n  -u, --username string   Username\n  \n[root@localhost dockerfile]# docker login -u xthsia -p Xth19970109\nWARNING! Using --password via the CLI is insecure. Use --password-stdin.\nWARNING! Your password will be stored unencrypted in /root/.docker/config.json.\nConfigure a credential helper to remove this warning. See\nhttps://docs.docker.com/engine/reference/commandline/login/#credentials-store\n\nLogin Succeeded\n[root@localhost dockerfile]# \n# 2.提交镜像，先要给自己的镜像加上ta\ndocker tag xthsia/cmdtest(镜像名字):1.0 \n#上传\ndocker push xthsia/cmdtest:1.0\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203462-k9vo8tt","Type":"NodeParagraph","Properties":{"id":"20220618203462-k9vo8tt","updated":"20220618203462"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/上传镜像-20220618203734-zorsgzk.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203463-bbvj87r","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203463-bbvj87r","updated":"20220618203463"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"自定义网络","Properties":{"id":""}}]},{"ID":"20220618203464-f06uj0q","Type":"NodeBlockquote","Properties":{"id":"20220618203464-f06uj0q","updated":"20220618203464"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203465-hq4eass","Type":"NodeParagraph","Properties":{"id":"20220618203465-hq4eass","updated":"20220618203465"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"查看所有的docker网络"}]}]},{"ID":"20220618203466-bjlb67v","Type":"NodeParagraph","Properties":{"id":"20220618203466-bjlb67v","updated":"20220618203466"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/docker网络-20220618203734-vcgnjsq.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203467-dw2b7me","Type":"NodeBlockquote","Properties":{"id":"20220618203467-dw2b7me","updated":"20220618203467"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203468-wp4p16m","Type":"NodeParagraph","Properties":{"id":"20220618203468-wp4p16m","updated":"20220618203468"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"网络模式"}]}]},{"ID":"20220618203469-slck0nv","Type":"NodeParagraph","Properties":{"id":"20220618203469-slck0nv","updated":"20220618203469"},"Children":[{"Type":"NodeText","Data":"bridge : 桥接 docker（默认）","Properties":{"id":""}}]},{"ID":"20220618203470-49dkcz0","Type":"NodeParagraph","Properties":{"id":"20220618203470-49dkcz0","updated":"20220618203470"},"Children":[{"Type":"NodeText","Data":"none：不配置网络","Properties":{"id":""}}]},{"ID":"20220618203471-31ydg7s","Type":"NodeParagraph","Properties":{"id":"20220618203471-31ydg7s","updated":"20220618203471"},"Children":[{"Type":"NodeText","Data":"host：和宿主机共享网络","Properties":{"id":""}}]},{"ID":"20220618203472-2qga57f","Type":"NodeParagraph","Properties":{"id":"20220618203472-2qga57f","updated":"20220618203472"},"Children":[{"Type":"NodeText","Data":"container：容器网络连通（用的少，局限性大）","Properties":{"id":""}}]},{"ID":"20220618203473-9lgrduf","Type":"NodeBlockquote","Properties":{"id":"20220618203473-9lgrduf","updated":"20220618203473"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203474-4b5hxwr","Type":"NodeParagraph","Properties":{"id":"20220618203474-4b5hxwr","updated":"20220618203474"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"测试"}]}]},{"ID":"20220618203475-tdj4o9g","Type":"NodeBlockquote","Properties":{"id":"20220618203475-tdj4o9g","updated":"20220618203475"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203476-2b1y1zk","Type":"NodeParagraph","Properties":{"id":"20220618203476-2b1y1zk","updated":"20220618203476"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/docker0-20220618203734-hm0xx16.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]}]},{"ID":"20220618203477-51iz3hv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203477-51iz3hv","updated":"20220618203477"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 我们直接启动的命令 --net bridge，桥接这是默认的，就是我们的docker0\ndocker run -d -p --name tomcat01 --net bridge tomcat\n\n# 自定义网络\ndocker network create --driver bridge --subnet 192.168.0.0/16 --gateway 192.168.0.1 mynet\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203478-61turs2","Type":"NodeParagraph","Properties":{"id":"20220618203478-61turs2","updated":"20220618203478"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/自定义网络-20220618203734-981i5nq.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203479-pzyk8bz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203479-pzyk8bz","updated":"20220618203479"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 定义两个网络,可以看到mynet分配了两个地址给tomcat-net-01和tomcat-net-02\ndocker run -d -P --name tomcat-net-01 --net mynet tomcat\ndocker run -d -P --name tomcat-net-02 --net mynet tomcat\ndocker network inspect mynet\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203480-zhmw6qq","Type":"NodeParagraph","Properties":{"id":"20220618203480-zhmw6qq","updated":"20220618203480"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/两个网络-20220618203734-xp1py0h.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203481-5r6va96","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203481-5r6va96","updated":"20220618203481"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 再次测试ping连接，ping通了\ndocker exec -it tomcat-net-01 ping 192.168.0.3\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203482-4l4oog9","Type":"NodeParagraph","Properties":{"id":"20220618203482-4l4oog9","updated":"20220618203482"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/ping通了-20220618203734-t3xe1j4.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203483-xnh4of3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203483-xnh4of3","updated":"20220618203483"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 再次ping通\ndocker exec -it tomcat-net-01 ping tomcat-net-02\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203484-fewvm1g","Type":"NodeParagraph","Properties":{"id":"20220618203484-fewvm1g","updated":"20220618203484"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/ping通2-20220618203734-xv9iw0y.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203485-lobecpa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203485-lobecpa","updated":"20220618203485"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"网络连通","Properties":{"id":""}}]},{"ID":"20220618203486-6ib1tm2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockFenceOffset":1,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203486-6ib1tm2","updated":"20220618203486"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":" # 如果网段不同那两个网络之间是ping不通的，docker容器通过下面的语句打通到另一个网络，也就是一个容器分配了两个网段\n docker network connect [options] NETWORK CONTAINER\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203487-fhxgqcn","Type":"NodeParagraph","Properties":{"id":"20220618203487-fhxgqcn","updated":"20220618203487"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/网络连接-20220618203734-35ozw95.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203488-3qtz44m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203488-3qtz44m","updated":"20220618203488"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 测试打通 tomcat01 - mynet\n1.创建tomcat01和tomcat02，这是默认用的docker0网段\ndocker run -d -P --name tomcat01 tomcat\ndocker run -d -P --name tomcat02 tomcat\n\n2.发现并不能打通\n[root@localhost ~]# docker exec -it tomcat01 ping tomcat-net-01\nping: tomcat-net-01: Name or service not known\n\n3.通过connect方式连接mynet\ndocker network connect mynet tomcat01\n\n4.查看mynet地址分配情况\ndocker network inspect mynet\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203489-lu4m5g9","Type":"NodeParagraph","Properties":{"id":"20220618203489-lu4m5g9","updated":"20220618203489"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/tomcat01-20220618203734-0kpqmdz.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203490-2ojyedm","Type":"NodeParagraph","Properties":{"id":"20220618203490-2ojyedm","updated":"20220618203490"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/都可以ping通-20220618203734-czvh0zy.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203491-b12mmss","Type":"NodeParagraph","Properties":{"id":"20220618203491-b12mmss","updated":"20220618203491"},"Children":[{"Type":"NodeText","Data":"结论：假设要跨网络操作别人，就需要使用docker network connect 连通","Properties":{"id":""}}]},{"ID":"20220618203492-qhggi58","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203492-qhggi58","updated":"20220618203492"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"yaml文件参数说明","Properties":{"id":""}}]},{"ID":"20220618203493-9o47oxz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"eWFtbA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203493-9o47oxz","updated":"20220618203493"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":" 1 apiVersion: v1                  #必选，版本号，例如v1，可以用 kubectl api-versions 查询到\n 2 kind: Pod                       #必选，指yaml文件定义的k8s 资源类型或角色，比如：Pod\n 3 metadata:                       #必选，元数据对象\n 4   name: string                  #必选，元数据对象的名字，自己定义，比如命名Pod的名字\n 5   namespace: string             #必选，元数据对象的名称空间，默认为\"default\"\n 6   labels:                       #自定义标签\n 7     key1: value1      　        #自定义标签键值对1\n 8     key2: value2      　        #自定义标签键值对2\n 9   annotations:                  #自定义注解\n10     key1: value1      　        #自定义注解键值对1\n11     key2: value2      　        #自定义注解键值对2\n12 spec:                           #必选，对象【如pod】的详细定义\n13   containers:                   #必选，spec对象的容器信息\n14   - name: string                #必选，容器名称\n15     image: string               #必选，要用到的镜像名称\n16     imagePullPolicy: [Always|Never|IfNotPresent]  #获取镜像的策略；(1)Always：意思是每次都尝试重新拉取镜像；(2)Never：表示仅使用本地镜像，即使本地没有镜像也不拉取；(3) IfNotPresent：如果本地有镜像就使用本地镜像，没有就拉取远程镜像。默认：Always\n17     command: [string]           #指定容器启动命令，由于是数组因此可以指定多个。不指定则使用镜像打包时指定的启动命令。\n18     args: [string]              #指定容器启动命令参数，由于是数组因此可以指定多个\n19     workingDir: string          #指定容器的工作目录\n20     volumeMounts:               #指定容器内部的存储卷配置\n21     - name: string              #指定可以被容器挂载的存储卷的名称。跟下面volume字段的name值相同表示使用这个存储卷\n22       mountPath: string         #指定可以被容器挂载的存储卷的路径，应少于512字符\n23       readOnly: boolean         #设置存储卷路径的读写模式，true或者false，默认为读写模式false\n24     ports:                      #需要暴露的端口号列表\n25     - name: string              #端口的名称\n26       containerPort: int        #容器监听的端口号\n27       #除非绝对必要，否则不要为 Pod 指定 hostPort。 将 Pod 绑定到hostPort时，它会限制 Pod 可以调度的位置数\n28       #DaemonSet 中的 Pod 可以使用 hostPort，从而可以通过节点 IP 访问到 Pod；因为DaemonSet模式下Pod不会被调度到其他节点。\n29       #一般情况下 containerPort与hostPort值相同\n30       hostPort: int     #可以通过宿主机+hostPort的方式访问该Pod。例如：pod在/调度到了k8s-node02【172.16.1.112】，hostPort为8090，那么该Pod可以通过172.16.1.112:8090方式进行访问。\n31       protocol: string          #端口协议，支持TCP和UDP，默认TCP\n32     env:                        #容器运行前需设置的环境变量列表\n33     - name: string              #环境变量名称\n34       value: string             #环境变量的值\n35     resources:                  #资源限制和资源请求的设置（设置容器的资源上线）\n36       limits:                   #容器运行时资源使用的上线\n37         cpu: string             #CPU限制，单位为core数，允许浮点数，如0.1等价于100m，0.5等价于500m；因此如果小于1那么优先选择如100m的形式，精度为1m。这个数字用作 docker run 命令中的 --cpu-quota 参数。\n38         memory: string          #内存限制，单位：E,P,T,G,M,K；或者Ei,Pi,Ti,Gi,Mi,Ki；或者字节数。将用于docker run --memory参数\n39       requests:                 #容器启动和调度时的限制设定\n40         cpu: string             #CPU请求，容器启动时初始化可用数量，单位为core数，允许浮点数，如0.1等价于100m，0.5等价于500m；因此如果小于1那么优先选择如100m的形式，精度为1m。这个数字用作 docker run 命令中的 --cpu-shares 参数。\n41         memory: string          #内存请求,容器启动的初始化可用数量。单位：E,P,T,G,M,K；或者Ei,Pi,Ti,Gi,Mi,Ki；或者字节数\n42     # 参见官网地址：https://kubernetes.io/zh/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/\n43     livenessProbe:      　　    #对Pod内各容器健康检查的设置，当探测无响应几次后将自动重启该容器，检查方法有exec、httpGet和tcpSocket，对一个容器【只需设置其中一种方法即可】\n44       exec:       　　　　　　  #对Pod内容器健康检查方式设置为exec方式\n45         command: [string]       #exec方式需要制定的命令或脚本\n46       httpGet:        　　　　  #对Pod内容器健康检查方法设置为HttpGet，需要制定Path、port\n47         path: string            #访问 HTTP 服务的路径\n48         port: number            #访问容器的端口号或者端口名。如果数字必须在 1 ~ 65535 之间。\n49         host: string            #当没有定义 \"host\" 时，使用 \"PodIP\"\n50         scheme: string          #当没有定义 \"scheme\" 时，使用 \"HTTP\"，scheme 只允许 \"HTTP\" 和 \"HTTPS\"\n51         HttpHeaders:            #请求中自定义的 HTTP 头。HTTP 头字段允许重复。\n52         - name: string\n53           value: string\n54       tcpSocket:      　　　　  #对Pod内容器健康检查方式设置为tcpSocket方式\n55          port: number\n56       initialDelaySeconds: 5    #容器启动完成后，kubelet在执行第一次探测前应该等待 5 秒。默认是 0 秒，最小值是 0。\n57       periodSeconds: 60    　　 #指定 kubelet 每隔 60 秒执行一次存活探测。默认是 10 秒。最小值是 1\n58       timeoutSeconds: 3    　　 #对容器健康检查探测等待响应的超时时间为 3 秒，默认1秒\n59       successThreshold: 1       #检测到有1次成功则认为服务是`就绪`\n60       failureThreshold: 5       #检测到有5次失败则认为服务是`未就绪`。默认值是 3，最小值是 1。\n61     nodeSelector:           　　#定义Node的label过滤标签，以key：value的格式指定。节点选择，先给主机打标签kubectl label nodes kube-node01 key1=value1 \n62       key1: value1\n63     imagePullSecrets:     　　  #Pull镜像时使用的secret名称，以name：secretKeyName格式指定\n64     - name: string\n65     hostNetwork: false      　　#是否使用主机网络模式，默认为false。如果设置为true，表示使用宿主机网络，不使用docker网桥\n66   restartPolicy: [Always|Never|OnFailure] #Pod的重启策略，默认Always。Always表示一旦不管以何种方式终止运行，kubelet都将重启；OnFailure表示只有Pod以非0退出码退出才重启；Nerver表示不再重启该Pod\n67   # volumes 和 containers 是同层级 ******************************\n68   # 参见官网地址：https://kubernetes.io/zh/docs/concepts/storage/volumes/\n69   volumes:        　　　　　　#定义了paues容器关联的宿主机或分布式文件系统存储卷列表 （volumes类型有很多种，选其中一种即可）\n70   - name: string     　　 　　#共享存储卷名称。\n71     emptyDir: {}      　　    #类型为emtyDir的存储卷，与Pod同生命周期的一个临时目录。当Pod因为某些原因被从节点上删除时，emptyDir卷中的数据也会永久删除。\n72     hostPath: string      　　#类型为hostPath的存储卷，表示挂载Pod所在宿主机的文件或目录\n73       path: string      　　  #在宿主机上文件或目录的路径\n74       type: [|DirectoryOrCreate|Directory|FileOrCreate|File] #空字符串（默认）用于向后兼容，这意味着在安装 hostPath 卷之前不会执行任何检查。DirectoryOrCreate：如果给定目录不存在则创建，权限设置为 0755，具有与 Kubelet 相同的组和所有权。Directory：给定目录必须存在。FileOrCreate：如果给定文件不存在，则创建空文件，权限设置为 0644，具有与 Kubelet 相同的组和所有权。File：给定文件必须存在。\n75     secret:       　　　　　  #类型为secret的存储卷，挂载集群预定义的secre对象到容器内部。Secret 是一种包含少量敏感信息例如密码、token 或 key 的对象。放在一个 secret 对象中可以更好地控制它的用途，并降低意外暴露的风险。\n76       secretName: string      #secret 对象的名字\n77       items:                  #可选，修改key 的目标路径\n78       - key: username         #username secret存储在/etc/foo/my-group/my-username 文件中而不是 /etc/foo/username 中。【此时存在spec.containers[].volumeMounts[].mountPath为/etc/foo】\n79         path: my-group/my-username\n80     configMap:      　　　　  #类型为configMap的存储卷，挂载预定义的configMap对象到容器内部。ConfigMap 允许您将配置文件与镜像文件分离，以使容器化的应用程序具有可移植性。\n81       name: string            #提供你想要挂载的 ConfigMap 的名字\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]}]}