"Type":"NodeText","Data":"#这就是匿名挂载，我们在-v只写了容器内的路径，没有写容器外的路径","Properties":{"id":""}}]}]},{"ID":"20220618203385-xij14sj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203385-xij14sj","updated":"20220618203385"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"具名挂载","Properties":{"id":""}}]},{"ID":"20220618203386-13263lu","Type":"NodeBlockquote","Properties":{"id":"20220618203386-13263lu","updated":"20220618203386"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203387-f8k0pfu","Type":"NodeParagraph","Properties":{"id":"20220618203387-f8k0pfu","updated":"20220618203387"},"Children":[{"Type":"NodeText","Data":"docker run -d -P --name nginx02 -v juming-nginx:/etc/nginx nginx","Properties":{"id":""}}]},{"ID":"20220618203388-kah3zhj","Type":"NodeParagraph","Properties":{"id":"20220618203388-kah3zhj","updated":"20220618203388"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/具名挂载-20220618203734-vdigzf9.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203389-z92m4m9","Type":"NodeParagraph","Properties":{"id":"20220618203389-z92m4m9","updated":"20220618203389"},"Children":[{"Type":"NodeText","Data":"#通过 -v 卷名：容器内路径       查看一下这个卷","Properties":{"id":""}}]},{"ID":"20220618203390-jrwl1al","Type":"NodeParagraph","Properties":{"id":"20220618203390-jrwl1al","updated":"20220618203390"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/查看卷-20220618203734-1hxbqn8.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203391-wz2c9ax","Type":"NodeParagraph","Properties":{"id":"20220618203391-wz2c9ax","updated":"20220618203391"},"Children":[{"Type":"NodeText","Data":"所有的docker容器内的卷，没有指定目录的情况下都在/var/lib/docker/volumes/xxxx/_data","Properties":{"id":""}}]},{"ID":"20220618203392-13t6vq2","Type":"NodeParagraph","Properties":{"id":"20220618203392-13t6vq2","updated":"20220618203392"},"Children":[{"Type":"NodeText","Data":"我们通过具名挂载可以方便的找到一个卷，大多数情况使用具名挂载","Properties":{"id":""}}]},{"ID":"20220618203393-lwwj6qm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203393-lwwj6qm","updated":"20220618203393"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#如何确定是具名挂载还是匿名挂载，还是指定路径挂载\n-v 容器内路径     # 匿名挂载\n-v 卷名:容器内路径 # 具名挂载\n-v /宿主机路径::容器内路径 # 指定路径挂载\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]}]},{"ID":"20220618203394-nhpwov4","Type":"NodeParagraph","Properties":{"id":"20220618203394-nhpwov4","updated":"20220618203394"},"Children":[{"Type":"NodeText","Data":"拓展：","Properties":{"id":""}}]},{"ID":"20220618203395-11cgilj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203395-11cgilj","updated":"20220618203395"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 通过-v 容器内路径：ro  rw 改变读写权限\nro  readonly # 只读\nrw  readwrite # 可读可写\n\n# 一旦设置了容器权限，容器对我们挂载出来的内容就有限定了\ndocker run -d -P --name nginx02 -v juming-nginx:/etc/nginx:ro nginx\ndocker run -d -P --name nginx02 -v juming-nginx:/etc/nginx:rw nginx\n\n# 只要看到ro就说明这个路径只能通过宿主机来操作，容器内部是无法操作的！\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203396-qf0qtol","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203396-qf0qtol","updated":"20220618203396"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"初识dockerfile","Properties":{"id":""}}]},{"ID":"20220618203397-zst0q12","Type":"NodeParagraph","Properties":{"id":"20220618203397-zst0q12","updated":"20220618203397"},"Children":[{"Type":"NodeText","Data":"Dockerfile就是用来构建docker镜像的构建文本！命令参数脚本","Properties":{"id":""}}]},{"ID":"20220618203398-87ogd7g","Type":"NodeParagraph","Properties":{"id":"20220618203398-87ogd7g","updated":"20220618203398"},"Children":[{"Type":"NodeText","Data":"通过这个脚本可以生成镜像，镜像是一层一层的，脚本是一个一个的命令，每个命令都是一层","Properties":{"id":""}}]},{"ID":"20220618203399-7zc1005","Type":"NodeBlockquote","Properties":{"id":"20220618203399-7zc1005","updated":"20220618203399"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203400-zlw92pj","Type":"NodeParagraph","Properties":{"id":"20220618203400-zlw92pj","updated":"20220618203400"},"Children":[{"Type":"NodeText","Data":"1.创建一个名为 Dockerfile 的文件夹，然后在该目录下创建一个文件名为 Dockerfile  然后将要写的内容写入","Properties":{"id":""}}]}]},{"ID":"20220618203401-4mk2yzg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203401-4mk2yzg","updated":"20220618203401"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#文件中的内容 指令（都是大写） \nFROM centos\n\nVOLUME [\"volume01\",\"volume02\"]\nCMD echo \"----end----\"\nCMD /bin/bash\n# 这里的每个指令，就是镜像的一层\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203402-cm9u81z","Type":"NodeBlockquote","Properties":{"id":"20220618203402-cm9u81z","updated":"20220618203402"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203403-nc50tft","Type":"NodeParagraph","Properties":{"id":"20220618203403-nc50tft","updated":"20220618203403"},"Children":[{"Type":"NodeText","Data":"2.build刚写的dockerfile文件","Properties":{"id":""}}]},{"ID":"20220618203404-27h6wy3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203404-27h6wy3","updated":"20220618203404"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"docker build -t 要设置的镜像名:版本号 .           #注意后面有一个点，-t的意思是设置版本号\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]}]},{"ID":"20220618203405-fusz1if","Type":"NodeParagraph","Properties":{"id":"20220618203405-fusz1if","updated":"20220618203405"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties