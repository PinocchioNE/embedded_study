"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203183-rlggm63","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203183-rlggm63","updated":"20220618203183"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#如何再进入容器？\ndocker attach 容器id\nor\ndocker exec -it 容器id /bin/bash\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203184-4c6ptf3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203184-4c6ptf3","updated":"20220618203184"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#如何查看容器id\ndocker ps -a\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203185-0u2alfa","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203185-0u2alfa","updated":"20220618203185"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"压力测试","Properties":{"id":""}}]},{"ID":"20220618203186-5q0mgle","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203186-5q0mgle","updated":"20220618203186"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"apt-get install -y stress\n# /usr/bin/stress\nwhich stress\nstress  --help\n# 创建几个进程\nstress --vm 1\n# 每一个进程分配多少内存(默认256M)\nstress --vm-byte 100M\n# debug输出\n--verbose\n\nstress --vm 1 --vm-bytes 100M --verbose\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203187-br64zvl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203187-br64zvl","updated":"20220618203187"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"（重要）如何创建在本地创建一个带有压力测试的镜像并给其分配cpu、内存资源并实时查看","Properties":{"id":""}}]},{"ID":"20220618203188-536lnmb","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203188-536lnmb","updated":"20220618203188"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"1.构建dockerfile文件","Properties":{"id":""}}]},{"ID":"20220618203189-cjlhxkg","Type":"NodeBlockquote","Properties":{"id":"20220618203189-cjlhxkg","updated":"20220618203189"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203190-iytfurh","Type":"NodeParagraph","Properties":{"id":"20220618203190-iytfurh","updated":"20220618203190"},"Children":[{"Type":"NodeText","Data":"（1）创建一个名为 Dockerfile 的文件夹，然后在该目录下创建一个文件名为 Dockerfile  然后将要写的内容写入","Properties":{"id":""}}]}]},{"ID":"20220618203191-o09moct","Type":"NodeParagraph","Properties":{"id":"20220618203191-o09moct","updated":"20220618203191"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/构建dockerfile-20220618203734-dxqusk1.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203192-gl80dti","Type":"NodeBlockquote","Properties":{"id":"20220618203192-gl80dti","updated":"20220618203192"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203193-n77aacy","Type":"NodeParagraph","Properties":{"id":"20220618203193-n77aacy","updated":"20220618203193"},"Children":[{"Type":"NodeText","Data":"（2）运行docker build 构建镜像","Properties":{"id":""}}]},{"ID":"20220618203194-httf21c","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203194-httf21c","updated":"20220618203194"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"docker build -t 要设置的镜像名:版本号 .           #注意后面有一个 .空格+点，-t的意思是设置版本号\n\n这里输入的是\ndocker build -t ubuntuteststress:1.0 .\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]}]},{"ID":"20220618203195-w7g2fuj","Type":"NodeParagraph","Properties":{"id":"20220618203195-w7g2fuj","updated":"20220618203195"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/build-20220618203734-9tki6mj.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203196-jsrcjux","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203196-jsrcjux","updated":"20220618203196"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.运行镜像文件并分配资源","Properties":{"id":""}}]},{"ID":"20220618203197-899d7tk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203197-899d7tk","updated":"20220618203197"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 所有参数含义 -it 进入容器内部； -m 设置内存大小限制为 xx兆； --cpuset-cpus 0 制定该容器只能在cpu0上跑，如果想查看有哪几个cpu可以输入top然后按1查看\n# -c 512 代表给定容器cpu的加权值为512，这个值直接看是看不出的，只有当两台都限制cpu的容器运行时进行查看，可以看出差别，这一点将在下面写\n#  ubuntuteststress:1.0是要使用的镜像以及镜像版本  /bin/bash照抄就可以；一般的镜像如果是最新版本只需要输入镜像名，但我们设定了版本为1.0，所以后面要跟\n# --name 设置容器名称（随便）\n####################################\n#这里给了两个容器以便对cpu进行比较\ndocker run -it --name cputest1 -m 200m --cpuset-cpus 0 -c 1024 ubuntuteststress:1.0 /bin/bash\ndocker run -it --name cputest2 -m 100m --cpuset-cpus 1 -c 512 ubuntuteststress:1.0 /bin/bash\n# 这里设定了两个cpu加权值 等会将压力值打满就能看到在cpu0上两个容器占用的cpu大小\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203198-yylnngg","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203198-yylnngg","updated":"20220618203198"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.实时查看","Properties":{"id":""}}]},{"ID":"20220618203199-atbu0m3","Type":"NodeBlockquote","Properties":{"id":"20220618203199-atbu0m3","updated":"20220618203199"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203200-mm6apco","Type":"NodeParagraph","Properties":{"id":"20220618203200-mm6apco","updated":"20220618203200"},"Children":[{"Type":"NodeText","Data":"进入容器并加压","Properties":{"id":""}}]},{"ID":"20220618203201-idrer5b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203201-idrer5b","updated":"20220618203201"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 1.查看所有容器\ndocker ps -a\n# 2.找到对应的容器id\n# 3.启动容器\ndocker start 容器id\n# 4.进入容器\ndocker exec -it 容器id /bin/bash\n# 5.加压  表示测试一个cpu负载\nstress -c 1\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]}]},{"ID":"20220618203202-lu4p3fb","Type":"NodeParagraph","Properties":{"id":"20220618203202-lu4p3fb","updated":"20220618203202"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/压力1-20220618203734-mu6tr8l.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203203-hn9ybgd","Type":"NodeParagraph","Properties":{"id":"20220618203203-hn9ybgd","updated":"20220618203203"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","