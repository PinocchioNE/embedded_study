{"ID":"20220618203155-lac1ada","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220618203155-lac1ada","title":"docker学习过程笔记","type":"doc","updated":"20220618203317"},"Children":[{"ID":"20220618203156-llxbk7n","Type":"NodeParagraph","Properties":{"id":"20220618203156-llxbk7n","updated":"20220618203156"},"Children":[{"Type":"NodeText","Data":"docker的学习过程","Properties":{"id":""}}]},{"ID":"20220618203157-efhy1sz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203157-efhy1sz","updated":"20220618203157"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"遇到的问题","Properties":{"id":""}}]},{"ID":"20220618203158-bpdnb3w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203158-bpdnb3w","updated":"20220618203158"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何给容器分配cpu、内存、swap","Properties":{"id":""}}]},{"ID":"20220618203159-yazy7gc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203159-yazy7gc","updated":"20220618203159"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"容器CPU设置","Properties":{"id":""}}]},{"ID":"20220618203160-yc9p2ez","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203160-yc9p2ez","updated":"20220618203160"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 所有参数含义 -it 进入容器内部； -m 设置内存大小限制为 xx兆； --cpuset-cpus 0 制定该容器只能在cpu0上跑，如果想查看有哪几个cpu可以输入top然后按1查看\n# -c 512 代表给定容器cpu的加权值为512，这个值直接看是看不出的，只有当两台都限制cpu的容器运行时进行查看，可以看出差别，这一点将在下面写\n#  ubuntuteststress:1.0是要使用的镜像以及镜像版本  /bin/bash照抄就可以\ndocker run -it --name cputest2 -m 100m --cpuset-cpus 0 -c 512 ubuntuteststress:1.0 /bin/bash\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203161-7p7fxte","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203161-7p7fxte","updated":"20220618203161"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"容器内存限额","Properties":{"id":""}}]},{"ID":"20220618203162-qqw16n7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203162-qqw16n7","updated":"20220618203162"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 允许该容器最多使用200MB的内存和100MB 的swap。\ndocker run -it -m 200M --memory-swap=300M ubuntu\n\n# 容器最多使用200M的内存和200M的Swap\ndocker run -it -m 200M ubuntu\n\n# 然后退出容器输入指令查看内存限制情况\ndocker stats\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203163-gvmrqqx","Type":"NodeParagraph","Properties":{"id":"20220618203163-gvmrqqx","updated":"20220618203163"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/limit-20220618203734-1dv5fhm.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618203164-bz2wbjg","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618203164-bz2wbjg","updated":"20220618203164"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何查看CPU、内存、磁盘使用情况","Properties":{"id":""}}]},{"ID":"20220618203165-4ym8lbl","Type":"NodeParagraph","Properties":{"id":"20220618203165-4ym8lbl","updated":"20220618203165"},"Children":[{"Type":"NodeText","Data":"1、先进入docker容器里","Properties":{"id":""}}]},{"ID":"20220618203166-914c44u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cG93ZXJzaGVsbA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203166-914c44u","updated":"20220618203166"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"docker exec -it b6bac438271d /bin/bash\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203167-k7m6c28","Type":"NodeParagraph","Properties":{"id":"20220618203167-k7m6c28","updated":"20220618203167"},"Children":[{"Type":"NodeText","Data":"2、查看磁盘","Properties":{"id":""}}]},{"ID":"20220618203168-ff4a4mz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618203168-ff4a4mz","updated":"20220618204118"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"ZG9ja2VyZmlsZQ=="},{"Type":"NodeCodeBlockCode","Data":"free -m\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618203169-b36jf00","Type":"NodeParagraph","Properties":{"id":"20220618203169-b36jf00","updated":"20220618203169"},"Children":[{"Type":"NodeText","Data":"3、查看cpu","Properties":{"id":""}}]},{"ID":"20220618203170-nfrll30","Type":"NodeBlockquote","Properties":{"id":"20220618203170-nfrll30","updated":"20220618203170"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203171-3hqp7vc","Type":"NodeParagraph","Properties":{"id":"20220618203171-3hqp7vc","updated":"20220618203171"},"Children":[{"Type":"NodeText","Data":"物理cpu：主板上实际插入的cpu数量，可以数不重复的 physical id 有几个（physical id）","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"cpu核数：单块CPU上面能处理数据的芯片组的数量","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"逻辑cpu：一般情况下，逻辑cpu=物理CPU个数×每颗核数","Properties":{"id":""}}]}]},{"ID":"20220618203172-541a2gn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203172-541a2gn","updated":"20220618203172"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"1.物理cpu数：grep 'physical id' /proc/cpuinfo|sort|uniq|wc -l\n\n2.cpu核数：grep 'cpu cores' /proc/cpuinfo|uniq|awk -F ':' '{print $2}'\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618203173-rcsfl0c","Type":"NodeParagraph","Properties":{"id":"20220618203173-rcsfl0c","updated":"20220618204230"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"注：top命令输入后，出现如下界面，再按1!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!，可以看逻辑cpu，及每个核的cpu使用情况。"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"内存.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/内存-20220618204230-w1aa5q4.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618203175-gshfg4k","Type":"NodeParagraph","Properties":{"id":"20220618203175-gshfg4k","updated":"20220618203175"},"Children":[{"Type":"NodeText","Data":"4、查看每个容器的内存、cpu消耗情况：","Properties":{"id":""}}]},{"ID":"20220618203176-0c8mwpv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618203176-0c8mwpv","updated":"20220618203176"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"#宿主机上输入命令\ndocker stats #这是实时查看cpu、内存消耗情况\ndocker stats --no-stream #查看瞬间的cpu、内存消耗情况\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618204333-yn2h662","Type":"NodeParagraph","Properties":{"id":"20220618204333-yn2h662","updated":"20220618204339"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"容器内存.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/容器内存-20220618204339-n42jx0g.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618203178-fj9oncu","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618203178-fj9oncu","updated":"20220618203178"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何创建一个系统镜像并进入","Properties":{"id":""}}]},{"ID":"20220618203179-k8aamr0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618203179-k8aamr0","updated":"20220618203179"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#启动docker\nsystemctl docker start\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","Co