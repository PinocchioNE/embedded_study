},{"ID":"20220618203364-34vzrat","Type":"NodeParagraph","Properties":{"id":"20220618203364-34vzrat","updated":"20220618203364"},"Children":[{"Type":"NodeText","Data":"docker是将应用和环境打包成一个镜像，数据都在容器内，如果删除容器数据就会丢失！\u003cfont color=#FF0000 \u003e需求：数据可以持久化\u003c/font\u003e","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"MYSQL，容器删了，删库跑路！\u003cfont color=#FF0000 \u003e需求：MYSQL数据可以存储在本地\u003c/font\u003e","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"卷技术就是将容器之间的数据进行共享，就是目录的挂载，将我们容器内的目录挂载到Linux！","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/卷技术-20220618203734-toqk4wk.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"目标："},{"Type":"NodeText","Data":"容器的持久化和同步操作，容器间数据可以共享！","Properties":{"id":""}}]},{"ID":"20220618203365-ohdo6cn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203365-ohdo6cn","updated":"20220618203365"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"使用数据卷","Properties":{"id":""}}]},{"ID":"20220618203366-qhshftg","Type":"NodeBlockquote","Properties":{"id":"20220618203366-qhshftg","updated":"20220618203366"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203367-mv4syfc","Type":"NodeParagraph","Properties":{"id":"20220618203367-mv4syfc","updated":"20220618203367"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"方法一："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"docker run -it -v 主机目录:内容目录 (好比-p就是映射端口，-v就是目录映射)","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"[root@localhost home]# docker run -it -v /home/ceshi:/home centos /bin/bash","Properties":{"id":""}}]}]},{"ID":"20220618203368-0vqtvc3","Type":"NodeBlockquote","Properties":{"id":"20220618203368-0vqtvc3","updated":"20220618203368"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203369-vwb3no8","Type":"NodeParagraph","Properties":{"id":"20220618203369-vwb3no8","updated":"20220618203369"},"Children":[{"Type":"NodeText","Data":"启动起来后可以通过","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"docker inspect 容器id","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/挂载-20220618203734-m5u552a.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/挂载效果-20220618203734-icy2lk3.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]}]},{"ID":"20220618203370-6uxau8h","Type":"NodeParagraph","Properties":{"id":"20220618203370-6uxau8h","updated":"20220618203370"},"Children":[{"Type":"NodeText","Data":"再进行测试！","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"1、停止容器","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"2、在宿主机上进行修改","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"3、启动容器","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"4、容器内的数据依旧是同步的","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"（就是说不管在挂载的容器内修改还是在宿主机中进行修改都是同步的）","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"这就解决了之前遇到的问题，每次修改配置文件都要进入容器很麻烦，现在只需挂载后在主机上修改就可以改动容器内的文件","Properties":{"id":""}}]},{"ID":"20220618203371-x48zk08","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203371-x48zk08","updated":"20220618203371"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"实战：安装MySQL","Properties":{"id":""}}]},{"ID":"20220618203372-2s8p7qr","Type":"NodeParagraph","Properties":{"id":"20220618203372-2s8p7qr","updated":"20220618203372"},"Children":[{"Type":"NodeText","Data":"思考：MySQL的数据持久化的问题","Properties":{"id":""}}]},{"ID":"20220618203373-niujqqc","Type":"NodeBlockquote","Properties":{"id":"20220618203373-niujqqc","updated":"20220618203373"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618203374-qbnyrnk","Type":"NodeParagraph","Properties":{"id":"20220618203374-qbnyrnk","updated":"20220618203374"},"Children":[{"Type":"NodeText","Data":"获取镜像：docker pull mysql：tag  （tag为版本号）","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"运行容器，需要做数据挂载。安装mysql，注意需要配置密码的！","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"官方测试：$ docker run --name some-mysql -e MYSQL_ROOT_PASSWORD=my-secret-pw -d mysql:tag","Properties":{"id":""}}]}]},{"ID":"20220618203375-7mndtdh","Type":"NodeParagraph","Properties":{"id":"20220618203375-7mndtdh","updated":"20220618203375"},"Children":[{"Type":"NodeText","Data":"开始进行测试！","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"-d 后台运行","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"-p 端口映射","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"-v 卷挂载","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"-e 环境配置","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"--name 容器名字","Properties":{"id":""}},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"docker run -d -p 3310:3306 -v /home/mysql/conf:/etc/mysql/conf.d -v /home/mysql/data:/var/lib/mysql -e MYSQL_ROOT_PASSWORD=123456 --name mysql01 mysql:5.7"},{"Type":"NodeHardBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"通过sqlyog连接端口3310，成功连接上数据库，在本地创建一个新的数据库，linux中也会生成一个数据库","Properties":{"id":""}}]},{"ID":"20220618203376-1ut1b1b","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618203376-1ut1b1b","updated":"20220618203376"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"具名和匿名挂载"}]},{"ID":"20220618203377-8d0dcp4","Type":"NodeHeading","HeadingLevel":3,"Properties":{