perties":{"id":""}}]},{"ID":"20220618202780-8j6630p","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202780-8j6630p","updated":"20220618202780"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 在主节点执行\nkubectl drain 节点名称 --delete-local-data --force --ignore-daemonsets\nkubectl delete node 节点名称\n# 查看是否删除\nkubectl get nodes\n# 然后在删除的边缘节点进行下面的卸载kubeedge操作\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202781-lcxw5ya","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202781-lcxw5ya","updated":"20220618202781"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"卸载kubeedge","Properties":{"id":""}}]},{"ID":"20220618202782-y2seuhw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202782-y2seuhw","updated":"20220618202782"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#0 进入keadm存在的文件夹\n./keadm reset --force\n\n#1 rm -rf /etc/kubeedge\nwhereis kubeedge   然后输入 rm -rf kubedge目录\n\n#2 master端\nwhereis cloudcore 然后输入 rm -rf cloudcore目录\n\n#3 edge端\nwhereis edgecore  然后输入 rm -rf edgecore目录\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202