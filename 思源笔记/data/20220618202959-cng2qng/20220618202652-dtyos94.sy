{"ID":"20220618202652-dtyos94","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220618202652-dtyos94","title":"Linux问题与Kubeedge搭建","type":"doc","updated":"20220618202712"},"Children":[{"ID":"20220618202653-rqdg6oo","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618202653-rqdg6oo","updated":"20220618202653"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"kubeedge(keadm搭建)","Properties":{"id":""}}]},{"ID":"20220618202654-v1kf74z","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202654-v1kf74z","updated":"20220618202654"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"准备工作","Properties":{"id":""}}]},{"ID":"20220618202655-63tqr0b","Type":"NodeBlockquote","Properties":{"id":"20220618202655-63tqr0b","updated":"20220618202655"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618202656-2yyyxul","Type":"NodeParagraph","Properties":{"id":"20220618202656-2yyyxul","updated":"20220618202656"},"Children":[{"Type":"NodeText","Data":"1.虚拟机两台，一台作为master，另一台作为edgenode","Properties":{"id":""}}]}]},{"ID":"20220618202657-t65504s","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202657-t65504s","updated":"20220618202657"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"换源","Properties":{"id":""}}]},{"ID":"20220618202658-g606raj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202658-g606raj","updated":"20220618202658"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.备份源列表\nsudo cp /etc/apt/sources.list /etc/apt/sources.list.bak\n\n#2.修改源文件 (vim安装sudo apt-get install vim  可能会遇到锁问题，解决办法如下)   \nsudo vim /etc/apt/sources.list\n\n#3.添加源（按a添加，加好后esc，shift+冒号，wq！保存）\ndeb http://mirrors.aliyun.com/ubuntu/ focal main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-security main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-security main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-updates main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-updates main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-proposed main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-proposed main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-backports main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-backports main restricted universe multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-backports main restricted universe multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security multiverse\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202659-u78o9qk","Type":"NodeParagraph","Properties":{"id":"20220618202659-u78o9qk","updated":"20220618202659"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"amd设备源（20.04）"}]},{"ID":"20220618202660-ixxbddb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202660-ixxbddb","updated":"20220618202660"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"## extensively as that contained in the main release, although it includes\n## newer versions of some applications which may provide useful features.\n## Also, please note that software in backports WILL NOT receive any review\n## or updates from the Ubuntu security team.\ndeb http://cn.archive.ubuntu.com/ubuntu/ focal-backports main restricted universe multiverse\n# deb-src http://cn.archive.ubuntu.com/ubuntu/ focal-backports main restricted universe multiverse\n\n## Uncomment the following two lines to add software from Canonical's\n## 'partner' repository.\n## This software is not part of Ubuntu, but is offered by Canonical and the\n## respective vendors as a service to Ubuntu users.\n# deb http://archive.canonical.com/ubuntu focal partner\n# deb-src http://archive.canonical.com/ubuntu focal partner\n\ndeb http://security.ubuntu.com/ubuntu focal-security main restricted\n# deb-src http://security.ubuntu.com/ubuntu focal-security main restricted\ndeb http://security.ubuntu.com/ubuntu focal-security universe\n# deb-src http://security.ubuntu.com/ubuntu focal-security universe\ndeb http://security.ubuntu.com/ubuntu focal-security multiverse\n# deb-src http://security.ubuntu.com/ubuntu focal-security multiverse\n\n# This system was installed using small removable media\n# (e.g. netinst, live or single CD). The matching \"deb cdrom\"\n# entries were disabled at the end of the installation process.\n# For information about how to configure apt package sources,\n# see the sources.list(5) manual.\ndeb http://mirrors.aliyun.com/ubuntu/ focal main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-security main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-security main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-updates main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-updates main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-proposed main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-proposed main restricted universe multiverse\n\ndeb http://mirrors.aliyun.com/ubuntu/ focal-backports main restricted universe multiverse\ndeb-src http://mirrors.aliyun.com/ubuntu/ focal-backports main restricted universe multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-updates multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-backports main restricted universe multiverse\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security main restricted\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security universe\ndeb http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ focal-security multiverse\ndeb [arch=amd64] https://mirrors.aliyun.com/docker-ce/linux/ubuntu focal stable\n# deb-src [arch=amd64] https://mirrors.aliyun.com/docker-ce/linux/ubuntu focal stable\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202661-8p3dg6h","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202661-8p3dg6h","updated":"20220618202661"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"中科大源","Properties":{"id":""}}]},{"ID":"20220618202662-xnah7k3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202662-xnah7k3","updated":"20220618202662"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"deb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates main restricted \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic universe \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates universe \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic multiverse \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates multiverse \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-backports main restricted universe multiverse \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security main restricted \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security universe \ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security multiverse \n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202663-o0jpv39","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202663-o0jpv39","updated":"20220618202663"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"tx2换源（jetson系列应该都可以用）","