Fence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202761-fr70d27","updated":"20220618202761"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#4.查看该命名空间中的pod名字\nkubectl get deployment -n 命名空间\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202762-q1v976v","Type":"NodeParagraph","Properties":{"id":"20220618202762-q1v976v","updated":"20220618202762"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/pod5-20220618202939-fjrh1qg.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202763-f4jwaj9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202763-f4jwaj9","updated":"20220618202763"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#5.删除depeloyment过的error pod\nkubectl delete deployment 要删除的pod的name -n 命名空间\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202764-dgftxhq","Type":"NodeParagraph","Properties":{"id":"20220618202764-dgftxhq","updated":"20220618202764"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/pod4-20220618202939-nr97c6h.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202765-gczld1z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202765-gczld1z","updated":"20220618202765"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#6.查看kubectl get pods -o wide如果还在就kubectl delete pod podname -n 命名空间\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202766-kgu8kmr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202766-kgu8kmr","updated":"20220618202766"},"Children":[{"Type":"NodeText","Data":"一些常见问题和指令"}]},{"ID":"20220618202768-84fiznd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202768-84fiznd","updated":"20220618202768"},"Children":[{"Type":"NodeText","Data":"近100条edgecore的日志查询"}]},{"ID":"20220618202769-ujk69xm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"eHNoZWxs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202769-ujk69xm","updated":"20220618202769"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eHNoZWxs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"journalctl -u edgecore.service -r\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202770-739v29y","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202770-739v29y","updated":"20220618202770"},"Children":[{"Type":"NodeText","Data":"查看各类进程状态"}]},{"ID":"20220618202771-g2hut7e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202771-g2hut7e","updated":"20220618202771"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"ps aux|grep mosquitto\n\n#查看kubelet日志\njournalctl -xeu kubelet\njournalctl -f -u kubelet\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202772-sk04sh6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202772-sk04sh6","updated":"20220618202772"},"Children":[{"Type":"NodeText","Data":"查看详细pod状态"}]},{"ID":"20220618202773-8kwqe96","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202773-8kwqe96","updated":"20220618202773"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.查看pod \nkubectl get pods -o wide\n\n\nroot@master:/src/github.com/kubeedge/examples/kubeedge-counter-demo/crds# kubectl get pods -o wide\nNAME                                    READY   STATUS    RESTARTS   AGE     IP               NODE      NOMINATED NODE   READINESS GATES\nkubeedge-counter-app-6984dcb4dd-qxqnn   1/1     Running   1          5h47m   192.168.137.89   master    \u003cnone\u003e           \u003cnone\u003e\nkubeedge-pi-counter-784d57c5d4-r6kf7    0/1     Error     2          6m32s   192.168.137.78   xthnano   \u003cnone\u003e           \u003cnone\u003e\n\n\n#2.详细查看pod\nkubectl describe pod 容器name --namespace=name空间\n\nkubectl describe pod kubeedge-pi-counter-784d57c5d4-r6kf7 --namespace=default\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202774-4u6bcbx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202774-4u6bcbx","updated":"20220618202774"},"Children":[{"Type":"NodeText","Data":"查看开放的端口"}]},{"ID":"20220618202775-oqfh3fn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202775-oqfh3fn","updated":"20220618202775"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.查看某个端口情况\nlsof -i:端口号\n#2.查看所有端口情况\nnetstat -aptn\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220726135420-vw5g6iu","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220726135420-vw5g6iu","updated":"20220726135431"},"Children":[{"Type":"NodeText","Data":"查找进程"}]},{"ID":"20220726135446-oz6g53z","Type":"NodeBlockquote","Properties":{"id":"20220726135446-oz6g53z","updated":"20220726135506"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID