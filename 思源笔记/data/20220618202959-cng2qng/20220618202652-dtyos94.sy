ckFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"kubectl desribe pod pod的name\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220620203613-u66b0yt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220620203613-u66b0yt","updated":"20220620203629"},"Children":[{"Type":"NodeText","Data":"磁盘满了导致docker无法启动如何处理"}]},{"ID":"20220620203631-u92hwl3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220620203631-u92hwl3","updated":"20220726121859"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"#1.首先查看磁盘状态\ndf -h\n#2.查看占用严重的磁盘 一般是100%使用的盘\n#3.移动到根目录 cd /\n#4.查看所有文件夹的大小，找出大文件\ndu -sh *\n#5.如果snap、var、usr过大有以下处理方法\n#6.先进入/var/log\ndu -sh *\n#7.找到journal 是否占用较大，进入journal进行删除\njournalctl --vacuum-size=10M\n#8.df -sh 查看当前磁盘状态，应该空余了一点\n#9.删除snap\nsudo apt autoremove --purge snapd\n如果报错就执行它提示的解决方法，然后再输上面的指令\n#10.df -h 查看状态，应该空了很多\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727122701-88e3r7c","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220727122701-88e3r7c","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"jetson nano刷机"}]},{"ID":"20220727122701-bwrvckx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727122701-bwrvckx","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"遇到的问题"}]},{"ID":"20220727122701-ml24mmx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-ml24mmx","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"和别的设备ping不通"}]},{"ID":"20220727122701-npsz3hj","Type":"NodeBlockquote","Properties":{"id":"20220727122701-npsz3hj","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-wpznsmd","Type":"NodeParagraph","Properties":{"id":"20220727122701-wpznsmd","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"可能电脑防火墙没关"}]}]},{"ID":"20220727122701-raoeara","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-raoeara","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"供电问题"}]},{"ID":"20220727122701-ncbp2wf","Type":"NodeBlockquote","Properties":{"id":"20220727122701-ncbp2wf","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-4gi43fz","Type":"NodeParagraph","Properties":{"id":"20220727122701-4gi43fz","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"1.充电器供电：要在j48插跳线帽"}]},{"ID":"20220727122701-80fznmv","Type":"NodeParagraph","Properties":{"id":"20220727122701-80fznmv","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"2.usb供电：拔掉跳线帽"}]}]},{"ID":"20220727122701-l64mfpz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-l64mfpz","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"出现a start job is running for end-user问题"}]},{"ID":"20220727122701-ffnqqc6","Type":"NodeBlockquote","Properties":{"id":"20220727122701-ffnqqc6","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-xtvz3t6","Type":"NodeParagraph","Properties":{"id":"20220727122701-xtvz3t6","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"如果是连的usb供电，就把摄像头csi拔了"}]}]},{"ID":"20220727122701-exykv7r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-exykv7r","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"出现连上wifi但是没网的情况"}]},{"ID":"20220727122701-x2t0b3i","Type":"NodeBlockquote","Properties":{"id":"20220727122701-x2t0b3i","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-s1nomq5","Type":"NodeParagraph","Properties":{"id":"20220727122701-s1nomq5","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"此时ping 一下百度，如果出现ping: www.baidu.com: Name or service not known"}]},{"ID":"20220727122701-wsc3igw","Type":"NodeParagraph","Properties":{"id":"20220727122701-wsc3igw","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"说明DNS没有设置"}]}]},{"ID":"20220727122701-r3v9hjd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727122701-r3v9hjd","updated":"20220727122701"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw="},{"Type":"NodeCodeBlockCode","Data":"vim /etc/resolv.conf\n# 添加以下内容即可\nnameserver 8.8.8.8\nnameserver 114.114.114.114\n\n# 以上方法只能解决一时的问题，用下面的方法可以一劳永逸，往里添加dns\nsudo vim /etc/resolvconf/resolv.conf.d/tail\n\n#添加\nnameserver 8.8.8.8\nnameserver 114.114.114.114\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727122701-ufn0faa","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-ufn0faa","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"如果发现没有resolvconf怎么办？"}]},{"ID":"20220727122701-27aunmb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727122701-27aunmb","updated":"20220727122701"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw="},{"Type":"NodeCodeBlockCode","Data":"sudo apt install resolvconf\n# 再执行上面的操作就可以，即\n#添加dns\nsudo vim /etc/resolvconf/resolv.conf.d/tail\n\n##添加\nnameserver 8.8.8.8\nnameserver 114.114.114.114\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727122701-8a1hayd","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-8a1hayd","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"主机和开发板在同一网段但是ping不通怎么办"}]},{"ID":"20220727122701-vjtp8u4","Type":"NodeBlockquote","Properties":{"id":"20220727122701-vjtp8u4","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-awsn83j","Type":"NodeParagraph","Properties":{"id":"20220727122701-awsn83j","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"先换一个热点看看开发板是否能和要连的主机ping通，如果可以说明是wifi的问题，重启发出热点的设备即可"}]}]},{"ID":"20220727122701-ao4lqu4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727122701-ao4lqu4","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"主机、虚拟机、开发板ping通"}]},{"ID":"20220727122701-gb7pciu","Type":"NodeBlockquote","Properties":{"id":"20220727122701-gb7pciu","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-a1e09ic","Type":"NodeParagraph","Properties":{"id":"20220727122701-a1e09ic","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"首先搞明白为什么要在同一网段内：因为想要ping通必须是同一个网络下（同一个wifi或者路由器插网线）"}]},{"ID":"20220727122701-xrew3ho","Type":"NodeParagraph","Properties":{"id":"20220727122701-xrew3ho","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"由于主机是虚拟机，所以需要进行桥接，将其看作是一个真的物理机，让其和主机共用一个网段"}]}]},{"ID":"20220727122701-xs75l9w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-xs75l9w","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"怎么操作？"}]},{"ID":"20220727122701-oh33vde","Type":"NodeParagraph","Properties":{"id":"20220727122701-oh33vde","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"以wifi模式为例"}]},{"ID":"20220727122701-ajslaax","Type":"NodeBlockquote","Properties":{"id":"20220727122701-ajslaax","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-iypmbj4","Type":"NodeParagraph","Properties":{"id":"20220727122701-iypmbj4","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"找一个wifi源"}]},{"ID":"20220727122701-r2cr92i","Type":"NodeParagraph","Properties":{"id":"20220727122701-r2cr92i","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"板子连上wifi 主机连上wifi"}]}]},{"ID":"20220727122701-xuywob1","Type":"NodeBlockquote","Properties":{"id":"20220727122701-xuywob1","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-radf5lz","Type":"NodeParagraph","Properties":{"id":"20220727122701-radf5lz","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"虚拟机进行桥接"}]},{"ID":"20220727122701-0ujsvrc","Type":"NodeParagraph","Properties":{"id":"20220727122701-0ujsvrc","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"管理员模式打开虚拟机"}]}]},{"ID":"20220727122701-8v22kch","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220727122701-8v22kch","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"1."}]},{"ID":"20220727122701-f9zgset","Type":"NodeParagraph","Properties":{"id":"20220727122701-f9zgset","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/桥-20220618221210-i80a5b1.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-p8hhmsn","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220727122701-p8hhmsn","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"2.桥接模式网卡选择，不能选自动，电脑用什么连的网就用哪个网卡"}]},{"ID":"20220727122701-xisbzli","Type":"NodeParagraph","Properties":{"id":"20220727122701-xisbzli","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/桥2-20220618221210-vyuyemd.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-l3o2k6k","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220727122701-l3o2k6k","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"3.在虚拟机的网络连接方式中选择桥接模式，下面的复制物理网络不用选"}]},{"ID":"20220727122701-c9viqnf","Type":"NodeParagraph","Properties":{"id":"20220727122701-c9viqnf","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/桥3-20220618221210-7kac5ri.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-uwil5hn","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220727122701-uwil5hn","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"改完桥接模式重新开机发现网络连不上怎么办？"}]},{"ID":"20220727122701-yvynffe","Type":"NodeParagraph","Properties":{"id":"20220727122701-yvynffe","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"案例：连接wifi的桥接模式下，虚拟机连不上网，出现网络连接激活失败。"}]},{"ID":"20220727122701-9cpq0zu","Type":"NodeParagraph","Properties":{"id":"20220727122701-9cpq0zu","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"1.控制面板-网络和internet-网络和共享中心 -更改适配器设置(左边)"}]},{"ID":"20220727122701-spp6dkr","Type":"NodeParagraph","Properties":{"id":"20220727122701-spp6dkr","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"2.查看wifi的ip段以及网关"}]},{"ID":"20220727122701-xmcg9j4","Type":"NodeParagraph","Properties":{"id":"20220727122701-xmcg9j4","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"1.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/1-20220618221246-persmey.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-ygqgo46","Type":"NodeParagraph","Properties":{"id":"20220727122701-ygqgo46","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"2.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/2-20220618221309-xeesrvg.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-2bv8cvf","Type":"NodeParagraph","Properties":{"id":"20220727122701-2bv8cvf","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"3.在ubutu中选择网络设置，在ipv4处选择手动添加ip以及网关，注意dns也最好写上，一般就是图中的8和114"}]},{"ID":"20220727122701-22j5e58","Type":"NodeParagraph","Properties":{"id":"20220727122701-22j5e58","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"3.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/3-20220618221331-doapdgt.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220727122701-qxu3527","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727122701-qxu3527","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"换源"}]},{"ID":"20220727122701-2cngfci","Type":"NodeBlockquote","Properties":{"id":"20220727122701-2cngfci","updated":"20220727122701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727122701-qriqowr","Type":"NodeParagraph","Properties":{"id":"20220727122701-qriqowr","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"镜像对应ubuntu版本18.04"}]}]},{"ID":"20220727122701-7oa4zlt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727122701-7oa4zlt","updated":"20220727122701"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw="},{"Type":"NodeCodeBlockCode","Data":"#1.备份源列表\nsudo cp /etc/apt/sources.list /etc/apt/sources.list.bak\n\n# 2.注释所有镜像，添加下方镜像\nsudo vim /etc/apt/sources.list\n# 中科大源\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates main restricted\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic universe\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates universe\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic multiverse\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-updates multiverse\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-backports main restricted universe multiverse\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security main restricted\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security universe\ndeb http://mirrors.ustc.edu.cn/ubuntu-ports/ bionic-security multiverse\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727122701-ynjnk3q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727122701-ynjnk3q","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"开风扇"}]},{"ID":"20220727122701-xh9dqed","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727122701-xh9dqed","updated":"20220727122701"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw="},{"Type":"NodeCodeBlockCode","Data":"#1.开风扇 最好设置100左右不然风很大\nsudo sh -c 'echo 100 \u003e /sys/devices/pwm-fan/target_pwm'\n#2.关闭风扇\nsudo sh -c ‘echo 0 \u003e /sys/devices/pwm-fan/target_pwm’\n#3.开机自启动\nsudo vim /etc/rc.local\n输入以下内容\n\n#!/bin/bash\nsleep 10\nsudo /usr/bin/jetson_clocks\nsudo sh -c 'echo 100 \u003e /sys/devices/pwm-fan/target_pwm'\n\n#4.添加权限\nsudo chmod 755 /etc/rc.local\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727122701-farvpmb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727122701-farvpmb","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"结果"}]},{"ID":"20220727122701-re4pfqy","Type":"NodeParagraph","Properties":{"id":"20220727122701-re4pfqy","updated":"20220727122701"},"Children":[{"Type":"NodeText","Data":"1.设备"}]},{"ID":"20220727122701-23ifgrr","Type":"NodeParagraph","Properties":{"id":"20220727122701-23ifgrr","updated":"20220727122701"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Da