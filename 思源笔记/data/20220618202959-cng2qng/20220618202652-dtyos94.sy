680-6imxjc0","Type":"NodeParagraph","Properties":{"id":"20220618202680-6imxjc0","updated":"20220618202680"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/树莓派1-20220618202939-gptkxm1.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202681-7pvbzqy","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618202681-7pvbzqy","updated":"20220618202681"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"换源20.04版本","Properties":{"id":""}}]},{"ID":"20220618202682-28ovhjv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202682-28ovhjv","updated":"20220618202682"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.备份源列表\nsudo cp /etc/apt/sources.list /etc/apt/sources.list.bak\n\n#2.修改源文件 (vim安装sudo apt-get install vim  可能会遇到锁问题，解决办法如下)   \nsudo vim /etc/apt/sources.list\n\n# 默认注释了源码仓库，如有需要可自行取消注释\ndeb https://mirrors.ustc.edu.cn/ubuntu-ports/ focal main restricted universe multiverse\n# deb-src https://mirrors.ustc.edu.cn/ubuntu-ports/ focal main main restricted universe multiverse\ndeb https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-updates main restricted universe multiverse\n# deb-src https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-updates main restricted universe multiverse\ndeb https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-backports main restricted universe multiverse\n# deb-src https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-backports main restricted universe multiverse\ndeb https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-security main restricted universe multiverse\n# deb-src https://mirrors.ustc.edu.cn/ubuntu-ports/ focal-security main restricted universe multiverse\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202683-gx8sq0i","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202683-gx8sq0i","updated":"20220618202683"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"对两台系统进行更新","Properties":{"id":""}}]},{"ID":"20220618202684-9033urc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202684-9033urc","updated":"20220618202684"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"sudo apt-get update\nsudo apt-get upgrade\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202685-3ddm1p2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202685-3ddm1p2","updated":"20220618202685"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如果出现锁问题，有以下几类，并附上解决办法","Properties":{"id":""}}]},{"ID":"20220618202686-90pzt08","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202686-90pzt08","updated":"20220618202686"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1\nE: 无法获得锁 /var/lib/dpkg/lock-frontend。锁正由进程 3700（aptd）持有\nN: 请注意，直接移除锁文件不一定是合适的解决方案，且可能损坏您的系统。\nE: 无法获取 dpkg 前端锁 (/var/lib/dpkg/lock-frontend)，是否有其他进程正占用它？\n\nsudo rm /var/lib/dpkg/lock-frontend\nsudo rm /var/lib/dpkg/lock\n\n#2\nE: 无法获得锁 /var/cache/apt/archives/lock。锁正由进程 3700（aptd）持有\nN: 请注意，直接移除锁文件不一定是合适的解决方案，且可能损坏您的系统。\nE: 无法对目录 /var/cache/apt/archives/ 加锁\n\nsudo rm /var/cache/apt/archives/lock\nsudo rm /var/lib/dpkg/lock \n\n#3\nE: 无法获得锁 /var/lib/apt/lists/lock。锁正由进程 3700（aptd）持有\nN: 请注意，直接移除锁文件不一定是合适的解决方案，且可能损坏您的系统。\nE: 无法对目录 /var/lib/apt/lists/ 加锁\n\nsudo rm /var/lib/apt/lists/lock\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202687-wso66v9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202687-wso66v9","updated":"20220618202687"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"设置静态ip","Properties":{"id":""}}]},{"ID":"20220618202688-ct35x7k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202688-ct35x7k","updated":"20220618202688"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1\ncd /etc/netplan/ 找到目录下的文件进行修改，注意gateway4网关在有线网络设置中自己先查看（先打开ubuntu然后在未更改ip的前提下打开右上角的有线网络设置，这里面的gateway就是等等要改的gateway4）\n\n要改的有两个 一个是addresses还有一个是gateway4\n# Let NetworkManager manage all devices on this system\nnetwork:\n  version: 2\n  renderer: NetworkManager\n  ethernets:\n        ens33:\n                dhcp4: false\n                addresses: [192.168.8.99/24]\n                optional: true\n                gateway4: 192.168.8.1\n                nameservers:\n                        addresses: [8.8.8.8,114.114.114.114]\n                 \n#2.更新网络\nsudo netplan apply     \n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202689-2xibvn3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202689-2xibvn3","updated":"20220618202689"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"安装ssh和wget","Properties":{"id":""}}]},{"ID":"20220618202690-11nygjy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202690-11nygjy","updated":"20220618202690"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"sudo apt-get install ssh\nsudo apt-get install wget\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202691-ynojjvt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202691-ynojjvt","updated":"20220618202691"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"xshell连接方式","Properties":{"id":""}}]},{"ID":"20220618202692-tqwwt4p","Type":"NodeParagraph","Properties":{"id":"20220618202692-tqwwt4p","updated":"20220618202692"},"Children":[{"Type":"NodeText","Data":"用户名是","Properties":{"id":""}}]},{"ID":"20220618202693-43wk5t4","Type":"NodeBlockquote","Properties":{"id":"20220618202693-43wk5t4","updated":"20220618202693"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618202694-59pvbwq","Type":"NodeParagraph","Properties":{"id":"20220618202694-59pvbwq","updated":"20220618202694"},"Children":[{"Type":"NodeText","Data":"xth","Properties":{"id":""}}]}]},{"ID":"20220618202695-e66jte5","Type":"NodeParagraph","Properties":{"id":"20220618202695-e66jte5","updated":"20220618202695"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/用户名-20220618202939-9wy1j3y.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202696-akrspoq","Type":"NodeParagraph","Properties":{"id":"20220618202696-akrspoq","updated":"20220618202696"},"Children":[{"Type":"NodeText","Data":"密码是登录密码","Properties":{"id":""}}]},{"ID":"20220618202697-gzx6lpw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202697-gzx6lpw","updated":"20220618202697"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"设置root模式","Properties":{"id":""}}]},{"ID":"20220618202698-3i66oe2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202698-3i66oe2","updated":"20220618202698"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1\nsudo passwd root\n输密码\n\n#2 登录方式 \nsu root\n\n#3 退出方式\nexit\n\n# 如何更改现有用户密码？ xx@yy\n1.先进入root模式\n2.改密码\nsudo passwd 要更改密码的用户名 # 注意输的是xx\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202699-xv1x11q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202699-xv1x11q","updated":"20220618202699"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"重中之重","Properties":{"id":""}}]},{"ID":"20220618202700-lp8r1sg","Type":"NodeBlockquote","Properties":{"id":"20220618202700-lp8r1sg","updated":"20220618202700"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618202701-ulg4vm5","Type":"NodeParagraph","Properties":{"id":"20220618202701-ulg4vm5","updated":"20220618202701"},"Children":[{"Type":"NodeText","Data":"\u003cstrong style=\"color:red;\"\u003e所有后面的操作都要在root模式下进行\u003c/strong\u003e","Properties":{"id":""}}]}]},{"ID":"20220618202702-v6xc3s1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202702-v6xc3s1","updated":"20220618202702"},"Children":[{"Type":"NodeText","Data":"搭建KubeEdge"}]},{"ID":"20220618202703-muz2719","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202703-muz2719","updated":"20220618202703"},"Children":[{"Type":"NodeText","Data":"两台系统都要做的"}]},{"ID":"20220618202704-yolt6g9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202704-yolt6g9","updated":"20220618202704"},"Children":[{"Type":"NodeText","Data":"常规操作"}]},{"ID":"20220618202705-yfu973h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202705-yfu973h","updated":"20220618202705"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#关闭防火墙\nsudo ufw disable\n#防火墙在系统启动时自动禁用\n#查看防火墙状态\nsudo ufw status\n状态：不活动\n\n#关闭交换分区\n//第一次必须要先临时关闭一下\nsudo swapoff -a\n//永久关闭\nsudo sed -i 's/.*swap.*/#\u0026/' /etc/fstab\n\n#修改主机名\n#修改XXX部分即可\nhostnamectl set-hostname XXX\n\n#在master和node添加节点ip\nsudo vim /etc/hosts\n#添加节点ip，分别是node节点和master节点 格式如下  \n192.168.107.130 xth\n192.168.107.131 xth1\n\n# 将桥接的IPv4流量传递到iptables的链\ncat \u003e /etc/sysctl.d/k8s.conf \u003c\u003c EOF\nnet.bridge.bridge-nf-call-ip6tables = 1\nnet.bridge.bridge-nf-call-iptables = 1\nEOF\nsysctl --system  # 生效\n\n#时间同步\nsudo apt-get install ntpdate -y\nntpdate time.windows.com\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202706-mo3tnbt","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202706-mo3tnbt","updated":"20220618202706"},"Children":[{"Type":"NodeText","Data":"docker安装  daemon的格式要改吗?不需要"}]},{"ID":"20220618202707-fu5wio1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202707-fu5wio1","updated":"20220618202707"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#**docker安装**\n#step 1: 安装必要的一些系统工具\nsudo apt-get update\nsudo apt-get -y install apt-transport-https ca-certificates curl software-properties-common\n#step 2: 安装GPG证书\ncurl -fsSL https://mirrors.aliyun.com/docker-ce/linux/ubuntu/gpg | sudo apt-key add -\n#Step 3: 写入软件源信息\nsudo add-apt-repository \"deb [arch=amd64] https://mirrors.aliyun.com/docker-ce/linux/ubuntu $(lsb_release -cs) stable\"\n#step4下载docker\nsudo apt-get -y update\ncurl -fsSL https://get.docker.com | bash -s docker --mirror Aliyun\n#查看docker版本\ndocker version\n#修改镜像源\nsudo vim /etc/docker/daemon.json\n#打开后输入以下内容  注意exec-opt这步不要改成systemd，还是写为cgroupfs\n\n{\n  \"registry-mirrors\": [\"https://dockerhub.azk8s.cn\",\"https://reg-mirror.qiniu.com\",\"https://quay-mirror.qiniu.com\"],\n  \"exec-opts\": [ \"native.cgroupdriver=cgroupfs\" ]    \n}\n#重启\nsudo systemctl daemon-reload\nsudo systemctl restart docker\n#查看修改后的 docker cgroup 状态\ndocker info | grep Cgroup\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202708-szhw2c1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202708-szhw2c1","updated":"20220618202708"},"Children":[{"Type":"NodeText","Data":"安装go环境"}]},{"ID":"20220618202709-18p9a1x","Type":"NodeParagraph","Properties":{"id":"20220618202709-18p9a1x","updated":"20220618202709"},"Children":[{"Type":"NodeText","Data":"\u003cstrong style=\"color:red;\"\u003e注意系统架构，arm的就得下arm的\u003c/strong\u003e","Properties":{"id":""}}]},{"ID":"20220618202710-utsijfc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202710-utsijfc","updated":"20220618202710"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1 下载go包\nsudo wget https://dl.google.com/go/go1.15.3.linux-amd64.tar.gz\n\n#2 解压到/usr/local/文件下\nsudo tar -zxvf go1.15.3.linux-amd64.tar.gz -C /usr/local/\n\n#3 将go添加至环境变量\nsudo cp /usr/local/go/bin/go /usr/local/bin/go\n\n#4 查看go是否安装成功\ngo version\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202711-pte5dge","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202711-pte5dge","updated":"20220618202711"},"Children":[{"Type":"NodeText","Data":"两个节点都要增加github的ip地址以及下载keadm"}]},{"ID":"20220618202712-qhuvkid","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618202712-qhuvkid","updated":"20220618202712"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"#首先登录websites.ipaddress.com\n#然后搜索github和raw.githubusercontent.com的域名解析\n#将域名添加在hosts中，如下图\nsudo vim /etc/hosts\n#有时候github的解析过段时间就会变，所以不好用就要重新解析一遍\n140.82.114.4 github.com\n185.199.108.133 raw.githubusercontent.com\n185.199.109.133 raw.githubusercontent.com\n185.199.110.133 raw.githubusercontent.com\n185.199.111.133 raw.githubusercontent.com\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618202713-1y9i239","Type":"NodeParagraph","Properties":{"id":"20220618202713-1y9i239","updated":"20220618202713"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/ip-20220618202939-n901dja.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202714-bojsh5p","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202714-bojsh5p","updated":"20220618202714"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1 先手动下载keadm，并且选择要下载的版本，然后通过xshell上传至节点\nhttps://github.com/kubeedge/kubeedge/releases\n\n#2 解压keadm\ntar -zxvf keadm-v1.8.0-linux-amd64.tar.gz \n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202715-l79et97","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202715-l79et97","updated":"20220618202715"},"Children":[{"Type":"NodeText","Data":"Master端部署k8s，node节点不需要做"}]},{"ID":"20220618202716-ds4ioqp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202716-ds4ioqp","updated":"20220618202716"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#使得 apt 支持 ssl 传输\napt-get update \u0026\u0026 apt-get install -y apt-transport-https\n#下载 gpg 密钥\ncurl https://mirrors.aliyun.com/kubernetes/apt/doc/apt-key.gpg | apt-key add - \n#添加 k8s 镜像源\ncat \u003c\u003cEOF \u003e/etc/apt/sources.list.d/kubernetes.list\ndeb https://mirrors.aliyun.com/kubernetes/apt/ kubernetes-xenial main\nEOF\n#更新源列表\napt-get update\n\n#下载 kubectl，kubeadm以及 kubelet,如果出现安装不了的情况就把-get删除\napt-get install -y kubelet=1.18.0-00 kubeadm=1.18.0-00 kubectl=1.18.0-00\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202717-fsyduv5","Type":"NodeParagraph","Properties":{"id":"20220618202717-fsyduv5","updated":"20220618202717"},"Children":[{"Type":"NodeText","Data":"\u003cstrong style=\"color:red;\"\u003e注意要改这里的address和kubernetes-version，并且版本要和kubelet那些的版本一致\u003c/strong\u003e","Properties":{"id":""}}]},{"ID":"20220618202718-7pqtnu4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202718-7pqtnu4","updated":"20220618202718"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#初始化 master 节点  \nkubeadm init \\\n  --apiserver-advertise-address=192.168.213.129 \\\n  --image-repository registry.aliyuncs.com/google_containers \\\n  --kubernetes-version v1.18.0 \\\n  --service-cidr=10.96.0.0/12 \\\n  --pod-network-cidr=10.244.0.0/16\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202719-2mb2753","Type":"NodeParagraph","Properties":{"id":"20220618202719-2mb2753","updated":"20220618202719"},"Children":[{"Type":"NodeText","Data":"成功后出现下图","Properties":{"id":""}}]},{"ID":"20220618202720-ob9n2i6","Type":"NodeParagraph","Properties":{"id":"20220618202720-ob9n2i6","updated":"20220618202720"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/成-20220618202939-54ypbwc.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202721-a14ekqr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202721-a14ekqr","updated":"20220618202721"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#依次输入图中中间的三句话\nmkdir -p $HOME/.kube\nsudo cp -i /etc/kubernetes/admin.conf $HOME/.kube/config\nsudo chown $(id -u):$(id -g) $HOME/.kube/config\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202722-07wlhgl","Type":"NodeParagraph","Properties":{"id":"20220618202722-07wlhgl","updated":"20220618202722"},"Children":[{"Type":"NodeText","Data":"下载网络插件","Properties":{"id":""}}]},{"ID":"20220618202723-y8tdilc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202723-y8tdilc","updated":"20220618202723"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#下载插件\nkubectl apply -f https://raw.githubusercontent.com/coreos/flannel/master/Documentation/kube-flannel.yml\n#查看拉取情况\nkubectl get pods -n kube-system\n#等待一段时间后(多次输出上面这条语句可以查看下载状况，等的时间依网速而定)\nkubectl get nodes\n#好了以后输出上面这句(ready就是成功了，name是master的名字)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202724-u5gb1lc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202724-u5gb1lc","updated":"20220618202724"},"Children":[{"Type":"NodeText","Data":"node端安装Mosquitto"}]},{"ID":"20220618202725-yg7mb2m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202725-yg7mb2m","updated":"20220618202725"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#添加源\nsudo apt-add-repository ppa:mosquitto-dev/mosquitto-ppa\nsudo apt-get update\n#下载并安装\nsudo apt-get install mosquitto\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202726-omnga0a","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202726-omnga0a","updated":"20220618202726"},"Children":[{"Type":"NodeText","Data":"Master端"}]},{"ID":"20220618202727-vwrkqpi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202727-vwrkqpi","updated":"20220618202727"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1 进入解压好的keadm最里面的文件夹找到keadm，然后输入下面的指令，版本号自己定，不要超过keadm的版本，速度可能会有点慢，因为要连外网，多等会\n./keadm init --kubeedge-version=1.8.0\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202728-2ew608z","Type":"NodeParagraph","Properties":{"id":"20220618202728-2ew608z","updated":"20220618202728"},"Children":[{"Type":"NodeText","Data":"出现cloudcore is running则成功","Properties":{"id":""}}]},{"ID":"20220618202729-7292vfy","Type":"NodeParagraph","Properties":{"id":"20220618202729-7292vfy","updated":"20220618202729"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/master-20220618202939-cnm49ke.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202730-zhwg8rz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202730-zhwg8rz","updated":"20220618202730"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#2 获取秘钥node端需要使用，还在keadm的路径下执行\n./keadm gettoken\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202731-94tpdtr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202731-94tpdtr","updated":"20220618202731"},"Children":[{"Type":"NodeText","Data":"node端"}]},{"ID":"20220618202732-7swwbda","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202732-7swwbda","updated":"20220618202732"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1 同样进入keadm最里面的文件夹找到keadm，输入以下指令，注意node和master的kubeedge版本要一样  可以指定名字也可以不指定,需要指定节点名称的时候可以使用\n./keadm join --cloudcore-ipport='master端所在的ip':10000 --edgenode-name='tx2' --kubeedge-version=1.8.0 --token='前面获取的token值'\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202733-9798jhg","Type":"NodeParagraph","Properties":{"id":"20220618202733-9798jhg","updated":"20220618202733"},"Children":[{"Type":"NodeText","Data":"出现edgecore is running则成功","Properties":{"id":""}}]},{"ID":"20220618202734-cuxzf7n","Type":"NodeParagraph","Properties":{"id":"20220618202734-cuxzf7n","updated":"20220618202734"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/edge-20220618202939-eacwxp2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202735-qyapxse","Type":"NodeParagraph","Properties":{"id":"20220618202735-qyapxse","updated":"20220618202735"},"Children":[{"Type":"NodeText","Data":"再master端输入，观察是否加入成功","Properties":{"id":""}}]},{"ID":"20220618202736-vvb3d7k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202736-vvb3d7k","updated":"20220618202736"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"kubectl get nodes\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202737-qj3eyya","Type":"NodeParagraph","Properties":{"id":"20220618202737-qj3eyya","updated":"20220618202737"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/加入-20220618202939-c8tq7pf.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202738-4yb5xlp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202738-4yb5xlp","updated":"20220618202738"},"Children":[{"Type":"NodeText","Data":"查看cloudcore是否开机自启"}]},{"ID":"20220618202739-qkrqv9x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202739-qkrqv9x","updated":"20220618202739"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#查看cloudcore启动情况\nps aux|grep cloudcore\n\n#输出如下表示启动:\nroot     23498  0.1  0.3 1012544 48640 ?       Ssl  May12  13:11 /usr/local/bin/cloudcore\n\n#查看端口 10000 10002 端口都有了\n#没有netstat命令,安装:yum install net-tools -y\nnetstat -tpnl\n#如下:\ntcp6       0      0 :::10000                :::*                    LISTEN      23498/cloudcore     \ntcp6       0      0 :::10002                :::*                    LISTEN      23498/cloudcore     \n\n#查看cloudcore启动状态\nsystemctl status cloudcore\n\n#如果没有设置开机启动服务则设置 复制开启自启动服务文件\ncp /etc/kubeedge/cloudcore.service /etc/systemd/system/cloudcore.service\n\n#添加文件权限\nchmod +x /etc/systemd/system/cloudcore.service\n\n#重新加载配置文件\nsystemctl daemon-reload\n\n#查看cloudcore启动的进程id,然后杀掉\nps aux|grep cloudcore\n#输出如下:\nroot     23498  0.1  0.3 1012544 48640 ?       Ssl  May12  13:12 /usr/local/bin/cloudcore\n#杀掉 可以不做！！！！\nkill -9 23498\n\n#启动cloudcore\nsystemctl start cloudcore\n\n#设置开机自启动\nsystemctl enable cloudcore.service\n\n#查看cloudcore开机启动状态 enabled:开启, disabled:关闭\nsystemctl is-enabled cloudcore.service\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202740-y7tjp8w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202740-y7tjp8w","updated":"20220618202740"},"Children":[{"Type":"NodeText","Data":"查看edgecore是否开机自启"}]},{"ID":"20220618202741-6sums4a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202741-6sums4a","updated":"20220618202741"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#查看edgecore是否开机启动\nsystemctl is-enabled edgecore\n\n#如果没有设置则设置 开启自启动\n如果没有设置则设置 开启自启动\nvim /etc/systemd/system/edgecore.service \n[Unit]\nDescription=edgecore.service\n\n[Service]\nType=simple\nExecStart=/usr/local/bin/edgecore\nRestart=always\nRestartSec=10\n\n[Install]\nWantedBy=multi-user.target\n\n#添加文件权限并启动edgecore\nchmod +x /etc/systemd/system/edgecore.service \n\n#重新加载配置文件\nsystemctl daemon-reload \n\n#启动edgecore      \nsystemctl start edgecore    \n\n#设置开机自启\nsystemctl enable edgecore.service  \n\n#查看edgecore开机启动状态 enabled:开启, disabled:关闭\nsystemctl is-enabled edgecore\n\n#查看状态     \nsystemctl status edgecore\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202742-6agtptx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202742-6agtptx","updated":"20220618202742"},"Children":[{"Type":"NodeText","Data":"demo部署"}]},{"ID":"20220618202743-ms8uy0l","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202743-ms8uy0l","updated":"20220618202743"},"Children":[{"Type":"NodeText","Data":"counter demo"}]},{"ID":"20220618202744-abk4q9e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202744-abk4q9e","updated":"20220618202744"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#下载示例代码\ngit clone https://github.com/kubeedge/examples.git $GOPATH/src/github.com/kubeedge/examples\n\n#创建 device model\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/crds\n\n#创建model\nkubectl create -f kubeedge-counter-model.yaml\n\n#创建device\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/crds\n#根据你的实际情况修改matchExpressions：\nvim kubeedge-counter-instance.yaml\n#主要修改的地方\n- key: ''  # 这里按这么写就可以\n  values:\n    - k8s-node-1 #这里是节点名称\n\n#运行yaml\nkubectl create -f kubeedge-counter-instance.yaml\n\n#部署云端应用\n#云端应用web-controller-app用来控制边缘端的pi-counter-app应用，该程序默认监听的端口号为80，此处修改为8089\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/web-controller-app\nvim main.go\nbeego.Run(\":8089\")\n\n#构建镜像\nmake all\nmake docker\n\n#部署web-controller-app\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/crds\nkubectl apply -f kubeedge-web-controller-app.yaml\n\n#部署边缘端应用\n#边缘端的pi-counter-app应用受云端应用控制，主要与mqtt服务器通信，进行简单的计数功能。\n#修改代码与构建镜像\n#需要将Makefile中的GOARCH修改为amd64才能运行该容器。默认是arm架构的\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/counter-mapper\nvim Makefile\nGOARCH=amd64  #在最底下添加就可以\ngo build -o pi-counter-app main.go\n\n#构建镜像\nmake all\nmake docker\n\n#部署Pi Counter App\ncd $GOPATH/src/github.com/kubeedge/examples/kubeedge-counter-demo/crds\nkubectl apply -f kubeedge-pi-counter-app.yaml\n#说明：为了防止Pod的部署卡在`ContainerCreating`，这里直接通过docker save、scp和docker load命令将镜像发布到边缘端\n#因为边缘端没有这个镜像,只能手动弄过去,或者先上传到私有镜像仓库, 边缘端配置私有仓库地址,就可以直接从私有仓库下载\n#这里就手动弄到边缘端\ndocker save -o kubeedge-pi-counter.tar kubeedge/kubeedge-pi-counter:v1.0.0\n\n#传到边缘端  这里的root要改成自己节点的hostname，ip也要改，路径改成/home/下的比较好，不然有权限会被限制\nscp kubeedge-pi-counter.tar root@172.16.72.142:/home/文件夹名称\n#在边缘端执行\ndocker load -i kubeedge-pi-counter.tar\n\n#在边缘端查看容器启动日志,有没有报错，这里要先docker ps查看容器id再执行，如果正常应该是什么也不显示的页面，就一直卡在那，因为云端没有发送消息\ndocker logs -f 容器id\n\n#master端查看部署情况\nkubectl get pods -o wide\nNAME                                    READY   STATUS    RESTARTS   AGE   IP            NODE           NOMINATED NODE   READINESS GATES\nkubeedge-counter-app-6984dcb4dd-jz5nh   1/1     Running   0          32m   172.16.72.143   k8s-master   \u003cnone\u003e           \u003cnone\u003e\nkubeedge-pi-counter-784d57c5d4-27v5g    1/1     Running   0          30m   \u003cnone\u003e        k8s-node-1        \u003cnone\u003e           \u003cnone\u003e\n\n#浏览器访问http://192.168.107.131:8089/\n注意这里的ip地址是master端的ip地址\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202745-tlluwcr","Type":"NodeParagraph","Properties":{"id":"20220618202745-tlluwcr","updated":"20220618202745"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/count-20220618202939-vpzufxo.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202746-upld9do","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202746-upld9do","updated":"20220618202746"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#在边缘节点执行\ndocker logs -f 容器id\n\n#可以查看到节点有数据显示\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202747-g00gjqh","Type":"NodeParagraph","Properties":{"id":"20220618202747-g00gjqh","updated":"20220618202747"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/demo-20220618202939-5aboiry.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202748-bcwmxob","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618202748-bcwmxob","updated":"20220618202748"},"Children":[{"Type":"NodeText","Data":"真实平台测试问题"}]},{"ID":"20220618202750-fogedi5","Type":"NodeParagraph","Properties":{"id":"20220618202750-fogedi5","updated":"20221125092011"},"Children":[{"Type":"NodeText","Data":"1.在测试前如果master端有部署过count demo 现在想重新部署，注意要删掉所有与count相关的dokcer image与container"}]},{"ID":"20220618202751-j47gmx1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202751-j47gmx1","updated":"20220618202751"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"###########################主节点\n#1.查看pod\nkubectl get -o wide\n#2.删除pod\nkubectl delete deployment pod的名称\n#3.停止docker容器\ndocker ps -a\ndocker stop 容器id\n#注意有一个阿里云的count进程，可以kill掉\ndocker kill 容器id\n#4.删除镜像\ndocker rmi -f 镜像id\n#5.examples最好重新下，因为要删要改的地方太多，时间一长又忘记了\n#6.注意\n  values:\n    - k8s-node-1 #这里的节点名称是kubectl get nodes反馈出来的名字\n    \n   \n有关的操作指令\n#1.查看pod状态\nkubectl describe pod pod的名字\n#2.如果有Error from server (AlreadyExists)请查看问题总结\n##############################边缘节点\n#1.同样停止count有关的docker进程，删除相关镜像\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202752-izleug1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202752-izleug1","updated":"20220618202752"},"Children":[{"Type":"NodeText","Data":"构建自己的dockerfile文件"}]},{"ID":"20220618202753-6pwunyj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202753-6pwunyj","updated":"20220618202753"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.先确定一个目录，然后在目录下创建目录  mkdir dockerfile   文件夹名必须是dockerfile\n\n#2.创建dockerfile文件，文件名随意，这里取为cloudedgetest\n\n#3.编辑文件内容 vim cloudedgetest 随便写一些docker命令\nFROM centos\nCMD [\"ls\",\"-a\"]\n\n#4.构建镜像，注意末尾有一个点 .\n\ndocker build -f 写了docker文件内容的文件名 -t 要构建成什么名字:版本号 .\n\n#以本文为例 \n\ndocker build -f cloudedgetest -t cloudedgetest:1.0 . \n\n#5.登录dockerhub\n\ndocker login -u 用户名 -p 密码\n\n#6.给镜像添加tag\n\ndocker tag cloudedgetest:1.0 xthsia(dockerhub用户名)/cloudedgetest(镜像名字):1.0(版本号，也是自己定的)\n\n#7.上传镜像\n\ndocker push (dockerhub用户名)/(镜像名:版本号)\n\ndocker push xthsia/cloudedgetest:1.0\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202754-h61s2rl","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618202754-h61s2rl","updated":"20220618202754"},"Children":[{"Type":"NodeText","Data":"如何删除运行deployment过的失败的pod？"}]},{"ID":"20220618202755-qxpi0fr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202755-qxpi0fr","updated":"20220618202755"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.查看所有的pod\nkubectl get pods -o wide\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202756-p84yhzq","Type":"NodeParagraph","Properties":{"id":"20220618202756-p84yhzq","updated":"20220618202756"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/pod-20220618202939-pgao72e.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202757-rmkivx5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202757-rmkivx5","updated":"20220618202757"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#2.删除第一个 NodeAffinity 的pod,注意这里能直接删除是因为这个pod都没deployment，所以可以直接删除\nkubectl delete pod podname\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202758-emzs4ut","T