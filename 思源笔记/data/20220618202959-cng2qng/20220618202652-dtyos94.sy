Properties":{"id":"20220618202791-tzylal7","updated":"20220618203300"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"1.系统设置\n2.用户账号\n3.lock\n4.automatic login打开\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618203245-2djhgc5","Type":"NodeParagraph","Properties":{"id":"20220618203245-2djhgc5","updated":"20220618203519"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"用户.jpg"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/用户-20220618203507-iwf6dl4.jpg"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20220618203528-kkrm41o","Type":"NodeParagraph","Properties":{"id":"20220618203528-kkrm41o","updated":"20220618203547"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"用户2.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/用户2-20220618203547-9mnthlh.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618202794-l0ecsex","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202794-l0ecsex","updated":"20220618202794"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何切换动态静态ip","Properties":{"id":""}}]},{"ID":"20220618202795-duwg96o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202795-duwg96o","updated":"20220618202795"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"一、配置静态IP\n\nsudo vi /etc/network/interfaces    -----------\u003e打开配置文件\n\n#----------------------配置文件中写入内容------------------------\nauto lo\niface lo inet loopback\n\nauto eth0\niface eth0 inet static\naddress 192.168.7.130    -----------------\u003e本地IP地址\ngateway 192.168.7.1       -----------------\u003e网关\nnetmask 255.255.255.0   -----------------\u003e子网掩码（不变）\n\n#-------------------------------------------------------------------\n\nsudo /etc/init.d/networking restart    ------------\u003e重启网络服务\n\n\n\n二、配置动态IP\n\nsudo vi /etc/network/interfaces    -----------\u003e打开配置文件\n\n#----------------------配置文件中写入内容------------------------\nauto lo\niface lo inet loopback\n\nauto eth0\niface eth0 inet dhcp\n#-------------------------------------------------------------------\n\nsudo /etc/init.d/networking restart    ------------\u003e重启网络服务\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202796-m10pzho","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202796-m10pzho","updated":"20220618202796"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"卸载本机已有docker","Properties":{"id":""}}]},{"ID":"20220618202797-cb9enps","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618202797-cb9enps","updated":"20220618202797"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"ubuntu卸载docker的方法：\n\n1.删除某软件及其安装时自动安装的所有包，命令如：\n\nsudo apt-get autoremove docker docker-ce docker-engine docker.io containerd runc\n\n2.删除docker卸载残留，命令如：\n\ndpkg -l | grep docker\n\ndpkg -l |grep ^rc|awk '{print $2}' |sudo xargs dpkg -P # 删除无用的相关的配置文件\n\n3.卸载没有删除的docker相关插件，命令如：\n\nsudo apt-get autoremove docker-ce-*\n\n4.删除docker的相关配置，命令如：\n\nsudo rm -rf /etc/systemd/system/docker.service.d\n\nsudo rm -rf /var/lib/docker\n\n5.检查是否卸载成功。\n\ndocker --version\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618202798-6l3wkmx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202798-6l3wkmx","updated":"20220618202798"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"怎么连wifi","Properties":{"id":""}}]},{"ID":"20220618202799-twth0zp","Type":"NodeParagraph","Properties":{"id":"20220618202799-twth0zp","updated":"20220618202799"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/linux连wifi-20220618202939-eho6n61.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618202800-vfz9tkm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618202800-vfz9tkm","updated":"20220618202800"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"up的wifi模块 如何设置？","Properties":{"id":""}}]},{"ID":"20220618202801-0zikny9","Type":"NodeBlockquote","Properties":{"id":"20220618202801-0zikny9","updated":"20220618202801"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618202802-fpiv828","Type":"NodeParagraph","Properties":{"id":"20220618202802-fpiv828","updated"