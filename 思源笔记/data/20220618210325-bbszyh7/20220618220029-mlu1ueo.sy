:"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220164-r91jfkt","updated":"20220618220164"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--使用like查询\n--查询名字中带x的人\n--1.   %(代表0到任意个字符)\nselect id,name,age from student where name like \"x%\";\n--2.   _(名字后只有一个字的)\nselect id,name,age from student where name like \"x_\";\n--3.   __(名字后有两个字的)\nselect id,name,age from student where name like \"x__\";\n--4.   ___1(名字中间有1的)\nselect id,name,age from student where name like \"___1\";\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220165-lj18n5d","Type":"NodeParagraph","Properties":{"id":"20220618220165-lj18n5d","updated":"20220618220165"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/有一-20220618220728-24zm35d.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220166-bqwndzo","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220166-bqwndzo","updated":"20220618220166"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"in（查找相对应的几个）——查找的是具体的一个或多个值","Properties":{"id":""}}]},{"ID":"20220618220167-l4rnnai","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220167-l4rnnai","updated":"20220618220167"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--查询年龄为18和25的\nselect id,name,age from student where age in (18,25);\n--比如找xt就查不到任何东西，必须写全，如\"xth\",\"xth1\"\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220168-nd78d3b","Type":"NodeParagraph","Properties":{"id":"20220618220168-nd78d3b","updated":"20220618220168"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/年龄-20220618220728-mba5o3c.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220169-gzkmbo1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220169-gzkmbo1","updated":"20220618220169"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"联表查询","Properties":{"id":""}}]},{"ID":"20220618220170-ocub7en","Type":"NodeTable","Data":"| 操作       | 描述                                       |\n| ---------- | ------------------------------------------ |\n| inner join | 如果表中至少有一个匹配，就返回行           |\n| left join  | 会从左表中返回所有的值，即使右表中没有匹配 |\n| right join | 会从右表中返回所有的值，即使左表中没有匹配 |","TableAligns":[0,0],"Properties":{"id":"20220618220170-ocub7en","updated":"20220618220170"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"操作","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"描述","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"inner join","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"如果表中至少有一个匹配，就返回行","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"left join","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"会从左表中返回所有的值，即使右表中没有匹配","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"right join","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"会从右表中返回所有的值，即使左表中没有匹配","Properties":{"id":""}}]}]}]},{"ID":"20220618220171-xnpy35l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220171-xnpy35l","updated":"20220618220171"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- join (连接的) on (判断的条件) 连接查询\n-- where 等值查询\n--join哪里就是以哪边的表为基准\n\n--inner join\nSELECT stu.id,stu.`name`,age,subjectNo,gradeNum \nFROM student AS stu --as表示把student替代为stu\nINNER JOIN grade AS gr \nON stu.id=gr.id  --从两个表中找学号一样的数据\n\n--left join\nSELECT stu.id,stu.`name`,age,subjectNo,gradeNum \nFROM student AS stu \nLEFT JOIN grade AS gr   \nON stu.id=gr.id\n\n--right join\nSELECT stu.id,stu.`name`,age,subjectNo,gradeNum \nFROM student AS stu \nRIGHT JOIN grade AS gr \nON stu.id=gr.id\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220172-6sc7ed6","Type":"NodeBlockquote","Properties":{"id":"20220618220172-6sc7ed6","updated":"20220618220172"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220173-1148yp9","Type":"NodeParagraph","Properties":{"id":"20220618220173-1148yp9","updated":"20220618220173"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"mark","TextMarkTextContent":"解题思路"}]},{"ID":"20220618220174-ejujwki","Type":"NodeParagraph","Properties":{"id":"20220618220174-ejujwki","updated":"20220618220174"},"Children":[{"Type":"NodeText","Data":"1.要查哪些数据","Properties":{"id":""}}]},{"ID":"20220618220175-odo5nvq","Type":"NodeParagraph","Properties":{"id":"20220618220175-odo5nvq","updated":"20220618220175"},"Children":[{"Type":"NodeText","Data":"2.从哪几个表中查 from 表 加入方法（right、left、inner） join 连接的表 on 交叉条件","Properties":{"id":""}}]},{"ID":"20220618220176-8oiqz8o","Type":"NodeParagraph","Properties":{"id":"20220618220176-8oiqz8o","updated":"20220618220176"},"Children":[{"Type":"NodeText","Data":"3.先查询两张表然后再慢慢增加","Properties":{"id":""}}]}]},{"ID":"20220618220177-fx7pg9k","Type":"NodeParagraph","Properties":{"id":"20220618220177-fx7pg9k","updated":"20220618220177"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/联查-20220618220728-dqfpjky.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220178-lq1cjpt","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220178-lq1cjpt","updated":"20220618220178"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"自连接","Properties":{"id":""}}]},{"ID":"20220618220179-c06421r","Type":"NodeBlockquote","Properties":{"id":"20220618220179-c06421r","updated":"20220618220179"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220180-sxmk063","Type":"NodeParagraph","Properties":{"id":"20220618220180-sxmk063","updated":"20220618220180"},"Children":[{"Type":"NodeText","Data":"自己的表和自己的表连接 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"mark","TextMarkTextContent":"核心：一张表拆为两张一样的表即可"}]}]},{"ID":"20220618220181-6rxv6w9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220181-6rxv6w9","updated":"20220618220181"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分页和排序","Properties":{"id":""}}]},{"ID":"20220618220182-qi8uy07","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220182-qi8uy07","updated":"20220618220182"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"排序","Properties":{"id":""}}]},{"ID":"20220618220183-w9yi26q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220183-w9yi26q","updated":"20220618220183"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--排序： \n升序ASC, 降序DESC\n\n--语法 \norder by 字段 ASC/DESC;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220184-y6o7mbh","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220184-y6o7mbh","updated":"20220618220184"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"排序前,分页前","Properties":{"id":""}}]},{"ID":"20220618220185-a0zf6vu","Type":"NodeParagraph","Properties":{"id":"20220618220185-a0zf6vu","updated":"20220618220185"},"Children":[{"Type":"NodeText","Data":" ","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/联排-20220618220728-sxqaviq.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220186-2kdfnun","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220186-2kdfnun","updated":"20220618220186"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"排序后","Properties":{"id":""}}]},{"ID":"20220618220187-o31ph99","Type":"NodeParagraph","Properties":{"id":"20220618220187-o31ph99","updated":"20220618220187"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/升序-20220618220728-4hx6j41.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220188-9asp0ej","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220188-9asp0ej","updated":"20220618220188"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分页","Properties":{"id":""}}]},{"ID":"20220618220189-krbtfyz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220189-krbtfyz","updated":"20220618220189"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--分页原因：缓解数据库压力，给人的体验更好 \n--语法： \nlimit 当前值,想要设置一页显示的大小\n--如一页显示五个数据\nlimit 0,5;\n--第n页计算公式\n第一页 limit 0,5\n第二页 limit 5,5\n第三页 limit 10,5\n第n页 limit (n-1)*pageSize,pageSize\n--pageSize(页面大小)\n--(n-1)*pageSize(起始值)\n--n:当前页\n--数据总数/页面大小 = 总页数\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220190-pyfersp","Type":"NodeParagraph","Properties":{"id":"20220618220190-pyfersp","updated":"20220618220190"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/分页-20220618220728-umo7m5i.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220191-xvnskoa","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220191-xvnskoa","updated":"20220618220191"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"子查询","Properties":{"id":""}}]},{"ID":"20220618220192-899206i","Type":"NodeParagraph","Properties":{"id":"20220618220192-899206i","updated":"20220618220192"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"特点：在where语句中嵌套一个子查询语句"}]},{"ID":"20220618220193-5arpvso","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220193-5arpvso","updated":"20220618220193"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--查询所有自控成绩大于70分前3的人，并降序排列\n--方法一，联表查方法\nSELECT s.`id`,s.`name`,age,subjectNo,gradeNum\nFROM student AS s\nRIGHT JOIN grade AS g \nON s.id = g.id\nWHERE subjectNo LIKE \"自控\" \u0026\u0026 gradeNum \u003e 70\nORDER BY gradeNum DESC\nLIMIT 0,3\n\n--方法二，子查询（由里及外）\nSELECT DISTINCT id,`name`,age\nFROM student\nWHERE id=ANY( --any是因为查询出了多条避免报错\n\tSELECT id FROM grade \n\tWHERE subjectNo LIKE '自控' AND gradeNum \u003e 70\n)\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220194-gj1sz7o","Type":"NodeParagraph","Properties":{"id":"20220618220194-gj1sz7o","updated":"20220618220194"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/子查询-20220618220728-akqj2wy.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220195-gyafnsg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220195-gyafnsg","updated":"20220618220195"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"删","Properties":{"id":""}}]},{"ID":"20220618220196-i3kziq5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220196-i3kziq5","updated":"20220618220196"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--物理删除\ndelete from 表名 where 条件\ndelete from students where name=\"小李飞刀\"\n\n--逻辑删除\n--用一个字段来表示 这条信息已经不能再使用了\n--给student表添加一个is_delete字段 bit 类型\nalter table students add is_delete bit default 0;\nupdate students set is_delete=1 where id=6;\n\n--删除某一行\ndelete from 表名 where 条件;\nDELETE FROM students WHERE id=2 OR id=3;\n\n--尽量使用tuncate清除表内容\ntruncate 'students';\n\n--truncate 和 delete的区别\n相同点：都能删除数据，都不会删除表结构\n不同点：\n\t1.truncant 重新设置自增列，即计数器会归零，delete不会删除自增，比如id已经是6了，但是用delete清空后重新生成的id是7，而truncant是1;\n\t2.truncant 不会影响事务\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220197-1ggnoru","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220197-1ggnoru","updated":"20220618220197"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"增加外键(用不到)","Properties":{"id":""}}]},{"ID":"20220618220198-a459geo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220198-a459geo","updated":"20220618220198"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"alter table 表名 add constraint 约束名 foreign key(作为外键的列) references 要引用的表(要引用的字段)\nalter table 'student' add constraint foreign key('gardeid') references 'grade'('gradeid')\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220199-f7nhh1x","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220199-f7nhh1x","updated":"20220618220199"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL函数","Properties":{"id":""}}]},{"ID":"20220618220200-g92rpe6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220200-g92rpe6","updated":"20220618220200"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"常用函数","Properties":{"id":""}}]},{"ID":"20220618220201-j9v16p9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220201-j9v16p9","updated":"20220618220201"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"SELECT ABS(-8); -- 绝对值\nSELECT CEILING(9.4) ;-- 向上取整 //9\nSELECT FLOOR(9.4);-- 向下取整 //10\nSELECT RAND(); -- 返回一个0~1之间的随机数\nSELECT SIGN(-10); -- 判断一个数的符号，0 返回0 负数返回-1 正数返回1\n\n-- 字符串函数\nSELECT CHAR_LENGTH('哈哈'); -- 字符串长度\nSELECT CONCAT('我','爱','你'); -- 拼接字符串\nSELECT INSERT('我爱编程helloworld',1,2,'超级热爱'); -- 插入，替换 //超级热爱编程helloworld 第一位就是1不是0\nSELECT LOWER('ZYY'); -- 小写字母\nSELECT UPPER('zyy'); -- 大写字母\nSELECT INSTR('zyy','y'); -- 返回第一次出现的子串的索引\nSELECT REPLACE('坚持就能成功','坚持','努力'); -- 替换出现的指定字符串\nSELECT SUBSTR('坚持就能成功', 5, 2); -- 返回指定的子字符串（源字符串，截取的位置，截取的长度）\nSELECT REVERSE('清晨我上马'); -- 反转\n\n\n-- 时间和日期函数（记住！）\nSELECT CURRENT_DATE(); -- 获取当前日期\nSELECT CURDATE(); -- 获取当前日期\nSELECT NOW(); -- 获取当前的时间\nSELECT LOCALTIME(); -- 获取本地时间\nSELECT SYSDATE(); -- 获取系统时间\n\nSELECT YEAR(NOW()); -- 年\nSELECT MONTH(NOW()); -- 月\nSELECT DAY(NOW()); -- 日\nSELECT HOUR(NOW()); -- 时\nSELECT MINUTE(NOW()); -- 分\nSELECT SECOND(NOW()); -- 秒\n\n-- 系统\nSELECT SYSTEM_USER();\nSELECT USER();\nSELECT VERSION();\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220202-p21pwmn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220202-p21pwmn","updated":"20220618220202"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"聚合函数以及分组过滤","Properties":{"id":""}}]},{"ID":"20220618220203-69jrpqx","Type":"NodeTable","Data":"| 函数名称 | 描述   |\n| -------- | ------ |\n| count()  | 计数   |\n| sum()    | 求和   |\n| avg()    | 平均值 |\n| max()    | 最大值 |\n| min()    | 最小值 |","TableAligns":[0,0],"Properties":{"id":"20220618220203-69jrpqx","updated":"20220618220203"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"函数名称","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"描述","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"count()","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"计数","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"sum()","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"求和","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"avg()","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"平均值","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"max()","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"最大值","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"min()","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"最小值","Properties":{"id":""}}]}]}]},{"ID":"20220618220204-incobgs","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220204-incobgs","updated":"20220618220204"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- 都能统计 表中数据\n\n-- count(字段) 会忽略所有的null值(想查询一个表中有多少个记录，就使用这个count())\nSELECT COUNT(student_name) FROM student;\n-- COUNT(*) 不会忽略所有的null值 本质计算行数\nSELECT COUNT(*) FROM student;\n-- COUNT(1) 不会忽略所有的null值 本质计算行数\nSELECT COUNT(1) FROM student;\n\nSELECT SUM(student_result) AS '总和' FROM result;\nSELECT AVG(student_result) AS '平均分' FROM result;\nSELECT MAX(student_result) AS '最高分' FROM result;\nSELECT MIN(student_result) AS '最低分' FROM result;\n\n--分组过滤\n-- 查询不同课程的平均分，最高分，最低分\nSELECT sub.subject_name AS '课程',AVG(res.student_result) AS '平均分',MAX(res.student_result) AS '最高分',MIN(res.student_result) AS '最低分'\nFROM result res\nINNER JOIN `subject` sub\nON res.`subject_no`=sub.`subject_no`\nGROUP BY res.`subject_no` --分组过滤，注意语法顺序，group要在having上面\nHAVING AVG(res.student_result) \u003e80;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220205-srkbrmp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220205-srkbrmp","updated":"20220618220205"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"MD5加密（扩展）","Properties":{"id":""}}]},{"ID":"20220618220206-tugah7u","Type":"NodeBlockquote","Properties":{"id":"20220618220206-tugah7u","updated":"20220618220206"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220207-02921yr","Type":"NodeParagraph","Properties":{"id":"20220618220207-02921yr","updated":"20220618220207"},"Children":[{"Type":"NodeText","Data":"主要增加算法复杂度和不可逆性。","Properties":{"id":""}}]},{"ID":"20220618220208-tc1erw8","Type":"NodeParagraph","Properties":{"id":"20220618220208-tc1erw8","updated":"20220618220208"},"Children":[{"Type":"NodeText","Data":"MD5不可逆，具体的值的md5是一样的","Properties":{"id":""}}]},{"ID":"20220618220209-2evbso1","Type":"NodeParagraph","Properties":{"id":"20220618220209-2evbso1","updated":"20220618220209"},"Children":[{"Type":"NodeText","Data":"MD5破解网站的原理，背后有一个字典，MD5加密后的值，加密前的值","Properties":{"id":""}}]}]},{"ID":"20220618220210-a68iug2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220210-a68iug2","updated":"20220618220210"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--语法\nINSERT INTO student VALUES(8,\"西泽保彦\",MD5('36'))\nUPDATE student\tSET age=MD5(age) WHERE id = 2\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220211-zn1lig6","Type":"NodeParagraph","Properties":{"id":"20220618220211-zn1lig6","updated":"20220618220211"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/md5-20220618220728-g52kuzl.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220212-4ma6xvb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220212-4ma6xvb","updated":"20220618220212"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--查找相对应的md5的数据\nSELECT * FROM student WHERE `name` = \"埃勒里奎因\" AND age = MD5('27')\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220213-d1mtfn0","Type":"NodeParagraph","Properties":{"id":"20220618220213-d1mtfn0","updated":"20220618220213"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"