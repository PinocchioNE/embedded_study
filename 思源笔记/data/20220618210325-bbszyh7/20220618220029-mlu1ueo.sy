","Num":-1},"Properties":{"id":"20220618220362-nibkv5c","updated":"20220618220362"},"Children":[{"ID":"20220618220363-fpd5vyv","Type":"NodeParagraph","Properties":{"id":"20220618220363-fpd5vyv","updated":"20220618220363"},"Children":[{"Type":"NodeText","Data":"故意增加一些计算列（从大数据库降低为小数据量的查询：索引）","Properties":{"id":""}}]}]}]},{"ID":"20220618220364-wk4a547","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220364-wk4a547","updated":"20220618220364"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDBC","Properties":{"id":""}}]},{"ID":"20220618220365-v0cez1v","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220365-v0cez1v","updated":"20220618220365"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"第一个JDBC程序","Properties":{"id":""}}]},{"ID":"20220618220366-70wpx48","Type":"NodeParagraph","Properties":{"id":"20220618220366-70wpx48","updated":"20220618220366"},"Children":[{"Type":"NodeText","Data":"导入connector jar包","Properties":{"id":""}}]},{"ID":"20220618220367-9ymf7wo","Type":"NodeParagraph","Properties":{"id":"20220618220367-9ymf7wo","updated":"20220618220367"},"Children":[{"Type":"NodeText","Data":"1.","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://blog.csdn.net/keyboard_/article/details/114344986","TextMarkTextContent":"下载地址"}]},{"ID":"20220618220368-atqmopk","Type":"NodeParagraph","Properties":{"id":"20220618220368-atqmopk","updated":"20220618220368"},"Children":[{"Type":"NodeText","Data":"2.打开java ide 新建directory 名称随意","Properties":{"id":""}}]},{"ID":"20220618220369-t2ve330","Type":"NodeParagraph","Properties":{"id":"20220618220369-t2ve330","updated":"20220618220369"},"Children":[{"Type":"NodeText","Data":"3.将下载好的jar包复制到新建的目录中","Properties":{"id":""}}]},{"ID":"20220618220370-pcjnggz","Type":"NodeParagraph","Properties":{"id":"20220618220370-pcjnggz","updated":"20220618220370"},"Children":[{"Type":"NodeText","Data":"4.将目录add as library"}]},{"ID":"20220629120309-vb5uj79","Type":"NodeParagraph","Properties":{"id":"20220629120309-vb5uj79","updated":"20220629120309"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"add.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/add-20220629120309-pe44vf7.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618220372-l846iz5","Type":"NodeParagraph","Properties":{"id":"20220618220372-l846iz5","updated":"20220618220372"},"Children":[{"Type":"NodeText","Data":"5.连接数据库","Properties":{"id":""}}]},{"ID":"20220618220373-qb5gc9m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220373-qb5gc9m","updated":"20220618220373"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package JDBCLesson;\n\nimport java.sql.*;\n\npublic class JDBCFirstDemo {\n    public static void main(String[] args) throws ClassNotFoundException, SQLException {\n        //1.加载驱动\n        Class.forName(\"com.mysql.cj.jdbc.Driver\");//固定写法，加载驱动\n\n        //2.用户信息和url\n        //其中school是你要连接的数据库名字  ？ 问号用于连接后面的参数\n        //这是规范写法,注意8.0版本后要加serverTimezone=UTC      useUnicode=true\u0026characterEncoding=utf8\u0026useSSL=true\u0026serverTimezone=UTC\n        String url = \"jdbc:mysql://localhost:3306/school?useUnicode=true\u0026characterEncoding=utf8\u0026useSSL=true\u0026serverTimezone=UTC\";\n        String username = \"root\";\n        String password = \"root\";\n        //3.连接成功，数据库对象 connection 代表数据库\n        Connection connection = DriverManager.getConnection(url, username, password);\n\n        //4.执行sql的对象  statement 执行sql的对象\n        Statement statement = connection.createStatement();\n\n        //5.执行sql的对象   执行sql--\u003e可能存在结果--\u003e查看返回结果\n        String sql = \"SELECT * FROM student\";\n        ResultSet resultSet = statement.executeQuery(sql);//返回的结果集，结果集中封装了我们全部的查询出来的结果\n        //一个一个拆分输出查询到的内容是什么\n        while(resultSet.next()){\n            System.out.println(\"id=\"+ resultSet.getObject(\"id\"));\n            System.out.println(\"name=\"+ resultSet.getObject(\"name\"));\n            System.out.println(\"age=\"+ resultSet.getObject(\"age\"));\n        }\n\n        //6.释放连接\n        resultSet.close();\n        statement.close();\n        connection.close();\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220374-bgbc2db","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220374-bgbc2db","updated":"20220618220374"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"步骤总结","Properties":{"id":""}}]},{"ID":"20220618220375-htlsqvz","Type":"NodeParagraph","Properties":{"id":"20220618220375-htlsqvz","updated":"20220618220375"},"Children":[{"Type":"NodeText","Data":"1.加载驱动","Properties":{"id":""}}]},{"ID":"20220618220376-y6szovu","Type":"NodeParagraph","Properties":{"id":"20220618220376-y6szovu","updated":"20220618220376"},"Children":[{"Type":"NodeText","Data":"2.连接数据库DriverManager","Properties":{"id":""}}]},{"ID":"20220618220377-a4zw9e1","Type":"NodeParagraph","Properties":{"id":"20220618220377-a4zw9e1","updated":"20220618220377"},"Children":[{"Type":"NodeText","Data":"3.获得执行sql的对象 statement","Properties":{"id":""}}]},{"ID":"20220618220378-h2terha","Type":"NodeParagraph","Properties":{"id":"20220618220378-h2terha","updated":"20220618220378"},"Children":[{"Type":"NodeText","Data":"4.获得返回的结果集","Properties":{"id":""}}]},{"ID":"20220618220379-hxfc9es","Type":"NodeParagraph","Properties":{"id":"20220618220379-hxfc9es","updated":"20220618220379"},"Children":[{"Type":"NodeText","Data":"5.释放连接","Properties":{"id":""}}]},{"ID":"20220618220380-iop04cg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220380-iop04cg","updated":"20220618220380"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDBC中对象解释","Properties":{"id":""}}]},{"ID":"20220618220381-ch2tzd1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220381-ch2tzd1","updated":"20220618220381"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"DriverManager","Properties":{"id":""}}]},{"ID":"20220618220382-9vv5nyj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220382-9vv5nyj","updated":"20220618220382"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//1.加载驱动\n//DriverManager.registerDriver(new com.mysql.jdbc.Driver());\n//推荐这种写法加载驱动\nClass.forName(\"com.mysql.jdbc.Driver\");\n\nConnection connection = DriverManager.getConnection(url, userName, passWord);\n// connection代表数据库\n// 数据库设置自动提交\n// 事务提交\n// 事务回滚\nconnection.setAutoCommit(true);\nconnection.commit();\nconnection.rollback();\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220383-y3fbgh2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220383-y3fbgh2","updated":"20220618220383"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"URL","Properties":{"id":""}}]},{"ID":"20220618220384-df2qtc3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220384-df2qtc3","updated":"20220618220384"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"String url = \"jdbc:mysql://localhost:3306/jdbcstudy?useUnicode=true\u0026characterEncoding=utf8\u0026useSSL=false\";\n\n// mysql默认端口3306\n// 协议://主机地址:端口号/数据库名?参数1\u0026参数2\u0026参数3\n// oracle默认端口1521\n// jdbc:oracle:thin:@localhost:1521:sid\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220385-4olkkji","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220385-4olkkji","updated":"20220618220385"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Statement","Properties":{"id":""}}]},{"ID":"20220618220386-2oxvkc5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220386-2oxvkc5","updated":"20220618220386"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"Statement 执行sql对象\n\nString sql = \"SELECT * FROM users\";//编写SQL\n\nstatement.executeQuery();//执行查询 返回ResultSet\nstatement.executeUpdate();//新增，删除，修改，都用更新的指令，返回受影响的内容用resultset接收\nstatement.execute();//执行任何SQL\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220387-e96gu8q","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220387-e96gu8q","updated":"20220618220387"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"1.建立properties文件","Properties":{"id":""}}]},{"ID":"20220618220388-dpwmvf6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220388-dpwmvf6","updated":"20220618220388"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"driver = com.mysql.cj.jdbc.Driver\nurl=jdbc:mysql://localhost:3306/school?useUnicode=true\u0026characterEncoding=utf8\u0026useSSL=true\u0026serverTimezone=UTC\nusername = root\npassword = root\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220389-he3okm2","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220389-he3okm2","updated":"20220618220389"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.建立初始化文件","Properties":{"id":""}}]},{"ID":"20220618220390-mn7pwwq","Type":"NodeBlockquote","Properties":{"id":"20220618220390-mn7pwwq","updated":"20220618220390"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220391-rb8zol4","Type":"NodeParagraph","Properties":{"id":"20220618220391-rb8zol4","updated":"20220618220391"},"Children":[{"Type":"NodeText","Data":"预先写好 加载驱动，登录数据库，连接数据库","Properties":{"id":""}}]}]},{"ID":"20220618220392-406tuwk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220392-406tuwk","updated":"20220618220392"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package JDBCLesson;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.sql.*;\nimport java.util.Properties;\n\npublic class JDBCUtils {\n    private static String driver = null;\n    private static String url = null;\n    private static String username = null;\n    private static String password = null;\n\n    static {\n        try {\n            //反射读取写好的properties文件\n            InputStream input = JDBCUtils.class.getClassLoader().getResourceAsStream(\"DataBaseSql.properties\");\n            Properties properties = new Properties();\n            properties.load(input);\n\n            driver = properties.getProperty(\"driver\");\n            url = properties.getProperty(\"url\");\n            username = properties.getProperty(\"username\");\n            password = properties.getProperty(\"password\");\n\n            //1.驱动只需要加载一次\n            Class.forName(driver);\n\n        } catch (Exception e) {\n            e.printStackTrace();\n        }\n    }\n    //获取连接\n    public static Connection getConnection() throws SQLException {\n        return DriverManager.getConnection(url,username,password);\n    }\n\n    //释放资源\n    public static void release(Connection con, Statement st, ResultSet rs){\n        if (rs!=null){\n            try {\n                rs.close();\n            } catch (SQLException throwables) {\n                throwables.printStackTrace();\n            }\n        }\n\n        if (st!=null){\n            try {\n                st.close();\n            } catch (SQLException throwables) {\n                throwables.printStackTrace();\n            }\n        }\n\n        if (con!=null){\n            try {\n                con.close();\n            } catch (SQLException throwables) {\n                throwables.printStackTrace();\n            }\n        }\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220393-bzzpml0","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220393-bzzpml0","updated":"20220618220393"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.测试用例","Properties":{"id":""}}]},{"ID":"20220618220394-9hmnaik","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220394-9hmnaik","updated":"20220618220394"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package JDBCLesson;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Statement;\n\npublic class JDBCDemo2 {\n\n        public static void main(String[] args) {\n            Connection con = null;\n            Statement st = null;\n            ResultSet rs = null;\n            try {\n                con = JDBCUtils.getConnection();\n                st = con.createStatement();\n                //String sql = \"INSERT INTO student(`id`,`name`,`age`)\" + \"VALUES (9,'江户川乱步',76)\";\n                String sql = \"SELECT * FROM student\";\n                int num = st.executeUpdate(sql);//数据库中的更新操作\n                //ResultSet resultSet = st.executeQuery(sql);\n                if (num \u003e 0) {\n                    System.out.println(\"插入成功！\");\n                }\n//                while(resultSet.next()){\n//                    System.out.println(\"id=\"+ resultSet.getObject(\"id\"));\n//                    System.out.println(\"name=\"+ resultSet.getObject(\"name\"));\n//                    System.out.println(\"age=\"+ resultSet.getObject(\"age\"));\n//                }\n\n            } catch (SQLException e) {\n                e.printStackTrace();\n            } finally {\n                JDBCUtils.release(con, st, rs);\n            }\n        }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220395-oiytpks","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220395-oiytpks","updated":"20220618220395"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ResultSet","Properties":{"id":""}}]},{"ID":"20220618220396-xzfe4kg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220396-xzfe4kg","updated":"20220618220396"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//查询的结果集，封装了所有的查询结果，获得指定的数据类型\n//在不知道列类型的情况下使用\nresultSet.getObject();\n//如果知道列类型，就使用指定的类型\nresultSet.getString();\nresultSet.getInt();\nresultSet.getDouble();\nresultSet.getBigDecimal();\nresultSet.getFloat();\nresultSet.getDate();\n//...\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220397-54wvxeq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220397-54wvxeq","updated":"20220618220397"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"遍历，指针","Properties":{"id":""}}]},{"ID":"20220618220398-och2o8e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220398-och2o8e","updated":"20220618220398"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"resultSet.beforeFirst();//移动到最前面\nresultSet.afterLast();//移动到最后面\nresultSet.next();//移动到下一个数据\nresultSet.previous();//移动到前一行\nresultSet.absolute(row);//移动到指定行\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220399-tclk6ah","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220399-tclk6ah","updated":"20220618220399"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"释放资源","Properties":{"id":""}}]},{"ID":"20220618220400-j1npj7h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220400-j1npj7h","updated":"20220618220400"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"resultSet.close();\nstatement.close();\nconnection.close();//消耗资源\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220401-3xcc00f","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220401-3xcc00f","updated":"20220618220401"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"sql注入问题","Properties":{"id":""}}]},{"ID":"20220618220402-fdxb6va","Type":"NodeParagraph","Properties":{"id":"20220618220402-fdxb6va","updated":"20220618220402"},"Children":[{"Type":"NodeText","Data":"sql存在漏洞，会被攻击导致数据泄露 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"mark","TextMarkTextContent":"SQL会被拼接"}]},{"ID":"20220618220403-zu6ccco","Type":"NodeParagraph","Properties":{"id":"20220618220403-zu6ccco","updated":"20220618220403"},"Children":[{"Type":"NodeText","Data":"导致结果：错误的用户名或者密码可以获取到全部的用户信息","Properties":{"id":""}}]},{"ID":"20220618220404-sg1esow","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220404-sg1esow","updated":"20220618220404"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Statement;\n\npublic class SQLQuestion {\n    public static void main(String[] args) {\n\n        //正常登录\n//        login(\"张三\",\"1234567\");\n\n        //sql注入\n        login(\"' or '1=1\",\"123456\");\n\n    }\n\n// 登录业务\n    public static void login(String userName, String password) {\n        Connection con = null;\n        Statement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            st = con.createStatement();\n            String sql = \"SELECT * FROM users WHERE `name`='\"+userName+\"' AND `password`='\"+password+\"'\";\n            // SELECT * FROM users WHERE `name`='' or '1=1' AND `password`='123456'\n            System.out.println(sql);\n            rs = st.executeQuery(sql);\n            while (rs.next()) {\n                System.out.println(\"id=\"+rs.getInt(\"id\"));\n                System.out.println(\"name=\"+rs.getString(\"name\"));\n            }\n\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n    }\n}\n// 结果会把所有的信息都传出来\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220405-4e76wvj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220405-4e76wvj","updated":"20220618220405"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"PreparedStatement对象","Properties":{"id":""}}]},{"ID":"20220618220406-yn43dpc","Type":"NodeBlockquote","Properties":{"id":"20220618220406-yn43dpc","updated":"20220618220406"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220407-wvjgt8l","Type":"NodeParagraph","Properties":{"id":"20220618220407-wvjgt8l","updated":"20220618220407"},"Children":[{"Type":"NodeText","Data":"可以防止sql注入","Properties":{"id":""}}]}]},{"ID":"20220618220408-oaywamh","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220408-oaywamh","updated":"20220618220408"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"新增","Properties":{"id":""}}]},{"ID":"20220618220409-hd6pzce","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220409-hd6pzce","updated":"20220618220409"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\n\npublic class TestInsert {\n    public static void main(String[] args) {\n        Connection con = null;\n        PreparedStatement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            //使用?占位符代替参数\n            String sql = \"INSERT INTO users(`id`,`name`,`password`,`email`,`birthday`) VALUES (?,?,?,?,?)\";\n            //预编译SQL，先写SQL，然后不执行\n            st = con.prepareStatement(sql);\n            //手动给参数赋值  1代表第一个占位符 2代表第二个 下同\n            st.setInt(1, 5);\n            st.setString(2, \"钱七\");\n            st.setString(3, \"123456\");\n            st.setString(4, \"qianqi@sina.com\");\n            st.setDate(5, new java.sql.Date(new java.util.Date().getTime()));\n            int num = st.executeUpdate();\n            if (num \u003e 0) {\n                System.out.println(\"插入成功！\");\n            }\n\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220410-2d7otzc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220410-2d7otzc","updated":"20220618220410"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"删除","Properties":{"id":""}}]},{"ID":"20220618220411-s7jhax8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220411-s7jhax8","updated":"20220618220411"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\n\npublic class TestDelete {\n    public static void main(String[] args) {\n        Connection con = null;\n        PreparedStatement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            //使用?占位符代替参数\n            String sql = \"DELETE FROM users WHERE `id`=?\";\n            //预编译SQL，先写SQL，然后不执行\n            st = con.prepareStatement(sql);\n            //手动给参数赋值\n            st.setInt(1, 5);\n            int num = st.executeUpdate();\n            if (num \u003e 0) {\n                System.out.println(\"删除成功！\");\n            }\n\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220412-sz54y40","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220412-sz54y40","updated":"20220618220412"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"更新","Properties":{"id":""}}]},{"ID":"20220618220413-qit3mk6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220413-qit3mk6","updated":"20220618220413"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\n\npublic class TestUpdate {\n    public static void main(String[] args) {\n        Connection con = null;\n        PreparedStatement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            //使用?占位符代替参数\n            String sql = \"UPDATE users SET birthday=? WHERE id=?\";\n            //预编译SQL，先写SQL，然后不执行\n            st = con.prepareStatement(sql);\n            //手动给参数赋值\n            st.setDate(1, new java.sql.Date(new java.util.Date().getTime()));\n            st.setInt(2, 1);\n            int num = st.executeUpdate();\n            if (num \u003e 0) {\n                System.out.println(\"修改成功！\");\n            }\n\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220414-bi2j0in","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220414-bi2j0in","updated":"20220618220414"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"查询","Properties":{"id":""}}]},{"ID":"20220618220415-r5zviek","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220415-r5zviek","updated":"20220618220415"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\n\npublic class TestSelect {\n    public static void main(String[] args) {\n        Connection con = null;\n        PreparedStatement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            //使用?占位符代替参数\n            String sql = \"SELECT * FROM users WHERE id=?\";\n            //预编译SQL，先写SQL，然后不执行\n            st = con.prepareStatement(sql);\n            //手动给参数赋值\n            st.setInt(1, 1);\n            rs = st.executeQuery();\n            while (rs.next()) {\n                System.out.println(\"id=\"+rs.getInt(\"id\"));\n                System.out.println(\"name=\"+rs.getString(\"name\"));\n            }\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220416-chzmv3p","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618220416-chzmv3p","updated":"20220618220416"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"防止sql注入","Properties":{"id":""}}]},{"ID":"20220618220417-2a4s143","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220417-2a4s143","updated":"20220618220417"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import com.zyy.lesson02.utils.JDBCUtils;\n\nimport java.sql.Connection;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\n\npublic class SQLQuestion {\n    public static void main(String[] args) {\n\n        //正常登录\n//        login(\"张三\",\"123456\");\n\n        //sql注入\n        login(\"' or '1=1\", \"123456\");\n\n    }\n\n    /**\n     * 登录业务\n     */\n    public static void login(String userName, String password) {\n        Connection con = null;\n        PreparedStatement st = null;\n        ResultSet rs = null;\n        try {\n            con = JDBCUtils.getConnection();\n            // PreparedStatement 防止SQL注入的本质，把传递进来的参数当做字符\n            // 假设其中存在转义字符，比如说单引号会被直接转义\n            String sql = \"SELECT * FROM users WHERE `name`=? AND `password`=?\";\n            st = con.prepareStatement(sql);\n            st.setString(1, userName);\n            st.setString(2, password);\n            rs = st.executeQuery();\n            while (rs.next()) {\n                System.out.println(\"id=\" + rs.getInt(\"id\"));\n                System.out.println(\"name=\" + rs.getString(\"name\"));\n            }\n\n        } catch (SQLException e) {\n            e.printStackTrace();\n        } finally {\n            JDBCUtils.release(con, st, rs);\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220418-grbd947","Type":"NodeParagraph","Properties":{"id":"20220618220418-grbd947","updated":"20220618220418"},"Children":[{"Type":"NodeText","Data":"执行结果：查不到任何结果","Properties":{"id":""}}]},{"ID":"20220618220419-hov9t4v","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220419-hov9t4v","updated":"20220618220419"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"IDE连接数据库","Properties":{"id":""}}]},{"ID":"20220618220420-tbnog2o","Type":"NodeBlockquote","Properties":{"id":"20220618220420-tbnog2o","update