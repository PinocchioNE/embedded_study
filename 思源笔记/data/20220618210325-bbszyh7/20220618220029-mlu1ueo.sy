d int unsigned defauld 0,\n\tis_delete bit default 0\n);\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220116-9ko9shk","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220116-9ko9shk","updated":"20220618220116"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"创建表格式","Properties":{"id":""}}]},{"ID":"20220618220117-zd6ylqh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220117-zd6ylqh","updated":"20220618220117"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"create table [if not exists] '表名'{\n\t'字段名' 列类型 [属性] [索引] [注释],\n\t'字段名' 列类型 [属性] [索引] [注释],\n\t...\n\t'字段名' 列类型 [属性] [索引] [注释]\n}[表类型] [字符集设置] [注释]\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220118-4obvih7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220118-4obvih7","updated":"20220618220118"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"create table academician(\n\t`工位编号` int unsigned not null auto_increment primary key comment'工位号',//comment'工位号'表示注释\n\t`姓名` varchar(30),\n\t`性别` enum(\"男\",\"女\",\"中性\",\"保密\") default \"保密\",\n\t`年龄` tinyint unsigned default 0,\n\t`身高_cm` decimal(5,2),\n\t`体重_kg` decimal(3,1)\n);\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220119-ga2kywn","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220119-ga2kywn","updated":"20220618220119"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"删除表","Properties":{"id":""}}]},{"ID":"20220618220120-75micny","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220120-75micny","updated":"20220618220120"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"drop table 表名;\ndrop table if exists 表名;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220121-4a6nr2a","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220121-4a6nr2a","updated":"20220618220121"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"表中插入数据","Properties":{"id":""}}]},{"ID":"20220618220122-1h8wvuu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220122-1h8wvuu","updated":"20220618220122"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"insert into students(表名) values(0, \"夏天豪\", 24, 173, \"