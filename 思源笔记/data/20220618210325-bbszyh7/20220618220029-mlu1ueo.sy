ext","Data":"基础语法","Properties":{"id":""}}]},{"ID":"20220618220291-mv1vg2e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220291-mv1vg2e","updated":"20220618220291"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- 索引的使用\n\n-- 1.在创建表的时候给字段增加索引\n-- 2.创建完毕后，增加索引\n\n-- 显示所有的索引信息\nSHOW INDEX FROM student;\n\n-- 新增一个索引 (索引名) 列名\n\nALTER TABLE `student` ADD UNIQUE KEY `UK_IDENTITY_CARD` (`identity_card`);\nALTER TABLE `student` ADD KEY `K_STUDENT_NAME`(`student_name`);\nALTER TABLE `student`  ADD FULLTEXT INDEX `FI_PHONE` (`phone`);\n\n-- explain 分析sql执行的状况\n\nEXPLAIN SELECT * FROM student; -- 非全文索引\n\nEXPLAIN SELECT * FROM student WHERE MATCH(`phone`) AGAINST('138'); -- 全文索引\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220292-c9erkfh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220292-c9erkfh","updated":"20220618220292"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.测试索引","Properties":{"id":""}}]},{"ID":"20220618220293-skvlyav","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220293-skvlyav","updated":"20220618220293"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--先创建表\nCREATE TABLE app_user (\n  `id` BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT COMMENT 'ID',\n  `name` VARCHAR(50)  DEFAULT '' COMMENT '用户昵称',\n  `email` VARCHAR(50)  NOT NULL COMMENT '用户邮箱',\n  `phone` VARCHAR(20)  DEFAULT '' COMMENT '手机号',\n  `gender` TINYINT(4)  UNSIGNED DEFAULT '0' COMMENT '性别（0：男  1：女）',\n  `password` VARCHAR(100)  NOT NULL COMMENT '密码',\n  `age` TINYINT(4)  DEFAULT '0' COMMENT '年龄',\n  `create_time` DATETIME  DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',\n  `update_time` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',\n  PRIMARY KEY (`id`)\n) ENGINE=INNODB DEFAULT CHARSET=utf8mb4 COMMENT='app用户表'\n\n\n-- 插入100万数据b (函数)\n\nDELIMITER $$ -- 写函数之前必须要写，标志\nCREATE FUNCTION mock_data()\nRETURNS INT\nBEGIN\n  DECLARE num INT DEFAULT 1000000;\n  DECLARE i INT DEFAULT 0;\n  WHILE i\u003cnum DO\n    INSERT INTO app_user(`name`,`email`,`phone`,`gender`,`password`,`age`)\n    VALUES(CONCAT('用户',i),'123345@qq.com',CONCAT('18',FLOOR(RAND()*((999999999-100000000)+100000000))),FLOOR(RAND()*2),UUID(),FLOOR(RAND()*100));\n    SET i = i+1;\n  END WHILE;\n  RETURN i;\nEND;\n\n-- 执行函数\nSELECT mock_data();\n\nSELECT * FROM app_user;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220294-rq8786z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220294-rq8786z","updated":"20220618220294"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"测试","Properties":{"id":""}}]},{"ID":"20220618220295-ysuxkqz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220295-ysuxkqz","updated":"20220618220295"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- 加索引前\nSELECT * FROM app_user WHERE `name` = '用户9999'; -- 12.554 sec\nEXPLAIN SELECT * FROM app_user WHERE `name` = '用户9999';\n\n-- 创建索引\n-- id_表名_字段名  索引名\n-- CREATE INDEX 索引名 ON 表名(`字段名`);\nCREATE INDEX id_app_user_name ON app_user(`name`);\n -- 加索引后\nSELECT * FROM app_user WHERE `name` = '用户9999'; -- 0sec\nEXPLAIN SELECT * FROM app_user WHERE `name` = '用户9999';\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220296-zxomvrr","Type":"NodeParagraph","Properties":{"id":"20220618220296-zxomvrr","updated":"20220618220296"},"Children":[{"Type":"NodeText","Data":"无索引的寻找结果，一共找了很多数据才找到用户9999","Properties":{"id":""}}]},{"ID":"20220618220297-avmsire","Type":"NodeParagraph","Properties":{"id":"20220618220297-avmsire","updated":"20220618220297"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/索引-20220618220728-5otn5t9.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220298-r1sz0lv","Type":"NodeParagraph","Properties":{"id":"20220618220298-r1sz0lv","updated":"20220618220298"},"Children":[{"Type":"NodeText","Data":"添加索引后就只找了这一条数据","Properties":{"id":""}}]},{"ID":"20220618220299-4d0yer9","Type":"NodeParagraph","Properties":{"id":"20220618220299-4d0yer9","updated":"20220618220299"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/索引1-20220618220728-x2is2ya.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220300-35xsjnc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220300-35xsjnc","updated":"20220618220300"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.索引原则","Properties":{"id":""}}]},{"ID":"20220618220301-qa95zj7","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220301-qa95zj7","updated":"20220618220301"},"Children":[{"ID":"20220618220302-igh9pyc","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220302-igh9pyc","updated":"20220618220302"},"Children":[{"ID":"20220618220303-ramk4co","Type":"NodeParagraph","Properties":{"id":"20220618220303-ramk4co","updated":"20220618220303"},"Children":[{"Type":"NodeText","Data":"索引不是越多越好","Properties":{"id":""}}]}]},{"ID":"20220618220304-l5sld4p","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220304-l5sld4p","updated":"20220618220304"},"Children":[{"ID":"20220618220305-nszbef5","Type":"NodeParagraph","Properties":{"id":"20220618220305-nszbef5","updated":"20220618220305"},"Children":[{"Type":"NodeText","Data":"不要对经常变动的数据加索引","Properties":{"id":""}}]}]},{"ID":"20220618220306-p5f0i9h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220306-p5f0i9h","updated":"20220618220306"},"Children":[{"ID":"20220618220307-xz1bpv7","Type":"NodeParagraph","Properties":{"id":"20220618220307-xz1bpv7","updated":"20220618220307"},"Children":[{"Type":"NodeText","Data":"小数据量的表不需要加索引","Properties":{"id":""}}]}]},{"ID":"20220618220308-cx6kw1y","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220308-cx6kw1y","updated":"20220618220308"},"Children":[{"ID":"20220618220309-d1x0uet","Type":"NodeParagraph","Properties":{"id":"20220618220309-d1x0uet","updated":"20220618220309"},"Children":[{"Type":"NodeText","Data":"索引一般加载常用来查询的字段上","Properties":{"id":""}}]}]}]},{"ID":"20220618220310-zwuz1ib","Type":"NodeParagraph","Properties":{"id":"20220618220310-zwuz1ib","updated":"20220618220310"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"http://blog.codinglabs.org/articles/theory-of-mysql-index.html","TextMarkTextContent":"MySQL索引背后的数据结构及算法原理"}]},{"ID":"20220618220311-1fizptm","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220311-1fizptm","updated":"20220618220311"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"用户权限管理","Properties":{"id":""}}]},{"ID":"20220618220312-xckcour","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220312-xckcour","updated":"20220618220312"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"可视化授权","Properties":{"id":""}}]},{"ID":"20220618220313-v16zdy0","Type":"NodeParagraph","Properties":{"id":"20220618220313-v16zdy0","updated":"20220618220313"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/授权-20220618220728-sqf6t66.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220314-qbqou2e","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220314-qbqou2e","updated":"20220618220314"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"命令行授权","Properties":{"id":""}}]},{"ID":"20220618220315-pdayu04","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220315-pdayu04","updated":"20220618220315"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- 创建用户\nCREATE USER xxx IDENTIFIED BY '123456';\n\n-- 修改密码(修改当前用户密码)\nSET PASSWORD = PASSWORD('123456');\n\n-- 修改密码(修改指定用户密码)\nSET PASSWORD FOR xxx = PASSWORD('123456');\n\n\n-- 重命名  RENAME 原名子 zyy TO 新名字;\nRENAME USER zyy TO xxx;\n\n\n-- 用户授权  ALL PRIVILEGES 全部的权限，库，表\n\n-- ALL PRIVILEGES 和root用户的区别是除了不能给别人授权，其他都能干\nGRANT ALL PRIVILEGES ON *.* TO xxx;\n\n-- 查询权限  \nSHOW GRANTS FOR xxx; -- 查看指定用户的权限\n\nSHOW GRANTS FOR root@localhost; -- 查看root用户的权限\n\n-- 撤销权限   REVOKE哪些权限，在哪个库，给谁撤销\nREVOKE ALL PRIVILEGES ON *.* FROM xxx;\n\n-- 删除用户\nDROP USER xxx;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220316-68d3vb0","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220316-68d3vb0","updated":"20220618220316"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL备份","Properties":{"id":""}}]},{"ID":"20220618220317-1brazun","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220317-1brazun","updated":"20220618220317"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"可视化备份","Properties":{"id":""}}]},{"ID":"20220618220318-wvrn5rs","Type":"NodeBlockquote","Properties":{"id":"20220618220318-wvrn5rs","updated":"20220618220318"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220319-k5jyry0","Type":"NodeParagraph","Properties":{"id":"20220618220319-k5jyry0","updated":"20220618220319"},"Children":[{"Type":"NodeText","Data":"选择备份数据库后其他的内容都是默认的，除了保存地址","Properties":{"id":""}}]}]},{"ID":"20220618220320-2xwwnnf","Type":"NodeParagraph","Properties":{"id":"20220618220320-2xwwnnf","updated":"20220618220320"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/备份-20220618220728-dd6q0hc.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220321-svo2wb1","Type":"NodeParagraph","Properties":{"id":"20220618220321-svo2wb1","updated":"20220618220321"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/备份2-20220618220728-xh3tlzp.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220322-cblugbc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220322-cblugbc","updated":"20220618220322"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"命令行备份","Properties":{"id":""}}]},{"ID":"20220618220323-6oqcajr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220323-6oqcajr","updated":"20220618220323"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--一张表 mysqldump -h主机 -u用户名 -p密码 数据库 表名 \u003e物理磁盘位置/文件名\nmysqldump -hlocalhost -uroot -p123456 school student \u003eD:/a.sql\n\n--多张表 mysqldump -h主机 -u用户名 -p密码 数据库 表名1 表名2 \u003e物理磁盘位置/文件名\nmysqldump -hlocalhost -uroot -p123456 school student result \u003eD:/a.sql\n\n--数据库 mysqldump -h主机 -u用户名 -p密码 数据库 \u003e物理磁盘位置/文件名\nmysqldump -hlocalhost -uroot -p123456 school \u003eD:/a.sql\n\n--导入\n--登录的情况下，切换到指定的数据库\nsource 备份文件\n--也可以这样\nmysql -u用户名 -p密码 库名\u003c备份文件\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220324-lg19p42","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220324-lg19p42","updated":"20220618220324"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库三大范式","Properties":{"id":""}}]},{"ID":"20220618220325-rdvy9xg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220325-rdvy9xg","updated":"20220618220325"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"为什么需要数据规范化？"}]},{"ID":"20220618220326-o89wr0e","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220326-o89wr0e","updated":"20220618220326"},"Children":[{"ID":"20220618220327-gpnjrlk","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220327-gpnjrlk","updated":"20220618220327"},"Children":[{"ID":"20220618220328-him9gpn","Type":"NodeParagraph","Properties":{"id":"20