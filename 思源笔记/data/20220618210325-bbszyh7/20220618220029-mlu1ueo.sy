Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"alter table 表名 drop 列名;\nalter table student drop high;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220135-cuox0kb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220135-cuox0kb","updated":"20220618220135"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据的增删改查(curd)","Properties":{"id":""}}]},{"ID":"20220618220136-5ro30cw","Type":"NodeParagraph","Properties":{"id":"20220618220136-5ro30cw","updated":"20220618220136"},"Children":[{"Type":"NodeText","Data":"创建(create)、更新(update)、读取(retrieve)、删除(delete)","Properties":{"id":""}}]},{"ID":"20220618220137-7o9f798","Type":"NodeParagraph","Properties":{"id":"20220618220137-7o9f798","updated":"20220618220137"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/数据库student-20220618220727-usvf3nx.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220138-ney4xu0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220138-ney4xu0","updated":"20220618220138"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"增","Properties":{"id":""}}]},{"ID":"20220618220139-tsymqi5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220139-tsymqi5","updated":"20220618220139"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--向students表插入一个学生信息（序号上的增添方式有这三种）\ninsert into students values(0,\"小李飞刀\",20,\"女\",1,\"1990-01-01\");\ninsert into students values(null,\"小李飞刀\",20,\"女\",1,\"1990-01-01\");\ninsert into students values(default,\"小李飞刀\",20,\"女\",1,\"1990-01-01\");\n\n--性别枚举中可以从下标1开始，因为枚举的是个集合，只能在这个范围里选\n                      gender enum(\"男\",\"女\",\"中性\",\"保密\") default \"保密\",\ninsert into students values(default,\"小李飞刀\",20,1,1,\"1990-01-01\"); 1的话表示就是男的\n\n--部分插入\ninsert into 表名(列1,...)values(值1,...)\ninsert into students (name, gender) values (\"小乔\"，2);\n\n--多行插入\ninsert into students (name, gender) values (\"小乔\"，2),(\"貂蝉\",2);    # 可以同时添加两人\ninsert into students values(default,\"西施\",20,\"女\",1,\"1990-01-01\"),(default,\"西施\",20,\"女\"，1,\"1990-01-01\")\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220140-ifsnrai","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220140-ifsnrai","updated":"20220618220140"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"修","Properties":{"id":""}}]},{"ID":"20220618220141-qkkwm9v","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220141-qkkwm9v","updated":"20220618220141"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"update 表名 set 列1=值1，列2=值2... where 条件;\nupdate students set gender=1 where id=3;  (一般是改id，因为改其他选项不好确定对象)\n--修改多个\nupdate students set gender=1,name=\"小李飞刀\" where id=1;\n--操作符\n--1.如果要规定不等于哪些地方是何种情况   !=  或者  \u003c\u003e  \nupdate students set gender=1 where id \u003c\u003e 1;\nupdate students set gender=1 where id != 1;\n--2.规定区间 between\nupdate students set gender=1 where id between 2 and 5; (2到5为闭区间)\n--3.多条件确定 and or\nupdate students set gender=1 where id=1 and name=\"小李飞刀\";\nupdate students set gender=1 where id = 1 or name=\"小乔\";(一改就全改了，慎用)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220142-1s8unuq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220142-1s8unuq","updated":"20220618220142"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"查（最重点）","Properties":{"id":""}}]},{"ID":"20220618220143-xqvjilq","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220143-xqvjilq","updated":"20220618220143"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"select完整语法","Properties":{"id":""}}]},{"ID":"20220618220144-3wdkfma","Type":"NodeParagraph","Properties":{"id":"20220618220144-3wdkfma","updated":"20220618220144"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"mark","TextMarkTextContent":"必须严格按照顺序来，不能更改语法顺序"}]},{"ID":"20220618220145-foom4m6","Type":"NodeParagraph","Properties":{"id":"20220618220145-foom4m6","updated":"20220618220145"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/完整-20220618220727-t9eaqw7.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220146-jx6jny9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c2hlbGw=","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220146-jx6jny9","updated":"20220618220146"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c2hlbGw=","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#查询所有列\nselect * from students;\n#定条件查询\nselect * from students where name=\"小李飞刀\";\nselect * from students where id\u003c6;\n#查询指定列\nselect 列1，列2，...from 表名;\nselect name,gender from students;\n#可以使用as为列或表指定明\nselect 字段[as 别名],字段[as 别名] from 数据表 where...;\nselect name as 姓名,gender as 性别 from students; #这里的姓名和性别不需要加引号\n#函数 cantact(a,b) 为每一个字段增加一个别名 这里的所有人表示表头名字,如下图\nselect concat (\"别名：\",[列名]) as [别名] from [表名]; \nselect concat(\"姓名：\",name) as 所有人 from student;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220147-adhh72k","Type":"NodeParagraph","Properties":{"id":"20220618220147-adhh72k","updated":"20220618220147"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/表头-20220618220728-bwjkhxn.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220148-fpq9qqj","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220148-fpq9qqj","updated":"20220618220148"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"去重","Properties":{"id":""}}]},{"ID":"20220618220149-ou3eypb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220149-ou3eypb","updated":"20220618220149"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"--去重distinct ， 比如一个学生参加考试的表格，想看哪些学生参加了考试，但是一个学生可能参加了多门，如果普通的select name可能会出现重复\nselect distinct 字段 from 表名\nselect distinct name from student;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220150-tdxl6eu","Type":"NodeParagraph","Properties":{"id":"20220618220150-tdxl6eu","updated":"20220618220150"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/去重-20220618220728-ar6w6cr.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220151-lyxm3b0","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618220151-lyxm3b0","updated":"20220618220151"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"用于计算","Properties":{"id":""}}]},{"ID":"20220618220152-rgw3hag","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220152-rgw3hag","updated":"20220618220152"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Ty