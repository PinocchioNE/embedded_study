,"Num":-1},"Properties":{"id":"20220618220221-tmohw3s","updated":"20220618220909"},"Children":[{"ID":"20220618220222-aw58k27","Type":"NodeListItem","Data":"-","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220222-aw58k27","updated":"20220618220909"},"Children":[{"ID":"20220618220223-sfeq99w","Type":"NodeParagraph","Properties":{"id":"20220618220223-sfeq99w","updated":"20220618220223"},"Children":[{"Type":"NodeText","Data":"比如银行转账，A给B转账200元，要么一起成功要么一起失败"}]},{"ID":"20220618220857-7fvobm0","Type":"NodeParagraph","Properties":{"id":"20220618220857-7fvobm0","updated":"20220618220909"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"原子性.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/原子性-20220618220909-82xtmtr.png"},{"Type":"NodeCloseParen"}]}]}]}]},{"ID":"20220618220225-7e0fdd6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220225-7e0fdd6","updated":"20220618220225"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"一致性（Consistency）","Properties":{"id":""}}]},{"ID":"20220618220226-svydsxe","Type":"NodeBlockquote","Properties":{"id":"20220618220226-svydsxe","updated":"20220618220226"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220227-74qppv9","Type":"NodeParagraph","Properties":{"id":"20220618220227-74qppv9","updated":"20220618220227"},"Children":[{"Type":"NodeText","Data":"事务前后数据的完整性必须保持一致。","Properties":{"id":""}}]}]},{"ID":"20220618220228-ve3shph","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220228-ve3shph","updated":"20220618220228"},"Children":[{"ID":"20220618220229-oysz8vm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618220229-oysz8vm","updated":"20220618220229"},"Children":[{"ID":"20220618220230-j5vk0ix","Type":"NodeParagraph","Properties":{"id":"20220618220230-j5vk0ix","updated":"20220618220230"},"Children":[{"Type":"NodeText","Data":"表示事务完成后，必须符合逻辑运算，比如上面的银行转账，操作完成前A:800 B:200, 操作完成后A:600 B:400","Properties":{"id":""}}]}]}]},{"ID":"20220618220231-czfu0rw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220231-czfu0rw","updated":"20220618220231"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"隔离性（Isolation）","Properties":{"id":""}}]},{"ID":"20220618220232-k212rir","Type":"NodeBlockquote","Properties":{"id":"20220618220232-k212rir","updated":"20220618220232"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220233-ssvxfn8","Type":"NodeParagraph","Properties":{"id":"20220618220233-ssvxfn8","updated":"20220618220233"},"Children":[{"Type":"NodeText","Data":"事务的隔离性是多个用户并发访问数据库时，数据库为每一个用户开启的事务，不能被其他事务的操作数据所干扰，多个并发事务之间要相互隔离。","Properties":{"id":""}}]}]},{"ID":"20220618220234-nln7exw","Type":"NodeParagraph","Properties":{"id":"20220618220234-nln7exw","updated":"20220618220234"},"Children":[{"Type":"NodeText","Data":"事务一）A向B转账200","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"事务二）C向B转账100","Properties":{"id":""}}]},{"ID":"20220618220235-z3hfslp","Type":"NodeParagraph","Properties":{"id":"20220618220235-z3hfslp","updated":"20220618220235"},"Children":[{"Type":"NodeText","Data":"两个事务同时进行，其中一个事务读取到另外一个事务还没有提交的数据，执行步骤如图所示，按照数字顺序执行","Properties":{"id":""}}]},{"ID":"20220618220236-b1kj5qd","Type":"NodeParagraph","Properties":{"id":"20220618220236-b1kj5qd","updated":"20220618220236"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/隔离性-20220618220728-kxl4gop.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220237-evhe0qc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220237-evhe0qc","updated":"20220618220237"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"持久性（Durability）","Properties":{"id":""}}]},{"ID":"20220618220238-2zgynik","Type":"NodeBlockquote","Properties":{"id":"20220618220238-2zgynik","updated":"20220618220238"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220239-32a7wc1","Type":"NodeParagraph","Properties":{"id":"20220618220239-32a7wc1","updated":"20220618220239"},"Children":[{"Type":"NodeText","Data":"持久性是指一个事务一旦被提交，它对数据库中数据的改变就是永久性的，接下来即使数据库发生故障也不应该对其有任何影响","Properties":{"id":""}}]}]},{"ID":"20220618220240-b2utt4k","Type":"NodeBlockquote","Properties":{"id":"20220618220240-b2utt4k","updated":"20220618220240"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220241-v11rfsr","Type":"NodeParagraph","Properties":{"id":"20220618220241-v11rfsr","updated":"20220618220241"},"Children":[{"Type":"NodeText","Data":"表示事务结束后的数据不随着外界原因导致数据丢失","Properties":{"id":""}}]},{"ID":"20220618220242-9b1lu3j","Type":"NodeParagraph","Properties":{"id":"20220618220242-9b1lu3j","updated":"20220618220242"},"Children":[{"Type":"NodeText","Data":"操作前A：800，B：200","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"操作后A：600，B：400","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"如果在操作前（事务还没有提交）服务器宕机或者断电，那么重启数据库以后，数据状态应该为","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"A：800，B：200","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"如果在操作后（事务已经提交）服务器宕机或者断电，那么重启数据库以后，数据状态应该为","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"A：600，B：400","Properties":{"id":""}}]}]},{"ID":"20220618220243-zsqwnhy","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220243-zsqwnhy","updated":"20220618220243"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"脏读","Properties":{"id":""}}]},{"ID":"20220618220244-fzenomy","Type":"NodeBlockquote","Properties":{"id":"20220618220244-fzenomy","updated":"20220618220244"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220245-9l0y7yb","Type":"NodeParagraph","Properties":{"id":"20220618220245-9l0y7yb","updated":"20220618220245"},"Children":[{"Type":"NodeText","Data":"指一个事务读取了另外一个事务未提交的数据。","Properties":{"id":""}}]}]},{"ID":"20220618220246-2xo8c60","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220246-2xo8c60","updated":"20220618220246"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"不可重复读","Properties":{"id":""}}]},{"ID":"20220618220247-r1uxvi7","Type":"NodeBlockquote","Properties":{"id":"20220618220247-r1uxvi7","updated":"20220618220247"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220248-fd897a5","Type":"NodeParagraph","Properties":{"id":"20220618220248-fd897a5","updated":"20220618220248"},"Children":[{"Type":"NodeText","Data":"在一个事务内读取表中的某一行数据，多次读取结果不同。（这个不一定是错误，只是某些场合不对）","Properties":{"id":""}}]},{"ID":"20220618220249-uy7t14j","Type":"NodeParagraph","Properties":{"id":"20220618220249-uy7t14j","updated":"20220618220249"},"Children":[{"Type":"NodeText","Data":"比如查询统计结果时B为300，但生成报表时有人给B转了300结果就变成了500，导致两次数据不一样","Properties":{"id":""}}]}]},{"ID":"20220618220250-i4ty5e6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618220250-i4ty5e6","updated":"20220618220250"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"虚读（幻读）","Properties":{"id":""}}]},{"ID":"20220618220251-bbfxhmk","Type":"NodeBlockquote","Properties":{"id":"20220618220251-bbfxhmk","updated":"20220618220251"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220252-400pi4w","Type":"NodeParagraph","Properties":{"id":"20220618220252-400pi4w","updated":"20220618220252"},"Children":[{"Type":"NodeText","Data":"是指在一个事务内读取到了别的事务插入的数据，导致前后读取数量总量不一致。","Properties":{"id":""}}]},{"ID":"20220618220253-18xzpvw","Type":"NodeParagraph","Properties":{"id":"20220618220253-18xzpvw","updated":"20220618220253"},"Children":[{"Type":"NodeText","Data":"比如在读ABC的数据时读取到了D的数据导致前后读取的数据总量不一致","Properties":{"id":""}}]}]},{"ID":"20220618220254-m487d43","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220254-m487d43","updated":"20220618220254"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"测试事务实现转账","Properties":{"id":""}}]},{"ID":"20220618220255-rh03rmg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220255-rh03rmg","updated":"20220618220255"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"一组事务的基本流程","Properties":{"id":""}}]},{"ID":"20220618220256-6ocvmxe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220256-6ocvmxe","updated":"20220618220256"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"-- mysql 是默认开启事务自动提交\n\n-- 关闭\nSET autocommit = 0; \n-- 开启（默认的）\nSET autocommit = 1;\n\n-- 手动处理事务\nSET autocommit = 0;  -- 关闭自动提交\n\n-- 事务开启\nSTART TRANSACTION;  -- 标记一个事务的开始，从这个之后的sql都在同一个事务内\n\nINSERT XX\n...\n...\nINSERT XX --如果其中有一个insert失败则全都会提交失败\n\n-- 提交 ： 持久化\nCOMMIT;\n-- 回滚 ： 回到的原来的样子（失败）\nROLLBACK;\n-- 事务结束\nSET autocommit = 1; -- 开启自动提交\n\n-- 了解\nSAVEPOINT 保存点名 -- 设置一个事务的保存点\nROLLBACK TO SAVEPOINT 保存点名 -- 回滚到保存点\nRELEASE SAVEPOINT 保存点名 -- 撤销保存点\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220257-yfqsobe","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618220257-yfqsobe","updated":"20220618220257"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"测试银行转账","Properties":{"id":""}}]},{"ID":"20220618220258-v6lm920","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618220258-v6lm920","updated":"20220618220258"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"CREATE DATABASE bank CHARACTER SET utf8 COLLATE utf8_general_ci\nUSE bank\n\nCREATE TABLE account(\n  id INT(10) NOT NULL AUTO_INCREMENT,\n  `name` VARCHAR(30) NOT NULL,\n  money DECIMAL(9,2) NOT NULL,\n  -- a指定指定小数点左边和右边可以存储的十进制数字的最大个数，最大精度38。\n  -- b指定小数点右边可以存储的十进制数字的最大个数。小数位数必须是从 0 到 a之间的值。默认小数位数是 0。\n  PRIMARY KEY (id)\n)ENGINE=INNODB DEFAULT CHARSET=utf8\n\nINSERT INTO account(`name`,`money`) VALUES('A',2000.00),('B',10000.00)\n\n-- 模拟转账事务\nSET autocommit = 0; -- 关闭自动提交\nSTART TRANSACTION -- 开启一个事务\n\n--注意：事务要一个一个执行，一次性全选执行也是会失败的\nUPDATE account SET money=money-500 WHERE `name`='A' -- A减500\nUPDATE account SET money=money+500 WHERE `name`='B' -- A减500\n\nCOMMIT; -- 提交事务，并且如果成功的话就会被持久化，即后面的回滚不会生效\nROLLBACK; -- 回滚，如果事务失败就会回到最初的值\n\nSET autocommit = 1; -- 恢复默认值\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618220259-zpjs3b3","Type":"NodeParagraph","Properties":{"id":"20220618220259-zpjs3b3","updated":"20220618220259"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/事务-20220618220728-b6thbm8.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618220260-31cwwnh","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618220260-31cwwnh","updated":"20220618220260"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"索引及索引的分类","Properties":{"id":""}}]},{"ID":"20220618220261-b5szsxr","Type":"NodeBlockquote","Properties":{"id":"20220618220261-b5szsxr","updated":"20220618220261"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618220262-6q8b6oq","Type":"NodeParagraph","Properties":{"id":"20220618220262-6q8b6oq","updated":"20220618220262"},"Children":[{"Type":"NodeText","Data":"Msql官方对索引的定义为：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"索引（index）是帮助MySQL高效获取数据的数据结构"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220618220263-ij2tzvm","Type":"NodeParagraph","Properties":{"id":"20220618220263-ij2tzvm","updated":"20220618220263"},"Children":[{"Type":"NodeText","Data":"提取句子主干，就可以得到索引的本质：索引是数据结构。","Prop