ulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-parigma","updated":"20250304084246"},"Children":[{"ID":"20250304084246-6kf4jb4","Type":"NodeParagraph","Properties":{"id":"20250304084246-6kf4jb4","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"状态记录"}]}]},{"ID":"20250304084246-gpgsb5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-gpgsb5l","updated":"20250304084246"},"Children":[{"ID":"20250304084246-zi7q13u","Type":"NodeParagraph","Properties":{"id":"20250304084246-zi7q13u","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"循环次数记录"}]}]}]},{"ID":"20250304084246-t1y4ers","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250304084246-t1y4ers","updated":"20250304084246"},"Children":[{"ID":"20250304084246-4dx9slf","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250304084246-4dx9slf","updated":"20250304084246"},"Children":[{"ID":"20250304084246-1ktksma","Type":"NodeParagraph","Properties":{"id":"20250304084246-1ktksma","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"运行时数据"}]}]}]},{"ID":"20250304084246-v9n2v8l","Type":"NodeList","ListData":{},"Properties":{"id":"20250304084246-v9n2v8l","updated":"20250304084246"},"Children":[{"ID":"20250304084246-eizwnvv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-eizwnvv","updated":"20250304084246"},"Children":[{"ID":"20250304084246-n7fhj3s","Type":"NodeParagraph","Properties":{"id":"20250304084246-n7fhj3s","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"电压数据"}]}]},{"ID":"20250304084246-rcts7r9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-rcts7r9","updated":"20250304084246"},"Children":[{"ID":"20250304084246-2tb9x8i","Type":"NodeParagraph","Properties":{"id":"20250304084246-2tb9x8i","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"电流数据"}]}]},{"ID":"20250304084246-g44pe3h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-g44pe3h","updated":"20250304084246"},"Children":[{"ID":"20250304084246-63hx73y","Type":"NodeParagraph","Properties":{"id":"20250304084246-63hx73y","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"温度数据"}]}]},{"ID":"20250304084246-aj1e0jd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250304084246-aj1e0jd","updated":"20250304084246"},"Children":[{"ID":"20250304084246-c049kkk","Type":"NodeParagraph","Properties":{"id":"20250304084246-c049kkk","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"状态标志"}]}]}]}]},{"ID":"20250226101254-16crjm3","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250226101254-16crjm3","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"开关电源常用词"}]},{"ID":"20250226101314-qhihbrx","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250226101314-qhihbrx","updated":"20250226101314"},"Children":[{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://www.cnblogs.com/smilingfrog/p/4618295.html","TextMarkATitle":"发布于 2015-07-03 12:24","TextMarkTextContent":"开关电源中的一些英文缩写"}]},{"ID":"20250226101312-k8j1c9j","Type":"NodeBlockquote","Properties":{"id":"20250226101312-k8j1c9j","updated":"20250226101314"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250226101314-a1uyj34","Type":"NodeParagraph","Properties":{"id":"20250226101314-a1uyj34","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"OCP over current protection 过流保护"}]},{"ID":"20250226101314-7t63myk","Type":"NodeParagraph","Properties":{"id":"20250226101314-7t63myk","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"OLP over load protection 过载保护"}]},{"ID":"20250226101314-9hybpjl","Type":"NodeParagraph","Properties":{"id":"20250226101314-9hybpjl","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"OVP over voltage protection 过压保护"}]},{"ID":"20250226101314-ngzpiw7","Type":"NodeParagraph","Properties":{"id":"20250226101314-ngzpiw7","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"OTP over temperature protection 过温保护"}]},{"ID":"20250226101314-e88vvo8","Type":"NodeParagraph","Properties":{"id":"20250226101314-e88vvo8","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"ESD eletro-static discharge 静电释放"}]},{"ID":"20250226101314-50wxah7","Type":"NodeParagraph","Properties":{"id":"20250226101314-50wxah7","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"UVLO under voltage lock out 欠压闭锁"}]},{"ID":"20250226101314-jjfgunh","Type":"NodeParagraph","Properties":{"id":"20250226101314-jjfgunh","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"PFC power factor correcion 功率因数校正"}]},{"ID":"20250226101314-et7te4b","Type":"NodeParagraph","Properties":{"id":"20250226101314-et7te4b","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"burst mode 跳周期模式 一般在空载下，启动几个周期，然后关闭几个周期，以减少空载待机功耗。"}]},{"ID":"20250226101314-0rny0i2","Type":"NodeParagraph","Properties":{"id":"20250226101314-0rny0i2","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"hiccup mode 打嗝模式，异常状态下的反复重启"}]},{"ID":"20250226101314-vcu2v2c","Type":"NodeParagraph","Properties":{"id":"20250226101314-vcu2v2c","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"Hiccup-mode is a method of operation in a power supply whose purpose is to protect the power supply from being damaged during an over-current fault condition. It also enables the power supply to restart when the fault is removed."}]},{"ID":"20250226101314-lgv60aw","Type":"NodeParagraph","Properties":{"id":"20250226101314-lgv60aw","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"source current 拉电流 输出端向外电路流出的负载电流"}]},{"ID":"20250226101314-2psrxty","Type":"NodeParagraph","Properties":{"id":"20250226101314-2psrxty","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"sink current 灌电流 从外电路流入输出端的负载电流"}]},{"ID":"20250226101314-v8yy92q","Type":"NodeParagraph","Properties":{"id":"20250226101314-v8yy92q","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"quiescent current 静态电流"}]},{"ID":"20250226101314-v82ufha","Type":"NodeParagraph","Properties":{"id":"20250226101314-v82ufha","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"RCD residual current devices 剩余电流动作保护器"}]},{"ID":"20250226101314-oerdm4i","Type":"NodeParagraph","Properties":{"id":"20250226101314-oerdm4i","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"MOSFET栅极与源极间电阻"}]},{"ID":"20250226101314-kkz3sf7","Type":"NodeParagraph","Properties":{"id":"20250226101314-kkz3sf7","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"一、为场效应管提供偏置电压；二、起到泻放电阻的作用——保护栅极G-源极S；第一个作用好理解，这里解释一下第二个作用的原理——保护栅极G-源极S：场效应管的G-S极间的电阻值是很大的，这样只要有少量的静电就能使他的G-S极间的等效电容两端产生很高的电压，如果不及时把这些少量的静电泻放掉，他两端的高压就有可能使场效应管产生误动作，甚至有可能击穿其G-S极；这时栅极与源极之间加的电阻就能把上述的静电泻放掉，从而起到了保护场效应管的作用。"}]},{"ID":"20250226101314-ckicnpk","Type":"NodeParagraph","Properties":{"id":"20250226101314-ckicnpk","updated":"20250226101314"},"Children":[{"Type":"NodeText","Data":"MOS管栅极与漏极和源极之间的绝缘电阻很高，绝缘层很薄，栅极很容易积累电荷把绝缘层击穿而损坏MOS管，在使用过程中如果有较高电压加到栅极也要击穿绝缘层而损坏MOS管，所以要在MOS管栅极并联稳压管以限制栅极电压在稳压管稳压值以下，保护MOS管栅极不被击穿。MOS管栅极并联的电阻是为了释放栅极电荷，不让电荷积累。总之与MOS管栅极并联的电阻稳压管起保护MOS管栅极的作用。"}]}]},{"ID":"20250218130942-3ulenks","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250218130942-3ulenks","updated":"20250219101045"},"Children":[{"Type":"NodeText","Data":"SoC"}]},{"ID":"20250218131011-rcfevnl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250218131011-rcfevnl","updated":"20250218163145"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"BMS（Battery Management System）软件的流程通常包括电池监测、充放电控制、保护机制、SOC（State of Charge）估算、均衡管理等功能。以下是一个嵌入式BMS软件的示例，涵盖 main 函数及各个功能块的代码，适用于基于 MCU（如 STM32）的开发。\n\nBMS 软件结构\n主函数 (main): 初始化系统，进入循环执行 BMS 逻辑。\nADC 采集 (adc.c): 读取电池电压、电流、温度等参数。\nSOC 估算 (soc.c): 计算当前电量百分比。\n充放电管理 (charge_discharge.c): 控制 MOSFET 进行充放电。\n保护功能 (protection.c): 过压、欠压、过流、短路等保护机制。\n均衡管理 (balance.c): 负责电池均衡，提高电池寿命。\n通信 (communication.c): 与外部设备（如 PC、MCU、CAN 总线等）通信。\n1. 主函数 (main.c)\nc\nCopy\nEdit\n#include \"includes.h\"\n\nvoid System_Init(void);\nvoid BMS_Task(void);\n\nint main(void)\n{\n    System_Init();  // 初始化系统（GPIO、ADC、I2C、UART、定时器等）\n  \n    while (1)\n    {\n        BMS_Task();  // 主要BMS任务，包括电压采样、SOC计算、保护等\n    }\n}\n\nvoid System_Init(void)\n{\n    ADC_Init();       // 初始化 ADC\n    UART_Init();      // 初始化串口通信\n    Timer_Init();     // 初始化定时器\n    Protection_Init();// 初始化保护机制\n}\n\nvoid BMS_Task(void)\n{\n    Read_Battery_Voltage();    // 读取电池电压\n    Read_Battery_Current();    // 读取电流\n    Read_Battery_Temperature();// 读取温度\n\n    SOC_Calculate();           // 计算当前 SOC 电量\n    Protection_Check();        // 保护功能检查\n    Charge_Discharge_Control();// 充放电控制\n    Balance_Control();         // 均衡管理\n\n    Communication_Process();   // 处理与外部设备通信\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250218163141-rfojp1s","Type":"NodeParagraph","Properties":{"id":"20250218163141-rfojp1s","updated":"20250218163141"}},{"ID":"20250219101040-zd39nx6","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250219101040-zd39nx6","updated":"20250225134315"},"Children":[{"Type":"NodeText","Data":"显示SoC"}]},{"ID":"20250219101048-qevu8r4","Type":"NodeParagraph","Properties":{"id":"20250219101048-qevu8r4","updated":"20250219101057"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: calc(100% - 8px);"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"20250219-101033"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/20250219-101033-20250219101048-wf2egj9.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: calc(100% - 8px);\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20250219101050-mk3915b","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250219101050-mk3915b","updated":"20250225150844"},"Children":[{"Type":"NodeText","Data":"安时积分法"}]},{"ID":"20250225134316-l9l93vo","Type":"NodeParagraph","Properties":{"id":"20250225134316-l9l93vo","updated":"20250225134530"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250225134530-3jfuvw2.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250225134533-bn8z4vl","Type":"NodeBlockquote","Properties":{"id":"20250225134533-bn8z4vl","updated":"20250225134631"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250225134631-rwbt6i2","Type":"NodeParagraph","Properties":{"id":"20250225134631-rwbt6i2","updated":"20250225134631"},"Children":[{"Type":"NodeText","Data":"(SOC_0)是初始SOC，(C_n)是电池的额定容量（单位为安时，Ah），(I(\\tau))是随时间变化的电流。简单来说，就是记录电池在充电或放电过程中的电流和时间，通过积分（在离散情况下可以用求和近似）来计算电池已经放出或充入的电量，再结合初始SOC来得到当前SOC"}]}]},{"ID":"20250225150837-4psjmdn","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250225150837-4psjmdn","updated":"20250225151912"},"Children":[{"Type":"NodeText","Data":"端电压和开路电压的关系"}]},{"ID":"20250225150845-9q9ec18","Type":"NodeBlockquote","Properties":{"id":"20250225150845-9q9ec18","updated":"20250225150847"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250225150846-d5ny36q","Type":"NodeParagraph","Properties":{"id":"20250225150846-d5ny36q","updated":"20250225150847"},"Children":[{"Type":"NodeText","Data":"端电压是实际测得的电压，开路电压等于电池静置一段时间后的端电压。如果通电流进行充放电，会出现极化电压和内阻电压，开路电压也会因为充放电发生改变。此时端电压等于变化后的开路电压加上极化电压和内阻电压，即Vt=EMF+Vh+Vp+Vr。（其中EMF+Vh = OCV）"}]}]},{"ID":"20250225151812-r33c4oc","Type":"NodeParagraph","Properties":{"id":"20250225151812-r33c4oc","updated":"20250225151812"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"开路电压（OCV, Open-Circuit Voltage）"},{"Type":"NodeText","Data":" 与 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"端电压（Terminal Voltage）"},{"Type":"NodeText","Data":" 的区别"}]},{"ID":"20250225151812-efotpl1","Type":"NodeTable","TableAligns":[0,0,0],"Properties":{"colgroup":"||","id":"20250225151812-efotpl1","updated":"20250225151812"},"Children":[{"Type":"NodeTableHead","Data":"thead","Children":[{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"对比项"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"开路电压（OCV）"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"端电压（Terminal Voltage）"}]}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"定义"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"电池在"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"无负载"},{"Type":"NodeText","Data":"情况下，两端的电压"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"电池在"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"连接负载"},{"Type":"NodeText","Data":"并工作时，两端的电压"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"测量条件"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"电池"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"未连接任何电路"},{"Type":"NodeText","Data":"（无电流流动）"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"电池"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"连接负载"},{"Type":"NodeText","Data":"（有电流流动）"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"影响因素"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"仅由电池的"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"化学特性"},{"Type":"NodeText","Data":"和SOC决定"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"受"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"化学特性、SOC、电流大小、内阻"},{"Type":"NodeText","Data":"等因素影响"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"测量方式"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"让电池静置一段时间（通常几分钟至数小时）后测量两端电压"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"在电池放电或充电过程中，直接测量两端电压"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"数值大小"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"大于或等于"},{"Type":"NodeText","Data":"端电压"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"小于或等于"},{"Type":"NodeText","Data":"开路电压（因内阻产生的电压降）"}]}]}]},{"ID":"20250225151906-vgkffto","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250225151906-vgkffto","updated":"20250225152228"},"Children":[{"Type":"NodeText","Data":"极化效应（Polarization Effect）"}]},{"ID":"20250225151906-nd569e1","Type":"NodeParag