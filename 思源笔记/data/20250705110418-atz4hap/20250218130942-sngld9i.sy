{"ID":"20250218130942-sngld9i","Spec":"1","Type":"NodeDocument","Properties":{"id":"20250218130942-sngld9i","title":"BMS","type":"doc","updated":"20250414142500"},"Children":[{"ID":"20250226100412-tkvubj3","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250226100412-tkvubj3","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"bms编写流程"}]},{"ID":"20250226100423-iv4fmy6","Type":"NodeBlockquote","Properties":{"id":"20250226100423-iv4fmy6","updated":"20250304084246"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250226100424-v0xj2mo","Type":"NodeParagraph","Properties":{"id":"20250226100424-v0xj2mo","updated":"20250226100424"},"Children":[{"Type":"NodeText","Data":"BMS代码模块\n├── 数据采集层（已完成电压/电流）\n│   ├── 电压采集（单节/整包）\n│   ├── 电流采集（充放电方向）\n│   └── 温度采集（电芯、环境、MOS温度）\n├── 状态估算层\n│   ├── SOC（荷电状态）估算\n│   ├── SOH（健康状态）估算\n│   └── SOP（功率状态）估算\n├── 保护控制层\n│   ├── 过压/欠压保护\n│   ├── 过流/短路保护\n│   ├── 过温保护\n│   └── 均衡控制\n├── 通信层\n│   ├── CAN/UART/RS485协议\n│   └── 数据上报（PC端/上位机）\n└── 硬件驱动层\n    ├── ADC驱动（电压/电流）\n    ├── GPIO控制（继电器、MOS管）\n    └── 温度传感器驱动（NTC/DS18B20）"}]},{"ID":"20250304084245-fv7k3z2","Type":"NodeParagraph","Properties":{"id":"20250304084245-fv7k3z2","updated":"20250304084245"}},{"ID":"20250304084246-2zbcyhr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20250304084246-2zbcyhr","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"关键功能实现"}]},{"ID":"20250304084246-v8wdmb3","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250304084246-v8wdmb3","updated":"20250304084246"},"Children":[{"ID":"20250304084246-29bmkrx","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250304084246-29bmkrx","updated":"20250304084246"},"Children":[{"ID":"20250304084246-sqez2mo","Type":"NodeParagraph","Properties":{"id":"20250304084246-sqez2mo","updated":"20250304084246"},"Children":[{"Type":"NodeText","Data":"电池保护功能"}]}]}]},{"ID":"20250304084246-5g4bww2","Type