","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20240423141451-mdtfaah","updated":"20240731133526"},"Children":[{"Type":"NodeText","Data":"转速"}]},{"ID":"20240530090854-m6vvy62","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240530090854-m6vvy62","updated":"20240731133526"},"Children":[{"Type":"NodeText","Data":"转速的原理"}]},{"ID":"20240530101459-hv44xc2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240530101459-hv44xc2","updated":"20240530101515"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"𝑉_𝑖𝑛=𝑉_𝑎𝑑𝑐∗(𝑅_1+𝑅_2)/𝑅_1 ∗𝐾_𝑐𝑢𝑟𝑟𝑒𝑛𝑡\n𝑉_𝑖𝑛=电机电压\n𝑉_𝑎𝑑𝑐=电机采样电压ADC\n𝐾_𝑐𝑢𝑟𝑟𝑒𝑛𝑡=电流系数\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240530090900-i5sb889","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240530090900-i5sb889","updated":"20240530090856"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"case 100:\n\tbrush_algorithm.k_cur = brush_algorithm.sm_adc1;\n\tif(brush_algorithm.k_cur==0)\n\t{ \n\t\tbrush_algorithm.k_cur = 4096;\n\t}\n\telse \n\t{\n\t\tbrush_algorithm.k_cur = 4096 / brush_algorithm.k_cur; //100ms updata once\n\t}\n\tswitch_pwm_io(Brush_Floor_Detect.smotduty);\nbreak;\ncase 3: \n\tbrush_algorithm.v_bat = sadc.value_filtered[ADC_CH_smv]; //电机电压\n\n\n\t#ifdef NO_CURRENT_LINEAR\n\t\tbrush_algorithm.sm_adc = sadc.value_filtered[ADC_CH_smcs]; //电机电流\n\t#endif\n\tif(brush_algorithm.sm_adc \u003c= 0 )\n\t{\n\t\tbrush_algorithm.sm_adc =  4096;\n\t}\n\n\tbrush_algorithm.test_v_bat1 = (uint32_t)(brush_algorithm.v_bat * 825 * 11 / 1024) * brush_algorithm.k_cur ; //电压的采样电阻为11k \t \n\tswitch_pwm_io(Brush_Floor_Detect.smotduty);\n\n\tbreak;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240530091326-8mt90de","Type":"NodeBlockquote","Properties":{"id":"20240530091326-8mt90de","updated":"20240530090856"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240530091327-nrp6ri7","Type":"NodeParagraph","Properties":{"id":"20240530091327-nrp6ri7","updated":"20240530092016"},"Children":[{"Type":"NodeText","Data":"brush_algorithm.v_bat * 825 * 11 / 1024怎么换算的"}]},{"ID":"20240530092017-u6wvwgk","Type":"NodeParagraph","Properties":{"id":"20240530092017-u6wvwgk","updated":"20240530093113"},"Children":[{"Type":"NodeText","Data":"采样电阻（R1+R2）/ (R2) = 11"}]},{"ID":"20240530092018-2y05jbp","Type":"NodeParagraph","Properties":{"id":"20240530092018-2y05jbp","updated":"20240530092102"},"Children":[{"Type":"NodeText","Data":"电机的输入电压Vin = Vadc * （R1+R2）/ (R2)"}]},{"ID":"20240530092106-5yiyc2c","Type":"NodeParagraph","Properties":{"id":"20240530092106-5yiyc2c","updated":"20240530092147"},"Children":[{"Type":"NodeText","Data":"Vadc = ADCvalue / ADCmax * 参考电压Vref"}]},{"ID":"20240530092147-gglnwqf","Type":"NodeParagraph","Properties":{"id":"20240530092147-gglnwqf","updated":"20240530092212"},"Children":[{"Type":"NodeText","Data":"Vin = （ADCvalue / ADCmax * 参考电压Vref）*（R1+R2）/ (R2)"}]},{"ID":"20240530092018-yr82a3h","Type":"NodeParagraph","Properties":{"id":"20240530092018-yr82a3h","updated":"20240530092239"}},{"ID":"20240530091352-d3rv6a7","Type":"NodeParagraph","Properties":{"id":"20240530091352-d3rv6a7","updated":"20240530091912"},"Children":[{"Type":"NodeText","Data":"Vin = 11 * (ADC/4096) * 3300     //电压的采样电阻为11k\n      = 11 * (ADC / (4096/4) )* (3300/4)"}]},{"ID":"20240530091919-owmu236","Type":"NodeParagraph","Properties":{"id":"20240530091919-owmu236","updated":"20240530091940"},"Children":[{"Type":"NodeText","Data":"      = 11 * (ADC / 1024 ) * 825"}]}]},{"ID":"20240423151521-lej8u72","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240423151521-lej8u72","updated":"20240731133526"},"Children":[{"Type":"NodeText","Data":"转速——地板和地毯"}]},{"ID":"20240426141901-uxy10xb","Type":"NodeHeading","He