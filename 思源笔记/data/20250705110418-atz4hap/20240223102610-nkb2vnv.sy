erties":{"id":"20240408162218-u2jaj23","updated":"20240408162332"},"Children":[{"Type":"NodeText","Data":"1.幅值Ampl：720mv ——\u003e 720mv/0.2Ω = 3.6A"}]},{"ID":"20240408162333-mrj7vvr","Type":"NodeParagraph","Properties":{"id":"20240408162333-mrj7vvr","updated":"20240408162507"},"Children":[{"Type":"NodeText","Data":"2.一个周期是1khz 可以看出三角形的底边长为440us ——\u003e 440/1000 = 44%  因为是三角形，面积再除以2——\u003e即 44% / 2 = 22%"}]},{"ID":"20240408162525-45rwy7o","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240408162525-45rwy7o","updated":"20240408162553"},"Children":[{"ID":"20240408162529-cyck0qw","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20240408162529-cyck0qw","updated":"20240408162553"},"Children":[{"ID":"20240408162529-3zmlc7v","Type":"NodeParagraph","Properties":{"id":"20240408162529-3zmlc7v","updated":"20240408162553"},"Children":[{"Type":"NodeText","Data":" 3.6A * 22% = 0.792A"}]}]}]}]},{"ID":"20240408162154-26w1r67","Type":"NodeParagraph","Properties":{"id":"20240408162154-26w1r67","updated":"20240408162204"}},{"ID":"20240328133827-jbp5st8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240328133827-jbp5st8","updated":"20240902101036"},"Children":[{"Type":"NodeText","Data":"地毯类型"}]},{"ID":"20240408085533-zhc07jy","Type":"NodeParagraph","Properties":{"id":"20240408085533-zhc07jy","updated":"20240902101036"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 33%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"rename_file"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/rename_file-20240408085533-uqb08g3.jpeg"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 33%;\"}"},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-