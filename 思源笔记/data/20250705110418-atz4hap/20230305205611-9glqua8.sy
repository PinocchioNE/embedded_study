ckFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char string[100] = \"I love C\"\n//定义了一个字符串数组string，用来存放多个字符，并且用“I love C”给string数组初始化，字符串“I love C”存放在string中\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313142259-alyj3tb","Type":"NodeParagraph","Properties":{"id":"20230313142259-alyj3tb","updated":"20230313143014"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"字符串指针"}]},{"ID":"20230313142936-jf3dzv2","Type":"NodeParagraph","Properties":{"id":"20230313142936-jf3dzv2","updated":"20230313143001"},"Children":[{"Type":"NodeText","Data":"在文字常量区开辟了一段空间存放字符串，将字符串的首地址赋给str"}]},{"ID":"20230313143218-00zkl37","Type":"NodeParagraph","Properties":{"id":"20230313143218-00zkl37","updated":"20230313143229"},"Children":[{"Type":"NodeText","Data":"文字常量区的内容是不可以修改的"}]},{"ID":"20230313142436-x0mheme","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313142436-x0mheme","updated":"20230313142624"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *str = \"I love C\"\n//定义了一个指针变量str，只能存放字符地址编号\n//这个字符串中的字符不能存放在str指针变量中\n//str只是存放了字符I的地址编号，“I love C”存放在文字常量区\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313142625-pkvpc66","Type":"NodeParagraph","Properties":{"id":"20230313142625-pkvpc66","updated":"20230313143012"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"堆"}]},{"ID":"20230313143018-1cba9tq","Type":"NodeParagraph","Properties":{"id":"20230313143018-1cba9tq","updated":"20230313143042"},"Children":[{"Type":"NodeText","Data":"使用malloc函数在堆区申请空间，将字符串拷贝至堆区"}]},{"ID":"20230313143232-fhicz09","Type":"NodeParagraph","Properties":{"id":"20230313143232-fhicz09","updated":"20230313143241"},"Children":[{"Type":"NodeText","Data":"堆区的内容是可以修改的"}]},{"ID":"20230313142629-rup4cep","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313142629-rup4cep","updated":"20230313142800"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *str = (char*)malloc(10*sizeof(char));//动态申请了10个字节的存储空间\n//首地址给str赋值\nstrcpy(str, \"I love C\");//将字符串\"I love C\"拷贝到str指向的内存里\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313143853-ixkvioi","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230313143853-ixkvioi","updated":"20230313143858"},"Children":[{"Type":"NodeText","Data":"数组指针"}]},{"ID":"20230313143859-wutw0kp","Type":"NodeParagraph","Properties":{"id":"20230313143859-wutw0kp","updated":"20230313144117"},"Children":[{"Type":"NodeText","Data":"本身是个指针，指向一个数组，加1跳一个数组，即指向下个数组"}]},{"ID":"20230313144117-p0x57sp","Type":"NodeParagraph","Properties":{"id":"20230313144117-p0x57sp","updated":"20230313144129"},"Children":[{"Type":"NodeText","Data":"数组指针的作用就是可以保存二维数组的首地址"}]},{"ID":"20230313144157-kq1edgr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230313144157-kq1edgr","updated":"20230313144203"},"Children":[{"Type":"NodeText","Data":"定义方法"}]},{"ID":"20230313144205-3qgvdc9","Type":"NodeParagraph","Properties":{"id":"20230313144205-3qgvdc9","updated":"20230313144231"},"Children":[{"Type":"NodeText","Data":"指向的数组的类型（*指针变量名）[指向的数组的元素个数]"}]},{"ID":"20230313144232-a3pxeqq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313144232-a3pxeqq","updated":"20230313145851"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int(*p)[5];//定义了一个数组指针变量p，p指向的是整型的有5个元素的数组\n//p+1往下指5个整型，跳过一个有5个整形元素的数组\n//中括号中写的是每一行的列数\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313150101-saa52q9","Type":"NodeParagraph","Properties":{"id":"20230313150101-saa52q9","updated":"20230313150105"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230313150102-aim6w54.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230313150105-8fyx1d4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230313150105-8fyx1d4","updated":"20230313151503"},"Children":[{"Type":"NodeText","Data":"数组名字和指针变量的区别："}]},{"ID":"20230313151215-qxm2345","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313151215-qxm2345","updated":"20230313151232"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int a[10];\nint *p;\np = a;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313151233-aprqvvy","Type":"NodeParagraph","Properties":{"id":"20230313151233-aprqvvy","updated":"20230313151501"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"相同点："}]},{"ID":"20230313151242-n5806qo","Type":"NodeBlockquote","Properties":{"id":"20230313151242-n5806qo","updated":"20230313151448"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230313151243-daevv4j","Type":"NodeParagraph","Properties":{"id":"20230313151243-daevv4j","updated":"20230313151338"},"Children":[{"Type":"NodeText","Data":"a是数组的名字，是a[0]的地址，p=a即p也保存了a[0]的地址，即a和p都指向a[0]，所以在引用数组元素的时候a和p等价"}]},{"ID":"20230313151356-7egy86r","Type":"NodeParagraph","Properties":{"id":"20230313151356-7egy86r","updated":"20230313151403"},"Children":[{"Type":"NodeText","Data":"引用数组元素回顾："}]},{"ID":"20230313151403-vsmqcgn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313151403-vsmqcgn","updated":"20230313151448"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"a[2]、*(a+2)、p[2]、*(p+2)都是对数组a中a[2]元素的引用\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]}]},{"ID":"20230313151340-shuox74","Type":"NodeParagraph","Properties":{"id":"20230313151340-shuox74","updated":"20230313151511"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"不同点："}]},{"ID":"20230313151509-2jie0iu","Type":"NodeBlockquote","Properties":{"id":"20230313151509-2jie0iu","updated":"20230313151608"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230313151519-51n5ko4","Type":"NodeParagraph","Properties":{"id":"20230313151519-51n5ko4","updated":"20230313151532"},"Children":[{"Type":"NodeText","Data":"1.a是常量、p是变量"}]},{"ID":"20230313151532-lo82j5v","Type":"NodeParagraph","Properties":{"id":"20230313151532-lo82j5v","updated":"20230313151550"},"Children":[{"Type":"NodeText","Data":"可以用等号给p赋值，但是不能用等号给a赋值"}]},{"ID":"20230313151550-hovw8e4","Type":"NodeParagraph","Properties":{"id":"20230313151550-hovw8e4","updated":"20230313151608"},"Children":[{"Type":"NodeText","Data":"2.对a取地址，和对p取地址结果不同"}]}]},{"ID":"20230313153238-5gqiwzj","Type":"NodeParagraph","Properties":{"id":"20230313153238-5gqiwzj","updated":"20230313153241"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230313153238-nur2tha.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230313153625-6cjukdj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230313153625-6cjukdj","updated":"20230313153637"},"Children":[{"Type":"NodeText","Data":"二维数组的数组名降级问题"}]},{"ID":"20230313153643-ahv3mgt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230313153643-ahv3mgt","updated":"20230313154505"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"//二维数组的数组名默认是一个行指针，加1保存下一行的首地址\n//二维数组的数据名取*，表示地址的降级，意味着行指针降级为列指针，加1保存下一个元素的地址\n\n//一维数组的数组名默认是一个列指针，加1保存下一个元素的地址\n//一维数组的数组名取\u0026，则是地址的升级，将列指针升级为行指针，加1保存下一行元素的首地址\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230313153711-n5ur91g","Type":"NodeParagraph","Properties":{"id":"20230313153711-n5ur91g","updated":"20230313154128"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230313154128-ahp4yju.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20230313154515-fshmstf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230313154515-fshmstf","updated":"20230313154521"},"Children":[{"Type":"NodeText","Data":"指针和函数的关系"}]},{"ID":"20230313154551-ha9njwe","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230313154551-ha9njwe","updated":"20230313154554"},"Children":[{"Type":"NodeText","Data":"传数值"}]},{"ID":"20230313154555-yufl6qc","Type":"NodeParagraph","Properties":{"id":"20230313154555-yufl6qc","updated":"20230313154934"},"Children":[{"Type":"NodeText","Data":"函数的传参方式：复制传参、地址传参、全局传参（几乎不用）"}]},{"ID":"20230313154934-4nklcdg","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20230313154934-4nklcdg","updated":"20230313154944"},"Children":[{"Type":"NodeText","Data":"复制传参"}]},{"ID":"20230313154947-np906gw","Type":"NodeBlockquote","Properties":{"id":"20230313154947-np906gw","updated":"20230313155629"},"Children"