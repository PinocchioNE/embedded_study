mage-20230314084454-ouhmq85.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20230314085313-4q34n7x","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230314085313-4q34n7x","updated":"20230314085325"},"Children":[{"Type":"NodeText","Data":"传数组"}]},{"ID":"20230314085819-3cf1qkx","Type":"NodeBlockquote","Properties":{"id":"20230314085819-3cf1qkx","updated":"20230314085958"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230314085850-jd03cbp","Type":"NodeParagraph","Properties":{"id":"20230314085850-jd03cbp","updated":"20230314085958"},"Children":[{"Type":"NodeText","Data":"将数组作为参数传递给函数，不存在复制传参和地址传参，本质都是地址传参，所以在函数内部对数组进行改变，则函数执行完毕后，原本的数组也会改变，因为传递给函数的都是数组的地址"}]}]},{"ID":"20230314085329-if0l5ai","Type":"NodeParagraph","Properties":{"id":"20230314085329-if0l5ai","updated":"20230314085431"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230314085428-23houop.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230314085522-84bxx5z","Type":"NodeParagraph","Properties":{"id":"20230314085522-84bxx5z","updated":"20230314085706"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230314085703-h8ni4um.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230314085749-fpv33o2","Type":"NodeParagraph","Properties":{"id":"20230314085749-fpv33o2","updated":"20230314085753"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230314085750-6o1ifga.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230314090018-q4lzxh5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230314090018-q4lzxh5","updated":"20230314090020"},"Children":[{"Type":"NodeText","Data":"指针函数"}]},{"ID":"20230314090035-oqzimv9","Type":"NodeParagraph","Properties":{"id":"20230314090035-oqzimv9","updated":"20230314090101"},"Children":[{"Type":"NodeText","Data":"指针作为函数的返回值"}]},{"ID":"20230314090102-u77g3o5","Type":"NodeParagraph","Properties":{"id":"20230314090102-u77g3o5","updated":"20230314090145"},"Children":[{"Type":"NodeText","Data":"指针函数本质是一个函数，只不过函数的返回值是一个指针"}]},{"ID":"20230314090451-6xkysnv","Type":"NodeParagraph","Properties":{"id":"20230314090451-6xkysnv","updated":"20230314090454"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230314090451-dxfk2kb.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230314090515-0c2zkhy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230314090515-0c2zkhy","updated":"20230314090518"},"Children":[{"Type":"NodeText","Data":"函数指针"}]},{"ID":"20230314090519-xmo3y9o","Type":"NodeParagraph","Properties":{"id":"20230314090519-xmo3y9o","updated":"20230314093428"},"Children":[{"Type":"NodeText","Data":" 定义一个指针变量来存放函数的地址"}]},{"ID":"20230314093429-887a90f","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230314093429-887a90f","updated":"20230314093437"},"Children":[{"Type":"NodeText","Data":"定义方法"}]},{"ID":"20230314093439-et29spt","Type":"NodeParagraph","Properties":{"id":"20230314093439-et29spt","updated":"20230314093546"},"Children":[{"Type":"NodeText","Data":"返回值类型 （*函数指针变量名）（形参列表）"}]},{"ID":"20230314093549-jrlvohn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230314093549-jrlvohn","updated":"20230314093740"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int (*p)(int,int);//定义了一个函数指针变量p，p指向的函数必须有一个整形的返回值，有两个整形参数\n\nint max(int x, int y){}\nint min(int x, int y){}\n\n//可以用这个p存放这类函数的地址\np = max;\np = min;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230314092952-ad8ri8q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230314092952-ad8ri8q","updated":"20230314093843"},"Children":[{"Type":"NodeText","Data":"调用方法"}]},{"ID":"20230314093844-vwyyzt4","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20230314093844-vwyyzt4","updated":"20230314093905"},"Children":[{"Type":"NodeText","Data":"1.通过函数的名字去调函数（最常用的）"}]},{"ID":"20230314093907-gqa6nqo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230314093907-gqa6nqo","updated":"20230314094008"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int max(int x, int y){}\n\nint main(){\n   int num;\n   num = max(3,5);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230314094022-ya80ze5","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20230314094022-ya80ze5","updated":"20230314094042"},"Children":[{"Type":"NodeText","Data":"2.通过函数指针变量去调用"}]},{"ID":"20230314094044-yev0yza","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230314094044-yev0yza","updated":"20230314094139"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int max(int x, int y){}\nint main(){\n   int num;\n   int (*p)(int, int);\n   p = max;\n   num = (*p)(3, 5);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230314103641-g1hjf9o","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230314103641-g1hjf9o","updated":"20230314103641"},"Children":[{"Type":"NodeText","Data":"函数指针最常用的地方"}]},{"ID":"20230314103643-8tl7ggi","Type":"NodeBlockquote","Properties":{"id":"20230314103643-8tl7ggi","updated":"20230314103747"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230314103646-7ng1ofg","Type":"NodeParagraph","Properties":{"id":"20230314103646-7ng1ofg","updated":"20230314103711"},"Children":[{"Type":"NodeText","Data":"在于将一个函数作为参数传递给另一个函数的时候要使用函数指针"}]},{"ID":"20230314103728-yfpdmfq","Type":"NodeParagraph","Properties":{"id":"20230314103728-yfpdmfq","updated":"20230314103747"},"Children":[{"Type":"NodeText","Data":"将一个函数作为参数传递给另一个函数，将这个函数称之为回调函数"}]}]},{"ID":"20230314094302-xoddlkq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230314094302-xoddlkq","updated":"20230314094333"},"Children":[{"Type":"NodeText","Data":"函数指针数组"}]},{"ID":"20230314094337-awquild","Type":"NodeParagraph","Properties":{"id":"20230314094337-awquild","updated":"20230314094407"},"Children":[{"Type":"NodeText","Data":"本质是一个数组，数组里面的每一个元素都是一个函数指针"}]},{"ID":"20230314094423-wjy9dfw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230314094423-wjy9dfw","updated":"20230314094509"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int (*p[10])(int, int);\n//定义了一个函数指针数组，有10个元素p[0]~p[9],每个元素都是函数指针变量\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230314103610-0yjqzzb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230314103610-0yjqzzb","updated":"20230314104633"},"Children":[{"Type":"NodeText","Data":"void*通用指针"}]},{"ID":"20230314104634-3yip0zs","Type":"NodeParagraph","Properties":{"id":"20230314104634-3yip0zs","updated":"20230314104917"},"Children":[{"Type":"NodeText","Data":"void* 通用指针，任何类型的指针都可以给void*类型的指针变量赋值，主要用在函数的参数和返回值的位置"}]},{"ID":"20230314104659-8v5jnhr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230314104659-8v5jnhr","updated":"20230314104720"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"int *p;\nvoid *q;\nq = p;//不用强制类型转换\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320132211-w8jfsdz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320132211-w8jfsdz","updated":"20230320133951"},"Children":[{"Type":"NodeText","Data":"main函数传参"}]},{"ID":"20230320133955-o3w9pss","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320133955-o3w9pss","updated":"20230320134345"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":" int main(int argc, char *argv[])\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320134404-hw81msa","Type":"NodeBlockquote","Properties":{"id":"20230320134404-hw81msa","updated":"20230320134456"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320134405-bty27a1","Type":"NodeParagraph","Properties":{"id":"20230320134405-bty27a1","updated":"20230320134432"},"Children":[{"Type":"NodeText","Data":"argc：是一个int类型的变量，标识命令终端传入的参数的个数"}]},{"ID":"20230320134433-hr1fa7p","Type":"NodeParagraph","Properties":{"id":"20230320134433-hr1fa7p","updated":"20230320134456"},"Children":[{"Type":"NodeText","Data":"argv：是一个指针数组，用于保存每一个命令终端传入的参数"}]}]},{"ID":"20230320134457-1tvnrfi","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20230320134457-1tvnrfi","updated":"20230320134547"},"Children":[{"Type":"NodeText","Data":"动态内存申请"}]},{"ID":"20230320134548-2jwqy2r","Type":"NodeBlockquote","Properties":{"id":"20230320134548-2jwqy2r","updated":"20230320134606"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320134556-1uh6h2u","Type":"NodeParagraph","Properties":{"id":"20230320134556-1uh6h2u","updated":"20230320134606"},"Children":[{"Type":"NodeText","Data":"实际就是在堆区开辟空间"}]}]},{"ID":"20230320134821-xofdj87","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320134821-xofdj87","updated":"20230320134839"},"Children":[{"Type":"NodeText","Data":"静态分配"}]},{"ID":"20230320134831-mzgojg9","Type":"NodeBlockquote","Properties":{"id":"20230320134831-mzgojg9","updated":"20230320135054"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320134927-xqvb5iu","Type":"NodeParagraph","Properties":{"id":"20230320134927-xqvb5iu","updated":"20230320135007"},"Children":[{"Type":"NodeText","Data":"1.在程序编译或运行过程中，按事先规定大小分配内存空间的分配方式 int a[10]"}]},{"ID":"20230320135008-t5o76jb","Type":"NodeParagraph","Properties":{"id":"20230320135008-t5o76jb","updated":"20230320135020"},"Children":[{"Type":"NodeText","Data":"2.必须事先知道所需空间的大小"}]},{"ID":"20230320135020-wugk2kx","Type":"NodeParagraph","Properties":{"id":"20230320135020-wugk2kx","updated":"20230320135047"},"Children":[{"Type":"NodeText","Data":"3.分配在栈区或全局变量区，一般以数组的形式"}]},{"ID":"20230320135049-cdoox14","Type":"NodeParagraph","Properties":{"id":"20230320135049-cdoox14","updated":"20230320135054"},"Children":[{"Type":"NodeText","Data":"4.按计划分配"}]}]},{"ID":"20230320135054-q6g52ot","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320135054-q6g52ot","updated":"20230320135103"},"Children":[{"Type":"NodeText","Data":"动态分配"}]},{"ID":"20230320135104-m48prxh","Type":"NodeBlockquote","Properties":{"id":"20230320135104-m48prxh","updated":"20230320135144"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320135104-vfrkv6t","Type":"NodeParagraph","Properties":{"id":"20230320135104-vfrkv6t","updated":"20230320135123"},"Children":[{"Type":"NodeText","Data":"1.在程序运行过程中，根据需要大小自由分配所需空间"}]},{"ID":"20230320135123-h5ahyio","Type":"NodeParagraph","Properties":{"id":"20230320135123-h5ahyio","updated":"20230320135127"},"Children":[{"Type":"NodeText","Data":"2.按需分配"}]},{"ID":"20230320135127-hijt38a","Type":"NodeParagraph","Properties":{"id":"20230320135127-hijt38a","updated":"20230320135144"},"Children":[{"Type":"NodeText","Data":"3.分配在堆区，一般使用特定的函数进行分配"}]}]},{"ID":"20230320135548-p8px804","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320135548-p8px804","updated":"20230320135552"},"Children":[{"Type":"NodeText","Data":"动态分配函数"}]},{"ID":"20230320135553-tirxt4z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230320135553-tirxt4z","updated":"20230320135559"},"Children":[{"Type":"NodeText","Data":"malloc函数"}]},{"ID":"20230320135600-q539wnx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320135600-q539wnx","updated":"20230320140039"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件：#include\u003cstblid.h\u003e\n函数原型：void *malloc(unsigned int size);\n功能说明：\n    在内存的动态存储区（堆区）中分配一块长度为size字节的连续区域，用来存放类型说明符指定的类型。\n    函数原型返回的void*指针，使用时必须做相应的强制类型转换，分配的内存空间内容不确定\n    一般使用memset初始化\n返回值：\n    分配空间的起始地址（分配成功）\n    成功：开辟好的空间的首地址\n    失败: NULL\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320140047-xkzkxwh","Type":"NodeBlockquote","Properties":{"id":"20230320140047-xkzkxwh","updated":"20230320142607"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320140102-7vgee7w","Type":"NodeParagraph","Properties":{"id":"20230320140102-7vgee7w","updated":"20230320140127"},"Children":[{"Type":"NodeText","Data":"注意：1.在调用malloc之后，一定要判断一下，是否申请内存成功"}]},{"ID":"20230320140124-45psivv","Type":"NodeParagraph","Properties":{"id":"20230320140124-45psivv","updated":"20230320140221"},"Children":[{"Type":"NodeText","Data":"\t   2.如果多次malloc申请的内存，"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"第一次和第二次申请的内存不一定是连续的"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]},{"ID":"20230320140249-mu066r7","Type":"NodeParagraph","Properties":{"id":"20230320140249-mu066r7","updated":"20230320142607"},"Children":[{"Type":"NodeText","Data":"\t   3.使用malloc开辟空间需要保存开辟好的空间的首地址，但是由于不确定空间用于做什么，所以本身返回值类型为void*，所以在调用函数时根据接受者的类型对其进行强制类型转换"}]}]},{"ID":"20230320140154-atk53rj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320140154-atk53rj","updated":"20230320145943"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *fun() {\n    //char ch[100] = \"hello world\" 这样子并不能使用，这是在栈区开辟的临时空间\n\n    //静态全局区的空间只要开辟好，除非程序结束否则不会释放\n    //所以如果是临时使用，不建议使用静态全局区的空间\n    //static char ch[100] = \"hello world\";\n\n    //堆区开辟空间，手动申请手动释放，更加灵活\n    //使用malloc函数的时候一般要进行强转\n    char *str = (char *)malloc(100 * sizeof(char));\n    str[0] = 'h';\n    str[1] = 'e';\n    str[2] = 'l';\n    str[3] = 'l';\n    str[4] = 'o';\n    str[5] = '\\0';\n\n    return str;\n}\nint main(int argc, char *argv[]) {\n    char *p;\n    p = fun();\n    printf(\"p = %s\\n\", p);\n    return 0;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320145623-7np807x","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230320145623-7np807x","updated":"20230320150004"},"Children":[{"Type":"NodeText","Data":"free函数（释放内存空间）"}]},{"ID":"20230320145955-2hadxyx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320145955-2hadxyx","updated":"20230320150258"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件： #include\u003cstdlib.h\u003e\n函数定义：void free(void *ptr)\n参数：\n   ptr：开辟后使用完毕的堆区的空间的首地址\n函数说明：free函数释放ptr指向的内存\n返回值：无\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320150212-e6lxxdv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320150212-e6lxxdv","updated":"20230320150525"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *p = (char *)malloc(100);\nfree(p);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320150118-5srgi7x","Type":"NodeBlockquote","Properties":{"id":"20230320150118-5srgi7x","updated":"20230320151312"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320150210-4xumxzj","Type":"NodeParagraph","Properties":{"id":"20230320150210-4xumxzj","updated":"20230320151053"},"Children":[{"Type":"NodeText","Data":"注意：1.ptr指向的内存必须是 malloc calloc relloc 动态申请的内存"}]},{"ID":"20230320150308-f2m4tfm","Type":"NodeParagraph","Properties":{"id":"20230320150308-f2m4tfm","updated":"20230320151114"},"Children":[{"Type":"NodeText","Data":"\t   2.free函数只能释放堆区的空间，其他区域的空间无法使用free"}]},{"ID":"20230320150330-nsfxszy","Type":"NodeParagraph","Properties":{"id":"20230320150330-nsfxszy","updated":"20230320151114"},"Children":[{"Type":"NodeText","Data":"       \t   3.free释放空间必须释放malloc或者calloc或者relloc的返回值对应的空间，不能说只释放一部分"}]},{"ID":"20230320151050-wq9j4kt","Type":"NodeParagraph","Properties":{"id":"20230320151050-wq9j4kt","updated":"20230320151312"},"Children":[{"Type":"NodeText","Data":"\t   4.free后，因为没有给p赋值，所以p还是指向原先动态申请的内存，但是内存已经不能再用了，p就变成了野指针，所以一般为了防止野指针，free完毕之后对p赋值为null"}]},{"ID":"20230320151050-63wjiwn","Type":"NodeParagraph","Properties":{"id":"20230320151050-63wjiwn","updated":"20230320151116"},"Children":[{"Type":"NodeText","Data":"\t   5.一块动态申请的内存只能free一次，不能多次free"}]}]},{"ID":"20230320151116-2474ql9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230320151116-2474ql9","updated":"20230320152418"},"Children":[{"Type":"NodeText","Data":"calloc函数"}]},{"ID":"20230320152419-a6r8lop","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320152419-a6r8lop","updated":"20230320152755"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件：#include\u003cstdlib.h\u003e\n函数定义：void *calloc(size_t nmemb, size_t size);\n\nsize_t实际是无符号整型，它是在头文件中，用typedf定义出来的\n\n函数的功能：在内存的堆中，申请nmemb块，每块的大小为size个字节的连续区域\n函数的返回值：\n\t成功 申请的内存的首地址\n\t失败 NUll\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320152903-j7wbv0c","Type":"NodeBlockquote","Properties":{"id":"20230320152903-j7wbv0c","updated":"20230320153011"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320152904-1pfwz6r","Type":"NodeParagraph","Properties":{"id":"20230320152904-1pfwz6r","updated":"20230320152908"},"Children":[{"Type":"NodeText","Data":"注意："}]},{"ID":"20230320152909-qp18axk","Type":"NodeParagraph","Properties":{"id":"20230320152909-qp18axk","updated":"20230320152920"},"Children":[{"Type":"NodeText","Data":"\tmalloc和calloc函数都是用来申请内存的"}]},{"ID":"20230320152920-qonnzge","Type":"NodeParagraph","Properties":{"id":"20230320152920-qonnzge","updated":"20230320152925"},"Children":[{"Type":"NodeText","Data":"区别："}]},{"ID":"20230320152925-6otjknq","Type":"NodeParagraph","Properties":{"id":"20230320152925-6otjknq","updated":"20230320152933"},"Children":[{"Type":"NodeText","Data":"\t1.函数的名字不一样"}]},{"ID":"20230320152934-zlsb68t","Type":"NodeParagraph","Properties":{"id":"20230320152934-zlsb68t","updated":"20230320152939"},"Children":[{"Type":"NodeText","Data":"\t2.参数的个数不一样"}]},{"ID":"20230320152940-yl7p3dc","Type":"NodeParagraph","Properties":{"id":"20230320152940-yl7p3dc","updated":"20230320153011"},"Children":[{"Type":"NodeText","Data":"\t3.malloc申请的内存，内存中存放的内容是随机的，不确定的，而calloc函数申请的内存中的内容为0"}]}]},{"ID":"20230320153019-le7rk1w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320153019-le7rk1w","updated":"20230320153113"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *p = (char *)calloc(3, 100);//在堆中申请了3块，每块大小为100个字节，即300个字节连续的区域\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320153115-9x4jyth","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230320153115-9x4jyth","updated":"20230320153152"},"Children":[{"Type":"NodeText","Data":"realloc函数（重新申请内存）"}]},{"ID":"20230320153142-cpcarze","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320153142-cpcarze","updated":"20230320153706"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件：#include\u003cstdlib.h\u003e\n函数的定义：void *realloc(void *s, unsigned int newsize);\n函数的功能：\n\t在原先s指向的内存基础上重新申请内存，新的内存大小为new_size个字节，\n\t如果原先内存后面有足够大的空间，就追加，如果后边的内存不够用，则realloc函数会在堆区找一个newsize个字节大小的内存申请，\n\t将原先内存中的内容拷贝过来，然后释放原先的内存，最后返回新内存的地址\n\t如果newsize比原先的内存小，则会释放原先内存的后面的存储空间，只留前面的newsize个字节\n返回值：新申请的内存的首地址\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320153700-8fbab9v","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320153700-8fbab9v","updated":"20230320154311"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *p;\np = (char *)malloc(100)\n//在100个字节后追加50个字节\np = (char *)realloc(p,150);// p指向的内存的新的大小为150个字节\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320154140-4jxbh8z","Type":"NodeParagraph","Properties":{"id":"20230320154140-4jxbh8z","updated":"20230320154143"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320154140-eqj9dub.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230320154312-6bn9cg3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320154312-6bn9cg3","updated":"20230320154415"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *p;\np = (char *)malloc(100)\n//想重新申请内存，新的大小为50字节\np = (char *)realloc(p,50);// p指向的内存的新的大小为50个字节，100各字节的后50各字节的存储空间就被释放\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320154423-6e88bi5","Type":"NodeParagraph","Properties":{"id":"20230320154423-6e88bi5","updated":"20230320154533"},"Children":[{"Type":"NodeText","Data":"注意：malloc calloc realloc动态申请的内存，只有在free或程序结束的时候才释放"}]},{"ID":"20230320154515-z88fbx7","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20230320154515-z88fbx7","updated":"20230320154555"},"Children":[{"Type":"NodeText","Data":"内存泄漏"}]},{"ID":"20230320154557-tuwz145","Type":"NodeBlockquote","Properties":{"id":"20230320154557-tuwz145","updated":"20230320160958"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230320160927-1vh652y","Type":"NodeParagraph","Properties":{"id":"20230320160927-1vh652y","updated":"20230320160958"},"Children":[{"Type":"NodeText","Data":"申请的内存，首地址丢了，找不了，再也没法使用了，也没法释放了，这块内存就被泄露了"}]}]},{"ID":"20230320161000-cpt9u15","Type":"NodeParagraph","Properties":{"id":"20230320161000-cpt9u15","updated":"20230320161152"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320161152-i0oydf8.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20230320161623-i81npsj","Type":"NodeParagraph","Properties":{"id":"20230320161623-i81npsj","updated":"20230320161633"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"解决方式 1："}]},{"ID":"20230320161630-vutmvip","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320161630-vutmvip","updated":"20230320161803"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"void fun(){\n\tchar *p;\n\tp = (char *)malloc(100);\n\tfree(p);\n}\nint main()\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320161122-f6vwz1g","Type":"NodeParagraph","Properties":{"id":"20230320161122-f6vwz1g","updated":"20230320161402"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"内存泄漏"}]},{"ID":"20230320161359-euy7k66","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320161359-euy7k66","updated":"20230320161526"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"void fun(){\n\tchar *p;\n\tp = (char *)malloc(100);\n\t//接下来，可以用p指向内存了\n}\nint main(){\n\t//每调用一次fun泄漏100各字节\n\tfun();\n\tfun();\n\treturn 0;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320161343-keo4n3l","Type":"NodeParagraph","Properties":{"id":"20230320161343-keo4n3l","updated":"20230320161822"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"解决方式2"}]},{"ID":"20230320161823-bspe2oa","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320161823-bspe2oa","updated":"20230320161948"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"void fun(){\n\tchar *p;\n\tp = (char *)malloc(100);\n\t//接下来，可以用p指向内存了\n\treturn p;\n}\nint main(){\n\tchar *q;\n\tq = fun();\n\tfree(q);\n\tq = NULL;//防止野指针\n\treturn 0;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230428092508-enc5ob4","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20230428092508-enc5ob4","updated":"20230428092514"},"Children":[{"Type":"NodeText","Data":"字符串处理"}]},{"ID":"20230320162019-43y64lj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320162019-43y64lj","updated":"20230320162039"},"Children":[{"Type":"NodeText","Data":"字符串处理函数"}]},{"ID":"20230320162041-99dcjxg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320162041-99dcjxg","updated":"20230320183818"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件： #include\u003cstring.h\u003e\n函数定义： size_t strlen(const char *s);\n函数功能：\n\t测字符指针s指向的字符串中字符的个数，不包括'\\0'\n返回值：字符串中字符个数\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320184259-6xmei5c","Type":"NodeParagraph","Properties":{"id":"20230320184259-6xmei5c","updated":"20230320184410"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320184356-5xm53nu.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320184410-mne4kjd.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20230320184415-jf8go4z","Type":"NodeParagraph","Properties":{"id":"20230320184415-jf8go4z","updated":"20230320184531"},"Children":[{"Type":"NodeText","Data":"为什么s2_size的大小是4？因为*s2是指针变量 所以s2只占4个字节（64位电脑占8位）"}]},{"ID":"20230320184412-jkpkcf5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320184412-jkpkcf5","updated":"20230320184615"},"Children":[{"Type":"NodeText","Data":"字符串拷贝函数"}]},{"ID":"20230320184616-skq6dnu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320184616-skq6dnu","updated":"20230320190118"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件： #include\u003cstring.h\u003e\n函数的定义：char *strcpy(char *dest, const char *src);\n函数的说明：\n\t拷贝src指向的字符串到dest指针指向的内存中，'\\0'也会拷贝\n函数的返回值：\n\t目的内存地址\n注意：再使用此函数的时候，必须保证dest指向的内存空间足够大，否则会出现内存污染\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320190326-8xj7vrc","Type":"NodeParagraph","Properties":{"id":"20230320190326-8xj7vrc","updated":"20230320190336"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320190333-k5nrdrz.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230320192403-qgeneke","Type":"NodeParagraph","Properties":{"id":"20230320192403-qgeneke","updated":"20230320192433"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320192404-y90q3jf.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230320192433-6h2uv6i.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20230320192434-23jetgc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320192434-23jetgc","updated":"20230321153042"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"char *strncpy(char *dest, const char *src, size_t n);\n函数的说明：\n\t将src指向的字符串前n个字节，拷贝到dest指向的内存中\n返回值：目的内存的首地址\n注意：\n\t1.strncpy不拷贝'\\0'\n\t2.如果n大于src指向的字符串中的字符个数，则在dest后面填充n-strlen(src)个'\\0'\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230320193530-7he5sbq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230320193530-7he5sbq","updated":"20230320193541"},"Children":[{"Type":"NodeText","Data":"字符串追加函数"}]},{"ID":"20230320193543-brt1sya","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230320193543-brt1sya","updated":"20230321150945"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"头文件： #include\u003cstring.h\u003e\n函数定义：char *strcat(char *dest, const char *src);\n函数功能：\n\tstrcat函数追加src字符串到dest指向的字符串的后面，追加的时候会追加'\\0'\n注意：保证dest指向的内存空间足够大\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230321153100-k8wael5","Type":"NodeParagraph","Properties":{"id":"20230321153100-k8wael5","updated":"20230321153103"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20230321153100-g27a9h5.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20230321153121-r3xzh1f","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230321153121-r3xzh1f","updated":"20230321153305"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：char *strncat(char *dest, const char *src, size_ n);\n追加src指向的字符串的前n个字符，到dest指向的字符串的后面\n注意如果n大于src的字符个数，则只将src字符串追加到dest指向的字符串的后面，追加的时候会追加'\\0'\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230321154143-u6z38mk","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230321154143-u6z38mk","updated":"20230321154150"},"Children":[{"Type":"NodeText","Data":"字符串比较函数"}]},{"ID":"20230321154152-uykc4vh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230321154152-uykc4vh","updated":"20230321154544"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"strcmp/strncmp\n头文件： #include \u003cstring.h\u003e\n函数定义：int strcmp(const char *s1, const char *s2);\n函数说明：\n\t比较s1和s2指向的字符串的大小\n\t比较的方法：逐个字符去比较ascii码，一旦比较出大小就返回，如果所有字符都一样则返回0\n返回值：\n\t如果s1指向的字符串大于s2指向的字符串 返回1\n\t如果s1指向的字符串小于s2指向的字符串 返回-1\n\t如果相等的话就返回0\n\n\n函数定义：int strcmp(const char *s1, const char *s2, size_t n);\n函数说明：比较s1和s2指向的字符串中的前n个字符\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230321154459-sezjkiw","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230321154459-sezjkiw","updated":"20230427160742"},"Children":[{"Type":"NodeText","Data":"字符查找函数"}]},{"ID":"20230427160744-ipqsiws","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230427160744-ipqsiws","updated":"20230427161157"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：char *strchr(const char *s, int c);\n函数说明： 在字符指针s指向的字符串中，找ascii码为c的字符（注意：是首次匹配，如果说s指向的字符串中由多个ASCII为c的字符，则找的是第一个字符）\n返回值：\n\t找到了返回找到的字符的地址\n\t找不到返回NULL\n\n\n函数的定义：char *strrchr(const char *s, int c);\n函数说明：末次匹配\n\t在s指向的字符串中，找最后一次出现的ASCII为c的字符\n返回值：\n\t末次匹配的字符的地址\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230427161531-jlnu7d5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230427161531-jlnu7d5","updated":"20230427161739"},"Children":[{"Type":"NodeText","Data":"  字符匹配函数"}]},{"ID":"20230427161741-upxpyfw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230427161741-upxpyfw","updated":"20230427161949"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：*strstr(const char *haystack, const char *needle);\n函数说明：\n\t在haystack指向的字符串中查找needle指向的字符串，也是首次匹配\n返回值：\n\t找到了：找到的字符串的首地址\n\t没找到：返回NULL\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230427162341-5ijwg5k","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230427162341-5ijwg5k","updated":"20230427162353"},"Children":[{"Type":"NodeText","Data":"字符串转换数值"}]},{"ID":"20230427162355-re0qjcu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230427162355-re0qjcu","updated":"20230427162508"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：int atoi(const char *nptr);\n函数说明：将一个数字型字符串转化为整形数据\n参数：\n\tnptr：指定的字符串\n返回值：\n\t获取到的整形数据\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230427162619-v5lkrm9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230427162619-v5lkrm9","updated":"20230427162628"},"Children":[{"Type":"NodeText","Data":"字符串切割函数"}]},{"ID":"20230427162630-j1uow3j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230427162630-j1uow3j","updated":"20230427164533"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：char *strtok(char *str, const char *delim);\n函数功能：对字符串进行切割\n参数：\n\tstr：要切割的字符串\n\t\t第一次切割，就传入指定的字符串，后面所有的切割传NULL\n\tdelim：标识符，要根据指定的delim进行切割，切割的结果不包含delim\n返回值：\n\t返回切割下来的字符串的首地址，如果都切割完毕，则返回NULL\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230427165051-phjb5vi","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230427165051-phjb5vi","updated":"20230427165058"},"Children":[{"Type":"NodeText","Data":"格式化字符串操作函数"}]},{"ID":"20230427165100-3ewkxl4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230427165100-3ewkxl4","updated":"20230427165833"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"函数定义：int sprintf(char *str, const char *format, ...);\n函数功能：将按照格式保存的字符串复制给str\n参数：\n\tstr：保存字符串\n\tformat：同printf\n返回值：\n\t保存的字符串的字节数\n\n函数定义： int sscanf(const char *str, const char *format, ...);\n功能：scanf是从终端读取数据并赋值给对应变量，而sscanf是从第一个参数中读取数据\n参数：\n\tstr：指定要获取内容的字符串\n\tformat：按照格式获取数据保存在变量中\n返回值：\n\t成功获取的个数\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230427165835-4jds1ft","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20230427165835-4jds1ft","updated":"20230428092538"},"Children":[{"Type":"NodeText","Data":"const"}]},{"ID":"20230428092608-mfnmd7b","Type":"NodeParagraph","Properties":{"id":"20230428092608-mfnmd7b","updated":"20230428093341"},"Children":[{"Type":"NodeText","Data":"1.修饰普通变量，代表只读"}]},{"ID":"20230428093341-gtcz7h2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230428093341-gtcz7h2","updated":"20230504092534"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"//const修饰全局变量\n//此时全局变量智能使用但是不能修改\n//如果直接拿全局变量修改值，编译直接报错\n//如果使用全局变量的地址修改值，运行时程序异常结束\n\n//const修饰普通局部变量\n//可以读取变量的值\n//不能直接通过变量进行修改值，编译报错\n//可以通过变量的地址修改值\n\n//如果const修饰指针变量的类型，无法通过指针变量修改地址里面的值\n//如果const修饰指针变量，无法修改指针变量保存的地址\n//如果const既修饰指针变量的类型，又修饰指针变量，则只能通过原本变量修改值\nconst int a = 100;//定义了一个只读变量a值为100\n以后在程序中，不能再给a赋值\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230428093343-sx43hbb","Type":"NodeParagraph","Properties":{"id":"20230428093343-sx43hbb","updated":"20230428093348"},"Children":[{"Type":"NodeText","Data":"2.修饰指针"}]},{"ID":"20230428093348-hdjyqvl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230428093348-hdjyqvl","updated":"20230428093505"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"（1）const char *str\n\t意思是str指向的内存的内容不能通过str来修改\n\t用来保护str指向的内存的内容\n\t但是str的指向是可以改变的\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230428093132-66pkwst","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20230428093132-66pkwst","updated":"20230504092652"},"Children":[{"Type":"NodeText","Data":"结构体、共用体、枚举"}]},{"ID":"20230504093241-61x47ld","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230504093241-61x47ld","updated":"20230504093247"},"Children":[{"Type":"NodeText","Data":"结构体"}]},{"ID":"20230504093248-aryzpx7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230504093248-aryzpx7","updated":"20230504093736"},"Children":[{"Type":"NodeText","Data":"结构体定义方法1"}]},{"ID":"20230504093253-he9006o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230504093253-he9006o","updated":"20230504093547"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct 结构体类型名{\n\t成员列表\n};\n\nstruct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n};\n\n//有了结构体类型后，就可以用类型定义变量\nstruct stu lucy,bob,lilei;//定义了三个struct stu类型的变量\n//每个变量都有三个成员，分别是num name sex\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230504093742-i00d2xb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230504093742-i00d2xb","updated":"20230504093742"},"Children":[{"Type":"NodeText","Data":"结构体定义方法2"}]},{"ID":"20230504093743-13s31as","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230504093743-13s31as","updated":"20230504093913"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct 结构体类型名{\n\t成员列表;\n}结构体变量1,变量2;\nstruct 结构体类型名 变量3, 变量4;\n\nstruct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n}lucy,bob,lilei;\nstruct stu xiaoming,xiaozhang;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230504093802-fk8n4c2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230504093802-fk8n4c2","updated":"20230504094046"},"Children":[{"Type":"NodeText","Data":"结构体定义方法3 无名结构体"}]},{"ID":"20230504094047-095h5fm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230504094047-095h5fm","updated":"20230504094123"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct{\n\t成员列表;\n}变量1,变量2;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230504094110-pur4l20","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230504094110-pur4l20","updated":"20230504094220"},"Children":[{"Type":"NodeText","Data":"结构体定义方法4 最常用的方法——给结构体类型取别名"}]},{"ID":"20230504094309-4fthojl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230504094309-4fthojl","updated":"20230504095317"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"typedef struct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n}STU;\n\n//此后STU就相当于struct stu\n//STU lucy和struct stu lucy是等价的，所以可以不指定stu这个名字\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230504112620-u283hox","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230504112620-u283hox","updated":"20230509085834"},"Children":[{"Type":"NodeText","Data":"结构体变量的定义初始化及使用"}]},{"ID":"20230509092015-rh50otb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509092015-rh50otb","updated":"20230509092024"},"Children":[{"Type":"NodeText","Data":"结构体变量的初始化"}]},{"ID":"20230509085844-3tis0lj","Type":"NodeBlockquote","Properties":{"id":"20230509085844-3tis0lj","updated":"20230509090029"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230509085854-h331opc","Type":"NodeParagraph","Properties":{"id":"20230509085854-h331opc","updated":"20230509085907"},"Children":[{"Type":"NodeText","Data":"结构体变量是若干个数据的集合"}]},{"ID":"20230509085907-ggq1hly","Type":"NodeParagraph","Properties":{"id":"20230509085907-ggq1hly","updated":"20230509085939"},"Children":[{"Type":"NodeText","Data":"注：1.在定义结构体变量之前首先得有结构体类型，然后再定义变量"}]},{"ID":"20230509085939-bg6wn21","Type":"NodeParagraph","Properties":{"id":"20230509085939-bg6wn21","updated":"20230509090012"},"Children":[{"Type":"NodeText","Data":"\t2.在定义结构体变量的时候，可以顺便给结构体变量赋初值，被称为结构体的初始化"}]},{"ID":"20230509090012-1islwo3","Type":"NodeParagraph","Properties":{"id":"20230509090012-1islwo3","updated":"20230509090029"},"Children":[{"Type":"NodeText","Data":"\t3.结构体变量初始化的时候，各个成员顺序初始化"}]}]},{"ID":"20230509090458-zslw0qi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509090458-zslw0qi","updated":"20230509091832"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n};\ntypedef struct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n}STU;\nint main(int argc, char *argv[]){\n\tstruct stu wangwu; //初始化\n\tstruct stu zhaoliu = {1001, \"赵六\", 'B'}; //初始化\n\tSTU xth1,xth2 = {100, \"夏天豪\", 'B'}; //typedf的只能这么初始化\n\n\t//结构体变量的使用\n\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509091808-nxdha5z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509091808-nxdha5z","updated":"20230509092034"},"Children":[{"Type":"NodeText","Data":"结构体变量的使用"}]},{"ID":"20230509092035-vwwoqi1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509092035-vwwoqi1","updated":"20230509092247"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n}zhangsan = {1002, \"张三\", 'B'};\n\nint main(int argc, char *argv[]){\n\tzhangsan.id = 1001;\n\tstrcpy(zhangsan.name, \"里斯\");\n\tzhangsan.sex = 'B';\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509092524-zmz7ya5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509092524-zmz7ya5","updated":"20230509092539"},"Children":[{"Type":"NodeText","Data":"在结构体中嵌套结构体"}]},{"ID":"20230509092541-dnawatn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509092541-dnawatn","updated":"20230509093111"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"typedf struct{\n\tint year;\n\tint month;\n\tint day;\n}BD;\n\ntypedf struct{\n\tint id;\n\tchar name[32];\n\tBD birthday;\n}STU;\n\nvoid test(){\n\tSTU xiaoming;\n\txiaoming.id = 1001;\n\tstrcpy(xiaoming,name, \"小明\");\n\t//如果结构体中嵌套结构体，赋值时找到最内层的成员再进行赋值\n\txiaoming.birthday.year = 2002;\n\txiaoming.birthday.month = 12;\n\txiaoming.birthday.day = 20;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509092717-i53yuw9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509092717-i53yuw9","updated":"20230509093728"},"Children":[{"Type":"NodeText","Data":"相同类型的结构体变量之间可以直接赋值"}]},{"ID":"20230509093735-nglzctp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509093735-nglzctp","updated":"20230509093756"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct stu lisi;\nlisi = zhangsan;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509093845-mx3scpo","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230509093845-mx3scpo","updated":"20230509093850"},"Children":[{"Type":"NodeText","Data":"结构体数组"}]},{"ID":"20230509093900-a8kvjtw","Type":"NodeBlockquote","Properties":{"id":"20230509093900-a8kvjtw","updated":"20230509093936"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230509093908-l2jei2a","Type":"NodeParagraph","Properties":{"id":"20230509093908-l2jei2a","updated":"20230509093936"},"Children":[{"Type":"NodeText","Data":"结构体数组是个数组，由若干个相同类型的结构体变量构成的集合"}]}]},{"ID":"20230509094647-flyo06t","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509094647-flyo06t","updated":"20230509094650"},"Children":[{"Type":"NodeText","Data":"定义方法"}]},{"ID":"20230509094654-7ciegkr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509094654-7ciegkr","updated":"20230509094714"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct 结构体类型名 数组名[元素个数];\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509094715-yqoaiuz","Type":"NodeParagraph","Properties":{"id":"20230509094715-yqoaiuz","updated":"20230509094721"},"Children":[{"Type":"NodeText","Data":"例子："}]},{"ID":"20230509095255-unwswjl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509095255-unwswjl","updated":"20230509095349"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"//定义一个结构体数组\nSTU edu[3] = {\n\t{101, \"lucy\", 78},\n\t{102, \"Bob\", 59.5},\n\t{103, \"Tom\", 85}\n};\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509094721-cj7693k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509094721-cj7693k","updated":"20230509094832"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct stu{\n\tint num;\n\tchar name;\n\tchar sex; \n};\nstruct stu edu[3]; //定义了一个struct stu 类型的结构体数组edu\n//这个数组有三个元素分别是edu[0]、edu[1]、edu[2]\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509094815-n9vujnq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509094815-n9vujnq","updated":"20230509095124"},"Children":[{"Type":"NodeText","Data":"结构体数组元素的引用"}]},{"ID":"20230509094919-a25wuld","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509094919-a25wuld","updated":"20230509095123"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"数组名[下标]\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509094905-vdw07du","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509094905-vdw07du","updated":"20230509101303"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"//数组元素的使用\nedu[0].num = 101;//用101给edu数组的第0个结构体变量的num赋值\nstrcpy(edu[1].name, \"lucy\");c结构体指针\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509094941-6nn6tyn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230509094941-6nn6tyn","updated":"20230509095433"},"Children":[{"Type":"NodeText","Data":"结构体指针"}]},{"ID":"20230509101334-wt3jzhv","Type":"NodeBlockquote","Properties":{"id":"20230509101334-wt3jzhv","updated":"20230509101949"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20230509101337-nuwy8j5","Type":"NodeParagraph","Properties":{"id":"20230509101337-nuwy8j5","updated":"20230509101949"},"Children":[{"Type":"NodeText","Data":"即结构体的地址，结构体变量存放在内存中，也有起始地址"}]}]},{"ID":"20230509101856-ubbdpec","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509101856-ubbdpec","updated":"20230509102001"},"Children":[{"Type":"NodeText","Data":"定义方法"}]},{"ID":"20230509102002-kmue9g6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509102002-kmue9g6","updated":"20230509102034"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct 结构体类型名 * 结构体指针变量名\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509102142-sgwpg7i","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509102142-sgwpg7i","updated":"20230509102154"},"Children":[{"Type":"NodeText","Data":"结构体指针变量对成员的引用"}]},{"ID":"20230509102155-8izdvve","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509102155-8izdvve","updated":"20230509103529"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"1 (*结构体指针变量名).成员\n2 结构体指针变量名-\u003e成员\n\nstruct stu *s;//定义了一个struct stu *类型的指针变量\n//变量名是p, p占4个字节，用来保存结构体变量的地址编号\n\n//在堆区开辟结构体空间并将其他地址保存在结构体指针变量中\ns = (struct stu *)malloc(sizeof(struct stu));\ns-\u003eid = 1001;\nstrcpy(s-\u003ename,\"张三\");\ns-\u003esex = 'B';\ns-\u003eage = 20;\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509102218-n4t7ex3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20230509102218-n4t7ex3","updated":"20230509102647"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"struct stu boy;\np = \u0026boy;\n//访问结构体变量的成员方法：\nboy.num = 101;//通过结构体变量名.成员名\n(*p).num = 101;//*p相当于p指向的变量boy\np-\u003enum = 101;//指针-\u003e成员名\n注：通过结构体指针来引用指针指向的结构体成员，前提是指针必须先指向一个结构体变量\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20230509104418-56ocqd1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20230509104418-56ocqd1","updated":"20230509104424"},"Children":[{"Type":"NodeText","Data":"结构体内存分配问题"}]},{"ID":"20230509104428-cpnwwta","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20230509104428-cpnwwta","updated":"20230509104433"},"Children":[{"Type":"NodeText","Data":"规则1"}]},{"ID":"20230509104434-3ik5oi5","Type":"NodeParagraph","Properties":{"id":"20230509104434-3ik5oi5","updated":"20230509104444"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 75%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"