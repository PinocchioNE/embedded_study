roperties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694693044209-213d9fbf-f3f1-41f1-9f95-3048338a2460.png#averageHue=%23e5e3e1\u0026clientId=u06ac360b-87c8-4\u0026from=paste\u0026height=111\u0026id=u16580143\u0026originHeight=122\u0026originWidth=862\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=17590\u0026status=done\u0026style=none\u0026taskId=u37282a50-8272-4abb-8c37-1daed1ff652\u0026title=\u0026width=783.6363466515032","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024082981-j3fkp9a","Type":"NodeBlockquote","Properties":{"id":"20231024082981-j3fkp9a","updated":"20231024082981"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024082982-trai0yj","Type":"NodeParagraph","Properties":{"id":"20231024082982-trai0yj","updated":"20231024082982"},"Children":[{"Type":"NodeText","Data":"那是因为m4_usartX用错了 比如华大jeta中pc13只能用3和4"}]}]},{"ID":"20231024082983-jtv6aii","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024082983-jtv6aii","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"定时器的分频和计数怎么算"}]},{"ID":"20231024082984-p7xqqwg","Type":"NodeBlockquote","Properties":{"id":"20231024082984-p7xqqwg","updated":"20231024082984"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024082985-sv804b6","Type":"NodeParagraph","Properties":{"id":"20231024082985-sv804b6","updated":"20231024082985"},"Children":[{"Type":"NodeText","Data":"计数器的时钟频率 f = CK_CNT = f(ck_psc) / (psc+1) = Tclk / (psc + 1)  ，对时钟源分频 。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"Tout溢出时间 =  (1/f) * (arr+1)  = ((psc+1) / Tlck) * (arr+1)"}]},{"ID":"20231024082986-v3mr0bb","Type":"NodeParagraph","Properties":{"id":"20231024082986-v3mr0bb","updated":"20231024082986"},"Children":[{"Type":"NodeText","Data":"如：F103默认配置下，生成1ms的时钟：Tout = (( 1+35 ) / 36M ) * ( 1+999 ) = 1ms"}]},{"ID":"20231024082987-jx28qwu","Type":"NodeParagraph","Properties":{"id":"20231024082987-jx28qwu","updated":"20231024082987"},"Children":[{"Type":"NodeText","Data":"比如分频72mhz 周期写19999 结果就是 72mhz/72*（19999+1）=20000us"}]}]},{"ID":"20231024082988-7n7h923","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024082988-7n7h923","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"寄存器的位与操作"}]},{"ID":"20231024082989-bwymrot","Type":"NodeParagraph","Properties":{"id":"20231024082989-bwymrot","updated":"20231024082989"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例子1："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"比如我们有一个8位的寄存器，初始化为0b10011011，我们想把这个寄存器的第4位（从左到右，从0开始编号，第4位为0b00001000）设置为0，我们可以这样操作（我们暂时假设这个寄存器的名字为registerA）："}]},{"ID":"20231024082990-oiuoafd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024082990-oiuoafd","updated":"20231024082990"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"registerA \u0026= ~(1 \u003c\u003c 4);  // 清除第4位\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024082991-hcxvq61","Type":"NodeParagraph","Properties":{"id":"20231024082991-hcxvq61","updated":"20231024082991"},"Children":[{"Type":"NodeText","Data":"这行代码的含义是：首先1 \u003c\u003c 4得到0b00010000，然后取反得到0b11101111，然后与registerA做\"与\"操作，这样可以确保第4位变为0，其他位保持不变，因为1与任何值做\"与\"操作结果还是那个值，0与任何值做\"与\"操作结果都是0。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例子2："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"如果我们想将上面那个寄存器registerA的第3位设置为1，我们可以这样操作："}]},{"ID":"20231024082992-mwfd5kx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024082992-mwfd5kx","updated":"20231024082992"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"registerA |= 1 \u003c\u003c 3;  // 设置第3位为1\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024082993-3iztnq9","Type":"NodeParagraph","Properties":{"id":"20231024082993-3iztnq9","updated":"20231024082993"},"Children":[{"Type":"NodeText","Data":"这行代码的含义是：首先1 \u003c\u003c 3得到0b00001000，然后与registerA做\"或\"操作，这样可以确保第3位变为1，其他位保持不变，因为1与任何值做\"或\"操作结果都是1，0与任何值做\"或\"操作结果还是那个值。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例子3："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"如果我们想将上面那个寄存器registerA的第0位和第1位设置为1，我们可以这样操作："}]},{"ID":"20231024082994-1yuncix","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024082994-1yuncix","updated":"20231024082994"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"registerA |= 3 \u003c\u003c 0;  // 设置第0位和第1位为1\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024082995-2mobug3","Type":"NodeParagraph","Properties":{"id":"20231024082995-2mobug3","updated":"20231024082995"},"Children":[{"Type":"NodeText","Data":"这行代码的含义是：首先3 \u003c\u003c 0得到0b00000011（因为3的二进制是11），然后与registerA做\"或\"操作，这样可以确保第0位和第1位变为1，其他位保持不变。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"以上这些例子中的1 \u003c\u003c 4，1 \u003c\u003c 3，3 \u003c\u003c 0这些操作，就是先创建一个模板（只有目标位是1，其他位是0的二进制数），然后通过与、或、非等位操作来改变寄存器的值。这是在嵌入式编程中常常会用到的技巧。"}]},{"ID":"20231024082996-eqkix8a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024082996-eqkix8a","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"RES#"}]},{"ID":"20231024082997-7gyhjox","Type":"NodeBlockquote","Properties":{"id":"20231024082997-7gyhjox","updated":"20231024082997"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024082998-wpl7suc","Type":"NodeParagraph","Properties":{"id":"20231024082998-wpl7suc","updated":"20231024082998"},"Children":[{"Type":"NodeTextMark","TextMarkType":"tag","TextMarkTextContent":"号表示低电平复位"}]}]},{"ID":"20231024082999-uldinz2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024082999-uldinz2","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Mhz和hz"}]},{"ID":"20231024083000-yrbsy5x","Type":"NodeBlockquote","Properties":{"id":"20231024083000-yrbsy5x","updated":"20231024083000"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083001-3ib72xh","Type":"NodeParagraph","Properties":{"id":"20231024083001-3ib72xh","updated":"20231024083001"},"Children":[{"Type":"NodeText","Data":"1 Megahertz（MHz）等于1000000 Hertz（Hz）"}]}]},{"ID":"20231024083002-6fla1di","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083002-6fla1di","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"占空比分辨率"}]},{"ID":"20231024083003-naeh9hu","Type":"NodeBlockquote","Properties":{"id":"20231024083003-naeh9hu","updated":"20231024083003"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083004-qvhmzeg","Type":"NodeParagraph","Properties":{"id":"20231024083004-qvhmzeg","updated":"20231024083004"},"Children":[{"Type":"NodeText","Data":"PWM的占空比分辨率，指的是PWM信号的占空比可以调整的最小单位。比如，如果一个PWM系统的占空比分辨率是1%，那么我们可以将占空比调整为1%，2%，3%，……，100%，但是不能将占空比调整为1.5%，2.5%等。分辨率越高，我们可以调整的占空比的精度就越高，PWM信号模拟模拟信号的效果也就越好。"}]}]},{"ID":"20231024083005-h8eu3i6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083005-h8eu3i6","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"12Mhz和72Mhz"}]},{"ID":"20231024083006-r9cw3aw","Type":"NodeBlockquote","Properties":{"id":"20231024083006-r9cw3aw","updated":"20231024083006"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083007-m6vt1s5","Type":"NodeParagraph","Properties":{"id":"20231024083007-m6vt1s5","updated":"20231024083007"},"Children":[{"Type":"NodeText","Data":"芯片上的12Mhz是震荡周期"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"72Mhz是时钟频率"}]}]},{"ID":"20231122094451-2zwyrrt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231122094451-2zwyrrt","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"为什么标志位每次只有第一次烧录完后有效"}]},{"ID":"20231122094513-otbp1cr","Type":"NodeBlockquote","Properties":{"id":"20231122094513-otbp1cr","updated":"20231122100414"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231122094516-5q9ku3g","Type":"NodeParagraph","Properties":{"id":"20231122094516-5q9ku3g","updated":"20231122100414"},"Children":[{"Type":"NodeText","Data":"那是因为单片可能软启动了 所以标志位并没有真的清零"}]}]},{"ID":"20231204090350-c7plo83","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231204090350-c7plo83","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"i2c的频率很高"}]},{"ID":"20231204142412-h3w6d5c","Type":"NodeParagraph","Properties":{"id":"20231204142412-h3w6d5c","updated":"20240205112251"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231204142412-v4b7v3m.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231204142414-q5mnjjz","Type":"NodeParagraph","Properties":{"id":"20231204142414-q5mnjjz","updated":"20231204142510"},"Children":[{"Type":"NodeText","Data":"因为原始工程中的i2c初始化时没有实际获取时钟频率 所以分频失败"}]},{"ID":"20231204141319-fas59zl","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231204141319-fas59zl","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"程序烧了以后开机就自动断电"}]},{"ID":"20231204141341-eo3wxxq","Type":"NodeBlockquote","Properties":{"id":"20231204141341-eo3wxxq","updated":"20231204141411"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231204141344-n04lies","Type":"NodeParagraph","Properties":{"id":"20231204141344-n04lies","updated":"20231204141411"},"Children":[{"Type":"NodeText","Data":"这是因为没有在魔法棒中没有正确设置开发板型号"}]}]},{"ID":"20231208091228-r4mjpgq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231208091228-r4mjpgq","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"陀螺仪中断触发以后程序跑飞了"}]},{"ID":"20231208091305-riwb8yi","Type":"NodeBlockquote","Properties":{"id":"20231208091305-riwb8yi","updated":"20231208141130"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231208091306-21fnv8k","Type":"NodeParagraph","Properties":{"id":"20231208091306-21fnv8k","updated":"20231208091619"},"Children":[{"Type":"NodeText","Data":"这是因为没有及时清除中断标志位 "}]},{"ID":"20231208091634-oilbj2r","Type":"NodeParagraph","Properties":{"id":"20231208091634-oilbj2r","updated":"20231208091637"},"Children":[{"Type":"NodeText","Data":"如果没有手动清除中断标志位，并且在中断处理函数里没有执行清除操作，那么中断标志位可能仍然保持为高电平。在这种情况下，中断处理函数将继续被触发，可能导致程序行为异常。"}]},{"ID":"20231208091634-wpyn9qu","Type":"NodeParagraph","Properties":{"id":"20231208091634-wpyn9qu","updated":"20231208091654"},"Children":[{"Type":"NodeText","Data":"之所以观察到将那句 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"if (IMU_INT2_READ() == 0)"},{"Type":"NodeText","Data":"​ 读中断引脚电平注释掉后程序能够正常执行，有可能是因为该条件下的代码块不再被执行，从而避免了进入中断处理函数的情况，而不是因为中断标志位的问题。"}]}]},{"ID":"20231208141130-d3umtsl","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231208141130-d3umtsl","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"为什么明明改了寄存器的值结果还是又变回去了？"}]},{"ID":"20231208141202-a0j3ip1","Type":"NodeBlockquote","Properties":{"id":"20231208141202-a0j3ip1","updated":"20231208143028"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231208141203-85nzmlc","Type":"NodeParagraph","Properties":{"id":"20231208141203-85nzmlc","updated":"20231208141226"},"Children":[{"Type":"NodeText","Data":"这是因为只read了reg 没有重新write一下reg"}]}]},{"ID":"20231211104005-sw6g7oa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231211104005-sw6g7oa","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"为什么吸尘器改了wifi上位机一直通信不到？"}]},{"ID":"20231221105633-b1he2d8","Type":"NodeBlockquote","Properties":{"id":"20231221105633-b1he2d8","updated":"20231221105712"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231221105635-wptzqxc","Type":"NodeParagraph","Properties":{"id":"20231221105635-wptzqxc","updated":"20231221105712"},"Children":[{"Type":"NodeText","Data":"是因为没有按机器开机，因为wifi和芯片不是一路电，所以不按wifi就没启动"}]}]},{"ID":"20240125141302-aeexnos","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240125141302-aeexnos","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"为什么keil仿真看到通过wifi发送的数据都是对的 但是python上位机收到的都是错的"}]},{"ID":"20240125141339-yun2yx9","Type":"NodeBlockquote","Properties":{"id":"20240125141339-yun2yx9","updated":"20240125141455"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240125141341-rdfiqu5","Type":"NodeParagraph","Properties":{"id":"20240125141341-rdfiqu5","updated":"20240125141455"},"Children":[{"Type":"NodeText","Data":"因为在c代码中有和wifi共用的串口sprintf代码所以当只用wifi的时候就收到太多数据了，所以要将sprintf的内容注释掉"}]}]},{"ID":"20240430092713-dnma784","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240430092713-dnma784","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"为什么程序没有办法debug并且通信口的电平在不开机的情况下始终是高电平？"}]},{"ID":"20240430092857-ym0pjxf","Type":"NodeBlockquote","Properties":{"id":"20240430092857-ym0pjxf","updated":"20240430093125"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240430092858-bmkuse5","Type":"NodeParagraph","Properties":{"id":"20240430092858-bmkuse5","updated":"20240430092957"},"Children":[{"Type":"NodeText","Data":"通信口不开机的情况下应该保持接地，高电平的原因可能是没有接上拉电阻，也可能是程序跑飞跑错内存地址；"}]},{"ID":"20240430092957-x4gu6dh","Type":"NodeParagraph","Properties":{"id":"20240430092957-x4gu6dh","updated":"20240430093125"},"Children":[{"Type":"NodeText","Data":"我遇到的问题是：因为芯片内存分配的rom只有4k，但是代码内所有的占用空间超过了4k，所以内存不够导致程序跑错地址，所以一直处于高电平"}]}]},{"ID":"20240430092713-lp183wb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240430092713-lp183wb","updated":"20241223135752"},"Children":[{"Type":"NodeText","Data":"USART和UART的区别"}]},{"ID":"20240726134900-e5qcjqr","Type":"NodeBlockquote","Properties":{"id":"20240726134900-e5qcjqr","updated":"20240726134903"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240726134903-d2po0no","Type":"NodeParagraph","Properties":{"id":"20240726134903-d2po0no","updated":"20240726134903"},"Children":[{"Type":"NodeText","Data":"USART（通用同步异步收发器）和UART（通用异步收发器）是用于串行通信的两种接口。它们之间有一些重要的区别："}]},{"ID":"20240726134903-iwvye2x","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240726134903-iwvye2x","updated":"20240726134903"},"Children":[{"ID":"20240726134903-eltvh8o","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20240726134903-eltvh8o","updated":"20240726134903"},"Children":[{"ID":"20240726134903-ytpkyhe","Type":"NodeParagraph","Properties":{"id":"20240726134903-ytpkyhe","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"同步与异步"},{"Type":"NodeText","Data":"："}]},{"ID":"20240726134903-p24bap4","Type":"NodeList","ListData":{},"Properties":{"id":"20240726134903-p24bap4","updated":"20240726134903"},"Children":[{"ID":"20240726134903-t1ss0v1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-t1ss0v1","updated":"20240726134903"},"Children":[{"ID":"20240726134903-v8s8416","Type":"NodeParagraph","Properties":{"id":"20240726134903-v8s8416","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"UART"},{"Type":"NodeText","Data":"：只支持异步通信。这意味着数据传输过程中没有时钟信号，发送和接收双方需要在预先约定的波特率下进行通信。"}]}]},{"ID":"20240726134903-abv5qaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-abv5qaw","updated":"20240726134903"},"Children":[{"ID":"20240726134903-hoe9vdr","Type":"NodeParagraph","Properties":{"id":"20240726134903-hoe9vdr","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"USART"},{"Type":"NodeText","Data":"：支持同步和异步通信。除了异步通信外，USART还能使用时钟信号进行同步通信，从而提高数据传输的可靠性和速度。"}]}]}]}]},{"ID":"20240726134903-cv0gimm","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20240726134903-cv0gimm","updated":"20240726134903"},"Children":[{"ID":"20240726134903-n8posm8","Type":"NodeParagraph","Properties":{"id":"20240726134903-n8posm8","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"时钟信号"},{"Type":"NodeText","Data":"："}]},{"ID":"20240726134903-why7szp","Type":"NodeList","ListData":{},"Properties":{"id":"20240726134903-why7szp","updated":"20240726134903"},"Children":[{"ID":"20240726134903-6mzbe43","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-6mzbe43","updated":"20240726134903"},"Children":[{"ID":"20240726134903-3oehzel","Type":"NodeParagraph","Properties":{"id":"20240726134903-3oehzel","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"UART"},{"Type":"NodeText","Data":"：不需要额外的时钟信号线，数据传输完全依赖于预先设定的波特率。"}]}]},{"ID":"20240726134903-2fzyyve","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-2fzyyve","updated":"20240726134903"},"Children":[{"ID":"20240726134903-p7fl6pk","Type":"NodeParagraph","Properties":{"id":"20240726134903-p7fl6pk","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"USART"},{"Type":"NodeText","Data":"：在同步模式下，使用额外的时钟信号线（SCLK）来同步数据传输。这允许更高的数据传输速率和更稳定的通信。"}]}]}]}]},{"ID":"20240726134903-jiejmo9","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20240726134903-jiejmo9","updated":"20240726134903"},"Children":[{"ID":"20240726134903-rhluoy7","Type":"NodeParagraph","Properties":{"id":"20240726134903-rhluoy7","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用场景"},{"Type":"NodeText","Data":"："}]},{"ID":"20240726134903-k0d0x24","Type":"NodeList","ListData":{},"Properties":{"id":"20240726134903-k0d0x24","updated":"20240726134903"},"Children":[{"ID":"20240726134903-mryjjvq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-mryjjvq","updated":"20240726134903"},"Children":[{"ID":"20240726134903-dzk4jzn","Type":"NodeParagraph","Properties":{"id":"20240726134903-dzk4jzn","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"UART"},{"Type":"NodeText","Data":"：广泛用于需要简单、低成本的通信场景，如嵌入式系统中的串行接口、RS-232接口等。"}]}]},{"ID":"20240726134903-cq5ad6y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-cq5ad6y","updated":"20240726134903"},"Children":[{"ID":"20240726134903-4v67jds","Type":"NodeParagraph","Properties":{"id":"20240726134903-4v67jds","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"USART"},{"Type":"NodeText","Data":"：由于其支持同步通信，适用于需要高速数据传输和更高可靠性的应用场景，如与外部模数转换器（ADC）、数模转换器（DAC）的通信等。"}]}]}]}]},{"ID":"20240726134903-9ubm477","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20240726134903-9ubm477","updated":"20240726134903"},"Children":[{"ID":"20240726134903-cl6c1no","Type":"NodeParagraph","Properties":{"id":"20240726134903-cl6c1no","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"硬件实现"},{"Type":"NodeText","Data":"："}]},{"ID":"20240726134903-o8rc8xf","Type":"NodeList","ListData":{},"Properties":{"id":"20240726134903-o8rc8xf","updated":"20240726134903"},"Children":[{"ID":"20240726134903-gbf4qtl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-gbf4qtl","updated":"20240726134903"},"Children":[{"ID":"20240726134903-sctl8sc","Type":"NodeParagraph","Properties":{"id":"20240726134903-sctl8sc","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"UART"},{"Type":"NodeText","Data":"：实现相对简单，仅需发送和接收数据的硬件。"}]}]},{"ID":"20240726134903-bevkmdl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240726134903-bevkmdl","updated":"20240726134903"},"Children":[{"ID":"20240726134903-7pid5ko","Type":"NodeParagraph","Properties":{"id":"20240726134903-7pid5ko","updated":"20240726134903"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"USART"},{"Type":"NodeText","Data":"：实现较为复杂，因为需要额外的同步时钟信号生成和处理电路。"}]}]}]}]}]}]},{"ID":"20240726134842-kzrkrx1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240726134842-kzrkrx1","updated":"20241223140048"},"Children":[{"Type":"NodeText","Data":"APT中main函数内结构体变量++不变化"}]},{"ID":"20241223135937-35i1zgq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241223135937-35i1zgq","updated":"20241223140048"},"Children":[{"Type":"NodeText","Data":"报错代码"}]},{"ID":"20240726134842-71m60jp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240726134842-71m60jp","updated":"20241223140048"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"typedef struct\n{\n\n uint32_t tick; \n uint32_t flag_1ms;\n uint32_t flag_com_1ms;\n uint32_t flag_10ms;\n uint32_t flag_ultrasonic_10ms;\n//uint8_t flag_500ms;\n user_state_t state;\n// uint8_t Distance;\n uint16_t HostType;\nuint8_t WriteFlagNear;\nuint8_t WriteFlagFar;\nuint32_t IAP_tick;\nuint32_t Dust_tick;\nuint32_t Delay_tick;\nuint8_t Screen_tick;\nuint8_t DustGear;\nuint8_t DustFlag;\nuint16_t Dust_num;\n}user_ctrl1_t;\nuser_ctrl1_t user_ctrl1;\nvoliate uint32_t sys_tick = 0;\nvoliate uint32_t usr_tick= 0;\n/**************************************************/\nint main(void) \n{\n\tAPT32F173_init();\n\n    memset(\u0026user_ctrl1, 0, sizeof(user_ctrl1)); \n\n\n\n\t\tif(1)\n\t\t{\n\t\t\tuser_ctrl1.flag_ultrasonic_10ms++;\n\t\t}\n\twhile(1)\n\t{\n\t\tsys_tick++;\n\t\tusr_tick++;\n\t\tuser_ctrl1.flag_ultrasonic_10ms=100;\n\t\tif(1)\n\t\t{\n\t\t\tuser_ctrl1.flag_ultrasonic_10ms++;\n\t\t}\n\t}\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240726134842-zknjvnh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240726134842-zknjvnh","updated":"20241223140037"},"Children":[{"Type":"NodeText","Data":"现象"}]},{"ID":"20241223140000-1igsqwg","Type":"NodeBlockquote","Properties":{"id":"20241223140000-1igsqwg","updated":"20241223140035"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241223140003-acuvpfe","Type":"NodeParagraph","Properties":{"id":"20241223140003-acuvpfe","updated":"20241223140035"},"Children":[{"Type":"NodeText","Data":"user_ctrl1.flag_ultrasonic_10ms的值就是不变，而sys_tick和usr_tick都是正确变化的"}]}]},{"ID":"20240726134842-pl7bnnk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240726134842-pl7bnnk","updated":"20241223140642"},"Children":[{"Type":"NodeText","Data":"原因"}]},{"ID":"20241223140041-uoha3ap","Type":"NodeBlockquote","Properties":{"id":"20241223140041-uoha3ap","updated":"20241223140636"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241223140042-sd64csu","Type":"NodeParagraph","Properties":{"id":"20241223140042-sd64csu","updated":"20241223140636"},"Children":[{"Type":"NodeText","Data":"结构体user_ctrl1_t被编译器自动优化了\n\n"}]},{"ID":"20241223140636-2e6iz1w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20241223140636-2e6iz1w","updated":"20241223140636"},"Children":[{"Type":"NodeText","Data":"**不频繁使用或不修改的变量**"}]},{"ID":"20241223140636-irckh9f","Type":"NodeParagraph","Properties":{"id":"20241223140636-irckh9f","updated":"20241223140636"},"Children":[{"Type":"NodeText","Data":"对于那些在某些代码路径中没有被修改或频繁使用的变量，编译器会认为它们是"},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeText","Data":"“静态的”"},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeText","Data":"，并且可能只会在函数开始时或代码块开始时被初始化一次。编译器会尝试将它们缓存到寄存器中或在循环中消除冗余访问，这样可以提高效率。"}]}]},{"ID":"20240726134843-i6qrplr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240726134843-i6qrplr","updated":"20241223140824"},"Children":[{"Type":"NodeText","Data":"解决方法"}]},{"ID":"20241223140644-3wku1r3","Type":"NodeBlockquote","Properties":{"id":"20241223140644-3wku1r3","updated":"20241223140809"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241223140645-vmx79xs","Type":"NodeParagraph","Properties":{"id":"20241223140645-vmx79xs","updated":"20241223140753"},"Children":[{"Type":"NodeText","Data":"给结构体增加voliate\n在.h文件中声明extern volatile user_ctrl_t user_ctrl;"}]},{"ID":"20241223140754-euv0o4t","Type":"NodeParagraph","Properties":{"id":"20241223140754-euv0o4t","updated":"20241223140809"},"Children":[{"Type":"NodeText","Data":".c中使用volatile user_ctrl_t user_ctrl;"}]}]},{"ID":"20241223140816-p9dudm3","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241223140816-p9dudm3","updated":"20241223141005"},"Children":[{"Type":"NodeText","Data":"结构体赋值"}]},{"ID":"20241223140826-k0j4r7i","Type":"NodeBlockquote","Properties":{"id":"20241223140826-k0j4r7i","updated":"20241223141005"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241223140828-5c4niz6","Type":"NodeParagraph","Properties":{"id":"20241223140828-5c4niz6","updated":"20241223141005"},"Children":[{"Type":"NodeText","Data":"user_ctrl_t user_ctrl={0};\n这样只会让结构体的第一个数赋值为0\n用memset(\u0026user_ctrl1, 0, sizeof(user_ctrl1));可以全部设置为0，并且要在函数体内使用memset才可以，memset不能用于函数体外"}]}]},{"ID":"20241223140816-48i11my","Type":"NodeParagraph","Properties":{"id":"20241223140816-48i11my","updated":"20241223140816"}},{"ID":"20231024083008-7x3dkq5","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083008-7x3dkq5","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"指针函数与函数指针"}]},{"ID":"20231024083009-ez2iv8d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083009-ez2iv8d","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"指针函数"}]},{"ID":"20231024083010-8ksflh9","Type":"NodeParagraph","Properties":{"id":"20231024083010-8ksflh9","updated":"20231024083010"},"Children":[{"Type":"NodeText","Data":"*"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"类型标识符 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em em","TextMarkTextContent":"函数名(参数表列);"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"指针函数是一类特殊的函数，这类函数的返回值是一个指针。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"在C语言中，指针是一个变量，其值为另一个变量的地址，即，内存位置的直接地址。当我们说一个函数是一个指针函数时，这意味着这个函数返回的是指向一个特定类型变量的指针。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"比如我们要定义一个函数，这个函数返回的是一个指向整数的指针，我们可以这样定义函数："}]},{"ID":"20231024083011-uomk77l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083011-uomk77l","updated":"20231024083011"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"int* function_name() {\n    // function body\n    // suppose we have an integer variable a\n    int a = 10;\n    // we return the address of a\n    return \u0026a;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083012-63emirf","Type":"NodeParagraph","Properties":{"id":"20231024083012-63emirf","updated":"20231024083012"},"Children":[{"Type":"NodeText","Data":"这个函数的返回值类型是整数的指针，这就意味着这个函数返回的值是指向一个整数的指针。这就是所谓的指针函数。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"然而，这种方式在实际中很少使用，因为函数内的局部变量在函数执行完毕后就会销毁，所以返回局部变量的地址的行为通常是不安全的。一种常见的用法是返回动态分配的内存地址，如："}]},{"ID":"20231024083013-dz5pddz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083013-dz5pddz","updated":"20231024083013"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"int* function_name() {\n    // dynamically allocate memory for an integer\n    int* a = malloc(sizeof(int));\n    *a = 10;\n    // we return the address of the dynamically allocated memory\n    return a;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083014-o3nry69","Type":"NodeParagraph","Properties":{"id":"20231024083014-o3nry69","updated":"20231024083014"},"Children":[{"Type":"NodeText","Data":"在这个例子中，函数返回的是指向一个整数的指针，而这个整数在堆上分配的，不会在函数结束时销毁，因此是安全的。然而，这样做的时候需要记住在不需要这块内存的时候，使用free函数将其释放，以避免内存泄漏的问题。"}]},{"ID":"20231024083015-93vvaak","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083015-93vvaak","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"函数指针"}]},{"ID":"20231024083016-605zta9","Type":"NodeParagraph","Properties":{"id":"20231024083016-605zta9","updated":"20231024083016"},"Children":[{"Type":"NodeText","Data":"函数指针是指向函数的指针变量，使用函数指针可以动态地改变函数的调用。函数指针的申明如下："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"返回类型 (*指针变量名)(参数类型);"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"下面给出一些函数指针的例子："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例子一："}]},{"ID":"20231024083017-pvggiq9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083017-pvggiq9","updated":"20231024083017"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include\u003cstdio.h\u003e\n\nvoid printHello() {\n    printf(\"Hello World!\\n\");\n}\n\nint main() {\n    void (*ptr)();  // 定义一个函数指针，指向一个无参数无返回值的函数\n    ptr = printHello;  // 将函数的地址赋给函数指针\n    ptr();  // 通过函数指针调用函数\n    return 0;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083018-eecmgak","Type":"NodeParagraph","Properties":{"id":"20231024083018-eecmgak","updated":"20231024083018"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例子二："}]},{"ID":"20231024083019-s154z9b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083019-s154z9b","updated":"20231024083019"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include\u003cstdio.h\u003e\n\nint add(int a, int b) {\n    return a+b;\n}\n\nint main() {\n    int (*ptr)(int, int); // 定义一个函数指针，指向一个有两个int参数且返回值为int的函数\n    ptr = add;  // 将函数的地址赋给函数指针\n    int result = ptr(2, 3);  // 通过函数指针调用函数\n    printf(\"Result is %d\\n\", result);\n    return 0;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083020-0715s0l","Type":"NodeParagraph","Properties":{"id":"20231024083020-0715s0l","updated":"20231024083020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"例子三："},{"Type":"NodeText","Data":"使用函数指针作为函数的参数"}]},{"ID":"20231024083021-v7eynoi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083021-v7eynoi","updated":"20231024083021"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include\u003cstdio.h\u003e\n\nvoid printNum(int num) {\n    printf(\"Num: %d\\n\", num);\n}\n\nvoid doSomething(int num, void (*callback)(int)) {\n    callback(num);\n}\n\nint main() {\n    doSomething(5, printNum);  // 将函数作为参数传给另一个函数\n    return 0;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083022-pzfmr9o","Type":"NodeParagraph","Properties":{"id":"20231024083022-pzfmr9o","updated":"20231024083022"},"Children":[{"Type":"NodeText","Data":"这些例子展示了如何定义函数指针，如何使用函数指针调用函数以及如何将函数指针作为函数的参数。"}]},{"ID":"20231024083023-n3qh0ha","Type":"NodeBlockquote","Properties":{"id":"20231024083023-n3qh0ha","updated":"20231024083023"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083024-pe3r76r","Type":"NodeParagraph","Properties":{"id":"20231024083024-pe3r76r","updated":"20231024083024"},"Children":[{"Type":"NodeText","Data":"\"Callback\"是一种编程概念，一般翻译为“回调函数”。在编程中，它是指将一个函数（\"A函数\"）作为参数传递给另一个函数（\"B函数\"）在B函数的内部，A函数被调用，这就是“回调”。因此，A函数叫做回调函数，将A函数交给B函数的过程，叫做“回调”。"}]}]},{"ID":"20231024083025-noi5r9n","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083025-noi5r9n","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"光电编码器"}]},{"ID":"20231024083026-34qrib9","Type":"NodeParagraph","Properties":{"id":"20231024083026-34qrib9","updated":"20231024083026"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1697789296910-0529fe8d-b0a9-4b83-a788-266441a5c468.png#averageHue=%23f9f8f8\u0026clientId=u63ce4997-1d23-4\u0026from=paste\u0026height=786\u0026id=u553b76aa\u0026originHeight=786\u0026originWidth=691\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=150152\u0026status=done\u0026style=none\u0026taskId=uf4974452-7d21-4063-b2dc-bb55341de29\u0026title=\u0026width=691","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083027-tqh1dcw","Type":"NodeBlockquote","Properties":{"id":"20231024083027-tqh1dcw","updated":"20231024083027"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083028-qtti1ba","Type":"NodeParagraph","Properties":{"id":"20231024083028-qtti1ba","updated":"20231024083028"},"Children":[{"Type":"NodeText","Data":"由图可知 当A相先经过索引脚B相再经过索引脚 即 A先高电平B再高电平就是正转 如果B先高电平A再高电平就是反转"}]}]},{"ID":"20231024083029-v6saxjl","Type":"NodeBlockquote","Properties":{"id":"20231024083029-v6saxjl","updated":"20231024083029"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083030-ce131mi","Type":"NodeParagraph","Properties":{"id":"20231024083030-ce131mi","updated":"20231024083030"},"Children":[{"Type":"NodeText","Data":"光电编码器，是一种通过光电转换将输出轴上的机械几何位移量转换成脉冲或数字量的传感器。这是目前应用最多的传感器，光电编码器是由光源、光码盘和光敏元件组成。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"光栅盘是在一定直径的圆板上等分地开通若干个长方形孔。由于光电码盘与电动机同轴，电动机旋转时，光栅盘与电动机同速旋转，经发光二极管等电子元件组成的检测装置检测输出若干脉冲信号，通过计算每秒光电编码器输出脉冲的个数就能反映当前电动机的转速。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"此外，为判断旋转方向，码盘还可提供相位相差90°的两路脉冲信号。"}]}]},{"ID":"20231024083031-kdmino8","Type":"NodeParagraph","Properties":{"id":"20231024083031-kdmino8","updated":"20231024083031"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/webp/38661095/1697785619446-6ca2a982-9762-4e04-ad99-c0c3c303d15c.webp#averageHue=%23d8d4b7\u0026clientId=ufb5d62a7-0a77-4\u0026from=paste\u0026id=u9eb942dc\u0026originHeight=307\u0026originWidth=720\u0026originalType=url\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026status=done\u0026style=none\u0026taskId=u74dfdd95-3605-4fc8-ab2e-52145e005e2\u0026title=","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083032-ab47yus","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083032-ab47yus","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"霍尔编码器"}]},{"ID":"20231024083033-3i667e0","Type":"NodeBlockquote","Properties":{"id":"20231024083033-3i667e0","updated":"20231024083033"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083034-ls4p4or","Type":"NodeParagraph","Properties":{"id":"20231024083034-ls4p4or","updated":"20231024083034"},"Children":[{"Type":"NodeText","Data":"霍尔编码器是一种通过磁电转换将输出轴上的机械几何位移量转换成脉冲或数字量的传感器。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"霍尔编码器是由霍尔码盘（磁环）和霍尔元件组成。"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"霍尔码盘是在一定直径的圆板上等分地布置有不同的磁极。霍尔码盘与电动机同轴，电动机旋转时，霍尔元件检测输出若干脉冲信号，为判断转向，一般输出两组存在一定相位差的方波信号。"}]}]},{"ID":"20231024083035-ispdiwk","Type":"NodeParagraph","Properties":{"id":"20231024083035-ispdiwk","updated":"20231024083035"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/webp/38661095/1697785619446-45e79632-a0c5-4905-94f4-67f6d4bb662d.webp#averageHue=%23cac8be\u0026clientId=ufb5d62a7-0a77-4\u0026from=paste\u0026id=ua3af8240\u0026originHeight=476\u0026originWidth=720\u0026originalType=url\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026status=done\u0026style=none\u0026taskId=u1256adce-e773-46aa-915c-8e4c65f73c3\u0026title=","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083036-bjmsu8z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083036-bjmsu8z","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"增量式编码器"}]},{"ID":"20231024083037-6h0xi5x","Type":"NodeParagraph","Properties":{"id":"20231024083037-6h0xi5x","updated":"20231024083037"},"Children":[{"Type":"NodeText","Data":"增量式编码器是将设备运动时的位移信息变成连续的脉冲信号，脉冲个数表示位移量的大小。其特点如下："}]},{"ID":"20231024083038-cj1nw7y","Type":"NodeList","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083038-cj1nw7y","updated":"20231024083038"},"Children":[{"ID":"20231024083039-4e7skpl","Type":"NodeListItem","Data":"-","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083039-4e7skpl","updated":"20231024083039"},"Children":[{"ID":"20231024083040-fdytwff","Type":"NodeParagraph","Properties":{"id":"20231024083040-fdytwff","updated":"20231024083040"},"Children":[{"Type":"NodeText","Data":"只有当"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"设备运动时"},{"Type":"NodeText","Data":"才会输出信号。"}]}]},{"ID":"20231024083041-lh7bvek","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083041-lh7bvek","updated":"20231024083041"},"Children":[{"ID":"20231024083042-oedkzro","Type":"NodeParagraph","Properties":{"id":"20231024083042-oedkzro","updated":"20231024083042"},"Children":[{"Type":"NodeText","Data":"一般会输出"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"通道A和通道B 两组信号，并且有90° 的相位差（1/4个周期）"},{"Type":"NodeText","Data":"，同时采集这两组信号就可以计算设备的运动速度和方向。"}]}]}]},{"ID":"20231024083043-wapx0ej","Type":"NodeParagraph","Properties":{"id":"20231024083043-wapx0ej","updated":"20231024083043"},"Children":[{"Type":"NodeText","Data":"如下图，通道A和通道B的信号的周期相同，且相位相差1/4个周期，结合两相的信号值："}]},{"ID":"20231024083044-bes79se","Type":"NodeList","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083044-bes79se","updated":"20231024083044"},"Children":[{"ID":"20231024083045-med4f3f","Type":"NodeListItem","Data":"-","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083045-med4f3f","updated":"20231024083045"},"Children":[{"ID":"20231024083046-jnoufv1","Type":"NodeParagraph","Properties":{"id":"20231024083046-jnoufv1","updated":"20231024083046"},"Children":[{"Type":"NodeText","Data":"当B相和A相先是都读到高电平（1 1），再B读到高电平，A读到低电平（1 0），则为"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"顺时针"},{"Type":"NodeText","Data":"转"}]}]},{"ID":"20231024083047-smn5nbg","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083047-smn5nbg","updated":"20231024083047"},"Children":[{"ID":"20231024083048-ekahqxx","Type":"NodeParagraph","Properties":{"id":"20231024083048-ekahqxx","updated":"20231024083048"},"Children":[{"Type":"NodeText","Data":"当B相和A相先是都读到低电平（0 0），再B读到高电平，A读到低电平（1 0），则为"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"逆时针"},{"Type":"NodeText","Data":"转"}]}]},{"ID":"20231024083049-nuw36wh","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083049-nuw36wh","updated":"20231024083049"},"Children":[{"ID":"20231024083050-o5mg26t","Type":"NodeParagraph","Properties":{"id":"20231024083050-o5mg26t","updated":"20231024083050"},"Children":[{"Type":"NodeText","Data":"除通道A、通道B 以外，还会设置一个额外的"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"通道Z 信号，表示编码器特定的参考位置"}]}]}]},{"ID":"20231024083051-plko9te","Type":"NodeParagraph","Properties":{"id":"20231024083051-plko9te","updated":"20231024083051"},"Children":[{"Type":"NodeText","Data":"如下图，传感器转一圈后Z 轴信号才会输出一个脉冲，在Z轴输出时，可以通过将AB通道的计数清零，实现对码盘绝对位置的计算。"}]},{"ID":"20231024083052-wdfx9dh","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083052-wdfx9dh","updated":"20231024083052"},"Children":[{"ID":"20231024083053-ae481d3","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20231024083053-ae481d3","updated":"20231024083053"},"Children":[{"ID":"20231024083054-e2hz7tm","Type":"NodeParagraph","Properties":{"id":"20231024083054-e2hz7tm","updated":"20231024083054"},"Children":[{"Type":"NodeText","Data":"增量式编码器只输出设备的位置变化和运动方向，不会输出设备的绝对位置。"}]}]}]},{"ID":"20231024083055-c7ublo8","Type":"NodeParagraph","Properties":{"id":"20231024083055-c7ublo8","updated":"20231024083055"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/webp/38661095/1697785619475-e6f351f7-6199-4c1b-808d-d22c531e6a9f.webp#averageHue=%23e6e6e4\u0026clientId=ufb5d62a7-0a77-4\u0026from=paste\u0026id=u8b43f8a5\u0026originHeight=457\u0026originWidth=643\u0026originalType=url\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026status=done\u0026style=none\u0026taskId=u636b3a7c-de20-4d47-b90c-6d8f58cf26b\u0026title=","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083056-5aysgsx","Type":"NodeParagraph","Properties":{"id":"20231024083056-5aysgsx","updated":"20231024083056"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1697790542091-44293d73-0a6c-4270-b3bc-6db7a87e639b.png#averageHue=%23fdfdfc\u0026clientId=u63ce4997-1d23-4\u0026from=paste\u0026height=587\u0026id=u4fc474f7\u0026originHeight=587\u0026originWidth=1520\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=70951\u0026status=done\u0026style=none\u0026taskId=ua4bc4746-017c-4f4f-a883-a94c00a52b7\u0026title=\u0026width=1520"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231024083058-irusv7w","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083058-irusv7w","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"奇偶校验"}]},{"ID":"20231024083059-hiaetiq","Type":"NodeParagraph","Properties":{"id":"20231024083059-hiaetiq","updated":"20231120152736"},"Children":[{"Type":"NodeText","Data":"\n奇校验是指每帧数据中，包括数据位和奇偶校验位的全部9个位中1的个数必须为奇数；偶校验是指每帧数据中，包括数据位和奇偶校验位的全部9个位中1的个数必须为偶数。\n"}]},{"ID":"20231024083060-keqp3t7","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083060-keqp3t7","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"时钟装置"}]},{"ID":"20231024083061-1c3zrkv","Type":"NodeParagraph","Properties":{"id":"20231024083061-1c3zrkv","updated":"20231024083061"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properti