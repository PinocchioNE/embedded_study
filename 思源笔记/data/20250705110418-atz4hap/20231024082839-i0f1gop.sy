nalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=578106\u0026status=done\u0026style=none\u0026taskId=u79c36570-35f6-4860-b546-125a618671f\u0026title=\u0026width=1035","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1696987194158-196a3120-c66c-43d0-b71c-d40c4c5f1533.png#averageHue=%23f5f4f3\u0026clientId=u0bf46aa8-a848-4\u0026from=paste\u0026height=668\u0026id=u321d0c83\u0026originHeight=668\u0026originWidth=971\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=276484\u0026status=done\u0026style=none\u0026taskId=u0b1bce53-1544-4f7f-93de-5fb4a297ccb\u0026title=\u0026width=971","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083372-7xjpoh4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083372-7xjpoh4","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_spi.h"}]},{"ID":"20231024083373-kngan90","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083373-kngan90","updated":"20231024083373"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_SPI_H__\n#define __BSP_SPI_H__\n\n\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n\n#include \"stm32f10x_usart.h\"\n#include \"stdio.h\"\n\n#include \"core_cm3.h\"\n\nvoid SPI1_Configuration(void);\nuint16_t SPI_Read(void);\n\n#define MAX6675_CS_LOW GPIO_ResetBits(GPIOA, GPIO_Pin_4)\n#define MAX6675_CS_High GPIO_SetBits(GPIOA, GPIO_Pin_4)\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083374-x8oj7ut","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083374-x8oj7ut","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_spi.c"}]},{"ID":"20231024083375-h092sc7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083375-h092sc7","updated":"20231024083375"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_spi.h\"\n#include \"stm32f10x_spi.h\"\n\n\nvoid SPI1_Configuration(void){//初始化配置和外设要求有关\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA|RCC_APB2Periph_SPI1, ENABLE);//开启时钟使能GPIOA和SPI1\n\t\n\t//PA4:CS\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//通用推挽输出 这里不用复用是因为要以gpio的形式来片选\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\t\n\t//PA5:SCK\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_5;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//复用推挽输出 因为此时管脚不能当做普通的GPIO来做 必须要复用为SPI\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\t\n\t//PA6:MISO\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//主机输入 有可能输入高电平也有可能输入低电平 所以浮空输入\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\t\n\t//PA7:MOSI\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//主机输出 复用为推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\n\tSPI_InitTypeDef SPI_InitStructure;\n\tSPI_InitStructure.SPI_Direction = SPI_Direction_2Lines_FullDuplex;//spi是单向还是双向模式 全双工 主机和从机既可收也可发\n\tSPI_InitStructure.SPI_Mode = SPI_Mode_Master;//是当从机还是主机\n\tSPI_InitStructure.SPI_DataSize = SPI_DataSize_16b ;//数据位是8位还是16位 看外设\n\tSPI_InitStructure.SPI_CPOL = SPI_CPOL_Low;//极性 看空闲时间是低电平还是高电平\n\tSPI_InitStructure.SPI_CPHA = SPI_CPHA_2Edge;//上升沿采集还是下降沿采集\n\tSPI_InitStructure.SPI_NSS = SPI_NSS_Soft;//NSS是由硬件控制还是软件控制\n\tSPI_InitStructure.SPI_BaudRatePrescaler = SPI_BaudRatePrescaler_2;//波特率 通信速度 分频系数越小采集频率越快\n\tSPI_InitStructure.SPI_FirstBit = SPI_FirstBit_MSB;//数据是从MSB（高位）开始还是LSB（低位）开始\n\tSPI_InitStructure.SPI_CRCPolynomial = 7;//校验\n\tSPI_Init(SPI1, \u0026SPI_InitStructure);\n\tSPI_Cmd(SPI1, ENABLE);\n}\n\nu16 SPI_Read(void){\n\t\n\twhile(SPI_I2S_GetFlagStatus(SPI1, SPI_I2S_FLAG_TXE)==RESET);//发送标志位是否为空\n\t\n\tSPI_I2S_SendData(SPI1, 0x00);//用于给从机发送一条无用消息 启动两者的连接\n\t\n\twhile(SPI_I2S_GetFlagStatus(SPI1, SPI_I2S_FLAG_RXNE)== RESET);//接受缓存非空标志位\n\n\treturn SPI_I2S_ReceiveData(SPI1);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083376-lywvc0x","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083376-lywvc0x","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083377-uqmm4gy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083377-uqmm4gy","updated":"20231024083377"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//spi\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_spi.h\"\n\nint main(){\n\tu16 c=1;\t\n\tunsigned int flag;\n\tu16 temp;\n\tfloat temprature;\n\t\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\tSPI1_Configuration();\n\twhile(1){\n\n\t\tMAX6675_CS_LOW;\n\t\tc = SPI_Read();\n\t\tMAX6675_CS_High;\n\n\t\tflag = ( c \u0026 0x04);//用于判断热电偶发回来的数据第二位 如果是高就有错\n\t\tif(0 == flag){\n\t\t\t//取出第三到第十四位数据\n\t\t\t\n\t\t\ttemp = c \u003c\u003c 1;\n\t\t\ttemp = temp \u003e\u003e 4;\n\t\t\ttemprature = temp * 0.25;\n\t\t\t\n\t\t\tprintf(\"temprature = %4.2f\\n\",temprature);\n\t\t}else{\n\t\t\tprintf(\"sensor is broken\\n\");\n\t\t}\n\t\t\n\t\tDelay_us(1000000);\n\t} \n\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083378-zf4d4ua","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083378-zf4d4ua","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"步进电机（配合uln2003）"}]},{"ID":"20231024083379-4qp0vj4","Type":"NodeParagraph","Properties":{"id":"20231024083379-4qp0vj4","updated":"20231024083379"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1697002840626-ea94ed0f-319c-43dc-9feb-26846fb4f4bd.png#averageHue=%23f7faf3\u0026clientId=u0bf46aa8-a848-4\u0026from=paste\u0026height=330\u0026id=u4635798a\u0026originHeight=330\u0026originWidth=695\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=283293\u0026status=done\u0026style=none\u0026taskId=ud76118aa-ba31-44a1-93d1-e1081455eba\u0026title=\u0026width=695","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083380-4zn6lps","Type":"NodeBlockquote","Properties":{"id":"20231024083380-4zn6lps","updated":"20231024083380"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083381-xf5pejj","Type":"NodeParagraph","Properties":{"id":"20231024083381-xf5pejj","updated":"20231024083381"},"Children":[{"Type":"NodeText","Data":"uln2003作用：将io口电平放大再输出"}]}]},{"ID":"20231024083382-8ybufwr","Type":"NodeParagraph","Properties":{"id":"20231024083382-8ybufwr","updated":"20231024083382"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1697004536558-21e273e5-026a-4010-a25b-59a10b688e6f.png#averageHue=%23918f85\u0026clientId=u0bf46aa8-a848-4\u0026from=paste\u0026height=280\u0026id=ubff390f6\u0026originHeight=280\u0026originWidth=385\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=118043\u0026status=done\u0026style=none\u0026taskId=ua3e568b2-b03f-443b-80a4-ed3cfd28996\u0026title=\u0026width=385","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083383-iuta5mc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083383-iuta5mc","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"url2003.h"}]},{"ID":"20231024083384-cj2j6js","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083384-cj2j6js","updated":"20231024083384"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __URL2003_H__\n#define __URL2003_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\n//pos 0 neg 1\nenum dir{Pos, \n\tNeg};\n\nvoid ULN2003_Configuration(void);\nvoid stepper(unsigned int dir, unsigned int speed);\nvoid angle_control(unsigned int dir, double angle, unsigned int speed);\n#define STEPPER_ANGLE 0.703125\t\n\t\n#define IN1_HIGH GPIO_WriteBit(GPIOA, GPIO_Pin_4, Bit_SET)\t\n#define IN1_LOW GPIO_WriteBit(GPIOA, GPIO_Pin_4, Bit_RESET)\n\n#define IN2_HIGH GPIO_WriteBit(GPIOA, GPIO_Pin_5, Bit_SET)\t\n#define IN2_LOW GPIO_WriteBit(GPIOA, GPIO_Pin_5, Bit_RESET)\n\n#define IN3_HIGH GPIO_WriteBit(GPIOA, GPIO_Pin_6, Bit_SET)\t\n#define IN3_LOW GPIO_WriteBit(GPIOA, GPIO_Pin_6, Bit_RESET)\n\n#define IN4_HIGH GPIO_WriteBit(GPIOA, GPIO_Pin_7, Bit_SET)\t\n#define IN4_LOW GPIO_WriteBit(GPIOA, GPIO_Pin_7, Bit_RESET)\t\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083385-b0tvryc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083385-b0tvryc","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"url2003.c"}]},{"ID":"20231024083386-wxtax1s","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083386-wxtax1s","updated":"20231024083386"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"url2003.h\"\n\n/*\n 连线表\n STM32\tULN2003驱动\n PA4\t\tIN1\t\tA\n PA5\t\tIN2\t\tB\n PA6\t\tIN3\t\tC\n PA7\t\tIN4\t\tD\n 内部带有减速装置 减速比 1/64 步距角：5.625°/64 (64个脉冲转动5.625°)\n*/\n// 正向 A-AB-B-BC-C-CD-D-DA  （字母代表低电平）（根据步进电机取反器所以要给高）\n// 反向 DA-D-DC-C-BC-B-AB-A\nvoid ULN2003_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4|GPIO_Pin_5|GPIO_Pin_6|GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_ResetBits(GPIOA, GPIO_Pin_4|GPIO_Pin_5|GPIO_Pin_6|GPIO_Pin_7);\n}\n//速度控制\n//dir 正反转 speed 转速 \nvoid stepper(unsigned int dir, unsigned int speed){\n\t//speed就是切换节拍的速度 即每个节拍之间的间隔时间\n\tif(dir == Pos){\n\t\t\t//实现正向八个节拍\n\t\tIN1_HIGH;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\tIN1_HIGH;\n\t\tIN2_HIGH;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\tIN1_LOW;\n\t\tIN2_HIGH;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\tIN1_LOW;\n\t\tIN2_HIGH;\n\t\tIN3_HIGH;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\n\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_HIGH;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\n\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_HIGH;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t\tIN1_HIGH;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t}else{\n\t\t\tIN1_HIGH;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_HIGH;\n\t\tIN4_HIGH;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_LOW;\n\t\tIN2_LOW;\n\t\tIN3_HIGH;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_LOW;\n\t\tIN2_HIGH;\n\t\tIN3_HIGH;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_LOW;\n\t\tIN2_HIGH;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_HIGH;\n\t\tIN2_HIGH;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t\t\n\t\t\t\tIN1_HIGH;\n\t\tIN2_LOW;\n\t\tIN3_LOW;\n\t\tIN4_LOW;\n\t\tDelay_us(speed);\n\t}\n}\n\nvoid angle_control(unsigned int dir, double angle, unsigned int speed){\n\t//64个脉冲会转动5.625° 一个节拍有八个脉冲 所以一个节拍会转动0.703125°\n\t//所以360度需要512个节拍\n\t//所以想要转动任意角度只需要用 想要的角度/0.703125 = 节拍数\n\tint i;\n\t\n\tfor(i = 0; i \u003c angle / STEPPER_ANGLE; i++){\n\t\tstepper(dir, speed);\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083387-yimdq84","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083387-yimdq84","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083388-2x1p22t","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083388-2x1p22t","updated":"20231024083388"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//步进电机\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n#include \"bsp_tcs3200.h\"\n#include \"bsp_dht11.h\"\n#include \"bsp_OLED.h\"\n#include \"bsp_bmp.h\"\n#include \"28BYJ_48_SteepMotor.h\"\n#include \"url2003.h\"\n\n\nint main(){\n\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\t\n\tULN2003_Configuration();\n\t\n\tangle_control(Pos, 360,2000);//角度控制\n\twhile(1){\n\t\t\n\t\t\n\t\t\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083389-5syqzev","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083389-5syqzev","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"JoyStick"}]},{"ID":"20231024083390-aqk5omt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083390-aqk5omt","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"bsp_JoyStick.h"}]},{"ID":"20231024090316-oeecxn8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231024090316-oeecxn8","updated":"20231024090318"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_JOYSTICK_H__\n#define __BSP_JOYSTICK_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x_adc.h\"\n\n/*\nVRX PC0\nVRY\tPC1\nSW\tPC2\n*/\n\nvoid JoyStick_Scan(void);\nvoid JoyStick_Configuration(void);\n#endif\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231024083391-s5v35rm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083391-s5v35rm","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_JoyStick.c"}]},{"ID":"20231024083392-96tkkxu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083392-96tkkxu","updated":"20231024083392"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_JoyStick.h\"\n\nvoid JoyStick_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tADC_InitTypeDef ADC_InitStructure; \n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_ADC1|RCC_APB2Periph_GPIOC, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AIN;//模拟输入\n\tGPIO_Init(GPIOC, \u0026GPIO_InitStructure);//初始化\n//\tGPIO_SetBits(GPIOE,GPIO_Pin_5);\n//\tGPIO_ResetBits(GPIOC,GPIO_Pin_5);\n\t\n\t//ADC1 10 11 \n\tADC_InitStructure.ADC_Mode = ADC_Mode_Independent;//只使用adc1 所以是Independent\n\tADC_InitStructure.ADC_ScanConvMode = DISABLE;//多通道扫描还是单通道\n\tADC_InitStructure.ADC_ContinuousConvMode = DISABLE;//是否是人为控制 还是 自动\n\tADC_InitStructure.ADC_ExternalTrigConv = ADC_ExternalTrigConv_None;//触发方式 当前是软件触发\n\tADC_InitStructure.ADC_DataAlign = ADC_DataAlign_Right;//数据对齐 右对齐（右对齐模式）：ADC转换的结果将会出现在数据寄存器的最右侧，也就是最低位。这是ADC的默认设置。在这种模式下，如果ADC是12位的，那么转换的结果将会在最低的12位，高位将会是0。\n\tADC_InitStructure.ADC_NbrOfChannel = 2;//PC0和PC1\n\tADC_Init(ADC1, \u0026ADC_InitStructure);\n\t\n\tRCC_ADCCLKConfig(RCC_PCLK2_Div8);//时钟 72/8 = 9MHz 没有超过14MHz\n\t//\n\n\tADC_Cmd(ADC1, ENABLE);\n\t\n\tADC_ResetCalibration(ADC1);//复位校准adc\n\twhile(ADC_GetResetCalibrationStatus(ADC1));//等待复位\n\tADC_StartCalibration(ADC1);\n\twhile(ADC_GetCalibrationStatus(ADC1));//等待校验完成 \n\t\n\t//PC2 按钮按下去 需要使用上拉输入 按下低电平 抬起高电平\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_2;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//上拉输入\n\tGPIO_Init(GPIOC, \u0026GPIO_InitStructure);//初始化\n}\n\nint Key_Scan_JoyStick(GPIO_TypeDef* GPIOx, unsigned int Pin){\n\tif(GPIO_ReadInputDataBit(GPIOx, Pin) == 0){\n\t\tDelay_us(500);\n\t\tif(GPIO_ReadInputDataBit(GPIOx, Pin)==0){\n\t\t\twhile(GPIO_ReadInputDataBit(GPIOx, Pin) == 0);\n\t\t\treturn KEY_ON;\n\t\t}\n\t\treturn KEY_OFF;\n\t}\n\treturn KEY_OFF;\n}\n\n//因为采集到的是12位 但是没有12位的数据格式 所以用16位的\nu16 Get_ADC_Value(unsigned int channel){\n\t//设置要打开的通道\n\tADC_RegularChannelConfig(ADC1, channel, 1, ADC_SampleTime_55Cycles5 );//指定让哪个通道开始工作\n\tADC_SoftwareStartConvCmd(ADC1, ENABLE);\n\n\twhile(!ADC_GetFlagStatus(ADC1, ADC_FLAG_EOC));//ADC_FLAG_EOC:转换结束标志位\n\t\n\treturn ADC_GetConversionValue(ADC1);\n\t\n}\n\nu16 Get_ADC_Average(unsigned int channel, unsigned int times){\n\tint i;\n\tu16 total = 0;\n\tfor(i = 0; i \u003c times; i++){\n\t\ttotal += Get_ADC_Value(channel);\n\t\tDelay_us(10000);\n\t}\n\treturn total / times;\n}\n/***\nstatus\t\tx\t\t\ty\nnone\t\t\t1\t\t\t1\nup\t\t\t\t1\t\t\t3\ndown\t\t\t1\t\t\t0\nleft\t\t\t3\t\t\t1\nright\t\t\t0\t\t\t1\nup_left\t\t3\t\t\t3\nup_right\t0\t\t\t3\ndown_left\t3\t\t\t0\ndown_right0\t\t\t0\n\n***/\nvoid JoyStick_Scan(void){\n\tu16 adc_x, adc_y, adc_z;\n\tint x,y,z;\n\t\n\tadc_x = Get_ADC_Average(ADC_Channel_10, 10);\n\tadc_y = Get_ADC_Average(ADC_Channel_11, 10);\n\t\n\tif(Key_Scan_JoyStick(GPIOC, GPIO_Pin_2) == 1){\n\t\tprintf(\"PRESS\\n\");\n\t}\n\t\n\t\n\tx = adc_x * (3.3 / 4096);// 输入电压是3.3v 4096的意思是：十二位adc 也就是 111111111111 结果就是4096\n\ty = adc_y * (3.3 / 4096);\n//\tz = adc_y * (3.3 / 4096);\n\n//\tprintf(\"adc_x = %lf\\n\", x);\n//\tprintf(\"adc_y = %lf\\n\", y);\n\t\n\tif(x == 1 \u0026\u0026 y == 3){\n\t\tprintf(\"UP\\n\");\n\t}else if(x == 1 \u0026\u0026 y == 0){\n\t\tprintf(\"DOWN\\n\");\n\t}else if(x == 3 \u0026\u0026 y == 1){\n\t\tprintf(\"LEFT\\n\");\n\t}else if(x == 0 \u0026\u0026 y == 1){\n\t\tprintf(\"RIGHT\\n\");\n\t}else if(x == 3 \u0026\u0026 y == 3){\n\t\tprintf(\"UP_LEFT\\n\");\n\t}else if(x == 0 \u0026\u0026 y == 3){\n\t\tprintf(\"UP_RIGHT\\n\");\n\t}else if(x == 3 \u0026\u0026 y == 0){\n\t\tprintf(\"DOWN_LEFT\\n\");\n\t}else if(x == 0 \u0026\u0026 y == 0){\n\t\tprintf(\"DOWN_RIGHT\\n\");\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083393-grehpgu","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083393-grehpgu","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083394-ev4zhtc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083394-ev4zhtc","updated":"20231024083394"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n#include \"bsp_tcs3200.h\"\n#include \"bsp_dht11.h\"\n#include \"bsp_OLED.h\"\n#include \"bsp_bmp.h\"\n#include \"28BYJ_48_SteepMotor.h\"\n#include \"url2003.h\"\n#include \"bsp_JoyStick.h\"\n\nint main(){\n\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\t\n\tJoyStick_Configuration();\n\twhile(1){\n\t\t\n\t\tJoyStick_Scan();\n\t\t\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231213095627-bnv14ed","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231213095627-bnv14ed","updated":"20241014112053"},"Children":[{"Type":"NodeText","Data":"陀螺仪移植"}]},{"ID":"20241014112047-lcqcfyn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241014112047-lcqcfyn","updated":"20241014112053"},"Children":[{"Type":"NodeText","Data":"i2c速率"}]},{"ID":"20241014112052-8md9nmx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241014112052-8md9nmx","updated":"20241014112053"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"I2C速率分三种模式：标准，快速以及高速，三者速率分别如下\n标准速率：100Kbits/s\n快速速率：400Kbits/s\n快速模式增强：1Mbit/s\n高速速率：3.4Mbits/s\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213095635-vkdq309","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231213095635-vkdq309","updated":"20241014112534"},"Children":[{"Type":"NodeText","Data":"陀螺仪配置几个重要的点"}]},{"ID":"20231213095901-iaa7707","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231213095901-iaa7707","updated":"20241014112534"},"Children":[{"Type":"NodeText","Data":"i2c的配置"}]},{"ID":"20231213100034-v584f2x","Type":"NodeBlockquote","Properties":{"id":"20231213100034-v584f2x","updated":"20231213100151"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213100035-8366o0x","Type":"NodeParagraph","Properties":{"id":"20231213100035-8366o0x","updated":"20231213100150"},"Children":[{"Type":"NodeText","Data":"时钟频率的问题 这是开始配置i2c时遇到的问题 逻辑分析仪在看信号的时候一直没有波形 表示i2c根本没有跑通 "}]}]},{"ID":"20231213100151-dwb3iof","Type":"NodeBlockquote","Properties":{"id":"20231213100151-dwb3iof","updated":"20241014112534"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213100153-gl0n3vq","Type":"NodeParagraph","Properties":{"id":"20231213100153-gl0n3vq","updated":"20231213100159"},"Children":[{"Type":"NodeText","Data":"还有时钟配置的方法"}]},{"ID":"20231213105546-efsw5h3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213105546-efsw5h3","updated":"20231213105602"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"预分频器设置 = 时钟频率源 / I2C时钟频率 = 48Mhz / ?kHz\n\n例如：如果是100khz 48MHz / 100kHz = 480000 KHz / 100 kHz = 480 (这里的结果是一个无单位的数字，表示一个频率相对于另一个频率的比率。)\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213105547-8s4rggy","Type":"NodeParagraph","Properties":{"id":"20231213105547-8s4rggy","updated":"20231213105623"},"Children":[{"Type":"NodeText","Data":"时钟频率相关"}]},{"ID":"20231213110027-hg8mret","Type":"NodeParagraph","Properties":{"id":"20231213110027-hg8mret","updated":"20241014112534"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 520px;","style":"width: 510px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213110027-ysl98gq.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 510px;\" parent-style=\"width: 520px;\"}"},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213110648-zejonvb.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeText","Data":"​​"}]},{"ID":"20231213105625-ryavtl2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213105625-ryavtl2","updated":"20231213110914"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"MPLL主相位锁定环 \n\t华大芯片的HRC是有两种模式的 一种是16 一种是20\n\t如果是20MHz的情况：\n\t\t输入 = 20 / 2 = 10 \n\t\t输出 = 10 * 30 = 300 \n\t\t时钟频率 = 300 / 5 = 60 MHz(这也是为什么陀螺仪程序跑出来时钟频率是60MHz的原因)\n\t如果是16MHz的情况：\n\t输入 = HRC / pllmDiv = 16 / 2 = 8\n\t输出 = MPLL输入 * plln = 8 * 30 = 240\n\t240 / 5 = 48 MHz\nHRC内部高速时钟\nplln倍频器\npllmDiv输入分频器\nHRC高速内部RC振荡器\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213105605-qwfmw6a","Type":"NodeParagraph","Properties":{"id":"20231213105605-qwfmw6a","updated":"20231213111941"},"Children":[{"Type":"NodeText","Data":"I2C中断引脚配置"}]},{"ID":"20231213112021-3ha6wgv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213112021-3ha6wgv","updated":"20231213112036"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"void IO_IMU_INT2_Init(void)\n{\n\tstc_port_init_t stcPortInit = {0};\n\n\tstcPortInit.enPinMode = Pin_Mode_In;\n\tstcPortInit.enPinDrv = Pin_Drv_L;\n\tstcPortInit.enPullUp = Disable;\n\tPORT_Init(IMU_INT2_PORT, IMU_INT2_PIN, \u0026stcPortInit);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213112021-hmb5z9s","Type":"NodeParagraph","Properties":{"id":"20231213112021-hmb5z9s","updated":"20231213112120"},"Children":[{"Type":"NodeText","Data":"i2c初始化（标注句是最重要的 就是这句话没有配置导致问题一直存在）"}]},{"ID":"20231213112951-hisy0bn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213112951-hisy0bn","updated":"20231213113000"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"en_result_t i2c_bus_init(i2c_bus_t *hi2c)\n{\n    en_result_t enRet;\n    float32_t fErr;\n    stc_i2c_init_t stcI2cInit;\n    stc_clk_freq_t stcClkFreq;\n\n    PORT_SetFunc(hi2c-\u003escl.port, hi2c-\u003escl.pin, hi2c-\u003escl.func_sel, Disable);\n    PORT_SetFunc(hi2c-\u003esda.port, hi2c-\u003esda.pin, hi2c-\u003esda.func_sel, Disable);\n\n    PWC_Fcg1PeriphClockCmd(hi2c-\u003ecfg.clk_periph, Enable);\n\n    I2C_DeInit(hi2c-\u003ei2c_periph);\n\tCLK_GetClockFreq(\u0026stcClkFreq);//这句是关键 需要将时钟频率进行配置 \n    MEM_ZERO_STRUCT(stcI2cInit);\n    stcI2cInit.u32Pclk3 = stcClkFreq.pclk3Freq;\n    stcI2cInit.u32Baudrate = hi2c-\u003ecfg.baudrate;\n    stcI2cInit.u32SclTime = 0ul;\n    enRet = I2C_Init(hi2c-\u003ei2c_periph, \u0026stcI2cInit);\n\n    I2C_BusWaitCmd(hi2c-\u003ei2c_periph, Enable);\n\n    return enRet;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213112952-8igggz7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20231213112952-8igggz7","updated":"20231213113012"},"Children":[{"Type":"NodeText","Data":"怎么调I2C？"}]},{"ID":"20231213112953-iu5z6e9","Type":"NodeParagraph","Properties":{"id":"20231213112953-iu5z6e9","updated":"20231213112953"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213112953-7wfshsf.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213113017-8y8ennm","Type":"NodeParagraph","Properties":{"id":"20231213113017-8y8ennm","updated":"20231213131235"},"Children":[{"Type":"NodeText","Data":"首先找到whoami"}]},{"ID":"20231213113026-abfpug9","Type":"NodeParagraph","Properties":{"id":"20231213113026-abfpug9","updated":"20231213131304"},"Children":[{"Type":"NodeText","Data":"然后在for 和 switch上打断点 看i2c的波形 看是否有ack应答"}]}]},{"ID":"20231213095842-33r925q","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231213095842-33r925q","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"陀螺仪初始化配置"}]},{"ID":"20231213112344-u5fy2rm","Type":"NodeParagraph","Properties":{"id":"20231213112344-u5fy2rm","updated":"20240726132920"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 75%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213112344-urw3g5f.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 75%;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213112356-6mumyaj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231213112356-6mumyaj","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"imu初始化配置"}]},{"ID":"20231213112419-55261d7","Type":"NodeBlockquote","Properties":{"id":"20231213112419-55261d7","updated":"20231213141021"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213112456-5kuc5bk","Type":"NodeParagraph","Properties":{"id":"20231213112456-5kuc5bk","updated":"20231213112537"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213112456-igygmyy.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213112545-elz54xg","Type":"NodeParagraph","Properties":{"id":"20231213112545-elz54xg","updated":"20231213131624"},"Children":[{"Type":"NodeText","Data":"​​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213112748-jmcpxmo.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213131624-b0nuph0.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20231213133331-r8xzvzf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20231213133331-r8xzvzf","updated":"20231213133549"},"Children":[{"Type":"NodeText","Data":"加速度角速度配置"}]},{"ID":"20231213133332-2b3jz7p","Type":"NodeParagraph","Properties":{"id":"20231213133332-2b3jz7p","updated":"20231213133332"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 47%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213132845-3bxzezz.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 47%;\"}"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 52%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213132857-vv7cm1x.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 52%;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213131631-5sphaz8","Type":"NodeBlockquote","Properties":{"id":"20231213131631-5sphaz8","updated":"20231213131702"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213131649-6hsloao","Type":"NodeParagraph","Properties":{"id":"20231213131649-6hsloao","updated":"20231213131702"},"Children":[{"Type":"NodeText","Data":"图一：注意imu初始化时用的什么模式 当时没注意这里面用的一直是SPI模式，所以也是导致i2c没起来的问题"}]},{"ID":"20231213131649-yejaadg","Type":"NodeParagraph","Properties":{"id":"20231213131649-yejaadg","updated":"20231213131649"},"Children":[{"Type":"NodeText","Data":"polling也是不能打开的 因为需要用中断触发来读取数据 如果轮询的话会非常浪费cpu资源和时间"}]}]},{"ID":"20231213131651-lb190cp","Type":"NodeBlockquote","Properties":{"id":"20231213131651-lb190cp","updated":"20231213133559"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213131704-xi8xb4t","Type":"NodeParagraph","Properties":{"id":"20231213131704-xi8xb4t","updated":"20231213133024"},"Children":[{"Type":"NodeText","Data":"图2："}]},{"ID":"20231213133149-wybrady","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213133149-wybrady","updated":"20231213133149"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    /* Setup MEMs properties. */\n    status |= inv_imu_read_reg(GYRO_CONFIG0, 1, (uint8_t*)\u0026icm_dev.gyro_cfg0);\n    status |= inv_imu_read_reg(ACCEL_CONFIG0, 1, (uint8_t*)\u0026icm_dev.acc_cfg0);\n\n    //我改的 角速度量程1000 加速度量程8g\n    icm_dev.gyro_cfg0.gyro_ui_fs_sel = GYRO_CONFIG0_FS_SEL_1000dps;\n    icm_dev.acc_cfg0.accel_ui_fs_sel = ACCEL_CONFIG0_FS_SEL_8g;\n    icm_dev.acc_cfg0.accel_odr = ACCEL_CONFIG0_ODR_50_HZ;\n    icm_dev.gyro_cfg0.gyro_odr = GYRO_CONFIG0_ODR_50_HZ;\n\n    status |= inv_imu_write_reg(GYRO_CONFIG0, 1, (uint8_t*)\u0026icm_dev.gyro_cfg0);\n    status |= inv_imu_write_reg(ACCEL_CONFIG0, 1, (uint8_t*)\u0026icm_dev.acc_cfg0);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213133025-moi5prs","Type":"NodeParagraph","Properties":{"id":"20231213133025-moi5prs"},"Children":[{"Type":"NodeText","Data":"首先"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"inv_imu_read_reg"},{"Type":"NodeText","Data":"​读寄存器"}]},{"ID":"20231213133028-526ty0i","Type":"NodeParagraph","Properties":{"id":"20231213133028-526ty0i"},"Children":[{"Type":"NodeText","Data":" 然后设定寄存器内的值 "}]},{"ID":"20231213133031-7o4gwb5","Type":"NodeParagraph","Properties":{"id":"20231213133031-7o4gwb5"},"Children":[{"Type":"NodeText","Data":"最后再"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"inv_imu_write_reg"},{"Type":"NodeText","Data":"​写入寄存器 其中加速度和角速度的频率都是50Hz 即采样时间 = 1 / 采样频率 = 1 / 50 = 20ms"}]}]},{"ID":"20231213133559-6olj6sy","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20231213133559-6olj6sy","updated":"20231213133603"},"Children":[{"Type":"NodeText","Data":"中断引脚配置"}]},{"ID":"20231213131919-genlpxv","Type":"NodeParagraph","Properties":{"id":"20231213131919-genlpxv","updated":"20231213133624"},"Children":[{"Type":"NodeText","Data":" ​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213133523-d38m2ir.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213133207-eyhlibf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213133207-eyhlibf","style":"line-height: 22px; background-color: var(--b3-font-background1);","updated":"20231213133616"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    status |= inv_imu_read_reg(INT_CONFIG_REG, 1, (uint8_t*)\u0026icm_dev.int_config_t_t);\n    //自己改的\n    icm_dev.int_config_t_t.int2_drive_circuit = INT_CONFIG_INT2_DRIVE_CIRCUIT_PP;//推挽输出\n    icm_dev.int_config_t_t.int2_polarity = INT_CONFIG_INT2_POLARITY_HIGH;//高电平有效\n    icm_dev.int_config_t_t.int2_mode = INT_CONFIG_INT2_LATCH;//锁存模式\n    // reg_int_config.int2_mode =INT_CONFIG_INT2_PULSE;\n    status |= inv_imu_write_reg(INT_CONFIG_REG, 1, (uint8_t*)\u0026icm_dev.int_config_t_t);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213131920-2pbo5e3","Type":"NodeBlockquote","Properties":{"id":"20231213131920-2pbo5e3","updated":"20231213133235"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213133211-ovhzzbe","Type":"NodeParagraph","Properties":{"id":"20231213133211-ovhzzbe","updated":"20231213133235"},"Children":[{"Type":"NodeText","Data":"配置陀螺仪的中断引脚 是要配置INT1还是INT2都需要注意"}]}]},{"ID":"20231213131920-984jsjn","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20231213131920-984jsjn","updated":"20231213133944"},"Children":[{"Type":"NodeText","Data":" 中断寄存器配置"}]},{"ID":"20231213134029-t1ew69p","Type":"NodeParagraph","Properties":{"id":"20231213134029-t1ew69p","updated":"20231213134111"},"Children":[{"Type":"NodeText","Data":"​​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213134111-bo82y69.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​​"}]},{"ID":"20231213133948-l1vtp6r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213133948-l1vtp6r","updated":"20231213134043"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    //get inital int src reg value\n    inv_imu_read_reg(INT_SOURCE3, 1, (uint8_t*)\u0026icm_dev.int_src3);//中断使能 int1还是int2 改过的\n    icm_dev.int_src3.drdy_int2_en = 1;//\n    // icm_dev.int_src3.agc_rdy_int2_en = 1;\n    inv_imu_write_reg(INT_SOURCE3, 1, (uint8_t*)\u0026icm_dev.int_src3);//中断使能 int1还是int2 改过的\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213131921-73w58pv","Type":"NodeBlockquote","Properties":{"id":"20231213131921-73w58pv","updated":"20231213134143"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213134113-l3i7d5z","Type":"NodeParagraph","Properties":{"id":"20231213134113-l3i7d5z","updated":"20231213134143"},"Children":[{"Type":"NodeText","Data":"寄存器第三位置1 设置为当有数据更新就会产生中断到INT2"}]}]},{"ID":"20231213131921-rgj28yc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20231213131921-rgj28yc","updated":"20231213134248"},"Children":[{"Type":"NodeText","Data":" 中断引脚信号的清除方式"}]},{"ID":"20231213134237-fc2em9a","Type":"NodeParagraph","Properties":{"id":"20231213134237-fc2em9a","updated":"20231213134237"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213134237-tdwzb7m.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20231213141021-3q2ia65","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20231213141021-3q2ia65","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"1.用的是什么模式？脉冲模式还是锁存模式"}]},{"ID":"20231213141021-13quelh","Type":"NodeParagraph","Properties":{"id":"20231213141021-13quelh","updated":"20231213141021"},"Children":[{"Type":"NodeText","Data":"latch模式和pluse模式区别"}]},{"ID":"20231213141021-rcvrat6","Type":"NodeBlockquote","Properties":{"id":"20231213141021-rcvrat6","updated":"20231213141021"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213141021-biyfd3j","Type":"NodeParagraph","Properties":{"id":"20231213141021-biyfd3j","updated":"20231213141021"},"Children":[{"Type":"NodeText","Data":"在传感器中，\"latch\"（锁存）模式和\"pulse\"（脉冲）模式是两种不同的中断触发模式。"}]},{"ID":"20231213141021-itp2vds","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20231213141021-itp2vds","updated":"20231213141021"},"Children":[{"ID":"20231213141021-i0oktpc","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20231213141021-i0oktpc","updated":"20231213141021"},"Children":[{"ID":"20231213141021-61lup42","Type":"NodeParagraph","Properties":{"id":"20231213141021-61lup42","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Latch模式："}]},{"ID":"20231213141021-jqx3702","Type":"NodeList","ListData":{},"Properties":{"id":"20231213141021-jqx3702","updated":"20231213141021"},"Children":[{"ID":"20231213141021-axiwzjw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20231213141021-axiwzjw","updated":"20231213141021"},"Children":[{"ID":"20231213141021-u80rbaw","Type":"NodeParagraph","Properties":{"id":"20231213141021-u80rbaw","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"概念："},{"Type":"NodeText","Data":" 在Latch模式下，一旦中断条件被满足，中断状态将一直保持，直到主机处理器（MCU）读取了相应的中断寄存器。换句话说，中断状态会被锁存，直到主机处理器采取措施将其清除。"}]}]},{"ID":"20231213141021-ur7qr06","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20231213141021-ur7qr06","updated":"20231213141021"},"Children":[{"ID":"20231213141021-c3hg1qn","Type":"NodeParagraph","Properties":{"id":"20231213141021-c3hg1qn","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用场景："},{"Type":"NodeText","Data":" Latch模式适用于需要确保中断状态被持久化，直到主机处理器处理完中断并清除状态的情况。这对于确保不错过中断事件很有用，即使主机处理器在中断发生后的某段时间内处于非活动状态。"}]}]}]}]},{"ID":"20231213141021-utme276","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20231213141021-utme276","updated":"20231213141021"},"Children":[{"ID":"20231213141021-vkwec3k","Type":"NodeParagraph","Properties":{"id":"20231213141021-vkwec3k","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Pulse模式："}]},{"ID":"20231213141021-s0ncbzz","Type":"NodeList","ListData":{},"Properties":{"id":"20231213141021-s0ncbzz","updated":"20231213141021"},"Children":[{"ID":"20231213141021-sac53kn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20231213141021-sac53kn","updated":"20231213141021"},"Children":[{"ID":"20231213141021-7gf1ta4","Type":"NodeParagraph","Properties":{"id":"20231213141021-7gf1ta4","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"概念："},{"Type":"NodeText","Data":" 在Pulse模式下，中断状态只在中断条件满足的瞬间保持，然后会立即清除。即，中断状态形成一个脉冲，主机处理器需要尽快处理中断以避免错过。"}]}]},{"ID":"20231213141021-ow59n85","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20231213141021-ow59n85","updated":"20231213141021"},"Children":[{"ID":"20231213141021-ikkne4t","Type":"NodeParagraph","Properties":{"id":"20231213141021-ikkne4t","updated":"20231213141021"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用场景："},{"Type":"NodeText","Data":" Pulse模式适用于需要快速响应中断，但不需要持久化中断状态的情况。如果主机处理器有能力迅速响应中断并且不需要保持中断状态，那么Pulse模式可能是更合适的选择。"}]}]}]}]}]}]},{"ID":"20231213135550-0lmm4k4","Type":"NodeParagraph","Properties":{"id":"20231213135550-0lmm4k4","updated":"20231213135550"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213135550-8gdz6s4.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​​"}]},{"ID":"20231213134156-tkljkom","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20231213134156-tkljkom","updated":"20231213135306"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    inv_imu_read_reg(INT_CONFIG0_MREG, 2, (uint8_t*)\u0026icm_dev.int_config0);//改latch的中断状态模式\n    icm_dev.int_config0.ui_drdy_int_clear = 0x2;// 10 0b10 = 0010 = 2^1 = 0000 0000 0000 0010 = 0x2\n    inv_imu_write_reg(INT_CONFIG0_MREG, 2, (uint8_t*)\u0026icm_dev.int_config0);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20231213134156-f8cpi0b","Type":"NodeBlockquote","Properties":{"id":"20231213134156-f8cpi0b","updated":"20231213135759"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213135322-9dsnlix","Type":"NodeParagraph","Properties":{"id":"20231213135322-9dsnlix","updated":"20231213135344"},"Children":[{"Type":"NodeText","Data":"配置为通过读取寄存器来清除中断"}]},{"ID":"20231213135553-yzhe82y","Type":"NodeParagraph","Properties":{"id":"20231213135553-yzhe82y","updated":"20231213135635"},"Children":[{"Type":"NodeText","Data":"图二为中断状态的清除方式解释 有数据自动置1 读取寄存器后变为0"}]}]}]},{"ID":"20231213135759-6pdxrth","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231213135759-6pdxrth","updated":"20241017085953"},"Children":[{"Type":"NodeText","Data":"数据处理"}]},{"ID":"20231213135806-xr2jgio","Type":"NodeBlockquote","Properties":{"id":"20231213135806-xr2jgio","updated":"20241017085953"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213135811-r914zx9","Type":"NodeParagraph","Properties":{"id":"20231213135811-r914zx9","updated":"20241017085953"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213135732-1xu1c7l.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213135819-5ppa4xn","Type":"NodeBlockquote","Properties":{"id":"20231213135819-5ppa4xn","updated":"20231213140102"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213135824-tyjjk5y","Type":"NodeParagraph","Properties":{"id":"20231213135824-tyjjk5y","updated":"20231213140100"},"Children":[{"Type":"NodeText","Data":"注意memset是清除数据的一步 但是为什么注释呢？因为一旦打开就会在开始获取数据前清除数组 "}]},{"ID":"20231213140102-5dad1mx","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20231213140102-5dad1mx","updated":"20231213140102"},"Children":[{"ID":"20231213140102-75gs6f0","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20231213140102-75gs6f0","updated":"20231213140102"},"Children":[{"ID":"20231213140102-zqwci5j","Type":"NodeParagraph","Properties":{"id":"20231213140102-zqwci5j","updated":"20231213140102"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"内存泄漏"},{"Type":"NodeText","Data":"：如果你的程序在运行时分配了内存但没有正确释放，可能会出现内存泄漏。随着程序的反复运行，可用内存可能越来越少，最终导致程序因内存不足而崩溃。"}]}]},{"ID":"20231213140102-ub7d7hi","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20231213140102-ub7d7hi","updated":"20231213140102"},"Children":[{"ID":"20231213140102-ubauy81","Type":"NodeParagraph","Properties":{"id":"20231213140102-ubauy81","updated":"20231213140102"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"内存越界"},{"Type":"NodeText","Data":"：在C语言中，如果你的程序越界访问了数组或其他数据结构，可能会破坏内存中的其他数据，导致未定义行为，包括程序崩溃。"}]}]},{"ID":"20231213140102-4b6wpto","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20231213140102-4b6wpto","updated":"20231213140102"},"Children":[{"ID":"20231213140102-cbbrsuw","Type":"NodeParagraph","Properties":{"id":"20231213140102-cbbrsuw","updated":"20231213140102"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"竞争条件"},{"Type":"NodeText","Data":"：如果你在使用多线程，可能存在线程之间的竞争条件。这可能导致数据结构在未同步的情况下被多个线程访问，从而破坏数据的一致性。"}]}]},{"ID":"20231213140102-gt6rg6d","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20231213140102-gt6rg6d","updated":"20231213140102"},"Children":[{"ID":"20231213140102-c7u7c9v","Type":"NodeParagraph","Properties":{"id":"20231213140102-c7u7c9v","updated":"20231213140102"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用未初始化的内存"},{"Type":"NodeText","Data":"：如果"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"memset"},{"Type":"NodeText","Data":"​被用来初始化"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"accGyroDataPacket"},{"Type":"NodeText","Data":"​结构体的内存，但是你移除了这个步骤，并且程序中其他地方假设这块内存是初始化过的，这可能导致问题。"}]}]}]}]},{"ID":"20231213135811-ceoif82","Type":"NodeParagraph","Properties":{"id":"20231213135811-ceoif82","updated":"20231213140143"},"Children":[{"Type":"NodeText","Data":"但是这一步注释也只使程序多运行了一会，接下来的一步才是最重要的"}]},{"ID":"20231213140210-nqfve8g","Type":"NodeParagraph","Properties":{"id":"20231213140210-nqfve8g","updated":"20231213140210"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213140210-ropcou9.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213140211-lkj0tty","Type":"NodeBlockquote","Properties":{"id":"20231213140211-lkj0tty","updated":"20231213140859"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231213140213-s99yovh","Type":"NodeParagraph","Properties":{"id":"20231213140213-s99yovh","updated":"20231213140641"},"Children":[{"Type":"NodeText","Data":"这一步将索引进行内部初始化 而不是只在函数外面定义一个全局变量就结束 因为单片机每次上电除了烧程序的第一次是运行函数外的变量的 之后除非函数内部初始化否则都是从上一次的数值接着变化的"}]}]},{"ID":"20231213140900-9dj701t","Type":"NodeParagraph","Properties":{"id":"20231213140900-9dj701t","updated":"20231213140900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231213140900-31moayr.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231213140900-f638jge","Type":"NodeParagraph","Properties":{"id":"20231213140900-f638jge","updated":"20231213140958"},"Children":[{"Type":"NodeText","Data":"这也是之前做决策树预测用户行为的问题，当时将上面这些变量都写在外面 没有初始化 导致每次进函数判断的时候都没有从0开始而导致判断有误"}]}]},{"ID":"20231213141201-ktdezwo","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231213141201-ktdezwo","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"吸尘器电流识别"}]},{"ID":"20240122092511-dvfw69n","Type":"NodeParagraph","Properties":{"id":"20240122092511-dvfw69n","updated":"20240701104415"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"1"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/1-20240122092511-km3y1iz.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20240122092546-hc9b1y0","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20240122092546-hc9b1y0","updated":"20250217143515"},"Children":[{"Type":"NodeText","Data":"uart发送格式参考"}]},{"ID":"20240731141918-ke4ioqj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240731141918-ke4ioqj","updated":"20240731141933"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"void Machine_Frame(void)\n{\n\tMachine_Tx.Checksum = 0;\n\tMachine_Tx.Index = 0;\n\t//////// 帧头\n\tMachine_Tx.TxBuf[Machine_Tx.Index++] = 0xF2;//数组长度为20\n\n\t//////// Cmd\n\tMachine_Tx.Cmd0 = MACHINE_TX_CMD0;//0xBB命令\n\n\tMachine_Tx.TxBuf[Machine_Tx.Index++] = Machine_Tx.Cmd0;\n\tMachine_Tx.Checksum += Machine_Tx.Cmd0;\n\n\tMachine_Tx.TxBuf[Machine_Tx.Index++] = Machine_Tx.Cmd1;\n\tMachine_Tx.Checksum += Machine_Tx.Cmd1;\n\n\t//////// Len\n\tMachine_Tx.TxBuf[Machine_Tx.Index++] = Machine_Tx.Len;\n\tMachine_Tx.Checksum += Machine_Tx.Len;\n\n\n\n//\tconst uint8_t testArr[] = {0x11,0x22,0x33};\n\n\t//////// 数据域\n\tfor (uint32_t i=0; i\u003cMachine_Tx.Len; i++)\n\t{\n//\t\tUART1_PrintArray((uint8_t *)testArr,3);//测试\n\t\tMachine_Tx.TxBuf[Machine_Tx.Index++] = Machine_Tx.Data[i];\n\t\tMachine_Tx.Checksum += Machine_Tx.Data[i];\n\t}\n\tMachine_Tx.Checksum = Machine_Tx.Checksum \u0026 0xFF;//0xFF是一个字节\n\t//////// checksum\n\tMachine_Tx.TxBuf[Machine_Tx.Index++] = Machine_Tx.Checksum;\n\n\n\n\tMachine_Transmit((uint8_t *)Machine_Tx.TxBuf, Machine_Tx.Index);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250217143508-8lhwvsl","Type":"NodeParagraph","Properties":{"id":"20250217143508-8lhwvsl","updated":"20250217143508"}},{"ID":"20250217143510-btq2kw9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250217143510-btq2kw9","updated":"20250217143515"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"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\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240731142038-yg4c1kv","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20240731142038-yg4c1kv","updated":"20250123095645"},"Children":[{"Type":"NodeText","Data":"采样频率"}]},{"ID":"20240731142038-b5o1nui","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240731142038-b5o1nui","updated":"20250123095645"},"Children":[{"Type":"NodeText","Data":"为什么以前是100us采集一次，现在是416us采集一次？"}]},{"ID":"20240731142038-df1duqt","Type":"NodeBlockquote","Properties":{"id":"20240731142038-df1duqt","updated":"20240731142038"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142038-a5udpd7","Type":"NodeParagraph","Properties":{"id":"20240731142038-a5udpd7","updated":"20240731142038"},"Children":[{"Type":"NodeText","Data":"原来的时钟分频是48分频，电机频率为1khz，也就是1s进行1000次周期运动，1s/1khz = 0.001s = 1ms = 1000us, 也就是100us触发一次中断采集， 即1s采集10次"}]},{"ID":"20240731142038-ehjv1t7","Type":"NodeParagraph","Properties":{"id":"20240731142038-ehjv1t7","updated":"20240731142038"},"Children":[{"Type":"NodeText","Data":"现在为了在电机的三角波输出最高点采集电流，并且是2.4khz采集，所以采用20分频，然后 1s/2.4khz = 0.416ms =416us, 也就是416us触发中断采集一次adc，即1s只能采集两次"}]}]},{"ID":"20240731142038-2lcm8o8","Type":"NodeParagraph","Properties":{"id":"20240731142038-2lcm8o8","updated":"20240731142038"},"Children":[{"Type":"NodeText","Data":"1 kHz 意味着每秒钟有 1000 次周期（赫兹表示频率，单位是每秒的周期数）。"}]},{"ID":"20240731142038-31jnf8n","Type":"NodeParagraph","Properties":{"id":"20240731142038-31jnf8n","updated":"20240731142038"},"Children":[{"Type":"NodeText","Data":"计算如下："}]},{"ID":"20240731142038-ngkaeem","Type":"NodeParagraph","Properties":{"id":"20240731142038-ngkaeem","updated":"20250123095645"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{周期时间} = \\frac{1 \\text{秒}}{1 \\text{kHz}}"},{"Type":"NodeText","Data":"\n"}]},{"ID":"20240731142038-ykvhl50","Type":"NodeParagraph","Properties":{"id":"20240731142038-ykvhl50","updated":"20240731142038"},"Children":[{"Type":"NodeText","Data":"由于 1 kHz 等于 1000 Hz，因此："}]},{"ID":"20240731142038-z9d1xlz","Type":"NodeParagraph","Properties":{"id":"20240731142038-z9d1xlz","updated":"20240731142038"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{周期时间} = \\frac{1 \\text{秒}}{1000} = 0.001 \\text{秒} = 1 \\text{毫秒}"}]},{"ID":"20240731141938-gkgp8b6","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20240731141938-gkgp8b6","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"三角波采集电机电流adc"}]},{"ID":"20240731142020-1akqyuo","Type":"NodeParagraph","Properties":{"id":"20240731142020-1akqyuo","updated":"20240731142020"}},{"ID":"20240731142020-y1swz7a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240731142020-y1swz7a","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"2.4khz的电机怎么配置的"}]},{"ID":"20240731142020-bkn1erf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240731142020-bkn1erf","updated":"20240731142021"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"\n/*************************************************************/\n//ETP0 Functions\n//EntryParameter:NONE\n//ReturnValue:NONE\n/*************************************************************/ \nvoid EPT_CONFIG(void)\n{\n\tEPT_Software_Prg();\t\t\t\t\t\t\t\t//EPT software reset\n//------------  EPT GPIO Setting  --------------------------------/\n\t//EPT_IO_SET(EPT_IO_CHAX,IO_NUM_PA00);\t\t\t//AX channel selection\n\t//EPT_IO_SET(EPT_IO_CHAY,IO_NUM_PA01);\t\t\t//AY channel selection\n\t//EPT_IO_SET(EPT_IO_CHBX,IO_NUM_PA07);\t\t\t//BX channel selection\n\tEPT_IO_SET(EPT_IO_CHBY,IO_NUM_PA08);\t\t\t//BY channel selection\n\t//EPT_IO_SET(EPT_IO_CHCX,IO_NUM_PB04);\t\t\t//CX channel selection\n//\tEPT_IO_SET(EPT_IO_CHCY,IO_NUM_PB05);\t\t\t//CY channel selection\n\t//EPT_IO_SET(EPT_IO_CHD,IO_NUM_PA13);\t\t\t//D channel selection\n//------------  EPT Control  --------------------------------/\n\t//计数模式为先上升后下降，且为连续输出\n\tEPT_PWM_Config(EPT_Selecte_PCLK,EPT_CNTMD_increaseTOdecrease,EPT_OPM_Continue,0);//PCLK as clock，increasing mode,continuous mode,TCLK=PCLK/(0+1) EPT_CNTMD_increase\n\t//EPT_Tevent_Selecte(0x00,0x00);\t\t\t\t//T1 source selection SYNCIN4,T2 source selectionSYNCIN5\n\t//EPT_SYNCR_Config(EPT_Triggle_Continue,EPT_SYNCUSR0_REARMTrig_DIS,EPT_TRGSRC0_ExtSync_SYNCUSR0,EPT_TRGSRC1_ExtSync_SYNCUSR4,0x30);//enable SYNCUSR4 SYNCUSR5 as trigger event,continuous mode\n\t//EPT_PWMX_Output_Control(EPT_PWMA,EPT_CA_Selecte_CMPA,EPT_CB_Selecte_CMPA,EPT_PWM_ZRO_Event_OutHigh,EPT_PWM_PRD_Event_Nochange,EPT_PWM_CAU_Event_OutLow,EPT_PWM_CAD_Event_OutLow,\n\t//\t\t\t\t\t\tEPT_PWM_CBU_Event_Nochange,EPT_PWM_CBD_Event_Nochange,EPT_PWM_T1U_Event_Nochange,EPT_PWM_T1D_Event_Nochange,EPT_PWM_T2U_Event_Nochange,EPT_PWM_T2D_Event_Nochange);\n\tEPT_PWMX_Output_Control(EPT_PWMB,//选择 EPT_PWMB 通道。\n\t\t\t\t\t\t\tEPT_CA_Selecte_CMPB,//比较寄存器 A 和 B 都选择 CMPB。\n\t\t\t\t\t\t\tEPT_CB_Selecte_CMPB,。\n\t\t\t\t\t\t\tEPT_PWM_ZRO_Event_OutLow,//在计数器为零时，输出低电平。\n\t\t\t\t\t\t\tEPT_PWM_PRD_Event_Nochange,//在计数器达到周期值时，不改变输出。 \n\t\t\t\t\t\t\tEPT_PWM_CAU_Event_OutHigh,//在计数器向上计数且达到比较寄存器 A 值时，输出高电平。\n\t\t\t\t\t\t\tEPT_PWM_CAD_Event_OutLow,//在计数器向下计数且达到比较寄存器 A 值时，输出低电平。\n\t\t\t\t\t\t\tEPT_PWM_CBU_Event_Nochange,//在计数器向上计数且达到比较寄存器 B 值时，不改变输出。\n\t\t\t\t\t\t\tEPT_PWM_CBD_Event_Nochange,//在计数器向下计数且达到比较寄存器 B 值时，不改变输出。\n\n\t\t\t\t\t\t\tEPT_PWM_T1U_Event_Nochange, //计数器 T1 和 T2 在向上和向下计数时都不改变输出。\n\t\t\t\t\t\t\tEPT_PWM_T1D_Event_Nochange,\n\t\t\t\t\t\t\tEPT_PWM_T2U_Event_Nochange,\n\t\t\t\t\t\t\tEPT_PWM_T2D_Event_Nochange);\n\t\t\n\t//EPT_PWMX_Output_Control(EPT_PWMC,EPT_CA_Selecte_CMPC,EPT_CB_Selecte_CMPC,EPT_PWM_ZRO_Event_OutHigh,EPT_PWM_PRD_Event_Nochange,EPT_PWM_CAU_Event_OutLow,EPT_PWM_CAD_Event_OutLow,\n\t//\t\t\t\t\t\tEPT_PWM_CBU_Event_Nochange,EPT_PWM_CBD_Event_Nochange,EPT_PWM_T1U_Event_Nochange,EPT_PWM_T1D_Event_Nochange,EPT_PWM_T2U_Event_Nochange,EPT_PWM_T2D_Event_Nochange);\n\t//EPT_PWMX_Output_Control(EPT_PWMD,EPT_CA_Selecte_CMPD,EPT_CB_Selecte_CMPD,EPT_PWM_ZRO_Event_OutHigh,EPT_PWM_PRD_Event_Nochange,EPT_PWM_CAU_Event_OutLow,EPT_PWM_CAD_Event_OutLow,\n\t//\t\t\t\t\t\tEPT_PWM_CBU_Event_Nochange,EPT_PWM_CBD_Event_Nochange,EPT_PWM_T1U_Event_Nochange,EPT_PWM_T1D_Event_Nochange,EPT_PWM_T2U_Event_Nochange,EPT_PWM_T2D_Event_Nochange);\n//\tEPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(20000,0,20000,0,0);//PRDR=2400,CMPA=1200,CMPB=600,CMPC=2400,CMPD=0\n\tEPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(10000,0,0,0,0);\n\tEPT_DB_CLK_Config(0,24,24);//Fdbclk=Fhclk/(0+1)，DTR=24clk，DTF=24clk 这个是死区时钟频率配置\n\t//EPT_DBCR_Config(EPT_CHA_Selecte,EPT_CHAINSEL_PWMA_RISE_FALL,EPT_CHA_OUTSEL_EnRise_EnFall,EPT_PB_OUT_Reverse,EPT_PAtoCHX_PBtoCHY);//PWMA Complementary,CHX rising edge,CHY falling edge\n\tEPT_DBCR_Config(EPT_CHB_Selecte,\n\t\t\t\t\tEPT_CHBINSEL_PWMB_RISE_FALL,\n\t\t\t\t\tEPT_CHB_OUTSEL_EnRise_EnFall,\n\t\t\t\t\tEPT_PB_OUT_Reverse,\n\t\t\t\t\tEPT_PAtoCHX_PBtoCHY);//PWMB Complementary,CHX rising edge,CHY falling edge\n\t\n\t//EPT_DBCR_Config(EPT_CHC_Selecte,EPT_CHCINSEL_PWMC_RISE_FALL,EPT_CHC_OUTSEL_EnRise_EnFall,EPT_PB_OUT_Reverse,EPT_PAtoCHX_PBtoCHY);//PWMC Complementary,CHX rising edge,CHY falling edge\n//------------  EPT interruption  --------------------------------/\n\t//EPT_Int_Enable(EPT_CAP_LD0);//CMPA load interrupt\n\t//EPT_Int_Enable(EPT_CAP_LD1);//CMPB load interrupt\n\t//EPT_Int_Enable(EPT_CAP_LD2);//CMPC load interrupt\n\t//EPT_Int_Enable(EPT_CAP_LD3);//CMPD load interrupt\n\t//EPT_Int_Enable(EPT_CAU);//Up-Counting phase CNT = CMPA interrupt request raw status\n\t//EPT_Int_Enable(EPT_CAD);//Down-Counting phase CNT = CMPA interrupt request raw statu\n\t//EPT_Int_Enable(EPT_CBU);//Up-Counting phase CNT = CMPB interrupt request raw status\n\t//EPT_Int_Enable(EPT_CBD);//Down-Counting phase CNT = CMPB interrupt request raw status\n\t//EPT_Int_Enable(EPT_CCU);//Up-Counting phase CNT = CMPC interrupt request raw status\n\t//EPT_Int_Enable(EPT_CCD);//Down-Counting phase CNT = CMPC interrupt request raw status\n\t//EPT_Int_Enable(EPT_CDU);//Up-Counting phase CNT = CMPD interrupt request raw status\n\t//EPT_Int_Enable(EPT_CDD);//Down-Counting phase CNT = CMPD interrupt request raw status\n\tEPT_Int_Enable(EPT_PEND);//触发中断\n\tEPT_Vector_Int_Enable();\n//------------  EPT start  --------------------------------/\n\n//------------  EPT capture config  --------------------------------/\n\t/*EPT_Software_Prg();\n\tEPT_Capture_Config(EPT_Selecte_PCLK,EPT_CNTMD_increase,EPT_CAPMD_Continue,EPT_CAP_EN,EPT_LDARST_EN,EPT_LDBRST_DIS,EPT_LDCRST_DIS,EPT_LDDRST_DIS,1,0);//TCLK=pclk/(1+0),CMPAload CMPBload\n\tEPT_SYNCR_Config(EPT_Triggle_Continue,EPT_SYNCUSR0_REARMTrig_DIS,EPT_TRGSRC0_ExtSync_SYNCUSR0,EPT_TRGSRC1_ExtSync_SYNCUSR4,0x04);//Enable SYNCUSR2 ,Continuous trigger\n\tEPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(0XFFFF,0,0,0,0);\n\tEPT_Int_Enable(EPT_CAP_LD0);//Capture Load to CMPA interrupt request raw status\n\tEPT_Int_Enable(EPT_CAP_LD1);//Capture Load to CMPB interrupt request raw status\n\tEPT_Vector_Int_Enable();\n\tEPT_Start();*/\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241017142539-lx482qp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241017142539-lx482qp","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"频率和周期的关系"}]},{"ID":"20241017144845-ljriu97","Type":"NodeBlockquote","Properties":{"id":"20241017144845-ljriu97","updated":"20241017144847"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241017144847-lw5g3tb","Type":"NodeParagraph","Properties":{"id":"20241017144847-lw5g3tb","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"频率与时间周期的转换："}]},{"ID":"20241017144847-r9yzya3","Type":"NodeParagraph","Properties":{"id":"20241017144847-r9yzya3","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"1、频率：1秒中发生的次数；"}]},{"ID":"20241017144847-vdqxoee","Type":"NodeParagraph","Properties":{"id":"20241017144847-vdqxoee","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"2、周期：发生一次所需要的时间；"}]},{"ID":"20241017144847-y56u2i8","Type":"NodeParagraph","Properties":{"id":"20241017144847-y56u2i8","updated":"20241017144847"},"Children":[{"Type":"NodeText","Data":"3、频率和周期互为倒数。"}]}]},{"ID":"20240731142020-dudmisn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240731142020-dudmisn","updated":"20250110133513"},"Children":[{"Type":"NodeText","Data":"2.4khz的配置"}]},{"ID":"20240731142020-w9owvud","Type":"NodeBlockquote","Properties":{"id":"20240731142020-w9owvud","updated":"20250110133513"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142020-37pbxja","Type":"NodeParagraph","Properties":{"id":"20240731142020-37pbxja","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"1.首先时钟频率是48MHz，周期寄存器的配置为10000次，即EPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(10000,0,0,0,0); PRDR=10000\n2."}]},{"ID":"20240731142020-0bundr2","Type":"NodeParagraph","Properties":{"id":"20240731142020-0bundr2","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"周期时间 = 周期寄存器的配置 / 时钟频率 =（10000+1）/ 48000000≈208.35微秒"}]},{"ID":"20240731142020-mxdt4qb","Type":"NodeParagraph","Properties":{"id":"20240731142020-mxdt4qb","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"对应的频率为："}]},{"ID":"20240731142020-83jplty","Type":"NodeParagraph","Properties":{"id":"20240731142020-83jplty","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{频率} = \\frac{1}{\\text{周期时间}}"}]},{"ID":"20240731142020-pyabddj","Type":"NodeParagraph","Properties":{"id":"20240731142020-pyabddj","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{频率} \\approx \\frac{1}{208.35 \\times 10^{-6}} \\approx 4.8 \\text{kHz}"}]},{"ID":"20240731142020-0pwjlgh","Type":"NodeParagraph","Properties":{"id":"20240731142020-0pwjlgh","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"3.EPT_PWM_Config(EPT_Selecte_PCLK, EPT_CNTMD_increaseTOdecrease, EPT_OPM_Continue, 0);"}]},{"ID":"20240731142020-o4r07mh","Type":"NodeParagraph","Properties":{"id":"20240731142020-o4r07mh","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"又因为配置的计数方式是上升-下降模式，这种模式下计数器将从0计数到10000，再从10000计数到0，所以一个完整的周期包含两个计数周期"}]},{"ID":"20240731142020-ta8hytx","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240731142020-ta8hytx","updated":"20240731142020"},"Children":[{"ID":"20240731142020-2zsn1ep","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20240731142020-2zsn1ep","updated":"20240731142020"},"Children":[{"ID":"20240731142020-dfw6vsk","Type":"NodeParagraph","Properties":{"id":"20240731142020-dfw6vsk","updated":"20240731142020"}}]}]},{"ID":"20240731142020-15zkge8","Type":"NodeParagraph","Properties":{"id":"20240731142020-15zkge8","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"总周期时间=2×208.35微秒≈416.7微秒"}]},{"ID":"20240731142020-m5ru07y","Type":"NodeParagraph","Properties":{"id":"20240731142020-m5ru07y","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"对应的频率为："}]},{"ID":"20240731142020-2sisbqu","Type":"NodeParagraph","Properties":{"id":"20240731142020-2sisbqu","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{频率} = \\frac{1}{\\text{总周期时间}}"}]},{"ID":"20240731142020-757fjki","Type":"NodeParagraph","Properties":{"id":"20240731142020-757fjki","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{频率} \\approx \\frac{1}{416.7 \\times 10^{-6}} \\approx 2.4 \\text{kHz}"}]},{"ID":"20250110133037-tzgy4zz","Type":"NodeParagraph","Properties":{"id":"20250110133037-tzgy4zz","updated":"20250110133037"}},{"ID":"20250110133037-0ay870e","Type":"NodeParagraph","Properties":{"id":"20250110133037-0ay870e","updated":"20250110133226"},"Children":[{"Type":"NodeText","Data":"比如系统24Mhz 那么1.2khz的灯配置方法就是：1 / 24 *20000 = 833微秒 那么 1 / 833 = 0.0012Mhz = 1.2khz"}]},{"ID":"20250110133228-7tad8eb","Type":"NodeParagraph","Properties":{"id":"20250110133228-7tad8eb","updated":"20250110133513"},"Children":[{"Type":"NodeText","Data":"系统时钟24Mhz 2.4khz三角波的电机配置方法就是：1 / 24 * 5000 = 208.3微秒 那么 1 /208.3 = 0.0048Mhz = 4.8khz 但是 三角波是两段 即 0~5000再5000~0 所以4.8khz / 2 = 2.4khz"}]}]},{"ID":"20240731142020-zx4wdlj","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20240731142020-zx4wdlj","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"绿灯配置"}]},{"ID":"20240731142020-zb7udj2","Type":"NodeBlockquote","Properties":{"id":"20240731142020-zb7udj2","updated":"20240731142021"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142020-snnxdzj","Type":"NodeParagraph","Properties":{"id":"20240731142020-snnxdzj","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"像之前绿灯的配置是"}]},{"ID":"20240731142020-5ve8sqe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240731142020-5ve8sqe","updated":"20240731142020"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"EPT_PWMX_Output_Control(EPT_PWMC,\n\nEPT_CA_Selecte_CMPC,\n\nEPT_CB_Selecte_CMPC,\n\nEPT_PWM_ZRO_Event_OutHigh,//计数到0时输出高电平\n\nEPT_PWM_PRD_Event_Nochange,\n\nEPT_PWM_CAU_Event_OutLow,//在计数器向上计数且达到比较寄存器 A 值时，输出低电平。\n\nEPT_PWM_CAD_Event_OutLow,\nEPT_PWM_CBU_Event_Nochange,\n\nEPT_PWM_CBD_Event_Nochange,\n\nEPT_PWM_T1U_Event_Nochange,\n\nEPT_PWM_T1D_Event_Nochange,\n\nEPT_PWM_T2U_Event_Nochange,\n\nEPT_PWM_T2D_Event_Nochange);\n\n#define    duty_cycle_40() \tEPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(40000,0,0,24000,0);\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240731142020-qizp9io","Type":"NodeParagraph","Properties":{"id":"20240731142020-qizp9io","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"表示："}]},{"ID":"20240731142020-6fach5v","Type":"NodeParagraph","Properties":{"id":"20240731142020-6fach5v","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"计数周期是40000"}]},{"ID":"20240731142020-c3ochsm","Type":"NodeParagraph","Properties":{"id":"20240731142020-c3ochsm","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"24000/40000 = 0.6\n即占空比输出应该为60%\n但又因为配置中设置了计数到周期计数值时输出低电平，所以60%输出为低电平，所以结果就是40%高电平"}]}]},{"ID":"20240731142020-dy2r1ek","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240731142020-dy2r1ek","updated":"20250106134434"},"Children":[{"Type":"NodeText","Data":"占空比设置"}]},{"ID":"20240731142020-vhdnho9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240731142020-vhdnho9","updated":"20240731142021"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"\n\nvoid Set_Duty(uint32_t duty)\n{ \n\t//duty =1000;\n\t//duty =(10000 - duty) / 2;\n\t//duty =duty / 2;\n\tEPT_PRDR_CMPA_CMPB_CMPC_CMPD_Config(10000,0,duty,0,0); //duty = 16000\n}\n\nvoid Brush_Duty_Set(uint32_t x)\n{\n\n\tif(x\u003e=1000)\n\t{\n\t\tx = 1000; \n\t}\n\tx = x * 10;\n\n\tSet_Duty(x);\n\n\t//BT_Period_CMP_Write(BT0,1000,x);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240731142020-nf5hqly","Type":"NodeBlockquote","Properties":{"id":"20240731142020-nf5hqly","updated":"20250106134434"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142020-85834xx","Type":"NodeParagraph","Properties":{"id":"20240731142020-85834xx","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"1.其中 10000表示周期寄存器的计数周期值为10000次"}]},{"ID":"20240731142020-3u209cf","Type":"NodeParagraph","Properties":{"id":"20240731142020-3u209cf","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"2.又因为电机用的是通道B，所以第三位设置的 duty"}]},{"ID":"20240731142020-s3ulopb","Type":"NodeParagraph","Properties":{"id":"20240731142020-s3ulopb","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"3.占空比=EPT_PRDR_Value / EPT_CMPB_Value × 100%"}]},{"ID":"20240731142020-eghcro1","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240731142020-eghcro1","updated":"20240731142020"},"Children":[{"ID":"20240731142020-r5noc5c","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20240731142020-r5noc5c","updated":"20240731142020"},"Children":[{"ID":"20240731142020-gzkwqxy","Type":"NodeParagraph","Properties":{"id":"20240731142020-gzkwqxy","updated":"20240731142020"}}]}]},{"ID":"20240731142020-bqab202","Type":"NodeList","ListData":{},"Properties":{"id":"20240731142020-bqab202","updated":"20240731142020"},"Children":[{"ID":"20240731142020-41sa9ue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240731142020-41sa9ue","updated":"20240731142020"},"Children":[{"ID":"20240731142020-63gb0ks","Type":"NodeParagraph","Properties":{"id":"20240731142020-63gb0ks","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"EPT_CMPB_Value"},{"Type":"NodeText","Data":"​ 是比较寄存器 B 的值，控制 PWM 的高电平持续时间。"}]}]},{"ID":"20240731142020-g0v04hs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240731142020-g0v04hs","updated":"20240731142020"},"Children":[{"ID":"20240731142020-w8pvlwc","Type":"NodeParagraph","Properties":{"id":"20240731142020-w8pvlwc","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"EPT_PRDR_Value"},{"Type":"NodeText","Data":"​ 是计时器的周期值，控制 PWM 的周期。"}]}]}]},{"ID":"20240731142020-jdnpkqs","Type":"NodeParagraph","Properties":{"id":"20240731142020-jdnpkqs","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"例如，如果 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"duty"},{"Type":"NodeText","Data":"​ 设置为 5000，那么 PWM 的占空比为："}]},{"ID":"20240731142020-mbnu47r","Type":"NodeParagraph","Properties":{"id":"20240731142020-mbnu47r","updated":"20250106134434"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\text{占空比} = \\frac{5000}{10000} \\times 100\\% = 50\\%"},{"Type":"NodeText","Data":"\n5.我们现在写的是0-1000是因为我们原来的占空比分辨率设置的0-1000，然后现在计数周期改为10000了，所以按照现在的2.4khz配置方式需要将占空比扩大10倍"}]}]},{"ID":"20240731142020-90hbsoi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240731142020-90hbsoi","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"中断触发采集adc"}]},{"ID":"20240731142020-e8jxjmq","Type":"NodeParagraph","Properties":{"id":"20240731142020-e8jxjmq","updated":"20240731142021"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 33%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240708120338-ftwqz7z.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 33%;\"}"},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 75%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240708155610-q04pnuj.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 75%;\"}"},{"Type":"NodeBr","Data":"br"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240708141433-qjlohwi.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240708120438-6g3jz49.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20240731142020-3kddycm","Type":"NodeBlockquote","Properties":{"id":"20240731142020-3kddycm","updated":"20240731142021"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142020-zok72p3","Type":"NodeParagraph","Properties":{"id":"20240731142020-zok72p3","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"通常情况下，电流的波动在特定时间内会达到最大值。电机的电流特性通常是周期性的，尤其是在对称模式下，电流会在正弦波或其他周期性波形的情况下波动。"}]},{"ID":"20240731142020-gtncoud","Type":"NodeParagraph","Properties":{"id":"20240731142020-gtncoud","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"当你在对称模式下进行PWM控制时，电机的电流会在周期内变化，这些变化通常会在周期的某些时刻达到最大值。 如果你的计数器用于检测PWM信号的周期，并且在周期的某个特定点（例如计数溢出点）触发ADC采集，那么在对称模式下，这个采集点很可能会接近或正好是电流的最大值。"}]}]},{"ID":"20240731142020-u23lyse","Type":"NodeBlockquote","Properties":{"id":"20240731142020-u23lyse","updated":"20240731142021"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240731142020-vcxdndf","Type":"NodeParagraph","Properties":{"id":"20240731142020-vcxdndf","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"当ept触发中断的时候就会进行adc采集，EPTIntHandler中断即电机pwm驱动会先使能adc中断，然后ADCIntHandler会进行采集"}]}]},{"ID":"20240731142020-z2pvqzq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240731142020-z2pvqzq","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"死区时钟频率配置"}]},{"ID":"20240731142020-ufllnm2","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240731142020-ufllnm2","updated":"20240731142021"},"Children":[{"ID":"20240731142020-dse4vxp","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20240731142020-dse4vxp","updated":"20240731142020"},"Children":[{"ID":"20240731142020-4mqfnth","Type":"NodeParagraph","Properties":{"id":"20240731142020-4mqfnth","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"死区时钟频率"},{"Type":"NodeText","Data":":"}]},{"ID":"20240731142020-fa54fs7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20240731142020-fa54fs7","updated":"20240731142020"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"EPT_DB_CLK_Config(0, 24, 24);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20240731142020-sipu42n","Type":"NodeParagraph","Properties":{"id":"20240731142020-sipu42n","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"根据函数的定义，死区时钟频率的计算公式为："}]},{"ID":"20240731142020-872cwcg","Type":"NodeParagraph","Properties":{"id":"20240731142020-872cwcg","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"F_{dbclk} = \\frac{F_{hclk}}{DPSC + 1}"},{"Type":"NodeText","Data":"其中，"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"F_{hclk}"},{"Type":"NodeText","Data":"​ 是系统时钟频率（48 MHz），"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DPSC"},{"Type":"NodeText","Data":"​ 是死区时钟分频器值（0）。"}]},{"ID":"20240731142020-mb2mdrp","Type":"NodeParagraph","Properties":{"id":"20240731142020-mb2mdrp","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"因此："}]},{"ID":"20240731142020-hjuwxcb","Type":"NodeParagraph","Properties":{"id":"20240731142020-hjuwxcb","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"F_{dbclk} = \\frac{48 \\text{ MHz}}{0 + 1} = 48 \\text{ MHz}"}]}]},{"ID":"20240731142020-y1zhkkm","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20240731142020-y1zhkkm","updated":"20240731142020"},"Children":[{"ID":"20240731142020-p8y2xof","Type":"NodeParagraph","Properties":{"id":"20240731142020-p8y2xof","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"死区上升时间和下降时间"},{"Type":"NodeText","Data":":"}]},{"ID":"20240731142020-2md4hpj","Type":"NodeList","ListData":{},"Properties":{"id":"20240731142020-2md4hpj","updated":"20240731142020"},"Children":[{"ID":"20240731142020-90jamu0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240731142020-90jamu0","updated":"20240731142020"},"Children":[{"ID":"20240731142020-b5b4n67","Type":"NodeParagraph","Properties":{"id":"20240731142020-b5b4n67","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DTR = 24"},{"Type":"NodeText","Data":"​"}]}]},{"ID":"20240731142020-5whgngg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20240731142020-5whgngg","updated":"20240731142020"},"Children":[{"ID":"20240731142020-msj9q7d","Type":"NodeParagraph","Properties":{"id":"20240731142020-msj9q7d","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DTF = 24"},{"Type":"NodeText","Data":"​"}]}]}]},{"ID":"20240731142020-103psw3","Type":"NodeParagraph","Properties":{"id":"20240731142020-103psw3","updated":"20240731142020"},"Children":[{"Type":"NodeText","Data":"死区时间（上升和下降时间）以死区时钟周期为单位，因此上升和下降时间分别为：\n"},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"T_{rise} = T_{fall} = \\frac{DTR}{F_{dbclk}} = \\frac{DTF}{F_{dbclk}}"},{"Type":"NodeText","Data":"带入数值："}]},{"ID":"20240731142020-s93ahsf","Type":"NodeParagraph","Properties":{"id":"20240731142020-s93ahsf","updated":"20240731142020"},"Children":[{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"T_{rise} = T_{fall} = \\frac{24}{48 \\text{ MHz}} = 0.5 \\text{ μs}"}]}]}]},{"ID":"20240731142020-iicrcmu","Type":"NodeParagraph","Properties":{"id":"20240731142020-iicrcmu","updated":"20240731142021"},"Children":[{"Type":"NodeText","Data":"因此，在48 MHz时钟频率下，"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DPSC"},{"Type":"NodeText","Data":"​ 为0，"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DTR"},{"Type":"NodeText","Data":"​ 和 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"DTF"},{"Type":"NodeText","Data":"​ 为24的配置下，死区上升和下降时间分别为0.5微秒"}]},{"ID":"20240731142020-2dmndg2","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20240731142020-2dmndg2","updated":"20240925164851"},"Children":[{"Type":"NodeText","Data":"UART中(GPIO_FUNC_33)"}]},{"ID":"20240731160329-ve2g8tq","Type":"NodeParagraph","Properties":{"id":"20240731160329-ve2g8tq","updated":"20240731160329"},"Chi