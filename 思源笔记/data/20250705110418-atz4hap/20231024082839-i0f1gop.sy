:"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083064-1exvkxi","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"三种模式"}]},{"ID":"20231024083065-7v6e114","Type":"NodeParagraph","Properties":{"id":"20231024083065-7v6e114","updated":"20231024083065"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1693980079924-075dc44b-86c4-40c8-8735-1aabf9a6bc6b.png#averageHue=%23fbfaf9\u0026clientId=u62b097dd-7635-4\u0026from=paste\u0026height=759\u0026id=u023dcf38\u0026originHeight=835\u0026originWidth=775\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=96963\u0026status=done\u0026style=none\u0026taskId=u2e3f0235-9db1-4229-a802-f2b065443e3\u0026title=\u0026width=704.5454392748434","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083066-st0czey","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083066-st0czey","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"72Mhz分频"}]},{"ID":"20231024083067-416r7fc","Type":"NodeParagraph","Properties":{"id":"20231024083067-416r7fc","updated":"20240205090639"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1693981517977-c20610c3-d177-414f-be76-1eee236605b3.png#averageHue=%23faf8f7\u0026clientId=u62b097dd-7635-4\u0026from=paste\u0026height=552\u0026id=u2772a88a\u0026originHeight=607\u0026originWidth=969\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=78412\u0026status=done\u0026style=none\u0026taskId=u8be89498-2c8f-4a16-a810-5b7a90c9348\u0026title=\u0026width=880.909071815901"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231024083068-1ucv56v","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083068-1ucv56v","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"输出模式"}]},{"ID":"20231024083069-rjhugzm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083069-rjhugzm","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"各种输入输出模式的英文"}]},{"ID":"20231024083070-d7v1y5a","Type":"NodeParagraph","Properties":{"id":"20231024083070-d7v1y5a","updated":"20231024083070"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694141772636-60feb22b-58ac-46a4-b4bd-2c9549a1e4ec.png#averageHue=%23fefefe\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=194\u0026id=uf0b4fc50\u0026originHeight=213\u0026originWidth=329\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=16141\u0026status=done\u0026style=none\u0026taskId=uebf7fbc5-13bd-45f2-907c-04e6078b3ef\u0026title=\u0026width=299.0909026082884","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083071-wguw1j7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083071-wguw1j7","updated":"20241017093601"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"关于上拉输入、下拉输入、模拟输入、浮空输入、推挽输出、开漏输出、复用输出的区别"}]},{"ID":"20231024083072-stjbjhu","Type":"NodeParagraph","Properties":{"id":"20231024083072-stjbjhu","updated":"20241017093601"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"1、上拉输入"},{"Type":"NodeText","Data":"：上拉就是把电位拉高，比如拉到Vcc。上拉就是将不确定的信号通过一个电阻嵌位在高电平！电阻同时起限流作用！弱强只是上拉电阻的阻值不同，没有什么严格区分。\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"2、下拉输入"},{"Type":"NodeText","Data":"：就是把电压拉低，拉到GND。与上拉原理相似。\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"3、浮空输入"},{"Type":"NodeText","Data":"：浮空（floating）就是逻辑器件的输入引脚即不接高电平，也不接低电平。由于逻辑器件的内部结构，当它输入引脚悬空时，相当于该引脚接了高电平。一般实际运用时，引脚不建议悬空，易受干扰。 通俗讲就是让管脚什么都不接，浮空着。\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"4、模拟输入"},{"Type":"NodeText","Data":"：模拟输入是指传统方式的输入.数字输入是输入PCM数字信号,即0,1的二进制数字信号,通过数模转换,转换成模拟信号,经前级放大进入功率放大器,功率放大器还是模拟的。\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"5、推挽输出"},{"Type":"NodeText","Data":":可以输出高,低电平,连接数字器件; 推挽结构一般是指两个三极管分别受两互补信号的控制,总是在一个三极管导通的时候另一个截止。高低电平由IC的电源低定。\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"6、开漏输出"},{"Type":"NodeText","Data":":输出端相当于三极管的集电极. 要得到高电平状态需要上拉电阻才行. 适合于做电流型的驱动,其吸收电流的能力相对强(一般20mA以内).\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"7、复用输出"},{"Type":"NodeText","Data":"：可以理解为GPIO口被用作第二功能时的配置情况（即并非作为通用IO口使用）。端口必须配置成复用功能输出模式(推挽或开漏)。\n在STM32中选用IO模式，下面是参考网上的总结一下。\n(1)GPIO_Mode_AIN 模拟输入—应用"},{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://so.csdn.net/so/search?q=ADC\u0026amp;spm=1001.2101.3001.7020","TextMarkTextContent":"ADC"},{"Type":"NodeText","Data":"模拟输入，或者低功耗下省电\n(2)GPIO_Mode_IN_FLOATING 浮空输入—可以做KEY识别\n(3)GPIO_Mode_IPD 下拉输入— IO内部下拉电阻输入\n(4)GPIO_Mode_IPU 上拉输入—IO内部上拉电阻输入\n(5)GPIO_Mode_Out_OD 开漏输出—IO输出0接GND，IO输出1，悬空，需要外接上拉电阻，才能实现输出高电平。当输出为1时，IO口的状态由上拉电阻拉高电平，但由于是开漏输出模式，这样IO口也就可以由外部电路改变为低电平或不变。可以读IO输入电平变化，实现C51的IO双向功能\n(6)GPIO_Mode_Out_PP 推挽输出—IO输出0-接GND， IO输出1 -接VCC，读输入值是未知的\n(7)GPIO_Mode_AF_OD 复用开漏输出—片内外设功能（TX1,MOSI,MISO.SCK.SS）\n(8)GPIO_Mode_AF_PP 复用推挽输出—片内外设功能（I2C的SCL,SDA）"}]},{"ID":"20240927094345-9dnqyxj","Type":"NodeParagraph","Properties":{"id":"20240927094345-9dnqyxj","updated":"20240927094345"}},{"ID":"20240927094345-lj3o6qc","Type":"NodeBlockquote","Properties":{"id":"20240927094345-lj3o6qc","updated":"20240927094853"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240927094348-322xtaz","Type":"NodeParagraph","Properties":{"id":"20240927094348-322xtaz","updated":"20240927094528"},"Children":[{"Type":"NodeText","Data":"推挽输出：上面导通就是高电平 下面导通就是低电平 即强上拉和强下拉的模式"}]},{"ID":"20240927094438-k2x2pj4","Type":"NodeParagraph","Properties":{"id":"20240927094438-k2x2pj4","updated":"20240927094445"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"height: 25vh;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240927094438-stdat8f.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"height: 25vh;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20240927094506-37xk9ys","Type":"NodeParagraph","Properties":{"id":"20240927094506-37xk9ys","updated":"20240927094506"}},{"ID":"20240927094506-lr6atkq","Type":"NodeParagraph","Properties":{"id":"20240927094506-lr6atkq","updated":"20240927094853"},"Children":[{"Type":"NodeText","Data":"开漏输出：输出低电平 下管导通 强下拉；输出高电平 下管断开 引脚处于浮空状态"}]},{"ID":"20240927094727-grd20uc","Type":"NodeParagraph","Properties":{"id":"20240927094727-grd20uc","updated":"20240927094757"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"height: 25vh;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240927094727-eh4he3m.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"height: 25vh;\"}"},{"Type":"NodeText","Data":"​"}]}]},{"ID":"20240927094504-93z7k74","Type":"NodeParagraph","Properties":{"id":"20240927094504-93z7k74","updated":"20240927094504"}},{"ID":"20240927094346-704x2un","Type":"NodeParagraph","Properties":{"id":"20240927094346-704x2un","updated":"20240927094346"}},{"ID":"20240927094346-o08q3ng","Type":"NodeParagraph","Properties":{"id":"20240927094346-o08q3ng","updated":"20240927094346"}},{"ID":"20231024083073-9r2qryd","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083073-9r2qryd","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"通信协议"}]},{"ID":"20231024083074-jfl7oax","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083074-jfl7oax","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"并行通信"}]},{"ID":"20231024083075-ipf20vz","Type":"NodeParagraph","Properties":{"id":"20231024083075-ipf20vz","updated":"20231024083075"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/