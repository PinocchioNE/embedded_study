61095/1693901876805-49aab373-a693-4e92-8cbd-e5589ec1c007.png#averageHue=%23f3f1f0\u0026clientId=u8eb85d8d-43ac-4\u0026from=paste\u0026height=468\u0026id=u4c1da6b2\u0026originHeight=515\u0026originWidth=772\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=114197\u0026status=done\u0026style=none\u0026taskId=u0c419661-0272-40b5-9525-079ad985726\u0026title=\u0026width=701.8181666066827","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1693901911947-52b03a58-064b-488e-8e7a-64e8518d05f4.png#averageHue=%23fbfbfb\u0026clientId=u8eb85d8d-43ac-4\u0026from=paste\u0026height=376\u0026id=u49533de9\u0026originHeight=414\u0026originWidth=690\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=141856\u0026status=done\u0026style=none\u0026taskId=u298382e6-d727-480f-95f5-ff003f22598\u0026title=\u0026width=627.2727136769573","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231127103320-zyj9337","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231127103320-zyj9337","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"I2C"}]},{"ID":"20231127103340-z92la9m","Type":"NodeParagraph","Properties":{"id":"20231127103340-z92la9m","updated":"20231127103347"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 67%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231127103340-e7eynjc.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 67%;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20231127103429-8wppknk","Type":"NodeParagraph","Properties":{"id":"20231127103429-8wppknk","updated":"20240204165903"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 75%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231127103429-9ea7b9j.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 75%;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20231024083082-0yloalv","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083082-0yloalv","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"上拉电阻"}]},{"ID":"20231024083083-ytopcxm","Type":"NodeParagraph","Properties":{"id":"20231024083083-ytopcxm","updated":"20231024105857"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694135625676-20a5053d-c586-477e-9e34-e92f43ec23cf.png#averageHue=%23c2c479\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=715\u0026id=u1786423b\u0026originHeight=787\u0026originWidth=1880\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=358421\u0026status=done\u0026style=none\u0026taskId=u4e707d12-422a-468b-b1d3-0cb9d6b68d6\u0026title=\u0026width=1709.0908720473622"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeText","Data":"\n:::tips\n上拉电阻本质是与单片机内部并联一个电阻，并联后整体阻值降低，输出点的电压就提高（第二张图下面的电阻阻值无穷大，所以电压都在他上面，所以输出高电平）\n:::"}]},{"ID":"20231024083084-bgg7z56","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083084-bgg7z56","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"下拉电阻"}]},{"ID":"20231024083085-fo1l83l","Type":"NodeParagraph","Properties":{"id":"20231024083085-fo1l83l","updated":"20231024105852"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694135941030-68fb4a31-7376-4199-ba9f-0652ed002afc.png#averageHue=%23f3f3f3\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=824\u0026id=u2f6f0f65\u0026originHeight=906\u0026originWidth=1385\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=273145\u0026status=done\u0026style=none\u0026taskId=u48e8e7e9-a6ce-4f7d-b8ba-4940598ab30\u0026title=\u0026width=1259.0908818008493"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"},{"Type":"NodeText","Data":"\n:::tips\nnpn的阻抗无穷大 所以输出的电压是低电平 如果此时接上一个电阻那么就可以很确定的把点位钳位在低电平\n:::"}]},{"ID":"20231024083086-w5o2v60","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083086-w5o2v60","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"GPIO_Write和GPIO_Setbit的区别"}]},{"ID":"20231024083087-mocxwnl","Type":"NodeBlockquote","Properties":{"id":"20231024083087-mocxwnl","updated":"20231024083087"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083088-l5v17em","Type":"NodeParagraph","Properties":{"id":"20231024083088-l5v17em","updated":"20231024083088"},"Children":[{"Type":"NodeText","Data":"GPIO_WriteBit  对单个IO口置0或1"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"GPIO_WriteBit(GPIOA,GPIO_Pin_8 , 0);"}]},{"ID":"20231024083089-lroszya","Type":"NodeParagraph","Properties":{"id":"20231024083089-lroszya","updated":"20231024083089"},"Children":[{"Type":"NodeText","Data":"GPIO_SetBits   对多个IO口置0或1"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"例"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"GPIO_SetBits(GPIOD,GPIO_Pin_0 | GPIO_Pin_5 | GPIO_Pin_6);"}]},{"ID":"20231024083090-n0dcv99","Type":"NodeParagraph","Properties":{"id":"20231024083090-n0dcv99","updated":"20231024083090"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"区别"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"一个只能单个引脚操作"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"一个可对多个引脚操作"}]}]},{"ID":"20231024083091-315f0h6","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083091-315f0h6","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"点灯"}]},{"ID":"20231024083092-e0p8ezj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083092-e0p8ezj","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.c"}]},{"ID":"20231024083093-medshyj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083093-medshyj","updated":"20231024083093"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"stm32f10x.h\"\n#include \"Led_Key.h\"\n\nvoid LED_Init(void)\n{\t\n\t//1.打开控制GPIOC的时钟(APB2)\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOE, ENABLE);\n\t\n\t//2.配置结构体\t\n\tGPIO_InitTypeDef led_init;\n\tled_init.GPIO_Pin   = GPIO_Pin_5;      //GPIOC13引脚\n\tled_init.GPIO_Mode  = GPIO_Mode_Out_PP; //推挽输出\t\n\tled_init.GPIO_Speed = GPIO_Speed_50MHz; //10MHz\n\t\n\t//3.对成员进行初始化\n\tGPIO_Init(GPIOE, \u0026led_init);\n\tGPIO_SetBits(GPIOE, GPIO_Pin_5);\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083094-w42a7c8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083094-w42a7c8","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.h"}]},{"ID":"20231024083095-zf0k71k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083095-zf0k71k","updated":"20231024083095"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":" \n#ifndef __LED_KEY_H__\n#define __LED_KEY_H__\n#include \u003cstm32f10x_gpio.h\u003e\n#include \u003cstm32f10x_rcc.h\u003e\n\n\nvoid LED_Init(void); //LED初始化函数声明\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083096-iv8vnkz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083096-iv8vnkz","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083097-h9rbgch","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083097-h9rbgch","updated":"20231024083097"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"stm32f10x.h\"\n#include \"Led_Key.h\"\n\nint  main()\n{\n\tLED_Init(); //LED初始化\n\t\n\twhile(1)\n\t{\n\t\t//方式1\n//\t\tGPIO_SetBits(GPIOB,GPIO_Pin_5);\t\t//P13引脚输出高电平\n        GPIO_ResetBits(GPIOE, GPIO_Pin_5); \t//P13引脚输出低电平\t\n\t}   \n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083098-8h9ikwe","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083098-8h9ikwe","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"按键点灯"}]},{"ID":"20231024083099-ibl2gre","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083099-ibl2gre","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.c"}]},{"ID":"20231024083100-uf03zk6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083100-uf03zk6","updated":"20231024083100"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"Led_Key.h\"\n\nvoid Delay(unsigned long nCount){\n\twhile(nCount--)\n\t{\n\t}\n}\n\nvoid Led_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);//使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_5;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);//初始化\n\tGPIO_SetBits(GPIOB,GPIO_Pin_5);\n}\n\nvoid Key_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOE, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;\n\tGPIO_Init(GPIOE, \u0026GPIO_InitStructure);\n\tGPIO_SetBits(GPIOE,GPIO_Pin_4);\n}\n\nint Key_Scan(GPIO_TypeDef* GPIOx, unsigned int Pin){\n\tif(GPIO_ReadInputDataBit(GPIOx, Pin) == 0){\n\t\tDelay(1000);\n\t\tif(GPIO_ReadInputDataBit(GPIOx, Pin)==0){\n\t\t\twhile(GPIO_ReadInputDataBit(GPIOx, Pin) == 0);\n\t\t\treturn KEY_ON;\n\t\t}\n\t\treturn KEY_OFF;\n\t}\n\treturn KEY_OFF;\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083101-kzrz9ug","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083101-kzrz9ug","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.h"}]},{"ID":"20231024083102-8tglbz4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083102-8tglbz4","updated":"20231024083102"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __LED_KEY_H__\n#define __LED_KEY_H__\n#include \u003cstm32f10x.h\u003e\nvoid Led_Configuration(void);\nvoid Key_Configuration(void);\nint Key_Scan(GPIO_TypeDef* GPIOx, unsigned int Pin);\n#include \u003cstm32f10x_gpio.h\u003e\n#include \u003cstm32f10x_rcc.h\u003e\n#define KEY_ON 0\n#define KEY_OFF 1\n#endif\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083103-3w5mak4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083103-3w5mak4","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083104-j7uj4nv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083104-j7uj4nv","updated":"20231024083104"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\n#include \"Led_Key.h\"\nvoid Delay(unsigned long nCount);\n\nint main(void){\n\tLed_Configuration();\n\tKey_Configuration();\n\t\n\twhile(1){\n\t\tif(Key_Scan(GPIOE, GPIO_Pin_4) == KEY_ON)\n\t\t\t{\n\t\t\t//LED状态切换\n\t\t\tGPIOB-\u003eODR ^= GPIO_Pin_5;\n\t\t\t//异或原理\n\t\t\t//0000 ^ 1111 = 1111\n\t\t\t//1111 ^ 1111 = 0000\n\t\t}\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083105-nl5epkf","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083105-nl5epkf","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"呼吸灯"}]},{"ID":"20231024083106-2cc2jom","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083106-2cc2jom","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.h"}]},{"ID":"20231024083107-2e8yknc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083107-2e8yknc","updated":"20231024083107"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __LED_KEY_H__\n#define __LED_KEY_H__\n#include \u003cstm32f10x.h\u003e\nvoid Led_Configuration(void);\nvoid Key_Configuration(void);\nint Key_Scan(GPIO_TypeDef* GPIOx, unsigned int Pin);\n#include \u003cstm32f10x_gpio.h\u003e\n#include \u003cstm32f10x_rcc.h\u003e\n#define KEY_ON 0\n#define KEY_OFF 1\n#endif\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083108-ldmuaye","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083108-ldmuaye","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.c"}]},{"ID":"20231024083109-4nx596w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083109-4nx596w","updated":"20231024083109"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"Led_Key.h\"\n\nvoid Delay(unsigned long nCount){\n\twhile(nCount--)\n\t{\n\t}\n}\n\nvoid Led_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);//使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_5;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);//初始化\n\tGPIO_SetBits(GPIOB,GPIO_Pin_5);\n\t\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOE, ENABLE);//使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_5;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOE, \u0026GPIO_InitStructure);//初始化\n\tGPIO_SetBits(GPIOE,GPIO_Pin_5);\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083110-ez9aysm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083110-ez9aysm","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083111-a7g0587","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083111-a7g0587","updated":"20231024083111"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//呼吸灯\n#include \"Led_Key.h\"\nvoid Delay(unsigned long nCount);\n\nint main(void){\n\tint i;\n\tLed_Configuration();\n\t\n\twhile(1){\n\t\tfor(i=0;i\u003c4000;i++){\n\t\t\tGPIO_ResetBits(GPIOB,GPIO_Pin_5);\n\t\t\tGPIO_ResetBits(GPIOE,GPIO_Pin_5);\n\t\t\tDelay(4000-i);\n\t\t\tGPIO_SetBits(GPIOB,GPIO_Pin_5);\n\t\t\tGPIO_SetBits(GPIOE,GPIO_Pin_5);\n\t\t\tDelay(i);\n\t\t}\n\t\tfor(i=0;i\u003c4000;i++){\n\t\t\tGPIO_ResetBits(GPIOB,GPIO_Pin_5);\n\t\t\tGPIO_ResetBits(GPIOE,GPIO_Pin_5);\n\t\t\tDelay(i);\n\t\t\tGPIO_SetBits(GPIOB,GPIO_Pin_5);\n\t\t\tGPIO_SetBits(GPIOE,GPIO_Pin_5);\n\t\t\tDelay(4000-i);\n\t\t}\n\t}\n\t\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083112-lz2x4l8","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083112-lz2x4l8","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"中断"}]},{"ID":"20231024083113-hayyhuy","Type":"NodeParagraph","Properties":{"id":"20231024083113-hayyhuy","updated":"20231024083113"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1692170133072-2e19695a-c682-4c9d-baf8-e6a57fcbae33.png#averageHue=%23edece9\u0026clientId=u762ab4e4-822a-4\u0026from=paste\u0026height=144\u0026id=u5c790414\u0026originHeight=144\u0026originWidth=838\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=118905\u0026status=done\u0026style=none\u0026taskId=u30e10c84-f921-4c22-85e1-893ba82f96e\u0026title=\u0026width=838","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::tips"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"什么都不按时是高电平"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"当按下按键由高电平变成低电平 即Falling是下降沿有效"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"当按件抬起由低电平变成高电平 即Rising上升沿有效"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"Rising_Falling 即两次中断"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::"}]},{"ID":"20231024083114-s01ozs4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083114-s01ozs4","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_exti.h"}]},{"ID":"20231024083115-2fr6m9x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083115-2fr6m9x","updated":"20231024083115"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_EXTI_H__\n#define __BSP_EXTI_H__\n#include \"Led_Key.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\nvoid PE5_EXIT5_Configuration(void);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083116-6ln8b5y","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083116-6ln8b5y","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Led_Key.c和Led_Key.h和上面按键的一样的"}]},{"ID":"20231024083117-a33gnct","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083117-a33gnct","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_exti.h"}]},{"ID":"20231024083118-u1qdt5c","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083118-u1qdt5c","updated":"20231024083118"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_exti.h\"\n\n\nvoid PE5_EXIT5_Configuration(void){\n\t\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tEXTI_InitTypeDef EXTI_InitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOE | RCC_APB2Periph_AFIO, ENABLE);//开启时钟，开启外部中断 即PB5的复用功能 使能gpiob\n\t\n\t//KEY0、KEY1和 WK_UP分别连接 分别连接 PE4、PE3和 PA0，\n\t//即对应了 EXTI4、EXTI3和 EXTI0这三条外部中断线。\n\t//这里需要注意的是 EXTI0到 EXTI4都是有单独的中断向量，\n\t//EXTI5到 EXTI9是公用 是公用 EXTI9_5_IRQn，EXTI10到 EXTI15是公用 是公用 EXTI15_10_IRQn。\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);//抢占优先级群分组 看具体文档\n//\tNVIC_InitStructure.NVIC_IRQChannel = EXTI9_5_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannel = EXTI4_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\n\t//将GPIO配置为外部中断的方式\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//推挽输出\n\tGPIO_Init(GPIOE, \u0026GPIO_InitStructure);//初始化\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOE, GPIO_PinSource4);//GPIO中断\n\t\n\t//中断函数 外部中断以哪种方式响应\n\tEXTI_InitStructure.EXTI_Line =  EXTI_Line4;//选择待使能或者失能的外部路线\n\tEXTI_InitStructure.EXTI_Mode = EXTI_Mode_Interrupt;//中断请求 优先级高于事件请求\n\tEXTI_InitStructure.EXTI_Trigger = EXTI_Trigger_Falling;//下降沿有效 即按下按键\n\tEXTI_InitStructure.EXTI_LineCmd = ENABLE;//中断使能\n\tEXTI_Init(\u0026EXTI_InitStructure);\n}\n\n//注意：这是系统里的EXTI4_IRQHandler 需要我们自己去补充中断的内容\nvoid EXTI4_IRQHandler(void){\n\tif(EXTI_GetITStatus(EXTI_Line4) != RESET){\n\t\tGPIOB-\u003eODR ^= GPIO_Pin_5;\n\t\tGPIOE-\u003eODR ^= GPIO_Pin_5;\n\t\tEXTI_ClearITPendingBit(EXTI_Line4);//清除标志位\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083119-h614v1r","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083119-h614v1r","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083120-s6vzpxe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083120-s6vzpxe","updated":"20231024083120"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//中断\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\nint main(void){\n\tLed_Configuration();\n\tPE5_EXIT5_Configuration();\n\twhile(1){\n\t}\n\t\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083121-viqq1kn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083121-viqq1kn","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"定时器"}]},{"ID":"20231024083122-cp2ry1d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083122-cp2ry1d","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_SysTick.h"}]},{"ID":"20231024083123-snwamj7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083123-snwamj7","updated":"20231024083123"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_SYSTICK_H__\n#define __BSP_SYSTICK_H__\n#include \"Led_Key.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\nextern unsigned int TimingDelay;\nvoid SysTick_Configuration(void);\nvoid Delay_us(unsigned int n);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083124-2xyogyh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083124-2xyogyh","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_SysTick.c"}]},{"ID":"20231024083125-8rwzels","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083125-8rwzels","updated":"20231024083125"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_SysTick.h\"\n\nunsigned int TimingDelay;\n\t\nvoid SysTick_Configuration(void){\n\t\t\n\t\twhile(SysTick_Config(72)); //初始化 周期72\n\t\t//先关闭定时器是因为后面可能还能工作要做，还不需要开启定时器，所以需要先关闭\n\t\tSysTick-\u003eCTRL \u0026= ~(1\u003c\u003c0);//最后一位置零 暂时初始化后先关闭定时器，使用前开启\n\t\n\n}\n\nvoid Delay_us(unsigned int n){\n\t\tTimingDelay = n;\n\t\tSysTick-\u003eCTRL |= (1\u003c\u003c0); // 开启systick\n\t\twhile(TimingDelay);\n\t\tSysTick-\u003eCTRL \u0026= ~(1\u003c\u003c0);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083126-xirh1qp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083126-xirh1qp","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083127-r9vkeer","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083127-r9vkeer","updated":"20231024083127"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//定时器\n#include \"bsp_SysTick.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n\nint main(void){\n\tSysTick_Configuration();\n\tLed_Configuration();\n\twhile(1){\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_SET);\n\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_SET);\n\t\tDelay_us(1000000);//1/72000000 * 72 = 1/1000000\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_RESET);\n\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_RESET);\n\t\tDelay_us(1000000);//1/72000000 * 72 = 1/1000000\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083128-gpfw83j","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083128-gpfw83j","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"独立看门狗"}]},{"ID":"20231024083129-u6bvncm","Type":"NodeBlockquote","Properties":{"id":"20231024083129-u6bvncm","updated":"20231024083129"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083130-33h9es6","Type":"NodeParagraph","Properties":{"id":"20231024083130-33h9es6","updated":"20231024083130"},"Children":[{"Type":"NodeText","Data":"利用的是stm32内部40khz的低速时钟"}]}]},{"ID":"20231024083131-jycri8g","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083131-jycri8g","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_iwdg.h"}]},{"ID":"20231024083132-ncy5kls","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083132-ncy5kls","updated":"20231024083132"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_IWDG_H__\n#define __BSP_IWDG_H__\n\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"stm32f10x_iwdg.h\"\nvoid IWDG_Configuration(void);\nvoid IWDG_FeedDog(void);\n#define LED_TOGGLE_B GPIOB-\u003eODR ^= GPIO_Pin_5\n#define LED_TOGGLE_E GPIOE-\u003eODR ^= GPIO_Pin_5\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083133-coly4mt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083133-coly4mt","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_iwdg.c"}]},{"ID":"20231024083134-fau45tm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083134-fau45tm","updated":"20231024083134"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_iwdg.h\"\n\nvoid IWDG_Configuration(void){\n\tIWDG_WriteAccessCmd(IWDG_WriteAccess_Enable);//看门狗使能\n\tIWDG_SetPrescaler(IWDG_Prescaler_64);//预分频值54位\n\t//重装载值625 因为40khz下如果要一秒实现复位 重装载寄存器的值设为625正好是1s\n\t//重装载值*（（4*2的n次方）/40000）\n\tIWDG_SetReload(625);\n\tIWDG_ReloadCounter();\n\tIWDG_Enable();\n\t\n}\n\n//喂狗\nvoid IWDG_FeedDog(void){\n\tIWDG_ReloadCounter();\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083135-rlp690f","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083135-rlp690f","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083136-khzl0ag","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083136-khzl0ag","updated":"20231024083136"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//看门狗\n#include \"bsp_iwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\nint main(void){\n\tSysTick_Configuration();\n\tLed_Configuration();\n\tIWDG_Configuration();\n\tKey_Configuration();\n\t//让灯闪烁亮灭一次\n\tLED_TOGGLE_B;\n\tLED_TOGGLE_E;\n\tDelay_us(100000);\n\tLED_TOGGLE_B;\n\tLED_TOGGLE_E;\n\tDelay_us(100000);\n\t\n\twhile(1){\n\t\tif (Key_Scan(GPIOE, GPIO_Pin_4) == KEY_ON){\n\t\t\tIWDG_FeedDog();\n\t\tDelay_us(1000);\n\t\t}\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083137-y4z78oz","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083137-y4z78oz","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"窗口看门狗"}]},{"ID":"20231024083138-5dbq4of","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083138-5dbq4of","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_wwdg.h"}]},{"ID":"20231024083139-6z8vai6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083139-6z8vai6","updated":"20231024083139"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_WWDG_H__\n#define __BSP_WWDG_H__\n\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"stm32f10x_wwdg.h\"\nvoid WWDG_Configuration(unsigned char tr, unsigned char wr, unsigned int pr);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083140-qig3y47","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083140-qig3y47","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_wwdg.c"}]},{"ID":"20231024083141-lrurd6o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083141-lrurd6o","updated":"20231024083141"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_wwdg.h\"\n//参数含义：计数器递减初值  上窗口值  分频系数\n\nunsigned char WWDG_CNT = 0x7F;\n\nvoid WWDG_NVIC_Init(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);//抢占优先级群分组 看具体文档\n //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannel = WWDG_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n}\n\nvoid WWDG_Configuration(unsigned char tr, unsigned char wr, unsigned int pr){\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_WWDG, ENABLE);\n\tWWDG_CNT = tr \u0026 WWDG_CNT;\n\tWWDG_SetPrescaler(pr);//分频\n\tWWDG_SetWindowValue(wr);//上窗口值\n\tWWDG_Enable(WWDG_CNT);//设置初值\n\t\n\tWWDG_NVIC_Init();//中断初始化\n\tWWDG_ClearFlag();//清除早期唤醒中断标志位\n\tWWDG_EnableIT();//使能中断\n}\n\nvoid WWDG_IRQHandler(void){\n\tWWDG_SetCounter(WWDG_CNT);\n\tWWDG_ClearFlag();\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083142-5hhzbhe","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083142-5hhzbhe","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083143-qrg9hqs","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083143-qrg9hqs","updated":"20231024083143"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//窗口看门狗\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n\nint main(void){\n\tSysTick_Configuration();\n\tLed_Configuration();\n\t\n\t//让灯闪烁亮灭一次\n\tLED_TOGGLE_B;//因为这两个灯是低电平亮 所以初始化就是亮的 所以写三次才能看到闪烁后熄灭\n\tLED_TOGGLE_E;\n\tDelay_us(100000);\n\tLED_TOGGLE_B;\n\tLED_TOGGLE_E;\n\tDelay_us(100000);\n\tLED_TOGGLE_B;\n\tLED_TOGGLE_E;\n\tDelay_us(100000);\n\tWWDG_Configuration(0x7F, 0x5F, WWDG_Prescaler_8);\n\t\n\twhile(1){\n//\tLED_TOGGLE_B;\n//\tLED_TOGGLE_E;\n//\tDelay_us(100000);\n//\tLED_TOGGLE_B;\n//\tLED_TOGGLE_E;\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083144-9ctap6m","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083144-9ctap6m","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"USART"}]},{"ID":"20231024083145-mekbw66","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083145-mekbw66","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.h"}]},{"ID":"20231024083146-rvy5lnw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083146-rvy5lnw","updated":"20231024083146"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_UART_H__\n#define __BSP_UART_H__\n\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"stm32f10x_wwdg.h\"\n#include \"stm32f10x_usart.h\"\nvoid Uart1_Configuration(void);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083147-f9ayzqo","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083147-f9ayzqo","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083148-d19lbg5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083148-d19lbg5","updated":"20231024083148"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_Cmd(USART1,ENABLE);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083149-nmta4ie","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083149-nmta4ie","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083150-egvqzil","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083150-egvqzil","updated":"20231024083150"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//uart\n#include \"bsp_iwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\nint main(void){\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\t\n\twhile(1){\n\t\tUSART_SendData(USART1,0x61);//字符A ASCII码是0x41\n\t\tDelay_us(1000000);\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083151-pa2mmd5","Type":"NodeParagraph","Properties":{"id":"20231024083151-pa2mmd5","updated":"20231024083151"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1692267619853-78728996-13e0-4797-ab44-2b1521feb69f.png#averageHue=%23f0efef\u0026clientId=u762ab4e4-822a-4\u0026from=paste\u0026height=433\u0026id=u13f48640\u0026originHeight=433\u0026originWidth=546\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=24320\u0026status=done\u0026style=none\u0026taskId=u054520f8-a12a-405e-b255-704fba4c07a\u0026title=\u0026width=546","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083152-eqh9dhf","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083152-eqh9dhf","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"usart发送字符串\u0026printf重定向"}]},{"ID":"20231024083153-w8782ry","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083153-w8782ry","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.h"}]},{"ID":"20231024083154-stijg74","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083154-stijg74","updated":"20231024083154"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_UART_H__\n#define __BSP_UART_H__\n\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n#include \"misc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"stm32f10x_wwdg.h\"\n#include \"stm32f10x_usart.h\"\n#include \"stdio.h\"\n\nvoid Uart1_Configuration(void);\nvoid USART_SendString(const unsigned char *pt);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083155-g9vt5k5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083155-g9vt5k5","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083156-pjxtucr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083156-pjxtucr","updated":"20231024083156"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_Cmd(USART1,ENABLE);\n}\n\nvoid USART_SendString(const unsigned char *pt){\n\twhile(*pt){\n\t\t//如果缓冲区发送完数据就变为空 即SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\t\tUSART_SendData(USART1, *pt);\n\t\t//如果发送完成就为空 SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);//发送完成标志位\n\t\tpt++;\n\t}\n}\n\n//重定向printf\nint fputc(int c, FILE *fp){\n\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\tUSART_SendData(USART1, c);\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\treturn 0;\n}\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083157-ni7ixux","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083157-ni7ixux","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083158-9kvkyq6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083158-9kvkyq6","updated":"20231024083158"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//uart 发送字符串\n#include \"bsp_iwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\nint main(void){\n\tint i = 0;\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\n\twhile(1){\n\t\tprintf(\"Hello World\\r\\n\");//  \\r\\n回车换行\n\t\tprintf(\"\");\n\t\tprintf(\"i = %d \\n\",i);\n\t\tDelay_us(1000000);\n\t}\n}\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083159-de1lfjh","Type":"NodeParagraph","Properties":{"id":"20231024083159-de1lfjh","updated":"20231024083159"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1692323050396-bef951fe-fc92-4773-b903-bd7ffd68390a.png#averageHue=%23efedec\u0026clientId=u762ab4e4-822a-4\u0026from=paste\u0026height=433\u0026id=u6ff32b1d\u0026originHeight=433\u0026originWidth=546\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=31904\u0026status=done\u0026style=none\u0026taskId=ud6ec65fc-f7c8-4fc6-a2d9-8ecd2da192c\u0026title=\u0026width=546","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083160-gayzq0q","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083160-gayzq0q","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"串口接收"}]},{"ID":"20231024083161-dh0h1m2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083161-dh0h1m2","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.h"}]},{"ID":"20231024083162-oma7dot","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083162-oma7dot","updated":"20231024083162"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_UART_H__\n#define __BSP_UART_H__\n\n\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n\n#include \"stm32f10x_usart.h\"\n#include \"stdio.h\"\n\nvoid Uart1_Configuration(void);\nvoid USART_SendString(const unsigned char *pt);\nvoid Uart1_NVIC_Init(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083163-wnpdwxa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083163-wnpdwxa","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083164-012gyia","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083164-012gyia","updated":"20231024083164"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//接收端注意要使用浮空状态\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_ITConfig(USART1, USART_IT_RXNE, ENABLE);//USART中断 第二个参数是要打开哪一类中断 这里是接收中断\n\tUSART_Cmd(USART1,ENABLE);\n}\n\nvoid Uart1_NVIC_Init(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);\n\tNVIC_InitStructure.NVIC_IRQChannel = USART1_IRQn; \n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 1;\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n}\n\n\n//重定向printf\nint fputc(int c, FILE *fp){\n\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\tUSART_SendData(USART1, c);\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\treturn 0;\n}\n\n//重定向fget\nint fgetc(FILE *fp){\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) != SET);\n\treturn (int)USART_ReceiveData(USART1);\n}\n\nvoid USART1_IRQHandler(void){\n\tunsigned char ch;\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n\t\tch = USART_ReceiveData(USART1);\n\t\tprintf(\"%c\\n\", ch + 1);\n\t}\n}\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083165-27rw0vt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083165-27rw0vt","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083166-gp5es3q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083166-gp5es3q","updated":"20231024083166"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//uart 串口接收\n#include \"bsp_iwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\nint main(void){\n\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\tUart1_NVIC_Init();\n\twhile(1){\n\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083167-ohwblil","Type":"NodeParagraph","Properties":{"id":"20231024083167-ohwblil","updated":"20231024083167"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1692329058483-97dbc827-8ef5-4f0e-ba2a-7d0ea1272347.png#averageHue=%23f1f0f0\u0026clientId=u762ab4e4-822a-4\u0026from=paste\u0026height=433\u0026id=u4232f5e4\u0026originHeight=433\u0026originWidth=546\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=31190\u0026status=done\u0026style=none\u0026taskId=u7e5eaec6-e22f-4e10-85ca-366139d7c54\u0026title=\u0026width=546","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083168-qlmpy2q","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083168-qlmpy2q","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"睡眠模式"}]},{"ID":"20231024083169-fxy10gq","Type":"NodeBlockquote","Properties":{"id":"20231024083169-fxy10gq","updated":"20231024083169"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083170-yeufa9m","Type":"NodeParagraph","Properties":{"id":"20231024083170-yeufa9m","updated":"20231024083170"},"Children":[{"Type":"NodeText","Data":"只是多了一个睡眠模式 和 睡眠模式的中断唤醒"}]}]},{"ID":"20231024083171-9a31xrm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083171-9a31xrm","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083172-4gksf84","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083172-4gksf84","updated":"20231024083172"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//睡眠模式\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\nint main(void){\n\tint i;\n\t\n\tSysTick_Configuration();\n\tLed_Configuration();\n\tPE5_EXIT5_Configuration();//中断唤醒睡眠模式\n\t\n\twhile(1){\n\t\tfor(int i = 0; i \u003c 10; i++){\n\n\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_RESET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_RESET);\n\t\t\tDelay_us(200000);\n\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_SET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_SET);\n\t\t\tDelay_us(200000);\t\t\t\n\t\t}\n\t\t__WFI();//睡眠模式\t \n\t}\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083173-a3f0b5h","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083173-a3f0b5h","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"停止模式"}]},{"ID":"20231024083174-98s0kcr","Type":"NodeBlockquote","Properties":{"id":"20231024083174-98s0kcr","updated":"20231024083174"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083175-5pdpdmx","Type":"NodeParagraph","Properties":{"id":"20231024083175-5pdpdmx","updated":"20231024083175"},"Children":[{"Type":"NodeText","Data":"注意：停止模式后电源会进入低功耗 只有40MHZ 需要将自带的驱动时钟电源频率的函数复制出来调用 将频率提升至72MHZ"}]}]},{"ID":"20231024083176-c24w9ip","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083176-c24w9ip","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.h"}]},{"ID":"20231024083177-9vcqjy6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083177-9vcqjy6","updated":"20231024083177"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_UART_H__\n#define __BSP_UART_H__\n\n\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n\n#include \"stm32f10x_usart.h\"\n#include \"stdio.h\"\n\n#include \"core_cm3.h\"\n\nvoid Uart1_Configuration(void);\nvoid USART_SendString(const unsigned char *pt);\nvoid Uart1_NVIC_Init(void);\nvoid SetSysClock_to_72MHZ(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083178-i5zi6nw","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083178-i5zi6nw","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083179-5h1tnhr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083179-5h1tnhr","updated":"20231024083179"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//接收端注意要使用浮空状态\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_ITConfig(USART1, USART_IT_RXNE, ENABLE);//USART中断 第二个参数是要打开哪一类中断 这里是接收中断\n\tUSART_Cmd(USART1,ENABLE);\n}\n\nvoid Uart1_NVIC_Init(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);\n\tNVIC_InitStructure.NVIC_IRQChannel = USART1_IRQn; \n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 1;\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n}\n\n\nvoid USART_SendString(const unsigned char *pt){\n\twhile(*pt){\n\t\t//如果缓冲区发送完数据就变为空 即SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\t\tUSART_SendData(USART1, *pt);\n\t\t//如果发送完成就为空 SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\t\tpt++;\n\t}\n}\n\n//重定向printf\nint fputc(int c, FILE *fp){\n\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\tUSART_SendData(USART1, c);\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\treturn 0;\n}\n\n//重定向fget\nint fgetc(FILE *fp){\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) != SET);\n\treturn (int)USART_ReceiveData(USART1);\n}\n\nvoid USART1_IRQHandler(void){\n\tunsigned char ch;\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n\t\tch = USART_ReceiveData(USART1);\n\t\tprintf(\"%c\\n\", ch + 1);\n\t}\n}\n\n//这是自带时钟频率驱动至72MHZ的函数 只是将函数名改变了 为了避免有影响\nvoid SetSysClock_to_72MHZ(void)\n{\n  __IO uint32_t StartUpCounter = 0, HSEStatus = 0;\n  \n  /* SYSCLK, HCLK, PCLK2 and PCLK1 configuration ---------------------------*/    \n  /* Enable HSE */    \n  RCC-\u003eCR |= ((uint32_t)RCC_CR_HSEON);\n \n  /* Wait till HSE is ready and if Time out is reached exit */\n  do\n  {\n    HSEStatus = RCC-\u003eCR \u0026 RCC_CR_HSERDY;\n    StartUpCounter++;  \n  } while((HSEStatus == 0) \u0026\u0026 (StartUpCounter != HSE_STARTUP_TIMEOUT));\n\n  if ((RCC-\u003eCR \u0026 RCC_CR_HSERDY) != RESET)\n  {\n    HSEStatus = (uint32_t)0x01;\n  }\n  else\n  {\n    HSEStatus = (uint32_t)0x00;\n  }  \n\n  if (HSEStatus == (uint32_t)0x01)\n  {\n    /* Enable Prefetch Buffer */\n    FLASH-\u003eACR |= FLASH_ACR_PRFTBE;\n\n    /* Flash 2 wait state */\n    FLASH-\u003eACR \u0026= (uint32_t)((uint32_t)~FLASH_ACR_LATENCY);\n    FLASH-\u003eACR |= (uint32_t)FLASH_ACR_LATENCY_2;    \n\n \n    /* HCLK = SYSCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_HPRE_DIV1;\n      \n    /* PCLK2 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE2_DIV1;\n    \n    /* PCLK1 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE1_DIV2;\n\n#ifdef STM32F10X_CL\n    /* Configure PLLs ------------------------------------------------------*/\n    /* PLL2 configuration: PLL2CLK = (HSE / 5) * 8 = 40 MHz */\n    /* PREDIV1 configuration: PREDIV1CLK = PLL2 / 5 = 8 MHz */\n        \n    RCC-\u003eCFGR2 \u0026= (uint32_t)~(RCC_CFGR2_PREDIV2 | RCC_CFGR2_PLL2MUL |\n                              RCC_CFGR2_PREDIV1 | RCC_CFGR2_PREDIV1SRC);\n    RCC-\u003eCFGR2 |= (uint32_t)(RCC_CFGR2_PREDIV2_DIV5 | RCC_CFGR2_PLL2MUL8 |\n                             RCC_CFGR2_PREDIV1SRC_PLL2 | RCC_CFGR2_PREDIV1_DIV5);\n  \n    /* Enable PLL2 */\n    RCC-\u003eCR |= RCC_CR_PLL2ON;\n    /* Wait till PLL2 is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLL2RDY) == 0)\n    {\n    }\n    \n   \n    /* PLL configuration: PLLCLK = PREDIV1 * 9 = 72 MHz */ \n    RCC-\u003eCFGR \u0026= (uint32_t)~(RCC_CFGR_PLLXTPRE | RCC_CFGR_PLLSRC | RCC_CFGR_PLLMULL);\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLXTPRE_PREDIV1 | RCC_CFGR_PLLSRC_PREDIV1 | \n                            RCC_CFGR_PLLMULL9); \n#else    \n    /*  PLL configuration: PLLCLK = HSE * 9 = 72 MHz */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_PLLSRC | RCC_CFGR_PLLXTPRE |\n                                        RCC_CFGR_PLLMULL));\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLSRC_HSE | RCC_CFGR_PLLMULL9);\n#endif /* STM32F10X_CL */\n\n    /* Enable PLL */\n    RCC-\u003eCR |= RCC_CR_PLLON;\n\n    /* Wait till PLL is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLLRDY) == 0)\n    {\n    }\n    \n    /* Select PLL as system clock source */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_SW));\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_SW_PLL;    \n\n    /* Wait till PLL is used as system clock source */\n    while ((RCC-\u003eCFGR \u0026 (uint32_t)RCC_CFGR_SWS) != (uint32_t)0x08)\n    {\n    }\n  }\n  else\n  { /* If HSE fails to start-up, the application will have wrong clock \n         configuration. User can add here some code to deal with this error */\n  }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083180-ophvnty","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083180-ophvnty","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083181-yxv1a6z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083181-yxv1a6z","updated":"20231024083181"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//停止模式\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"stm32f10x_pwr.h\"\n\n\nint main(void){\n\tint i;\n\t\n\tSysTick_Configuration();\n\tLed_Configuration();\n\tPE5_EXIT5_Configuration();//中断唤醒睡眠模式\n\n\twhile(1){\n\t\tfor(int i = 0; i \u003c 10; i++){\n\n\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_RESET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_RESET);\n\t\t\tDelay_us(200000);\n\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_SET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_SET);\n\t\t\tDelay_us(200000);\t\t\t\n\t\t}\n\t\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_PWR, ENABLE);//外部时钟电源使能\n\t\tPWR_EnterSTOPMode(PWR_Regulator_LowPower, PWR_STOPEntry_WFI);//但是此时还是低功耗模式 只有40MHZ\n\t\tSetSysClock_to_72MHZ();//将时钟频率恢复到72MHZ\n\t\twhile(1){\n\t\t\t\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_RESET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_RESET);\n\t\t\tDelay_us(200000);\n\t\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_SET);\n\t\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_SET);\n\t\t\tDelay_us(200000);\t\t\n\t\t}\n\t\t\n\t}\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083182-h2dg7eu","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083182-h2dg7eu","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"DMA 直接内存访问"}]},{"ID":"20231024083183-oyn0ee1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083183-oyn0ee1","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_dma.h"}]},{"ID":"20231024083184-4v7ejld","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083184-4v7ejld","updated":"20231024083184"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_DMA_H__\n#define __BSP_DMA_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\nvoid DMA_Configuration(void);\nextern unsigned char arr[2000];\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083185-7jo85vx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083185-7jo85vx","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_dma.c"}]},{"ID":"20231024083186-7iwf3q9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083186-7iwf3q9","updated":"20231024083186"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_dma.h\"\n\nunsigned char arr[2000];\n\nvoid DMA_Configuration(void){\n\tDMA_InitTypeDef DMA_InitStructure;\n\tRCC_AHBPeriphClockCmd(RCC_AHBPeriph_DMA1, ENABLE);\n\t\n\tDMA_InitStructure.DMA_PeripheralBaseAddr = (uint32_t)\u0026(USART1-\u003eDR);//外设的基地址\n\tDMA_InitStructure.DMA_MemoryBaseAddr = (uint32_t) arr;//内存的基地址\n\tDMA_InitStructure.DMA_DIR = DMA_DIR_PeripheralDST;//数据传输的方向。DMA_DIR_PeripheralSRC表示数据从外设传输到内存，DMA_DIR_PeripheralDST表示数据从内存传输到外设。\n\tDMA_InitStructure.DMA_BufferSize = 2000;//传输的数据的数量\n\tDMA_InitStructure.DMA_PeripheralInc = DMA_PeripheralInc_Disable;//外设地址的增量\n\tDMA_InitStructure.DMA_MemoryInc = DMA_MemoryInc_Enable;//内存地址的增量\n\tDMA_InitStructure.DMA_PeripheralDataSize = DMA_PeripheralDataSize_Byte;//数据宽度\n\tDMA_InitStructure.DMA_MemoryDataSize = DMA_MemoryDataSize_Byte;//数据宽度\n\tDMA_InitStructure.DMA_Mode = DMA_Mode_Circular;//DMA的模式DMA_Mode_Circular表示当数据传输完成后，DMA将从起始地址重新开始传输。\n\tDMA_InitStructure.DMA_Priority = DMA_Priority_Medium;//优先级\n\tDMA_InitStructure.DMA_M2M = DMA_M2M_Disable;\n\tDMA_Init(DMA1_Channel4, \u0026DMA_InitStructure);\n\tDMA_Cmd(DMA1_Channel4, ENABLE);\n\t\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083187-kuybo7v","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083187-kuybo7v","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083188-4bsbawe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083188-4bsbawe","updated":"20231024083188"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//DMA\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n\n#include \"bsp_dma.h\"\n\n\nint main(void){\n\tint i;\n\tSysTick_Configuration();\n\tLed_Configuration();\n\tUart1_Configuration();\n\tDMA_Configuration();\n\tfor(i = 0; i\u003c2000;i++){\n\t\tarr[i] = 'A';\n\t}\n\tUSART_DMACmd(USART1, USART_DMAReq_Tx, ENABLE);\n\twhile(1){\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_RESET);\n\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_RESET);\n\t\tDelay_us(200000);\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_5,Bit_SET);\n\t\tGPIO_WriteBit(GPIOE,GPIO_Pin_5,Bit_SET);\n\t\tDelay_us(200000);\t\t\t\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083189-lswvtb7","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083189-lswvtb7","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"ADC"}]},{"ID":"20231120152755-l3iwhm2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231120152755-l3iwhm2","updated":"20240731160329"},"Children":[{"Type":"NodeText","Data":"原理"}]},{"ID":"20231120152806-e0s2yvq","Type":"NodeBlockquote","Properties":{"id":"20231120152806-e0s2yvq","updated":"20231120154118"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231120152808-rdmj8kg","Type":"NodeParagraph","Properties":{"id":"20231120152808-rdmj8kg","updated":"20231120153048"},"Children":[{"Type":"NodeText","Data":"位数：多少位ADC表示ADC的分辨率 如：12位的adc的分辨率 就是 5V/12 或者 3V/12 位数越多能感知到的电压就越细"}]},{"ID":"20231120153036-alrxsgo","Type":"NodeParagraph","Properties":{"id":"20231120153036-alrxsgo","updated":"20231120153206"},"Children":[{"Type":"NodeText","Data":"通道数：如18个通道，有16个外部通道和2个内部通道，外部就是给外设用的，内部就是测量单片机内部的传感器的，比如单片机自身的温度传感器，还有内部电源模块"}]},{"ID":"20231120153301-fxmn8co","Type":"NodeParagraph","Properties":{"id":"20231120153301-fxmn8co","updated":"20231120153536"},"Children":[{"Type":"NodeText","Data":"扫描模式：表示对adc所有通道进行扫描，比如有很多外设连了adc通道，就需要扫描所有的值"}]},{"ID":"20231120153709-1kdyem4","Type":"NodeParagraph","Properties":{"id":"20231120153709-1kdyem4","updated":"20231120153825"},"Children":[{"Type":"NodeText","Data":"间断模式：一次取几个通道进行扫描"}]},{"ID":"20231120153826-qt6vjzm","Type":"NodeParagraph","Properties":{"id":"20231120153826-qt6vjzm","updated":"20231120153826"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231120153826-fn0my61.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231120153331-9k03b7k","Type":"NodeParagraph","Properties":{"id":"20231120153331-9k03b7k","updated":"20231120153429"},"Children":[{"Type":"NodeText","Data":"单次：只采集一次"}]},{"ID":"20231120153339-k5wztb6","Type":"NodeParagraph","Properties":{"id":"20231120153339-k5wztb6","updated":"20231120153448"},"Children":[{"Type":"NodeText","Data":"连续：采集很多次"}]},{"ID":"20231120154118-9xsr486","Type":"NodeParagraph","Properties":{"id":"20231120154118-9xsr486","updated":"20231120154118"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231120153658-qqcs2b4.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]}]},{"ID":"20231120153658-hmn26ls","Type":"NodeBlockquote","Properties":{"id":"20231120153658-hmn26ls","updated":"20231120154559"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231120154124-fhfp7xz","Type":"NodeParagraph","Properties":{"id":"20231120154124-fhfp7xz","updated":"20231120154559"},"Children":[{"Type":"NodeText","Data":"注意：想要adc准的话参考电压必须很准 因为如果参考电压是3.3v那基本会在3.1-3.4v之间浮动 如果想要很准的话 就需要在参考电压前接一个稳压芯片"}]}]},{"ID":"20231120153702-uzhcktm","Type":"NodeBlockquote","Properties":{"id":"20231120153702-uzhcktm","updated":"20231120155151"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20231120154959-uzkb3j4","Type":"NodeParagraph","Properties":{"id":"20231120154959-uzkb3j4","updated":"20231120155014"},"Children":[{"Type":"NodeText","Data":"规则通道\u0026注入通道"}]},{"ID":"20231120155015-we5ykg0","Type":"NodeParagraph","Properties":{"id":"20231120155015-we5ykg0","updated":"20231120155015"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20231120155015-gwoqmtx.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20231120155015-xsopar3","Type":"NodeParagraph","Properties":{"id":"20231120155015-xsopar3","updated":"20231120155151"},"Children":[{"Type":"NodeText","Data":"注入通道和规则通道可以理解为：一个工厂如果有很多ad值需要一直检测偶尔需要检测工厂外面的数据就可以使用注入通道"}]}]},{"ID":"20231024083190-fbhj20h","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083190-fbhj20h","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_adc.h"}]},{"ID":"20231024083191-rais2oy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083191-rais2oy","updated":"20231024083191"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_ADC_H__\n#define __BSP_ADC_H__\n\n\n#include \"stm32f10x.h\"\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_adc.h\"\n\n#define V25 0x6EF\n#define AVG_SLOPE 0x5 \n#define ADC_DR 0x4001244C\nextern uint16_t ADC_ConvertVal;\nvoid ADC_Configuration(void);\nvoid Uart1_Configuration(void);\nvoid SysTick_Configuration(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083192-vd5rtym","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083192-vd5rtym","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_adc.c"}]},{"ID":"20231024083193-6bime8f","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083193-6bime8f","updated":"20231024083193"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_adc.h\"\n\nuint16_t ADC_ConvertVal;\n\nvoid ADC_Configuration(void){\n\tDMA_InitTypeDef DMA_InitStructure;\n\tADC_InitTypeDef ADC_InitStructure;\n\t\n\tRCC_AHBPeriphClockCmd(RCC_AHBPeriph_DMA1, ENABLE);\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_ADC1, ENABLE);\n\t\n\tDMA_InitStructure.DMA_PeripheralBaseAddr = ADC_DR;//外设的基地址\n\tDMA_InitStructure.DMA_MemoryBaseAddr = (uint32_t)\u0026ADC_ConvertVal;//内存的基地址\n\tDMA_InitStructure.DMA_DIR = DMA_DIR_PeripheralSRC;//数据传输的方向。DMA_DIR_PeripheralSRC表示数据从外设传输到内存，DMA_DIR_PeripheralDST表示数据从内存传输到外设。\n\tDMA_InitStructure.DMA_BufferSize = 1;//传输的数据的数量\n\tDMA_InitStructure.DMA_PeripheralInc = DMA_PeripheralInc_Disable;//外设地址的增量\n\tDMA_InitStructure.DMA_MemoryInc = DMA_MemoryInc_Disable;//内存地址的增量\n\tDMA_InitStructure.DMA_PeripheralDataSize = DMA_PeripheralDataSize_HalfWord;//数据宽度\n\tDMA_InitStructure.DMA_MemoryDataSize = DMA_MemoryDataSize_HalfWord;//数据宽度\n\tDMA_InitStructure.DMA_Mode = DMA_Mode_Circular;//DMA的模式DMA_Mode_Circular表示当数据传输完成后，DMA将从起始地址重新开始传输。\n\tDMA_InitStructure.DMA_Priority = DMA_Priority_High ;//优先级\n\tDMA_InitStructure.DMA_M2M = DMA_M2M_Disable;\n\tDMA_Init(DMA1_Channel1, \u0026DMA_InitStructure);\n\tDMA_Cmd(DMA1_Channel1, ENABLE);\n\n\tADC_InitStructure.ADC_Mode = ADC_Mode_Independent;\n\tADC_InitStructure.ADC_ScanConvMode = DISABLE;\n\tADC_InitStructure.ADC_ContinuousConvMode = ENABLE;\n\tADC_InitStructure.ADC_ExternalTrigConv = ADC_ExternalTrigConv_None;\n\tADC_InitStructure.ADC_DataAlign = ADC_DataAlign_Right;\n\tADC_InitStructure.ADC_NbrOfChannel = 1;\n\tADC_Init(ADC1, \u0026ADC_InitStructure);\n\t\n\tRCC_ADCCLKConfig(RCC_PCLK2_Div8);\n\tADC_RegularChannelConfig(ADC1, ADC_Channel_16, 1, ADC_SampleTime_55Cycles5 );\n\t\n\tADC_TempSensorVrefintCmd(ENABLE);\n\t\n\tADC_DMACmd(ADC1, ENABLE);\n\tADC_Cmd(ADC1, ENABLE);\n\t\n\tADC_ResetCalibration(ADC1);\n\twhile(ADC_GetResetCalibrationStatus(ADC1));\n\tADC_StartCalibration(ADC1);\n\twhile(ADC_GetCalibrationStatus(ADC1));\n\t\n\tADC_SoftwareStartConvCmd(ADC1, ENABLE);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083194-bbgrvjq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083194-bbgrvjq","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083195-tv6wm7m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083195-tv6wm7m","updated":"20231024083195"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//adc\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n\n\nint main(){\n\tfloat temperature; \n\tSysTick_Configuration();\n\tUart1_Configuration();\n\tADC_Configuration();\n\t\n\twhile(1){\n\t\ttemperature = (V25 - ADC_ConvertVal)/ AVG_SLOPE +25;\n\t\tprintf(\"Temperature = %.lf\\n\", temperature );\n\t\tDelay_us(1000000);\n\t}\n\t\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083196-c80su8q","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083196-c80su8q","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"TIM定时器"}]},{"ID":"20231024083197-rvzgfu6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083197-rvzgfu6","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim2.h"}]},{"ID":"20231024083198-6zi9u8s","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083198-6zi9u8s","updated":"20231024083198"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM2_H__\n#define __BSP_TIM2_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM2_BaseConfiguration(void);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083199-h536yil","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083199-h536yil","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim2.c"}]},{"ID":"20231024083200-rwp8vrf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083200-rwp8vrf","updated":"20231024083200"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_tim2.h\"\n\nunsigned int times = 0;\n\nvoid TIM2_BaseConfiguration(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\t\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);\n\t\n\tNVIC_InitStructure.NVIC_IRQChannel = TIM2_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\t\n\t//period 和 prescaler 都是1 不是0 因为除数不能为0\n\tTIM_TimeBaseStructure.TIM_Period = 999; //周期 计多少数 看挂载在哪个总线上就是多少频率 72MHZ/72分频=1M\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM2, \u0026TIM_TimeBaseStructure);\n\t\n\tTIM_ClearFlag(TIM2, TIM_FLAG_Update);//清除标志位\n\tTIM_ITConfig(TIM2, TIM_IT_Update, ENABLE);//中断使能\n\tTIM_Cmd(TIM2, ENABLE);\n\t//暂时先关闭TIM2时钟，等全部初始化结束后正式使用定时器前再开启\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);\n}\n\nvoid TIM2_IRQHandler(void){\n\tif(TIM_GetITStatus(TIM2, TIM_IT_Update) == SET){\n\t\ttimes++;\n\t\tif(times == 500){\n\t\t\tLED_TOGGLE_B;\n\t\t\ttimes = 0;\n\t\t}\n\t\tTIM_ClearITPendingBit(TIM2, TIM_IT_Update);//清除中断标志位\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083201-qk403c1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083201-qk403c1","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083202-nz979aa","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083202-nz979aa","updated":"20231024083202"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//tim2\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim2.h\"\n\nint main(){\n\n\tSysTick_Configuration();\n\tLed_Configuration();\n\tTIM2_BaseConfiguration();\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);\n\n\t\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083203-sls7lwd","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083203-sls7lwd","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"RTC(Real Time Clock)显示系统时间"}]},{"ID":"20231024083204-plpetc0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083204-plpetc0","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_rtc.h"}]},{"ID":"20231024083205-hw90jwl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083205-hw90jwl","updated":"20231024083205"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_RTC_H__\n#define __BSP_RTC_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n\n#define leapyear(a) ((a%4==0) \u0026\u0026 (a%100!=0) || (a%400 == 0))\n#define days_in_year(i) (leapyear(i) ? 366 : 365)\n\n\nvoid RTC_Configuration(void);\nvoid Time_Display(u32 TimeVal);\n\nstruct rtc_tm{\n\tunsigned int year;\n\tunsigned int month;\n\tunsigned int day;\n\tunsigned int hour;\n\tunsigned int minute;\n\tunsigned int second;\n};\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083206-kan6049","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083206-kan6049","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_rtc.c"}]},{"ID":"20231024083207-t6yup9o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083207-t6yup9o","updated":"20231024083207"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_rtc.h\"\n#include \u003cstdio.h\u003e\nunsigned int days_in_month[13] = {0,31,28,31,30,31,30,31,31,30,31,30,31};\n\nvoid RTC_Configuration(void){\n\t//使能BKP PWR的外部时钟APB1\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_BKP | RCC_APB1Periph_PWR, ENABLE);\n\tPWR_BackupAccessCmd(ENABLE);\n\tBKP_DeInit();//后备寄存器\n\tRCC_LSEConfig(RCC_LSE_ON);//启动外部低速时钟\n\twhile(RCC_GetFlagStatus(RCC_FLAG_LSERDY) == RESET);//判断当前低速时钟是否就绪\n\tRCC_RTCCLKConfig(RCC_RTCCLKSource_LSE);\n\tRCC_RTCCLKCmd(ENABLE);\n\tRTC_WaitForLastTask();//等待上一次写操作是否完成\n\tRTC_WaitForSynchro();//等待同步\n\tRTC_SetPrescaler(32767);//分频 起始值为1 所以是32768\n\tRTC_WaitForLastTask();//等待上一次写操作是否完成\n}\n\nvoid Time_Display(u32 TimeVal){\n\tstruct rtc_tm tm;\n\tunsigned int days,hms;\n\tunsigned int i,j;\n\t\n\tdays = TimeVal /86400;\n\thms = TimeVal % 86400;\n\t\n\ttm.hour = hms / 3600;\n\ttm.minute = (hms % 3600) / 60;\n\ttm.second = (hms % 3600) % 60;\n\t\n\tfor(i = 1970; days \u003e= days_in_year(i); i++){\n\t\tdays -= days_in_year(i);\n\t}\n\ttm.year = i;\n\n\tif(leapyear(i))\n\t\tdays_in_month[2] = 29;\n\telse\n\t\tdays_in_month[2] = 28;\n\tfor( j= 1; days \u003e= days_in_month[j]; j++)\n\t\tdays -= days_in_month[j];\n\ttm.month = j;\n\t\n\ttm.day = days+1;\n\t\n\tprintf(\"%d-%d-%d: %d:%d:%d\\n\", tm.year, tm.month, tm.day, tm.hour, tm.minute, tm.second);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083208-chm2vrg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083208-chm2vrg","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083209-8f7u92z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083209-8f7u92z","updated":"20231024083209"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//rtc\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_rtc.h\"\n\nint main(){\n\n\tSysTick_Configuration();\n\tRTC_Configuration();\n\tUart1_Configuration();\n\twhile(1){\n\t\tTime_Display(RTC_GetCounter());\n\t\tDelay_us(1000000);\n\t}\n\t\n\t\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083210-jvz0knk","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083210-jvz0knk","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"矩阵按键"}]},{"ID":"20231024083211-qlw5o7v","Type":"NodeParagraph","Properties":{"id":"20231024083211-qlw5o7v","updated":"20231024083211"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694137985267-efde701f-cbca-4b8c-8389-9569e04b4f09.png#averageHue=%23f5f0e7\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=665\u0026id=ep3y9\u0026originHeight=732\u0026originWidth=1677\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=949910\u0026status=done\u0026style=none\u0026taskId=uc1cf3b3c-2f99-483a-8fc2-7995846cce0\u0026title=\u0026width=1524.5454215018224","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::tips"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"如何确定按键？"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"1.首先将PA0-PA3设置为输入，即解上拉电阻，输入高电平；PA4-PA7设置为推挽输出，即输出低电平"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"2.当PA1从高电平转为低电平时，则可以确定是第二列"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"3.此时翻转PA0-PA3为输出,PA4-PA7为输入"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"4.当PA5从高电平转为低电平时，则可以确定为第二行"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"5.最终确定为s6"}]},{"ID":"20231024083212-5p0so7u","Type":"NodeParagraph","Properties":{"id":"20231024083212-5p0so7u","updated":"20231024083212"},"Children":[{"Type":"NodeText","Data":"并可以确定PA3-PA0的低电平状态分别为："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"1111（0xF）1110（0xE）1101（0xD）1011（0xB）0111（0x7）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"PA7-PA4的低电平状态可以确定为：（为什么是F0因为是PA7-PA4为高四位）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"1111（0xF0）1110（0xE0）1101（0xD0）1011（0xB0）0111（0x70）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694138119168-164d3927-ddea-42a7-829b-9a330dacfc34.png#averageHue=%23f5f5f4\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=544\u0026id=uafea7318\u0026originHeight=598\u0026originWidth=1487\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=533648\u0026status=done\u0026style=none\u0026taskId=ua2a4bb31-0782-4f30-8cd2-05384891ae0\u0026title=\u0026width=1351.8181525183124","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::tips"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"16个按键按如上的形式定义s1-s16"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"以第一行为基准val 为 1     5     9     13"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"第二行则为 1+1      5+1     9+1      13+1"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"以此类推"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"确定一个按键的方法就可以变为val+？（？为0、1、2、3）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::"}]},{"ID":"20231024083213-8tkkljj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083213-8tkkljj","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"代码逻辑"}]},{"ID":"20231024083214-kffzxu9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083214-kffzxu9","updated":"20231024083214"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"1.开启PA0端口的时钟\n2.PA0-PA3定义成上拉输入\n3.PA4-PA7定成推挽输出 并且输出低电平\n4.读取PA0-PA3的电平状态\nif (PA0~PA3!=0xF){\n    1）消抖\n    2）if(PA0~PA3!=0xF){\n        switch(PA0~PA3){\n            case 0xE:val = 1;\n            case 0xD:val = 5;\n            case 0xB:val = 9;\n            case 0x7:val = 13;\n        }\n    }else{\n        return 0;\n    }\n    3）行列转换\n        PA0~PA3定义为推挽输出\n        PA4~PA7定义为上拉输入\n        if（PA4~PA7!=0xF0）{\n            消抖\n            if(PA4~PA7!=0xF0){\n        \t\tswitch(PA4~PA7){\n                    case 0xE0:val += 0;\n                    case 0xD0:val += 1;\n                    case 0xB0:val += 2;\n                    case 0x70:val += 3;\n        }\n            }\n        else\n            return 0;\n        }\n}else\n    return 0;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083215-rt1w0c0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083215-rt1w0c0","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"代码"}]},{"ID":"20231024083216-l2ta5x9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083216-l2ta5x9","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"matrix_key.h"}]},{"ID":"20231024083217-39d0ui4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083217-39d0ui4","updated":"20231024083217"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __LED_KEY_H__\n#define __LED_KEY_H__\n#include \u003cstm32f10x.h\u003e\nvoid Led_Configuration(void);\nvoid Key_Configuration(void);\nint Key_Scan(GPIO_TypeDef* GPIOx, unsigned int Pin);\nint Matrix_Key_Scan(void);\n\n\n#include \u003cstm32f10x_gpio.h\u003e\n#include \u003cstm32f10x_rcc.h\u003e\n#define KEY_ON 1\n#define KEY_OFF 0\n#endif\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083218-i83ut6b","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083218-i83ut6b","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"matrix_key.c"}]},{"ID":"20231024083219-qlo2vsz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083219-qlo2vsz","updated":"20231024083219"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//矩阵按键\n\nint Matrix_Key_Scan(void){\n\tu8 val,key = 0;\n\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//上拉输入\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4|GPIO_Pin_5|GPIO_Pin_6|GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_WriteBit(GPIOA,GPIO_Pin_4|GPIO_Pin_5|GPIO_Pin_6|GPIO_Pin_7, Bit_RESET);//设置为低电平 （推挽输出为低电平）\n\t//GPIOA-\u003eIDR就是用来读取GPIOA端口输入电平的\n\t//例如，if (GPIOA-\u003eIDR \u0026 (1 \u003c\u003c 3)) { ... } 就可以用来判断GPIOA端口的第3个引脚的电平是否为高\n\tif((GPIOA-\u003eIDR\u00260xF) != 0xF){\n\t\t\tDelay(1000);\n\t\t\tkey = GPIOA-\u003eIDR \u0026 0xF;\n\t\t\tif(key != 0xF){\n\t\t\t\tswitch(key){\n\t\t\t\t\tcase 0xE:\n\t\t\t\t\t\tval = 1;break;\n\t\t\t\t\tcase 0xD:\n\t\t\t\t\t\tval = 5;break;\n\t\t\t\t\tcase 0xB:\n\t\t\t\t\t\tval = 9;break;\n\t\t\t\t\tcase 0x7:\n\t\t\t\t\t\tval = 13;break;\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}else{\n\t\t\t\treturn 0;\n\t\t\t}\n\t//翻转 矩阵按键行判断\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4|GPIO_Pin_5|GPIO_Pin_6|GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//上拉输入\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\t\t\t\n\tGPIO_WriteBit(GPIOA,GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3, Bit_RESET);\n\t\n\tif((GPIOA-\u003eIDR\u00260xF0) != 0xF0){\n\t\t\tDelay(1000);\n\t\t\tkey = GPIOA-\u003eIDR \u0026 0xF0;\n\t\t\tif(key != 0xF0){\n\t\t\t\tswitch(key){\n\t\t\t\t\tcase 0xE0:\n\t\t\t\t\t\tval += 0;break;\n\t\t\t\t\tcase 0xD0:\n\t\t\t\t\t\tval += 1;break;\n\t\t\t\t\tcase 0xB0:\n\t\t\t\t\t\tval += 2;break;\n\t\t\t\t\tcase 0x70:\n\t\t\t\t\t\tval += 3;break;\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}else{\n\t\t\t\treturn 0;\n\t\t\t}\n\t\t}else{\n\t\t\treturn 0;\n\t\t}\n\t\t\twhile((GPIOA-\u003eIDR \u0026 0xF0) != 0xF0){//等待按键弹起才会返回返回值\n\t\t\t\t\n\t\t}\n\t\treturn val;\n\t\t\n\t}else{\n\t\treturn 0;\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083220-81ubgb7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083220-81ubgb7","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083221-51m7kq7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083221-51m7kq7","updated":"20231024083221"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//矩阵按键\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_rtc.h\"\n\nint main(){\n\t//如果使用usart1并且使用PA2 PA3要拔掉PA2和PA3的跳线帽\n\tint key_num;\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);//开启时钟使能gpiob\n\twhile(1){\n\t\tkey_num = Matrix_Key_Scan();\n\t\tif(key_num != 0){\n\t\t\n\t\tprintf(\"Key %d is pressed.\\n\", key_num);\n\t\t}\t\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083222-hqluzsm","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083222-hqluzsm","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"PWM呼吸灯"}]},{"ID":"20231024083223-41r9bnr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083223-41r9bnr","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"占空比"}]},{"ID":"20231024083224-tf7ncvi","Type":"NodeBlockquote","Properties":{"id":"20231024083224-tf7ncvi","updated":"20231024083224"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083225-29nqe01","Type":"NodeParagraph","Properties":{"id":"20231024083225-29nqe01","updated":"20231024083225"},"Children":[{"Type":"NodeText","Data":"调周期（即使调频率）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"占空比 = 高电平 / 周期"}]}]},{"ID":"20231024083226-gyf2eye","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083226-gyf2eye","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"注意"}]},{"ID":"20231024083227-zd5g1up","Type":"NodeBlockquote","Properties":{"id":"20231024083227-zd5g1up","updated":"20231024083227"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083228-uhrqy7d","Type":"NodeParagraph","Properties":{"id":"20231024083228-uhrqy7d","updated":"20231024083228"},"Children":[{"Type":"NodeText","Data":"STM32F103ZET6的led灯分别为PB5和PE5"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"通过手册可以知道其中只有PB5支持重定义功能 即本节的定时器控制PWM功能 即TIM3_CH2"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"并且在初始化定时器PWM时必须要使能复用功能模块以及定时器部分重映射"}]}]},{"ID":"20231024083229-025zf4m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083229-025zf4m","updated":"20231024083229"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"GPIO_PinRemapConfig(GPIO_PartialRemap_TIM3, ENABLE); //Timer3部分重映射 TIM3_CH2-\u003ePB5\nRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083230-y1419af","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083230-y1419af","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"代码"}]},{"ID":"20231024083231-0jlh9h9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083231-0jlh9h9","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.h"}]},{"ID":"20231024083232-wiqzmn8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083232-wiqzmn8","updated":"20231024083232"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM3_H__\n#define __BSP_TIM3_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM3_PWM_Configuration(void);\nvoid TIM3_BaseConfiguration(void);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083233-rojlem3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083233-rojlem3","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.c"}]},{"ID":"20231024083234-oe9j3ed","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083234-oe9j3ed","updated":"20231024083234"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_tim3.h\"\n\nunsigned int times3 = 0;\n\nvoid TIM3_BaseConfiguration(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\t\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3, ENABLE);\n\t\n\tNVIC_InitStructure.NVIC_IRQChannel = TIM3_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\t\n\t//period 和 prescaler 都是1 不是0 因为除数不能为0\n\tTIM_TimeBaseStructure.TIM_Period = 999; //周期 计多少数 看挂载在哪个总线上就是多少频率 72MHZ/72分频=1M\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\tTIM_ClearFlag(TIM3, TIM_FLAG_Update);//清除标志位\n\tTIM_ITConfig(TIM3, TIM_IT_Update, ENABLE);//中断使能\n\tTIM_Cmd(TIM3, ENABLE);\n\t//暂时先关闭TIM3时钟，等全部初始化结束后正式使用定时器前再开启\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3, ENABLE);\n}\n\nvoid TIM3_IRQHandler(void){\n\tif(TIM_GetITStatus(TIM3, TIM_IT_Update) == SET){\n\t\ttimes3++;\n\t\tif(times3 == 500){\n\t\t\tLED_TOGGLE_B;\n\t\t\ttimes3 = 0;\n\t\t}\n\t\tTIM_ClearITPendingBit(TIM3, TIM_IT_Update);//清除中断标志位\n\t}\n}\n\nvoid TIM3_PWM_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\tTIM_OCInitTypeDef TIM_OCInitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3,ENABLE);\n\t\n\tGPIO_PinRemapConfig(GPIO_PartialRemap_TIM3, ENABLE); //Timer3部分重映射 TIM3_CH2-\u003ePB5 \n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_5;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//复用推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);\n\n\t//设置定时器\n\tTIM_TimeBaseStructure.TIM_Period = 1999; //周期 72MHZ/72分频=1M 如果分频72的话这里period写多少就是多少ms\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\t//设置pwm\n\tTIM_OCInitStructure.TIM_OCMode = TIM_OCMode_PWM1;//PWM模式1中，计数器的值小于CCRx时，通道是有效的，否则是无效的\n\tTIM_OCInitStructure.TIM_OCPolarity = TIM_OCPolarity_High;//设置PWM的有效状态为高电平\n\tTIM_OCInitStructure.TIM_OutputState = TIM_OutputState_Enable;//比较输出使能\n\tTIM_OC2Init(TIM3, \u0026TIM_OCInitStructure);//根据T指定的参数初始化外设TIM3 OC2 oc2是通道2的意思\n\tTIM_Cmd(TIM3, ENABLE);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083235-5e51u03","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083235-5e51u03","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083236-oiqif1l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083236-oiqif1l","updated":"20231024083236"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//pwm呼吸灯\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n\nint main(){\n\t\n\tint i;\n\n\tSysTick_Configuration();\n\t\n\tTIM3_PWM_Configuration();\n\t\n\twhile(1){\n\t\t\tfor(i = 0; i\u003c2000; i++){\n\t\t\t\tTIM_SetCompare2(TIM3, i);//2表示通道2 i越来越大表示灯越来越亮\n\t\t\t\tDelay_us(500);//0.5ms\n\t\t\t}\n\t\t\tfor(i = 2000; i\u003e0; i--){\n\t\t\t\tTIM_SetCompare2(TIM3, i);\n\t\t\t\tDelay_us(500);\n\t\t\t}\n\t\t}\n\t\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083237-hkgjrnz","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083237-hkgjrnz","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"PWM控制舵机"}]},{"ID":"20231024083238-3mevazd","Type":"NodeParagraph","Properties":{"id":"20231024083238-3mevazd","updated":"20231024083238"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694400778011-d82a2406-db0c-4916-93a7-0e928d4ccd84.png#averageHue=%23eff4b4\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=173\u0026id=u799c1753\u0026originHeight=190\u0026originWidth=242\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=37643\u0026status=done\u0026style=none\u0026taskId=u034a4df7-ebbf-4d00-acf4-b61e7bdacd3\u0026title=\u0026width=219.99999523162853","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083239-jcehcx3","Type":"NodeBlockquote","Properties":{"id":"20231024083239-jcehcx3","updated":"20231024083239"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083240-uban00l","Type":"NodeParagraph","Properties":{"id":"20231024083240-uban00l","updated":"20231024083240"},"Children":[{"Type":"NodeText","Data":"舵机的工作周期时20ms"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"比如要转45度 那占空比就是设置 1.0ms/20ms"}]}]},{"ID":"20231024083241-7k9n2aa","Type":"NodeParagraph","Properties":{"id":"20231024083241-7k9n2aa","updated":"20231024083241"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694412490484-81300ae1-f6c1-4771-8340-7be62ae2a465.png#averageHue=%23f5f4f3\u0026clientId=u742c219a-d4db-4\u0026from=paste\u0026height=684\u0026id=u708a230c\u0026originHeight=752\u0026originWidth=1002\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=147147\u0026status=done\u0026style=none\u0026taskId=ucb955db8-f2e1-4767-85bc-342067eca69\u0026title=\u0026width=910.9090711656685","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083242-mdf4yq0","Type":"NodeBlockquote","Properties":{"id":"20231024083242-mdf4yq0","updated":"20231024083242"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083243-gjutns9","Type":"NodeParagraph","Properties":{"id":"20231024083243-gjutns9","updated":"20231024083243"},"Children":[{"Type":"NodeText","Data":"注意：在进行重定义的时候要注意引脚在手册上是支持部分重定义还是全部重定义"}]}]},{"ID":"20231024083244-nnab6ck","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083244-nnab6ck","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.h"}]},{"ID":"20231024083245-2ge9xgo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083245-2ge9xgo","updated":"20231024083245"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM3_H__\n#define __BSP_TIM3_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM3_PWM_Configuration(void);\nvoid TIM3_BaseConfiguration(void);\nvoid TIM3_PWM_Servo_Configuration(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083246-d217dsx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083246-d217dsx","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.c"}]},{"ID":"20231024083247-7k2bq6i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083247-7k2bq6i","updated":"20231024083247"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"void TIM3_PWM_Servo_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\tTIM_OCInitTypeDef TIM_OCInitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOC, ENABLE);//PC07\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3,ENABLE);\n\t\n\tGPIO_PinRemapConfig(GPIO_FullRemap_TIM3, ENABLE); //Timer3全部重映射 TIM3_CH2-\u003ePB5 \n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//复用推挽输出\n\tGPIO_Init(GPIOC, \u0026GPIO_InitStructure);\n\n\t//设置定时器\n\tTIM_TimeBaseStructure.TIM_Period = 19999; //周期 计多少数 看挂载在哪个总线上就是多少频率 72MHZ/72分频=1M\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\t//设置pwm\n\tTIM_OCInitStructure.TIM_OCMode = TIM_OCMode_PWM1;//PWM模式1中，计数器的值小于CCRx时，通道是有效的，否则是无效的\n\tTIM_OCInitStructure.TIM_OCPolarity = TIM_OCPolarity_High;//设置PWM的有效状态为高电平\n\tTIM_OCInitStructure.TIM_OutputState = TIM_OutputState_Enable;//比较输出使能\n\tTIM_OC2Init(TIM3, \u0026TIM_OCInitStructure);//根据T指定的参数初始化外设TIM3 OC2 oc2是通道2的意思\n\tTIM_Cmd(TIM3, ENABLE);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083248-bbgimba","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083248-bbgimba","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083249-o4vumzr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083249-o4vumzr","updated":"20231024083249"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//pwm控制舵机\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n\nint main(){\n\t\n\tSysTick_Configuration();\n\t\n\tTIM3_PWM_Servo_Configuration();\n\t\n\twhile(1){\n\n\t\t\t\tTIM_SetCompare2(TIM3, 500);//0.5ms -- 0°\n\t\t\t\tDelay_us(1000000);//1s\n\t\t\n\t\t\t\tTIM_SetCompare2(TIM3, 1000);//1ms -- 45°\n\t\t\t\tDelay_us(1000000);//1s\n\t\t\n\t\t\t\tTIM_SetCompare2(TIM3, 1500);//1.5ms -- 90°\n\t\t\t\tDelay_us(1000000);//1s\n\n\t\t\t\tTIM_SetCompare2(TIM3, 2000);//2ms -- 135°\n\t\t\t\tDelay_us(1000000);//1s\n\t\t\n\t\t\t\tTIM_SetCompare2(TIM3, 2500);//2.5ms -- 180°\n\t\t\t\tDelay_us(1000000);//1s\n\t\t\t}\t\t\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083250-hkpt52b","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083250-hkpt52b","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"超声波"}]},{"ID":"20231024083251-trtbdbh","Type":"NodeParagraph","Properties":{"id":"20231024083251-trtbdbh","updated":"20231024083251"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694414366741-4e417927-b943-4b11-953a-44fb2aeec595.png#averageHue=%23edecdd\u0026clientId=u5b48a06e-b60f-4\u0026from=paste\u0026height=240\u0026id=u795d70c8\u0026originHeight=264\u0026originWidth=633\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=125359\u0026status=done\u0026style=none\u0026taskId=u8acf61bf-7fea-467c-a2b8-b95953e835f\u0026title=\u0026width=575.4545329819043","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083252-u01gr6c","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083252-u01gr6c","updated":"20231024083252"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"Trig（控制端）\nEcho（接收端）\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083253-omc4hpd","Type":"NodeParagraph","Properties":{"id":"20231024083253-omc4hpd","updated":"20231024083253"},"Children":[{"Type":"NodeText","Data":":::tips"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"控制逻辑："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"1.先给trig一个10us的高电平让超声波启动"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"2.echo等待检测信号 只要持续有高电平就一直让定时器计时（循环）直至检测到低电平"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"3. （(T2-T1)"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"340 m/s）/ 2"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":":::"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":":::tips"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"TIM_TimeBaseStructure.TIM_Period = 0xFFFF;定时器最大值为65535 所以65535"},{"Type":"NodeText","Data":"0.000001（us-\u003es）*340/2 = 11.14095m 计时器的理论最大测距距离 所以永远不会溢出"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":":::"}]},{"ID":"20231024083254-50m0r6l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083254-50m0r6l","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_hcsr04.h"}]},{"ID":"20231024083255-imjlovj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083255-imjlovj","updated":"20231024083255"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_HCSR04_H__\n#define __BSP_HCSR04_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n\n//PB6给出高电平\n#define TRIG_H GPIO_WriteBit(GPIOB, GPIO_Pin_6, Bit_SET)\n#define TRIG_L GPIO_WriteBit(GPIOB, GPIO_Pin_6, Bit_RESET)\n#define ECHO GPIO_ReadInputDataBit(GPIOB, GPIO_Pin_7)//读取电平\nvoid TIM3_Count_Configuration(void);\nvoid HCSR04_GPIO_Configuration(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083256-inp1xvd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083256-inp1xvd","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_hcsr04.c"}]},{"ID":"20231024083257-4exb9hw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083257-4exb9hw","updated":"20231024083257"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_hcsr04.h\"\n\n\nvoid TIM3_Count_Configuration(void){\n\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\t\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3, ENABLE);\n\t\n\t//period 和 prescaler 都是1 不是0 因为除数不能为0\n\t//period最大值为65535 所以65535*0.000001（us-\u003es）*340/2 = 11.14095m 计时器的理论最大测距距离 所以永远不会溢出\n\tTIM_TimeBaseStructure.TIM_Period = 0xFFFF; //周期 72MHZ/72分频=1M 记一个数需要1us\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\n\tTIM_Cmd(TIM3, ENABLE);\n\t//暂时先关闭TIM3时钟，等全部初始化结束后正式使用定时器前再开启\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3, DISABLE);\n\n}\n\n//PB6(OUTPUT):TRIG  PB7(INPUT):ECHO\nvoid HCSR04_GPIO_Configuration(void){\n\t\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//通用推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);\n\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//浮空\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083258-e32zwmh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083258-e32zwmh","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083259-72ve1n5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083259-72ve1n5","updated":"20231024083259"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//超声波\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n\nint main(){\n\tunsigned int time =0;\n\t\n\tfloat distance = 0.0;\n\t\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\t\n\tTIM3_Count_Configuration();\n\t\n\tHCSR04_GPIO_Configuration();\n\t\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3, ENABLE);//开启时钟使能gpiob\n\twhile(1){\n\t\tTIM_Cmd(TIM3, ENABLE);//每次启动打开定时器\n\t\tTRIG_H;//让trig保持10ms以上高电平\n\t\tDelay_us(15);\n\t\tTRIG_L;//切换为低电平\n\t\twhile(ECHO==0); //持续接收电平信号 直至ECHO接收到高电平\n\t\tTIM_SetCounter(TIM3,0);//让定时器3开始计数\n\t\twhile(ECHO==1);//只要高电平不变继续计数\n\t\tTIM_Cmd(TIM3, DISABLE);//关闭定时器\n\t\ttime = TIM_GetCounter(TIM3);\n\t\t//单位是cm(time*0.034)/2\n\t\tdistance = time*0.017;\n\t\tprintf(\"Distance =  %.2f cm\\n\",distance);\n\t\tDelay_us(1000000);\n\t} \n\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083260-smm9hi1","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083260-smm9hi1","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"自定义UART数据格式"}]},{"ID":"20231024083261-qtsn7wd","Type":"NodeBlockquote","Properties":{"id":"20231024083261-qtsn7wd","updated":"20231024083261"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083262-3uvu8lb","Type":"NodeParagraph","Properties":{"id":"20231024083262-3uvu8lb","updated":"20231024083262"},"Children":[{"Type":"NodeText","Data":"1.CPU和CPU之间"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"2.外设和CPU之间"}]}]},{"ID":"20231024083263-l4lxyw9","Type":"NodeBlockquote","Properties":{"id":"20231024083263-l4lxyw9","updated":"20231024083263"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083264-zdmws54","Type":"NodeParagraph","Properties":{"id":"20231024083264-zdmws54","updated":"20231024083264"},"Children":[{"Type":"NodeText","Data":"LED：在串口调试助手上发送一串数据，来控制4个LED灯"}]}]},{"ID":"20231024083265-sbdks64","Type":"NodeBlockquote","Properties":{"id":"20231024083265-sbdks64","updated":"20231024083265"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083266-3ia9cb8","Type":"NodeParagraph","Properties":{"id":"20231024083266-3ia9cb8","updated":"20231024083266"},"Children":[{"Type":"NodeText","Data":"数据格式："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"起始位 数据位1（灯的编号） \t\t数据位1（灯的状态）\t\t校验位 \t\t\t停止位"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"0xaa    01/02/03/04\t\t\t00/01\t\t\t\t\t数据位1+数据位2\t0xff"}]}]},{"ID":"20231024083267-62hvano","Type":"NodeBlockquote","Properties":{"id":"20231024083267-62hvano","updated":"20231024083267"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083268-qbnw6ex","Type":"NodeParagraph","Properties":{"id":"20231024083268-qbnw6ex","updated":"20231024083268"},"Children":[{"Type":"NodeText","Data":"例如："},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"LED1点亮：aa 01 01 02 ff（02是01+01）"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"LED1熄灭：aa 01 00 01 ff"}]}]},{"ID":"20231024083269-l73im9j","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083269-l73im9j","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694603171629-4e7ba26a-6c5c-4b43-9517-175abe607ff6.png#averageHue=%23efefef\u0026clientId=u9ccb61ce-49d2-4\u0026from=paste\u0026height=394\u0026id=u61085fd3\u0026originHeight=433\u0026originWidth=546\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=26722\u0026status=done\u0026style=none\u0026taskId=ufec15122-62ab-4f79-aa1c-dad50cf50ee\u0026title=\u0026width=496.3636256052445","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083270-y1ww65m","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083270-y1ww65m","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.h"}]},{"ID":"20231024083271-abmql9f","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083271-abmql9f","updated":"20231024083271"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_UART_H__\n#define __BSP_UART_H__\n\n\n#include \"bsp_SysTick.h\"\n#include \"stm32f10x.h\"\n\n#include \"stm32f10x_usart.h\"\n#include \"stdio.h\"\n\n#include \"core_cm3.h\"\n\nvoid Uart1_Configuration(void);\nvoid USART_SendString(const unsigned char *pt);\nvoid Uart1_NVIC_Init(void);\nvoid SetSysClock_to_72MHZ(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083272-x4x936t","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083272-x4x936t","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083273-vxjjwyj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083273-vxjjwyj","updated":"20231024083273"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//接收端注意要使用浮空状态\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_ITConfig(USART1, USART_IT_RXNE, ENABLE);//USART中断 第二个参数是要打开哪一类中断 这里是接收中断\n\tUSART_Cmd(USART1,ENABLE);\n}\n\nvoid Uart1_NVIC_Init(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);\n\tNVIC_InitStructure.NVIC_IRQChannel = USART1_IRQn; \n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 1;\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n}\n\n\nvoid USART_SendString(const unsigned char *pt){\n\twhile(*pt){\n\t\t//如果缓冲区发送完数据就变为空 即SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\t\tUSART_SendData(USART1, *pt);\n\t\t//如果发送完成就为空 SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\t\tpt++;\n\t}\n}\n\n//重定向printf\nint fputc(int c, FILE *fp){\n\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\tUSART_SendData(USART1, c);\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\treturn 0;\n}\n\n//重定向fget\nint fgetc(FILE *fp){\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) != SET);\n\treturn (int)USART_ReceiveData(USART1);\n}\n\n//void USART1_IRQHandler(void){\n//\tunsigned char ch;\n//\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n//\t\tch = USART_ReceiveData(USART1);\n//\t\tprintf(\"%c\\n\", ch + 1);\n//\t}\n//}\n\nvoid control_LED(unsigned int LED_number, unsigned int status){\n\t//1\u003c\u003cLED_number表示gpio几，因为pin2就表示1左移两位，BitAction是电平set的枚举类型\n\t//GPIO_WriteBit(GPIOB, (uint16_t)1\u003c\u003cLED_number, (BitAction)status);\n\tswitch(LED_number){\n\t\tcase 0x01:\n\t\tGPIO_WriteBit(GPIOB, GPIO_Pin_5, (BitAction)status);//注意stm32自带的两个灯是低电平点亮\n\t\t\tbreak;\n\t\tcase 0x02:\n\t\t\tGPIO_WriteBit(GPIOE, GPIO_Pin_5, (BitAction)status);\n\t\t\tbreak;\n\t}\n\t\n}\n\nvoid USART1_IRQHandler(void){\n\t\n//使用static即使是局部变量也会在全局生效 并且第一次生效后之后再进函数再也不会初始化 00000\n\tstatic unsigned int arr[5] = {0,0,0,0,0};\n\tstatic unsigned int flag = 0;\n\tstatic unsigned int i = 1;\n\tunsigned char ch;\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n\n\t\tch = USART_ReceiveData(USART1);\n\n\t\tif(ch == 0xaa){//必须要从接收到起始位才开始分析数据\n\t\t\tarr[0] = ch;//第一位为起始位\n\t\t\tflag = 1;//将标志位置1\n\t\t\t\n\t\t}\n\t\tif(ch != 0xaa \u0026\u0026 flag == 1){//如果接收到的数据不是起始位并且标志位置1了\n\t\t\tarr[i++] = ch;//接收数据\n\t\t\tif(i == 5){\n\t\t\t\tflag = 0;\n\t\t\t\ti = 1;\n\t\t\t\tif(((arr[i]+arr[2]) == arr[3]) \u0026\u0026 (arr[4] == 0xff)){\n\n\t\t\t\t\t\tcontrol_LED(arr[1], arr[2]);\n\t\t\t\t\t\tprintf(\"1\");//测试串口助手是否接收到\n\t\t\t\t\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t}\n\n\t\n}\n\n\n\n//这是自带时钟频率驱动至72MHZ的函数 只是将函数名改变了 为了避免有影响\nvoid SetSysClock_to_72MHZ(void)\n{\n  __IO uint32_t StartUpCounter = 0, HSEStatus = 0;\n  \n  /* SYSCLK, HCLK, PCLK2 and PCLK1 configuration ---------------------------*/    \n  /* Enable HSE */    \n  RCC-\u003eCR |= ((uint32_t)RCC_CR_HSEON);\n \n  /* Wait till HSE is ready and if Time out is reached exit */\n  do\n  {\n    HSEStatus = RCC-\u003eCR \u0026 RCC_CR_HSERDY;\n    StartUpCounter++;  \n  } while((HSEStatus == 0) \u0026\u0026 (StartUpCounter != HSE_STARTUP_TIMEOUT));\n\n  if ((RCC-\u003eCR \u0026 RCC_CR_HSERDY) != RESET)\n  {\n    HSEStatus = (uint32_t)0x01;\n  }\n  else\n  {\n    HSEStatus = (uint32_t)0x00;\n  }  \n\n  if (HSEStatus == (uint32_t)0x01)\n  {\n    /* Enable Prefetch Buffer */\n    FLASH-\u003eACR |= FLASH_ACR_PRFTBE;\n\n    /* Flash 2 wait state */\n    FLASH-\u003eACR \u0026= (uint32_t)((uint32_t)~FLASH_ACR_LATENCY);\n    FLASH-\u003eACR |= (uint32_t)FLASH_ACR_LATENCY_2;    \n\n \n    /* HCLK = SYSCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_HPRE_DIV1;\n      \n    /* PCLK2 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE2_DIV1;\n    \n    /* PCLK1 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE1_DIV2;\n\n#ifdef STM32F10X_CL\n    /* Configure PLLs ------------------------------------------------------*/\n    /* PLL2 configuration: PLL2CLK = (HSE / 5) * 8 = 40 MHz */\n    /* PREDIV1 configuration: PREDIV1CLK = PLL2 / 5 = 8 MHz */\n        \n    RCC-\u003eCFGR2 \u0026= (uint32_t)~(RCC_CFGR2_PREDIV2 | RCC_CFGR2_PLL2MUL |\n                              RCC_CFGR2_PREDIV1 | RCC_CFGR2_PREDIV1SRC);\n    RCC-\u003eCFGR2 |= (uint32_t)(RCC_CFGR2_PREDIV2_DIV5 | RCC_CFGR2_PLL2MUL8 |\n                             RCC_CFGR2_PREDIV1SRC_PLL2 | RCC_CFGR2_PREDIV1_DIV5);\n  \n    /* Enable PLL2 */\n    RCC-\u003eCR |= RCC_CR_PLL2ON;\n    /* Wait till PLL2 is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLL2RDY) == 0)\n    {\n    }\n    \n   \n    /* PLL configuration: PLLCLK = PREDIV1 * 9 = 72 MHz */ \n    RCC-\u003eCFGR \u0026= (uint32_t)~(RCC_CFGR_PLLXTPRE | RCC_CFGR_PLLSRC | RCC_CFGR_PLLMULL);\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLXTPRE_PREDIV1 | RCC_CFGR_PLLSRC_PREDIV1 | \n                            RCC_CFGR_PLLMULL9); \n#else    \n    /*  PLL configuration: PLLCLK = HSE * 9 = 72 MHz */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_PLLSRC | RCC_CFGR_PLLXTPRE |\n                                        RCC_CFGR_PLLMULL));\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLSRC_HSE | RCC_CFGR_PLLMULL9);\n#endif /* STM32F10X_CL */\n\n    /* Enable PLL */\n    RCC-\u003eCR |= RCC_CR_PLLON;\n\n    /* Wait till PLL is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLLRDY) == 0)\n    {\n    }\n    \n    /* Select PLL as system clock source */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_SW));\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_SW_PLL;    \n\n    /* Wait till PLL is used as system clock source */\n    while ((RCC-\u003eCFGR \u0026 (uint32_t)RCC_CFGR_SWS) != (uint32_t)0x08)\n    {\n    }\n  }\n  else\n  { /* If HSE fails to start-up, the application will have wrong clock \n         configuration. User can add here some code to deal with this error */\n  }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083274-vweqp2n","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083274-vweqp2n","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083275-0nho64k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083275-0nho64k","updated":"20231024083275"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//自定义uart\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n\nint main(){\n\n\tSysTick_Configuration();\n\t\n\tLed_Configuration();\n\t\n\tUart1_Configuration();\n\n\tUart1_NVIC_Init();\n\n\twhile(1){\n\n\t} \n\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083276-c0hhlsh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20231024083276-c0hhlsh","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"串口通信舵机"}]},{"ID":"20231024083277-rvnlywu","Type":"NodeBlockquote","Properties":{"id":"20231024083277-rvnlywu","updated":"20231024083277"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083278-sumvhzn","Type":"NodeParagraph","Properties":{"id":"20231024083278-sumvhzn","updated":"20231024083278"},"Children":[{"Type":"NodeText","Data":"只需要在规定的协议帧中定义方法就可以"}]}]},{"ID":"20231024083279-p99bswn","Type":"NodeParagraph","Properties":{"id":"20231024083279-p99bswn","updated":"20231024083279"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694602747800-9febd955-86c7-4e8a-90d3-2b899c1872a7.png#averageHue=%23fcfbfa\u0026clientId=u9ccb61ce-49d2-4\u0026from=paste\u0026height=367\u0026id=u913b91b5\u0026originHeight=404\u0026originWidth=616\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=26823\u0026status=done\u0026style=none\u0026taskId=u4d712170-9b88-4051-bf10-2b90315a50b\u0026title=\u0026width=559.9999878623271","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083280-gxtlobr","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083280-gxtlobr","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"无源蜂鸣器"}]},{"ID":"20231024083281-8a1ueq1","Type":"NodeBlockquote","Properties":{"id":"20231024083281-8a1ueq1","updated":"20231024083281"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083282-smn6gv7","Type":"NodeParagraph","Properties":{"id":"20231024083282-smn6gv7","updated":"20231024083282"},"Children":[{"Type":"NodeText","Data":"源指的是震荡源 有源蜂鸣器只有一种声音"}]}]},{"ID":"20231024083283-tlu92tm","Type":"NodeBlockquote","Properties":{"id":"20231024083283-tlu92tm","updated":"20231024083283"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083284-s2k9usu","Type":"NodeParagraph","Properties":{"id":"20231024083284-s2k9usu","updated":"20231024083284"},"Children":[{"Type":"NodeText","Data":"无源蜂鸣器无内部驱动和震荡电路 通过信号输出声音 改变频率"}]}]},{"ID":"20231024083285-l1m6bgs","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083285-l1m6bgs","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.h"}]},{"ID":"20231024083286-gwqk2o5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083286-gwqk2o5","updated":"20231024083286"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM3_H__\n#define __BSP_TIM3_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM3_PWM_Configuration(void);\nvoid TIM3_BaseConfiguration(void);\nvoid TIM3_PWM_Servo_Configuration(void);\nvoid TIM3_PWM_Video_Configuration(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083287-r92gs7l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083287-r92gs7l","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.c"}]},{"ID":"20231024083288-iu5wddx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083288-iu5wddx","updated":"20231024083288"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"void TIM3_PWM_Video_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\tTIM_OCInitTypeDef TIM_OCInitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOC, ENABLE);//PC07\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3,ENABLE);\n\t\n\tGPIO_PinRemapConfig(GPIO_FullRemap_TIM3, ENABLE); //Timer3全部重映射 TIM3_CH2-\u003ePB7 \n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//复用推挽输出\n\tGPIO_Init(GPIOC, \u0026GPIO_InitStructure);\n\n\t//设置定时器\n\tTIM_TimeBaseStructure.TIM_Period = 999; //周期 1KHZ\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\t//设置pwm\n\tTIM_OCInitStructure.TIM_OCMode = TIM_OCMode_PWM1;//PWM模式1中，计数器的值小于CCRx时，通道是有效的，否则是无效的\n\tTIM_OCInitStructure.TIM_OCPolarity = TIM_OCPolarity_High;//设置PWM的有效状态为高电平\n\tTIM_OCInitStructure.TIM_Pulse = 500;//翻转值 占空比一半 所以只需要周期的一半 占空比50%的方波\n\tTIM_OCInitStructure.TIM_OutputState = TIM_OutputState_Enable;//比较输出使能\n\tTIM_OC2Init(TIM3, \u0026TIM_OCInitStructure);//根据T指定的参数初始化外设TIM3 OC2 oc2是通道2的意思\n\tTIM_Cmd(TIM3, ENABLE);\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083289-wypu5k2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083289-wypu5k2","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083290-bo5dwr9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083290-bo5dwr9","updated":"20231024083290"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//蜂鸣器\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n\nint main(){\n\n\tSysTick_Configuration();\n\n\tTIM3_PWM_Video_Configuration();\n\twhile(1){\n\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083291-9lkzhde","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083291-9lkzhde","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"SPI"}]},{"ID":"20231024083292-3sm6tze","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083292-3sm6tze","updated":"20231024083292"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"spi：串行外围设备接口\n高速、全双工、同步的通信总线\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083293-ywsb76y","Type":"NodeParagraph","Properties":{"id":"20231024083293-ywsb76y","updated":"20231024083293"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694605578110-0920ccc5-6dfb-48af-87cf-ac945a9e38d4.png#averageHue=%23ece7de\u0026clientId=u9ccb61ce-49d2-4\u0026from=paste\u0026height=411\u0026id=u0929e574\u0026originHeight=452\u0026originWidth=882\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=327363\u0026status=done\u0026style=none\u0026taskId=u4317de1c-78f5-4a88-97da-a42c4ceb259\u0026title=\u0026width=801.8181644392412","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083294-n7z1jx6","Type":"NodeBlockquote","Properties":{"id":"20231024083294-n7z1jx6","updated":"20231024083294"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083295-bgqjkai","Type":"NodeParagraph","Properties":{"id":"20231024083295-bgqjkai","updated":"20231024083295"},"Children":[{"Type":"NodeText","Data":"类似上课提问  老师叫张三回答问题 所有从机都能听见 但只有张三片选回答问题"}]}]},{"ID":"20231024083296-1edkeqy","Type":"NodeParagraph","Properties":{"id":"20231024083296-1edkeqy","updated":"20231024083296"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1694606487896-ebb271a0-b4f0-472b-8050-f521200ad8ff.png#averageHue=%23eeeae8\u0026clientId=u9ccb61ce-49d2-4\u0026from=paste\u0026height=175\u0026id=u990a0818\u0026originHeight=192\u0026originWidth=829\u0026originalType=binary\u0026ratio=1.100000023841858\u0026rotation=0\u0026showTitle=false\u0026size=32882\u0026status=done\u0026style=none\u0026taskId=u20c602d2-9b2e-468a-9c39-3126e6b5e40\u0026title=\u0026width=753.6363473017357","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083297-jtct72s","Type":"NodeBlockquote","Properties":{"id":"20231024083297-jtct72s","updated":"20231024083297"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083298-ty9cmyl","Type":"NodeParagraph","Properties":{"id":"20231024083298-ty9cmyl","updated":"20231024083298"},"Children":[{"Type":"NodeText","Data":"分别代表spi的四个管脚 cs片选 sck时钟 miso主输入从输出 mosi主输出从输入"}]}]},{"ID":"20231024083299-z40n2h0","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083299-z40n2h0","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"定时器输入捕获"}]},{"ID":"20231024083300-h3kwhmy","Type":"NodeBlockquote","Properties":{"id":"20231024083300-h3kwhmy","updated":"20231024083300"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083301-8jiv83b","Type":"NodeParagraph","Properties":{"id":"20231024083301-8jiv83b","updated":"20231024083301"},"Children":[{"Type":"NodeText","Data":"1.如何计算周期：连续两次上升沿的时间差就是周期"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"2.高电平时间：上升沿到下降沿的时间（不算低电平时间）"}]}]},{"ID":"20231024083302-tqsg4n1","Type":"NodeBlockquote","Properties":{"id":"20231024083302-tqsg4n1","updated":"20231024083302"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083303-jdh08ej","Type":"NodeParagraph","Properties":{"id":"20231024083303-jdh08ej","updated":"20231024083303"},"Children":[{"Type":"NodeText","Data":"频率+周期（周期即计数上限）"}]}]},{"ID":"20231024083304-chd8ne3","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083304-chd8ne3","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim2.h"}]},{"ID":"20231024083305-w295e7z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083305-w295e7z","updated":"20231024083305"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM2_H__\n#define __BSP_TIM2_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM2_PWM_Configuration(void);\nvoid TIM2_BaseConfiguration(void);\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083306-ku2e0mv","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083306-ku2e0mv","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim2.c"}]},{"ID":"20231024083307-btux3ao","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083307-btux3ao","updated":"20231024083307"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"void TIM2_PWM_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\tTIM_OCInitTypeDef TIM_OCInitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2,ENABLE);\n\t\n\tGPIO_PinRemapConfig(GPIO_FullRemap_TIM2, ENABLE); //Timer2部分重映射 注意在文档手册中引脚一列如果有重定义功能都要重新这样写\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;//复用推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);\n\n\t//设置定时器\n\tTIM_TimeBaseStructure.TIM_Period = 19999; //周期 计多少数 看挂载在哪个总线上就是多少频率 72MHZ/72分频=1M\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM2, \u0026TIM_TimeBaseStructure);\n\t\n\t//设置pwm\n\tTIM_OCInitStructure.TIM_OCMode = TIM_OCMode_PWM1;//PWM模式1中，计数器的值小于CCRx时，通道是有效的，否则是无效的\n\tTIM_OCInitStructure.TIM_OCPolarity = TIM_OCPolarity_High;//设置PWM的有效状态为高电平\n\tTIM_OCInitStructure.TIM_OutputState = TIM_OutputState_Enable;//比较输出使能\n\tTIM_OC3Init(TIM2, \u0026TIM_OCInitStructure);//根据T指定的参数初始化外设TIM3 OC2 oc2是通道2的意思\n\tTIM_Cmd(TIM2, ENABLE);\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083308-d5dfjhz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083308-d5dfjhz","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.h"}]},{"ID":"20231024083309-921ei0e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083309-921ei0e","updated":"20231024083309"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TIM3_H__\n#define __BSP_TIM3_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\nvoid TIM3_PWM_Configuration(void);\nvoid TIM3_BaseConfiguration(void);\nvoid TIM3_PWM_Servo_Configuration(void);\nvoid TIM3_PWM_Video_Configuration(void);\nvoid TIM3_InputCaputure_Configuration(void);\nextern unsigned int high_value;\nextern unsigned char high_complete_flag;\nextern unsigned int period_times;\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083310-7ao43s1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083310-7ao43s1","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim3.c"}]},{"ID":"20231024083311-vhgurz9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083311-vhgurz9","updated":"20231024083311"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"void TIM3_InputCaputure_Configuration(void){//输出捕获\n\t\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\tTIM_ICInitTypeDef TIM_ICInitStructure;\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOC, ENABLE);//PC06\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_AFIO, ENABLE);  //使能AFIO复用功能模块时钟\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM3,ENABLE);\n\t\t\n\tGPIO_PinRemapConfig(GPIO_FullRemap_TIM3, ENABLE); //Timer3全部重映射 TIM3_CH2-\u003ePC7 这个很重要\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//复用推挽输出\n\tGPIO_Init(GPIOC, \u0026GPIO_InitStructure);\n\n\tTIM_TimeBaseStructure.TIM_Period = 0xFFFF; //当前测量的单次测量的最大周期是65535 1KHZ 20ms\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//TIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM3, \u0026TIM_TimeBaseStructure);\n\t\n\tTIM_ICInitStructure.TIM_Channel = TIM_Channel_1;\n\tTIM_ICInitStructure.TIM_ICPolarity = TIM_ICPolarity_Rising;//用于捕获上升沿还是下降沿\n\tTIM_ICInitStructure.TIM_ICSelection = TIM_ICSelection_DirectTI;//输入是直接从TIx（即，定时器的输入通道，如TI1，TI2等）如果是indirect选择TI1将从TI2接收\n\tTIM_ICInitStructure.TIM_ICPrescaler = TIM_ICPSC_DIV1;//捕获每探测到一个边沿执行一次 DIV4就是4个事件执行一次\n\tTIM_ICInitStructure.TIM_ICFilter = 0x00;//输入滤波器 前几个脉冲不要 因为前几个可能有误差 0x00就表示一个都不滤过\n\tTIM_ICInit(TIM3, \u0026TIM_ICInitStructure);\n\t\n//\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);\n\tNVIC_InitStructure.NVIC_IRQChannel = TIM3_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\t\n\tTIM_ClearFlag(TIM3, TIM_FLAG_CC1|TIM_IT_Update);//输入捕获电平跳变的标志位\n\tTIM_ITConfig(TIM3, TIM_FLAG_CC1|TIM_IT_Update, ENABLE);//TIM_IT_Update防止溢出\n\tTIM_Cmd(TIM3, ENABLE);\n}\n\n//定时器捕获\nvoid TIM3_IRQHandler(void){\n\tstatic unsigned char high_flag = 0;\n\n\tif(high_complete_flag == 0){\n\t\t\tif(TIM_GetITStatus(TIM3, TIM_IT_Update) == SET){\n\t\t\t\tif(high_flag == 1){\n\t\t\t\t\tperiod_times++;\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(TIM_GetITStatus(TIM3, TIM_FLAG_CC1) == SET){\n\t\t\t\t\tif(high_flag == 0){\n\t\t\t\t\t\tTIM_SetCounter(TIM3, 0);\n\t\t\t\t\t\thigh_flag = 1;\n\t\t\t\t\t\thigh_value = 0;\n\t\t\t\t\t\tTIM_OC1PolarityConfig(TIM3, TIM_OCPolarity_Low);//改变极性\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\telse{\n\t\t\t\t\thigh_value = TIM_GetCounter(TIM3);\n\t\t\t\t\tTIM_OC1PolarityConfig(TIM3, TIM_OCPolarity_High);\n\t\t\t\t\thigh_flag = 0;\n\t\t\t\t\thigh_complete_flag = 1;\n\t\t\t}\n\t\t}\n\t}\n\t\tTIM_ClearITPendingBit(TIM3, TIM_FLAG_CC1 | TIM_IT_Update);//清除中断标志位\n\t\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083312-pd4934o","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083312-pd4934o","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083313-1oiv9sr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083313-1oiv9sr","updated":"20231024083313"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"int main(){\n\n\tSysTick_Configuration();\n\tUart1_Configuration();\n\t\n\tTIM2_PWM_Configuration();\n\t\n\tTIM3_InputCaputure_Configuration();\n\t\n\n\tTIM_SetCompare3(TIM2, 10000);//占空比50% 10ms高电平时间 因为分频72 计数周期19999 所以计算下来是20ms一个周期 所以10ms是50%占空比\n\twhile(1){\n\n\t\tif(high_complete_flag == 1){\n\n\t\t\tprintf(\"hign level = %d us \\n\",period_times*65535+high_value);//period是为了计算溢出的计数量 如果不溢出就是0\n\t\t\thigh_complete_flag = 0;\n\t\t\tperiod_times = 0;\n\t\t}\n\t\tDelay_us(100000);\n\t} \n\n}\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083314-wu9p14s","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083314-wu9p14s","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"数码管"}]},{"ID":"20231024083315-tg5e5z9","Type":"NodeBlockquote","Properties":{"id":"20231024083315-tg5e5z9","updated":"20231024083315"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083316-31swqlm","Type":"NodeParagraph","Properties":{"id":"20231024083316-31swqlm","updated":"20231024083316"},"Children":[{"Type":"NodeText","Data":"共阴 高电平点亮"},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"共阳 低电平点亮"}]}]},{"ID":"20231024083317-21mc2px","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083317-21mc2px","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_digitalDisplay.h"}]},{"ID":"20231024083318-hh9z8zw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083318-hh9z8zw","updated":"20231024083318"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_digitalDisplay.h\"\nextern unsigned int Number[];\nunsigned int Number[]=\n{   \n\t0xc0,//0\n\t0xf9,//1\n\t0xa4,//2\n\t0xb0,//3\n\t0x99,//4\n\t0x92,//5\n\t0x82,//6\n\t0xf8,//7\n\t0x80,//8\n\t0x90,//9\n\t0x88,//A\n\t0x83,//B\n\t0xc6,//C\n\t0xa1,//D\n\t0x86,//E\n\t0x8e, //F\n\t0x00, //全亮\n\t0xff  //熄灭\n};\n//SCLK:PB13 RCLK:PB12 DIO:PB15\nvoid HC595_GPIO_Configuration(void){\n\t\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_12|GPIO_Pin_13|GPIO_Pin_15;\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//通用推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);\n\t\n\tGPIO_WriteBit(GPIOB,GPIO_Pin_12, Bit_RESET);\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_13, Bit_RESET);\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_15, Bit_RESET);\n}\n\n//串入\nvoid HC595_Send_Byte(unsigned char byte){\n//写入八位数据 需要看手册先压入的是高位还是低位\n\t\tunsigned int i;\n\t\n\tfor(i = 0; i \u003c 8; i++){\n\t\t\tif(byte \u0026 0x80){//看当前位是 不是高电平 如果是高电平就是有数据 要写入\n\t\t\t\tGPIO_WriteBit(GPIOB, GPIO_Pin_15, Bit_SET);\n\t\t\t}else{\n\t\t\t\tGPIO_WriteBit(GPIOB, GPIO_Pin_15, Bit_RESET);\n\t\t\t}\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_13, Bit_RESET);\n\t\tDelay_us(10);\n\t\tGPIO_WriteBit(GPIOB,GPIO_Pin_13, Bit_SET);\n\t\tDelay_us(10);\n\t\t\t\n\t\t\tbyte\u003c\u003c=1;\n\t}\n}\n\n//并出\nvoid HC595_Send_Data(unsigned char num, unsigned char show_bit){\n\t\t\n\tHC595_Send_Byte(num);//要显示的数字\n\tHC595_Send_Byte(1 \u003c\u003c show_bit);//数码管选择 3: 0000 1000 \n\t\n\t//低电平到高电平使能RCLK\n\tGPIO_WriteBit(GPIOB,GPIO_Pin_12, Bit_RESET);\n\tDelay_us(10);\n\tGPIO_WriteBit(GPIOB,GPIO_Pin_12, Bit_SET);\n\tDelay_us(10);\n\t\n}\n\nvoid display(unsigned int n){\n\tstatic unsigned int thousand_bit, hundred_bit, ten_bit, single_bit;\n\t\n\tthousand_bit = n / 1000;\n\thundred_bit = (n%1000) / 100;\n\tten_bit = n % 1000 % 100 /10;\n\tsingle_bit = n % 10;\n\t\n\tHC595_Send_Data(Number[thousand_bit], 3);\n\tHC595_Send_Data(Number[hundred_bit], 2);\n\tHC595_Send_Data(Number[ten_bit], 1);\n\tHC595_Send_Data(Number[single_bit], 0);\n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083319-d26ym96","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083319-d26ym96","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_digitalDisplay.c"}]},{"ID":"20231024083320-ymm7o46","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083320-ymm7o46","updated":"20231024083320"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_DIGITALDISPLAY_H__\n#define __BSP_DIGITALDISPLAY_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n\n\nvoid HC595_GPIO_Configuration(void);\nvoid HC595_Send_Data(unsigned char num, unsigned char show_bit);\nvoid HC595_Send_Byte(unsigned char byte);\n\nvoid display(unsigned int n);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083321-scxaj6s","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083321-scxaj6s","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tim2.c"}]},{"ID":"20231024083322-psfgw8u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083322-psfgw8u","updated":"20231024083322"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_tim2.h\"\n\nunsigned int times = 0;\nextern unsigned int count;\nvoid TIM2_BaseConfiguration(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\tTIM_TimeBaseInitTypeDef TIM_TimeBaseStructure;\n\t\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);\n\t\n\tNVIC_InitStructure.NVIC_IRQChannel = TIM2_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\t\n\t//period 和 prescaler 都是1 不是0 因为除数不能为0\n\tTIM_TimeBaseStructure.TIM_Period = 999; //周期 计多少数 看挂载在哪个总线上就是多少频率 72MHZ/72分频=1M\n\tTIM_TimeBaseStructure.TIM_Prescaler = 71;\n//\tTIM_TimeBaseStructure.TIM_ClockDivision = ; 时钟分割\n\tTIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;//向上或向下计数\n\tTIM_TimeBaseInit(TIM2, \u0026TIM_TimeBaseStructure);\n\t\n\tTIM_ClearFlag(TIM2, TIM_FLAG_Update);//清除标志位\n\tTIM_ITConfig(TIM2, TIM_IT_Update, ENABLE);//中断使能\n\tTIM_Cmd(TIM2, ENABLE);\n\t//暂时先关闭TIM2时钟，等全部初始化结束后正式使用定时器前再开启\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);\n}\n\nvoid TIM2_IRQHandler(void){\n\tif(TIM_GetITStatus(TIM2, TIM_IT_Update) == SET){\n\t\ttimes++;\n\t\tif(times == 1000){\n//\t\t\tLED_TOGGLE_B;\n\n//\t\t\ttimes = 0;\n\n\t\t\tcount++;\n\t\t\t\n\t\t\ttimes =0;\n\t\t}\n\t\tTIM_ClearITPendingBit(TIM2, TIM_IT_Update);//清除中断标志位\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083323-9a50m04","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083323-9a50m04","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083324-8rkz194","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083324-8rkz194","updated":"20231024083324"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//数码管\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_digitalDisplay.h\"\n\nunsigned int count=0;\n\nint main()\n{\n\n\tSysTick_Configuration();\n\t\n\tHC595_GPIO_Configuration();\n\t\n//\tHC595_Send_Data(Number[2], 3);//三号数码管，最左侧显示数字2\n\n\tTIM2_BaseConfiguration();\n\n\twhile(1)\n\t{\t\n\t\tdisplay(count);\n\n//\t\tDelay_us(1000000);\n\t}\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083325-lirpmyn","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083325-lirpmyn","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"RTC系统时间"}]},{"ID":"20231024083326-bhl3mr3","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083326-bhl3mr3","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_rtc.h"}]},{"ID":"20231024083327-y7bnpr8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083327-y7bnpr8","updated":"20231024083327"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_RTC_H__\n#define __BSP_RTC_H__\n\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#define leapyear(a) ((a%4==0) \u0026\u0026 (a%100!=0) || (a%400 == 0))\n#define days_in_year(i) (leapyear(i) ? 366 : 365)\n\n\nint RTC_Configuration(void);\nvoid Time_Display(u32 TimeVal);\n\nstruct rtc_tm{\n\tunsigned int year;\n\tunsigned int month;\n\tunsigned int day;\n\tunsigned int hour;\n\tunsigned int minute;\n\tunsigned int second;\n};\n\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083328-vbxamdl","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083328-vbxamdl","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_rtc.c"}]},{"ID":"20231024083329-xz9undz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083329-xz9undz","updated":"20231024083329"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_rtc.h\"\n#include \u003cstdio.h\u003e\n\nunsigned int days_in_month[13] = {0,31,28,31,30,31,30,31,31,30,31,30,31};\nstruct rtc_tm tm;\nunsigned int time_counter = 0;\nunsigned int count=0;\nvoid Set_Time(void){\n\tunsigned int i;\n\t\n\tfor(i=1970; i\u003ctm.year; i++){\n\t\t\ttime_counter += days_in_year(i) * 86400;\n\t}\n\tif(leapyear(tm.year)){\n\t\tdays_in_month[2] = 29;\n\t}else{\n\t\tdays_in_month[2] = 28;\n\t}\n\tfor(i = 1; i \u003c tm.month; i++){\n\t\t\ttime_counter += days_in_month[i] * 86400;\t\n\t}\n\ttime_counter += (tm.day - 1) * 86400; \n\ttime_counter += tm.hour * 3600 + tm.minute * 60 +tm.second;\n\t\n\tRTC_SetCounter(time_counter);\n\t\n\n}\n\nint RTC_Configuration(void){\n\t//使能BKP PWR的外部时钟APB1\n\tRCC_APB1PeriphClockCmd(RCC_APB1Periph_BKP | RCC_APB1Periph_PWR, ENABLE);\n\tPWR_BackupAccessCmd(ENABLE);\n\n\tif(BKP_ReadBackupRegister(BKP_DR1) != 0xABCD){\n\t\tBKP_DeInit();//后备寄存器\n\t\tRCC_LSEConfig(RCC_LSE_ON);//启动外部低速时钟\n\t\twhile(RCC_GetFlagStatus(RCC_FLAG_LSERDY) == RESET);//判断当前低速时钟是否就绪\n\t\tRCC_RTCCLKConfig(RCC_RTCCLKSource_LSE);\n\t\tRCC_RTCCLKCmd(ENABLE);\n\t\tRTC_WaitForLastTask();//等待上一次写操作是否完成\n\t\tRTC_WaitForSynchro();//等待同步\n\t\tRTC_SetPrescaler(32767);//分频 起始值为1 所以是32768\n\t\tRTC_WaitForLastTask();//等待上一次写操作是否完成\n\t\t\n\t\tprintf(\"Please enter year:\\n\");\n\t\tcount++;\n\t\tUart1_scanf(\u0026tm.year, 4);\n\t\tprintf(\"year = %d\\n\", tm.year);\n\t\t\t\n\t\tprintf(\"Please enter month:\\n\");\n\t\tUart1_scanf(\u0026tm.month, 2);\n\t\tprintf(\"month = %d\\n\", tm.month);\n\t\tcount++;\n\t\tprintf(\"Please enter date:\\n\");\n\t\tUart1_scanf(\u0026tm.day, 2);\n\t\tprintf(\"date = %d\\n\", tm.day);\n\t\t\n\t\tprintf(\"Please enter hour:\\n\");\n\t\tUart1_scanf(\u0026tm.hour, 2);\n\t\tprintf(\"hour = %d\\n\", tm.hour);\n\t\t\n\t\tprintf(\"Please enter minute:\\n\");\n\t\tUart1_scanf(\u0026tm.minute, 2);\n\t\tprintf(\"minute = %d\\n\", tm.minute);\n\t\t\n\t\tprintf(\"Please enter second:\\n\");\n\t\tUart1_scanf(\u0026tm.second, 2);\n\t\tprintf(\"second = %d\\n\", tm.second);\n\t\t\n\t\tSet_Time();\n\t\t\n\t\tBKP_WriteBackupRegister(BKP_DR1, 0xABCD);\n\t\t\n\t\tRTC_WaitForLastTask();\n\t\t\n\t\treturn 0;\n\t}\n\telse{\n\t\treturn 1;\n\t\n\t}\n}\n\nvoid Time_Display(u32 TimeVal){\n\tstruct rtc_tm tm;\n\tunsigned int days,hms;\n\tunsigned int i,j;\n\t\n\tdays = TimeVal /86400;\n\thms = TimeVal % 86400;\n\t\n\ttm.hour = hms / 3600;\n\ttm.minute = (hms % 3600) / 60;\n\ttm.second = (hms % 3600) % 60;\n\t\n\tfor(i = 1970; days \u003e= days_in_year(i); i++){\n\t\tdays -= days_in_year(i);\n\t}\n\ttm.year = i;\n\n\tif(leapyear(i))\n\t\tdays_in_month[2] = 29;\n\telse\n\t\tdays_in_month[2] = 28;\n\tfor( j= 1; days \u003e= days_in_month[j]; j++)\n\t\tdays -= days_in_month[j];\n\ttm.month = j;\n\t\n\ttm.day = days+1;\n\t\n\tprintf(\"%d-%d-%d: %d:%d:%d\\n\", tm.year, tm.month, tm.day, tm.hour, tm.minute, tm.second);\n}\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083330-akexw67","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083330-akexw67","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_uart.c"}]},{"ID":"20231024083331-4az8js0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083331-4az8js0","updated":"20231024083331"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_uart.h\"\n\nvoid Uart1_Configuration(void){\n\tUSART_InitTypeDef USART_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA | RCC_APB2Periph_USART1, ENABLE);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;//TX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_PP;\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource9);\n\t\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_10;//RX\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN_FLOATING;//接收端注意要使用浮空状态\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource10);\n\t\n\tUSART_InitStructure.USART_BaudRate = 115200;//波特率\n\tUSART_InitStructure.USART_WordLength = USART_WordLength_8b;//数据位长度\n\tUSART_InitStructure.USART_StopBits = USART_StopBits_1;//停止位\n\tUSART_InitStructure.USART_Parity = USART_Parity_No;//奇偶位\n\tUSART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;//浮空 因为收发有高低电平不需要上下拉电阻\n\tUSART_InitStructure.USART_Mode = USART_Mode_Tx | USART_Mode_Rx;//收发\n\tUSART_Init(USART1, \u0026USART_InitStructure);\n\tUSART_ITConfig(USART1, USART_IT_RXNE, ENABLE);//USART中断 第二个参数是要打开哪一类中断 这里是接收中断\n\tUSART_Cmd(USART1,ENABLE);\n}\n\nvoid Uart1_NVIC_Init(void){\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\t\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);\n\tNVIC_InitStructure.NVIC_IRQChannel = USART1_IRQn; \n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 1;\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n}\n\n\nvoid USART_SendString(const unsigned char *pt){\n\twhile(*pt){\n\t\t//如果缓冲区发送完数据就变为空 即SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\t\tUSART_SendData(USART1, *pt);\n\t\t//如果发送完成就为空 SET\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\t\tpt++;\n\t}\n}\n\n//重定向printf\nint fputc(int c, FILE *fp){\n\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TXE) != SET);//空 标志位\n\tUSART_SendData(USART1, c);\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_TC) != SET);\n\treturn 0;\n}\n\n//重定向fget\nint fgetc(FILE *fp){\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) != SET);\n\treturn (int)USART_ReceiveData(USART1);\n}\n\n//void USART1_IRQHandler(void){\n//\tunsigned char ch;\n//\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n//\t\tch = USART_ReceiveData(USART1);\n//\t\tprintf(\"%c\\n\", ch + 1);\n//\t}\n//}\n\nvoid control_LED(unsigned int LED_number, unsigned int status){\n\t//1\u003c\u003cLED_number表示gpio几，因为pin2就表示1左移两位，BitAction是电平set的枚举类型\n\t//GPIO_WriteBit(GPIOB, (uint16_t)1\u003c\u003cLED_number, (BitAction)status);\n\tswitch(LED_number){\n\t\tcase 0x01:\n\t\tGPIO_WriteBit(GPIOB, GPIO_Pin_5, (BitAction)status);\n\t\t\tbreak;\n\t\tcase 0x02:\n\t\t\tGPIO_WriteBit(GPIOE, GPIO_Pin_5, (BitAction)status);\n\t\t\tbreak;\n\t}\n\t\n}\n\n\nvoid USART1_IRQHandler(void){\n\t\n//使用static即使是局部变量也会在全局生效 并且第一次生效后之后再进函数再也不会初始化 00000\n\tstatic unsigned int arr[5] = {0,0,0,0,0};\n\tstatic unsigned int flag = 0;\n\tstatic unsigned int i = 1;\n\tunsigned char ch;\n\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == SET){\n\n\t\tch = USART_ReceiveData(USART1);\n\n\t\tif(ch == 0xaa){//必须要从接收到起始位才开始分析数据\n\t\t\tarr[0] = ch;//第一位为起始位\n\t\t\tflag = 1;//将标志位置1\n\t\t\t\n\t\t}\n\t\tif(ch != 0xaa \u0026\u0026 flag == 1){//如果接收到的数据不是起始位并且标志位置1了\n\t\t\tarr[i++] = ch;//接收数据\n\t\t\tif(i == 5){\n\t\t\t\tflag = 0;\n\t\t\t\ti = 1;\n\t\t\t\tif(((arr[i]+arr[2]) == arr[3]) \u0026\u0026 (arr[4] == 0xff)){\n\n\t\t\t\t\t\tcontrol_LED(arr[1], arr[2]);\n\t\t\t\t\t\tprintf(\"1\");\n\t\t\t\t\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t}\n\n\t\n}\n\nvoid Uart1_scanf(unsigned int *pt, unsigned int bits){\n\t\n\tunsigned int i = 0;\n\t\n\tunsigned int tmp[] = {0,0,0,0}; \n\n\twhile(i \u003c bits){\n\t\twhile(USART_GetFlagStatus(USART1, USART_FLAG_RXNE) == RESET);\n\t\ttmp[i++] = USART_ReceiveData(USART1);\n\t\t\n\t\t}\n\tif(bits == 4){\n\t\t*pt = (tmp[0] - '0')*1000 + (tmp[1] - '0')*100 + (tmp[2] - '0')*10 + (tmp[3] - '0' );\n\t}else{\n\t\t*pt = (tmp[0] - '0')*10 + (tmp[1] - '0');\n\t}\n\t\n}\n\n\n\n\n//这是自带时钟频率驱动至72MHZ的函数 只是将函数名改变了 为了避免有影响\nvoid SetSysClock_to_72MHZ(void)\n{\n  __IO uint32_t StartUpCounter = 0, HSEStatus = 0;\n  \n  /* SYSCLK, HCLK, PCLK2 and PCLK1 configuration ---------------------------*/    \n  /* Enable HSE */    \n  RCC-\u003eCR |= ((uint32_t)RCC_CR_HSEON);\n \n  /* Wait till HSE is ready and if Time out is reached exit */\n  do\n  {\n    HSEStatus = RCC-\u003eCR \u0026 RCC_CR_HSERDY;\n    StartUpCounter++;  \n  } while((HSEStatus == 0) \u0026\u0026 (StartUpCounter != HSE_STARTUP_TIMEOUT));\n\n  if ((RCC-\u003eCR \u0026 RCC_CR_HSERDY) != RESET)\n  {\n    HSEStatus = (uint32_t)0x01;\n  }\n  else\n  {\n    HSEStatus = (uint32_t)0x00;\n  }  \n\n  if (HSEStatus == (uint32_t)0x01)\n  {\n    /* Enable Prefetch Buffer */\n    FLASH-\u003eACR |= FLASH_ACR_PRFTBE;\n\n    /* Flash 2 wait state */\n    FLASH-\u003eACR \u0026= (uint32_t)((uint32_t)~FLASH_ACR_LATENCY);\n    FLASH-\u003eACR |= (uint32_t)FLASH_ACR_LATENCY_2;    \n\n \n    /* HCLK = SYSCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_HPRE_DIV1;\n      \n    /* PCLK2 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE2_DIV1;\n    \n    /* PCLK1 = HCLK */\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_PPRE1_DIV2;\n\n#ifdef STM32F10X_CL\n    /* Configure PLLs ------------------------------------------------------*/\n    /* PLL2 configuration: PLL2CLK = (HSE / 5) * 8 = 40 MHz */\n    /* PREDIV1 configuration: PREDIV1CLK = PLL2 / 5 = 8 MHz */\n        \n    RCC-\u003eCFGR2 \u0026= (uint32_t)~(RCC_CFGR2_PREDIV2 | RCC_CFGR2_PLL2MUL |\n                              RCC_CFGR2_PREDIV1 | RCC_CFGR2_PREDIV1SRC);\n    RCC-\u003eCFGR2 |= (uint32_t)(RCC_CFGR2_PREDIV2_DIV5 | RCC_CFGR2_PLL2MUL8 |\n                             RCC_CFGR2_PREDIV1SRC_PLL2 | RCC_CFGR2_PREDIV1_DIV5);\n  \n    /* Enable PLL2 */\n    RCC-\u003eCR |= RCC_CR_PLL2ON;\n    /* Wait till PLL2 is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLL2RDY) == 0)\n    {\n    }\n    \n   \n    /* PLL configuration: PLLCLK = PREDIV1 * 9 = 72 MHz */ \n    RCC-\u003eCFGR \u0026= (uint32_t)~(RCC_CFGR_PLLXTPRE | RCC_CFGR_PLLSRC | RCC_CFGR_PLLMULL);\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLXTPRE_PREDIV1 | RCC_CFGR_PLLSRC_PREDIV1 | \n                            RCC_CFGR_PLLMULL9); \n#else    \n    /*  PLL configuration: PLLCLK = HSE * 9 = 72 MHz */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_PLLSRC | RCC_CFGR_PLLXTPRE |\n                                        RCC_CFGR_PLLMULL));\n    RCC-\u003eCFGR |= (uint32_t)(RCC_CFGR_PLLSRC_HSE | RCC_CFGR_PLLMULL9);\n#endif /* STM32F10X_CL */\n\n    /* Enable PLL */\n    RCC-\u003eCR |= RCC_CR_PLLON;\n\n    /* Wait till PLL is ready */\n    while((RCC-\u003eCR \u0026 RCC_CR_PLLRDY) == 0)\n    {\n    }\n    \n    /* Select PLL as system clock source */\n    RCC-\u003eCFGR \u0026= (uint32_t)((uint32_t)~(RCC_CFGR_SW));\n    RCC-\u003eCFGR |= (uint32_t)RCC_CFGR_SW_PLL;    \n\n    /* Wait till PLL is used as system clock source */\n    while ((RCC-\u003eCFGR \u0026 (uint32_t)RCC_CFGR_SWS) != (uint32_t)0x08)\n    {\n    }\n  }\n  else\n  { /* If HSE fails to start-up, the application will have wrong clock \n         configuration. User can add here some code to deal with this error */\n  }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083332-2cwh1a6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083332-2cwh1a6","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083333-elij6bh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083333-elij6bh","updated":"20231024083333"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//RTC设置\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n\n//unsigned int count=0;\nint main(){\n\n\tSysTick_Configuration();\n\n\tUart1_Configuration();\n\t\t\n\tRTC_Configuration();\n\n\n\twhile(1){\n\n\t\tTime_Display(RTC_GetCounter());\n\t\tDelay_us(1000000);\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083334-3x7wsb0","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083334-3x7wsb0","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"LCD1602"}]},{"ID":"20231024083335-o25lf5s","Type":"NodeParagraph","Properties":{"id":"20231024083335-o25lf5s","updated":"20231024083335"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1695626999930-b32d99be-a046-471d-ac92-7c7f263781ac.png#averageHue=%23f7f2f1\u0026clientId=u53ecdd46-a534-4\u0026from=paste\u0026height=487\u0026id=u2994e740\u0026originHeight=487\u0026originWidth=871\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=275011\u0026status=done\u0026style=none\u0026taskId=u964b0ec4-f62c-4e64-b1c8-5d668206486\u0026title=\u0026width=871","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1695626860502-38741acc-8114-405e-b314-1a65e0253d9a.png#averageHue=%23f7f6f5\u0026clientId=u53ecdd46-a534-4\u0026from=paste\u0026height=458\u0026id=uce97dd93\u0026originHeight=458\u0026originWidth=786\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=204508\u0026status=done\u0026style=none\u0026taskId=u5aa571c0-3bd9-4b8f-a39b-7d330bfa1e3\u0026title=\u0026width=786","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083336-5dpi4aj","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083336-5dpi4aj","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"测温模块"}]},{"ID":"20231024083337-pxk43i2","Type":"NodeParagraph","Properties":{"id":"20231024083337-pxk43i2","updated":"20231024083337"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1695883871351-77c83a3d-0554-486c-83c8-e2fd44c71642.png#averageHue=%23e3d46a\u0026clientId=u53ecdd46-a534-4\u0026from=paste\u0026height=450\u0026id=u153fb845\u0026originHeight=450\u0026originWidth=799\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=324941\u0026status=done\u0026style=none\u0026taskId=u10547962-89c4-48f8-bc09-b4cdfe175db\u0026title=\u0026width=799","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083338-j6jop17","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083338-j6jop17","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_ds18b20.h"}]},{"ID":"20231024083339-8qhtz1r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083339-8qhtz1r","updated":"20231024083339"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_DS18B20_H__\n#define __BSP_DS18B20_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\n#define DS18B20_DATA_OUT(a) GPIO_WriteBit(GPIOB, GPIO_Pin_6, (BitAction)(a))\n\n\nvoid DS18B20_GPIO_Configuration(void);\nvoid DS18B20_Init(void);\nfloat DS18B20_Get_Temperature(void);\n\n\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083340-bt6bbeh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083340-bt6bbeh","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_ds18b20.c"}]},{"ID":"20231024083341-lxqtwcu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083341-lxqtwcu","updated":"20231024083341"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_ds18b20.h\"\n\nvoid DS18B20_Mode_Out_PP(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);//初始化\n}\n\nvoid DS18B20_Mode_IPU(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//上拉输入\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);//初始化\n\n}\n\n\nvoid DS18B20_GPIO_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOB, ENABLE);\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOB, \u0026GPIO_InitStructure);//初始化\n}\n\n\nvoid DS18B20_Init(void){\n\t\n\tDS18B20_Mode_Out_PP();\n\t\n\tDS18B20_DATA_OUT(0);\n\tDelay_us(750);//保持450ms低电平\n\tDS18B20_DATA_OUT(1);\n\tDelay_us(20);//高电平保持20ms\n\t\t\n\tDS18B20_Mode_IPU();//配置为上拉输入\n\t\n\twhile(GPIO_ReadInputDataBit(GPIOB, GPIO_Pin_6) != 0);//等待低电平到来\n\twhile(GPIO_ReadInputDataBit(GPIOB, GPIO_Pin_6) == 0);//等待初始化结束\n\n}\n\nvoid DS18B20_Write_Byte(unsigned char dat){\n\t\n\tunsigned int i;\n\t\n\tDS18B20_Mode_Out_PP();\n\t\n\tfor(i = 0; i \u003c 8; i++){\n\t\t\n\t\tif(dat \u0026 0x1){\n\t\t\tDS18B20_DATA_OUT(0);\n\t\t\tDelay_us(8);\n\t\t\t\n\t\t\tDS18B20_DATA_OUT(1);\n\t\t\tDelay_us(58);\n\t\t\t\n\t\t}else{\n\t\t\tDS18B20_DATA_OUT(0);\n\t\t\tDelay_us(70);\n\t\t\tDS18B20_DATA_OUT(1);\n\t\t\tDelay_us(2);\n\t\t}\n\t\tdat = dat \u003e\u003e 1;\n\t\n\t}\n\n}\n\nunsigned char DS18B20_Read_Byte(void){\n\tunsigned char dat = 0;\n\tunsigned int i;\n\tfor(i = 0; i\u003c 8; i++){\n\t\tDS18B20_Mode_Out_PP();\n\t\tDS18B20_DATA_OUT(0);\n\t\tDelay_us(10);\n\t\tDS18B20_Mode_IPU();\n\t\t\n\t\tdat |= (GPIO_ReadInputDataBit(GPIOB, GPIO_Pin_6)\u003c\u003ci);\n\t\t\n\t\tDelay_us(55);\n\t\n\t}\n\treturn dat;\n}\n\nfloat DS18B20_Get_Temperature(void){\n\t\n\tunsigned char tp_lsb, tp_msb;\n\tshort s_tp;\n\tfloat temperature;\n\t\n\tDS18B20_Init();\n\tDS18B20_Write_Byte(0xCC);\n\tDS18B20_Write_Byte(0x44);\n\t\n\tDS18B20_Init();\n\tDS18B20_Write_Byte(0xCC);\n\tDS18B20_Write_Byte(0xBE);\n\t\n\ttp_lsb = DS18B20_Read_Byte();\n\ttp_msb = DS18B20_Read_Byte();\n\t\n\ts_tp = tp_msb \u003c\u003c 8;\n\ts_tp = s_tp | tp_lsb;\n\t\n\tif(s_tp\u003c0){ // 负温度值\n\t\ttemperature = 0 - (~s_tp + 1) * 0.0625;//如果值小于0要取绝对值再乘系数 0再减去得到最终温度 \n\t}else{\n\t\n\t\ttemperature = s_tp * 0.0625;//如果是正常温度直接乘系数\n\t}\n\t\n\treturn temperature;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083342-sowlh2x","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083342-sowlh2x","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083343-s91uqpn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083343-s91uqpn","updated":"20231024083343"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//DS18B20测温\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n\nunsigned int i=0;\nint main(){\n\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\t\n\tDS18B20_GPIO_Configuration();\n\t\n\tDS18B20_Init();\n\t\n\twhile(1){\n\n\t\tprintf(\"Temperature = %f \\n\",DS18B20_Get_Temperature());\n\t\tDelay_us(1000000);\n\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083344-zkodgct","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083344-zkodgct","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"颜色传感器"}]},{"ID":"20231024083345-t0pq7jn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083345-t0pq7jn","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tcs3200.h"}]},{"ID":"20231024083346-cx1qz8h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083346-cx1qz8h","updated":"20231024083346"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_TCS3200_H__\n#define __BSP_TCS3200_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\nvoid TCS3200_Configuration(unsigned int s0, unsigned int s1);\nvoid PA4_EXIT4_Configuration(void);\nvoid White_balance(void);\n\nunsigned int tcs3200_red(void);\nunsigned int tcs3200_green(void);\nunsigned int tcs3200_blue(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083347-pklnrey","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083347-pklnrey","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_tcs3200.c"}]},{"ID":"20231024083348-8vz02te","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083348-8vz02te","updated":"20231024083348"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_tcs3200.h\"\n\nunsigned int amount;\nunsigned int Red_Pulse, Blue_Pulse, Green_Pulse;\ndouble Red_Ratio, Blue_Ratio, Green_Ratio;\n\n//PA0:S0 PA1:S1 PA2:S2 PA3:S3\nvoid TCS3200_Configuration(unsigned int s0, unsigned int s1){\n\t\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);//开启时钟使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\t\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_0, (BitAction)s0);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_1, (BitAction)s1);\n} //单位时间内高电平次数就是多少个脉冲\n\n//PA4:output\nvoid PA4_EXIT4_Configuration(void){\n\t\n\tNVIC_InitTypeDef NVIC_InitStructure;\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tEXTI_InitTypeDef EXTI_InitStructure;\n\t\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOE | RCC_APB2Periph_AFIO, ENABLE);//开启时钟，开启外部中断 即PB5的复用功能 使能gpiob\n\t\n\t//KEY0、KEY1和 WK_UP分别连接 分别连接 PE4、PE3和 PA0，\n\t//即对应了 EXTI4、EXTI3和 EXTI0这三条外部中断线。\n\t//这里需要注意的是 EXTI0到 EXTI4都是有单独的中断向量，\n\t//EXTI5到 EXTI9是公用 是公用 EXTI9_5_IRQn，EXTI10到 EXTI15是公用 是公用 EXTI15_10_IRQn。\n\tNVIC_PriorityGroupConfig(NVIC_PriorityGroup_1);//抢占优先级群分组 看具体文档 这个是管优先级的 和引脚没关系\n//\tNVIC_InitStructure.NVIC_IRQChannel = EXTI9_5_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannel = EXTI4_IRQn; //NVIC管理哪一个中断源\n\tNVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;//抢占优先级 哥哥和弟弟 弟弟优先级高\n\tNVIC_InitStructure.NVIC_IRQChannelSubPriority = 2;//响应优先级 在抢占优先级相同时看响应\n\tNVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;\n\tNVIC_Init(\u0026NVIC_InitStructure);\n\n\t//将GPIO配置为外部中断的方式\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_4;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\tGPIO_EXTILineConfig(GPIO_PortSourceGPIOA, GPIO_PinSource4);//GPIO中断 SOURCE对应pin脚\n\t\n\t//中断函数 外部中断以哪种方式响应\n\tEXTI_InitStructure.EXTI_Line =  EXTI_Line4;//选择待使能或者失能的外部路线 Line对应pin脚\n\tEXTI_InitStructure.EXTI_Mode = EXTI_Mode_Interrupt;//中断请求 优先级高于事件请求\n\tEXTI_InitStructure.EXTI_Trigger = EXTI_Trigger_Falling;//下降沿有效 即按下按键  //单位时间内高电平次数就是多少个脉冲\n\tEXTI_InitStructure.EXTI_LineCmd = ENABLE;//中断使能\n\tEXTI_Init(\u0026EXTI_InitStructure);\n}\n\n//注意：这是系统里的EXTI4_IRQHandler 需要我们自己去补充中断的内容\nvoid EXTI4_IRQHandler(void){\n\tif(EXTI_GetITStatus(EXTI_Line4) != RESET){\n\t\t\n\t\tamount++;\n\t\tEXTI_ClearITPendingBit(EXTI_Line4);//清除标志位\n\t}\n}\n\n//白平衡\nvoid White_balance(void){\n\t//打开红色滤波器 S2\u0026S3 低电平\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_RESET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_RESET);\n\tamount = 0;\n\tDelay_us(10000);\n\tRed_Pulse = amount;//红色光脉冲个数\n\tRed_Ratio = (double)255/Red_Pulse; //测得的值与255之间的系数关系\n//\tprintf(\"Red_Pluse = %d\\n\", Red_Pulse);\n//\tprintf(\"Red_Ratio = %.2f\\n\", Red_Ratio);\n\tamount = 0;\n\t\n\t//打开绿色滤波器 S2\u0026S3 高电平\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_SET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_SET);\n\tamount = 0;\n\tDelay_us(10000);\n\tGreen_Pulse = amount;//绿色光脉冲个数\n\tGreen_Ratio = (double)255/Green_Pulse ; //测得的值与255之间的系数关系\n//\tprintf(\"Green_Pluse = %d\\n\", Green_Pulse);\n//\tprintf(\"Green_Ratio = %.2f\\n\", Green_Ratio);\n\tamount = 0;\n\t\n\t//打开蓝色滤波器 S2：0 S3：1 \n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_RESET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_SET);\n\tamount = 0;\n\tDelay_us(10000);\n\tBlue_Pulse = amount;//蓝色光脉冲个数\n\tBlue_Ratio = (double) 255/Blue_Pulse ; //测得的值与255之间的系数关系\n//\tprintf(\"Blue_Pulse = %d\\n\", Blue_Pulse);\n//\tprintf(\"Blue_Ratio = %.2f\\n\", Blue_Ratio);\n\tamount = 0;\n\t \n\t//关闭通道  S2：1 S3：0 \n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_SET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_RESET);\t\n}\n\n//红色通道output的输出脉冲个数\nunsigned int tcs3200_red(void){\n\t\n\tunsigned int Red_Value;\n\tunsigned int Green_Value;\n\tunsigned int Blue_Value;\n\t\n\t//打开红色滤波器 S2\u0026S3 低电平\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_RESET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_RESET);\n\tamount = 0;\n\tDelay_us(10000);\n\tRed_Value = amount * Red_Ratio;\n\tif(Red_Value \u003e 255){\n\t\tRed_Value = 255;\n\t}\n\treturn Red_Value;\n\t\n}\n\n//绿色通道output的输出脉冲个数\nunsigned int tcs3200_green(void){\n\t\n\n\tunsigned int Green_Value;\n\n\t\n\t//打开红色滤波器 S2\u0026S3 低电平\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_SET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_SET);\n\tamount = 0;\n\tDelay_us(10000);\n\tGreen_Value = amount * Green_Ratio;\n\tif(Green_Value \u003e 255){\n\t\tGreen_Value = 255;\n\t}\n\treturn Green_Value;\n\t\n}\n\n//蓝色通道output的输出脉冲个数\nunsigned int tcs3200_blue(void){\n\t\n\n\tunsigned int Blue_Value;\n\t\n\t//打开蓝色滤波器 S2\u0026S3 低电平\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_2, Bit_RESET);\n\tGPIO_WriteBit(GPIOA, GPIO_Pin_3, Bit_SET);\n\tamount = 0;\n\tDelay_us(10000);\n\tBlue_Value = amount * Blue_Ratio;\n\tif(Blue_Value \u003e 255){\n\t\tBlue_Value = 255;\n\t}\n\treturn Blue_Value;\n\t\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083349-tb3fkjw","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083349-tb3fkjw","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083350-nl4wros","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083350-nl4wros","updated":"20231024083350"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//tcs3200颜色传感器\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n#include \"bsp_tcs3200.h\"\n\n\nint main(){\n\n\tunsigned int R=0, G=0, B=0;\n\t\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\n\tTCS3200_Configuration(1,1);\n\t\n\tPA4_EXIT4_Configuration();\n\t\n\tWhite_balance();//白平衡\n\t\n\twhile(1){\n\t\tR = tcs3200_red();\n\t\tG = tcs3200_green();\n\t\tB = tcs3200_blue();\n\t\t \n\t\tprintf(\"R = %d\\n\", R);\n\t\tprintf(\"G = %d\\n\", G);\n\t\tprintf(\"B = %d\\n\", B);\n\t\tprintf(\"---------------\");\n\t\tDelay_us(1000000);\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083351-20mky35","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083351-20mky35","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"温湿度传感器"}]},{"ID":"20231024083352-lf1r3lf","Type":"NodeBlockquote","Properties":{"id":"20231024083352-lf1r3lf","updated":"20231024083352"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20231024083353-c9rqf1l","Type":"NodeParagraph","Properties":{"id":"20231024083353-c9rqf1l","updated":"20231024083353"},"Children":[{"Type":"NodeText","Data":"没有进行测试 因为传感器有问题"}]}]},{"ID":"20231024083354-g2mszgb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083354-g2mszgb","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_dht11.h"}]},{"ID":"20231024083355-gn41ucj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083355-gn41ucj","updated":"20231024083355"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_DHT11_H__\n#define __BSP_DHT11_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\nvoid Dht11_Configuration(void);\n\n#define DHT11_DATA_OUT(a)  GPIO_WriteBit(GPIOA, GPIO_Pin_7, (BitAction)(a))\n\nextern unsigned char Hum_H, Hum_L, Tem_H, Tem_L;\nvoid DHT11_Read(void);\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083356-vqecbd4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083356-vqecbd4","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_dht11.c"}]},{"ID":"20231024083357-336vkgx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083357-336vkgx","updated":"20231024083357"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_dht11.h\"\n\nunsigned char Hum_H, Hum_L, Tem_H, Tem_L;\n\n//PA7:DHT11_DATA\nvoid Dht11_Configuration(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);//开启时钟使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n}\n\n//因为PA7既要做输入又要做输出 所以要设置两种模式\nvoid DHT11_Mode_out_pp(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n}\n\nvoid DHT11_Mode_out_IPU(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_7;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_IPU;//上拉输入\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n}\n\nvoid DHT11_Start(void){\n\tunsigned int timeout;\n\tDHT11_Mode_out_pp();//将PA7设置为输出模式\n\tDHT11_DATA_OUT(0);//按照时序要求需要先将电平拉低\n\tDelay_us(20000);//保持低电平至少18ms\n\t\n\tDHT11_DATA_OUT(1);//将电平拉高\n\tDelay_us(30000);//保持高电平20~40ms\n\t\n\t//此时stm从输出转为输入\n\tDHT11_Mode_out_IPU();\n\ttimeout = 80;\n\t//因为想要读到的是低电平 所以取反为真 80us低电平响应信号\n\twhile((!GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)) \u0026\u0026 (timeout\u003e0)){//读dht11的低电平\n\t\ttimeout--;\n\t\tDelay_us(1);//延迟一个微秒\n\t}\n\t\n\t//DHT拉高80us\n\ttimeout = 80;\n\twhile((GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)) \u0026\u0026 (timeout\u003e0)){//读dht11的低电平\n\t\ttimeout--;\n\t\tDelay_us(1);//延迟一个微秒\n\t}\n}\n\n//读取40个位bit 分5次 每次一个字节\nunsigned char DHT11_Read_Byte(void){\n\tunsigned char dat = 0;\n\tunsigned int i;\n\tunsigned int highTime;\n\tunsigned int timeout;\n\t\n\t//将data配置为输入\n\tDHT11_Mode_out_IPU();\n\t\n\n\tfor(i=0; i\u003c8; i++){\n\t\t\twhile(GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)==0);\n\t\t\t\n//\t\t\thighTime = 0;\n//\t\t\twhile(GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)){\n//\t\t\t\thighTime++;\n//\t\t\t\tDelay_us(1);\n//\t\t\t}\n//\t\t\tif((26\u003c= highTime) \u0026\u0026 (highTime \u003c= 28)){\n//\t\t\t\t\n//\t\t\t\n//\t\t\t}else if(highTime==70){\n//\t\t\t\t\t\n//\t\t\t\n//\t\t\t}\n//\t\t\thighTime = 0;\n\t\t\t\n\t\t\tDelay_us(40);//跨过40us后再去读取信号线上的电平 如果低数据为0 否则为高\n\t\t\tdat \u003c\u003c= 1;\n\t\t\tif(GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)){\n\t\t\t\tdat +=  1;\n\t\t\t\tprintf(\"dat= %#x\\n\",dat);\n\t\t\t}\n\t\t\t\n\t\t\ttimeout = 50;\n\t\t\twhile((GPIO_ReadInputDataBit(GPIOA, GPIO_Pin_7)) \u0026\u0026 (timeout\u003e0)){//读dht11的低电平\n\t\t\t\ttimeout--;\n\t\t\t\tDelay_us(1);//延迟一个微秒\n\t\t\t}\n\t\t\t\n\t}\n//\tprintf(\"dat=%d\",dat);\n\treturn dat;\n}\n\nvoid DHT11_Read(void){\n\t\n\tunsigned char Hum_H_temp, Hum_L_temp, Tem_H_temp, Tem_L_temp, Check_Sum; \n\t\n\tDHT11_Start();//启动DHT11\n\t\n\t//连续读取5个字节 共计40个bit 包括湿度8位整数位 湿度8位小数位 温度8位整数位 温度8位小数位 校验和\n\tHum_H_temp = DHT11_Read_Byte();\n\n\tHum_L_temp = DHT11_Read_Byte();\n\tTem_H_temp = DHT11_Read_Byte();\n\tTem_L_temp = DHT11_Read_Byte();\n\tCheck_Sum = DHT11_Read_Byte();\n\n\t//发送结束标志\n\tDHT11_Mode_out_pp();\n\tDHT11_DATA_OUT(1);\n\n\t//判断所有值相加是否等于校验和\n\tif((Hum_H_temp+Hum_L_temp+Tem_H_temp+Tem_L_temp)==Check_Sum){\n\t\t\tHum_H = Hum_H_temp;\n\t\t\tHum_L = Hum_L_temp;\n\t\t\tTem_H = Tem_H_temp;\n\t\t\tTem_L = Tem_L_temp;\n\t\t\n\t}\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083358-qihd8wg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083358-qihd8wg","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083359-mlv4o6t","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083359-mlv4o6t","updated":"20231024083359"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\n//dht11\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n#include \"bsp_tcs3200.h\"\n#include \"bsp_dht11.h\"\n\n\nint main(){\n\n\n\t\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\n\tDht11_Configuration();\n\t\n\twhile(1){\n\t\tDHT11_Read();\n\t\tprintf(\"Temperature = %d.%d摄氏度\\n\\n\", Tem_H, Tem_L);\n\t\tprintf(\"Humidity = %d.%d%%RH\\n\\n\", Hum_H, Hum_L);\n\t\tprintf(\"-----------------------------\");\n\t\tDelay_us(1000000);\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083360-1ljf9sf","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20231024083360-1ljf9sf","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"OLED"}]},{"ID":"20231024083361-tpb9ae7","Type":"NodeParagraph","Properties":{"id":"20231024083361-tpb9ae7","updated":"20231024083361"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"image.png","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://cdn.nlark.com/yuque/0/2023/png/38661095/1696900554959-43559ecd-2929-4721-a919-28927ab7ef23.png#averageHue=%23f6f4f3\u0026clientId=uc04da9e3-2c24-4\u0026from=paste\u0026height=456\u0026id=u2ecce7f9\u0026originHeight=456\u0026originWidth=736\u0026originalType=binary\u0026ratio=1\u0026rotation=0\u0026showTitle=false\u0026size=183092\u0026status=done\u0026style=none\u0026taskId=u18ea9d95-065e-424c-be8d-f5d614be658\u0026title=\u0026width=736","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20231024083362-gphax2a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083362-gphax2a","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_OLED.h"}]},{"ID":"20231024083363-wybh876","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083363-wybh876","updated":"20231024083363"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_OLED_H__\n#define __BSP_OLED_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\n/***\nOLED0.96  默认SPI通信\nGND\nVCC-3.3v\nD0(SCLK) \tPA6\nD1(SDIN)\tPA7\nRES\tPA8\nDC(DATA/COMMAND)\tPA0\nCS\tPA1\n***/\n\n#define OLED_RST_Set() GPIO_SetBits(GPIOA, GPIO_Pin_8)\n#define OLED_RST_Clr() GPIO_ResetBits(GPIOA, GPIO_Pin_8)\n\n#define OLED_DC_Set() GPIO_SetBits(GPIOA, GPIO_Pin_0)\n#define OLED_DC_Clr() GPIO_ResetBits(GPIOA, GPIO_Pin_0)\n\n#define OLED_CS_Set() GPIO_SetBits(GPIOA, GPIO_Pin_1)\n#define OLED_CS_Clr() GPIO_ResetBits(GPIOA, GPIO_Pin_1)\n\n#define OLED_SCLK_Set() GPIO_SetBits(GPIOA, GPIO_Pin_6)\n#define OLED_SCLK_Clr() GPIO_ResetBits(GPIOA, GPIO_Pin_6)\n\n#define OLED_SDIN_Set() GPIO_SetBits(GPIOA, GPIO_Pin_7)\n#define OLED_SDIN_Clr() GPIO_ResetBits(GPIOA, GPIO_Pin_7)\nvoid OLED_DrawBMP(unsigned char x0,unsigned char y0,unsigned char x1,unsigned char y1, unsigned char bmp[]);\nvoid OLED_Init(void);\n\n#define OLED_CMD 0\n#define OLED_DATA 1\n#endif\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083364-etvr6wn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083364-etvr6wn","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bsp_OLED.c"}]},{"ID":"20231024083365-oj8szn2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083365-oj8szn2","updated":"20231024083365"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#include \"bsp_OLED.h\"\n\n\n\n//dat:要写入的数据/命令 \n//com：0表示命令 1表示数据\nvoid OLED_WR_Byte(unsigned char dat, unsigned int cmd){\n\t\n\tunsigned int i;\n\tif(cmd){//根据命令拉高拉低DC线\n\t\tOLED_DC_Set();\n\t}else{\n\t\tOLED_DC_Clr();\n\t}\n\t\n\t//拉低片选信号线\n\t OLED_CS_Clr();\n\t\n\tfor(i = 0; i \u003c 8; i++){\n\t\tOLED_SCLK_Clr();//先低电平拉低然后获取数据\n\t\t//数据8位从高位到低位发送\n\t\tif(dat \u0026 0x80){//如果数据是高电平则拉高数据线\n\t\t\tOLED_SDIN_Set();\n\t\t}else{\n\t\t\tOLED_SDIN_Clr();\n\t\t}\n\t\tOLED_SCLK_Set();//高电平\n\t\tdat \u003c\u003c= 1;   \n\t}\n\tOLED_CS_Set();\n}\n\nvoid OLED_Clear(){\n\tunsigned int i,j;\n\tfor(i = 0; i \u003c 8; i++){\n\t\t//126*64 像素 行分为了8行 8个像素点为一页\n\t\t//0xbo 表示第一页 0xb7表示第8页 \n\t\tOLED_WR_Byte(0xb0 + i, OLED_CMD); //设置page地址\n\t\tOLED_WR_Byte(0x00, OLED_CMD);\t//设置列地址的低位\n\t\tOLED_WR_Byte(0x10, OLED_CMD); //设置列地址的高位\n\t\tfor(j = 0; j \u003c 128; j++){\n\t\t\tOLED_WR_Byte(0x0, OLED_DATA);\n\t\t}\n\t}\n}\n\n//x:表示的列， 分为（列低地址和列高地址），y表示的是page页编号（0-7 ）\nvoid OLED_Set_Pos(unsigned int x, unsigned int y){\n\tOLED_WR_Byte(0xb0 + y, OLED_CMD);\n\t\n\tOLED_WR_Byte((x\u00260x0F), OLED_CMD);//低8位\n\tOLED_WR_Byte((x\u00260xF0)\u003e\u003e4 | 0x10, OLED_CMD);//高8位\n}\n\n//y0-y1的取值范围是0-7， x0-x1的取值范围是0-127\nvoid OLED_DrawBMP(unsigned char x0,unsigned char y0,unsigned char x1,unsigned char y1, unsigned char bmp[]){\n\tunsigned char y;\n\tunsigned char x;\n\tunsigned int i = 0;\n\tfor(y = y0; y \u003c y1; y++){\n\t\tOLED_Set_Pos(x0, y);\n\t\tfor(x = x0; x \u003c= x1; x++){\n\t\t\tOLED_WR_Byte(bmp[i++], OLED_DATA);\n\t\t}\n\t}\n\n}\n\nvoid OLED_Init(void){\n\tGPIO_InitTypeDef GPIO_InitStructure;\n\tRCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOA, ENABLE);//开启时钟使能gpiob\n\tGPIO_InitStructure.GPIO_Pin = GPIO_Pin_6|GPIO_Pin_7|GPIO_Pin_8|GPIO_Pin_0|GPIO_Pin_1;//端口配置\n\tGPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;//io口速度为50MHZ\n\tGPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;//推挽输出\n\tGPIO_Init(GPIOA, \u0026GPIO_InitStructure);//初始化\n\t\n\t//拉高电平\n\tGPIO_SetBits(GPIOA, GPIO_Pin_6|GPIO_Pin_7|GPIO_Pin_8|GPIO_Pin_0|GPIO_Pin_1);\n\t\n\tOLED_RST_Set();//拉高\n\tDelay_us(1000000);\n\tOLED_RST_Clr();//拉低\n\tDelay_us(20);\n\tOLED_RST_Set();//拉高\n\t\n\tOLED_WR_Byte(0xA8, OLED_CMD);\n\tOLED_WR_Byte(0x3F, OLED_CMD);\n\tOLED_WR_Byte(0xD3, OLED_CMD);\n\tOLED_WR_Byte(0x00, OLED_CMD);\n\tOLED_WR_Byte(0x40, OLED_CMD);\n\tOLED_WR_Byte(0xA1, OLED_CMD);   //A0:A1 控制屏幕显示左右映射翻转\n\tOLED_WR_Byte(0xC8, OLED_CMD);\t\t//C0:C8 控制屏幕上下映射翻转\n\tOLED_WR_Byte(0xDA, OLED_CMD);\n\tOLED_WR_Byte(0x12, OLED_CMD);\t\t//02:隔行显示 12:逐行显示\n\tOLED_WR_Byte(0x81, OLED_CMD);\n\tOLED_WR_Byte(0x7F, OLED_CMD);\n\tOLED_WR_Byte(0xA4, OLED_CMD);\n\tOLED_WR_Byte(0xA6, OLED_CMD);\n\tOLED_WR_Byte(0xD5, OLED_CMD);\n\tOLED_WR_Byte(0x80, OLED_CMD);\n\tOLED_WR_Byte(0x8D, OLED_CMD);\n\tOLED_WR_Byte(0x14, OLED_CMD);\n\tOLED_WR_Byte(0xAF, OLED_CMD);\n\t\n\tOLED_Clear();//清屏\n\tOLED_Set_Pos(0,0);  \n\t\n\t\n}\n\n\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083366-ypuq2eb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083366-ypuq2eb","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"main.c"}]},{"ID":"20231024083367-v3bs3rm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083367-v3bs3rm","updated":"20231024083367"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//OLED\n#include \"bsp_iwdg.h\"\n#include \"bsp_wwdg.h\"\n#include \"bsp_exti.h\"\n#include \"Led_Key.h\"\n#include \"bsp_SysTick.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_dma.h\"\n#include \"bsp_adc.h\"\n#include \"bsp_tim3.h\"\n#include \"bsp_rtc.h\"\n#include \"bsp_hcsr04.h\"\n#include \"bsp_tim2.h\"\n#include \"bsp_1602.h\"\n#include \"bsp_ds18b20.h\"\n#include \"bsp_tcs3200.h\"\n#include \"bsp_dht11.h\"\n#include \"bsp_OLED.h\"\n#include \"bsp_bmp.h\"\n\nint main(){\n\n\n\t\n\tSysTick_Configuration();\n\t\n\tUart1_Configuration();\n\n\tOLED_Init();\n\t\n\n\twhile(1){\n\t\tOLED_DrawBMP(0, 0, 127, 7, gImage_niude);\n\t} \n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20231024083368-pjtruwb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20231024083368-pjtruwb","updated":"20240731160329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"bmp字符数组"}]},{"ID":"20231024083369-ohkyaqj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20231024083369-ohkyaqj","updated":"20231024083369"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#ifndef __BSP_BMP_H__\n#define __BSP_BMP_H__\n\n#include \"stm32f10x_pwr.h\"\n#include \"stm32f10x.h\"\n#include \"stm32f10x_dma.h\"\n#include \"stm32f10x_rcc.h\"\n#include \"stm32f10x_exti.h\"\n#include \"misc.h\"\n#include \"Led_Key.h\"\n#include \"stm32f10x_tim.h\"\n#include \"bsp_iwdg.h\"\n#include \"stm32f10x_bkp.h\"\n#include \"stm32f10x_rtc.h\"\n#include \"bsp_uart.h\"\n#include \"bsp_SysTick.h\"\n\nunsigned char gImage_niude[] = {\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,\n0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0