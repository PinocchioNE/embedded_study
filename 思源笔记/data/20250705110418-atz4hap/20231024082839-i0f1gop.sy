1608-wezillr","updated":"20240927132443"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240927131613-i2lfay3","Type":"NodeParagraph","Properties":{"id":"20240927131613-i2lfay3","updated":"20240927132351"},"Children":[{"Type":"NodeText","Data":"每个从机都有自己的7位地址id\n比如MPU6050是1101000\n但如果有相同的芯片挂在在同一条总线上，就需要修改地址id的最后几位"}]},{"ID":"20240927132351-2jf1jav","Type":"NodeParagraph","Properties":{"id":"20240927132351-2jf1jav","updated":"20240927132431"},"Children":[{"Type":"NodeText","Data":"用MPU6050举例，修改方式为：AD0接高电平就是11011001 AD0接低电平就是11011000"}]},{"ID":"20240927132443-yrkdsgs","Type":"NodeParagraph","Properties":{"id":"20240927132443-yrkdsgs","updated":"20240927132443"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240927132443-8adsz87.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]}]},{"ID":"20240927132420-uv4x0ma","Type":"NodeParagraph","Properties":{"id":"20240927132420-uv4x0ma","updated":"20240927132420"}},{"ID":"20240927133458-h8rtemt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20240927133458-h8rtemt","updated":"20250210090906"},"Children":[{"Type":"NodeText","Data":"数据解读"}]},{"ID":"20240927142329-o5tr88o","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20240927142329-o5tr88o","updated":"20250210090906"},"Children":[{"Type":"NodeText","Data":"指定地址写"}]},{"ID":"20240927142337-swthn43","Type":"NodeParagraph","Properties":{"id":"20240927142337-swthn43","updated":"20241008163357"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: 67vw;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240927142337-mjg9e1i.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 67vw;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20240927142352-l20mxsz","Type":"NodeParagraph","Properties":{"id":"20240927142352-l20mxsz","updated":"20240927142352"}},{"ID":"20240927133508-grhwgo0","Type":"NodeParagraph","Properties":{"id":"20240927133508-grhwgo0","updated":"20241017094818"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20240927133508-la9p8ru.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20240927133510-x63kjtb","Type":"NodeBlockquote","Properties":{"id":"20240927133510-x63kjtb","updated":"20240927145802"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20240927133624-uvaqf2z","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20240927133624-uvaqf2z","updated":"20240927145802"},"Children":[{"ID":"20240927133624-44kngof","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20240927133624-44kngof","updated":"20240927133624"},"Children":[{"ID":"20240927133516-iiey018","Type":"NodeParagraph","Properties":{"id":"20240927133516-iiey018","updated":"20240927133621"},"Children":[{"Type":"NodeText","Data":"首先起始条件：SCL高电平期间SDA拉低了，表示开始"}]}]},{"ID":"20240927133633-3f2ndxi","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20240927133633-3f2ndxi","updated":"20240927133633"},"Children":[{"ID":"20240927133633-u28scky","Type":"NodeParagraph","Properties":{"id":"20240927133633-u28scky","updated":"20240927133934"},"Children":[{"Type":"NodeText","Data":"开始后，SCL高电平期间SDA要发送数据，这里首先发的是从机ID 1101000 还有一位0表示读写位，表示要写入还是读取；高位先行，表示为0xD0"}]}]},{"ID":"20240927133936-7h7i327","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20240927133936-7h7i327","updated":"20240927133936"},"Children":[{"ID":"20240927133936-2ljh7sd","Type":"NodeParagraph","Properties":{"id":"20240927133936-2ljh7sd","updated":"20240927145555"},"Children":[{"Type":"NodeText","Data":"在读写位的后一位表示 接收从机的应答位，此时主机要释放SDA应该是高电平，但是从机此时要回答0表示要写入，根据线与逻辑，所以是低电平"}]}]},{"ID":"20240927145555-2i4t1vx","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20240927145555-2i4t1vx","updated":"20240927145802"},"Children":[{"ID":"20240927145555-p3u7wjh","Type":"NodeParagraph","Properties":{"id":"20240927145555-p3u7wjh","updated":"20240927145802"},"Children":[{"Type":"NodeText","Data":"又迅速由高电平变为低电平，因为从机要先释放SDA，然后迅速在时钟低电平的时候变换数据"}]}]}]}]},{"ID":"20240927150134-1ka1g7r","Type":"NodeParagraph","Properties":{"id":"20240927150134-1ka1g7r","updated":"20240927150134"}},{"ID":"20241107150009-0u1xqg9","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241107150009-0u1xqg9","updated":"20250326094604"},"Children":[{"Type":"NodeText","Data":"华大052芯片为什么tx、rx半双工切换一直失败"}]},{"ID":"20250210091002-wludk3h","Type":"NodeBlockquote","Properties":{"id":"20250210091002-wludk3h","updated":"20250210091011"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250210091005-c7440z0","Type":"NodeParagraph","Properties":{"id":"20250210091005-c7440z0","updated":"20250210091011"},"Children":[{"Type":"NodeText","Data":"原来的寄存器选错了"}]}]},{"ID":"20250210091015-w3dxubn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250210091015-w3dxubn","updated":"20250210091045"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"\n错误\n//\t\t\tUSART_DisableIrq(HC_USART1, USART_FLAG_TC); //关闭tx\t\t\n//\t\t\tUSART_EnableIrq(HC_USART1, USART_FLAG_RC); //开启rx\n\n\n正确\n\t\t\tusart1__close(USART_CR1_TE, USART_FLAG_TC); // 关闭tx\t\t\n\t\t\tusart1__open(USART_CR1_RE, USART_FLAG_RC);  // 开启rx\nvoid usart1__close(uint32_t u32State, uint32_t u32Irq)\n{\n\tREG_CLEARBITS(HC_USART1-\u003eCR1, u32State);  // 关闭 TX 发送\n\tUSART_DisableIrq(HC_USART1, u32Irq);  // 关闭 TX 发送完成中断\n\tUSART_ClearIrq(HC_USART1, u32Irq);   // 清除 TX 发送完成标志\n}\n\n\nvoid usart1__open(uint32_t u32State, uint32_t u32Irq)\n{\n\tREG_SETBITS(HC_USART1-\u003eCR1, u32State);  // 开启 TX 发送\n\tUSART_EnableIrq(HC_USART1, u32Irq);  // 使能 TX 发送完成中断（可选）\n\n}\n\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250210091031-ecopuh3","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250210091031-ecopuh3","updated":"20250326104208"},"Children":[{"Type":"NodeText","Data":"大端格式\u0026小端格式"}]},{"ID":"20250326094635-qc8rmbt","Type":"NodeBlockquote","Properties":{"id":"20250326094635-qc8rmbt","updated":"20250326094959"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250326094647-ky0x61z","Type":"NodeParagraph","Properties":{"id":"20250326094647-ky0x61z","updated":"20250326094840"},"Children":[{"Type":"NodeText","Data":"例如内存地址从0x4000开始存储，小端格式：存入一个0x12345678，那么从0x4000开始就是先存入78再56..."}]},{"ID":"20250326094841-m1b6avu","Type":"NodeParagraph","Properties":{"id":"20250326094841-m1b6avu","updated":"20250326094959"},"Children":[{"Type":"NodeText","Data":"大端格式：先存入12，再34"}]}]},{"ID":"20250326094643-rwh85pe","Type":"NodeParagraph","Properties":{"id":"20250326094643-rwh85pe","updated":"20250326094643"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250326094635-6gu0ph1.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250326094636-1ba7l69","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250326094636-1ba7l69","updated":"20250421132811"},"Children":[{"Type":"NodeText","Data":"地址*0x1000000       地址*0x10000什么意思"}]},{"ID":"20250326104212-haob21q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250326104212-haob21q","updated":"20250326104214"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    Update_Info.Checksum    = *(uint8_t *)(FLASH_APP1_ADDR_START + 0x24) * 0x1000000\n                            + *(uint8_t *)(FLASH_APP1_ADDR_START + 0x25) * 0x10000\n                            + *(uint8_t *)(FLASH_APP1_ADDR_START + 0x26) * 0x100\n                            + *(uint8_t *)(FLASH_APP1_ADDR_START + 0x27);\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250326104215-h86sgp9","Type":"NodeBlockquote","Properties":{"id":"20250326104215-h86sgp9","updated":"20250326104306"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250326104224-feo091i","Type":"NodeParagraph","Properties":{"id":"20250326104224-feo091i","updated":"20250326104306"},"Children":[{"Type":"NodeText","Data":"含义是："}]},{"ID":"20250326104249-ba06pv3","Type":"NodeParagraph","Properties":{"id":"20250326104249-ba06pv3","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"这些乘法操作是用来将单个字节按照位置组合成一个完整的32位整数："}]},{"ID":"20250326104249-92qpq4j","Type":"NodeList","ListData":{},"Properties":{"id":"20250326104249-92qpq4j","updated":"20250326104249"},"Children":[{"ID":"20250326104249-ih6xp4m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-ih6xp4m","updated":"20250326104249"},"Children":[{"ID":"20250326104249-1eyrv6j","Type":"NodeList","ListData":{},"Properties":{"id":"20250326104249-1eyrv6j","updated":"20250326104249"},"Children":[{"ID":"20250326104249-yod5v2v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-yod5v2v","updated":"20250326104249"},"Children":[{"ID":"20250326104249-389cnkh","Type":"NodeParagraph","Properties":{"id":"20250326104249-389cnkh","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x1000000 相当于将字节左移24位（3个字节的位置）"}]}]}]}]},{"ID":"20250326104249-i7mxjj7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-i7mxjj7","updated":"20250326104249"},"Children":[{"ID":"20250326104249-m8pyfz3","Type":"NodeParagraph","Properties":{"id":"20250326104249-m8pyfz3","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x1000000 = 16,777,216 (十进制) = 2^24"}]}]},{"ID":"20250326104249-5wben2p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-5wben2p","updated":"20250326104249"},"Children":[{"ID":"20250326104249-zivtrpg","Type":"NodeParagraph","Properties":{"id":"20250326104249-zivtrpg","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"例如，如果 *(uint8_t *)(FLASH_APP1_ADDR_START + 0x24) 的值是0x12，则"}]}]},{"ID":"20250326104249-ekw4co5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-ekw4co5","updated":"20250326104249"},"Children":[{"ID":"20250326104249-ew7tp6r","Type":"NodeParagraph","Properties":{"id":"20250326104249-ew7tp6r","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x12 * 0x1000000 = 0x12000000"}]}]},{"ID":"20250326104249-irw671v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-irw671v","updated":"20250326104249"},"Children":[{"ID":"20250326104249-1h1fmj8","Type":"NodeList","ListData":{},"Properties":{"id":"20250326104249-1h1fmj8","updated":"20250326104249"},"Children":[{"ID":"20250326104249-0hvqpx8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-0hvqpx8","updated":"20250326104249"},"Children":[{"ID":"20250326104249-eipqfti","Type":"NodeParagraph","Properties":{"id":"20250326104249-eipqfti","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x10000 相当于将字节左移16位（2个字节的位置）"}]}]}]}]},{"ID":"20250326104249-d0xuzi5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-d0xuzi5","updated":"20250326104249"},"Children":[{"ID":"20250326104249-vq769oe","Type":"NodeParagraph","Properties":{"id":"20250326104249-vq769oe","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x10000 = 65,536 (十进制) = 2^16"}]}]},{"ID":"20250326104249-93jmakz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-93jmakz","updated":"20250326104249"},"Children":[{"ID":"20250326104249-9ov5f3l","Type":"NodeParagraph","Properties":{"id":"20250326104249-9ov5f3l","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"例如，如果 *(uint8_t *)(FLASH_APP1_ADDR_START + 0x25) 的值是0x34，则"}]}]},{"ID":"20250326104249-r5lxzzr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250326104249-r5lxzzr","updated":"20250326104249"},"Children":[{"ID":"20250326104249-j9bd64z","Type":"NodeParagraph","Properties":{"id":"20250326104249-j9bd64z","updated":"20250326104249"},"Children":[{"Type":"NodeText","Data":"0x34 * 0x10000 = 0x00340000"}]}]}]},{"ID":"20250326104249-gdge1cg","Type":"NodeParagraph","Properties":{"id":"20250326104249-gdge1cg","updated":"20250326104303"},"Children":[{"Type":"NodeText","Data":"这样四个字节的组合过程是：\n0x12 * 0x1000000 + 0x34 * 0x10000 + 0x56 * 0x100 + 0x78 = 0x12345678"}]}]},{"ID":"20250326104328-w8ucprn","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250326104328-w8ucprn","updated":"20250423104514"},"Children":[{"Type":"NodeText","Data":"状态处理函数"}]},{"ID":"20250421133132-4oxufa3","Type":"NodeBlockquote","Properties":{"id":"20250421133132-4oxufa3","updated":"20250421133154"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250421133133-54x2v85","Type":"NodeParagraph","Properties":{"id":"20250421133133-54x2v85","updated":"20250421133154"},"Children":[{"Type":"NodeText","Data":"不同的结构体状态下对应不一样的函数"}]}]},{"ID":"20250421132812-sletgvh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250421132812-sletgvh","updated":"20250421132830"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"// 风扇状态定义\ntypedef enum {\n    FAN_STATE_OFF = 0,    // 关闭\n    FAN_STATE_LOW,        // 低速\n    FAN_STATE_MEDIUM,     // 中速\n    FAN_STATE_HIGH,       // 高速\n    FAN_STATE_MAX         // 状态数量\n} fan_state_t;\n\n// 风扇控制\ntypedef struct {\n    fan_state_t state;    // 当前状态\n} fan_t;\n\nfan_t my_fan = {FAN_STATE_OFF};  // 初始状态为关闭\n\n// 各状态处理函数\nvoid handle_off(void)\n{\n    // 关闭状态下的操作\n    printf(\"风扇已关闭\\n\");\n    stop_motor();\n}\n\nvoid handle_low(void)\n{\n    // 低速状态下的操作\n    printf(\"风扇低速运转\\n\");\n    set_motor_speed(30);\n}\n\nvoid handle_medium(void)\n{\n    // 中速状态下的操作\n    printf(\"风扇中速运转\\n\");\n    set_motor_speed(60);\n}\n\nvoid handle_high(void)\n{\n    // 高速状态下的操作\n    printf(\"风扇高速运转\\n\");\n    set_motor_speed(100);\n}\n\n// 状态处理函数表 handle_off是上面的函数\nstatic void (*fan_handlers[FAN_STATE_MAX])(void) = \n{\n    [FAN_STATE_OFF]    = handle_off,\n    [FAN_STATE_LOW]    = handle_low,\n    [FAN_STATE_MEDIUM] = handle_medium,\n    [FAN_STATE_HIGH]   = handle_high\n};\n\n// 按下按钮时更改状态\nvoid press_button(void)\n{\n    my_fan.state = (my_fan.state + 1) % FAN_STATE_MAX;  // 循环切换状态\n}\n\n// 主循环\nvoid main(void)\n{\n    while(1)\n    {\n        // 根据当前状态调用对应的处理函数\n        fan_handlers[my_fan.state]();\n        \n        // 等待按钮按下\n        if(button_pressed())\n        {\n            press_button();  // 更改状态\n        }\n        \n        delay(100);  // 延时100ms\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250421133108-trzw9up","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250421133108-trzw9up","updated":"20250507143412"},"Children":[{"Type":"NodeText","Data":"为什么电机采样电阻测出来的电流大小和实际adc读出来的不一样？为什么在电机电流恒定4A的情况下，电池包电量越低电机电流adc读数越大？"}]},{"ID":"20250423113014-3sne5re","Type":"NodeParagraph","Properties":{"id":"20250423113014-3sne5re","updated":"20250423113843"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250423113014-6mh7ys6.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250423113843-o0fpz2l.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250423104430-qf76ef8","Type":"NodeBlockquote","Properties":{"id":"20250423104430-qf76ef8","updated":"20250507143412"},"Children":[{"ID":"20250423105228-chgfe90","Type":"NodeParagraph","Properties":{"id":"20250423105228-chgfe90","updated":"20250423113637"},"Children":[{"Type":"NodeText","Data":"在实际检测的时候，钳流表钳的是电机线，这是一个平均电流，而adc采集的是三角波的顶点，是一个最大值，即我们采集和实际看的点不是一个点，所以读取的值有偏差。"}]},{"ID":"20250423104622-nzgviok","Type":"NodeParagraph","Properties":{"id":"20250423104622-nzgviok","updated":"20250507143412"},"Children":[{"Type":"NodeText","Data":"因为功率守恒（图中为并联）：\nU电 为"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"整条回路"},{"Type":"NodeText","Data":"的电压，I电 为"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"整条回路"},{"Type":"NodeText","Data":"的电流， U负为电机的电压 I负为电机的电流，P=UI 那么图中， U电*I电=U负*I负"}]},{"ID":"20250423105113-ka8jn4z","Type":"NodeParagraph","Properties":{"id":"20250423105113-ka8jn4z","updated":"20250423113748"},"Children":[{"Type":"NodeText","Data":"当电池包电压假设30V，负载上的 I负 始终为4A，电机内阻假设不变， 那么U负也不变，但是当电池包电压下降到25V的时候，U负和I负不变，I电就要上升，所以读取到的采样电阻的ADC值在不断上升"}]},{"ID":"20250423113646-ouozx63","Type":"NodeParagraph","Properties":{"id":"20250423113646-ouozx63","updated":"20250423113715"},"Children":[{"Type":"NodeText","Data":"并且当电压越小时，电机的峰值电流会更大，那么采集到的电流也会偏大"}]},{"Type":"NodeBlockquoteMarker","Data":"\u003e"}]},{"ID":"20250506092434-inde5vc","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250506092434-inde5vc","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"为什么ZB2481之前的电机电压ADC转换后对应不上实际电压值？"}]},{"ID":"20250506092434-n47i5ya","Type":"NodeBlockquote","Properties":{"id":"20250506092434-n47i5ya","updated":"20250506093157"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250506093121-w7d4pav","Type":"NodeParagraph","Properties":{"id":"20250506093121-w7d4pav","updated":"20250506093157"},"Children":[{"Type":"NodeText","Data":"原因是分频系数太小导致adc频率太高 将分频系数改为10即可"}]}]},{"ID":"20250506092438-v6o5l8a","Type":"NodeBlockquote","Properties":{"id":"20250506092438-v6o5l8a","updated":"20250506093142"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250506093142-cmqpsmy","Type":"NodeParagraph","Properties":{"id":"20250506093142-cmqpsmy","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"基于60MHz系统时钟的ADC分频分析："}]},{"ID":"20250506093142-yzq1t9d","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093142-yzq1t9d","updated":"20250506093142"},"Children":[{"ID":"20250506093142-gl900h6","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093142-gl900h6","updated":"20250506093142"},"Children":[{"ID":"20250506093142-sgywagw","Type":"NodeParagraph","Properties":{"id":"20250506093142-sgywagw","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"当前设置:"}]}]}]},{"ID":"20250506093142-4k0bstz","Type":"NodeList","ListData":{},"Properties":{"id":"20250506093142-4k0bstz","updated":"20250506093142"},"Children":[{"ID":"20250506093142-zi5x20u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-zi5x20u","updated":"20250506093142"},"Children":[{"ID":"20250506093142-e5rujt4","Type":"NodeParagraph","Properties":{"id":"20250506093142-e5rujt4","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"AdcMskClkDiv10 - 分频系数为10"}]}]},{"ID":"20250506093142-urh2ryy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-urh2ryy","updated":"20250506093142"},"Children":[{"ID":"20250506093142-k2iwl3m","Type":"NodeParagraph","Properties":{"id":"20250506093142-k2iwl3m","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"ADC时钟 = 60MHz ÷ 10 = 6MHz"}]}]}]},{"ID":"20250506093142-gkmx0so","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093142-gkmx0so","updated":"20250506093142"},"Children":[{"ID":"20250506093142-io7ap7n","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093142-io7ap7n","updated":"20250506093142"},"Children":[{"ID":"20250506093142-bijjfyr","Type":"NodeParagraph","Properties":{"id":"20250506093142-bijjfyr","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"ADC时钟频率要求:"}]}]}]},{"ID":"20250506093142-h0dyq95","Type":"NodeList","ListData":{},"Properties":{"id":"20250506093142-h0dyq95","updated":"20250506093142"},"Children":[{"ID":"20250506093142-t9eole7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-t9eole7","updated":"20250506093142"},"Children":[{"ID":"20250506093142-qf5tb5c","Type":"NodeParagraph","Properties":{"id":"20250506093142-qf5tb5c","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"大多数ADC模块要求时钟频率在1-14MHz之间"}]}]},{"ID":"20250506093142-p6nhm51","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-p6nhm51","updated":"20250506093142"},"Children":[{"ID":"20250506093142-6n6ep17","Type":"NodeParagraph","Properties":{"id":"20250506093142-6n6ep17","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"太高的频率会导致转换精度下降"}]}]},{"ID":"20250506093142-z7nbk72","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-z7nbk72","updated":"20250506093142"},"Children":[{"ID":"20250506093142-lupdso0","Type":"NodeParagraph","Properties":{"id":"20250506093142-lupdso0","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"太低的频率会使采样过慢"}]}]}]},{"ID":"20250506093142-kr9fr8y","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093142-kr9fr8y","updated":"20250506093142"},"Children":[{"ID":"20250506093142-6ofizix","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093142-6ofizix","updated":"20250506093142"},"Children":[{"ID":"20250506093142-b3zwdxt","Type":"NodeParagraph","Properties":{"id":"20250506093142-b3zwdxt","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"6MHz ADC时钟评估:"}]}]}]},{"ID":"20250506093142-iwp7fgs","Type":"NodeList","ListData":{},"Properties":{"id":"20250506093142-iwp7fgs","updated":"20250506093142"},"Children":[{"ID":"20250506093142-7p4xqzx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-7p4xqzx","updated":"20250506093142"},"Children":[{"ID":"20250506093142-4u06gej","Type":"NodeParagraph","Properties":{"id":"20250506093142-4u06gej","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"这个频率处于典型ADC工作范围的中间位置"}]}]},{"ID":"20250506093142-df7uxa5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-df7uxa5","updated":"20250506093142"},"Children":[{"ID":"20250506093142-61jv12z","Type":"NodeParagraph","Properties":{"id":"20250506093142-61jv12z","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"对于电机电流电压采样完全足够"}]}]},{"ID":"20250506093142-2yk823q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-2yk823q","updated":"20250506093142"},"Children":[{"ID":"20250506093142-ewqnoob","Type":"NodeParagraph","Properties":{"id":"20250506093142-ewqnoob","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"每次采样+转换约需2-5μs (取决于ADC位数和采样周期)"}]}]}]},{"ID":"20250506093142-c572ubn","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093142-c572ubn","updated":"20250506093142"},"Children":[{"ID":"20250506093142-pdqwjtw","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093142-pdqwjtw","updated":"20250506093142"},"Children":[{"ID":"20250506093142-a69nbis","Type":"NodeParagraph","Properties":{"id":"20250506093142-a69nbis","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"分频系数建议:"}]}]}]},{"ID":"20250506093142-cnut1ws","Type":"NodeList","ListData":{},"Properties":{"id":"20250506093142-cnut1ws","updated":"20250506093142"},"Children":[{"ID":"20250506093142-vtzlbz9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-vtzlbz9","updated":"20250506093142"},"Children":[{"ID":"20250506093142-88bo5yd","Type":"NodeParagraph","Properties":{"id":"20250506093142-88bo5yd","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"AdcMskClkDiv10(6MHz): 当前设置，平衡了速度和精度，适合大多数应用"}]}]},{"ID":"20250506093142-iv0r3ld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-iv0r3ld","updated":"20250506093142"},"Children":[{"ID":"20250506093142-u7o4klm","Type":"NodeParagraph","Properties":{"id":"20250506093142-u7o4klm","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"AdcMskClkDiv12(5MHz): 如果需要更稳定的结果，略微降低速度"}]}]},{"ID":"20250506093142-wq4xxcs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-wq4xxcs","updated":"20250506093142"},"Children":[{"ID":"20250506093142-qgfaraj","Type":"NodeParagraph","Properties":{"id":"20250506093142-qgfaraj","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"AdcMskClkDiv8(7.5MHz): 如果需要更快的采样速度，可能会略微降低稳定性"}]}]}]},{"ID":"20250506093142-fabq56g","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093142-fabq56g","updated":"20250506093142"},"Children":[{"ID":"20250506093142-dua8npv","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093142-dua8npv","updated":"20250506093142"},"Children":[{"ID":"20250506093142-fjliksu","Type":"NodeParagraph","Properties":{"id":"20250506093142-fjliksu","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"最终建议:"}]}]}]},{"ID":"20250506093142-i4b4fsn","Type":"NodeList","ListData":{},"Properties":{"id":"20250506093142-i4b4fsn","updated":"20250506093142"},"Children":[{"ID":"20250506093142-mg0ccb2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-mg0ccb2","updated":"20250506093142"},"Children":[{"ID":"20250506093142-6h0c6rc","Type":"NodeParagraph","Properties":{"id":"20250506093142-6h0c6rc","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"保持AdcMskClkDiv10设置即可"}]}]},{"ID":"20250506093142-ui2rzhk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-ui2rzhk","updated":"20250506093142"},"Children":[{"ID":"20250506093142-88aa7lw","Type":"NodeParagraph","Properties":{"id":"20250506093142-88aa7lw","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"对于60MHz系统时钟，分频10得到6MHz的ADC时钟是非常合理的"}]}]},{"ID":"20250506093142-g15rk87","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250506093142-g15rk87","updated":"20250506093142"},"Children":[{"ID":"20250506093142-vr2p89p","Type":"NodeParagraph","Properties":{"id":"20250506093142-vr2p89p","updated":"20250506093142"},"Children":[{"Type":"NodeText","Data":"这个设置能够在采样速度和采样精度之间取得很好的平衡"}]}]}]}]},{"ID":"20250423104430-o03bz6w","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250423104430-o03bz6w","updated":"20250509135939"},"Children":[{"Type":"NodeText","Data":"为什么ZB2481之前的pid控制电机转速不稳？会存在抖动？"}]},{"ID":"20250506091043-7yze57z","Type":"NodeBlockquote","Properties":{"id":"20250506091043-7yze57z","updated":"20250506093316"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250506093211-u4t8ig9","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093211-u4t8ig9","updated":"20250506093223"},"Children":[{"ID":"20250506093223-i7f1a3l","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250506093223-i7f1a3l","updated":"20250506093223"},"Children":[{"ID":"20250506093223-ubrlceb","Type":"NodeParagraph","Properties":{"id":"20250506093223-ubrlceb","updated":"20250506093223"},"Children":[{"Type":"NodeText","Data":"上一条原因，adc不准"}]}]}]},{"ID":"20250506093211-5o1suuz","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250506093211-5o1suuz","updated":"20250506093316"},"Children":[{"ID":"20250506093211-jrv4me5","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20250506093211-jrv4me5","updated":"20250506093316"},"Children":[{"ID":"20250506093211-uc81ejp","Type":"NodeParagraph","Properties":{"id":"20250506093211-uc81ejp","updated":"20250506093316"},"Children":[{"Type":"NodeText","Data":"电机pwm分辨率太低，只有100精度，将分辨率调整为1000后稳定性上升"}]}]}]}]},{"ID":"20250506091043-nfjm7do","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250506091043-nfjm7do","updated":"20250509142054"},"Children":[{"Type":"NodeText","Data":"ram和sram有什么区别"}]},{"ID":"20250509135940-mq6udcp","Type":"NodeBlockquote","Properties":{"id":"20250509135940-mq6udcp","updated":"20250509140337"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250509135944-tjyca2k","Type":"NodeParagraph","Properties":{"id":"20250509135944-tjyca2k","updated":"20250509140306"},"Children":[{"Type":"NodeText","Data":"sram是ram的一种特定类型，即静态ram"}]},{"ID":"20250509140307-8mfsb6r","Type":"NodeParagraph","Properties":{"id":"20250509140307-8mfsb6r","updated":"20250509140337"},"Children":[{"Type":"NodeText","Data":"ram整体就是存放临时变量、局部变量还有堆栈之类的"}]}]},{"ID":"20250509142045-5s3f08f","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250509142045-5s3f08f","updated":"20250512104243"},"Children":[{"Type":"NodeText","Data":"keil的option ram设置"}]},{"ID":"20250509142057-eag64pk","Type":"NodeParagraph","Properties":{"id":"20250509142057-eag64pk","updated":"20250509142102"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250509142057-84ybsz8.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250509142104-qqwtfzr","Type":"NodeBlockquote","Properties":{"id":"20250509142104-qqwtfzr","updated":"20250509142913"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250509142105-9wdt5uc","Type":"NodeParagraph","Properties":{"id":"20250509142105-9wdt5uc","updated":"20250509142913"},"Children":[{"Type":"NodeText","Data":"左边是程序开始运行的位置 即flash放程序的位置"}]},{"ID":"20250509142121-al8kd3f","Type":"NodeParagraph","Properties":{"id":"20250509142121-al8kd3f","updated":"20250509142133"},"Children":[{"Type":"NodeText","Data":"右边为ram的起始位置"}]}]},{"ID":"20250509142901-0bjm7jk","Type":"NodeParagraph","Properties":{"id":"20250509142901-0bjm7jk","updated":"20250509142901"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250509142901-o47td1d.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512104222-n86den5","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250512104222-n86den5","updated":"20250512110244"},"Children":[{"Type":"NodeText","Data":"bootloader配置方法\u0026DVC2108芯片bootloader跳转问题"}]},{"ID":"20250512104245-dgcclsy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250512104245-dgcclsy","updated":"20250512110244"},"Children":[{"Type":"NodeText","Data":"方法流程"}]},{"ID":"20250512104614-g1fm0iv","Type":"NodeParagraph","Properties":{"id":"20250512104614-g1fm0iv","updated":"20250512105038"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512104614-o5skq7x.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"图1"}]},{"ID":"20250512104643-bplhgpv","Type":"NodeParagraph","Properties":{"id":"20250512104643-bplhgpv","updated":"20250512105041"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512104643-cih0f2z.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"图2"}]},{"ID":"20250512104742-zs2w8j7","Type":"NodeBlockquote","Properties":{"id":"20250512104742-zs2w8j7","updated":"20250512110230"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250512104755-fvv2oan","Type":"NodeParagraph","Properties":{"id":"20250512104755-fvv2oan","updated":"20250512105135"},"Children":[{"Type":"NodeText","Data":"1.先确定flash的大小以及地址，以DVC2108为例，flash地址为0x08000000-0x0800FFFF，一共64k，每一页大小为128byte（字节），"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong text","TextMarkTextContent":"扇区大小为4k（很重要）"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]},{"ID":"20250512104940-cswofan","Type":"NodeParagraph","Properties":{"id":"20250512104940-cswofan","updated":"20250512104947"},"Children":[{"Type":"NodeText","Data":"2.编写bootloader，"}]},{"ID":"20250512105302-m4m6y4o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250512105302-m4m6y4o","updated":"20250512105314"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"#define FLASH_APP0_ADDR_START      \t((uint32_t)0x08000600) // APP0 30K   0x08000600\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250512105302-yrbqsk3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250512105302-yrbqsk3","updated":"20250512105306"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"/* RAM相关宏定义 */\n#define SRAM_BASE           ((uint32_t)0x20000000UL)    // RAM基地址  这个地址即为图2中SRAM的起始地址\n#define RAM_SIZE            ((uint32_t)0x00002000UL)    // RAM尺寸 (8KB) 图2中显示ram大小为8k\nvoid JumpTo(uint32_t Addr)\n{\n    uint32_t JumpAddress;\n    func_ptr_t JumpToApplication;\n    uint32_t u32StackTop =  *((__IO uint32_t *)Addr);    // 读取APP程序栈顶地址  注意，传入的addr虽然为0x08000600，但实际读取有效值后会变为0x20000000~0x20001FFF内\n\n    /* 判断栈顶地址有效性 */\n    if ((u32StackTop \u003e SRAM_BASE) \u0026\u0026 (u32StackTop \u003c= (SRAM_BASE + RAM_SIZE)))\n\n    {\n\t\t\t\t__disable_irq();\n        /* 配置跳转到用户程序复位中断入口 */\n        JumpAddress = *(__IO uint32_t *)(Addr + 4);\n        JumpToApplication = (func_ptr_t)JumpAddress;\n\t\t\t\n        /* 初始化用户程序的栈顶指针 */\n        __set_MSP(*(__IO uint32_t *)Addr);\n        JumpToApplication();\n    }\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250512105302-lcjyt5b","Type":"NodeParagraph","Properties":{"id":"20250512105302-lcjyt5b","updated":"20250512105340"},"Children":[{"Type":"NodeText","Data":"3.设置bootloader的地址配置"}]},{"ID":"20250512105407-jlrrwr4","Type":"NodeParagraph","Properties":{"id":"20250512105407-jlrrwr4","updated":"20250512105623"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512105407-83oaz6y.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"bootloader从flash初始地址开始，共1.5k，即0x600"}]},{"ID":"20250512105432-tmvck93","Type":"NodeParagraph","Properties":{"id":"20250512105432-tmvck93","updated":"20250512105449"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512105432-5zx0qmw.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"flash地址 64k"}]},{"ID":"20250512105459-zfu8tjl","Type":"NodeParagraph","Properties":{"id":"20250512105459-zfu8tjl","updated":"20250512105648"},"Children":[{"Type":"NodeText","Data":"4.设置app程序的地址配置 从bootloader后面开始，大小就写64k，不用管"}]},{"ID":"20250512105544-249xaiv","Type":"NodeParagraph","Properties":{"id":"20250512105544-249xaiv","updated":"20250512105544"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512105544-aeo0wf6.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512105501-weoelno","Type":"NodeParagraph","Properties":{"id":"20250512105501-weoelno","updated":"20250512105729"},"Children":[{"Type":"NodeText","Data":"5.设置app程序的向量表的偏移地址"}]},{"ID":"20250512105734-1lo9mzg","Type":"NodeParagraph","Properties":{"id":"20250512105734-1lo9mzg","updated":"20250512105815"},"Children":[{"Type":"NodeText","Data":"从boot后面开始，并且flash的基地址就是0x08000000，所以只需要便宜0x600即可，不需要写0x08000600"}]},{"ID":"20250512105729-alcepkm","Type":"NodeParagraph","Properties":{"id":"20250512105729-alcepkm","updated":"20250512105729"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512105729-w91v62y.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512105501-76yv0jh","Type":"NodeParagraph","Properties":{"id":"20250512105501-76yv0jh","updated":"20250512110230"},"Children":[{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"text","TextMarkTextContent":"6.注意！dvc2108芯片的扇区大小为4k，boot的地址范围和app的部分地址范围都在前4k内，如果配置中选择了erase sectros就会擦除扇区，所以烧完bootloader，再烧录app的时候就会把bootloader都删掉。所以，如果选择do not erase就不会删除这片扇区"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]},{"ID":"20250512110125-s36as78","Type":"NodeParagraph","Properties":{"id":"20250512110125-s36as78","updated":"20250512110125"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512110125-fajksno.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512105502-vcwq0bj","Type":"NodeParagraph","Properties":{"id":"20250512105502-vcwq0bj","updated":"20250512105502"}},{"ID":"20250512105503-b7lhcyu","Type":"NodeParagraph","Properties":{"id":"20250512105503-b7lhcyu","updated":"20250512105503"}}]},{"ID":"20250512105457-4rmb3dn","Type":"NodeParagraph","Properties":{"id":"20250512105457-4rmb3dn","updated":"20250512105457"}},{"ID":"20250512104648-6561166","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250512104648-6561166","updated":"20250512112136"},"Children":[{"Type":"NodeText","Data":"遇到的问题"}]},{"ID":"20250512110249-y69f5bk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20250512110249-y69f5bk","updated":"20250512112136"},"Children":[{"Type":"NodeText","Data":"问题一 为什么boot跳转一直失败"}]},{"ID":"20250512104300-p9y10su","Type":"NodeBlockquote","Properties":{"id":"20250512104300-p9y10su","updated":"20250512111107"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250512104450-pyzsdym","Type":"NodeParagraph","Properties":{"id":"20250512104450-pyzsdym","updated":"20250512110632"},"Children":[{"Type":"NodeText","Data":"前置条件：bootloader大小1.5k 地址0x08000000~0x08000600     app起始地址：0x08000600"}]},{"ID":"20250512104453-n9qb4ew","Type":"NodeParagraph","Properties":{"id":"20250512104453-n9qb4ew","updated":"20250512110556"},"Children":[{"Type":"NodeText","Data":"现象：变量中可以看到u32StackTop是0xFFFFFFFF，说明跳转的时候app地址内没有程序"}]},{"ID":"20250512110515-q0d8qod","Type":"NodeParagraph","Properties":{"id":"20250512110515-q0d8qod","updated":"20250512110601"},"Children":[{"Type":"NodeText","Data":"\t   再从图二中也可以看到0x08000600之后的地址都是空的FF"}]},{"ID":"20250512110546-jykuqq0","Type":"NodeParagraph","Properties":{"id":"20250512110546-jykuqq0","updated":"20250512110803"},"Children":[{"Type":"NodeText","Data":"原因：因为dvc2108芯片的扇区大小为4k，所以烧完bootloader再烧app程序的时候，如果配置中选择了erase sectors会将bootloader一起删掉（见上述流程中的第6点）"}]},{"ID":"20250512110824-g29k122","Type":"NodeParagraph","Properties":{"id":"20250512110824-g29k122","updated":"20250512111019"},"Children":[{"Type":"NodeText","Data":"\t   而华大的芯片配置bootloader时没有出现过这种现象的原因是，华大芯片扇区大小为512字节，一般boot超过了这个大小，所以以前没有遇到过这种问题"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: calc(50% - 8px);"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512110929-t2oc1eo.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: calc(50% - 8px);\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512110515-jr2srtx","Type":"NodeParagraph","Properties":{"id":"20250512110515-jr2srtx","updated":"20250512111107"},"Children":[{"Type":"NodeText","Data":"解决方法：将bootloader大小改为4k，或者依旧保持1.5k，但是烧录app的时候要选择do not erase（不删除扇区）"}]}]},{"ID":"20250512104538-j841raq","Type":"NodeParagraph","Properties":{"id":"20250512104538-j841raq","updated":"20250512104538"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512104538-al3uqsy.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512110506-crv77pr","Type":"NodeParagraph","Properties":{"id":"20250512110506-crv77pr","updated":"20250512110506"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250512110506-hqbtsfv.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250512112129-9nukeok","Type":"NodeParagraph","Properties":{"id":"20250512112129-9nukeok","updated":"20250512112129"}},{"ID":"20250512112131-auxh7lx","Type":"NodeParagraph","Properties":{"id":"20250512112131-auxh7lx","updated":"20250512112131"}},{"ID":"20250512112131-3e85nv5","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250512112131-3e85nv5","updated":"20250512150032"},"Children":[{"Type":"NodeText","Data":"为什么设置的app地址是0x08000600，但是uint32"},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"_"}]},{"Type":"NodeText","Data":"t u32StackTop "},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"="}]},{"Type":"NodeText","Data":"  "},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeText","Data":"(("},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"_"}]},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"_"}]},{"Type":"NodeText","Data":"IO uint32"},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"_"}]},{"Type":"NodeText","Data":"t "},{"Type":"NodeBackslash","Data":"span","Children":[{"Type":"NodeText","Data":"*"}]},{"Type":"NodeText","Data":")Addr); 读取有效值后就会变成ram地址空间的值"}]},{"ID":"20250512112131-5h8ljja","Type":"NodeParagraph","Properties":{"id":"20250512112131-5h8ljja","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"这个问题涉及到ARM架构启动过程中向量表的工作原理。"}]},{"ID":"20250512112131-3nji5fg","Type":"NodeParagraph","Properties":{"id":"20250512112131-3nji5fg","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"当您从地址0x08000600读取值时，您实际上是在读取应用程序的向量表。在ARM Cortex-M架构中，向量表的第一个条目(地址0x08000600)是初始栈指针(SP)的值，即栈顶地址。"}]},{"ID":"20250512112131-wfh0xu1","Type":"NodeParagraph","Properties":{"id":"20250512112131-wfh0xu1","updated":"20250512112207"},"Children":[{"Type":"NodeText","Data":"这个值必须指向RAM区域，因为栈必须位于RAM中而不是Flash中。"}]},{"ID":"20250512112131-3tnbi00","Type":"NodeParagraph","Properties":{"id":"20250512112131-3tnbi00","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"读取地址0x08000600的内容时，得到的是应用程序设置的栈顶地址，这个值自然会指向RAM地址空间(通常是SRAM区域的高地址部分)。"}]},{"ID":"20250512112131-j4ikpas","Type":"NodeParagraph","Properties":{"id":"20250512112131-j4ikpas","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"这是完全正常的行为，因为："}]},{"ID":"20250512112131-53jp0ry","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20250512112131-53jp0ry","updated":"20250512112131"},"Children":[{"ID":"20250512112131-7nroemq","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20250512112131-7nroemq","updated":"20250512112131"},"Children":[{"ID":"20250512112131-9fi2bt8","Type":"NodeParagraph","Properties":{"id":"20250512112131-9fi2bt8","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"向量表的第一个字(0偏移)存储的是栈顶指针值"}]}]},{"ID":"20250512112131-m8h7dd9","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20250512112131-m8h7dd9","updated":"20250512112131"},"Children":[{"ID":"20250512112131-9sk5qmf","Type":"NodeParagraph","Properties":{"id":"20250512112131-9sk5qmf","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"向量表的第二个字(4字节偏移)存储的是复位向量(Reset_Handler的地址)"}]}]},{"ID":"20250512112131-vpee4xt","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20250512112131-vpee4xt","updated":"20250512112131"},"Children":[{"ID":"20250512112131-9530opp","Type":"NodeParagraph","Properties":{"id":"20250512112131-9530opp","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"栈指针必须指向RAM区域"}]}]}]},{"ID":"20250512112131-hqycuo6","Type":"NodeParagraph","Properties":{"id":"20250512112131-hqycuo6","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"这就是为什么当您从0x08000600读取到的值看起来像RAM地址 - 因为它就是RAM地址，指定了应用程序启动时栈应该位于的位置。"}]},{"ID":"20250512112131-htr9pm8","Type":"NodeParagraph","Properties":{"id":"20250512112131-htr9pm8","updated":"20250512112131"},"Children":[{"Type":"NodeText","Data":"在跳转过程中，Bootloader正确地读取了这个栈顶指针并使用它来设置SP寄存器，然后跳转到复位向量地址开始执行应用程序。"}]},{"ID":"20250512140103-995cm90","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250512140103-995cm90","updated":"20250519104057"},"Children":[{"Type":"NodeText","Data":"ota流程"}]},{"ID":"20250512150033-zswhb1z","Type":"NodeBlockquote","Properties":{"id":"20250512150033-zswhb1z","updated":"20250512150313"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250512150038-m4109jv","Type":"NodeParagraph","Properties":{"id":"20250512150038-m4109jv","updated":"20250512150113"},"Children":[{"Type":"NodeText","Data":"1.先将要更新的固件写入app1区中"}]},{"ID":"20250512150113-2pp402m","Type":"NodeParagraph","Properties":{"id":"20250512150113-2pp402m","updated":"20250512150138"},"Children":[{"Type":"NodeText","Data":"2.上电后bootloader检测到app1有数据，将固件复制到app0中"}]},{"ID":"20250512150138-200e68h","Type":"NodeParagraph","Properties":{"id":"20250512150138-200e68h","updated":"20250512150313"},"Children":[{"Type":"NodeText","Data":"3.如果中途断电了，再次上电会根据持久标志位判断是不是有固件要更新，如果有就更新，直到更新完毕才会清除持久标志位"}]}]},{"ID":"20250519104028-0j5ps5k","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250519104028-0j5ps5k","updated":"20250612090622"},"Children":[{"Type":"NodeText","Data":"串口在接收解析后发送总会把整个缓冲区先发出来再发实际数据？"}]},{"ID":"20250519104059-11o6s5e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250519104059-11o6s5e","updated":"20250519104121"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"    case BmsRxState_End:        // 帧尾\n\t\tif (0xF2 != uart_rx_data)\n        {\n            bms_rx_clear();\n        }\n        else\n        {\n\t\t\tbms_rx.tick = 0; \t \n\t\t\t//绝对不能打开 会影响\n//\t\t\tLL_USART_DisableIT_RXNE(USART2);//关闭rx\t\n//\t\t\tLL_USART_DisableIT_PE(USART2);\n//\t\t\tLL_USART_DisableIT_ERROR(USART2);\n//\t\t\tLL_USART_DisableDirectionRx(USART2); \n//\t\t\tLL_USART_EnableIT_TXE(USART2);//开启tx Enable TX Empty Interrupt  \n \t\t\t\n\t\t\tbms_rx.sucess_flag = 1;\n\t\t\tbms_rx.flag = 0;\t\n            bms_rx_clear(); \n\t\t\t\n        }\n        break;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250519104124-26tsb3e","Type":"NodeBlockquote","Properties":{"id":"20250519104124-26tsb3e","updated":"20250519104245"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250519104126-gcdqawz","Type":"NodeParagraph","Properties":{"id":"20250519104126-gcdqawz","updated":"20250519104245"},"Children":[{"Type":"NodeText","Data":"原因是，接收完数据的尾帧后立刻打开了tx，而实际上缓冲区数据还没有写入，index_in和index_out可能并没有对齐，所以只有在全部写入再发送才是正确的"}]}]},{"ID":"20250612090615-s4xezhv","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250612090615-s4xezhv","updated":"20250619112727"},"Children":[{"Type":"NodeText","Data":"红外脏污传感器工作原理"}]},{"ID":"20250619112719-k6g75iw","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250619112719-k6g75iw","updated":"20250619112727"},"Children":[{"Type":"NodeText","Data":"发射端"}]},{"ID":"20250619112724-idg02ug","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250619112724-idg02ug","updated":"20250619112727"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA=="},{"Type":"NodeCodeBlockCode","Data":"开机启动\n    ↓\n设置初始功率(1880)\n    ↓\n进入校准状态\n    ↓\n等待3秒稳定\n    ↓\n开始自适应调节\n    ↓\n┌─────────────────────┐\n│   每100ms检查AD值    │\n│                     │\n│ AD\u003e1350 → 功率-10   │\n│ AD\u003e1100 → 进入工作   │\n│ AD\u003e100  → 功率+10   │\n│ AD≤100  → 报故障    │\n└─────────────────────┘\n    ↓\n进入工作状态(功率固定)\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250612090637-zgvdyo7","Type":"NodeParagraph","Properties":{"id":"20250612090637-zgvdyo7","updated":"20250612090637"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250612090637-x6yzahj.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250612094550-gchisph","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250612094550-gchisph","updated":"20250612094600"},"Children":[{"Type":"NodeText","Data":"无水检测\u0026水满检测"}]},{"ID":"20250612094600-whwqfiv","Type":"NodeParagraph","Properties":{"id":"20250612094600-whwqfiv","updated":"20250612094600"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: 1191px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250612094600-8xnaell.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 1191px;\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20250612094708-g6gietb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250612094708-g6gietb","updated":"20250612094830"},"Children":[{"Type":"NodeText","Data":"无水检测"}]},{"ID":"20250612094714-60a0db5","Type":"NodeParagraph","Properties":{"id":"20250612094714-60a0db5","updated":"20250612094714"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250612094714-8yrpf83.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250612094828-egb93rh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250612094828-egb93rh","updated":"20250707134816"},"Children":[{"Type":"NodeText","Data":"水满检测"}]},{"ID":"20250612094833-9xojhh8","Type":"NodeParagraph","Properties":{"id":"20250612094833-9xojhh8","updated":"20250612094833"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250612094833-rd8w443.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250612113056-sss4tr1","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20250612113056-sss4tr1","updated":"20250708153701"},"Children":[{"Type":"NodeText","Data":"边角识别"}]},{"ID":"20250708142049-8szfhbk","Type":"NodeParagraph","Properties":{"id":"20250708142049-8szfhbk","updated":"20250708142050"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250708141903-log2edv.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20250707134819-cpkenep","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250707134819-cpkenep","updated":"20250708150709"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA=="},{"Type":"NodeCodeBlockCode","Data":"传感器部分：\n┌─────────────┐    ┌─────────────┐\n│  IR LED     │───→│   墙面/边角  │\n│ (红外发射)   │    │  (反射面)   │\n└─────────────┘    └─────────────┘\n                          │\n                          ↓ 反射光\n                   ┌─────────────┐\n                   │光电二极管    │\n                   │(80mV信号) │\n                   └─────────────┘\n                          │\n                          ↓ 微弱电压信号\n放大部分：\n                   ┌─────────────┐\n                   │  OPA0\u0026OPA1二级放大  \n                   │  (运放放大)  │ 放大36.8倍\n                   └─────────────┘\n                          │\n                          ↓ 放大后电压信号(V级)\n比较部分：\n                   ┌─────────────┐\n                   │    VC0      │\n                   │ (电压比较器) │\n                   └─────────────┘\n                          │\n                          ↓ 数字脉冲\n计数部分：\n                   ┌─────────────┐\n                   │  VC_cnt++   │\n                   │  (中断计数) │\n                   └─────────────┘\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250707134857-fuvtpo2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20250707134857-fuvtpo2","updated":"20250707134858"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA=="},{"Type":"NodeCodeBlockCode","Data":"// 根据引脚配置推测硬件连接：\n// PB10/PB13 (OPA_INP) ← 连接传感器信号\n// PB02/PB12 (OPA_INN) ← 连接参考地或偏置电压\n// PB11/PB14 (OPA_OUT) → 连接到比较器输入端 (PB01)\n\n// 信号流向：\n// 传感器 → OPA输入 → OPA输出 → 比较器P端 → 中断计数\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20250708103120-r5gmpgb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20250708103120-r5gmpgb","updated":"20250708153701"},"Children":[{"Type":"NodeText","Data":"逻辑流程"}]},{"ID":"20250708111147-axspsl3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20250708111147-axspsl3","updated":"20250708153701"},"Children":[{"Type":"NodeText","Data":"完整运行逻辑"}]},{"ID":"20250708111141-qrlpe4c","Type":"NodeBlockquote","Properties":{"id":"20250708111141-qrlpe4c","updated":"20250708141321"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250708111141-2en7l8l","Type":"NodeParagraph","Properties":{"id":"20250708111141-2en7l8l","updated":"20250708111512"},"Children":[{"Type":"NodeText","Data":"初始化配置"}]},{"ID":"20250708111429-5rvks6y","Type":"NodeParagraph","Properties":{"id":"20250708111429-5rvks6y","updated":"20250708111437"}},{"ID":"20250708111429-zequx0p","Type":"NodeParagraph","Properties":{"id":"20250708111429-zequx0p","updated":"20250708111429"},"Children":[{"Type":"NodeText","Data":"进入边角任务"}]},{"ID":"20250708111426-77icz9k","Type":"NodeParagraph","Properties":{"id":"20250708111426-77icz9k","updated":"20250708111426"}},{"ID":"20250708111423-b2lli2g","Type":"NodeParagraph","Properties":{"id":"20250708111423-b2lli2g","updated":"20250708133033"},"Children":[{"Type":"NodeText","Data":"第1ms 运放校零，打开左前边角红外接收，打开左前边角红外发射（5khz），读取当前方向的出厂校验值"}]},{"ID":"20250708132110-g8y2krr","Type":"NodeParagraph","Properties":{"id":"20250708132110-g8y2krr","updated":"20250708132110"}},{"ID":"20250708132110-vsdx29o","Type":"NodeParagraph","Properties":{"id":"20250708132110-vsdx29o","updated":"20250708132444"},"Children":[{"Type":"NodeText","Data":"第4ms 配置VC(模拟电压比较器)的比较电压值，VC中断关闭，VC控制开启"}]},{"ID":"20250708132359-8rnwvcv","Type":"NodeParagraph","Properties":{"id":"20250708132359-8rnwvcv","updated":"20250708132400"}},{"ID":"20250708132400-scvpt3q","Type":"NodeParagraph","Properties":{"id":"20250708132400-scvpt3q","updated":"20250708132413"},"Children":[{"Type":"NodeText","Data":"第5ms VC中断开启"}]},{"ID":"20250708132414-u0h7q3u","Type":"NodeParagraph","Properties":{"id":"20250708132414-u0h7q3u","updated":"20250708132415"}},{"ID":"20250708132415-yh1qyi4","Type":"NodeParagraph","Properties":{"id":"20250708132415-yh1qyi4","updated":"20250708134303"},"Children":[{"Type":"NodeText","Data":"第10ms VC控制关闭 VC中断关闭"}]},{"ID":"20250708132503-eai66rt","Type":"NodeParagraph","Properties":{"id":"20250708132503-eai66rt","updated":"20250708132503"}},{"ID":"20250708132504-kv38et0","Type":"NodeParagraph","Properties":{"id":"20250708132504-kv38et0","updated":"20250708141321"},"Children":[{"Type":"NodeText","Data":"第11ms 关闭发射 获取vc中断触发次数，滤波（判断连续触发次数是否达到3次），关闭红外发射"}]},{"ID":"20250708134607-u1bkorf","Type":"NodeParagraph","Properties":{"id":"20250708134607-u1bkorf","updated":"20250708141239"},"Children":[{"Type":"NodeText","Data":"​​"}]},{"ID":"20250708134356-agicdqi","Type":"NodeParagraph","Properties":{"id":"20250708134356-agicdqi","updated":"20250708134618"},"Children":[{"Type":"NodeText","Data":"第20ms 计时清零 重新开始"}]},{"ID":"20250708141251-e7z97ox","Type":"NodeParagraph","Properties":{"id":"20250708141251-e7z97ox","updated":"20250708141317"},"Children":[{"Type":"NodeText","Data":"即发射一次的周期为20ms，四贴边全部轮转发射一遍需要80ms，所以判定一次边角触发至少240ms"}]},{"ID":"20250708141243-nik4u4l","Type":"NodeParagraph","Properties":{"id":"20250708141243-nik4u4l","updated":"20250708141243"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"height: 50vh"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"rename_file"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/rename_file-20250708141155-h7y34si.jpeg"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"height: 50vh\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20250708141231-pulukkb","Type":"NodeParagraph","Properties":{"id":"20250708141231-pulukkb","updated":"20250708141250"}}]},{"ID":"20250708110939-sfa0muh","Type":"NodeBlockquote","Properties":{"id":"20250708110939-sfa0muh","updated":"20250708153701"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20250708110940-2ynh1hh","Type":"NodeParagraph","Properties":{"id":"20250708110940-2ynh1hh","updated":"20250708110940"},"Children":[{"Type":"NodeText","Data":"1.输出配置\n高级定时器ATIM3 共6路独立PWM 使用4路 分别控制左前右前绿灯PWM、左前右前贴边的红外PWM\n高级定时器ATIM1 共2路独立PWM 使用2路 分别控制左右两边的PWM\n频率均为5khz\nApp_Timer3Cfg(6000, 3000, 3000); //\nmhz对应微秒\n时钟频率为60mhz    6000/60 = 100微秒\n周期为 1/100 = 0.01mhz = 10khz\n又因为配置为三角波 所以 10khz / 2 = 5khz"}]},{"ID":"20250708110950-cuc4tdp","Type":"NodeParagraph","Properties":{"id":"20250708110950-cuc4tdp","updated":"20250708110951"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: calc(50% - 8px);"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"rename_file"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/rename_file-20250708110728-ivo32y2.jpeg"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: calc(50% - 8px);\"}"},{"Type":"NodeText","Data":"​"}]},{"ID":"20250708110953-x9fn5vb","Type":"NodeParagraph","Properties":{"id":"20250708110953-x9fn5vb","updated":"20250708134900"},"Children":[{"Type":"NodeText","Data":"2.发射逻辑为：每20ms一个周期，一个周期内只打开一个发射管，且模拟电压比较器的中断只打开5ms"}]},{"ID":"20250708134900-u7ntt60","Type":"NodeParagraph","Properties":{"id":"20250708134900-u7ntt60","updated":"20250708135055"},"Children":[{"Type":"NodeText","Data":"理论上，发波频率5khz即200微秒发一次，即5ms内最多接收到25个中断"}]},{"ID":"20250708135049-5lzggq7","Type":"NodeParagraph","Properties":{"id":"20250708135049-5lzggq7","updated":"20250708135049"},"Children":[{"Type":"NodeText","Data":"#define VC_CNT_VALUE\t(18)\n#define VC_CNT_LIMIT    (30)"}]},{"ID":"20250708135057-y0x84hk","Type":"NodeParagraph","Properties":{"id":"20250708135057-y0x84hk","updated":"20250708153455"},"Children":[{"Type":"NodeText","Data":"程序中设定的触发边角的电压值范围为  3300mv / 64 级 ＝51.56mv       51.56mv * 18 = 928.125mv      51.56mv * 30 = 1546.875mv"}]},{"ID":"20250708135614-el6rdwi","Type":"NodeParagraph","Properties":{"id":"20250708135614-el6rdwi","updated":"20250708153723"},"Children":[{"Type":"NodeText","Data":"在出厂校验完后 每个边角都会重新确定VC_CNT_VALUE的大小"}]},{"ID":"20250708153701-bst8e5t","Type":"NodeParagraph","Properties":{"id":"20250708153701-bst8e5t","updated":"20250708153701"}},{"ID":"20250708141039-elr08ws","Type":"NodeParagraph","Properties":{"id":"20250708141039-elr08ws","updated":"20250708141559"},"Children":[{"Type":"NodeText","Data":"3.将接收到的红外电压信号经过两级opa（运算放大器）进行放大     （INP为正极（输入），INN为负极，参考电压或地）"}]},{"ID":"20250708141727-ksm82c4","Type":"NodeParagraph","Properties":{"id":"20250708141727-ksm82c4","updated":"20250708141831"},"Children":[{"Type":"NodeText","Data":"图中为同向放大器，放大比例为 1+ (Rf / Rin)   Rf反馈电阻  Rin输入电阻"}]},{"ID":"20250708141914-2h9drcn","Type":"NodeParagraph","Properties":{"id":"20250708141914-2h9drcn","updated":"20250708142002"},"Children":[{"Type":"NodeText","Data":"一级放大为4倍 二级放大为9.2倍 所以共放大36.8倍"}]},{"ID":"20250708141559-0c2adtu","Type":"NodeParagraph","Properties":{"id":"20250708141559-0c2adtu","updated":"20250708141719"},"Children":[{"Type":"NodeText","Data":"从PB14输出到PB10，最后输出到PB01（内部连接，给模拟电压比较器比较）"}]},{"ID":"20250708141040-0l77hb6","Type":"NodeParagraph","Properties":{"id":"20250708141040-0l77hb6","updated":"20250708142044"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Properties":{"style":"width: calc(50% - 8px);"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20250707174202-dpu4hp0.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: calc(50% - 8px);\"}"},{"Type":"NodeText","Data":"​​"}]},{"ID":"20250708141041-5a186ox","Type":"NodeParagraph","Properties":{"id":"20250708141041-5a186ox","updated":"20250708142058"}},{"ID":"20250708142058-4k7bt0w","Type":"NodeParagraph","Properties":{"id":"20250708142058-4k7bt0w","updated":"20250708151225"},"Children":[{"Type":"NodeText","Data":"4.在5ms内计数模拟电压比较器触发的次数，内部分级为64级，在第11ms与出厂校验的标定值进行比较，判断是否靠近边角"}]},{"ID":"20250708150835-cvvwxt5","Type":"NodeParagraph","Properties":{"id":"20250708150835-cvvwxt5","updated":"20250708151117"},"Children":[{"Type":"NodeText","Data":"电压比较器的正端连接的是PB01 负端连的是内置电阻分压输出的电压 即3.3v      3300 / 64 = 51mv"}]},{"ID":"20250708150911-jm1spk6","Type":"NodeParagraph","Properties":{"id":"20250708150911-jm1spk6","updated":"20250708152001"}},{"ID":"20250708152002-g4jq29q","Type":"NodeParagraph","Properties":{"id":"20250708152002-g4jq29q","updated":"20250708152017"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"配置解释"}]},{"ID":"20250708152237-7e3av2u","Type":"NodeParagraph","Properties":{"id":"20250708152237-7e3av2u","updated":"20250708152237"},"Children":[{"Type":"NodeText","Data":"VcInitStruct.enVcFilterSrcClk = VcFilterClkPCLK;"}]},{"ID":"20250708152238-9qijidh","Type":"NodeParagraph","Properties":{"id":"20250708152238-9qijidh","updated":"20250708152258"},"Children":[{"Type":"NodeText","Data":"滤波时钟选择系统时钟60MHz"}]},{"ID":"20250708152318-deknret","Type":"NodeParagraph","Properties":{"id":"20250708152318-deknret","updated":"20250708152318"}},{"ID":"20250708152003-l1md0wv","Type":"NodeParagraph","Properties":{"id":"20250708152003-l1md0wv","updated":"20250708152140"},"Children":[{"Type":"NodeText","Data":"VcInitStruct.enVcFilterTime   = VcFilterFltClk15;    /* VC输出滤波宽度小于15个滤波时钟的信号 */"}]},{"ID":"20250708152031-scnd19o","Type":"NodeList","ListData":{},"Properties":{"id":"20250708152031-scnd19o","updated":"20250708152213"},"Children":[{"ID":"20250708152031-if0tws1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250708152031-if0tws1","updated":"20250708152031"},"Children":[{"ID":"20250708152031-c0yhf2a","Type":"NodeParagraph","Properties":{"id":"20250708152031-c0yhf2a","updated":"20250708152031"},"Children":[{"Type":"NodeText","Data":"滤波时钟周期 = 1 / 60MHz ≈ 16.7ns"}]}]},{"ID":"20250708152031-1i2wu7b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250708152031-1i2wu7b","updated":"20250708152151"},"Children":[{"ID":"20250708152031-jzr9pit","Type":"NodeParagraph","Properties":{"id":"20250708152031-jzr9pit","updated":"20250708152151"},"Children":[{"Type":"NodeText","Data":"滤波窗口长度 = 15"}]}]},{"ID":"20250708152031-6nhy7o3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250708152031-6nhy7o3","updated":"20250708152207"},"Children":[{"ID":"20250708152031-rn4f9xj","Type":"NodeParagraph","Properties":{"id":"20250708152031-rn4f9xj","updated":"20250708152207"},"Children":[{"Type":"NodeText","Data":"滤波总时间 =15 × 16.7ns ≈ 250.5ns"}]}]},{"ID":"20250708152052-jocsw5z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250708152052-jocsw5z","updated":"20250708152213"},"Children":[{"ID":"20250708152053-mo5a6b3","Type":"NodeList","ListData":{},"Properties":{"id":"20250708152053-mo5a6b3","updated":"20250708152213"},"Children":[{"ID":"20250708152053-rsrww0n","Type":"NodeListItem","ListData":{"BulletChar":4