18213874"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs"},{"Type":"NodeCodeBlockCode","Data":"select * from user limit startIndex,pageSize;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213875-gd9d1rj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213875-gd9d1rj","updated":"20220618213875"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs"},{"Type":"NodeCodeBlockCode","Data":"每页显示两个从第0个开始\nselect * from user limit 0,2; # 这个2的实际取值范围不能小于0\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213876-282td8k","Type":"NodeParagraph","Properties":{"id":"20220618213876-282td8k","updated":"20220618213876"},"Children":[{"Type":"NodeText","Data":"使用Mybatis实现分页，核心SQL"}]},{"ID":"20220618213877-kk4he6o","Type":"NodeParagraph","Properties":{"id":"20220618213877-kk4he6o","updated":"20220618213877"},"Children":[{"Type":"NodeText","Data":"1.接口"}]},{"ID":"20220618213878-vc7dc29","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213878-vc7dc29","updated":"20220618213878"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    //分页\n   List\u003cUser\u003e getUserByLimit(Map\u003cString,Integer\u003e map);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213879-vtezpxy","Type":"NodeParagraph","Properties":{"id":"20220618213879-vtezpxy","updated":"20220618213879"},"Children":[{"Type":"NodeText","Data":"2.Mapper.xml"}]},{"ID":"20220618213880-kmfzraf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213880-kmfzraf","updated":"20220618213880"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003c!--分页--\u003e\n    \u003cselect id=\"getUserByLimit\" parameterType=\"map\" resultType=\"user\"\u003e\n        select * from mybatis.user limit #{startIndex},#{pageSize}\n    \u003c/select\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213881-jcl4fq3","Type":"NodeParagraph","Properties":{"id":"20220618213881-jcl4fq3","updated":"20220618213881"},"Children":[{"Type":"NodeText","Data":"3.测试"}]},{"ID":"20220618213882-a0jf8p3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213882-a0jf8p3","updated":"20220618213882"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    @Test\n    public void getUserByLimit(){\n        SqlSession sqlSession = MybatisUtils.getSqlSession();\n        UserMapper mapper = sqlSession.getMapper(UserMapper.class);\n\n        HashMap\u003cString, Integer\u003e map = new HashMap\u003cString, Integer\u003e();\n\n        map.put(\"startIndex\",2);\n        map.put(\"pageSize\",2);\n\n        List\u003cUser\u003e userByList = mapper.getUserByLimit(map);\n\n        for (User user : userByList){\n            System.out.println(user);\n        }\n\n        sqlSession.close();\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213883-ofwkn7g","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213883-ofwkn7g","updated":"20220618213883"},"Children":[{"Type":"NodeText","Data":"使用注解开发"}]},{"ID":"20220618213884-e6o9mcx","Type":"NodeParagraph","Properties":{"id":"20220618213884-e6o9mcx","updated":"20220618213884"},"Children":[{"Type":"NodeText","Data":"1.注解在接口上实现"}]},{"ID":"20220618213885-gk1czpw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213885-gk1czpw","updated":"20220618213885"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Select(\"select * from user\")\n    List\u003cUser\u003e getUsers();\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213886-f3fu5sz","Type":"NodeParagraph","Properties":{"id":"20220618213886-f3fu5sz","updated":"20220618213886"},"Children":[{"Type":"NodeText","Data":"2.需要在核心配置文件中绑定接口"}]},{"ID":"20220618213887-ddy8hsg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213887-ddy8hsg","updated":"20220618213887"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cmappers\u003e\n        \u003cmapper class=\"com.Xia.Dao.UserMapper\"/\u003e\n    \u003c/mappers\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213888-bsu66xp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213888-bsu66xp","updated":"20220618213888"},"Children":[{"Type":"NodeText","Data":"CRUD"}]},{"ID":"20220618213889-mdt7rp1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213889-mdt7rp1","updated":"20220618213889"},"Children":[{"Type":"NodeText","Data":"3.1自动提交事务"}]},{"ID":"20220618213890-29g317x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213890-29g317x","updated":"20220618213890"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//SqlSessionFactory\npublic class MybatisUtils {\n\n    private static SqlSessionFactory sqlSessionFactory;\n\n    static{\n        try {\n            //使用Mybatis第一步：获取SqlSessionFactory对象\n            String resource = \"mybatis-config.xml\";\n            InputStream inputStream = Resources.getResourceAsStream(resource);\n            sqlSessionFactory = new SqlSessionFactoryBuilder().build(inputStream);\n        } catch (IOException e) {\n            e.printStackTrace();\n        }\n    }\n    //既然有了SqlSessionFactory 顾名思义 我们就可以从中获得SqlSession的实例了\n    //SqlSession完全包含了面向数据库执行SQL 命令所需的所有方法\n    public static SqlSession getSqlSession(){\n        return sqlSessionFactory.openSession(true); //自动提交，一般不要这么写！！！！！！\n\n\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213891-h8w6osx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213891-h8w6osx","updated":"20220618213891"},"Children":[{"Type":"NodeText","Data":"3.2编写接口，增加注解"}]},{"ID":"20220618213892-023sgky","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213892-023sgky","updated":"20220811113500"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public interface UserMapper {\n\n    @Select(\"select * from user\")\n    List\u003cUser\u003e getUsers();\n\n    //方法存在多个参数，所有参数前面必须加上@Param（“id”）注解\n    @Select(\"select * from user where id = #{id}\")\n    User getUserById(@Param(\"id\") int id);\n\n    @Insert(\"insert into user(id,name,pwd) values (#{id},#{name},#{pwd})\")\n    int addUser(User user);\n\n    @Update(\"update user set name=#{name},pwd=#{pwd} where id =#{id}\")\n    int updateUser(User user);\n\n    @Delete(\"delete from user where id = #{uid}\")\n    int deleteUser(@Param(\"uid\")int id);\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213893-jln97uw","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213893-jln97uw","updated":"20220618213893"},"Children":[{"Type":"NodeText","Data":"3.3测试类"}]},{"ID":"20220618213894-c2jjsz0","Type":"NodeParagraph","Properties":{"id":"20220618213894-c2jjsz0","updated":"20220618213894"},"Children":[{"Type":"NodeText","Data":"【注意：必须要将接口注册绑定到核心配置文件中】"}]},{"ID":"20220618213895-51on2m4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213895-51on2m4","updated":"20220618213895"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cmappers\u003e\n        \u003cmapper class=\"com.Xia.Dao.UserMapper\"/\u003e\n    \u003c/mappers\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213896-1iyrnne","Type":"NodeParagraph","Properties":{"id":"20220618213896-1iyrnne","updated":"20220618213896"},"Children":[{"Type":"NodeText","Data":"测试"}]},{"ID":"20220618213897-ke4uj5q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213897-ke4uj5q","updated":"20220618213897"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class UserDaoTest {\n\n    @Test\n    public void test(){\n        SqlSession sqlSession = MybatisUtils.getSqlSession();\n\n        //底层主要应用反射\n        UserMapper mapper = sqlSession.getMapper(UserMapper.class);\n\n        mapper.addUser(new User(5,\"Niu\",\"123456\"));\n\n        sqlSession.close();\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213898-qvkzb8z","Type":"NodeParagraph","Properties":{"id":"20220618213898-qvkzb8z","updated":"20220618213898"},"Children":[{"Type":"NodeText","Data":"本质：反射机制实现"}]},{"ID":"20220618213899-q2lzjb1","Type":"NodeParagraph","Properties":{"id":"20220618213899-q2lzjb1","updated":"20220618213899"},"Children":[{"Type":"NodeText","Data":"底层：动态代理"}]},{"ID":"20220618213900-49awlj8","Type":"NodeParagraph","Properties":{"id":"20220618213900-49awlj8","updated":"20220618213900"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220613142126555"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220613142126555-20220618215622-7gz9ui0.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213901-o5g9qq9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213901-o5g9qq9","updated":"20220618213901"},"Children":[{"Type":"NodeText","Data":"Lombok"}]},{"ID":"20220618213902-u3pc7es","Type":"NodeParagraph","Properties":{"id":"20220618213902-u3pc7es","updated":"20220618213902"},"Children":[{"Type":"NodeText","Data":"使用步骤："}]},{"ID":"20220618213903-st0fk9p","Type":"NodeParagraph","Properties":{"id":"20220618213903-st0fk9p","updated":"20220618213903"},"Children":[{"Type":"NodeText","Data":"1.在idea中安装Lombok——setting——plugins"}]},{"ID":"20220618213904-q7r5syi","Type":"NodeParagraph","Properties":{"id":"20220618213904-q7r5syi","updated":"20220618213904"},"Children":[{"Type":"NodeText","Data":"2.在项目中导入lombok的jar包"}]},{"ID":"20220618213905-klv5wdq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213905-klv5wdq","updated":"20220618213905"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cdependencies\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.projectlombok\u003c/groupId\u003e\n            \u003cartifactId\u003elombok\u003c/artifactId\u003e\n            \u003cversion\u003e1.18.24\u003c/version\u003e\n            \u003cscope\u003eprovided\u003c/scope\u003e\n        \u003c/dependency\u003e\n    \u003c/dependencies\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213906-ad90fph","Type":"NodeParagraph","Properties":{"id":"20220618213906-ad90fph","updated":"20220618213906"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220613160046145"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220613160046145-20220618215622-2nudwpx.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213907-pcszzyj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213907-pcszzyj","updated":"20220618213907"},"Children":[{"Type":"NodeText","Data":"多对一处理"}]},{"ID":"20220903135649-jaa3d89","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220903135649-jaa3d89","updated":"20220903135657"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"resultMap"},{"Type":"NodeText","Data":"详解"}]},{"ID":"20220903135657-2cx6whk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220903135657-2cx6whk","updated":"20220903135708"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--column不做限制，可以为任意表的字段，而property须为type 定义的pojo属性--\u003e\n\u003cresultMap id=\"唯一的标识\" type=\"映射的pojo对象\"\u003e\n  \u003cid column=\"表的主键字段，或者可以为查询语句中的别名字段\" jdbcType=\"字段类型\" property=\"映射pojo对象的主键属性\" /\u003e\n  \u003cresult column=\"表的一个字段（可以为任意表的一个字段）\" jdbcType=\"字段类型\" property=\"映射到pojo对象的一个属性（须为type定义的pojo对象中的一个属性）\"/\u003e\n  \u003cassociation property=\"pojo的一个对象属性\" javaType=\"pojo关联的pojo对象\"\u003e\n    \u003cid column=\"关联pojo对象对应表的主键字段\" jdbcType=\"字段类型\" property=\"关联pojo对象的主席属性\"/\u003e\n    \u003cresult  column=\"任意表的字段\" jdbcType=\"字段类型\" property=\"关联pojo对象的属性\"/\u003e\n  \u003c/association\u003e\n  \u003c!-- 集合中的property须为oftype定义的pojo对象的属性--\u003e\n  \u003ccollection property=\"pojo的集合属性\" ofType=\"集合中的pojo对象\"\u003e\n    \u003cid column=\"集合中pojo对象对应的表的主键字段\" jdbcType=\"字段类型\" property=\"集合中pojo对象的主键属性\" /\u003e\n    \u003cresult column=\"可以为任意表的字段\" jdbcType=\"字段类型\" property=\"集合中的pojo对象的属性\" /\u003e  \n  \u003c/collection\u003e\n\u003c/resultMap\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213908-imdlgfg","Type":"NodeParagraph","Properties":{"id":"20220618213908-imdlgfg","updated":"20220618213908"},"Children":[{"Type":"NodeText","Data":"建表"}]},{"ID":"20220618213909-8vbk3qg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213909-8vbk3qg","updated":"20220618213909"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs"},{"Type":"NodeCodeBlockCode","Data":"CREATE TABLE `teacher`(\n`id` INT(10) NOT NULL,\n`name` VARCHAR(30) DEFAULT NULL,\nPRIMARY KEY(`id`)\n)ENGINE=INNODB DEFAULT CHARSET=utf8\n\nINSERT INTO teacher(`id`,`name`)VALUES (1,'秦老师');\n\nCREATE TABLE `student`(\n`id` INT(10) NOT NULL,\n`name` VARCHAR(30) DEFAULT NULL,\n`tid` INT DEFAULT NULL,\nPRIMARY KEY(`id`),\nKEY `fktid`(`tid`),\nCONSTRAINT `fktid` FOREIGN KEY (`tid`) REFERENCES `teacher` (`id`)\n)ENGINE=INNODB DEFAULT CHARSET=utf8\n\nINSERT INTO `student`(`id`,`name`,`tid`) VALUES(1,'小明',1);\nINSERT INTO `student`(`id`,`name`,`tid`) VALUES(2,'小红',1);\nINSERT INTO `student`(`id`,`name`,`tid`) VALUES(3,'小张',1);\nINSERT INTO `student`(`id`,`name`,`tid`) VALUES(4,'小李',1);\nINSERT INTO `student`(`id`,`name`,`tid`) VALUES(5,'小王',1);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213910-vbruvy3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213910-vbruvy3","updated":"20220618213910"},"Children":[{"Type":"NodeText","Data":"测试环境搭建"}]},{"ID":"20220618213911-to5vria","Type":"NodeParagraph","Properties":{"id":"20220618213911-to5vria","updated":"20220618213911"},"Children":[{"Type":"NodeText","Data":"1.导入lombok"}]},{"ID":"20220618213912-4t1l8bw","Type":"NodeParagraph","Properties":{"id":"20220618213912-4t1l8bw","updated":"20220618213912"},"Children":[{"Type":"NodeText","Data":"2.新建实体类Teacher，Student"}]},{"ID":"20220618213913-ut866ju","Type":"NodeParagraph","Properties":{"id":"20220618213913-ut866ju","updated":"20220618213913"},"Children":[{"Type":"NodeText","Data":"3.建立Mapper接口"}]},{"ID":"20220618213914-57c2f3y","Type":"NodeParagraph","Properties":{"id":"20220618213914-57c2f3y","updated":"20220618213914"},"Children":[{"Type":"NodeText","Data":"4.建立Mapper.XML文件"}]},{"ID":"20220618213915-riwbkbf","Type":"NodeParagraph","Properties":{"id":"20220618213915-riwbkbf","updated":"20220618213915"},"Children":[{"Type":"NodeText","Data":"5.在核心配置文件中绑定注册Mapepr接口或文件"}]},{"ID":"20220618213916-60mrycb","Type":"NodeParagraph","Properties":{"id":"20220618213916-60mrycb","updated":"20220618213916"},"Children":[{"Type":"NodeText","Data":"6.测试查询是否能够成功"}]},{"ID":"20220618213917-97jpmx0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213917-97jpmx0","updated":"20220618213917"},"Children":[{"Type":"NodeText","Data":"按照查询嵌套处理"}]},{"ID":"20220618213918-jlk5qx4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213918-jlk5qx4","updated":"20220903154125"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cselect id=\"getStudent\" resultMap=\"StudentTeacher\"\u003e\n        select * from student\n    \u003c/select\u003e\n    \u003cresultMap id=\"StudentTeacher\" type=\"Student\"\u003e \u003c!--id自己取--\u003e\n        \u003cresult property=\"id\" column=\"id\"/\u003e\n        \u003cresult property=\"name\" column=\"name\"/\u003e\n\t复杂的属性，我们需要单独处理  \n\t对象：association多对一\n\t集合：collection一对多\n\n        \u003cassociation property=\"teacher\" column=\"tid\" javaType=\"Teacher\" select=\"getTeacher\"/\u003e\n    \u003c/resultMap\u003e  \n\n    \u003cselect id=\"getTeacher\" resultType=\"Teacher\"\u003e\n        select * from teacher where id = #{id}\n    \u003c/select\u003e\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213919-udbghxk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213919-udbghxk","updated":"20220618213919"},"Children":[{"Type":"NodeText","Data":"按照结果嵌套处理"}]},{"ID":"20220618213920-d78dxsc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213920-d78dxsc","updated":"20220618213920"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--按照结果嵌套处理--\u003e\n\u003cselect id=\"getStudent2\" resultMap=\"StudentTeacher2\"\u003e\n    select s.id sid,s.name sname,t.name tname\n    from student s, teacher t\n    where s.tid = t.id;\n\u003c/select\u003e\n\u003cresultMap id=\"StudentTeacher2\" type=\"Student\"\u003e\n    \u003cresult property=\"id\" column=\"sid\"/\u003e\n    \u003cresult property=\"name\" column=\"sname\"/\u003e\n    \u003cassociation property=\"teacher\" javaType=\"Teacher\"\u003e\n        \u003cresult property=\"name\" column=\"tname\"/\u003e\n    \u003c/association\u003e\n\u003c/resultMap\u003e\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213921-ij11rmp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213921-ij11rmp","updated":"20220618213921"},"Children":[{"Type":"NodeText","Data":"一对多"}]},{"ID":"20220618213922-frzuxg7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213922-frzuxg7","updated":"20220618213922"},"Children":[{"Type":"NodeText","Data":"环境搭建"}]},{"ID":"20220618213923-dh8yks4","Type":"NodeParagraph","Properties":{"id":"20220618213923-dh8yks4","updated":"20220618213923"},"Children":[{"Type":"NodeText","Data":"和上一部分一样"}]},{"ID":"20220618213924-0o5wd9m","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213924-0o5wd9m","updated":"20220618213924"},"Children":[{"Type":"NodeText","Data":"实体类"}]},{"ID":"20220618213925-m5dp7yt","Type":"NodeBlockquote","Properties":{"id":"20220618213925-m5dp7yt","updated":"20220618213925"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213926-o846yx9","Type":"NodeParagraph","Properties":{"id":"20220618213926-o846yx9","updated":"20220618213926"},"Children":[{"Type":"NodeText","Data":"Teacher"}]}]},{"ID":"20220618213927-nj1fv19","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213927-nj1fv19","updated":"20220618213927"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Data\npublic class Teacher {\n    private int id;\n    private String name;\n\n    //一个老师拥有多个学生\n    private List\u003cStudent\u003e students;\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213928-5galtsz","Type":"NodeBlockquote","Properties":{"id":"20220618213928-5galtsz","updated":"20220618213928"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213929-rhs8k9v","Type":"NodeParagraph","Properties":{"id":"20220618213929-rhs8k9v","updated":"20220618213929"},"Children":[{"Type":"NodeText","Data":"Student"}]}]},{"ID":"20220618213930-jga5znj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213930-jga5znj","updated":"20220618213930"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Data\npublic class Student {\n    private int id;\n    private String name;\n    private int tid;\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213931-b4noe0d","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213931-b4noe0d","updated":"20220618213931"},"Children":[{"Type":"NodeText","Data":"按照结果嵌套处理"}]},{"ID":"20220618213932-47lqbto","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213932-47lqbto","updated":"20220618213932"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003cmapper namespace=\"com.Xia.Dao.TeacherMapper\"\u003e\n        \u003c!--按结果嵌套查询--\u003e\n        \u003cselect id=\"getTeacher\" resultMap=\"TeacherStudent\"\u003e\n                select s.id sid,s.name sname, t.name tname, t.id tid\n                from student s, teacher t\n                where s.tid = t.id and t.id = #{tid}\n        \u003c/select\u003e\n\n        \u003cresultMap id=\"TeacherStudent\" type=\"Teacher\"\u003e\n                \u003cresult property=\"id\" column=\"tid\"/\u003e\n                \u003cresult property=\"name\" column=\"tname\"/\u003e\n                \u003c!--复杂的属性需要单独处理，对象：association 集合：collection\n                javatype指定属性的类型\n                集合中的泛型信息，使用oftype获取\n                --\u003e\n                \u003ccollection property=\"students\" ofType=\"Student\"\u003e\n                        \u003cresult property=\"id\" column=\"sid\"/\u003e\n                        \u003cresult property=\"name\" column=\"sname\"/\u003e\n                        \u003cresult property=\"tid\" column=\"tid\"/\u003e\n                \u003c/collection\u003e\n        \u003c/resultMap\u003e\n\u003c/mapper\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213933-fwbkt5k","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213933-fwbkt5k","updated":"20220618213933"},"Children":[{"Type":"NodeText","Data":"测试"}]},{"ID":"20220618213934-aaqjyvx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213934-aaqjyvx","updated":"20220618213934"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class MyTest {\n    @Test\n    public void test(){\n        SqlSession sqlSession = MybatisUtils.getSqlSession();\n        TeacherMapper mapper = sqlSession.getMapper(TeacherMapper.class);\n\n        Teacher teacher1 = mapper.getTeacher(1);\n\n        System.out.println(teacher1);\n        sqlSession.close();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213935-u6ggapx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213935-u6ggapx","updated":"20220618213935"},"Children":[{"Type":"NodeText","Data":"小结"}]},{"ID":"20220618213936-dfm372w","Type":"NodeParagraph","Properties":{"id":"20220618213936-dfm372w","updated":"20220618213936"},"Children":[{"Type":"NodeText","Data":"1.关联- association【多对一】"}]},{"ID":"20220618213937-x9s72ee","Type":"NodeParagraph","Properties":{"id":"20220618213937-x9s72ee","updated":"20220618213937"},"Children":[{"Type":"NodeText","Data":"2.集合- collection【一对多】"}]},{"ID":"20220618213938-suoqvnw","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213938-suoqvnw","updated":"20220618213938"},"Children":[{"ID":"20220618213939-brzimzy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213939-brzimzy","updated":"20220618213939"},"Children":[{"ID":"20220618213940-97d589j","Type":"NodeParagraph","Properties":{"id":"20220618213940-97d589j","updated":"20220618213940"},"Children":[{"Type":"NodeText","Data":"javaType \u0026 ofType"}]},{"ID":"20220618213941-r6udnmt","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20220618213941-r6udnmt","updated":"20220618213941"},"Children":[{"ID":"20220618213942-n6wiy0h","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20220618213942-n6wiy0h","updated":"20220618213942"},"Children":[{"ID":"20220618213943-c1lb0o4","Type":"NodeParagraph","Properties":{"id":"20220618213943-c1lb0o4","updated":"20220618213943"},"Children":[{"Type":"NodeText","Data":"JavaType用来指定实体类中属性的类型"}]}]},{"ID":"20220618213944-2v4x7my","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20220618213944-2v4x7my","updated":"20220618213944"},"Children":[{"ID":"20220618213945-0iu9wuy","Type":"NodeParagraph","Properties":{"id":"20220618213945-0iu9wuy","updated":"20220618213945"},"Children":[{"Type":"NodeText"