621135840-5khrbi2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220621135840-5khrbi2","updated":"20220621140144"},"Children":[{"Type":"NodeText","Data":"byType"}]},{"ID":"20220621140145-un8ewet","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621140145-un8ewet","updated":"20220621140235"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cbean id=\"cat\" class=\"com.Xia.pojo.Cat\"/\u003e\n    \u003cbean id=\"dog\" class=\"com.Xia.pojo.Dog\"/\u003e  \n  \u003c!--\n    byName:会自动在容器上下文中查找，和自己对象属性类型相同的bean \n    --\u003e\n    \u003cbean id=\"people\" class=\"com.Xia.pojo.People\" autowire=\"byType\"\u003e\n        \u003cproperty name=\"name\" value=\"卷王\"/\u003e\n    \u003c/bean\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220621140242-tspcovr","Type":"NodeParagraph","Properties":{"id":"20220621140242-tspcovr","updated":"20220621140833"},"Children":[{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"区别：byName只要getset方法中的id和bean的id一致即可并且id唯一，但是byType需要保证所有bean的class唯一，并且这个bean和自动注入的属性的类型一致​​​"}]},{"ID":"20220621140346-e9nym2l","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220621140346-e9nym2l","updated":"20220621140957"},"Children":[{"Type":"NodeText","Data":"使用注解实现自动装配"}]},{"ID":"20220621141000-s61xi7q","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20220621141000-s61xi7q","updated":"20220621141216"},"Children":[{"ID":"20220621141220-x4elhxf","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20220621141220-x4elhxf","updated":"20220621141220"},"Children":[{"ID":"20220621141220-f21dwv3","Type":"NodeParagraph","Properties":{"id":"20220621141220-f21dwv3","updated":"20220621141344"},"Children":[{"Type":"NodeText","Data":"导入约束：context约束"}]}]},{"ID":"20220621141227-mjr2nxb","Type":"NodeListIte