":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213707-digw21c","updated":"20220618213707"},"Children":[{"Type":"NodeText","Data":"第一个Mybatis程序"}]},{"ID":"20220618213708-5ixrcwq","Type":"NodeParagraph","Properties":{"id":"20220618213708-5ixrcwq","updated":"20220618213708"},"Children":[{"Type":"NodeText","Data":"思路：搭建环境--\u003e导入Mybatis--\u003e编写代码--\u003e测试"}]},{"ID":"20220618213709-idmm691","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213709-idmm691","updated":"20220618213709"},"Children":[{"Type":"NodeText","Data":"1.搭建环境"}]},{"ID":"20220618213710-2cwtdfr","Type":"NodeParagraph","Properties":{"id":"20220618213710-2cwtdfr","updated":"20220618213710"},"Children":[{"Type":"NodeText","Data":"搭建数据库"}]},{"ID":"20220618213711-22binm6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213711-22binm6","updated":"20220618213711"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs"},{"Type":"NodeCodeBlockCode","Data":"CREATE DATABASE `mybatis`;\n\nUSE `mybatis`;\n\nCREATE TABLE `user`(\n\t`id` INT(20) NOT NULL PRIMARY KEY,\n\t`name` VARCHAR(30) DEFAULT NULL,\n\t`pwd` VARCHAR(30) DEFAULT NULL\n)ENGINE=INNODB DEFAULT CHARSET=utf8;\n\nINSERT INTO `user`(`id`,`name`,`pwd`) VALUES\n(1,'岛田庄司','12345'),\n(2,'埃勒里奎因','12345'),\n(3,'钱德勒雷蒙','12345')\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213712-ytex5t6","Type":"NodeParagraph","Properties":{"id":"20220618213712-ytex5t6","updated":"20220618213712"},"Children":[{"Type":"NodeText","Data":"新建项目"}]},{"ID":"20220618213713-qcy6mbe","Type":"NodeBlockquote","Properties":{"id":"20220618213713-qcy6mbe","updated":"20220618213713"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213714-ymmsn17","Type":"NodeParagraph","Properties":{"id":"20220618213714-ymmsn17","updated":"20220618213714"},"Children":[{"Type":"NodeText","Data":"删除src文件"}]},{"ID":"20220618213715-0uwyzo4","Type":"NodeParagraph","Properties":{"id":"20220618213715-0uwyzo4","updated":"20220618213715"},"Children":[{"Type":"NodeText","Data":"导入maven依赖"}]}]},{"ID":"20220618213716-yazth5t","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213716-yazth5t","updated":"20220618213716"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--导入依赖--\u003e\n  \u003cdependencies\u003e\n    \u003c!--mybatis--\u003e\n    \u003cdependency\u003e\n      \u003cgroupId\u003eorg.mybatis\u003c/groupId\u003e\n      \u003cartifactId\u003emybatis\u003c/artifactId\u003e\n      \u003cversion\u003e3.5.10\u003c/version\u003e\n    \u003c/dependency\u003e\n    \u003c!--mysql驱动--\u003e\n    \u003cdependency\u003e\n      \u003cgroupId\u003emysql\u003c/groupId\u003e\n      \u003cartifactId\u003emysql-connector-java\u003c/artifactId\u003e\n      \u003cversion\u003e8.0.27\u003c/version\u003e\n  \u003c/dependency\u003e\n    \u003c!--junit--\u003e\n    \u003cdependency\u003e\n      \u003cgroupId\u003ejunit\u003c/groupId\u003e\n      \u003cartifactId\u003ejunit\u003c/artifactId\u003e\n      \u003cversion\u003e4.11\u003c/version\u003e\n    \u003c/dependency\u003e\n  \u003c/dependencies\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213717-4mcbhlf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213717-4mcbhlf","updated":"20220618213717"},"Children":[{"Type":"NodeText","Data":"2.创建一个新的模块"}]},{"ID":"20220618213718-7zlph8s","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213718-7zlph8s","updated":"20220618213718"},"Children":[{"ID":"20220618213719-72x8ict","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213719-72x8ict","updated":"20220618213719"},"Children":[{"ID":"20220618213720-5w3771m","Type":"NodeParagraph","Properties":{"id":"20220618213720-5w3771m","updated":"20220618213720"},"Children":[{"Type":"NodeText","Data":"编写mybatis的核心配置文件"}]},{"ID":"20220618213721-42op31r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213721-42op31r","updated":"20220618213721"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF8\"?\u003e\n\u003c!DOCTYPE configuration\n        PUBLIC \"-//mybatis.org//DTD Config 3.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-3-config.dtd\"\u003e\n\n\n\u003cconfiguration\u003e\n    \u003cenvironments default=\"development\"\u003e\n        \u003cenvironment id=\"development\"\u003e\n            \u003ctransactionManager type=\"JDBC\"/\u003e\n            \u003cdataSource type=\"POOLED\"\u003e\n                \u003cproperty name=\"driver\" value=\"com.mysql.jdbc.Driver\"/\u003e\n                \u003cproperty name=\"url\" value=\"jdbc:mysql://localhost:3306/mybatis?useSSL=false\u0026amp;useUnicode=true\u0026amp;characterEncoding=UTF8\"/\u003e\n                \u003cproperty name=\"username\" value=\"root\"/\u003e\n                \u003cproperty name=\"password\" value=\"root\"/\u003e\n            \u003c/dataSource\u003e\n        \u003c/environment\u003e\n    \u003c/environments\u003e\n\n\t\u003c!--注意这里的resource路径要以斜杠的形式写--\u003e\n    \u003cmappers\u003e\n        \u003cmapper resource=\"com/Xia/Dao/UserMapp.xml\"/\u003e\n    \u003c/mappers\u003e\n\u003c/configuration\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]}]},{"ID":"20220618213722-jmghwqr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213722-jmghwqr","updated":"20220618213722"},"Children":[{"ID":"20220618213723-tf7whnj","Type":"NodeParagraph","Properties":{"id":"20220618213723-tf7whnj","updated":"20220618213723"},"Children":[{"Type":"NodeText","Data":"编写mybatis的工具类"}]}]}]},{"ID":"20220618213724-zd1piou","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213724-zd1piou","updated":"20220618213724"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.utils;\n\nimport org.apache.ibatis.io.Resources;\nimport org.apache.ibatis.session.SqlSession;\nimport org.apache.ibatis.session.SqlSessionFactory;\nimport org.apache.ibatis.session.SqlSessionFactoryBuilder;\n\nimport java.io.IOException;\nimport java.io.InputStream;\n\n//SqlSessionFactory\npublic class MybatisUtils {\n\n    private static SqlSessionFactory sqlSessionFactory;\n\n    static{\n        try {\n            //使用Mybatis第一步：获取SqlSessionFactory对象\n            String resource = \"mybatis-config.xml\";\n            InputStream inputStream = Resources.getResourceAsStream(resource);\n            sqlSessionFactory = new SqlSessionFactoryBuilder().build(inputStream);\n        } catch (IOException e) {\n            e.printStackTrace();\n        }\n    }\n    //既然有了SqlSessionFactory 顾名思义 我们就可以从中获得SqlSession的实例了\n    //SqlSession完全包含了面向数据库执行SQL 命令所需的所有方法\n    public static SqlSession getSqlSession(){\n        return sqlSessionFactory.openSession();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213725-76mvbqu","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213725-76mvbqu","updated":"20220618213725"},"Children":[{"Type":"NodeText","Data":"3.编写代码"}]},{"ID":"20220618213726-6gwefv5","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213726-6gwefv5","updated":"20220618213726"},"Children":[{"ID":"20220618213727-s6nuij2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213727-s6nuij2","updated":"20220618213727"},"Children":[{"ID":"20220618213728-cvh7w0f","Type":"NodeParagraph","Properties":{"id":"20220618213728-cvh7w0f","updated":"20220618213728"},"Children":[{"Type":"NodeText","Data":"实体类"}]},{"ID":"20220618213729-69iv7yq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213729-69iv7yq","updated":"20220618213729"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package pojo;\n\n//实体类\npublic class User {\n    private int id;\n    private String name;\n    private String pwd;\n    public User(){\n\n    }\n    public User(int id,String name, String pwd){\n        this.id = id;\n        this.name = name;\n        this.pwd = pwd;\n    }\n\n    public void setId(int id) {\n        this.id = id;\n    }\n\n    public String getName() {\n        return name;\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public String getPwd() {\n        return pwd;\n    }\n\n    public void setPwd(String pwd) {\n        this.pwd = pwd;\n    }\n\n    public int getId() {\n        return id;\n    }\n\n    @Override\n    public String toString() {\n        return \"User{\" +\n                \"id=\" + id +\n                \", name='\" + name + '\\'' +\n                \", pwd='\" + pwd + '\\'' +\n                '}';\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]}]},{"ID":"20220618213730-bg4rwnv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213730-bg4rwnv","updated":"20220618213730"},"Children":[{"ID":"20220618213731-9ua8wr4","Type":"NodeParagraph","Properties":{"id":"20220618213731-9ua8wr4","updated":"20220618213731"},"Children":[{"Type":"NodeText","Data":"Dao接口"}]},{"ID":"20220618213732-ziwluy3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213732-ziwluy3","updated":"20220618213732"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":