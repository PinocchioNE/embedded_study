","Data":"```"}]},{"ID":"20220621094544-9rb75ha","Type":"NodeParagraph","Properties":{"id":"20220621094544-9rb75ha","updated":"20220621094605"},"Children":[{"Type":"NodeText","Data":"实体类中要有无参与有参构造"}]},{"ID":"20220621094606-cfvqc1a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621094606-cfvqc1a","updated":"20220621094619"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    public User(){\n\n    }\n\n    public User(String name, int age) {\n        this.name = name;\n        this.age = age;\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220621094620-k5dspq7","Type":"NodeParagraph","Properties":{"id":"20220621094620-k5dspq7","updated":"20220621094622"},"Children":[{"Type":"NodeText","Data":"测试"}]},{"ID":"20220621094623-2ka2d2z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621094623-2ka2d2z","updated":"20220621094637"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class MyTest {\n    public static void main(String[] args) {\n    }\n    @Test\n    public void test2(){\n        ClassPathXmlApplicationContext contex = new ClassPathXmlApplicationContext(\"userbeans.xml\");\n        User user = contex.getBean(\"user2\", User.class);\n        System.out.println(user);\n    }\n}\n//结果：User{name='xth1', age=20}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220621094638-2wfb411","Type":"NodeParagraph","Properties":{"id":"20220621094638-2wfb411","updated":"20220621094736"},"Children":[{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"注意：p命名与c命名需要导入xml约束"}]},{"ID":"20220621094736-xyl242c","Type":"NodeThematicBreak","Properties":{"id":"20220621094736-xyl242c"}},{"ID":"20220621094739-rfhkyyk","Type":"NodeHeading",