0220621085930"},"Children":[{"Type":"NodeText","Data":"完善注入信息"}]},{"ID":"20220621085930-2l0xroe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621085930-2l0xroe","updated":"20220621085947"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003cbeans xmlns=\"http://www.springframework.org/schema/beans\"\n       xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n       xsi:schemaLocation=\"http://www.springframework.org/schema/beans\n        https://www.springframework.org/schema/beans/spring-beans.xsd\"\u003e\n\n    \u003cbean id=\"address\" class=\"com.Xia.pojo.Address\"\u003e\n        \u003cproperty name=\"address\" value=\"沈阳\"/\u003e\n    \u003c/bean\u003e\n    \u003cbean id=\"student\" class=\"com.Xia.pojo.Student\"\u003e\n        \u003c!--第一种，普通值注入，value--\u003e\n        \u003cproperty name=\"name\" value=\"旷野之息\"/\u003e\n\n        \u003c!--第二种，bean注入，ref--\u003e\n        \u003cproperty name=\"address\" ref=\"address\"/\u003e\n\n        \u003c!--第三种，数组注入，ref--\u003e\n        \u003cproperty name=\"books\"\u003e\n            \u003carray\u003e\n                \u003cvalue\u003e希腊棺材之谜\u003c/value\u003e\n                \u003cvalue\u003eX的悲剧\u003c/value\u003e\n                \u003cvalue\u003e占星术杀人魔法\u003c/value\u003e\n                \u003cvalue\u003e钟表馆事件\u003c/value\u003e\n            \u003c/array\u003e\n        \u003c/property\u003e\n\n        \u003c!--list--\u003e\n        \u003cproperty name=\"hobbys\"\u003e\n            \u003clist\u003e\n                \u003cvalue\u003e看小说\u003c/value\u003e\n                \u003cvalue\u003e看电影\u003c/value\u003e\n            \u003c/list\u003e\n        \u003c/property\u003e\n\n        \u003c!--Map--\u003e\n        \u003cproperty name=\"card\"\u003e\n            \u003cmap\u003e\n                \u003centry key=\"身份证\" value=\"123\"/\u003e\n                \u003centry key=\"银行卡\" value=\"321\"/\u003e\n            \u003c/map\u003e\n        \u003c/property\u003e\n\n        \u003c!--Set--\u003e\n        \u003cproperty name=\"games\"\u003e\n            \u003cset\u003e\n                \u003cvalue\u003eLOL\u003c/value\u003e\n                \u003cvalue\u003ecoc\u003c/value\u003e\n                \u003cvalue\u003ebob\u003c/value\u003e\n            \u003c/set\u003e\n        \u003c/property\u003e\n\n        \u003c!--null--\u003e\n        \u003cproperty name=\"wife\"\u003e\n            \u003cnull/\u003e\n        \u003c/property\u003e\n\n        \u003c!--Properties--\u003e\n        \u003cproperty name=\"info\"\u003e\n            \u003cprops\u003e\n                \u003cprop key=\"学号\"\u003e2020123\u003c/prop\u003e\n                \u003cprop key=\"姓名\"\u003e岛田洁\u003c/prop\u003e\n            \u003c/props\u003e\n        \u003c/property\u003e\n\n    \u003c/bean\u003e\n\u003c/beans\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220621085915-b338621","Type":"NodeParagraph","Properties":{"id":"20220621085915-b338621","updated":"20220621090053"},"Children":[{"Type":"NodeText","Data":"测试结果"}]},{"ID":"20220621090054-ss5o22k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621090054-ss5o22k","updated":"20220621090318"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class MyTest {\n    public static void main(String[] args) {\n        ClassPathXmlApplicationContext context = new ClassPathXmlApplicationContext(\"beans.xml\");\n        Student student = (Student) context.getBean(\"student\");\n        System.out.println(student.toString());\n\n        /* 测试结果\n        Student{name='旷野之息', address=Address{address='沈阳'},\n         books=[希腊棺材之谜, X的悲剧, 占星术杀人魔法, 钟表馆事件],\n         hobbys=[看小说, 看电影],\n         card={身份证=123, 银行卡=321},\n         games=[LOL, coc, bob],\n          wife='null',\n          info={学号=2020123, 姓名=岛田洁}}\n         */\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220620141233-j8i5wa5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220620141233-j8i5wa5","updated":"20220620141237"},"Children":[{"Type":"NodeText","Data":"3.拓展方式注入"}]},{"ID":"20220621082835-k596co9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220621082835-k596co9","updated":"20220621092833"},"Children":[{"Type":"NodeText","Data":"p命名空间"}]},{"ID":"20220621092834-otpbowb","Type":"NodeParagraph","Properties":{"id":"20220621092834-otpbowb","updated":"20220621092850"},"Children":[{"Type":"NodeText","Data":"beans.xml"}]},{"ID":"20220621092859-d3lsvef","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621092859-d3lsvef","updated":"20220621092957"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003cbeans xmlns=\"http://www.springframework.org/schema/beans\"\n       xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n       xmlns:p=\"http://www.springframework.org/schema/p\"  \u003c!--注意要写依赖--\u003e\n       xsi:schemaLocation=\"http://www.springframework.org/schema/beans\n        https://www.springframework.org/schema/beans/spring-beans.xsd\"\u003e\n\n    \u003c!--p命名空间注入，可以直接注入属性的值：property--\u003e\n    \u003cbean id=\"user\" class=\"com.Xia.pojo.User\" p:name=\"xth\" p:age=\"18\"/\u003e\n\n\u003c/beans\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220621092929-57qjo48","Type":"NodeParagraph","Properties":{"id":"20220621092929-57qjo48","updated":"20220621093002"},"Children":[{"Type":"NodeText","Data":"测试"}]},{"ID":"20220621093003-3lhynpi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220621093003-3lhynpi","updated"