st {\n    public static void main(String[] args) {\n        //获取ApplicationContext:拿到spring的容器\n        ClassPathXmlApplicationContext context = new ClassPathXmlApplicationContext(\"beans.xml\");\n        //需要什么就get什么\n        UserServiceImpl userServiceImpl = (UserServiceImpl) context.getBean(\"UserServiceImpl\");\n\n        userServiceImpl.getUser();\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618223468-cd8ywgp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618223468-cd8ywgp","updated":"20220618223468"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"IOC创建对象的方式","Properties":{"id":""}}]},{"ID":"20220618223469-d8v6f9w","Type":"NodeParagraph","Properties":{"id":"20220618223469-d8v6f9w","updated":"20220618223469"},"Children":[{"Type":"NodeText","Data":"1.使用无参构造创建对象","Properties":{"id":""}}]},{"ID":"20220618223470-b6p6m52","Type":"NodeParagraph","Properties":{"id":"20220618223470-b6p6m52","updated":"20220618223470"},"Children":[{"Type":"NodeText","Data":"2.假设我们要使用有参构造创建对象","Properties":{"id":""}}]},{"ID":"20220618223471-epjfrx1","Type":"NodeParagraph","Properties":{"id":"20220618223471-epjfrx1","updated":"20220618223471"},"Children":[{"Type":"NodeText","Data":"​\t1.下标赋值","Properties":{"id":""}}]},{"ID":"20220618223472-vqaf8ad","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"eG1s","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618223472-vqaf8ad","updated":"20220618223472"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"    \u003cbean id=\"user\" class=\"com.Xia.pojo.User\"\u003e\n       \u003cconstructor-arg i