":"20220618213807-tgomo5v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213807-tgomo5v","updated":"20220618213807"},"Children":[{"ID":"20220618213808-wmu8jt8","Type":"NodeParagraph","Properties":{"id":"20220618213808-wmu8jt8","updated":"20220618213808"},"Children":[{"Type":"NodeText","Data":"mappers（映射器）"}]}]}]}]}]},{"ID":"20220622162338-7lvgo8b","Type":"NodeParagraph","Properties":{"id":"20220622162338-7lvgo8b"}},{"ID":"20220618213809-gvvbfhd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213809-gvvbfhd","updated":"20220618213809"},"Children":[{"Type":"NodeText","Data":"环境配置"}]},{"ID":"20220618213810-v3b7x6e","Type":"NodeParagraph","Properties":{"id":"20220618213810-v3b7x6e","updated":"20220618213810"},"Children":[{"Type":"NodeText","Data":"Mybatis可以配置乘适应多种环境"}]},{"ID":"20220618213811-vt1eyg3","Type":"NodeParagraph","Properties":{"id":"20220618213811-vt1eyg3","updated":"20220618213811"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"不过要记住，尽管可以配置多个环境，但每个SqlSessionFactory实例只能选择一种环境"}]},{"ID":"20220618213812-4k8dgwc","Type":"NodeParagraph","Properties":{"id":"20220618213812-4k8dgwc","updated":"20220618213812"},"Children":[{"Type":"NodeText","Data":"Mybatis默认的事务管理器就是JDBC，连接池：POOLED"}]},{"ID":"20220618213813-11pbygk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213813-11pbygk","updated":"20220618213813"},"Children":[{"Type":"NodeText","Data":"属性"}]},{"ID":"20220618213814-lckdqz3","Type":"NodeParagraph","Properties":{"id":"20220618213814-lckdqz3","updated":"20220810151906"},"Children":[{"Type":"NodeText","Data":"可以通过properties属性来实现引用配置文件"}]},{"ID":"20220618213815-d6uc95h","Type":"NodeParagraph","Properties":{"id":"20220618213815-d6uc95h","updated":"20220618213815"},"Children":[{"Type":"NodeText","Data":"编写一个配置文件db.properties"}]},{"ID":"20220618213816-0pn5wkq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213816-0pn5wkq","updated":"20220618213816"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw=="},{"Type":"NodeCodeBlockCode","Data":"driver=com.mysql.jdbc.Driver\nurl=jdbc:mysql://localhost:3306/mybatis?useSSL=false\u0026useUnicode=true\u0026characterEncoding=UTF8\nusername=root\npassword=root\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213817-tenx2g3","Type":"NodeParagraph","Properties":{"id":"20220618213817-tenx2g3","updated":"20220618213817"},"Children":[{"Type":"NodeText","Data":"更改mybatis-config.xml文件"}]},{"ID":"20220618213818-1b7x5xx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213818-1b7x5xx","updated":"20220622164332"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF8\"?\u003e\n\u003c!DOCTYPE configuration\n        PUBLIC \"-//mybatis.org//DTD Config 3.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-3-config.dtd\"\u003e\n\n\u003cconfiguration\u003e\n\n    \u003c!--引入外部配置文件--\u003e\n    \u003cproperties resource=\"db.properties\"\u003e\n    \u003c/properties\u003e\n\n    \u003csettings\u003e\n        \u003csetting name=\"logImpl\" value=\"STDOUT_LOGGING\"/\u003e\n    \u003c/settings\u003e\n    \u003c!--可以给实体类起别名--\u003e\n    \u003ctypeAliases\u003e\n        \u003cpackage name=\"com.Xia.pojo\"/\u003e\n    \u003c/typeAliases\u003e\n\n    \u003cenvironments default=\"development\"\u003e\n        \u003cenvironment id=\"development\"\u003e\n            \u003ctransactionManager type=\"JDBC\"/\u003e\n            \u003cdataSource type=\"POOLED\"\u003e\n                \u003cproperty name=\"driver\" value=\"${driver}\"/\u003e\n                \u003cproperty name=\"url\" value=\"${url}\"/\u003e\n                \u003cproperty name=\"username\" value=\"${username}\"/\u003e\n                \u003cproperty name=\"password\" value=\"${password}\"/\u003e\n            \u003c/dataSource\u003e\n        \u003c/environment\u003e\n    \u003c/environments\u003e\n\n        \u003cmappers\u003e\n            \u003cmapper class=\"com.Xia.Dao.TeacherMapper\"/\u003e\n            \u003cmapper class=\"com.Xia.Dao.StudentMapper\"/\u003e\n        \u003c/mappers\u003e\n\n\u003c/configuration\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213819-9h6ru9m","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213819-9h6ru9m","updated":"20220618213819"},"Children":[{"Type":"NodeText","Data":"类型别名"}]},{"ID":"20220618213820-fhcnkf0","Type":"NodeParagraph","Properties":{"id":"20220618213820-fhcnkf0","updated":"20220618213820"},"Children":[{"Type":"NodeText","Data":"第一种：可以自定义名字，实体类较少时使用"}]},{"ID":"20220618213821-ybc6of6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213821-ybc6of6","updated":"20220618213821"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003c!--可以给实体类起别名--\u003e\n    \u003ctypeAliases\u003e\n        \u003ctypeAlias type=\"com.Xia.pojo.User\" alias=\"User\"/\u003e\n    \u003c/typeAliases\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213822-vst6wu7","Type":"NodeParagraph","Properties":{"id":"20220618213822-vst6wu7","updated":"20220618213822"},"Children":[{"Type":"NodeText","Data":"第二种：不可以自定义名字，只能和pojo下的类名一样，但不区分大小写，实体类十分多时使用"}]},{"ID":"20220618213823-w9d14qe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213823-w9d14qe","updated":"20220618213823"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003c!--可以给实体类起别名--\u003e\n    \u003ctypeAliases\u003e\n        \u003cpackage name=\