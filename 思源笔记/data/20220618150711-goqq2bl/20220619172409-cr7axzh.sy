D":"20220618211727-2rp7w6h","Type":"NodeParagraph","Properties":{"id":"20220618211727-2rp7w6h","updated":"20220618211727"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/浮点-20220618215622-lwu18af.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618211728-r1t6if7","Type":"NodeParagraph","Properties":{"id":"20220618211728-r1t6if7","updated":"20220618211728"},"Children":[{"Type":"NodeText","Data":"​"}]},{"ID":"20220618211729-0tpg50z","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211729-0tpg50z","updated":"20220618211729"},"Children":[{"Type":"NodeText","Data":"大数运算BigInteger"}]},{"ID":"20220618211730-mh1opp3","Type":"NodeParagraph","Properties":{"id":"20220618211730-mh1opp3","updated":"20220618211730"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/梅森素数-20220618215622-8ban8fb.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618211731-iinrymh","Type":"NodeParagraph","Properties":{"id":"20220618211731-iinrymh","updated":"20220618211731"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/大数运算-20220618215622-dbgm0qp.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618211732-x3r1rga","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211732-x3r1rga","updated":"20220618211732"},"Children":[{"Type":"NodeText","Data":"颠倒的价牌"}]},{"ID":"20220618211733-w2d98z1","Type":"NodeParagraph","Properties":{"id":"20220618211733-w2d98z1","updated":"20220618211733"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/颠倒的价牌-20220618215622-bd8o9f7.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618211734-82d2d8c","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618211734-82d2d8c","updated":"20220618211734"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Iterator;\npublic class ReversePrice {\n\tpublic static void main(String[] args) {\n\t\tfor (int i = 1000; i\u003c=9999; i++) {\n\t\t\tint ReverseNum = Reverse(i);\n\t\t\t//要保证亏的价格在-200到-300 并且倒转的数不会以0开头\n\t\t\tif(ReverseNum \u003e= 1000 \u0026\u0026 (ReverseNum - i) \u003c= -200 \u0026\u0026 (ReverseNum - i) \u003e -300) {\n\t\t\t\tfor(int j = 1000; j \u003c= 9999; j++) {\n\t\t\t\t\tint ReverseNum2 = Reverse(j);\n\t\t\t\t\t//保证赚的价格在800-900 并且倒转的数不会以0开头 并且两数相加为558\n\t\t\t\t\tif ((ReverseNum - i) + (ReverseNum2 - j) == 558 \u0026\u0026 ReverseNum2 \u003e= 1000 \u0026\u0026 (ReverseNum2 - j) \u003e= 800 \u0026\u0026 (ReverseNum2 - j) \u003c 900) {\n\t\t\t\t\t\tSystem.out.println(\"赔200的原价是:\"+i);\n\t\t\t\t\t\tbreak;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\t\t\t\t\n\t\t}\n\t}\n\tstatic int Reverse(int num) {\n\t\tint num1 = num / 1000; //千位  倒转后为个位\n\t\tint num2 = num / 100 % 10;// 百位 倒转后为十位位\n\t\tint num3 = num % 100 / 10;// 十位 倒转后为百位\n\t\tint num4 = num % 10;// 个位 倒转后为千位\n\t\n\t\t//3、4、7不能倒\n\t\tif(num1 == 3 || num2 == 3 || num2 == 3 || num2 == 3) {\n\t\t\treturn 0;\n\t\t}\n\t\tif(num1 == 4 || num2 == 4 || num2 == 4 || num2 == 4) {\n\t\t\treturn 0;\n\t\t}\n\t\tif(num1 == 7 || num2 == 7 || num2 == 7 || num2 == 7) {\n\t\t\treturn 0;\n\t\t}\n\n\t\t//6变9  9变6\n\t\tif(num1 == 6) {\n\t\t\tnum1 = 9;\n\t\t}else if(num1 == 9) {\n\t\t\tnum1 = 6;\n\t\t}\n\t\tif(num2 == 6) {\n\t\t\tnum2 = 9;\n\t\t}else if(num2 == 9) {\n\t\t\tnum2 = 6;\n\t\t}\n\t\tif(num3 == 6) {\n\t\t\tnum3 = 9;\n\t\t}else if(num3 == 9) {\n\t\t\tnum3 = 6;\n\t\t}\n\t\tif(num4 == 6) {\n\t\t\tnum4 = 9;\n\t\t}else if(num4 == 9) {\n\t\t\tnum4 = 6;\n\t\t}\n\t\tint newNum = num4*1000 + num3*100 + num2*10 + num1;\n\t\treturn newNum;\n\t}\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618211735-01l6su9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211735-01l6su9","updated":"20220618211735"},"Children":[{"Type":"NodeText","Data":"逆波兰表达式"}]},{"ID":"20220618211736-9kop6sg","Type":"NodeParagraph","Properties":{"id":"20220618211736-9kop6sg","updated":"20220618211736"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/逆波兰表达式-20220618215622-tp10huq.png"},{"Type":"NodeCloseParen"}]}]}]}