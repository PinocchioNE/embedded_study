rties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/thread-20220618215622-bbvih9y.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212456-2et5cp4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212456-2et5cp4","updated":"20220618212456"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package TestThread;\n//创建线程方式一：继承Thread类，重写run方法，调用start开启线程\npublic class testThread extends Thread{\n    @Override\n    public void run() {\n        //run方法线程体\n        for (int i = 0; i \u003c 20; i++) {\n            System.out.println(\"我在看代码--\"+i);\n        }\n    }\n\n    public static void main(String[] args) {\n        //main线程，主线程\n\n        //创建一个线程对象\n        testThread testThread1 = new testThread();\n\n        //调用start()方法开启线程\n        testThread1.start();\n\n        for (int i = 0; i \u003c 2000; i++) {\n            System.out.println(\"我在学习多线程--\"+i);\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212457-t9ft901","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212457-t9ft901","updated":"20220618212457"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220618212458-xvua63y","Type":"NodeBlockquote","Properties":{"id":"20220618212458-xvua63y","updated":"20220618212458"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212459-tbijztm","Type":"NodeParagraph","Properties":{"id":"20220618212459-tbijztm","updated":"20220618212459"},"Children":[{"Type":"NodeText","Data":"创建线程方式一：继承Thread类，重写run方法，调用start开启线程","Properties":{"id":""}}]},{"ID":"20220618212460-4w8hu14","Type":"NodeParagraph","Properties":{"id":"20220618212460-4w8hu14","updated":"20220618212460"},"Children":[{"Type":"NodeText","Data":"注意，线程开启不一定立即执行，执行顺序由CPU调度","Properties":{"id":""}}]}]},{"ID":"20220618212461-h87p7o6","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212461-h87p7o6","updated":"20220618212461"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"案例：下载图片","Properties":{"id":""}}]},{"ID":"20220618212462-2y5g7i6","Type":"NodeParagraph","Properties":{"id":"20220618212462-2y5g7i6","updated":"20220618212462"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/图片-20220618215622-luxgw44.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212463-ixm569k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212463-ixm569k","updated":"20220618212463"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package TestThread;\n\nimport org.apache.commons.io.FileUtils;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.net.URL;\n\n//练习Thread,实现多线程同步下载图片\npublic class testThread2 extends Thread{\n    private String url;// 网络图片地址\n    private String name;//保存的文件名\n\n    public testThread2(String url,String name){\n        this.url = url;\n        this.name = name;\n    }\n\n    //下载图片线程的执行体\n    @Override\n    public void run() {\n        WebDownloader webDownloader = new WebDownloader();\n        webDownloader.downloader(url, name);\n        System.out.println(\"下载了文件名为：\"+name);\n    }\n\n    public static void main(String[] args) {\n        testThread2 t1 = new testThread2(\"\",\"\");//\"图片地址\",\"保存的文件名\"\n        testThread2 t2 = new testThread2(\"\",\"\");\n        testThread2 t3 = new testThread2(\"\",\"\");\n        t1.start();\n        t2.start();\n        t3.start();\n    }\n}\n//下载器\nclass WebDownloader{\n    //下载方法\n    public void downloader(String url, String name){\n        try {\n            FileUtils.copyURLToFile(new URL(url),new File(name));\n        } catch (IOException e) {\n            e.printStackTrace();\n            System.out.println(\"IO异常，downloader方法出现问题\");\n        }\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212464-k40pcng","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212464-k40pcng","updated":"20220618212464"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.Runnable创建方法","Properties":{"id":""}}]},{"ID":"20220618212465-kp5q58l","Type":"NodeParagraph","Properties":{"id":"20220618212465-kp5q58l","updated":"20220618212465"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/run-20220618215622-p2heyww.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212466-bvg98wn","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212466-bvg98wn","updated":"20220618212466"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220618212467-sq1k0i8","Type":"NodeParagraph","Properties":{"id":"20220618212467-sq1k0i8","updated":"20220618212467"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/小-20220618215622-sp78vw6.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212468-7mdprrm","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212468-7mdprrm","updated":"20220618212468"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"龟兔赛跑案例","Properties":{"id":""}}]},{"ID":"20220618212469-v27oved","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212469-v27oved","updated":"20220618212469"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package TestThread;\n\n//模拟龟兔赛跑\npublic class race implements Runnable{\n\n    //胜利者\n    private static String winner;\n\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c= 1000; i++) {\n            //模拟兔子睡觉，每10步休息1ms\n            if (Thread.currentThread().getName().equals(\"兔子\")\u0026\u0026 i%10==0){\n                try {\n                    Thread.sleep(1);\n                } catch (InterruptedException e) {\n                    e.printStackTrace();\n                }\n            }\n\n            //判断比赛是否结束\n            boolean flag = gameOver(i);\n            //如果比赛结束了，就停止程序\n            if (flag){\n                break;\n            }\n\n            System.out.println(Thread.currentThread().getName()+\"--\u003e跑了\"+i+\"步\");\n        }\n    }\n\n    //判断是否完成比赛\n    private boolean gameOver(int steps){\n        //判断是否有胜利者\n        if(winner!=null){//已经存在胜利者\n            return true;\n        }\n        if (steps\u003e=1000){\n            winner = Thread.currentThread().getName();\n            System.out.println(\"winner is \"+winner);\n            return true;\n        }\n        return false;\n    }\n\n    public static void main(String[] args) {\n\n        race race1 = new race();\n\n        new Thread(race1,\"兔子\").start();\n        new Thread(race1,\"乌龟\").start();\n\n    }\n}\n\n部分结果：\n乌龟--\u003e跑了277步\n兔子--\u003e跑了14步\n兔子--\u003e跑了15步\n兔子--\u003e跑了16步\n兔子--\u003e跑了17步\n兔子--\u003e跑了18步\n兔子--\u003e跑了19步\n乌龟--\u003e跑了278步\n乌龟--\u003e跑了279步\n乌龟--\u003e跑了280步\n乌龟--\u003e跑了281步\n乌龟--\u003e跑了282步\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212470-4o1p08t","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212470-4o1p08t","updated":"20220618212470"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.实现Callable接口","Properties":{"id":""}}]},{"ID":"20220618212471-m0kdmkt","Type":"NodeParagraph","Properties":{"id":"20220618212471-m0kdmkt","updated":"20220618212471"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/call-20220618215622-twhgybx.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212472-8g1l57e","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212472-8g1l57e","updated":"20220618212472"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"静态代理","Properties":{"id":""}}]},{"ID":"20220618212473-6xrjkwt","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212473-6xrjkwt","updated":"20220618212473"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220618212474-bktbvwy","Type":"NodeBlockquote","Properties":{"id":"20220618212474-bktbvwy","updated":"20220618212474"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212475-lqv6697","Type":"NodeParagraph","Properties":{"id":"20220618212475-lqv6697","updated":"20220618212475"},"Children":[{"Type":"NodeText","Data":"真实对象和代理对象都要实现同一个接口","Properties":{"id":""}}]},{"ID":"20220618212476-mvivpm4","Type":"NodeParagraph","Properties":{"id":"20220618212476-mvivpm4","updated":"20220618212476"},"Children":[{"Type":"NodeText","Data":"代理对象要代理真实角色","Properties":{"id":""}}]}]},{"ID":"20220618212477-y705i0d","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212477-y705i0d","updated":"20220618212477"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"好处：","Properties":{"id":""}}]},{"ID":"20220618212478-r51g0in","Type":"NodeBlockquote","Properties":{"id":"20220618212478-r51g0in","updated":"20220618212478"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212479-kxczb5t","Type":"NodeParagraph","Properties":{"id":"20220618212479-kxczb5t","updated":"20220618212479"},"Children":[{"Type":"NodeText","Data":"代理对象可以做很多真实对象做不了的事情","Properties":{"id":""}}]},{"ID":"20220618212480-8q5c5jd","Type":"NodeParagraph","Properties":{"id":"20220618212480-8q5c5jd","updated":"20220618212480"},"Children":[{"Type":"NodeText","Data":"真实对象专注做自己的事情","Properties":{"id":""}}]}]},{"ID":"20220618212481-x5ajl0x","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212481-x5ajl0x","updated":"20220618212481"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"通过婚庆公司例子对比线程的静态代理","Properties":{"id":""}}]},{"ID":"20220618212482-spl76le","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212482-spl76le","updated":"20220618212482"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package StaticProxy;\n\npublic class Staticproxy {\n    public static void main(String[] args) {\n        You you = new You();\n\n        //对比Thread与结婚函数，Thread代理Runnable，调用start方法\n        //婚庆公司代理我自己，调用happymarry方法\n        new Thread(()-\u003e System.out.println(\"gun\")).start();//lambda表达式\n\n        new WeddingCompany(new You()).HappyMarry();\n    }\n}\n\ninterface Marry{\n    void HappyMarry();\n}\n\n//自己\nclass You implements Marry{\n    @Override\n    public void HappyMarry() {\n        System.out.println(\"结婚，开心\");\n    }\n}\n\n//婚庆公司\nclass WeddingCompany implements Marry{\n\n    private Marry target;//代理谁？真实的结婚对象\n\n    public WeddingCompany(Marry target){\n        this.target = target;\n    }\n\n    @Override\n    public void HappyMarry() {\n        before();\n        this.target.HappyMarry();//真实的自己\n        after();\n    }\n    private void before() {\n        System.out.println(\"布置\");\n    }\n    private void after() {\n        System.out.println(\"收钱\");\n    }\n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212483-8y53nrn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212483-8y53nrn","updated":"20220618212483"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Lambda表达式","Properties":{"id":""}}]},{"ID":"20220618212484-e623dzm","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212484-e623dzm","updated":"20220618212484"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么要用Lambda","Properties":{"id":""}}]},{"ID":"20220618212485-hxx0cub","Type":"NodeParagraph","Properties":{"id":"20220618212485-hxx0cub","updated":"20220618212485"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/表达-20220618215622-6qhya4r.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212486-gjzelvz","Type":"NodeBlockquote","Properties":{"id":"20220618212486-gjzelvz","updated":"20220618212486"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212487-q8n1xjm","Type":"NodeParagraph","Properties":{"id":"20220618212487-q8n1xjm","updated":"20220618212487"},"Children":[{"Type":"NodeText","Data":"避免匿名内部类定义过多","Properties":{"id":""}}]},{"ID":"20220618212488-kr9rets","Type":"NodeParagraph","Properties":{"id":"20220618212488-kr9rets","updated":"20220618212488"},"Children":[{"Type":"NodeText","Data":"可以让你的代码看起来很简洁","Properties":{"id":""}}]},{"ID":"20220618212489-9xlat1o","Type":"NodeParagraph","Properties":{"id":"20220618212489-9xlat1o","updated":"20220618212489"},"Children":[{"Type":"NodeText","Data":"去掉了一堆没有意义的代码，只留下核心的逻辑","Properties":{"id":""}}]}]},{"ID":"20220618212490-lsefbuy","Type":"NodeParagraph","Properties":{"id":"20220618212490-lsefbuy","updated":"20220618212490"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/lam-20220618215622-ge8fult.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212491-58c1la0","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212491-58c1la0","updated":"20220618212491"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"lambda与其他方法的区别","Properties":{"id":""}}]},{"ID":"20220618212492-0zy9xnx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212492-0zy9xnx","updated":"20220618212492"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package lambda;\n\nimport javax.jws.soap.SOAPBinding;\n\npublic class lambda {\n\n    //3.静态内部类\n    static class Like2 implements ILike{\n        @Override\n        public void lambda() {\n            System.out.println(\"i like lambda2\");\n        }\n    }\n\n    public static void main(String[] args) {\n        ILike like =new Like();\n        like.lambda();\n\n        like = new Like2();\n        like.lambda();\n\n        //4.局部内部类\n        class Like3 implements ILike{\n            @Override\n            public void lambda() {\n                System.out.println(\"i like lmadba3\");\n            }\n        }\n\n        like = new Like3();\n        like.lambda();\n\n        //匿名内部类\n        like = new ILike() {\n            @Override\n            public void lambda() {\n                System.out.println(\"i like lambda4\");\n            }\n        };\n        like.lambda();\n\n        //6.用lambda简化\n        like = ()-\u003e{\n            System.out.println(\"i like lambda5\");\n        };\n        like.lambda();\n    }\n}\n\n//1.定义一个函数式接口\ninterface ILike{\n    void lambda();\n}\n\n//2.实现类\nclass Like implements ILike{\n    @Override\n    public void lambda() {\n        System.out.println(\"i like lambda\");\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212493-bxkaa3r","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212493-bxkaa3r","updated":"20220618212493"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"lambda表达式书写","Properties":{"id":""}}]},{"ID":"20220618212494-quka8ac","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212494-quka8ac","updated":"20220618212494"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package lambda;\n\npublic class TestLambda {\n    public static void main(String[] args) {\n        ILove love = null;\n        //1.lambda表示简化\n//        ILove love = (int a)-\u003e{\n//            System.out.println(\"i love you __\u003e\"+a);\n//        };\n//        love.love(10);\n\n        // 简化1.参数类型\n//        love = (a)-\u003e{\n//            System.out.println(\"i love you --\u003e\"+a);\n//        };\n\n        //简化2.简化括号\n//        love = a-\u003e{\n//            System.out.println(\"i love you --\u003e\"+a);\n//        };\n//\n        //简化3.去掉花括号\n        love = a-\u003e System.out.println(\"i love you --\u003e\"+a);\n        love.love(10);\n\n        //总结：1.lambda表达式只能有一行代码的情况下才能简化成一行，如果有多行，就用代码块包裹\n        //2.前提是接口为函数式接口\n        //3.多个参数也可以去掉参数类型，要去掉就都去掉，必须加上括号\n    }\n\n}\n\ninterface ILove{\n    void love(int a);\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212495-36oho0h","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212495-36oho0h","updated":"20220618212495"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"三、线程状态","Properties":{"id":""}}]},{"ID":"20220618212496-0lrld0z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212496-0lrld0z","updated":"20220618212496"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"五大状态","Properties":{"id":""}}]},{"ID":"20220618212497-8yuywo6","Type":"NodeParagraph","Properties":{"id":"20220618212497-8yuywo6","updated":"20220618212497"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/状态-20220618215622-hcl9ljo.pn