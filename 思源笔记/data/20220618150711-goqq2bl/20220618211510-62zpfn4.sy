au","Type":"NodeParagraph","Properties":{"id":"20220618211945-5eytjau","updated":"20220618211945"},"Children":[{"Type":"NodeText","Data":"super和this不能同时调用构造方法","Properties":{"id":""}}]}]}]},{"ID":"20220618211946-jiykdcp","Type":"NodeParagraph","Properties":{"id":"20220618211946-jiykdcp","updated":"20220618211946"},"Children":[{"Type":"NodeText","Data":"对比 this","Properties":{"id":""}}]},{"ID":"20220618211947-hrpcqmo","Type":"NodeParagraph","Properties":{"id":"20220618211947-hrpcqmo","updated":"20220618211947"},"Children":[{"Type":"NodeText","Data":"代表的对象不同：","Properties":{"id":""}}]},{"ID":"20220618211948-ktop0ox","Type":"NodeParagraph","Properties":{"id":"20220618211948-ktop0ox","updated":"20220618211948"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tthis：本身调用着这个对象","Properties":{"id":""}}]},{"ID":"20220618211949-fe61s5m","Type":"NodeParagraph","Properties":{"id":"20220618211949-fe61s5m","updated":"20220618211949"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tsuper：代表父类对象的引用","Properties":{"id":""}}]},{"ID":"20220618211950-mtmtfvz","Type":"NodeParagraph","Properties":{"id":"20220618211950-mtmtfvz","updated":"20220618211950"},"Children":[{"Type":"NodeText","Data":"前提：","Properties":{"id":""}}]},{"ID":"20220618211951-rar3ktd","Type":"NodeParagraph","Properties":{"id":"20220618211951-rar3ktd","updated":"20220618211951"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tthis：没有继承也可以使用","Properties":{"id":""}}]},{"ID":"20220618211952-tuu4pp5","Type":"NodeParagraph","Properties":{"id":"20220618211952-tuu4pp5","updated":"20220618211952"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tsuper：只能在继承条件才可以使用","Properties":{"id":""}}]},{"ID":"20220618211953-b6bcbu1","Type":"NodeParagraph","Properties":{"id":"20220618211953-b6bcbu1","updated":"20220618211953"},"Children":[{"Type":"NodeText","Data":"构造方法","Properties":{"id":""}}]},{"ID":"20220618211954-zi0whzy","Type":"NodeParagraph","Properties":{"id":"20220618211954-zi0whzy","updated":"20220618211954"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tthis（）：本类的构造","Properties":{"id":""}}]},{"ID":"20220618211955-tuppdc7","Type":"NodeParagraph","Properties":{"id":"20220618211955-tuppdc7","updated":"20220618211955"},"Children":[{"Type":"NodeText","Data":"​\t\t\t\tsuper（）：父类的构造","Properties":{"id":""}}]}]},{"ID":"20220618211956-3um0ge0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211956-3um0ge0","updated":"20220618211956"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 父类\npublic class Person {\n    public void say() {\n        System.out.println(\"爷在父类说了一句话\");\n    }\n}\n\n\n# 子类\npublic class Student extends Person{\n    public void say() {\n        System.out.println(\"爷在子类说了一句话\");\n    }\n\n    public void test(){\n        say(); //调用子类自己的\n        this.say(); //调用子类自己的\n        super.say(); //调用父类的\n\n    }\n}\n\n\n# new一个student\npublic class test {\n    public static void main(String[] args) {\n        Student student = new Student();\n        student.test();\n    }\n}\n\n# 结果\n爷在子类说了一句话\n爷在子类说了一句话\n爷在父类说了一句话\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211957-wvo1jos","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618211957-wvo1jos","updated":"20220618211957"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"方法重写","Properties":{"id":""}}]},{"ID":"20220618211958-sgw6imv","Type":"NodeBlockquote","Properties":{"id":"20220618211958-sgw6imv","updated":"20220618211958"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618211959-goo4d7z","Type":"NodeParagraph","Properties":{"id":"20220618211959-goo4d7z","updated":"20220618211959"},"Children":[{"Type":"NodeText","Data":"重写都是方法的重写，和属性无关","Properties":{"id":""}}]}]},{"ID":"20220618211960-mlck8x3","Type":"NodeBlockquote","Properties":{"id":"20220618211960-mlck8x3","updated":"20220618211960"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618211961-56yg5ji","Type":"NodeParagraph","Properties":{"id":"20220618211961-56yg5ji","updated":"20220618211961"},"Children":[{"Type":"NodeText","Data":"以下不能重写：","Properties":{"id":""}}]},{"ID":"20220618211962-yq645ov","Type":"NodeParagraph","Properties":{"id":"20220618211962-yq645ov","updated":"20220618211962"},"Children":[{"Type":"NodeText","Data":"1.static 方法，属于类，他不属于实例，不能重写","Properties":{"id":""}}]},{"ID":"20220618211963-w14s9zi","Type":"NodeParagraph","Properties":{"id":"20220618211963-w14s9zi","updated":"20220618211963"},"Children":[{"Type":"NodeText","Data":"2.final 常量；","Properties":{"id":""}}]},{"ID":"20220618211964-l6y7e88","Type":"NodeParagraph","Properties":{"id":"20220618211964-l6y7e88","updated":"20220618211964"},"Children":[{"Type":"NodeText","Data":"3.private方法；","Properties":{"id":""}}]}]},{"ID":"20220618211965-ks392jg","Type":"NodeBlockquote","Properties":{"id":"20220618211965-ks392jg","updated":"20220618211965"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618211966-5sajpyo","Type":"NodeParagraph","Properties":{"id":"20220618211966-5sajpyo","updated":"20220618211966"},"Children":[{"Type":"NodeText","Data":"重写：需要有继承关系，子类重写个父类的方法！","Properties":{"id":""}}]},{"ID":"20220618211967-q5zxwj8","Type":"NodeParagraph","Properties":{"id":"20220618211967-q5zxwj8","updated":"20220618211967"},"Children":[{"Type":"NodeText","Data":"​\t1.方法名必须相同","Properties":{"id":""}}]},{"ID":"20220618211968-eqo62fv","Type":"NodeParagraph","Properties":{"id":"20220618211968-eqo62fv","updated":"20220618211968"},"Child