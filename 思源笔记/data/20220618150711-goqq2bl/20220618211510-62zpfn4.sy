:"NodeLinkDest","Data":"assets/5-20220618215622-xtqk3ym.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212684-z3v3wkm","Type":"NodeParagraph","Properties":{"id":"20220618212684-z3v3wkm","updated":"20220618212684"},"Children":[{"Type":"NodeText","Data":"第五步","Properties":{"id":""}}]},{"ID":"20220618212685-q3885y3","Type":"NodeBlockquote","Properties":{"id":"20220618212685-q3885y3","updated":"20220618212685"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212686-jl9s844","Type":"NodeParagraph","Properties":{"id":"20220618212686-jl9s844","updated":"20220618212686"},"Children":[{"Type":"NodeText","Data":"选build","Properties":{"id":""}}]}]},{"ID":"20220618212687-6n1yvqu","Type":"NodeParagraph","Properties":{"id":"20220618212687-6n1yvqu","updated":"20220618212687"},"Children":[{"Type":"NodeText","Data":"第六步","Properties":{"id":""}}]},{"ID":"20220618212688-nle5sbq","Type":"NodeParagraph","Properties":{"id":"20220618212688-nle5sbq","updated":"20220618212688"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/6-20220618215622-ez5l485.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212689-5vwo9yz","Type":"NodeParagraph","Properties":{"id":"20220618212689-5vwo9yz","updated":"20220618212689"},"Children":[{"Type":"NodeText","Data":"第七步","Properties":{"id":""}}]},{"ID":"20220618212690-4qc2vzz","Type":"NodeBlockquote","Properties":{"id":"20220618212690-4qc2vzz","updated":"20220618212690"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212691-gx9wolg","Type":"NodeParagraph","Properties":{"id":"20220618212691-gx9wolg","updated":"20220618212691"},"Children":[{"Type":"NodeText","Data":"如何运行,在文件名前加cmd","Properties":{"id":""}}]}]},{"ID":"20220618212692-z94i5ta","Type":"NodeParagraph","Properties":{"id":"20220618212692-z94i5ta","updated":"20220618212692"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/7-20220618215622-22c7dl6.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212693-gcptxb3","Type":"NodeParagraph","Properties":{"id":"20220618212693-gcptxb3","updated":"20220618212693"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/8-20220618215622-lp6aj46.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212694-yszl2lh","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618212694-yszl2lh","updated":"20220618212694"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"网络编程","Properties":{"id":""}}]},{"ID":"20220618212695-81r8ey8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212695-81r8ey8","updated":"20220618212695"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"网络基础理论知识","Properties":{"id":""}}]},{"ID":"20220618212696-19l01sf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212696-19l01sf","updated":"20220618212696"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"1、早期的ARPAnet使用ncp控制协议\n\n2、TCP / IP协议\n\t\tTCP:用来检测网络传输中的差错问题。\n\t\tIP :用于互联不同网络的主机。\n\t\tTCP/IP协议是iniernet网络中的“世界语”\n\n3、网络体系结构：网络层次结构和协议的集合。\n\t\t\t  网络体系结构分为osi模型和tcp/ip模型。\nosi模型7层结构：应用层、表示层、会话层、传输层、网络层、数据链路层、物理层。\n\t\t  tcp/ip体系结构：应用层、传输层、网络层、网络接口和物理层。\n\t\t  应用层：http\n\t\t  传输层：tcp，udp\n\t\t  网络层: ip, icmp\n\t\t  网络接口层(数据链路与物理层)： 以太网\n4、TCP/IP是协议是传输控制协议，以称为网络通信协议。\n\t\ttcp/IP协议协议族:\n\t\t\tTCP:传输控制协议。\n\t\t\tIP：网间协议\n\t\t\tUDP：数据报协议\n\t\t\tSMTP：邮件传输协议\n\t\t\tHTTP:超文本传输协议\n5、UDP和TCP \t\n\t共同点：同为传输层协议\n\t不同点：\n\t\tTCP:面向有连接，可靠(保证数据可靠\u003c数据无失序、无重复、无丢失到达\u003e)\n\t\tUDP:面向无连接，不保证数据可靠\nTCP:是一种面向连接的传输协议，提供高可靠通信（数据无丢失，数据无误，数据无失序）\n\t三次握手，四次挥手\n\t使用场景：对传输质量要求较高，传输大量数据的通信\n\t\nUDP：用户数据报协议，是不可靠的无连接协议。\n\t使用场景：    1.传输小尺寸数据\n\t\t\t\t2.应答困难的网络中（无线网络）\n\t\t\t\t3.QQ点对点的文件传输和音视频传输\n\t\t\t\t4.网络电话、流媒体\n\t\t\t\t5.广播、组播\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212697-21ah75l","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212697-21ah75l","updated":"20220618212697"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"三次握手，四次挥手","Properties":{"id":""}}]},{"ID":"20220618212698-4iz9l9b","Type":"NodeParagraph","Properties":{"id":"20220618212698-4iz9l9b","updated":"20220618212698"},"Children":[{"Type":"NodeText","Data":"握手","Properties":{"id":""}}]},{"ID":"20220618212699-1z4hvyc","Type":"NodeParagraph","Properties":{"id":"20220618212699-1z4hvyc","updated":"20220618212699"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/握手-20220618215622-vy2i3ng.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212700-q6e68dl","Type":"NodeParagraph","Properties":{"id":"20220618212700-q6e68dl","updated":"20220618212700"},"Children":[{"Type":"NodeText","Data":"挥手","Properties":{"id":""}}]},{"ID":"20220618212701-jmvazq1","Type":"NodeParagraph","Properties":{"id":"20220618212701-jmvazq1","updated":"20220618212701"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/挥手-20220618215622-s6doiuv.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212702-hcoy5j5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212702-hcoy5j5","updated":"20220618212702"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"查询IP","Properties":{"id":""}}]},{"ID":"20220618212703-06atc98","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212703-06atc98","updated":"20220618212703"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"InetAddress类","Properties":{"id":""}}]},{"ID":"20220618212704-2o29mkm","Type":"NodeParagraph","Properties":{"id":"20220618212704-2o29mkm","updated":"20220618212704"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[",