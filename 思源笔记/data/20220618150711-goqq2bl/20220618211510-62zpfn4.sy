:{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class ForDemo02 {\n    public static void main(String[] args) {\n        //练习1：计算0到100之间的奇数和偶数的和\n\n        int oodSum = 0;\n        int evenSum = 0;\n        for (int i = 0; i \u003c 100; i++) {\n            if (i%2 != 0){//奇数\n                oodSum += i;\n            }else{//偶数\n                evenSum += i;\n            }\n        }\n        System.out.println(\"100内奇数的和\"+oodSum);\n\n\n        System.out.println(\"100内偶数的和\"+evenSum);\n    }\n}\n\n结果：\n    100内奇数的和2500\n\t100内偶数的和2450\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211834-b1qap0u","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618211834-b1qap0u","updated":"20220618211834"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"练习2：用while或for循环输出1-1000之间能被5整除的数，并且每行输出3个","Properties":{"id":""}}]},{"ID":"20220618211835-zzl2shd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211835-zzl2shd","updated":"20220618211835"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class ForDemo03 {\n    public static void main(String[] args) {\n        //练习2：用while或for循环输出1-1000之间能被5整除的数，并且每行输出3个\n\n        for (int i = 0; i \u003c= 1000; i++) {\n            if (i%5 == 0){\n                System.out.print(i+\"\\t\");\n            }\n            if (i%(5*3)==0){//每行  每有三个5的倍数换一行 4*5就表示4个5的倍数\n                System.out.println();\n                //System.out.print(\"\\n\");\n            }\n        }\n        //println 输出会换行\n        //print 输出不会换行\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211836-i2bxmz5","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618211836-i2bxmz5","updated":"20220618211836"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"练习3：打印九九乘法表","Properties":{"id":""}}]},{"ID":"20220618211837-cryn7zy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211837-cryn7zy","updated":"20220618211837"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class ForDemo04 {\n    public static void main(String[] args) {\n        int sum = 0;\n        for (int i = 1; i \u003c= 9; i++) {\n            for (int j = 1; j \u003c= i; j++) {\n                sum = j * i;\n                System.out.print(j+ \"*\"+i+ \"=\"+sum+\"\\t\");\n            }\n            System.out.println();\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211838-1q2775z","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618211838-1q2775z","updated":"20220618211838"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"TEST：打印5行的三角形","Properties":{"id":""}}]},{"ID":"20220618211839-t1k38ni","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211839-t1k38ni","updated":"20220618211839"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class TestDemo {\n    public static void main(String[] args) {\n        for (int i = 1; i \u003c= 5; i++) {\n            for (int j = 5; j \u003e= i ; j--) {\n                System.out.print(\" \");\n            }\n            for (int j = 1; j \u003c= i; j++) {\n                System.out.print(\"*\");\n            }\n            for (int j = 1; j \u003c i; j++) {\n                System.out.print(\"*\");\n            }\n            System.out.println();\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211840-i06toyr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618211840-i06toyr","updated":"20220618211840"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"增强for循环：遍历数组中的元素","Properties":{"id":""}}]},{"ID":"20220618211841-se0d83w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211841-se0d83w","updated":"20220618211841"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class ForDemo05 {\n    public static void main(String[] args) {\n        int [] numbers = {1,2,3,4};\n        for (int x:numbers){\n            System.out.println(x);\n        }\n    }\n}\n\n\n//快捷键\n数组名.for\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211842-2hq65i0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211842-2hq65i0","updated":"20220618211842"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"switch代码格式","Properties":{"id":""}}]},{"ID":"20220618211843-41k4zc0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211843-41k4zc0","updated":"20220618211843"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import java.util.Scanner;\npublic class SwitchDemo01 {\n    public static void main(String[] args) {\n        // case 穿透\n        Scanner scanner = new Scanner(System.in);\n\n        char grade = 'B';\n        switch (grade){\n            case 'A':\n                System.out.println(\"优秀\");\n                break;\n            case 'B':\n                System.out.println(\"良好\");\n                break;\n            case 'C':\n                System.out.println(\"及格\");\n                break;\n            case 'D':\n                System.out.println(\"不及格\");\n                break;\n            case 'E':\n                System.out.println(\"完啦\");\n                break;\n        }\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211844-fopdcw9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211844-fopdcw9","updated":"20220618211844"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"调用方法","Properties":{"id":""}}]},{"ID":"20220618211845-jgufncd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618211845-jgufncd","updated":"20220618211845"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class Demo01 {\n    //main方法\n    public static void main(String[] args) {\n        int sum = add(1,2);//调用了 加法函数\n        System.out.println(sum);\n        test();//调用了test函数\n    }\n    \n    \n    //加法\n    public static int add(int a, int b){\n        return a+b;\n    }\n    \n    \n    //调用其他方法\n    public static void test(){\n        //计算0到100之间的奇数和偶数的和\n\n        int oodSum = 0;\n        int evenSum = 0;\n        for (int i = 0; i \u003c 100; i++) {\n            if (i%2 != 0){//奇数\n                oodSum += i;\n            }else{//偶数\n                evenSum += i;\n            }\n        }\n        System.out.println(\"100内奇数的和\"+oodSum);\n\n\n        System.out.println(\"100内偶数的和\"+evenSum);\n    }\n}\n\n//这里调用了两个写好的函数\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618211846-onrf8xz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618211846-onrf8xz","updated":"20220618211846"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"方法的定义","Properties":{"id":""}}]},{"ID":"20220618211847-gf64b7y","Type":"NodeParagraph","Properties":{"id":"20220618211847-gf64b7y","updated":"20220618211847"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"