erties":{"id":""}},{"Type":"NodeText","Data":"特点","Properties":{"id":""}}]},{"ID":"20220618212248-l14znaa","Type":"NodeBlockquote","Properties":{"id":"20220618212248-l14znaa","updated":"20220618212248"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212249-5jpyepv","Type":"NodeParagraph","Properties":{"id":"20220618212249-5jpyepv","updated":"20220618212249"},"Children":[{"Type":"NodeText","Data":"代表一组任意类型的对象、无序、无下标、不能重复。","Properties":{"id":""}}]}]},{"ID":"20220618212250-tuautwm","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212250-tuautwm","updated":"20220618212250"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"方法","Properties":{"id":""}}]},{"ID":"20220618212251-d24oz36","Type":"NodeParagraph","Properties":{"id":"20220618212251-d24oz36","updated":"20220618212251"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/coll-20220618215622-vf3vgdr.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212252-y96uai9","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212252-y96uai9","updated":"20220618212252"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"add类、contains类、size类、isEmpty类、remove类、","Properties":{"id":""}}]},{"ID":"20220618212253-zba5x4d","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212253-zba5x4d","updated":"20220618212253"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class demo01 {\n    public static void main(String[] args) {\n        //创建集合\n        Collection collection = new ArrayList();\n        //(1)添加元素\n        collection.add(\"香蕉\");\n        collection.add(\"苹果\");\n        collection.add(\"西瓜\");\n        System.out.println(\"元素个数：\"+collection.size());\n        System.out.println(collection);//其中ArrayList已经包含tostring方法了\n        \n        //(3)遍历元素\n        //3.1使用增强for，因为不使用下标\n        System.out.println(\"----------------------------\");\n        for (Object object : collection) {\n            System.out.println(object);\n        }\n        \n        //3.2使用迭代器\n        //hasNext();有没有下一个元素\n        //next();获取下一个元素\n        //remove（）；删除当前元素\n        System.out.println(\"----------------------------\");\n        Iterator it = collection.iterator();\n        while(it.hasNext()){\n            String s =(String)it.next();\n            System.out.println(s);\n            it.remove();//不能使用collection删除方法，因为不能和collection其他方法并发使用\n            System.out.println(\"删除之后：\"+collection.size());\n        }\n        System.out.println(\"----------------------------\");\n        \n        //(4)判断\n        System.out.println(collection.contains(\"西瓜\"));\n        System.out.println(collection.isEmpty());\n        System.out.println(\"----------------------------\");\n        \n        //(2)删除元素\n        collection.remove(\"西瓜\");\n        System.out.println(\"删除之后：\"+collection.size());\n    }\n}\n\n//结果：\n元素个数：3\n[香蕉, 苹果, 西瓜]\n----------------------------\n香蕉\n苹果\n西瓜\n----------------------------\n香蕉\n删除之后：2\n苹果\n删除之后：1\n西瓜\n删除之后：0\n----------------------------\nfalse\ntrue\n----------------------------\n删除之后：0\n\nProcess finished with exit code 0\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212254-70vfsc6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212254-70vfsc6","updated":"20220618212254"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"三、List接口与实现类","Properties":{"id":""}}]},{"ID":"20220618212255-tht4j87","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212255-tht4j87","updated":"20220618212255"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"List子接口","Properties":{"id":""}}]},{"ID":"20220618212256-6l72l7l","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212256-6l72l7l","updated":"20220618212256"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"特点","Properties":{"id":""}}]},{"ID":"20220618212257-8kqcn2k","Type":"NodeBlockquote","Properties":{"id":"20220618212257-8kqcn2k","updated":"20220618212257"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212258-xrwtrly","Type":"NodeParagraph","Properties":{"id":"20220618212258-xrwtrly","updated":"20220618212258"},"Children":[{"Type":"NodeText","Data":"有序、有下标、元素可以重复","Properties":{"id":""}}]}]},{"ID":"20220618212259-ig2fel3","Type":"NodeParagraph","Properties":{"id":"20220618212259-ig2fel3","updated":"20220618212259"},"Children":[{"Type":"NodeText","Data":"方法","Properties":{"id":""}}]},{"ID":"20220618212260-p4ud9g3","Type":"NodeParagraph","Properties":{"id":"20220618212260-p4ud9g3","updated":"20220618212260"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/list-