8212611"},"Children":[{"Type":"NodeText","Data":"GUI的核心技术：AWT、Swing","Properties":{"id":""}}]},{"ID":"20220618212612-v7ifbzd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212612-v7ifbzd","updated":"20220618212612"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"AWT","Properties":{"id":""}}]},{"ID":"20220618212613-agdicd6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212613-agdicd6","updated":"20220618212613"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"组件和容器","Properties":{"id":""}}]},{"ID":"20220618212614-23h8dvw","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212614-23h8dvw","updated":"20220618212614"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"1.frame","Properties":{"id":""}}]},{"ID":"20220618212615-3ic1il6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212615-3ic1il6","updated":"20220618212615"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\n\n//GUI的第一个界面\npublic class TestFrame {\n    public static void main(String[] args) {\n        //Frame,JDK, 看源码\n        Frame frame = new Frame(\"我的第一个java图形界面窗口\");\n\n        //需要设置可见性 w h\n        frame.setVisible(true);\n\n        //设置窗口大小\n        frame.setSize(400,400 );\n\n        //设置背景颜色 Color\n        frame.setBackground(new Color(224, 51, 51));\n\n        //弹出的初始位置\n        frame.setLocation(200,200);\n\n        //设置大小固定\n        frame.setResizable(false);\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212616-4ntpjsy","Type":"NodeParagraph","Properties":{"id":"20220618212616-4ntpjsy","updated":"20220618212616"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/java窗口-20220618215622-ern08h4.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212617-9tsiaks","Type":"NodeParagraph","Properties":{"id":"20220618212617-9tsiaks","updated":"20220618212617"},"Children":[{"Type":"NodeText","Data":"尝试回顾封装：","Properties":{"id":""}}]},{"ID":"20220618212618-q31pzho","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212618-q31pzho","updated":"20220618212618"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\n\nimport java.awt.*;\n\npublic class TestFrame2 {\n    public static void main(String[] args) {\n        //展示多个窗口 new\n        MyFrame window1 = new MyFrame(100, 100, 200, 200, Color.blue);\n        MyFrame window2 = new MyFrame(300, 100, 200, 200, Color.yellow);\n        MyFrame window3 = new MyFrame(100, 300, 200, 200, Color.gray);\n        MyFrame window4 = new MyFrame(300, 300, 200, 200, Color.magenta);\n\n    }\n}\nclass MyFrame extends Frame {\n    static int id = 0;//可能存在多个窗口，我们需要一个计数器\n\n    public MyFrame(int x, int y, int w, int h, Color color){\n        //super(\"Myframe\"+(++id));\n        setBackground(color);\n        setBounds(x,y,w,h);\n        setVisible(true);\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212619-xrs1m5t","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212619-xrs1m5t","updated":"20220618212619"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.panel","Properties":{"id":""}}]},{"ID":"20220618212620-32rg7in","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212620-32rg7in","updated":"20220618212620"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.WindowAdapter;\nimport java.awt.event.WindowEvent;\n\n//Panel 可以看成是一个空间，但是不能单独存在\npublic class TestPanel {\n    public static void main(String[] args) {\n        Frame frame = new Frame();\n        Panel panel = new Panel();\n\n        //设置布局\n        frame.setLayout(null);\n\n        //坐标\n        frame.setBounds(300,300,500,500);\n        frame.setBackground(new Color(39, 167, 46));\n\n        //panel设置坐标，相对于frame\n        panel.setBounds(50,50,400,400);\n        panel.setBackground(new Color(142, 28, 28));\n\n        //frame.add(panel)\n        frame.add(panel);\n\n        frame.setVisible(true);\n\n        //监听事件，监听窗口关闭事件 system.exit(0) 用来关闭窗口\n        frame.addWindowListener(new WindowAdapter() { //WindowAdapter适配器\n            @Override\n            public void windowClosing(WindowEvent e) {\n                //结束程序\n                System.exit(0);\n            }\n        });\n\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212621-ogf1ib4","Type":"NodeParagraph","Properties":{"id":"20220618212621-ogf1ib4","updated":"20220618212621"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/panel-20220618215622-82npzla.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212622-daz8otv","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212622-daz8otv","updated":"20220618212622"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.布局管理器","Properties":{"id":""}}]},{"ID":"20220618212623-416nqcc","Type":"NodeList","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618212623-416nqcc","updated":"20220618212623"},"Children":[{"ID":"20220618212624-yffz1a4","Type":"NodeListItem","Data":"-","ListData":{"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220618212624-yffz1a4","updated":"20220618212624"},"Children":[{"ID":"20220618212625-wuaovyi","Type":"NodeParagraph","Properties":{"id":"20220618212625-wuaovyi","updated":"20220618212625"},"Children":[{"Type":"NodeText","Data":"流式布局","Properties":{"id":""}}]},{"ID":"20220618212626-l0olmdr","Type":"NodeParagraph","Properties":{"id":"20220618212626-l0olmdr","updated":"20220618212626"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":