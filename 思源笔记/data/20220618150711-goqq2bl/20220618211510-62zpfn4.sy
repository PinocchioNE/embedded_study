odeText","Data":"线程状态观测","Properties":{"id":""}}]},{"ID":"20220618212521-uxxcbag","Type":"NodeParagraph","Properties":{"id":"20220618212521-uxxcbag","updated":"20220618212521"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/state-20220618215622-75hg06d.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212522-qepoj18","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212522-qepoj18","updated":"20220618212522"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"线程的优先级","Properties":{"id":""}}]},{"ID":"20220618212523-q64lmut","Type":"NodeParagraph","Properties":{"id":"20220618212523-q64lmut","updated":"20220618212523"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/优先级-20220618215622-8qe2crk.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212524-jhes7vk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212524-jhes7vk","updated":"20220618212524"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//测试线程的优先级\npublic class TestPriority {\n    public static void main(String[] args) {\n        //主线程默认优先级为5\n        System.out.println(Thread.currentThread().getName()+\"--\u003e\"+Thread.currentThread().getPriority());\n\n        MyPriority myPriority = new MyPriority();\n\n        Thread thread1 = new Thread(myPriority);\n        Thread thread2 = new Thread(myPriority);\n        Thread thread3 = new Thread(myPriority);\n        Thread thread4 = new Thread(myPriority);\n        Thread thread5 = new Thread(myPriority);\n\n        //设置优先级再启动\n        thread2.setPriority(1);\n        thread3.setPriority(9);\n        thread4.setPriority(2);\n        thread5.setPriority(Thread.MAX_PRIORITY);\n\n        thread1.start();\n        thread2.start();\n        thread3.start();\n        thread4.start();\n        thread5.start();\n    }\n}\n\nclass MyPriority implements Runnable{\n    @Override\n    public void run() {\n        System.out.println(Thread.currentThread().getName()+\"--\u003e\"+Thread.currentThread().getPriority());\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212525-w89he24","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212525-w89he24","updated":"20220618212525"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"守护（daemon）线程","Properties":{"id":""}}]},{"ID":"20220618212526-o37z5uf","Type":"NodeParagraph","Properties":{"id":"20220618212526-o37z5uf","updated":"20220618212526"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/守护-20220618215622-mwtw2cx.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212527-2jbmqi8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212527-2jbmqi8","updated":"20220618212527"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package deamon;\n\npublic class TestDeamon {\n    public static void main(String[] args) {\n\n        God god = new God();\n        You you = new You();\n\n        Thread thread = new Thread(god);\n        thread.setDaemon(true);//默认false表示是用户线程，正常的线程都是用户线程\n\n        thread.start();//上帝守护线程启动\n        \n        new Thread(you).start();//你 用户线程启动\n//注意一个是new的thread 一个是直接new Thread\n    }\n}\n\n//上帝\nclass God implements Runnable{\n    @Override\n    public void run() {\n        while(true){\n            System.out.println(\"上帝保佑着你\");\n        }\n    }\n}\n//自己\nclass You implements Runnable{\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c 36500; i++) {\n            System.out.println(\"你一生都开心的活着\");\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212528-a9jwvbg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212528-a9jwvbg","updated":"20220618212528"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"四、线程同步（重点）","Properties":{"id":""}}]},{"ID":"20220618212529-fx6vard","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212529-fx6vard","updated":"20220618212529"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"线程同步概念","Properties":{"id":""}}]},{"ID":"20220618212530-mnd3bix","Type":"NodeBlockquote","Properties":{"id":"20220618212530-mnd3bix","updated":"20220618212530"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212531-nrgj7mk","Type":"NodeParagraph","Properties":{"id":"20220618212531-nrgj7mk","updated":"20220618212531"},"Children":[{"Type":"NodeText","Data":"处理多线程问题时,多个线程访问同一个对象，并且某些线程还想修改这个对象.这时候我们就需要线程同步﹒线程同步其实就是一种等待机制,多个需要同时访","Properties":{"id":""}}]},{"ID":"20220618212532-ah6r0p5","Type":"NodeParagraph","Properties":{"id":"20220618212532-ah6r0p5","updated":"20220618212532"},"Children":[{"Type":"NodeText","Data":"问此对象的线程进入这个对象的等待池形成队列,等待前面线程使用完毕，下一个线程再使用","Properties":{"id":""}}]}]},{"ID":"20220618212533-upcythk","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212533-upcythk","updated":"20220618212533"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"形成条件","Properties":{"id":""}}]},{"ID":"20220618212534-af6lco5","Type":"NodeBlockquote","Properties":{"id":"20220618212534-af6lco5","updated":"20220618212534"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212535-2jf8etz","Type":"NodeParagraph","Properties":{"id":"20220618212535-2jf8etz","updated":"20220618212535"},"Children":[{"Type":"NodeText","Data":"队列+锁","Properties":{"id":""}}]}]},{"ID":"20220618212536-5tgfhft","Type":"NodeParagraph","Properties":{"id":"20220618212536-5tgfhft","updated":"20220618212536"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/同步-20220618215622-hn82j8i.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212537-2vqrhoj","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212537-2vqrhoj","updated":"20220618212537"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"线程不安全的情况","Properties":{"id":""}}]},{"ID":"20220618212538-nwc7v47","Type":"NodeBlockquote","Properties":{"id":"20220618212538-nwc7v47","updated":"20220618212538"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212539-nr0sg0l","Type":"NodeParagraph","Properties":{"id":"20220618212539-nr0sg0l","updated":"20220618212539"},"Children":[{"Type":"NodeText","Data":"比如两个人去取一张有100w的银行卡的钱，如果都要取100w两个人加起来就是200w了，所以这就是线程的不安全","Properties":{"id":""}}]}]},{"ID":"20220618212540-gfgil0d","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212540-gfgil0d","updated":"20220618212540"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"同步方法","Properties":{"id":""}}]},{"ID":"20220618212541-a9lwt9d","Type":"NodeParagraph","Properties":{"id":"20220618212541-a9lwt9d","updated":"20220618212541"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/同步方法-20220618215622-qip6vea.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212542-axt8esl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212542-axt8esl","updated":"20220618212542"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"同步块synchronized方法","Properties":{"id":""}}]},{"ID":"20220618212543-g2ig0dn","Type":"NodeBlockquote","Properties":{"id":"20220618212543-g2ig0dn","updated":"20220618212543"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212544-bjb2dkn","Type":"NodeParagraph","Properties":{"id":"20220618212544-bjb2dkn","updated":"20220618212544"},"Children":[{"Type":"NodeText","Data":"注意：同步块锁的是对象","Properties":{"id":""}}]}]},{"ID":"20220618212545-h7wntn7","Type":"NodeParagraph","Properties":{"id":"20220618212545-h7wntn7","updated":"20220618212545"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/同步块-20220618215622-r6lqfdd.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212546-vqki5cr","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212546-vqki5cr","updated":"20220618212546"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"三大不安全案例解决方法","Properties":{"id":""}}]},{"ID":"20220618212547-0zb3qag","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220618212547-0zb3qag","updated":"20220618212547"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"买票案例","Properties":{"id":""}}]},{"ID":"20220618212548-4jysadm","Type":"NodeBlockquote","Properties":{"id":"20220618212548-4jysadm","updated":"20220618212548"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212549-mzlt0lr","Type":"NodeParagraph","Properties":{"id":"20220618212549-mzlt0lr","updated":"20220618212549"},"Children":[{"Type":"NodeText","Data":"synchronized同步方法锁的时this！！！","Properties":{"id":""}}]}]},{"ID":"20220618212550-7a0exqy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212550-7a0exqy","updated":"20220618212550"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package sychronized;\n\npublic class UnsafeBuyTicket{\n    public static void main(String[] args) {\n        BuyTicket buyTicket = new BuyTicket();\n\n        new Thread(buyTicket,\"小明\").start();\n        new Thread(buyTicket,\"老师\").start();\n        new Thread(buyTicket,\"黄牛\").start();\n    }\n}\n\nclass BuyTicket implements Runnable{\n    //票\n    private int ticketNums = 10;\n    boolean flag = true;//外部停止方式\n\n    @Override\n    public void run() {\n        //买票\n        while (flag){\n            try {\n                buy();\n                Thread.sleep(100);\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n        }\n\n    }\n    //加了sychronized方法，保证队列等待\n    public synchronized void buy() throws InterruptedException{\n        if (ticketNums\u003c=0){\n            flag = false;\n            System.out.println(\"没票了\");\n            return;\n        }\n        System.out.println(Thread.currentThread().getName()+\"买到了第\"+ticketNums--+\"张票\");\n    }\n}\n\n//结果:\n小明买到了第10张票\n黄牛买到了第9张票\n老师买到了第8张票\n老师买到了第7张票\n黄牛买到了第6张票\n小明买到了第5张票\n小明买到了第4张票\n黄牛买到了第3张票\n老师买到了第2张票\n小明买到了第1张票\n没票了\n没票了\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212551-rfl7k9y","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220618212551-rfl7k9y","updated":"20220618212551"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"银行取钱案例","Properties":{"id":""}}]},{"ID":"20220618212552-x01ir2h","Type":"NodeBlockquote","Properties":{"id":"20220618212552-x01ir2h","updated":"20220618212552"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212553-nuva0pp","Type":"NodeParagraph","Properties":{"id":"20220618212553-nuva0pp","updated":"20220618212553"},"Children":[{"Type":"NodeText","Data":"锁的目标是变化的量，需要增删改的目标","Properties":{"id":""}}]}]},{"ID":"20220618212554-j0b9rhu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212554-j0b9rhu","updated":"20220618212554"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package sychronized;\n\npublic class UnsafeBank {\n    public static void main(String[] args) {\n        Account account = new Account(100, \"学习基金\");\n\n        Bank you = new Bank(account, 50, \"你\");\n        Bank girl = new Bank(account, 100, \"对象\");\n\n        you.start();\n        girl.start();\n    }\n\n}\n\n//账户\nclass Account{\n    int Money;\n    String Name;\n\n    public Account(int money, String name){\n        this.Money = money;\n        this.Name = name;\n    }\n}\n//银行\nclass Bank extends Thread{\n\n    Account account;//账户\n    int drawingMoney;//取钱\n    int nowMoney;//现在手里一共多少钱\n\n    public Bank(Account account, int drawingMoney, String name){\n        super(name);\n        this.account = account;\n        this.drawingMoney = drawingMoney;\n    }\n\n    //取钱\n    //synchronizecd默认锁的是this\n    @Override\n    public void run() {\n        synchronized (account){//采用同步块，把account锁了，而不是把银行锁了\n            if(account.Money - drawingMoney \u003c 0){\n                System.out.println(Thread.currentThread().getName()+\"取不了钱，余额不足！\");\n                return;\n            }\n\n            try {\n                Thread.sleep(100);\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n\n            //卡内余额 = 余额 - 取的钱\n            account.Money = account.Money - drawingMoney;\n            //手里的钱\n            nowMoney = nowMoney + drawingMoney;\n\n            System.out.println(account.Name+ \"余额为\"+ account.Money);\n            //手里的钱还有多少  Thread.currentThread().getName() = this.getName();\n            System.out.println(this.getName()+\"手里的钱\"+nowMoney);\n        }\n        }\n\n}\n\n//结果\n学习基金余额为50\n你手里的钱50\n对象取不了钱，余额不足！\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212555-imtz313","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220618212555-imtz313","updated":"20220618212555"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ArrayList锁方法","Properties":{"id":""}}]},{"ID":"20220618212556-9hs5c95","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212556-9hs5c95","updated":"20220618212556"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package sychronized;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\npublic class UnSafeList {\n    public static void main(String[] args) {\n        List\u003cString\u003e list = new ArrayList\u003cString\u003e();\n        for (int i = 0; i \u003c 10000; i++) {\n            new Thread(()-\u003e{\n                synchronized (list){//锁住\n                    list.add(Thread.currentThread().getName());\n                }\n            }).start();\n        }\n        try {\n            Thread.sleep(1000);\n        } catch (InterruptedException e) {\n            e.printStackTrace();\n        }\n        System.out.println(list.size());\n        //不加同步方式的后果就是有可能出现两个线程出现在同一位置，重叠了\n    }\n}\n\n//结果\n10000\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212557-t463q1q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618212557-t463q1q","updated":"20220618212557"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁","Properties":{"id":""}}]},{"ID":"20220618212558-jwfhkxg","Type":"NodeParagraph","Properties":{"id":"20220618212558-jwfhkxg","updated":"20220618212558"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/死锁-20220618215622-505wd5l.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212559-y42dg7v","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212559-y42dg7v","updated":"20220618212559"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"避免死锁的方法","Properties":{"id":""}}]},{"ID":"20220618212560-rn8yvcq","Type":"NodeParagraph","Properties":{"id":"20220618212560-rn8yvcq","updated":"20220618212560"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/避免死锁-20220618215622-2ufsnou.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212561-9vaa8t5","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212561-9vaa8t5","updated":"20220618212561"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"lock锁","Properties":{"id":""}}]},{"ID":"20220618212562-r3hk07u","Type":"NodeParagraph","Properties":{"id":"20220618212562-r3hk07u","updated":"20220618212562"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/可重复-20220618215622-ffywqs3.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212563-83u5hjh","Type":"NodeParagraph","Properties":{"id":"20220618212563-83u5hjh","updated":"20220618212563"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/lock-20220618215622-1alkftp.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212564-njy8ykf","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212564-njy8ykf","updated":"20220618212564"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"synchronized与lock对比","Properties":{"id":""}}]},{"ID":"20220618212565-vpx7y5i","Type":"NodeParagraph","Properties":{"id":"20220618212565-vpx7y5i","updated":"20220618212565"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/对比-20220618215622-7cv2wem.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212566-l8shaho","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212566-l8shaho","updated":"20220618212566"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"五、线程通信问题","Properties":{"id":""}}]},{"ID":"20220618212567-msv6yzs","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212567-msv6yzs","updated":"20220618212567"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"生产者与消费者问题","Properties":{"id":""}}]},{"ID":"20220618212568-gnxlxq9","Type":"NodeParagraph","Properties":{"id":"20220618212568-gnxlxq9","updated":"20220618212568"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/分析-20220618215622-okwmqhd.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212569-ekaffg2","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212569-ekaffg2","updated":"20220618212569"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"线程通信","Properties":{"id":""}}]},{"ID":"20220618212570-jlu0krw","Type":"NodeParagraph","Properties":{"id":"20220618212570-jlu0krw","updated":"20220618212570"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/线程通信-20220618215622-g1og49x.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212571-2rqwtc8","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212571-2rqwtc8","updated":"20220618212571"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"解决办法","Properties":{"id":""}}]},{"ID":"20220618212572-hgvzan9","Type":"NodeParagraph","Properties":{"id":"20220618212572-hgvzan9","updated":"20220618212572"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/解决-20220618215622-j26m55y.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212573-fky7143","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212573-fky7143","updated":"20220618212573"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"管程法","Properties":{"id":""}}]},{"ID":"20220618212574-wb2hq4h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212574-wb2hq4h","updated":"20220618212574"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package guanchengMethod;\n\n//测试：生产着消费者模型————\u003e利用缓冲区解决：管程法\n\n//生产者，消费者，产品，缓冲区\npublic class GuanChengMethod {\n    public static void main(String[] args) {\n        SynContainer container = new SynContainer();\n\n        new Productor(container).start();\n        new Consumer(container).start();\n    }\n}\n\n//生产者\nclass Productor extends Thread{\n    SynContainer container;\n\n    public  Productor(SynContainer container){\n        this.container = container;\n    }\n    //生产\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c 100; i++) {\n\n            container.push(new Chicken(i));\n            System.out.println(\"生产了\"+i+\"只鸡\");\n        }\n    }\n}\n\n//消费者\nclass Consumer extends Thread{\n    SynContainer container;\n\n    public  Consumer(SynContainer container){\n        this.container = container;\n    }\n    //消费\n\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c 100; i++) {\n            System.out.println(\"消费了--\u003e\"+container.pop().id+\"只鸡\");\n        }\n    }\n}\n\n//产品\nclass Chicken{\n    int id;//产品编号\n\n    public Chicken(int id){\n\n        this.id = id;\n    }\n}\n\n//缓冲区\nclass SynContainer{\n    //需要一个容器大小\n    Chicken[] chickens = new Chicken[10];\n    int count = 0;\n    //生产者放入产品\n    public synchronized void push(Chicken chicken){\n        //如果容器满了，就需要等待消费者\n        if (count==chickens.length){\n            //通知消费者消费，生产等待\n            try {\n                this.wait();\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n\n        }\n        //如果没满，就需要丢入产品\n        chickens[count] = chicken;\n        count++;\n\n        //通知生产者消费\n        this.notifyAll();\n\n\n    }\n\n    //消费者消费产品\n    public synchronized Chicken pop(){\n        //判断能否消费\n        if (count==0){\n            //等待生产者生产，消费者等待\n            try{\n                this.wait();\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n\n        }\n        //如果可以消费\n        count--;\n        Chicken chicken = chickens[count];\n\n        //吃完了，通知生产者生产\n        this.notifyAll();\n        return chicken;\n    }\n}\n\n//部分结果\n生产了0只鸡\n生产了1只鸡\n生产了2只鸡\n生产了3只鸡\n生产了4只鸡\n生产了5只鸡\n生产了6只鸡\n生产了7只鸡\n生产了8只鸡\n生产了9只鸡\n生产了10只鸡\n消费了--\u003e9只鸡\n消费了--\u003e10只鸡\n消费了--\u003e11只鸡\n生产了11只鸡\n消费了--\u003e8只鸡\n生产了12只鸡\n消费了--\u003e12只鸡\n生产了13只鸡\n生产了14只鸡\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212575-lq0zfux","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212575-lq0zfux","updated":"20220618212575"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"信号灯法","Properties":{"id":""}}]},{"ID":"20220618212576-evazvg2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212576-evazvg2","updated":"20220618212576"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package SignalLightMethod;\n\npublic class SignalLightMethod {\n    public static void main(String[] args) {\n        TV tv = new TV();\n\n        new Player(tv).start();\n        new Wacther(tv).start();\n    }\n\n}\n\n//生产者--\u003e演员\nclass Player extends Thread{\n    TV tv;\n    public Player(TV tv){\n        this.tv = tv;\n    }\n\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c 20; i++) {\n            if(i%2==0){\n                this.tv.play(\"节目播放中\");\n            }else{\n                this.tv.play(\"广告中\");\n            }\n        }\n    }\n}\n\n\n//消费者--\u003e观众\nclass Wacther extends Thread{\n    TV tv;\n    public Wacther(TV tv){\n        this.tv = tv;\n    }\n\n    @Override\n    public void run() {\n        for (int i = 0; i \u003c 20; i++){\n            tv.watch();\n        }\n\n    }\n}\n\n//产品--\u003e节目\nclass TV{\n    //演员表演，观众等待\n    //观众观看，演员等待\n    String voice;//表演的jiem\n    boolean flag = true;\n\n    //表演\n    public synchronized void play(String voice){\n        if(!flag){\n            try {\n                this.wait();\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n        }\n        System.out.println(\"演员表演了:\"+voice);\n        //通知观众观看\n        this.notifyAll();//通知唤醒\n        this.voice = voice;\n        this.flag = !this.flag;\n\n    }\n\n    //观看\n    public synchronized void watch(){\n        if (flag){\n            try {\n                this.wait();\n            } catch (InterruptedException e) {\n                e.printStackTrace();\n            }\n        }\n        System.out.println(\"观看了：\"+voice);\n        //通知演员表演\n        this.notifyAll();\n        this.flag = !this.flag;\n    }\n\n\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212577-s1drz0l","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212577-s1drz0l","updated":"20220618212577"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"线程池","Properties":{"id":""}}]},{"ID":"20220618212578-pzr977b","Type":"NodeParagraph","Properties":{"id":"20220618212578-pzr977b","updated":"20220618212578"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOp