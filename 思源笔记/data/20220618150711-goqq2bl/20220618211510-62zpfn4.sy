Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/表格-20220618215622-9f1iril.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212633-ez8avjc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212633-ez8avjc","updated":"20220618212633"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"4.事件监听","Properties":{"id":""}}]},{"ID":"20220618212634-s8bir07","Type":"NodeParagraph","Properties":{"id":"20220618212634-s8bir07","updated":"20220618212634"},"Children":[{"Type":"NodeText","Data":"事件监听：当某个事情发生的时候——\u003e干什么 addActionListener","Properties":{"id":""}}]},{"ID":"20220618212635-57pxqvy","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212635-57pxqvy","updated":"20220618212635"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"1.设计按钮能够监听事件，按下按钮输出“牛”，按下叉能够关闭窗口","Properties":{"id":""}}]},{"ID":"20220618212636-o6fcqw1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212636-o6fcqw1","updated":"20220618212636"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\nimport java.awt.event.WindowAdapter;\nimport java.awt.event.WindowEvent;\n\npublic class TestAction {\n    public static void main(String[] args) {\n        //按下按钮，触发一些事件\n        Frame frame = new Frame();\n        Button button = new Button(\"按钮\");\n\n        //因为,addActionListener()需要一个Actionlistener,所以我们需要构造一个ActionListener\n        MyActionlistener myActionlistener = new MyActionlistener();\n        button.addActionListener(myActionlistener);\n\n        frame.add(button, BorderLayout.CENTER);\n        frame.pack();\n\n        windowClose(frame);\n        frame.setVisible(true);\n    }\n    //关闭窗体的事件\n    private static void windowClose(Frame frame){\n        frame.addWindowListener(new WindowAdapter() {\n            @Override\n            public void windowClosing(WindowEvent e) {\n                System.exit(0);\n            }\n        });\n    }\n}\n\n//事件监听 因为 button.addActionListener()必须要有参数，所以要自己写一个类\nclass MyActionlistener implements ActionListener{\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        System.out.println(\"牛\");\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212637-kfi0kfn","Type":"NodeParagraph","Properties":{"id":"20220618212637-kfi0kfn","updated":"20220618212637"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/按钮关-20220618215622-ax9n340.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212638-vlo3ar9","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212638-vlo3ar9","updated":"20220618212638"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.设计两个按钮可以共享监听事件的","Properties":{"id":""}}]},{"ID":"20220618212639-tui91db","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212639-tui91db","updated":"20220618212639"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\npublic class TestAction02 {\n    public static void main(String[] args) {\n        //两个按钮，实现同一个监听\n        //开始， 停止\n        Frame frame = new Frame();\n        Button button1 = new Button(\"start\");\n        Button button2 = new Button(\"stop\");\n\n        //可以显示的定义触发会返回的命令，如果不显示定义，则会走默认的值！\n        //可以多个按钮只写一个监听类\n        button2.setActionCommand(\"button2-stop\");\n\n        MyMonitor myMonitor = new MyMonitor();\n\n        button1.addActionListener(myMonitor);\n        button2.addActionListener(myMonitor);\n\n        frame.add(button1,BorderLayout.SOUTH);\n        frame.add(button2,BorderLayout.NORTH);\n\n        frame.pack();\n        frame.setVisible(true);\n    }\n}\n//监听事件，用于共享\nclass MyMonitor implements ActionListener{\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        // e.getActionCommand()获得按钮的信息\n        System.out.println(\"按钮被点击了： msg=\u003e\"+e.getActionCommand());\n        if(e.getActionCommand().equals(\"start\")){\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212640-g1kwuug","Type":"NodeParagraph","Properties":{"id":"20220618212640-g1kwuug","updated":"20220618212640"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/共享-20220618215622-wvhkd1y.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212641-la92pwn","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212641-la92pwn","updated":"20220618212641"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"练习画出如下按钮布局","Properties":{"id":""}}]},{"ID":"20220618212642-ogn58mw","Type":"NodeParagraph","Properties":{"id":"20220618212642-ogn58mw","updated":"20220618212642"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/作业-20220618215622-inzw2js.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212643-rbfdwcr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212643-rbfdwcr","updated":"20220618212643"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"5.输入框TextField监听","Properties":{"id":""}}]},{"ID":"20220618212644-ndqkw6t","Type":"NodeParagraph","Properties":{"id":"20220618212644-ndqkw6t","updated":"20220618212644"},"Children":[{"Type":"NodeText","Data":"在文本框内输入文字，用星号替换文字","Properties":{"id":""}}]},{"ID":"20220618212645-kdbe51m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212645-kdbe51m","updated":"20220618212645"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\npublic class TestText01 {\n    public static void main(String[] args) {\n        //启动\n        new MyFrame1();\n    }\n}\nclass MyFrame1 extends Frame{\n    public MyFrame1(){\n        TextField textField = new TextField();\n        add(textField);\n\n        //监听这个文本框输入的文字\n        MyActionListener3 myActionListener = new MyActionListener3();\n        textField.addActionListener(myActionListener);\n\n        //设置替换编码,把输入的文本替换为星号\n        textField.setEchoChar('*');\n\n        setVisible(true);\n        pack();\n    }\n}\nclass MyActionListener3 implements ActionListener{\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        TextField textField1 = (TextField) e.getSource();//因为getSource是objetct类，所以可以转型为text\n        System.out.println(textField1.getText());//获得输入框的文本\n        textField1.setText(\"\");//清空文本框，按回车后自动清空文本框并显示输入的文字\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212646-ld7kx7q","Type":"NodeParagraph","Properties":{"id":"20220618212646-ld7kx7q","updated":"20220618212646"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/文本-20220618215622-3zkxskn.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212647-greyiss","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212647-greyiss","updated":"20220618212647"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"6.简易计算器，组合+内部类回顾复习","Properties":{"id":""}}]},{"ID":"20220618212648-zghsf53","Type":"NodeParagraph","Properties":{"id":"20220618212648-zghsf53","updated":"20220618212648"},"Children":[{"Type":"NodeText","Data":"面向对象原则：组合大于继承","Properties":{"id":""}}]},{"ID":"20220618212649-kepuc1q","Type":"NodeParagraph","Properties":{"id":"20220618212649-kepuc1q","updated":"20220618212649"},"Children":[{"Type":"NodeText","Data":"面向过程的写法","Properties":{"id":""}}]},{"ID":"20220618212650-magao3y","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212650-magao3y","updated":"20220618212650"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\npublic class TestCalculator {\n    public static void main(String[] args) {\n        new Calculator();\n\n    }\n}\n//计算器类\nclass Calculator extends Frame{\n    public Calculator(){\n        //3个文本框\n        TextField num1 = new TextField(10);\n        TextField num2 = new TextField(10);\n        TextField num3 = new TextField(20);\n\n        //1个按钮\n        Button button = new Button(\"=\");\n        button.addActionListener(new MyCalculatorListener(num1, num2, num3));\n\n        //1个标签\n        Label label = new Label(\"+\");\n\n        //布局\n        setLayout(new FlowLayout());\n        add(num1);\n        add(label);\n        add(num2);\n        add(button);\n        add(num3);\n\n        pack();\n        setVisible(true);\n    }\n}\n\n//监听器类\nclass MyCalculatorListener implements ActionListener{\n    //获取三个变量\n    private TextField num1, num2, num3;\n\n    public MyCalculatorListener(TextField num1, TextField num2, TextField num3){\n        this.num1 = num1;\n        this.num2 = num2;\n        this.num3 = num3;\n    };\n\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        //1. 获得加数和被加数,integer用于转换类型，这里将字符串类型转为整形\n        int n1 = Integer.parseInt(num1.getText());\n        int n2 = Integer.parseInt(num2.getText());\n\n        //2. 将这个值 + 法运算后放到第三个框\n        num3.setText(\"\"+(n1+n2));\n\n        //3. 清除前两个框\n        num1.setText(\"\");\n        num2.setText(\"\");\n\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212651-j57qx0t","Type":"NodeParagraph","Properties":{"id":"20220618212651-j57qx0t","updated":"20220618212651"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/计算器1-20220618215622-k2h3h0r.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212652-de2d1o5","Type":"NodeParagraph","Properties":{"id":"20220618212652-de2d1o5","updated":"20220618212652"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/计算器3-20220618215622-xleacgh.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212653-kqyvroe","Type":"NodeParagraph","Properties":{"id":"20220618212653-kqyvroe","updated":"20220618212653"},"Children":[{"Type":"NodeText","Data":"完全面向对象的写法","Properties":{"id":""}}]},{"ID":"20220618212654-ou0qg8j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212654-ou0qg8j","updated":"20220618212654"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\npublic class TestCalculator {\n    public static void main(String[] args) {\n        new Calculator().loadFrame();\n\n    }\n}\n//计算器类\nclass Calculator extends Frame{\n\n        //属性\n        TextField num1,num2,num3;\n\n        //方法\n        public void loadFrame(){\n            num1 = new TextField(10);\n            num2 = new TextField(10);\n            num3 = new TextField(20);\n            //1个按钮\n            Button button = new Button(\"=\");\n            button.addActionListener(new MyCalculatorListener(this));\n\n            //1个标签\n            Label label = new Label(\"+\");\n\n            //布局\n            setLayout(new FlowLayout());\n            add(num1);\n            add(label);\n            add(num2);\n            add(button);\n            add(num3);\n\n            pack();\n            setVisible(true);\n        }\n}\n\n//监听器类\nclass MyCalculatorListener implements ActionListener{\n\n    //获取计算器这个对象，在一个类中组合另外一个类\n    Calculator calculator = null;\n\n    public MyCalculatorListener(Calculator calculator){\n        this.calculator= calculator;\n    }\n\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        //1. 获得加数和被加数,integer用于转换类型，这里将字符串类型转为整形\n        //2. 将这个值 + 法运算后放到第三个框\n        //3. 清除前两个框\n\n        int n1 = Integer.parseInt(calculator.num1.getText());\n        int n2 = Integer.parseInt(calculator.num2.getText());\n        calculator.num3.setText(\"\"+(n1+n2));\n        calculator.num1.setText(\"\");\n        calculator.num2.setText(\"\");\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212655-8fh5jdo","Type":"NodeParagraph","Properties":{"id":"20220618212655-8fh5jdo","updated":"20220618212655"},"Children":[{"Type":"NodeText","Data":"内部类,计算器更高级的写法","Properties":{"id":""}}]},{"ID":"20220618212656-pfy529j","Type":"NodeBlockquote","Properties":{"id":"20220618212656-pfy529j","updated":"20220618212656"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212657-rucn2p6","Type":"NodeParagraph","Properties":{"id":"20220618212657-rucn2p6","updated":"20220618212657"},"Children":[{"Type":"NodeText","Data":"内部类的最大好处就是可以畅通无阻的访问外部类的属性和方法","Properties":{"id":""}}]}]},{"ID":"20220618212658-tts4kdg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212658-tts4kdg","updated":"20220618212658"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GUI;\n\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\npublic class TestCalculator {\n    public static void main(String[] args) {\n        new Calculator().loadFrame();\n\n    }\n}\n//计算器类\nclass Calculator extends Frame{\n\n        //属性\n        TextField num1,num2,num3;\n\n        //方法\n        public void loadFrame(){\n            num1 = new TextField(10);\n            num2 = new TextField(10);\n            num3 = new TextField(20);\n            //1个按钮\n            Button button = new Button(\"=\");\n            button.addActionListener(new MyCalculatorListener());\n\n            //1个标签\n            Label label = new Label(\"+\");\n\n            //布局\n            setLayout(new FlowLayout());\n            add(num1);\n            add(label);\n            add(num2);\n            add(button);\n            add(num3);\n\n            pack();\n            setVisible(true);\n        }\n        //监听器类  内部类\n        private class MyCalculatorListener implements ActionListener{\n\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                //1. 获得加数和被加数,integer用于转换类型，这里将字符串类型转为整形\n                //2. 将这个值 + 法运算后放到第三个框\n                //3. 清除前两个框\n                int n1 = Integer.parseInt(num1.getText());\n                int n2 = Integer.parseInt(num2.getText());\n                num3.setText(\"\"+(n1+n2));\n                num1.setText(\"\");\n                num2.setText(\"\");\n            }\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212659-578t7nd","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212659-578t7nd","updated":"20220618212659"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"7.画笔","Properties":{"id":""}}]},{"ID":"20220618212660-ctmcsy5","Type":"NodeParagraph","Properties":{"id":"20220618212660-ctmcsy5","updated":"20220618212660"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/画笔-20220618215622-w8yzfwf.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212661-myw3vls","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212661-myw3vls","updated":"20220618212661"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"8.鼠标监听","Properties":{"id":""}}]},{"ID":"20220618212662-v7b8dwd","Type":"NodeParagraph","Properties":{"id":"20220618212662-v7b8dwd","updated":"20220618212662"},"Children":[{"Type":"NodeText","Data":"目的：实现鼠标画画","Properties":{"id":""}}]},{"ID":"20220618212663-fkg698c","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212663-fkg698c","updated":"20220618212663"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"9.窗口监听","Properties":{"id":""}}]},{"ID":"20220618212664-gr0u7uo","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618212664-gr0u7uo","updated":"20220618212664"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"10.键盘监听","Properties":{"id":""}}]},{"ID":"20220618212665-301yons","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618212665-301yons","updated":"20220618212665"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"贪吃蛇案例","Properties":{"id":""}}]},{"ID":"20220618212666-urn9qio","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212666-urn9qio","updated":"20220618212666"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"1.主函数","Properties":{"id":""}}]},{"ID":"20220618212667-knucix9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212667-knucix9","updated":"20220618212667"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GluttonousSnake;\n\nimport javax.swing.*;\n\npublic class GluttonousSnake {\n    public static void main(String[] args) {\n        //1.绘制一个静态窗口 JFrame\n        JFrame frame = new JFrame();\n        frame.setBounds(10,10,915,720);//设置界面大小\n        frame.setResizable(false);//窗口大小则不可以改变\n        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);//设置关闭时间，游戏可以关闭\n\n        //2.面板panel 可以加入到JFrame\n        frame.add(new GamePanel());\n\n        frame.setVisible(true);//让窗口显示出来\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212668-yc53bhf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212668-yc53bhf","updated":"20220618212668"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.加载图片的函数","Properties":{"id":""}}]},{"ID":"20220618212669-eavekyz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212669-eavekyz","updated":"20220618212669"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GluttonousSnake;\n\n\nimport javax.swing.*;\nimport java.net.URL;\n\n//存放外部数据\npublic class Data {\n\n    //头部的图片 url:定位图片的地址 ImafeIcon：图片\n    public static URL headerURL = Data.class.getResource(\"/GluttonousSnake/static/header.png\");\n    public static ImageIcon header= new ImageIcon(headerURL);\n\n    //所有图片\n    public static URL upUrl = Data.class.getResource(\"/GluttonousSnake/static/up.png\");\n    public static URL downUrl = Data.class.getResource(\"/GluttonousSnake/static/down.png\");\n    public static URL leftUrl = Data.class.getResource(\"/GluttonousSnake/static/left.png\");\n    public static URL rightUrl = Data.class.getResource(\"/GluttonousSnake/static/right.png\");\n    public static URL foodUrl = Data.class.getResource(\"/GluttonousSnake/static/food.png\");\n    public static URL bodyUrl = Data.class.getResource(\"/GluttonousSnake/static/body.png\");\n\n    public static ImageIcon up= new ImageIcon(upUrl);\n    public static ImageIcon down= new ImageIcon(downUrl);\n    public static ImageIcon left= new ImageIcon(leftUrl);\n    public static ImageIcon right= new ImageIcon(rightUrl);\n    public static ImageIcon food= new ImageIcon(foodUrl);\n    public static ImageIcon body= new ImageIcon(bodyUrl);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212670-a0fr87m","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212670-a0fr87m","updated":"20220618212670"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"3.面板函数","Properties":{"id":""}}]},{"ID":"20220618212671-0n68h4l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212671-0n68h4l","updated":"20220618212671"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"package GluttonousSnake;\n\nimport javax.swing.*;\nimport java.awt.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\nimport java.awt.event.KeyEvent;\nimport java.awt.event.KeyListener;\nimport java.util.Random;\n\npublic class GamePanel extends JPanel implements KeyListener, ActionListener {\n\n\n    int length;//蛇的长度\n    int[] snakeX = new int[600]; //蛇的坐标x\n    int[] snakeY = new int[500]; //蛇的坐标y\n    String direction;//上下左右\n\n    boolean isStart = false;//游戏是否开始\n    Timer timer = new Timer(120,this);//定时器\n\n    //1.定义一个食物\n    int foodx;\n    int foody;\n    Random random = new Random();\n\n    //死亡判断\n    boolean isFail = false;\n\n    //积分系统\n    int score;\n\n    //构造器\n    public GamePanel(){\n        init();\n        //获取键盘的监听事件\n        this.setFocusable(true);//聚焦于游戏\n        this.addKeyListener(this);//继承KeyListen重写的方法\n        timer.start();\n    }\n\n    //初始化\n    public void init(){\n        length = 3;\n        snakeX[0] = 100; snakeY[0] = 100; //头部坐标\n        snakeX[1] = 75; snakeY[1] = 100; //第一个身体坐标\n        snakeX[2] = 50; snakeY[2] = 100; //第二个身体坐标\n\n        direction = \"R\";\n\n        foodx = 25 + 25* random.nextInt(34);\n        foody = 75 + 25* random.nextInt(24);\n\n        score = 0;\n    }\n\n    //画板： 画界面，画蛇\n    //Graphics：huabi\n    @Override\n    protected void paintComponent(Graphics g) {\n        super.paintComponent(g);//清屏\n        this.setBackground(Color.BLACK);//设置背景颜色\n\n        //绘制头部的广告栏\n        Data.header.paintIcon(this, g,25,11);\n\n        //绘制游戏区域\n        g.fillRect(25,75,850,600);\n\n        //画一条静态小蛇\n        if (direction.equals(\"R\")){\n            Data.right.paintIcon(this,g,snakeX[0],snakeY[0]);\n        }else if(direction.equals(\"L\")){\n            Data.left.paintIcon(this,g,snakeX[0],snakeY[0]);\n        } else if(direction.equals(\"U\")){\n            Data.up.paintIcon(this,g,snakeX[0],snakeY[0]);\n        }else if(direction.equals(\"D\")){\n            Data.down.paintIcon(this,g,snakeX[0],snakeY[0]);\n        }\n        for (int i = 1; i \u003c length; i++) {\n            Data.body.paintIcon(this,g,snakeX[i],snakeY[i]);//蛇的身体长度通过length来控制\n        }\n\n        //画积分\n        g.setColor(Color.WHITE);\n        g.setFont(new Font(\"微软雅黑\",Font.BOLD,18));\n        g.drawString(\"长度:\"+length, 750, 35);\n        g.drawString(\"分数:\"+length, 750, 55);\n\n\n        //画食物\n        Data.food.paintIcon(this,g,foodx,foody);\n\n        //游戏提示：是否开始\n        if (isStart==false){\n            //画一个文字 String\n            g.setColor(Color.WHITE);//设置画笔颜色\n            g.setFont(new Font(\"微软雅黑\",Font.BOLD,40));//设置字体\n            g.drawString(\"按下空格开始游戏\",300,300);\n\n        }\n        //失败提醒\n        if (isFail){\n            //画一个文字 String\n            g.setColor(Color.RED);//设置画笔颜色\n            g.setFont(new Font(\"微软雅黑\",Font.BOLD,40));//设置字体\n            g.drawString(\"这个飞爷就是逊诶，按下空格重新开始游戏\",50,300);\n\n        }\n    }\n    //接收键盘的输入：监听\n    @Override\n    public void keyTyped(KeyEvent e) {\n\n    }\n\n    @Override\n    public void keyPressed(KeyEvent e) {\n        //获取按下的键盘是哪个键\n        int keyCode = e.getKeyCode();\n\n\n        if (keyCode==KeyEvent.VK_SPACE){//如果按下的是空格\n            if (isFail){ //失败，游戏再来一遍\n                isFail = false;\n                init();//重新初始化游戏\n            }else{//暂停游戏\n                isStart = !isStart;\n            }\n\n            repaint();//刷新界面\n        }\n        //键盘控制方向\n        if (keyCode == KeyEvent.VK_LEFT){\n            direction = \"L\";\n        }else if(keyCode == KeyEvent.VK_RIGHT) {\n            direction = \"R\";\n        }else if(keyCode == KeyEvent.VK_UP) {\n            direction = \"U\";\n        }else if(keyCode == KeyEvent.VK_DOWN) {\n            direction = \"D\";\n        }\n    }\n\n    @Override\n    public void keyReleased(KeyEvent e) {\n\n    }\n\n\n    //定时器，执行定时操作，监听事件\n    @Override\n    public void actionPerformed(ActionEvent e) {\n        //如果游戏处于开始状态，并且游戏没有结束\n        if (isStart \u0026\u0026 isFail==false){\n            //右移f\n            for (int i = length - 1; i \u003e 0; i--) {//除了脑袋，身体都向前移动\n                snakeX[i] = snakeX[i-1];\n                snakeY[i] = snakeY[i-1];\n            }\n            //通过控制方向让头部移动\n            if(direction.equals(\"R\")){\n                snakeX[0] = snakeX[0] + 25;\n                if (snakeX[0]\u003e850){snakeX[0] = 25;}//边界判断\n            }else if (direction.equals(\"L\")){\n                snakeX[0] = snakeX[0] - 25;\n                if (snakeX[0]\u003c25){snakeX[0] = 850;}//边界判断\n            }else if (direction.equals(\"U\")){\n                snakeY[0] = snakeY[0] - 25;\n                if (snakeY[0]\u003c75){snakeY[0] = 650;}//边界判断\n            }else if (direction.equals(\"D\")){\n                snakeY[0] = snakeY[0] + 25;\n                if (snakeY[0]\u003e650){snakeY[0] = 75;}//边界判断\n            }\n\n            //如果吃到实物\n            if (snakeX[0]==foodx \u0026\u0026 snakeY[0] == foody){\n                //长度+1\n                length++;\n\n                //分数\n                score += 10;\n\n                //重新生成实物\n                foodx = 25 + 25* random.nextInt(34);//该方法的作用是生成一个随机的int值，该值介于[0,n)的区间，也就是0到n之间的随机int值，包含0而不包含n。\n                foody = 75 + 25* random.nextInt(24);\n            }\n\n            //结束判断\n            for (int i = 1; i \u003c length; i++) {\n                if (snakeX[0]==snakeX[i] \u0026\u0026 snakeY[0]==snakeY[i]){\n                    isFail = true;\n                }else if(snakeX[0]==25){\n                    isFail = true;\n                }else if(snakeX[0]==850){\n                    isFail = true;\n                }else if(snakeY[0]==650){\n                    isFail = true;\n                }else if(snakeY[0]==75){\n                    isFail = true;\n                }\n\n            }\n\n            //刷新界面\n            repaint();\n\n        }\n        timer.start();\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212672-bu6d33z","Type":"NodeBlockquote","Properties":{"id":"20220618212672-bu6d33z","updated":"20220618212672"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212673-7sktilf","Type":"NodeParagraph","Properties":{"id":"20220618212673-7sktilf","updated":"20220618212673"},"Children":[{"Type":"NodeText","Data":"结果","Properties":{"id":""}}]}]},{"ID":"20220618212674-csru3fo","Type":"NodeParagraph","Properties":{"id":"20220618212674-csru3fo","updated":"20220618212674"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/贪吃蛇-20220618215622-0ica185.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212675-b86t62f","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212675-b86t62f","updated":"20220618212675"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"打包项目","Properties":{"id":""}}]},{"ID":"20220618212676-473vrmt","Type":"NodeParagraph","Properties":{"id":"20220618212676-473vrmt","updated":"20220618212676"},"Children":[{"Type":"NodeText","Data":"第一步","Properties":{"id":""}}]},{"ID":"20220618212677-zo66c07","Type":"NodeParagraph","Properties":{"id":"20220618212677-zo66c07","updated":"20220618212677"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/1-20220618215622-vxfdvjq.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618212678-w3udf7t","Type":"NodeParagraph","Properties":{"id":"20220618212678-w3udf7t","updated":"20220618212678"},"Children":[{"Type":"NodeText","Data":"第二步","Properties":{"id":""}}]