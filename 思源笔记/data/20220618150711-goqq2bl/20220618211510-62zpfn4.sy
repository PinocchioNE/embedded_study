":{"id":""}}]},{"ID":"20220618212269-7d7x33j","Type":"NodeParagraph","Properties":{"id":"20220618212269-7d7x33j","updated":"20220618212269"},"Children":[{"Type":"NodeText","Data":"size：实际元素的个数","Properties":{"id":""}}]},{"ID":"20220618212270-nptchg0","Type":"NodeParagraph","Properties":{"id":"20220618212270-nptchg0","updated":"20220618212270"},"Children":[{"Type":"NodeText","Data":"add：添加元素","Properties":{"id":""}}]}]},{"ID":"20220618212271-ll8eo2t","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618212271-ll8eo2t","updated":"20220618212271"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import java.util.ArrayList;\nimport java.util.Iterator;\nimport java.util.List;\nimport java.util.ListIterator;\n\npublic class arraylist {\n    public static void main(String[] args) {\n        List list = new ArrayList\u003c\u003e();\n        //添加元素\n        list.add(\"苹果\");\n        list.add(\"小米\");\n        list.add(0,\"华为\");\n        System.out.println(\"元素个数\"+list.size());\n        System.out.println(list.toString());\n\n        //遍历\n        //1.for 循环\n        System.out.println(\"-------------\");\n        for (int i = 0; i \u003c list.size(); i++) {\n            System.out.println(list.get(i));\n        }\n        //2.增强for\n        System.out.println(\"-------------\");\n        for (Object object : list) {\n            System.out.println(object);\n        }\n        //3.使用迭代器\n        System.out.println(\"-------------\");\n\n        Iterator lis = list.iterator();\n        while (lis.hasNext()){\n            System.out.println(lis.next());\n        }\n        //4.使用列表迭代，与Iterator区别是ListTterator可以向前或向后遍历，添加、删除、修改元素\n        System.out.println(\"-------------\");\n        ListIterator lit = list.listIterator();\n        //迭代器从前往后\n        System.out.println(\"-------------\");\n        while (lit.hasNext()){\n            System.out.println(lit.nextIndex()+\":\"+lit.next());\n        }\n        //迭代器从后往前\n        System.out.println(\"-------------\");\n        while (lit.hasPrevious()){\n            System.out.println(lit.previousIndex()+\":\"+lit.previous());\n        }\n\n        //判断\n        System.out.println(\"-------------\");\n        System.out.println(list.contains(\"苹果\"));\n        System.out.println(list.isEmpty());\n\n        //获取位置\n        System.out.println(\"-------------\");\n        System.out.println(list.indexOf(\"华为\"));\n\n\n        //删除元素\n        System.out.println(\"-------------\");\n        list.remove(0);\n\t\t\n        //sublist,返回子集合，含头不含尾\n        List sublist =  list.subList(0, 2);\n        System.out.println(sublist.toString());\n    }\n}\n\n//结果\n元素个数3\n[华为, 苹果, 小米]\n-------------\n华为\n苹果\n小米\n-------------\n华为\n苹果\n小米\n-------------\n华为\n苹果\n小米\n-------------\n-------------\n0:华为\n1:苹果\n2:小米\n-------------\n2:小米\n1:苹果\n0:华为\n-------------\ntrue\nfalse\n-------------\n0\n-------------\n[华为, 苹果]\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618212272-7paqdq3","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618212272-7paqdq3","updated":"20220618212272"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Vector","Properties":{"id":""}}]},{"ID":"20220618212273-9v0lbib","Type":"NodeBlockquote","Properties":{"id":"20220618212273-9v0lbib","updated":"20220618212273"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618212274-hanheld","Type":"NodeParagraph","Properties":{"id":"20220618212274-hanheld","updated":"20220618212274"},"Children":[{"Type":"NodeT