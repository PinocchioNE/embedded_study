1536"},"Children":[{"Type":"NodeText","Data":"如果出现tomcat能够进入但不能进入子目录网页出现500怎么办"}]},{"ID":"20220618211537-0c07ddr","Type":"NodeParagraph","Properties":{"id":"20220618211537-0c07ddr","updated":"20220618211537"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220526135643863"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220526135643863-20220618215622-js8nt62.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618211538-2phymrf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211538-2phymrf","updated":"20220618211538"},"Children":[{"Type":"NodeText","Data":"如何判断二维数组是否为空？"}]},{"ID":"20220618211539-vnuedgl","Type":"NodeBlockquote","Properties":{"id":"20220618211539-vnuedgl","updated":"20220618211539"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618211540-cvnfevz","Type":"NodeParagraph","Properties":{"id":"20220618211540-cvnfevz","updated":"20220618211540"},"Children":[{"Type":"NodeText","Data":"有三点要注意："}]},{"ID":"20220618211541-n4zdbaq","Type":"NodeParagraph","Properties":{"id":"20220618211541-n4zdbaq","updated":"20220618211541"},"Children":[{"Type":"NodeText","Data":"1.数组首地址是否为空"}]},{"ID":"20220618211542-a25nxxu","Type":"NodeParagraph","Properties":{"id":"20220618211542-a25nxxu","updated":"20220618211542"},"Children":[{"Type":"NodeText","Data":"2.是否为{}，也就是array.length==0的情况"}]},{"ID":"20220618211543-93p66d6","Type":"NodeParagraph","Properties":{"id":"20220618211543-93p66d6","updated":"20220618211543"},"Children":[{"Type":"NodeText","Data":"3.{{}}，这时array.length=1，但是array[0].length==0。满足任意一个条件就可以返回false了。"}]},{"ID":"20220618211544-wlgchys","Type":"NodeParagraph","Properties":{"id":"20220618211544-wlgchys","updated":"20220618211544"},"Children":[{"Type":"NodeText","Data":"即以下为判断方法："}]},{"ID":"20220618211545-je34ptf","Type":"NodeParagraph","Properties":{"id":"20220618211545-je34ptf","updated":"20220618211545"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"if(array==null||array.length==0||(array.length==1\u0026amp;\u0026amp;array[0].length==0)) return false;"}]}]},{"ID":"20220618211546-hd2ihni","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211546-hd2ihni","updated":"20220618211546"},"Children":[{"Type":"NodeText","Data":"String和StringBuilder"}]},{"ID":"20220618211547-do7cfci","Type":"NodeBlockquote","Properties":{"id":"20220618211547-do7cfci","updated":"20220618211547"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618211548-258beou","Type":"NodeParagraph","Properties":{"id":"20220618211548-258beou","updated":"20220618211548"},"Children":[{"Type":"NodeText","Data":"尽管StringBuilder和String都表示字符序列，但它们的实现方式不同。String是不可变的类型。也就是说，每个看似修改String对象的操作实际上都会创建一个新字符串。"}]}]},{"ID":"20220618211549-xa128w9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618211549-xa128w9","updated":"20220618211549"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"StringBuilder sb = new StringBuilder(\"ABC\", 50);\n\n// Append three characters (D, E, and F) to the end of the StringBuilder.\nsb.Append(new char[] { 'D', 'E', 'F' });\n\n// Append a format string to the end of the StringBuilder.\nsb.AppendFormat(\"GHI{0}{1}\", 'J', 'k');\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618211550-oapn191","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211550-oapn191","updated":"20220618211550"},"Children":[{"Type":"NodeText","Data":"charAt（）"}]},{"ID":"20220618211551-0j9yh6h","Type":"NodeBlockquote","Properties":{"id":"20220618211551-0j9yh6h","updated":"20220618211551"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618211552-rl8s7a8","Type":"NodeParagraph","Properties":{"id":"20220618211552-rl8s7a8","updated":"20220618211552"},"Children":[{"Type":"NodeText","Data":"charAt() 方法用于返回指定索引处的字符。索引范围为从 0 到 length() - 1。"}]}]},{"ID":"20220618211553-7629hr8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618211553-7629hr8","updated":"20220618211553"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class Test {\n    public static void main(String args[]) {\n        String s = \"www.runoob.com\";\n        char result = s.charAt(6);\n        System.out.println(result);\n    }\n}\n以上程序执行结果为：\n\nn\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618211554-iig4w5p","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618211554-iig4w5p","updated":"20220618211554"},"Children":[{"Type":"NodeText","Data":"单引号和双引号的区别"}]},{"ID":"20220618211555-3g7bt1s","Type":"NodeBlockquote","Properties":{"id":"20220618211555-3g7bt1s","updated":"20220618211555"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618211556-oap4lsu","Type":"NodeParagraph","Properties":{"id":"20220618211556-oap4lsu","updated":"20220618211556"},"Children":[{"Type":"NodeText","Data":"区别1：java中的单引号表示字符，java中的双引号是字符串。"}]},{"ID":"20220618211557-sku08j3","Type":"NodeParagraph","Properties":{"id":"20220618211557-sku08j3","updated":"20220618211557"},"Children":[{"Type":"NodeText","Data":"区别2：单引号引的数据一般是char类型的；双引号引的数据 是String类型的。"}]}]},{"ID":"20220630091006-sodkozj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220630091006-sodkozj","updated":"20220630091125"},"Children":[{"Type":"NodeText","Data":"什么是构造方法"}]},{"ID":"20220630091126-tc2iwp0","Type":"NodeBlockquote","Properties":{"id":"20220630091126-tc2iwp0","updated":"20220630091556"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220630091556-acd0t1y","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20220630091556-acd0t1y","updated":"20220630091556"},"Children":[{"ID":"20220630091556-b4ptptf","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20220630091556-b4ptptf","updated":"20220630091556"},"Children":[{"ID":"20220630091556-k42skmh","Type":"NodeParagraph","Properties":{"id":"20220630091556-k42skmh","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"不写返回值类型"}]}]},{"ID":"20220630091556-wb5edju","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20220630091556-wb5edju","updated":"20220630091556"},"Children":[{"ID":"20220630091556-hoz0hqb","Type":"NodeParagraph","Properties":{"id":"20220630091556-hoz0hqb","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"名字与类名称完全相同"}]}]},{"ID":"20220630091556-e0oz9gq","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20220630091556-e0oz9gq","updated":"20220630091556"},"Children":[{"ID":"20220630091556-dv01kt8","Type":"NodeParagraph","Properties":{"id":"20220630091556-dv01kt8","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"不能return"}]}]},{"ID":"20220630091556-2a5li58","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20220630091556-2a5li58","updated":"20220630091556"},"Children":[{"ID":"20220630091556-egmxplf","Type":"NodeParagraph","Properties":{"id":"20220630091556-egmxplf","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"不自己写构造方法时，默认存在一个空的构造方法"}]}]},{"ID":"20220630091556-tb77z2y","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20220630091556-tb77z2y","updated":"20220630091556"},"Children":[{"ID":"20220630091556-vzbsk1e","Type":"NodeParagraph","Properties":{"id":"20220630091556-vzbsk1e","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"没有参数没有方法体 一旦写了至少一个构造方法，默认那个空的就不存在了 【还想用没有参数的构造函数需要自己写】"}]}]},{"ID":"20220630091556-3uv9ada","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ni4=","Num":6},"Properties":{"id":"20220630091556-3uv9ada","updated":"20220630091556"},"Children":[{"ID":"20220630091556-p7jbc2s","Type":"NodeParagraph","Properties":{"id":"20220630091556-p7jbc2s","updated":"20220630091556"},"Children":[{"Type":"NodeText","Data":"构造方法可以重载"}]}]}]}]},{"ID":"20220630091713-ctvjyef","Type":"NodeParagraph","Properties":{"id":"20220630091713-ctvjyef","updated":"20220630091717"},"Children":[{"Type":"NodeText","Data":"格式"}]},{"ID":"20220630091650-lmpalhs","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220630091650-lmpalhs","updated":"20220630091736"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public 类名称（参数类型 参数名称）{\n\n 方法体\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706102009-zolhlju","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220706102009-zolhlju","updated":"20220706102009"},"Children":[{"Type":"NodeText","Data":"XML 与 HTML 的主要差异"}]},{"ID":"20220706102009-y8dcpn1","Type":"NodeBlockquote","Properties":{"id":"20220706102009-y8dcpn1","updated":"20220706102024"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220706102013-w16yqgj","Type":"NodeParagraph","Properties":{"id":"20220706102013-w16yqgj","updated":"20220706102022"},"Children":[{"Type":"NodeText","Data":"XML 不是 HTML 的替代"}]},{"ID":"20220706102009-ihnsvhp","Type":"NodeParagraph","Properties":{"id":"20220706102009-ihnsvhp","updated":"20220706102022"},"Children":[{"Type":"NodeText","Data":"XML 和 HTML 为不同的目的而设计"}]},{"ID":"20220706102009-8k61j1t","Type":"NodeParagraph","Properties":{"id":"20220706102009-8k61j1t","updated":"20220706102023"},"Children":[{"Type":"NodeText","Data":"XML 被设计为传输和存储数据，其焦点是数据的内容"}]},{"ID":"20220706102009-qphgpix","Type":"NodeParagraph","Properties":{"id":"20220706102009-qphgpix","updated":"20220706102023"},"Children":[{"Type":"NodeText","Data":"HTML 被设计用来显示数据，其焦点是数据的外观"}]},{"ID":"20220706102009-lfgoxzr","Type":"NodeParagraph","Properties":{"id":"20220706102009-lfgoxzr","updated":"20220706102024"},"Children":[{"Type":"NodeText","Data":"HTML 旨在显示信息，而 XML 旨在传输信息"}]}]},{"ID":"20220713214059-64y5ad7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220713214059-64y5ad7","updated":"20220713214132"},"Children":[{"Type":"NodeText","Data":"在Map中如何通过value寻找key的值"}]},{"ID":"20220713214158-2rhcl4t","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713214158-2rhcl4t","updated":"20220714085242"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//先定义map\nHashMap\u003cInteger,Integer\u003e map = new HashMap\u003cInteger,Integer\u003e();\n//这里的Map相当于是int的概念，用来定义遍历map的另一个集合entry\nint temp=1；\nfor(Map.Entry\u003cInteger,Integer\u003e entry : map.entrySet()){\n                    if(entry.getValue().equals(temp)){ //判断entry中是否存在对应的值\n                        int index = entry.getKey();//如果有的保存key值\n\t\t\treturn index;\n                    }\n                }\n\n//转变思想，比如要找某个值的key，那我可以把key的位置写成值，即k-\u003ev,v-\u003ek\n//再通过get的方法就能得到key的值\nint[] nums = new nums[n]\nfor (int i = 0; i \u003c nums.length; ++i) {\n            if (hashtable.containsKey(target - nums[i])) {\n                return new int[]{hashtable.get(target - nums[i]), i};//这里的hashtable.get(target - nums[i])就相当于是通过v找k\n            }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714084742-8xiq1wz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220714084742-8xiq1wz","updated":"20220714084806"},"Children":[{"Type":"NodeText","Data":"什么情况用String、StringBuilder、StringBuffer"}]},{"ID":"20220714084808-7m4dfh3","Type":"NodeBlockquote","Properties":{"id":"20220714084808-7m4dfh3","updated":"20220714084913"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220714084844-v3vsvan","Type":"NodeParagraph","Properties":{"id":"20220714084844-v3vsvan","updated":"20220714084906"},"Children":[{"Type":"NodeText","Data":"使用环境："}]},{"ID":"20220714084814-8lr5z4p","Type":"NodeParagraph","Properties":{"id":"20220714084814-8lr5z4p","updated":"20220714084819"},"Children":[{"Type":"NodeText","Data":"操作少量的数据使用 String\n单线程操作大量数据使用 StringBuilder\n多线程操作大量数据使用 StringBuffer"}]},{"ID":"20220714084913-0z98zpv","Type":"NodeParagraph","Properties":{"id":"20220714084913-0z98zpv"}},{"ID":"20220714084858-fgmmtqh","Type":"NodeParagraph","Properties":{"id":"20220714084858-fgmmtqh","updated":"20220714084903"},"Children":[{"Type":"NodeText","Data":"线程安全："}]},{"ID":"20220714084858-l2qqq94","Type":"NodeParagraph","Properties":{"id":"20220714084858-l2qqq94","updated":"20220714084858"},"Children":[{"Type":"NodeText","Data":"StringBuffer：线程安全\nStringBuilder：线程不安全"}]},{"ID":"20220714084912-073znhd","Type":"NodeParagraph","Properties":{"id":"20220714084912-073znhd"}},{"ID":"20220714084858-iudqlzo","Type":"NodeParagraph","Properties":{"id":"20220714084858-iudqlzo","updated":"20220714084858"},"Children":[{"Type":"NodeText","Data":"速度："}]},{"ID":"20220714084858-77w332d","Type":"NodeParagraph","Properties":{"id":"20220714084858-77w332d","updated":"20220714084858"},"Children":[{"Type":"NodeText","Data":"一般情况下，速度从快到慢为 StringBuilder \u003e StringBuffer \u003e String，当然这是相对的，不是绝对的。"}]}]},{"ID":"20220723203355-j07mbdt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220723203355-j07mbdt","updated":"20220723203959"},"Children":[{"Type":"NodeText","Data":"IDEA import导入的本地类爆红"}]},{"ID":"20220723204002-ct17m19","Type":"NodeParagraph","Properties":{"id":"20220723204002-ct17m19","updated":"20220723204033"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpen