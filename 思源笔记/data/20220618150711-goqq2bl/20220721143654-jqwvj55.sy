ildren":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    public static void main(String[] args) {\n        Scanner in = new Scanner(System.in);\n        int n = in.nextInt();\n        int[] nums = new int[n];\n        for (int i = 0; i \u003c n; i++){\n            nums[i] = in.nextInt();\n        }\n        System.out.println(Arrays.toString(nums));\n        for (int each:nums\n             ) {\n            System.out.println(each);\n        }\n        in.close();\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220813203123-ljw3w59","Type":"NodeParagraph","Properties":{"id":"20220813203123-ljw3w59","updated":"20220813203211"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 67%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220813203201-7l6lg4w.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 67%;\"}"}]},{"ID":"20220813203214-ra1ndh2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220813203214-ra1ndh2","updated":"20220813205925"},"Children":[{"Type":"NodeText","Data":"3.输入n行m列"}]},{"ID":"20220813205925-ptq3yz9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220813205925-ptq3yz9","updated":"20220813205928"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    public static void main(String[] args) {\n        Scanner in = new Scanner(System.in);\n        int n = in.nextInt();\n        int m = in.nextInt();\n        int[][] num = new int[n][m];\n        System.out.println(n+\" \"+m);\n        for (int j = 0; j \u003c n; j++){\n            for (int i = 0; i \u003c m; i++) {\n                num[j][i] = in.nextInt();\n            }\n        }\n        //逐个输出\n        for (int[] each:num\n             ) {\n            for (int data:each\n                 ) {\n                System.out.println(data);\n            }\n        }\n        //多行输出\n        for (int[] each:num\n             ) {\n            System.out.println(Arrays.toString(each));\n        }\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220813210004-ecl10uh","Type":"NodeParagraph","Properties":{"id":"20220813210004-ecl10uh","updated":"20220813210006"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220813210006-e2t9cge.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220813204106-8ocot8k","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220813204106-8ocot8k","updated":"20220813204115"},"Children":[{"Type":"NodeText","Data":"4.读取有限行"}]},{"ID":"20220813204117-e36y3q0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220813204117-e36y3q0","updated":"20220813204119"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    public static void main(String[] args) {\n        Scanner in = new Scanner(System.in);\n\n        int n = in.nextInt();\n        while (n--\u003e0){\n            int a = in.nextInt();\n            int b = in.nextInt();\n            System.out.println(a+b);\n\n        }\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220813204138-wxfmfte","Type":"NodeParagraph","Properties":{"id":"20220813204138-wxfmfte","updated":"20220813204142"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"pa