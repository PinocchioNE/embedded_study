MarkTextContent":"git clone 仓库地址"}]}]},{"ID":"20220725164815-wopohlv","Type":"NodeParagraph","Properties":{"id":"20220725164815-wopohlv","updated":"20220725165342"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220725165342-timvs62.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220725161600-czmjkzp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220725161600-czmjkzp","updated":"20220725161612"},"Children":[{"Type":"NodeText","Data":"工作区、暂存区、版本库概念"}]},{"ID":"20220725165638-sr0gn7l","Type":"NodeBlockquote","Properties":{"id":"20220725165638-sr0gn7l","updated":"20220725165720"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220725165638-56epau6","Type":"NodeParagraph","Properties":{"id":"20220725165638-56epau6","updated":"20220725165714"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"版本库:"},{"Type":"NodeText","Data":"    .git隐藏文件夹就是版本库，版本库中存储了很多配置信息、日志信息和文件版本信息等"}]},{"ID":"20220725165658-cyaw872","Type":"NodeParagraph","Properties":{"id":"20220725165658-cyaw872","updated":"20220725165722"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"工作区:"},{"Type":"NodeText","Data":"     包含.git文件夹的目录就是工作区，也称为工作目录，主要用于存放开发的代码"}]},{"ID":"20220725165701-vtmvgqn","Type":"NodeParagraph","Properties":{"id":"20220725165701-vtmvgqn","updated":"20220725165720"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"暂存区:"},{"Type":"NodeText","Data":"    .git文件夹中有很多文件，其中有一个index文件就是暂存区，也可以叫做stage。暂存区是一个临时保存修改文件的地方"}]}]},{"ID":"20220725170119-268ko8p","Type":"NodeParagraph","Properties":{"id":"20220725170119-268ko8p","updated":"20220725170122"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},