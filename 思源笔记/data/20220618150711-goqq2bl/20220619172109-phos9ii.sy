"}]}]},{"ID":"20220618213075-r86kt7t","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213075-r86kt7t","updated":"20220618213075"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第一种"}]},{"ID":"20220618213076-ct8x49f","Type":"NodeParagraph","Properties":{"id":"20220618213076-ct8x49f","updated":"20220618213076"},"Children":[{"Type":"NodeText","Data":"使用function关键字来定义函数"}]},{"ID":"20220618213077-l3ghwc3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213077-l3ghwc3","updated":"20220618213077"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n     //定义无参函数\n     function f(){\n         alert(\"被调用啦\")\n     }\n     f();\n     function fun(a, b){\n         alert(a+\"被调用啦\"+b)\n     }\n     fun(12,\"ddd\");//结果  12被调用啦ddd\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213078-2m71ecp","Type":"NodeParagraph","Properties":{"id":"20220618213078-2m71ecp","updated":"20220618213078"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/函数-20220618215622-6h989h8.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213079-9ydopx2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213079-9ydopx2","updated":"20220618213079"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第二种"}]},{"ID":"20220618213080-ama6wn6","Type":"NodeCodeBlock","IsFenced