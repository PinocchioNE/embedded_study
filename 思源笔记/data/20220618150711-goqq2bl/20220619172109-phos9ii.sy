td\u003e\n        \u003c/tr\u003e\n\n        \u003ctr\u003e\n            \u003ctd\u003e自我评价:\u003c/td\u003e\n            \u003ctd\u003e\u003ctextarea rows=\"10\" cols=\"20\"\u003e请在此填写\u003c/textarea\u003e\u003cbr/\u003e\u003c/td\u003e\n        \u003c/tr\u003e\n\n        \u003ctr\u003e\n            \u003ctd\u003e\u003cinput type=\"reset\" value=\"重置\"/\u003e\u003c/td\u003e\n            \u003ctd align=\"center\"/\u003e\u003cinput type=\"submit\" \u003e\u003c/td\u003e\n        \u003c/tr\u003e\n    \u003c/table\u003e\n\u003c/form\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618212877-gasnf06","Type":"NodeParagraph","Properties":{"id":"20220618212877-gasnf06","updated":"20220618212877"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/表单1-20220618215622-5jw3y3i.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618212878-7xjuipr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618212878-7xjuipr","updated":"20220618212878"},"Children":[{"Type":"NodeText","Data":"表单提交的细节"}]},{"ID":"20220618212879-xl1amvc","Type":"NodeParagraph","Properties":{"id":"20220618212879-xl1amvc","updated":"20220618212879"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"form标签是表单标签"}]},{"ID":"20220618212880-hkeynud","Type":"NodeList","ListData":{},"Properties":{"id":"20220618212880-hkeynud","updated":"20220618212880"},"Children":[{"ID":"20220618212881-bf6svb4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618212881-bf6svb4","updated":"20220618212881"},"Children":[{"ID":"20220618212882-j44i1e9","Type":"NodeParagraph","Properties":{"id":"20220618212882-j44i1e9","updated":"20220618212882"},"Children":[{"Type":"NodeText","Data":"action属性设置提交的服务器地址"}]}]},{"ID":"20220618212883-eyrnh15","Type":"NodeListItem","Lis