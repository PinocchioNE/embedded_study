c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213058-bpn8hqc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213058-bpn8hqc","updated":"20220618213058"},"Children":[{"Type":"NodeText","Data":"逻辑运算"}]},{"ID":"20220618213059-1e0snqv","Type":"NodeParagraph","Properties":{"id":"20220618213059-1e0snqv","updated":"20220618213059"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"在js语言中，所有的变量都可以作为一个boolean类型的变量去使用"}]},{"ID":"20220618213060-o9zwav7","Type":"NodeParagraph","Properties":{"id":"20220618213060-o9zwav7","updated":"20220618213060"},"Children":[{"Type":"NodeText","Data":"0、null、undefined、“”（空字符串）都认为是false"}]},{"ID":"20220618213061-wkwhexm","Type":"NodeParagraph","Properties":{"id":"20220618213061-wkwhexm","updated":"20220618213061"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"\u0026amp;\u0026amp; 且运算："}]},{"ID":"20220618213062-w7102ti","Type":"NodeParagraph","Properties":{"id":"20220618213062-w7102ti","updated":"20220618213062"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第一种情况："},{"Type":"NodeText","Data":"当表达式全为真的时候返回最后一个表达式的值"}]},{"ID":"20220618213063-nqzar4h","Type":"NodeParagraph","Properties":{"id":"20220618213063-nqzar4h","updated":"20220618213063"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第二种情况："},{"Type":"NodeText","Data":"当表达式中，有一个为假的时候，返回第一个为假的表达式的值"}]},{"ID":"20220618213064-bs2zvn6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213064-bs2zvn6","updated":"20220618213064"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n       var a=\"12\";\n       var b=12;\n       var c = false;\n       var d = null;\n       alert(a \u0026\u0026 b);//结果为 true\n       alert(b \u0026\u0026 a);//结果为 true\n       alert(a \u0026\u0026 c);//结果为 null\n       alert(c \u0026\u0026 d);//结果为 false\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\u003c/body\u003e\n\u003c/ht\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213065-1dc8e2l","Type":"NodeParagraph","Properties":{"id":"20220618213065-1dc8e2l","updated":"20220618213065"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"||或运算："},{"Type":"NodeText","Data":"\n\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第一种情况："},{"Type":"NodeText","Data":"当表达式全为假时，返回最后一个表达式的值\n\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第二种情况："},{"Type":"NodeText","Data":"只要有一个表达式为真。就会把第一个为真的表达式的值返回"}]},{"ID":"20220618213066-9mc06ui","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213066-9mc06ui","updated":"20220618213066"},"Children":[{"Type":"NodeText","Data":"数组（重点）"}]},{"ID":"20220618213067-k1uem5h","Type":"NodeParagraph","Properties":{"id":"20220618213067-k1uem5h","updated":"20220618213067"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"javaScript语言中的数组，只要我们通过数组下标赋值，那么最大的下标值就会自动的给数组做扩容操作。"}]},{"ID":"20220618213068-af58f68","Type":"NodeParagraph","Properties":{"id":"20220618213068-af58f68","updated":"20220618213068"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"格式"}]},{"ID":"20220618213069-ayu1om2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213069-ayu1om2","updated":"20220618213069"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{