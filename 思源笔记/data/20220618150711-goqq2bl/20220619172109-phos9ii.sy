eTextMark","TextMarkType":"strong","TextMarkTextContent":"花括号形式的自定义对象"}]},{"ID":"20220618213087-vu0iltd","Type":"NodeParagraph","Properties":{"id":"20220618213087-vu0iltd","updated":"20220618213087"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"对象的定义："}]},{"ID":"20220618213088-cls2qlm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213088-cls2qlm","updated":"20220618213088"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"var 变量名 ={ 空对象\n属性名：值, //定义一个属性\n函数名：function(){}, //定义一个函数\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213089-oqzy85i","Type":"NodeParagraph","Properties":{"id":"20220618213089-oqzy85i","updated":"20220618213089"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"对象的访问："}]},{"ID":"20220618213090-nmyj7od","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213090-nmyj7od","updated":"20220618213090"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"变量名.属性();\n变量名.函数名();\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213091-z0axnip","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213091-z0axnip","updated":"20220618213091"},"Children":[{"Type":"NodeText","Data":"js事件"}]},{"ID":"20220618213092-ae5nm02","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213092-ae5nm02","updated":"20220618213092"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"常用的事件"}]},{"ID":"20220618213093-4pcncur","Type":"NodeParagraph","Properties":{"id":"20220618213093-4pcncur","updated":"20220618213093"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"onload 加载完成事件:"},{"Type":"NodeText","Data":"\t\t\t\t\t页面加载完成之后，常用于做页面js 代码初始化操作\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"onclick单击事件:"},{"Type":"NodeText","Data":"\t\t\t\t\t \t\t常用于按钮的点击响应操作\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"onblur失去焦点事件:"},{"Type":"NodeText","Data":"\t\t\t  \t    常用用于输入框失去焦点后验证其输入内容是否合法\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"onchange内容发生改变事件:"},{"Type":"NodeText","Data":"  \t   常用于下拉列表和输入框内容发生改变后操作\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"onsubmit表单提交事件:"},{"Type":"NodeText","Data":"\t\t\t\t 常用于表单提交前，验证所有表单项是否合法"}]},{"ID":"20220618213094-novh0pz","Type":"NodeParagraph","Properties":{"id":"20220618213094-novh0pz","updated":"20220618213094"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"事件的注册又分为静态注册和动态注册两种:"}]},{"ID":"20220618213095-2o59v1y","Type":"NodeParagraph","Properties":{"id":"20220618213095-2o59v1y","updated":"20220618213095"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"什么是事件的注册（绑定)"},{"Type":"NodeText","Data":"\n​\t\t\t其实就是告诉浏览器，当事件响应后要执行哪些操作代码，叫事件注册或事件绑定。"}]},{"ID":"20220618213096-zia41c4","Type":"NodeParagraph","Properties":{"id":"20220618213096-zia41c4","updated":"20220618213096"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"静态注册事件:"},{"Type":"NodeText","Data":"通过html标签的事件属性直接赋于事件响应后的代码，这种方式我们叫静态注册。"}]},{"ID":"20220618213097-a8pwt39","Type":"NodeParagraph","Properties":{"id":"20220618213097-a8pwt39","updated":"20220618213097"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"动态注册事件:"},{"Type":"NodeText","Data":"是指先通过js代码得到标签的dom对象，然后再通过    dom对象.事件名 = function()      这种形式赋于事件响应后的代\t\t码，\t\t\t\t\t\t叫动态注册。"}]},{"ID":"20220618213098-prjslub","Type":"NodeParagraph","Properties":{"id":"20220618213098-prjslub","updated":"20220618213098"},"Children":[{"Type":"NodeText","Data":"​\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"动态注册基本步骤:"},{"Type":"NodeText","Data":"\n​\t\t1、获取标签对象\n​\t\t2、标签对象.事件名= fucntion(){}"}]},{"ID":"20220618213099-mfwthqa","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213099-mfwthqa","updated":"20220618213099"},"Children":[{"Type":"NodeText","Data":"onload 加载完成事件"}]},{"ID":"20220618213100-5gdv4ho","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213100-5gdv4ho","updated":"20220618213100"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        //onload事件的方法\n     function f(){\n         alert(\"静态注册onload事件\")\n     }\n     //onload事件动态注册,这是固定写法\n      window.onload = function (){\n         alert(\"动态注册方法\")\n      }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003c!--静态事件调用方法\n    onload事件是浏览器解析完页面后就会自动触发的事件\n    \u003cbody onload=\"onloadFun();\"\u003e\n--\u003e\n\u003cbody\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213101-ifob2hf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213101-ifob2hf","updated":"20220618213101"},"Children":[{"Type":"NodeText","Data":"onclick事件"}]},{"ID":"20220618213102-03m46xo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213102-03m46xo","updated":"20220618213102"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        //onload事件的方法\n     function f(){\n         alert(\"静态注册onload事件\")\n     }\n     //onload事件动态注册,这是固定写法\n      window.onload = function (){\n          //1.获取标签对象\n          var button01 = document.getElementById(\"button01\");\n          //2.通过标签对象.事件名 = function(){}\n         button01.onclick = function(){\n             alert(\"动态注册的onclick\");\n          }\n      }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003c!--静态注册onclick事件--\u003e\n\u003cbutton onclick=\"f();\"\u003e按钮1\u003c/button\u003e\n\u003cbutton id=\"button01\"\u003e按钮2\u003c/button\u003e\n\n\u003cbody\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213103-ypiuxva","Type":"NodeParagraph","Properties":{"id":"20220618213103-ypiuxva","updated":"20220618213103"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/按钮1-20220618215622-f0b16va.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213104-2xefuf2","Type":"NodeParagraph","Properties":{"id":"20220618213104-2xefuf2","updated":"20220618213104"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/按钮2-20220618215622-rz2nqaj.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213105-16nblm1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213105-16nblm1","updated":"20220618213105"},"Children":[{"Type":"NodeText","Data":"onblur失去焦点事件"}]},{"ID":"20220618213106-7xwyzm4","Type":"NodeParagraph","Properties":{"id":"20220618213106-7xwyzm4","updated":"20220618213106"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"console是控制台对象，是由JavaScript语言提供，专门用来向浏览器的控制器打印输出，用于测试使用"}]},{"ID":"20220618213107-6ixn5q0","Type":"NodeParagraph","Properties":{"id":"20220618213107-6ixn5q0","updated":"20220618213107"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"log()是打印的方法"}]},{"ID":"20220618213108-ukfppg1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213108-ukfppg1","updated":"20220618213108"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        //静态事件失去焦点事件\n     function onblurfun(){\n         console.log(\"静态注册onload事件\");\n     }\n     window.onload = function (){\n         //1.获取标签对象\n         var passwordObj = document.getElementById(\"password\");\n         //2.通过标签对象.事件名 = function(){}\n         passwordObj.onblur = function (){\n             console.log(\"动态注册失去焦点事件\")\n         }\n     }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    用户名：\u003cinput type=\"text\" onblur=\"onblurfun();\"\u003e\u003cbr/\u003e\n    密码：\u003cinput id=\"password\" type=\"text\"\u003e\u003cbr/\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213109-tu39pb6","Type":"NodeParagraph","Properties":{"id":"20220618213109-tu39pb6","updated":"20220618213109"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/失去焦点-20220618215622-8ony0nm.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213110-qokxyl9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213110-qokxyl9","updated":"20220618213110"},"Children":[{"Type":"NodeText","Data":"onchange事件"}]},{"ID":"20220618213111-58fhto2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213111-58fhto2","updated":"20220618213111"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        //静态事件失去焦点事件\n        function onbchangefun(){\n            alert(\"选择静态\");\n        }\n        window.onload = function (){\n            //1.获取标签对象\n            var seldObj = document.getElementById(\"selectobj\");\n            //2.通过标签对象.事件名 = function(){}\n            seldObj.onchange = function (){\n                alert(\"选择动态\");\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\u003cselect onchange=\"onbchangefun();\"\u003e\n    \u003coption\u003e----女神----\u003c/option\u003e\n    \u003coption\u003e瞎说的\u003c/option\u003e\n    \u003coption\u003e啊是的\u003c/option\u003e\n\u003c/select\u003e\n\u003cselect id=\"selectobj\"\u003e\n    \u003coption\u003e----男神----\u003c/option\u003e\n    \u003coption\u003e撒的\u003c/option\u003e\n    \u003coption\u003e是大法官\u003c/option\u003e\n\n\u003c/select\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213112-w90sg2h","Type":"NodeParagraph","Properties":{"id":"20220618213112-w90sg2h","updated":"20220618213112"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/onchange-20220618215622-sffenpq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213113-hsvc63g","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213113-hsvc63g","updated":"20220618213113"},"Children":[{"Type":"NodeText","Data":"onsubmit表单提交事件"}]},{"ID":"20220618213114-bk2hmqi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213114-bk2hmqi","updated":"20220618213114"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        //静态事件失去焦点事件\n        function onsubmitfun(){\n            alert(\"选择静态---不合法\");\n            return false;\n        }\n        window.onload = function (){\n            //1.获取标签对象\n            var submitObj = document.getElementById(\"submitobj\");\n            //2.通过标签对象.事件名 = function(){}\n            submitObj.onsubmit = function (){\n                alert(\"选择动态---不合法\");\n                return false;\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\u003cform action=\"http://localhost:8080\" method=\"get\" onsubmit=\"return onsubmitfun()\"\u003e\n    \u003cinput type=\"submit\" value=\"静态注册\"/\u003e\n\u003c/form\u003e\n\u003cform action=\"http://localhost:8080\" id=\"submitobj\"\u003e\n    \u003cinput type=\"submit\" value=\"动态注册\"/\u003e\n\u003c/form\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213115-ywdm8r2","Type":"NodeParagraph","Properties":{"id":"20220618213115-ywdm8r2","updated":"20220618213115"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/提交-20220618215622-0by1yl4.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213116-48uj5i7","Type":"NodeParagraph","Properties":{"id":"20220618213116-48uj5i7","updated":"20220618213116"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/提交2-20220618215622-34lkojt.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213117-g78ycl4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213117-g78ycl4","updated":"20220618213117"},"Children":[{"Type":"NodeText","Data":"DOM模型"}]},{"ID":"20220618213118-nh2lk2f","Type":"NodeParagraph","Properties":{"id":"20220618213118-nh2lk2f","updated":"20220618213118"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（Document Object Model）文档对象模型"}]},{"ID":"20220618213119-ujxab6z","Type":"NodeParagraph","Properties":{"id":"20220618213119-ujxab6z","updated":"20220618213119"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"作用：把文档中的标签、属性、文本，转换成为对象来管理（用一个类去记录相关信息）"}]},{"ID":"20220618213120-1q90239","Type":"NodeParagraph","Properties":{"id":"20220618213120-1q90239","updated":"20220618213120"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/结构-20220618215622-9kw78qr.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213121-qjga5a4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213121-qjga5a4","updated":"20220618213121"},"Children":[{"Type":"NodeText","Data":"Document对象中的方法介绍（重点）"}]},{"ID":"20220618213122-6ty6qeo","Type":"NodeParagraph","Properties":{"id":"20220618213122-6ty6qeo","updated":"20220618213122"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementById(elementId)"}]},{"ID":"20220618213123-95xde7q","Type":"NodeParagraph","Properties":{"id":"20220618213123-95xde7q","updated":"20220618213123"},"Children":[{"Type":"NodeText","Data":"通过标签的 id 属性查找标签 dom 对象，elementId 是标签的 id 属性值"}]},{"ID":"20220618213124-oiami8e","Type":"NodeParagraph","Properties":{"id":"20220618213124-oiami8e","updated":"20220618213124"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementsByName(elementName)"}]},{"ID":"20220618213125-uesznlk","Type":"NodeParagraph","Properties":{"id":"20220618213125-uesznlk","updated":"20220618213125"},"Children":[{"Type":"NodeText","Data":"通过标签的 name 属性查找标签 dom 对象，elementName 标签的 name 属性值"}]},{"ID":"20220618213126-5jf5ew3","Type":"NodeParagraph","Properties":{"id":"20220618213126-5jf5ew3","updated":"20220618213126"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementsByTagName(tagname)"}]},{"ID":"20220618213127-4eaqpqg","Type":"NodeParagraph","Properties":{"id":"20220618213127-4eaqpqg","updated":"20220618213127"},"Children":[{"Type":"NodeText","Data":"通过标签名查找标签 dom 对象，tagname 是标签名"}]},{"ID":"20220618213128-i4atyig","Type":"NodeParagraph","Properties":{"id":"20220618213128-i4atyig","updated":"20220618213128"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.createElement( tagName)"}]},{"ID":"20220618213129-8phmsqj","Type":"NodeParagraph","Properties":{"id":"20220618213129-8phmsqj","updated":"20220618213129"},"Children":[{"Type":"NodeText","Data":"方法，通过给定的标签名，创建一个标签对象。tagName 是要创建的标签名"}]},{"ID":"20220618213130-110of9d","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213130-110of9d","updated":"20220618213130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementById(elementId)"}]},{"ID":"20220618213131-x3uxi5p","Type":"NodeBlockquote","Properties":{"id":"20220618213131-x3uxi5p","updated":"20220618213131"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213132-cmhs3mx","Type":"NodeParagraph","Properties":{"id":"20220618213132-cmhs3mx","updated":"20220618213132"},"Children":[{"Type":"NodeText","Data":"需求：用户点击了验证按钮，要获取输出框中的内容，验证其是否合法"}]}]},{"ID":"20220618213133-3sw7auv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213133-3sw7auv","updated":"20220618213133"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        function onclickFun(){\n            //1.当我们需要操作一个标签的时候，一定要先获取这个对象\n            var usernameObj = document.getElementById(\"username\");\n            var usernameText = usernameObj.value;\n            //如何验证字符串，符合某个规则，需要使用正则表达式技术\n            var patt = /^\\w{5,12}$/;//表示有字幕、数字、下划线组成 长度为5，12  正则表达式\n            //test()方法用于测试某个字符串，是不是匹配设定的规则 匹配为ture  不匹配为false\n            if(patt.test(usernameText)){\n                alert(\"合法\")\n            }else {\n                alert(\"不合法\");\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    用户名：\u003cinput type=\"text\" id=\"username\"/\u003e\n    \u003cbutton onclick=\"onclickFun()\"\u003e校验\u003c/button\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213134-7q63nel","Type":"NodeParagraph","Properties":{"id":"20220618213134-7q63nel","updated":"20220618213134"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/合法-20220618215622-wlk131w.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213135-s8dei18","Type":"NodeParagraph","Properties":{"id":"20220618213135-s8dei18","updated":"20220618213135"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/不合法-20220618215622-4uvsxou.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213136-7pjee2s","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618213136-7pjee2s","updated":"20220618213136"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementById(elementId)  第二种显示效果"}]},{"ID":"20220618213137-f48yopp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213137-f48yopp","updated":"20220618213137"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        function onclickFun(){\n            //1.当我们需要操作一个标签的时候，一定要先获取这个对象\n            var usernameObj = document.getElementById(\"username\");\n            var usernameText = usernameObj.value;\n            var patt = /^\\w{5,12}$/;\n            var usernameSpanObj = document.getElementById(\"usernameSpan\");\n            //innerHTML表示起始标签和结束标签中的内容\n            //innerHTML属性可读可写\n            //test()方法用于测试某个字符串，是不是匹配设定的规则 匹配为ture  不匹配为false\n            usernameSpanObj.innerHTML = \"牛啊\";\n\n            if(patt.test(usernameText)){\n                usernameSpanObj.innerHTML = \"用户名合法\";\n            }else {\n                usernameSpanObj.innerHTML = \"用户名不合法\";\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    用户名：\u003cinput type=\"text\" id=\"username\"/\u003e\n    \u003cspan id=\"usernameSpan\" style=\"color: red;\" \u003e\u003c/span\u003e\n    \u003cbutton onclick=\"onclickFun()\"\u003e校验\u003c/button\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213138-0g7x3pz","Type":"NodeParagraph","Properties":{"id":"20220618213138-0g7x3pz","updated":"20220618213138"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/校验-20220618215622-8b9rpp3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213139-wh96x47","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220618213139-wh96x47","updated":"20220618213139"},"Children":[{"Type":"NodeText","Data":"加入图片元素进行校验"}]},{"ID":"20220618213140-fb6hi0p","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213140-fb6hi0p","updated":"20220618213140"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n\n    \u003cscript type=\"text/javascript\"\u003e\n        function onclickFun(){\n            //1.当我们需要操作一个标签的时候，一定要先获取这个对象\n            var usernameObj = document.getElementById(\"username\");\n            var usernameText = usernameObj.value;\n            var patt = /^\\w{5,12}$/;\n            var usernameSpanObj = document.getElementById(\"usernameSpan\");\n            //innerHTML表示起始标签和结束标签中的内容\n            //innerHTML属性可读可写\n            //test()方法用于测试某个字符串，是不是匹配设定的规则 匹配为ture  不匹配为false\n            usernameSpanObj.innerHTML = \"牛啊\";\n\t\t\t\n            if(patt.test(usernameText)){\n                usernameSpanObj.innerHTML = \"\u003cimg src=\\\"right.png\\\" width=\\'18\\' height=\\'18\\'\u003e\";\n            }else {//     \\\"right.png\\\"   \\\"是对引号转义\n                usernameSpanObj.innerHTML = \"\u003cimg src=\\\"wrong.png\\\" width=\\'18\\' height=\\'18\\'\u003e\";\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    用户名：\u003cinput type=\"text\" id=\"username\"/\u003e\n    \u003cspan id=\"usernameSpan\" style=\"color: red;\" \u003e\u003c/span\u003e\n    \u003cbutton onclick=\"onclickFun()\"\u003e校验\u003c/button\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213141-sd6kvpg","Type":"NodeParagraph","Properties":{"id":"20220618213141-sd6kvpg","updated":"20220618213141"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/校验图片-20220618215622-tp2o1ny.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213142-mt9nrxy","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213142-mt9nrxy","updated":"20220618213142"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementsByName(elementName)"}]},{"ID":"20220618213143-3u982zv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213143-3u982zv","updated":"20220618213143"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n    \u003cscript type=\"text/javascript\"\u003e\n        function checkAll(){\n            //选中所有的复选框\n            //byname是根据指定的name属性查询返回多个标签对象集合\n            //这个集合的操作和数组一样是按顺序来的  集合中都是dom对象\n            var hobbise = document.getElementsByName(\"hobby\")\n            //checked表示复选框的选中状态 如果选中就是true 没选就是false\n            for (var i = 0; i \u003c hobbise.length; i++){\n                hobbise[i].checked = true;\n            }\n        }\n        function checkNone(){\n            var hobbise = document.getElementsByName(\"hobby\")\n            //checked表示复选框的选中状态 如果选中就是true 没选就是false\n            for (var i = 0; i \u003c hobbise.length; i++){\n                hobbise[i].checked = false;\n            }\n        }\n        function checkReverse(){\n            var hobbise = document.getElementsByName(\"hobby\")\n            //checked表示复选框的选中状态 如果选中就是true 没选就是false\n            for (var i = 0; i \u003c hobbise.length; i++){\n                hobbise[i].checked = !hobbise[i].checked;\n            }\n        }\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    兴趣爱好：\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003ejava\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003epython\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003ec++\n    \u003cbr/\u003e\n    \u003cbutton onclick=\"checkAll()\"\u003e全选\u003c/button\u003e\n    \u003cbutton onclick=\"checkNone()\"\u003e全不选\u003c/button\u003e\n    \u003cbutton onclick=\"checkReverse()\"\u003e反选\u003c/button\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213144-8rgm93x","Type":"NodeParagraph","Properties":{"id":"20220618213144-8rgm93x","updated":"20220618213144"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/全选-20220618215622-y5t1zu1.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213145-0bkf2t9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213145-0bkf2t9","updated":"20220618213145"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"document.getElementsByTagName(tagname)"}]},{"ID":"20220618213146-wgaj7lz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213146-wgaj7lz","updated":"20220618213146"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA=="},{"Type":"NodeCodeBlockCode","Data":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh_cn\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003e标题\u003c/title\u003e\n    \u003cscript type=\"text/javascript\"\u003e\n        function checkAll(){\n            //选中所有的复选框\n            //byname是根据指定的name属性查询返回多个标签对象集合\n            //这个集合的操作和数组一样是按顺序来的\n            var hobbise = document.getElementsByTagName(\"input\")//注意就这里换了 input是标签名\n            //checked表示复选框的选中状态 如果选中就是true 没选就是false\n            for (var i = 0; i \u003c hobbise.length; i++){\n                hobbise[i].checked = true;\n            }\n        }\n\n    \u003c/script\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    兴趣爱好：\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003ejava\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003epython\n    \u003cinput type=\"checkbox\" name=\"hobby\" /\u003ec++\n    \u003cbr/\u003e\n    \u003cbutton onclick=\"checkAll()\"\u003e全选\u003c/button\u003e\n    \u003cbutton onclick=\"checkNone()\"\u003e全不选\u003c/button\u003e\n    \u003cbutton onclick=\"checkReverse()\"\u003e反选\u003c/button\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213147-07vr3jc","Type":"NodeParagraph","Properties":{"id":"20220618213147-07vr3jc","updated":"20220618213147"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/标签-20220618215622-k9w28ys.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213148-fh7w1e4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213148-fh7w1e4","updated":"20220618213148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"节点的常用属性和方法"}]},{"ID":"20220618213149-yfsx7fp","Type":"NodeParagraph","Properties":{"id":"20220618213149-yfsx7fp","updated":"20220618213149"},"Children":[{"Type":"NodeText","Data":"节点就是标签对象"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"方法："}]},{"ID":"20220618213150-uoxcgqk","Type":"NodeParagraph","Properties":{"id":"20220618213150-uoxcgqk","updated":"20220618213150"},"Children":[{"Type":"NodeText","Data":"通过具体的元素节点调用"}]},{"ID":"20220618213151-oe25stk","Type":"NodeParagraph","Properties":{"id":"20220618213151-oe25stk","updated":"20220618213151"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"getElementsByTagName()"}]},{"ID":"20220618213152-0rflhj9","Type":"NodeParagraph","Properties":{"id":"20220618213152-0rflhj9","updated":"20220618213152"},"Children":[{"Type":"NodeText","Data":"方法，获取当前节点的指定标签名孩子节点"}]},{"ID":"20220618213153-uqzhuh9","Type":"NodeParagraph","Properties":{"id":"20220618213153-uqzhuh9","updated":"20220618213153"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"appendChild( oChildNode )"}]},{"ID":"20220618213154-zh6if77","Type":"NodeParagraph","Properties":{"id":"20220618213154-zh6if77","updated":"20220618213154"},"Children":[{"Type":"NodeText","Data":"方法，可以添加一个子节点，oChildNode 是要添加的孩子节点"}]},{"ID":"20220618213155-fm0gjjv","Type":"NodeParagraph","Properties":{"id":"20220618213155-fm0gjjv","updated":"20220618213155"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"属性："}]},{"ID":"20220618213156-ge2qlh6","Type":"NodeParagraph","Properties":{"id":"20220618213156-ge2qlh6","updated":"20220618213156"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkT