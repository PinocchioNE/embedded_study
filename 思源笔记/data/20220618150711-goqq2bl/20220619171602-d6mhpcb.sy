18213604"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220601200257036"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220601200257036-20220618215622-zrm0fvq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213605-40r0yv6","Type":"NodeParagraph","Properties":{"id":"20220618213605-40r0yv6","updated":"20220618213605"},"Children":[{"Type":"NodeText","Data":"2.编写过滤器"}]},{"ID":"20220618213606-51k9k0v","Type":"NodeParagraph","Properties":{"id":"20220618213606-51k9k0v","updated":"20220618213606"},"Children":[{"Type":"NodeText","Data":"实现Filter接口，重写对应的方法即可"}]},{"ID":"20220618213607-imbxe2x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213607-imbxe2x","updated":"20220618213607"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class CharacterEncodingFilter implements Filter{\n\n    //初始化\n    public void init(FilterConfig filterConfig) throws ServletException {\n        System.out.println(\"初始化\");\n    }\n    /*chain:链\n    1.过滤中的所有代码，在过滤特定请求的时候都会执行\n    2.必须要让过滤器继续同行\n    Chain.doFilter(Request,Response);\n     */\n    public void doFilter(ServletRequest Request, ServletResponse Response, FilterChain Chain) throws IOException, ServletException {\n        Request.setCharacterEncoding(\"utf-8\");\n        //Response.setCharacterEncoding(\"utf-8\");\n        Response.setContentType(\"text/html;charset=UTF-8\");\n\n        System.out.println(\"CharacterEncodingFilter执行前...\");\n        Chain.doFilter(Request,Response);//让我们的请求继续走，如果不写，程序到这里就被拦截停止\n        System.out.println(\"CharacterEncodingFilter执行后\");\n    }\n\n    //销毁:web服务器关闭的时候，过滤器会销毁  \n    public void destroy() {\n        System.out.println(\"销毁\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213608-lg0jjbj","Type":"NodeParagraph","Properties":{"id":"20220618213608-lg0jjbj","updated":"20220618213608"},"Children":[{"Type":"NodeText","Data":"3.在web.xml中配置Filter"}]},{"ID":"20220618213609-3j2rk03","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213609-3j2rk03","updated":"20220618213609"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\t\u003cfilter\u003e\n        \u003cfilter-name\u003eCharacterEncodingFilter\u003c/filter-name\u003e\n        \u003cfilter-class\u003ecom.Xia.filter.CharacterEncodingFilter\u003c/filter-class\u003e\n    \u003c/filter\u003e\n    \u003cfilter-mapping\u003e\n        \u003cfilter-name\u003eCharacterEncodingFilter\u003c/filter-name\u003e\n        \u003curl-pattern\u003e/servlet/*\u003c/url-pattern\u003e\n    \u003c/filter-mapping\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213610-0qp7b4l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213610-0qp7b4l","updated":"20220618213610"},"Children":[{"Type":"NodeText","Data":"监听器"}]},{"ID":"20220618213611-60emd7z","Type":"NodeParagraph","Properties":{"id":"20220618213611-60emd7z","updated":"20220618213611"},"Children":[{"Type":"NodeText","Data":"实现一个监听器的接口"}]},{"ID":"20220618213612-z6wfeeq","Type":"NodeParagraph","Properties":{"id":"20220618213612-z6wfeeq","updated":"20220618213612"},"Children":[{"Type":"NodeText","Data":"1.编写一个监听器"}]},{"ID":"20220618213613-kcwwjeo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213613-kcwwjeo","updated":"20220618213613"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//统计网站在线人数：统计session\npublic class OnlineCountListener implements HttpSessionListener{\n\n    //创建session监听：看你的一举一动\n    //一旦创建session就会触发一次这个事件！\n    public void sessionCreated(HttpSessionEvent se) {\n        ServletContext ctx = se.getSession().getServletContext();\n        Integer onlineCount = (Integer)ctx.getAttribute(\"OnlineCount\");\n\n        if (onlineCount==null){\n            onlineCount = new Integer(1);\n        }else {\n            int count = onlineCount.intValue();\n            onlineCount = new Integer(count+1);\n        }\n\n        ctx.setAttribute(\"OnlineCount\",onlineCount);\n    }\n\n    //销毁session监听\n    public void sessionDestroyed(HttpSessionEvent se) {\n        ServletContext ctx = se.getSession().getServletContext();\n        Integer onlineCount = (Integer)ctx.getAttribute(\"OnlineCount\");\n\n        if (onlineCount==null){\n            onlineCount = new Integer(0);\n        }else {\n            int count = onlineCount.intValue();\n            onlineCount = new Integer(count-1);\n        }\n\n        ctx.setAttribute(\"OnlineCount\",onlineCount);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213614-s7qcddf","Type":"NodeParagraph","Properties":{"id":"20220618213614-s7qcddf","updated":"20220618213614"},"Children":[{"Type":"NodeText","Data":"2.web.xml中注册监听器"}]},{"ID":"20220618213615-nqcv7l8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213615-nqcv7l8","updated":"20220618213615"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--注册监听器--\u003e\n    \u003clistener\u003e\n        \u003clistener-class\u003ecom.Xia.filter.listener.OnlineCountListener\u003c/listener-class\u003e\n    \u003c/listener\u003e\n  \n    \u003csession-config\u003e\n        \u003csession-timeout\u003e1\u003c/session-timeout\u003e\n    \u003c/session-config\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213616-h8dahsk","Type":"NodeParagraph","Properties":{"id":"20220618213616-h8dahsk","updated":"20220618213616"},"Children":[{"Type":"NodeText","Data":"3.看情况是否使用"}]},{"ID":"20220618213617-sc9u3ta","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213617-sc9u3ta","updated":"20220618213617"},"Children":[{"Type":"NodeText","Data":"过滤器、监听器常见应用"}]},{"ID":"20220618213618-aarrz15","Type":"NodeParagraph","Properties":{"id":"20220618213618-aarrz15","updated":"20220618213618"},"Children":[{"Type":"NodeText","Data":" 用户登录之后才能进入主页，用户注销之后就不能进入主页了"}]},{"ID":"20220618213619-jlihs2c","Type":"NodeParagraph","Properties":{"id":"20220618213619-jlihs2c","updated":"20220618213619"},"Children":[{"Type":"NodeText","Data":"1.用户登录之后，向session中放入用户的数据"}]},{"ID":"20220618213620-2w5l5fv","Type":"NodeParagraph","Properties":{"id":"20220618213620-2w5l5fv","updated":"20220618213620"},"Children":[{"Type":"NodeText","Data":"2.进入主页的时候要判断用户是否已经登录；要求：在过滤器中实现"}]},{"ID":"20220618213621-7gtwov0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213621-7gtwov0","updated":"20220618213621"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"HttpServletRequest request = (HttpServletRequest) req;\nHttpServletResponse response = (HttpServletResponse) req;\n\nif (request.getSession().getAttribute(\"USER_SESSION\")==null){\n    response.sendRedirect(\"/sys/error.jsp\");\n}\nchain.doFilter(request, response);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213622-c8khu5f","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213622-c8khu5f","updated":"20220618213622"},"Children":[{"Type":"NodeText","Data":"JDBC回顾"}]},{"ID":"20220618213623-5pkjtcg","Type":"NodeParagraph","Properties":{"id":"20220618213623-5pkjtcg","updated":"20220618213623"},"Children":[{"Type":"NodeText","Data":"什么是JDBC：JAVA连接数据库"}]},{"ID":"20220618213624-h60029i","Type":"NodeParagraph","Properties":{"id":"20220618213624-h6