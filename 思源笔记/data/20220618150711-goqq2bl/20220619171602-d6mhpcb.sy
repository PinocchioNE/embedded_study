ies":{"id":"20220618213540-5i04ebf","updated":"20220618213540"},"Children":[{"ID":"20220618213541-bg1156p","Type":"NodeParagraph","Properties":{"id":"20220618213541-bg1156p","updated":"20220618213541"},"Children":[{"Type":"NodeText","Data":"用户登录之后，整个网站都可以访问——\u003e保存用户信息；保存购物车信息..."}]}]}]},{"ID":"20220618213542-awzg8s0","Type":"NodeParagraph","Properties":{"id":"20220618213542-awzg8s0","updated":"20220618213542"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Session和cookie的区别："}]},{"ID":"20220618213543-6rzoss9","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213543-6rzoss9","updated":"20220618213543"},"Children":[{"ID":"20220618213544-enwt42s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213544-enwt42s","updated":"20220618213544"},"Children":[{"ID":"20220618213545-ayumt83","Type":"NodeParagraph","Properties":{"id":"20220618213545-ayumt83","updated":"20220618213545"},"Children":[{"Type":"NodeText","Data":"Cookie是把用户的数据写给用户的浏览器，浏览器保存（可以保存多个）"}]}]},{"ID":"20220618213546-87ra6x7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213546-87ra6x7","updated":"20220618213546"},"Children":[{"ID":"20220618213547-udv7mnv","Type":"NodeParagraph","Properties":{"id":"20220618213547-udv7mnv","updated":"20220618213547"},"Children":[{"Type":"NodeText","Data":"Session把用户的数据写到用户独占Session中，服务器端保存（保存重要信息，减少服务器资源的浪费）"}]}]},{"ID":"20220618213548-u36hq8n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213548-u36hq8n","updated":"20220618213548"},"Children":[{"ID":"20220618213549-pk3l961","Type":"NodeParagraph","Properties":{"id":"20220618213549-pk3l961","updated":"20220618213549"},"Children":[{"Type":"NodeText","Data":"Session对象由服务器创建"}]}]}]},{"ID":"20220618213550-csyccuv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213550-csyccuv","updated":"20220618213550"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":" //解决乱码问题\n req.setCharacterEncoding(\"UTF-8\");\n resp.setCharacterEncoding(\"UTF-8\");\n resp.setContentType(\"text/html;charset=utf-8\");\n\n//得到session\nHttpSession session = req.getSession();\n\n//给session中存东西\nsession.setAttribute(\"name\",new Person(\"夏天豪\",1));\n\n//获取session的id\nString sessionId = session.getId();\n\n//判断session是不是新的\nif (session.isNew()){\nresp.getWriter().write(\"seesion创建成功,ID\"+sessionId);\n}else {\nresp.getWriter().write(\"seesion已经在服务器中存在了,ID:\"+sessionId);\n}\n\n //得到session\n HttpSession session = req.getSession();\n\nPerson person = (Person) session.getAttribute(\"name\");\n\nSystem.out.println(person.toString());\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213551-7xzi2v3","Type":"NodeParagraph","Properties":{"id":"20220618213551-7xzi2v3","updated":"20220618213551"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"会话过期设置：web.xml设置"}]},{"ID":"20220618213552-0pr0n2q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213552-0pr0n2q","updated":"20220618213552"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--设置session默认的失效时间--\u003e\n        \u003csession-config\u003e\n            \u003c!--15分钟后session自动失效,以分钟为单位--\u003e\n            \u003csession-timeout\u003e1\u003c/session-timeout\u003e\n        \u003c/session-config\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213553-s8wrbp5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213553-s8wrbp5","updated":"20220618213553"},"Children":[{"Type":"NodeText","Data":"JavaBean"}]},{"ID":"20220618213554-ykq6b46","Type":"NodeParagraph","Properties":{"id":"20220618213554-ykq6b46","u