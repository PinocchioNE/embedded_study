,{"ID":"20220618213634-mhr5ye7","Type":"NodeParagraph","Properties":{"id":"20220618213634-mhr5ye7","updated":"20220618213634"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"导入数据库依赖"}]},{"ID":"20220618213635-b2mmw3e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213635-b2mmw3e","updated":"20220618213635"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\t\u003cdependency\u003e\n      \u003cgroupId\u003emysql\u003c/groupId\u003e\n      \u003cartifactId\u003emysql-connector-java\u003c/artifactId\u003e\n      \u003cversion\u003e8.0.27\u003c/version\u003e\n    \u003c/dependency\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213636-k83r8yu","Type":"NodeParagraph","Properties":{"id":"20220618213636-k83r8yu","updated":"20220618213636"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"IDE中连接数据库"}]},{"ID":"20220618213637-gawm8yo","Type":"NodeParagraph","Properties":{"id":"20220618213637-gawm8yo","updated":"20220618213637"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605145922920"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605145922920-20220618215622-u13xh31.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213638-vj2bpuv","Type":"NodeParagraph","Properties":{"id":"20220618213638-vj2bpuv","updated":"20220618213638"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605150229100"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605150229100-20220618215622-cs44g1j.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213639-hn4nipj","Type":"NodeBlockquote","Properties":{"id":"20220618213639-hn4nipj","updated":"20220618213639"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213640-2ri4aja","Type":"NodeParagraph","Properties":{"id":"20220618213640-2ri4aja","updated":"20220618213640"},"Children":[{"Type":"NodeText","Data":"driver导入失败看下图"}]}]},{"ID":"20220618213641-z0sl2sb","Type":"NodeParagraph","Properties":{"id":"20220618213641-z0sl2sb","updated":"20220618213641"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605150402053"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605150402053-20220618215622-6fttt8g.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213642-0vl3128","Type":"NodeBlockquote","Properties":{"id":"20220618213642-0vl3128","updated":"20220618213642"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213643-ipwlmvy","Type":"NodeParagraph","Properties":{"id":"20220618213643-ipwlmvy","updated":"20220618213643"},"Children":[{"Type":"NodeText","Data":"然后选择jdbc"}]}]},{"ID":"20220618213644-vhkuiz9","Type":"NodeParagraph","Properties":{"id":"20220618213644-vhkuiz9","updated":"20220618213644"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605150457048"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605150457048-20220618215622-ki2teya.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213645-6wlmzj5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213645-6wlmzj5","updated":"20220618213645"},"Children":[{"Type":"NodeText","Data":"JDBC固定步骤"}]},{"ID":"20220618213646-t9ubt7k","Type":"NodeParagraph","Properties":{"id":"20220618213646-t9ubt7k","updated":"20220618213646"},"Children":[{"Type":"NodeText","Data":"1.加载驱动"}]},{"ID":"20220618213647-z7owmdv","Type":"NodeParagraph","Properties":{"id":"20220618213647-z7owmdv","updated":"20220618213647"},"Children":[{"Type":"NodeText","Data":"2.连接数据库，代表数据库"}]},{"ID":"20220618213648-z1vluyo","Type":"NodeParagraph","Properties":{"id":"20220618213648-z1vluyo","updated":"20220618213648"},"Children":[{"Type":"NodeText","Data":"3.向数据库发送sql的对象statement：CRUD"}]},{"ID":"20220618213649-cdhk752","Type":"NodeParagraph","Properties":{"id":"20220618213649-cdhk752","updated":"20220618213649"},"Children":[{"Type":"NodeText","Data":"4.编写sql（根据业务不同的sql）"}]},{"ID":"20220618213650-d2s7spz","Type":"NodeParagraph","Properties":{"id":"20220618213650-d2s7spz","updated":"20220618213650"},"Children":[{"Type":"NodeText","Data":"5.执行sql"}]},{"ID":"20220618213651-b1sbv1f","Type":"NodeParagraph","Properties":{"id":"20220618213651-b1sbv1f","updated":"20220618213651"},"Children":[{"Type":"NodeText","Data":"6.关闭连接"}]},{"ID":"20220618213652-xjp3sr1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213652-xjp3sr1","updated":"20220618213652"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia;\n\nimport java.sql.*;\n\npublic class TestJDBC {\n    public static void main(String[] args) throws ClassNotFoundException, SQLException {\n        //配置信息\n        String url = \"jdbc:mysql://localhost:3306/jdbc?useUnicode=true\u0026characterEncoding=utf-8\";\n        String username = \"root\";\n        String password = \"123456\";\n\n        //1.加载驱动\n        Class.forName(\"com.mysql.jdbc.Driver\");\n        //2.连接数据库,代表数据库\n        Connection connection = DriverManager.getConnection(url, username, password);\n\n        //3.向数据库发送sql的对象statement：CRUD\n        Statement statement = connection.createStatement();\n\n        //4。编写sql\n        String sql = \"select * from users\";\n\n        //5.执行查询sql，返回一个ResultSet:结果集\n        ResultSet resultSet = statement.executeQuery(sql);\n\n        while (resultSet.next()){\n            System.out.println(\"id=\"+resultSet.getObject(\"id\"));\n            System.out.println(\"name=\"+resultSet.getObject(\"name\"));\n            System.out.println(\"password=\"+resultSet.getObject(\"password\"));\n            System.out.println(\"email=\"+resultSet.getObject(\"email\"));\n            System.out.println(\"birthday=\"+resultSet.getObject(\"birthday\"));\n        }\n\n        //6.关闭连接，释放资源（一定要做），先开后关\n        resultSet.close();\n        statement.close();\n        connection.close();\n\n\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213653-ing1ljb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213653-ing1ljb","updated":"20220618213653"},"Children":[{"Type":"NodeText","Data":"预编译SQL"}]},{"ID":"20220618213654-h6f5gqu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213654-h6f5gqu","updated":"20220618213654"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia;\n\nimport javax.xml.crypto.Data;\nimport java.sql.*;\n\npublic class TestJDBC2 {\n    public static void main(String[] args) throws ClassNotFoundException, SQLException {\n        //配置信息\n        String url = \"jdbc:mysql://localhost:3306/jdbc?useUnicode=true\u0026characterEncoding=utf-8\";\n        String username = \"root\";\n        String password = \"root\";\n\n        //1.加载驱动\n        Class.forName(\"com.mysql.jdbc.Driver\");\n        //2.连接数据库,代表数据库\n        Connection connection = DriverManager.getConnection(url, username, password);\n\n        //3.编写sql\n        String sql = \"insert into users(id,name,password,email,birthday) values (?,?,?,?,?)\";\n\n        //4.预编译\n        PreparedStatement preparedStatement = connection.prepareStatement(sql);\n\n        preparedStatement.setInt(1,5);\n        preparedStatement.setString(2,\"岛田庄司\");\n        preparedStatement.setString(3,\"12345\");\n        preparedStatement.setString(4,\"123@qq.com\");\n        preparedStatement.setDate(5,new Date(new java.util.Date().getTime()));\n\n        //5.执行sql\n        int i = preparedStatement.executeUpdate();\n\n        if(i\u003e0){\n            System.out.println(\"插入成功\");\n        }\n\n        //6.关闭连接，释放资源（一定要做），先开后关\n        preparedStatement.close();\n        connection.close();\n\n\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213655-81z3ndc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213655-81z3ndc","updated":"20220618213655"},"Children":[{"Type":"NodeText","Data":"事物"}]},{"ID":"20220618213656-q752iyx","Type":"NodeParagraph","Properties":{"id":"20220618213656-q752iyx","updated":"20220618213656"},"Children":[{"Type":"NodeText","Data":"要么都成功，要么都失败"}]},{"ID":"20220618213657-qzhklu7","Type":"NodeParagraph","Properties":{"id":"20220618213657-qzhklu7","updated":"20220618213657"},"Children":[{"Type":"NodeText","Data":"ACID原则：保证数据的安全"}]},{"ID":"20220618213658-tstxuxc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213658-tstxuxc","updated":"20220618213658"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.*;\n\npublic class TestJDBC3 {\n\n    @Test\n    public void test(){\n        //配置信息\n        String url = \"jdbc:mysql://localhost:3306/jdbc?useUnicode=true\u0026characterEncoding=utf-8\";\n        String username = \"root\";\n        String password = \"root\";\n\n        Connection connection = null;\n\n        //1.加载驱动\n        try{\n            Class.forName(\"com.mysql.jdbc.Driver\");\n            //2.连接数据库,代表数据库\n            connection = DriverManager.getConnection(url, username, password);\n\n            //3.通知数据库开启业务，false为开启!!!!!!!!!(重要)\n            connection.setAutoCommit(false);\n            String sql = \"update account set money = money - 100 where name = 'A'\";\n            connection.prepareStatement(sql).executeUpdate();\n\n            //4.制造错误\n            //int i = 1/0;\n\n            String sql2 = \"update account set money = money + 100 where name = 'B'\";\n            connection.prepareStatement(sql2).executeUpdate();\n\n            connection.commit();\n            System.out.println(\"success\");\n        } catch (Exception e){\n            try {\n                //如果出现异常，就通知数据库回滚事务\n                connection.rollback();\n            }catch (SQLException e1){\n                e1.printStackTrace();\n            }\n            e.printStackTrace();\n        }finally {\n            try {\n                connection.close();\n            }catch (SQLException e){\n                e.printStackTrace();\n            }\n        }\n\n\n    }\n\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213659-qm2asxo","Type":"NodeParagraph","Properties":{"id":"20220618213659-qm2asxo","updated":"20220618213659"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605160745424"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605160745424-20220618215622-4sdrc29.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213660-a8poda1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213660-a8poda1","updated":"20220618213660"},"Children":[{"Type":"NodeText","Data":"Junit单元测试"}]},{"ID":"20220618213661-hou9249","Type":"NodeParagraph","Properties":{"id":"20220618213661-hou9249","updated":"20220618213661"},"Children":[{"Type":"NodeText","Data":"可以不写main函数直接进行测试"}]},{"ID":"20220618213662-q92ne9k","Type":"NodeParagraph","Properties":{"id":"20220618213662-q92ne9k","updated":"20220618213662"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"依赖"}]},{"ID":"20220618213663-3md57rs","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213663-3md57rs","updated":"20220618213663"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cdependency\u003e\n      \u003cgroupId\u003ejunit\u003c/groupId\u003e\n      \u003cartifactId\u003ejunit\u003c/artifactId\u003e\n      \u003cversion\u003e4.11\u003c/version\u003e\n      \u003cscope\u003etest\u003c/scope\u003e\n    \u003c/dependency\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213664-1b1ryqo","Type":"NodeParagraph","Properties":{"id":"20220618213664-1b1ryqo","updated":"20220618213664"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"简单使用"}]},{"ID":"20220618213665-mexfpiy","Type":"NodeParagraph","Properties":{"id":"20220618213665-mexfpiy","updated":"20220618213665"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220605154452975"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220605154452975-20220618215622-e1lacj7.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213666-ezs9x1d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213666-ezs9x1d","updated":"20220618213666"},"Children":[{"Type":"NodeText","Data":"SMBMS（超市订单管理系统）"}]},{"ID":"20220618213667-tvw3cho","Type":"NodeParagraph","Properties":{"id":"20220618213667-tvw3cho","updated":"20220618213667"},"Children":[{"Type":"NodeText","Data":"狂神JavaWeb P30-结束 项目没看"}]}]}