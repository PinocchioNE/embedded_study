operties":{"id":"20220618213427-xrbq1as","updated":"20220618213427"},"Children":[{"Type":"NodeText","Data":"在java目录下新建properties"}]}]},{"ID":"20220618213428-t1dx6zk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213428-t1dx6zk","updated":"20220618213428"},"Children":[{"ID":"20220618213429-hu8n3av","Type":"NodeParagraph","Properties":{"id":"20220618213429-hu8n3av","updated":"20220618213429"},"Children":[{"Type":"NodeText","Data":"在resources目录下新建properties"}]}]}]},{"ID":"20220618213430-f5kz01b","Type":"NodeParagraph","Properties":{"id":"20220618213430-f5kz01b","updated":"20220618213430"},"Children":[{"Type":"NodeText","Data":"都被打包在了同一个路径下：classes，俗称为classpath"}]},{"ID":"20220618213431-7ui7cis","Type":"NodeParagraph","Properties":{"id":"20220618213431-7ui7cis","updated":"20220618213431"},"Children":[{"Type":"NodeText","Data":"思路：需要一个文件流"}]},{"ID":"20220618213432-tvfx89u","Type":"NodeParagraph","Properties":{"id":"20220618213432-tvfx89u","updated":"20220618213432"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220526150600561"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220526150600561-20220618215622-0z25b70.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213433-4wndvry","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213433-4wndvry","updated":"20220618213433"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class ServletDemo05 extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        InputStream is = this.getServletContext().getResourceAsStream(\"/WEB-INF/classes/db.properties\");\n\n        Properties properties = new Properties();\n        properties.load(is);\n        String user = properties.getProperty(\"username\");\n        String pwd = properties.getProperty(\"password\");\n\n        resp.getWriter().println(user+\":\"+pwd);\n\n    }\n\n    @Override\n    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        doGet(req, resp);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213434-k2ywxbj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213434-k2ywxbj","updated":"20220618213434"},"Children":[{"Type":"NodeText","Data":"HttpServletResponse"}]},{"ID":"20220618213435-9qx7zv5","Type":"NodeParagraph","Properties":{"id":"20220618213435-9qx7zv5","updated":"20220618213435"},"Children":[{"Type":"NodeText","Data":"web服务器接收到客户端的http请求，针对这个请求，分别创建一个代表请求的HttpServletRequest对象，代表响应的一个HttpServletResponse"}]},{"ID":"20220618213436-njl05qm","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213436-njl05qm","updated":"20220618213436"},"Children":[{"ID":"20220618213437-eyou22s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213437-eyou22s","updated":"20220618213437"},"Children":[{"ID":"20220618213438-1bok5yr","Type":"NodeParagraph","Properties":{"id":"20220618213438-1bok5yr","updated":"20220618213438"},"Children":[{"Type":"NodeText","Data":"如果要获取客户端请求过来的参数：找HttpServletRequest"}]}]},{"ID":"20220618213439-ajmwdng","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213439-ajmwdng","updated":"20220618213439"},"Children":[{"ID":"20220618213440-w5nkqod","Type":"NodeParagraph","Properties":{"id":"20220618213440-w5nkqod","updated":"20220618213440"},"Children":[{"Type":"NodeText","Data":"如果要给客户端响应一些信息：找HttpServletResponse"}]}]}]},{"ID":"20220618213441-pgbdrks","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213441-pgbdrks","updated":"20220618213441"},"Children":[{"Type":"NodeText","Data":"1.简单分类"}]},{"ID":"20220618213442-o4pjcri","Type":"NodeParagraph","Properties":{"id":"20220618213442-o4pjcri","updated":"20220618213442"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"负责向浏览器发送数据的方法"}]},{"ID":"20220618213443-2rom7ko","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213443-2rom7ko","updated":"20220618213443"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"ServletOutStream getOutputStream() throws IOException;\nPrintWriter getWriter() throws IOException;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213444-to5795s","Type":"NodeParagraph","Properties":{"id":"20220618213444-to5795s","updated":"20220618213444"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"部分负责向浏览器发送响应头的方法"}]},{"ID":"20220618213445-1jjpj61","Type":"NodeParagraph","Properties":{"id":"20220618213445-1jjpj61","updated":"20220618213445"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220526153328320"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220526153328320-20220618215622-w3b8mq1.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213446-8wa30lr","Type":"NodeParagraph","Properties":{"id":"20220618213446-8wa30lr","updated":"20220618213446"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"部分响应的状态码"}]},{"ID":"20220618213447-fjvary8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213447-fjvary8","updated":"20220618213447"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"int SC_OK = 200;\nint SC_BAD_REQUEST = 400;\nint SC_NOT_FOUND = 404;\nint SC_INTERNAL_SERVER_ERROR = 500;\nint SC_BAD_GATEWAY = 502;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213448-s5f1y8e","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213448-s5f1y8e","updated":"20220618213448"},"Children":[{"Type":"NodeText","Data":"2.下载文件"}]},{"ID":"20220618213449-llwg0hr","Type":"NodeParagraph","Properties":{"id":"20220618213449-llwg0hr","updated":"20220618213449"},"Children":[{"Type":"NodeText","Data":"​\t2.1向浏览器输出消息"}]},{"ID":"20220618213450-wza874x","Type":"NodeParagraph","Properties":{"id":"20220618213450-wza874x","updated":"20220618213450"},"Children":[{"Type":"NodeText","Data":"​\t2.2下载文件"}]},{"ID":"20220618213451-zj1llec","Type":"NodeParagraph","Properties":{"id":"20220618213451-zj1llec","updated":"20220618213451"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.1要获取下载文件的路径"}]},{"ID":"20220618213452-tj9eo2v","Type":"NodeParagraph","Properties":{"id":"20220618213452-tj9eo2v","updated":"20220618213452"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.2下载的文件是什么"}]},{"ID":"20220618213453-i0sn4a9","Type":"NodeParagraph","Properties":{"id":"20220618213453-i0sn4a9","updated":"20220618213453"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.3设置想办法让浏览器能够支持下载我们需要的东西"}]},{"ID":"20220618213454-mm5j6h6","Type":"NodeParagraph","Properties":{"id":"20220618213454-mm5j6h6","updated":"20220618213454"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.4获取下载文件的输入流"}]},{"ID":"20220618213455-k8nxvp3","Type":"NodeParagraph","Properties":{"id":"20220618213455-k8nxvp3","updated":"20220618213455"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.5创建缓冲区"}]},{"ID":"20220618213456-6e4dnj5","Type":"NodeParagraph","Properties":{"id":"20220618213456-6e4dnj5","updated":"20220618213456"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.6获取OutputStream对象"}]},{"ID":"20220618213457-hqsrssj","Type":"NodeParagraph","Properties":{"id":"20220618213457-hqsrssj","updated":"20220618213457"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.7将FileOutputStream流写入到buffer缓冲区"}]},{"ID":"20220618213458-s15hmrm","Type":"NodeParagraph","Properties":{"id":"20220618213458-s15hmrm","updated":"20220618213458"},"Children":[{"Type":"NodeText","Data":"​\t\t2.2.8使用OutputStream将缓冲区中的数据输出到客户端"}]},{"ID":"20220618213459-jf8h6h7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213459-jf8h6h7","updated":"20220618213459"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class FileServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n//    2.2.1要获取下载文件的路径\n        String realPath = \"D:\\\\Maven_Java\\\\JavaMaven\\\\Response\\\\target\\\\classes\\\\1.jpg\";\n        System.out.println(\"下载的文件路径\"+realPath);\n//    2.2.2下载的文件是什么\n        String fileName = realPath.substring(realPath.lastIndexOf(\"\\\\\") + 1);\n//    2.2.3设置想办法让浏览器能够支持(content-disposition)下载我们需要的东西,中文文件名URLEncoder.encode编码，否则有可能乱码\n        resp.setHeader(\"Content-Disposition\",\"attachment;filename=\"+ URLEncoder.encode(fileName,\"UTF-8\"));\n//    2.2.4获取下载文件的输入流\n        FileInputStream in = new FileInputStream(realPath);\n//    2.2.5创建缓冲区\n        int len = 0;\n        byte[] buffer = new byte[1024];\n//    2.2.6获取OutputStream对象\n        ServletOutputStream out = resp.getOutputStream();\n//    2.2.7将FileOutputStream流写入到buffer缓冲区\n        while ((len=in.read(buffer))\u003e0){\n            out.write(buffer,0,len);\n        }\n//    2.2.8使用OutputStream将缓冲区中的数据输出到客户端\n        in.close();\n        out.close();\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213460-pdmi6hd","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213460-pdmi6hd","updated":"20220618213460"},"Children":[{"Type":"NodeText","Data":"3.验证码功能"}]},{"ID":"20220618213461-o1glll1","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213461-o1glll1","updated":"20220618213461"},"Children":[{"ID":"20220618213462-v65v70g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213462-v65v70g","updated":"20220618213462"},"Children":[{"ID":"20220618213463-fejqg43","Type":"NodeParagraph","Properties":{"id":"20220618213463-fejqg43","updated":"20220618213463"},"Children":[{"Type":"NodeText","Data":"前端实现"}]}]},{"ID":"20220618213464-plbi8og","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213464-plbi8og","updated":"20220618213464"},"Children":[{"ID":"20220618213465-64jlo62","Type":"NodeParagraph","Properties":{"id":"20220618213465-64jlo62","updated":"20220618213465"},"Children":[{"Type":"NodeText","Data":"后端实现，需要用到java的图片类，生成一个图片"}]}]}]},{"ID":"20220618213466-ys9node","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213466-ys9node","updated":"20220618213466"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class imageServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        //如何让浏览器5秒自动刷新一次\n        resp.setHeader(\"refresh\",\"3\");\n\n        //在内存中创建一个图片\n        BufferedImage bufferedImage = new BufferedImage(80, 20,BufferedImage.TYPE_3BYTE_BGR);\n        //得到图片\n        Graphics2D g= (Graphics2D) bufferedImage.getGraphics();\n        //设置图片的背景颜色\n        g.setColor(Color.white);\n        g.fillRect(0,0,80,20);\n        //给图片写数据\n        g.setColor(Color.BLUE);\n        g.setFont(new Font(null, Font.BOLD, 20));\n        g.drawString(makeNum(),0,20);\n\n        //告诉浏览器，这个请求用图片的方式打开\n        resp.setContentType(\"image/jpeg\");\n        //网站存在缓存，不让浏览器缓存\n        resp.setDateHeader(\"expires\",-1);\n        resp.setHeader(\"Cache-Control\",\"no-cache\");\n        resp.setHeader(\"Pragma\",\"no-cache\");\n\n        //把图片写给浏览器\n        boolean writer = ImageIO.write(bufferedImage,\"jpg\",resp.getOutputStream());\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213467-x7a6mah","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213467-x7a6mah","updated":"20220618213467"},"Children":[{"Type":"NodeText","Data":"4.实现重定向"}]},{"ID":"20220618213468-54u2slb","Type":"NodeParagraph","Properties":{"id":"20220618213468-54u2slb","updated":"20220618213468"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220526213057928"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220526213057928-20220618215622-64jye2b.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213469-ovyy75k","Type":"NodeParagraph","Properties":{"id":"20220618213469-ovyy75k","updated":"20220618213469"},"Children":[{"Type":"NodeText","Data":"一个web资源收到客户端请求后，他会通知客户端去访问另一个web资源，这个过程是重定向"}]},{"ID":"20220618213470-hmicywf","Type":"NodeParagraph","Properties":{"id":"20220618213470-hmicywf","updated":"20220618213470"},"Children":[{"Type":"NodeText","Data":"常见场景："}]},{"ID":"20220618213471-8z1n5dd","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213471-8z1n5dd","updated":"20220618213471"},"Children":[{"ID":"20220618213472-nkcs0ql","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213472-nkcs0ql","updated":"20220618213472"},"Children":[{"ID":"20220618213473-t6fjwn5","Type":"NodeParagraph","Properties":{"id":"20220618213473-t6fjwn5","updated":"20220618213473"},"Children":[{"Type":"NodeText","Data":"​\t用户登录"}]}]}]},{"ID":"20220618213474-rz2rxpb","Type":"NodeParagraph","Properties":{"id":"20220618213474-rz2rxpb","updated":"20220618213474"},"Children":[{"Type":"NodeText","Data":"测试："}]},{"ID":"20220618213475-vya772g","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213475-vya772g","updated":"20220618213475"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class RedirectServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        /*\n            resp.setHeader(\"Location\",\"/r/img\");\n            resp.setStatus(302);//状态码\n        */\n        resp.sendRedirect(\"/r/img\");//重定向\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213476-ek0hdkr","Type":"NodeParagraph","Properties":{"id":"20220618213476-ek0hdkr","updated":"20220618213476"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"面试题：请你聊聊重定向和转发的区别？"}]},{"ID":"20220618213477-b238f6l","Type":"NodeBlockquote","Properties":{"id":"20220618213477-b238f6l","updated":"20220618213477"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213478-x15qrvm","Type":"NodeParagraph","Properties":{"id":"20220618213478-x15qrvm","updated":"20220618213478"},"Children":[{"Type":"NodeText","Data":"相同点："}]},{"ID":"20220618213479-f39fjlo","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213479-f39fjlo","updated":"20220618213479"},"Children":[{"ID":"20220618213480-0fk5riv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213480-0fk5riv","updated":"20220618213480"},"Children":[{"ID":"20220618213481-x2c2wdz","Type":"NodeParagraph","Properties":{"id":"20220618213481-x2c2wdz","updated":"20220618213481"},"Children":[{"Type":"NodeText","Data":"页面都会实现跳转"}]}]}]},{"ID":"20220618213482-l4g6t9r","Type":"NodeParagraph","Properties":{"id":"20220618213482-l4g6t9r","updated":"20220618213482"},"Children":[{"Type":"NodeText","Data":"不同点"}]},{"ID":"20220618213483-fqsaqo5","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213483-fqsaqo5","updated":"20220618213483"},"Children":[{"ID":"20220618213484-wrcs3xb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213484-wrcs3xb","updated":"20220618213484"},"Children":[{"ID":"20220618213485-uz3t85f","Type":"NodeParagraph","Properties":{"id":"20220618213485-uz3t85f","updated":"20220618213485"},"Children":[{"Type":"NodeText","Data":"请求转发的时候，url不会产生变化"}]}]},{"ID":"20220618213486-nk58cm9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213486-nk58cm9","updated":"20220618213486"},"Children":[{"ID":"20220618213487-9em14tx","Type":"NodeParagraph","Properties":{"id":"20220618213487-9em14tx","updated":"20220618213487"},"Children":[{"Type":"NodeText","Data":"重定向的时候，url地址栏会发生变化"}]}]}]}]},{"ID":"20220618213488-tqdjmcp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213488-tqdjmcp","updated":"20220618213488"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class RequestTest extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        //处理请求\n        String username = req.getParameter(\"username\");\n        String password = req.getParameter(\"password\");\n\n        System.out.println(username+\":\"+password);\n        //重定向的时候一定要注意路径问题,否则404 注意这里的路径指的是war创建下的映射路径\n        resp.sendRedirect(\"/Response_war/success.jsp\");\n    }\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213489-7q8asl0","Type":"NodeParagraph","Properties":{"id":"20220618213489-7q8asl0","updated":"20220618213489"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220527093322721"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220527093322721-20220618215622-kalld87.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213490-0eg1hi8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213490-0eg1hi8","updated":"20220618213490"},"Children":[{"Type":"NodeText","Data":"HttpServletRequest"}]},{"ID":"20220618213491-tdbeuwd","Type":"NodeParagraph","Properties":{"id":"20220618213491-tdbeuwd","updated":"20220618213491"},"Children":[{"Type":"NodeText","Data":"HttpServletRequest代表客户端的请求，用户通过http协议访问服务器，http请求中的阿所有信息会被封装到httpServletRequest，通过这个HttpServletRequest方法，获得客户端的所有信息"}]},{"ID":"20220618213492-liu8q9p","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213492-liu8q9p","updated":"20220618213492"},"Children":[{"Type":"NodeText","Data":"1.获取前端传递的参数，并请求转发"}]},{"ID":"20220618213493-ahlgwak","Type":"NodeParagraph","Properties":{"id":"20220618213493-ahlgwak","updated":"20220618213493"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220527141731649"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220527141731649-20220618215622-b7dwjp3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213494-agcwo3x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213494-agcwo3x","updated":"20220618213494"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class LoginServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n\n        req.setCharacterEncoding(\"utf-8\");\n        resp.setCharacterEncoding(\"utf-8\");\n\n        String username = req.getParameter(\"username\");\n        String password = req.getParameter(\"password\");\n        String[] hobbys = req.getParameterValues(\"hobbys\");\n        System.out.println(\"================================\");\n        //后台接收中文乱码问题在开始输入req.setCharacterEncoding(\"utf-8\");\n        System.out.println(username);\n        System.out.println(password);\n        System.out.println(Arrays.toString(hobbys));\n        System.out.println(\"================================\");\n\n        //通过请求转发\n        req.getRequestDispatcher(\"/success.jsp\").forward(req,resp);\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213495-a9ckr42","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618213495-a9ckr42","updated":"20220618213495"},"Children":[{"Type":"NodeText","Data":"Cookie、Session"}]},{"ID":"20220618213496-qbgdcqt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213496-qbgdcqt","updated":"20220618213496"},"Children":[{"Type":"NodeText","Data":"会话"}]},{"ID":"20220618213497-2sw4yhp","Type":"NodeParagraph","Properties":{"id":"20220618213497-2sw4yhp","updated":"20220618213497"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"会话："},{"Type":"NodeText","Data":"用户打开了一个浏览器，点击了很多超链接，访问多个web资源，关闭浏览器，这个过程可以称之为会话"}]},{"ID":"20220618213498-vjz3c2l","Type":"NodeParagraph","Properties":{"id":"20220618213498-vjz3c2l","updated":"20220618213498"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"有状态会话："},{"Type":"NodeText","Data":"一个同学来过教室，下次再来就会知道这个同学曾经来过，称之为有状态会话"}]},{"ID":"20220618213499-u1y0paf","Type":"NodeParagraph","Properties":{"id":"20220618213499-u1y0paf","updated":"20220618213499"},"Children":[{"Type":"NodeText","Data":"客户端 \t\t\t服务端"}]},{"ID":"20220618213500-csgcz88","Type":"NodeParagraph","Properties":{"id":"20220618213500-csgcz88","updated":"20221012093227"},"Children":[{"Type":"NodeText","Data":"\t1.服务端给客户端一个信件，客户端下次访问服务端带上信件就可以了；cookie"}]},{"ID":"20220618213501-7pp4ey3","Type":"NodeParagraph","Properties":{"id":"20220618213501-7pp4ey3","updated":"20220618213501"},"Children":[{"Type":"NodeText","Data":"​\t2.服务器登记你来过了，下次你来的时候来匹配你；session"}]},{"ID":"20220618213502-f6pd9vr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213502-f6pd9vr","updated":"20220618213502"},"Children":[{"Type":"NodeText","Data":"保存会话的两种技术"}]},{"ID":"20220618213503-xselzgw","Type":"NodeParagraph","Properties":{"id":"20220618213503-xselzgw","updated":"20220618213503"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"cookie——饼干"}]},{"ID":"20220618213504-b76ywls","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213504-b76ywls","updated":"20220618213504"},"Children":[{"ID":"20220618213505-v6yaukl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213505-v6yaukl","updated":"20220618213505"},"Children":[{"ID":"20220618213506-frh4hih","Type":"NodeParagraph","Properties":{"id":"20220618213506-frh4hih","updated":"20220618213506"},"Children":[{"Type":"NodeText","Data":"客户端技术（响应，请求）"}]}]}]},{"ID":"20220618213507-90ens2o","Type":"NodeParagraph","Properties":{"id":"20220618213507-90ens2o","updated":"20220618213507"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"session——会话"}]},{"ID":"20220618213508-h5ijj8n","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213508-h5ijj8n","updated":"20220618213508"},"Children":[{"ID":"20220618213509-nse6z7a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20220618213509-nse6z7a","updated":"20220618213509"},"Children":[{"ID":"20220618213510-ej6u20h","Type":"NodeParagraph","Properties":{"id":"20220618213510-ej6u20h","updated":"20220618213510"},"Children":[{"Type":"NodeText","Data":"服务器技术，利用这个技术，可以保存用户的会话信息？我们可以把信息或者数据放在session中"}]}]}]},{"ID":"20220618213511-3wsh3y4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213511-3wsh3y4","updated":"20220618213511"},"Children":[{"Type":"NodeText","Data":"Cookie"}]},{"ID":"20220618213512-6pknwys","Type":"NodeParagraph","Properties":{"id":"20220618213512-6pknwys","updated":"20220618213512"},"Children":[{"Type":"NodeText","Data":"1.从请求中拿到cookie信息"}]},{"ID":"20220618213513-bdxofd8","Type":"NodeParagraph","Properties":{"id":"20220618213513-bdxofd8","updated":"20220618213513"},"Children":[{"Type":"NodeText","Data":"2.服务器响应给客户端cookie"}]},{"ID":"20220618213514-dv18ql7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213514-dv18ql7","updated":"20220618213514"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"Cookie[] cookies = req.getCookies();//获得cookie\ncookie.getName();//获得cookie中的key\ncookie.getValue();//获得cookie中的value\nCookie cookie = new Cookie(\"lastLoginTime\", System.currentTimeMillis()+\"\");//新建一个cookie\ncookie.setMaxAge(24*60*60);//设置cookie有效期\nresp.addCookie(cookie);//响应给客户端一个cookie\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213515-iox648c","Type":"NodeBlockquote","Properties":{"id":"20220618213515-iox648c","updated":"20220618213515"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213516-qgwp0ch","Type":"NodeParagraph","Properties":{"id":"20220618213516-qgwp0ch","updated":"20220618213516"},"Children":[{"Type":"NodeText","Data":"一般保存在本地的用户目录下Appdate"}]}]},{"ID":"20220618213517-n6vhtsn","Type":"NodeParagraph","Properties":{"id":"20220618213517-n6vhtsn","updated":"20220618213517"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"一个网站cookie是否存在上限？"}]},{"ID":"20220618213518-4gboh49","Type":"NodeList","ListData":{},"Properties":{"id":"20220618213518-4gboh49","updated":"20221012093255"},"Children":[{"ID":"20220618213519-mjzlrti","Type":"NodeListItem",