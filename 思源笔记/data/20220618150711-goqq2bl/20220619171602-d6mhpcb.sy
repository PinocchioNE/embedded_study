":"20220618213368"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213369-6cuzza0","Type":"NodeParagraph","Properties":{"id":"20220618213369-6cuzza0","updated":"20220618213369"},"Children":[{"Type":"NodeText","Data":"1.编写一个普通类"}]},{"ID":"20220618213370-7y20fdi","Type":"NodeParagraph","Properties":{"id":"20220618213370-7y20fdi","updated":"20220618213370"},"Children":[{"Type":"NodeText","Data":"2.实现servlet接口，直接继承HttpServlet"}]}]},{"ID":"20220618213371-5d1uohf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213371-5d1uohf","updated":"20220618213371"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.buhui;\n\nimport javax.servlet.ServletException;\nimport javax.servlet.http.HttpServlet;\nimport javax.servlet.http.HttpServletRequest;\nimport javax.servlet.http.HttpServletResponse;\nimport java.io.IOException;\nimport java.io.PrintWriter;\n\npublic class HelloServlet extends HttpServlet {\n\n    //由于get或者post只是请求实现的不同的方式，可以相互调用，业务逻辑一样\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        PrintWriter writer = resp.getWriter(); //响应流\n        writer.println(\"Hello,Servlet\");\n    }\n\n    @Override\n    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        doGet(req, resp);\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213372-9bbvo56","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213372-9bbvo56","updated":"20220618213372"},"Children":[{"Type":"NodeText","Data":"5.编写servlet的映射"}]},{"ID":"20220618213373-c6s1t8m","Type":"NodeBlockquote","Properties":{"id":"20220618213373-c6s1t8m","updated":"20220618213373"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213374-flky9v5","Type":"NodeParagraph","Properties":{"id":"20220618213374-flky9v5","updated":"20220618213374"},"Children":[{"Type":"NodeText","Data":"为什么需要映射？"}]},{"ID":"20220618213375-r0lazqm","Type":"NodeParagraph","Properties":{"id":"20220618213375-r0lazqm","updated":"20220618213375"},"Children":[{"Type":"NodeText","Data":"我们写的是java程序，但是要通过浏览器访问，而浏览器需要连接web服务器，所以我们需要在web服务中注册我们写的servlet，还需要给她一个浏览器能够访问的路径"}]}]},{"ID":"20220618213376-tj9ajez","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213376-tj9ajez","updated":"20220618213376"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003c!--注册servlet--\u003e\n    \u003cservlet\u003e\n        \u003cservlet-name\u003ehello\u003c/servlet-name\u003e  \n        \u003cservlet-class\u003ecom.Xia.buhui.HelloServlet\u003c/servlet-class\u003e\n    \u003c/servlet\u003e\n    \u003c!--servlet的请求路径--\u003e\n    \u003cservlet-mapping\u003e\n        \u003cservlet-name\u003ehello\u003c/servlet-name\u003e\n        \u003curl-pattern\u003e/hello\u003c/url-pattern\u003e\n    \u003c/servlet-mapping\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213377-zgh3ei3","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213377-zgh3ei3","updated":"20220618213377"},"Children":[{"Type":"NodeText","Data":"整体流程"}]},{"ID":"20220618213378-khvhz8t","Type":"NodeParagraph","Properties":{"id":"20220618213378-khvhz8t","updated":"20220618213378"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image-20220525164327617"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220525164327617-20220618215622-p9mb1wa.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220618213379-8kuv7qx","Type":"NodeParagraph","Properties":{"id":"20220618213379-8