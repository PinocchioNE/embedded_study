ata":"3.一个Servlet可以指定公用映射路径"}]},{"ID":"20220618213406-tqx49rk","Type":"NodeParagraph","Properties":{"id":"20220618213406-tqx49rk","updated":"20220618213406"},"Children":[{"Type":"NodeText","Data":"4.指定一些后缀或前缀"}]},{"ID":"20220618213407-27jizs3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618213407-27jizs3","updated":"20220618213407"},"Children":[{"Type":"NodeText","Data":"ServletContext"}]},{"ID":"20220618213408-ooyo11y","Type":"NodeParagraph","Properties":{"id":"20220618213408-ooyo11y","updated":"20220618213408"},"Children":[{"Type":"NodeText","Data":"web容器在启动时会为每个web程序都创建一个对应的ServletContext对象它他代表了当前的web应用"}]},{"ID":"20220618213409-e6juxge","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213409-e6juxge","updated":"20220618213409"},"Children":[{"Type":"NodeText","Data":"1.共享数据"}]},{"ID":"20220618213410-rj4k1wm","Type":"NodeParagraph","Properties":{"id":"20220618213410-rj4k1wm","updated":"20220618213410"},"Children":[{"Type":"NodeText","Data":"在这个servlet中保存的数据，可以在另外一个servlet中取到"}]},{"ID":"20220618213411-zc5x1wg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213411-zc5x1wg","updated":"20220618213411"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class GetServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        ServletContext servletContext = this.getServletContext();\n        String username = (String) servletContext.getAttribute(\"username\");\n\n        resp.setContentType(\"text/html\");\n        resp.setCharacterEncoding(\"utf-8\");\n        resp.getWriter().print(\"名字\"+username);\n    }\n\n    @Override\n    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        doGet(req, resp);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213412-f8zxlss","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213412-f8zxlss","updated":"20220618213412"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003cservlet\u003e\n    \u003cservlet-name\u003ehello\u003c/servlet-name\u003e\n    \u003cservlet-class\u003ecom.Xth.Hello\u003c/servlet-class\u003e\n\u003c/servlet\u003e\n\u003c!--servlet的请求路径--\u003e\n\u003cservlet-mapping\u003e\n    \u003cservlet-name\u003ehello\u003c/servlet-name\u003e\n    \u003curl-pattern\u003e/hello\u003c/url-pattern\u003e\n\u003c/servlet-mapping\u003e\n\n\u003cservlet\u003e\n    \u003cservlet-name\u003eget\u003c/servlet-name\u003e\n    \u003cservlet-class\u003ecom.Xth.GetServlet\u003c/servlet-class\u003e\n\u003c/servlet\u003e\n\u003c!--servlet的请求路径--\u003e\n\u003cservlet-mapping\u003e\n    \u003cservlet-name\u003eget\u003c/servlet-name\u003e\n    \u003curl-pattern\u003e/get\u003c/url-pattern\u003e\n\u003c/servlet-mapping\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213413-2cxlak7","Type":"NodeBlockquote","Properties":{"id":"20220618213413-2cxlak7","updated":"20220618213413"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213414-gh5su2h","Type":"NodeParagraph","Properties":{"id":"20220618213414-gh5su2h","updated":"20220618213414"},"Children":[{"Type":"NodeText","Data":"测试访问结果"}]}]},{"ID":"20220618213415-7wtm0xn","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213415-7wtm0xn","updated":"20220618213415"},"Children":[{"Type":"NodeText","Data":"2.获取初始化参数"}]},{"ID":"20220618213416-0h1gxd0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213416-0h1gxd0","updated":"20220618213416"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":" \u003c!--配置一些web应用初始化参数--\u003e\n        \u003ccontext-param\u003e\n            \u003cparam-name\u003eurl\u003c/param-name\u003e\n            \u003cparam-value\u003ejdbc:mysql://localhost:3306/mybatis\u003c/param-value\u003e\n        \u003c/context-param\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213417-lpfwwm1","Type":"NodeBlockquote","Properties":{"id":"20220618213417-lpfwwm1","updated":"20220618213417"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220618213418-9j6njhz","Type":"NodeParagraph","Properties":{"id":"20220618213418-9j6njhz","updated":"20220618213418"},"Children":[{"Type":"NodeText","Data":"使用"}]}]},{"ID":"20220618213419-00bt0s4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213419-00bt0s4","updated":"20220618213419"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        ServletContext servletContext = this.getServletContext();\n        String url = servletContext.getInitParameter(\"url\");\n        resp.getWriter().println(url);\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618213420-iud6uea","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618213420-iud6uea","updated":"20220618213420"},"Children":[{"Type":"NodeText","Data":"3.请求转发"}]},{"ID":"20220618213421-qmn3uvl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220618213421-qmn3uvl","updated":"20220618213421"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"protected void doGet(HttpServletRequest req, HttpServletResponse resp) th