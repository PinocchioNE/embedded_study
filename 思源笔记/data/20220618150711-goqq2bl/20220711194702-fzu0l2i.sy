ia.Spboot.service.StudentService;\nimport org.springframework.stereotype.Controller;\nimport org.springframework.ui.Model;\nimport org.springframework.web.bind.annotation.RequestBody;\nimport org.springframework.web.bind.annotation.RequestMapping;\nimport org.springframework.web.bind.annotation.ResponseBody;\n\nimport javax.annotation.Resource;\nimport java.util.List;\n\n@Controller\n@ResponseBody\npublic class StudentControl {\n    @Resource\n    private StudentService studentService;\n\n    //查询全部\n    @RequestMapping(\"/app\")\n    public String a(){\n        List\u003cStudent\u003e studentList = studentService.findById(1);\n        return studentList.toString();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827213248-01rcz5w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220827213248-01rcz5w","updated":"20220827213340"},"Children":[{"Type":"NodeText","Data":"6.启动类"}]},{"ID":"20220827213342-ib0d65u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220827213342-ib0d65u","updated":"20220827213353"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.Spboot;\n\nimport org.mybatis.spring.annotation.MapperScan;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\nimport org.springframework.web.bind.annotation.RequestMapping;\n\n@SpringBootApplication\n@MapperScan(value = \"com/Xia/Spboot/mapper\")\npublic class SpringBootStudyApplication {\n\n    public static void main(String[] args) {\n        SpringApplication.run(SpringBootStudyApplication.class, args);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827213407-8tzbbim","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220827213407-8tzbbim","updated":"20220827213409"},"Children":[{"Type":"NodeText","Data