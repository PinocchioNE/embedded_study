gLevel":3,"Properties":{"id":"20220727133639-w8o9ryx","updated":"20220727133646"},"Children":[{"Type":"NodeText","Data":"哈希hash操作命令"}]},{"ID":"20220727150938-zm8qqvz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727150938-zm8qqvz","updated":"20220727151000"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"HSET key field value\t\t#将哈希表key中的字段field的值设为value\nHGET key field\t\t\t#获取存储在哈希表中指定字段的值\nHDEL key field\t\t\t#删除存储在哈希表中的指定字段\nHKEYS key\t\t\t#获取哈希表中所有字段\nHVALS key\t\t\t#获取哈希表中所有值\nHGETALL key\t\t\t#获取在哈希表中指定key的所有字段和值\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727151135-794e1cf","Type":"NodeParagraph","Properties":{"id":"20220727151135-794e1cf","updated":"20220727151139"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220727151136-6c228pf.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: parent-style=\"display: block;\"}"}]},{"ID":"20220727133647-fkba350","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727133647-fkba350","updated":"20220727133652"},"Children":[{"Type":"NodeText","Data":"列表list操作命令"}]},{"ID":"20220727151419-grhm44l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727151419-grhm44l","updated":"20220727151457"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"LPUSH key value1 [value2]\t\t#将一个或多个值插入到列表头部\nLRANGE key start stop\t\t\t#获取列表指定范围内的元素\nRPOP key\t\t\t\t#移除并获取列表最后一个元素\nLLEN key\t\t\t\t#获取列表长度\nBRPOP key1 [key2 ] timeout\t\t#移出并获取列表的最后一个元素，如果列表没有元素会阻塞列表直到等待超时或发现可弹出元素为止\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727151547-3boky1z","Type":"NodeParagraph","Properties":{"id":"20220727151547-3boky1z","updated":"20220727151551"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220727151548-r2nvnn3.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: parent-style=\"display: block;\"}"}]},{"ID":"20220727133653-lebz6l3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727133653-lebz6l3","updated":"20220727133659"},"Children":[{"Type":"NodeText","Data":"集合set操作命令"}]},{"ID":"20220727152451-frjdld9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727152451-frjdld9","updated":"20220727155554"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"SADD key member1 [member2]\t\t\t#向集合添加一个或多个成员\nSMEMBERS key\t\t\t\t\t#返回集合中的所有成员\nSCARD key\t\t\t\t\t#获取集合的成员数\nSINTER key1 [key2]\t\t\t\t#返回给定所有集合的交集\nsuNION key1 [key2]\t\t\t\t#返回所有给定集合的并集\nSDIFF key1 [key2]\t\t\t\t#返回给定所有集合的差集，从前者集合减后者集合中没有的元素[1,2,3] -[3,4,5] = [1,2]\nSREM key member1 [member2]\t\t\t#移除集合中一个或多个成员\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727152556-tm884fp","Type":"NodeParagraph","Properties":{"id":"20220727152556-tm884fp","updated":"20220727152559"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220727152557-5zl6aj1.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: parent-style=\"display: block;\"}"}]},{"ID":"20220727133700-p1ldqns","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220727133700-p1ldqns","updated":"20220727133710"},"Children":[{"Type":"NodeText","Data":"有序集合sorted set操作命令"}]},{"ID":"20220727160221-j6jamvk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220727160221-j6jamvk","updated":"20220727160242"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"ZADD key score1 member1 [score2 member2]\t\t#向有序集合添加一个或多个成员，或者更新已存在成员的分数\nZRANGE key start stop [WITHSCORES]\t\t\t#通过索引区间返回有序集合中指定区间内的成员\nZINCRBY key increment member\t\t\t\t#有序集合中对指定成员的分数加上增量increment\nZREM key member [member ..]\t\t\t\t#移除有序集合中的一个或多个成员\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220727160249-7fpa2zr","Type":"NodeParagraph","Properties":{"id":"20220727160249-7fpa2zr","updated":"20220727160251"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220727160250-h8cbyf0.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: parent-style=\"display: block;\"}"}]},{"ID":"20220802150448-21fjuf2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220802150448-21fjuf2","updated":"20220802150508"},"Children":[{"Type":"NodeText","Data":"通用命令"}]},{"ID":"20220802150510-kftqexn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220802150510-kftqexn","updated":"20220802150643"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cG93ZXJzaGVsbA=="},{"Type":"NodeCodeBlockCode","Data":"KEYS pattern\t\t\t#查找所有符合给定模式( pattern)的key\nEXISTs key\t\t\t#检查给定key是否存在\nTYPE key\t\t\t#返回key所储存的值的类型\nTTL key\t\t\t\t#返回给定key 的剩余生存时间(TTL, time to live)，以秒为单位\nDEL key\t\t\t\t#该命令用于在 key存在是删除key\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220802152314-gjbmpo5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220802152314-gjbmpo5","updated":"20220802152339"},"Children":[{"Type":"NodeText","Data":"Spring Data Redis"}]},{"ID":"20220802152339-1a9x624","Type":"NodeBlockquote","Properties":{"id":"20220802152339-1a9x624","updated":"20220802152402"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220802152340-1yqszqa","Type":"NodeParagraph","Properties":{"id":"20220802152340-1yqszqa","updated":"20220802152356"},"Children":[{"Type":"NodeText","Data":"在Spring Boot项目中，可以使用Spring Data Redis来简化Redis操作"}]}]},{"ID":"20220802152402-2jsijtl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220802152402-2jsijtl","updated":"20220802152418"},"Children":[{"Type":"NodeText","Data":"Spring Data Redis 的 maven"}]},{"ID":"20220802152421-oi6uaym","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220802152421-oi6uaym","updated":"20220802165637"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003cdependency\u003e\n    \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n    \u003cartifactId\u003espring-boot-starter-data-redis\u003c/artifactId\u003e\n    \u003cversion\u003e2.5.5\u003c/version\u003e\n\u003c/dependency\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220802152958-ep79tvo","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220802152958-ep79tvo","updated":"20220802153111"},"Children":[{"Type":"NodeText","Data":"RedisTemplate类"}]},{"ID":"20220802152845-4wdt8fe","Type":"NodeBlockquote","Properties":{"id":"20220802152845-4wdt8fe","updated":"20220802152958"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220802152846-g47e0yn","Type":"NodeParagraph","Properties":{"id":"20220802152846-g47e0yn","updated":"20220802152851"},"Children":[{"Type":"NodeText","Data":"Spring Data Redis中提供了一个高度封装的类: RedisTemplate，针对jedis客户端中大量api进行了归类封装,将同一类型操作封装为operation接口，具体分类如下："}]}]},{"ID":"20220802152851-5drpzrb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220802152851-5drpzrb","updated":"20220802152940"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"ValueOperations:\t简单K-V操作\nSetOperations: \t\tset类型数据操作\nzSetOperations: \tzset类型数据操作\nHashOperations:\t\t针对map类型的数据操作\nListOperations:\t\t针对list类型的数据操作\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220802153752-b5r0qs9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220802153752-b5r0qs9","updated":"20220802153756"},"Children":[{"Type":"NodeText","Data":"yaml配置"}]},{"ID":"20220802153758-4ni5p75","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220802153758-4ni5p75","updated":"20220802154714"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"spring:\n    application:\n        name: helloworld\n    #Redis相关配置\n    reids:\n        host: localhost\n        port: 6379\n        #password\n        database: 0  # 操作的是0号数据库，默认第一个数据库为0号和数组一样\n        jedis:\n            #Redis连接池配置\n            pool:\n                max-active: 8 #最大连接数\n                max-wait: 1ms\n                max-idle: 4 #连接池中的最大空闲连接\n                min-idle: 0 #连接池中的最小空闲连接\n\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220803220739-n1ldsal","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803220739-n1ldsal","updated":"20220803220751"},"Children":[{"Type":"NodeText","Data":"自定义序列化配置文件"}]},{"ID":"20220803220800-bbgyruu","Type":"NodeParagraph","Properties":{"id":"20220803220800-bbgyruu","updated":"20220803220813"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220803220813-m6pcyx9.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220803220754-k7n6llj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220803220754-k7n6llj","updated":"20220803220947"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"import org.springframework.cache.annotation.CachingConfigurerSupport;\nimport org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.data.redis.connection.RedisConnectionFactory;\nimport org.springframework.data.redis.core.RedisTemplate;\nimport org.springframework.data.redis.serializer.StringRedisSerializer;\n\n@Configuration\npublic class RedisConfig extends CachingConfigurerSupport {\n    @Bean\n    public RedisTemplate\u003cObject,Object\u003e redisTemplate(RedisConnectionFactory connectionFactory){\n        RedisTemplate\u003cObject, Object\u003e redisTemplate = new RedisTemplate\u003c\u003e();\n        //默认的Key序列化器为：JdkSerializationRedisSerializer\n        redisTemplate.setKeySerializer(new StringRedisSerializer());\n        redisTemplate.setConnectionFactory(connectionFactory);\n        return redisTemplate;\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220803154424-u5ich9x","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803154424-u5ich9x","updated":"20220803154446"},"Children":[{"Type":"NodeText","Data":"单元测试"}]},{"ID":"20220803154427-wmm5ae4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220803154427-wmm5ae4","updated":"20220803154442"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"@SpringBootTest\n@RunWith(SpringRunner.class)\npublic class HelloworldApplicationTests {\n\n    @Autowired\n    private RedisTemplate redisTemplate;\n\n    @Test\n    public void testingString(){\n        redisTemplate.opsForValue().set(\"city123\",\"beijing\");\n\n        String city123 = (String) redisTemplate.opsForValue().get(\"city123\");\n        System.out.println(city123);\n\n        redisTemplate.opsForValue().set(\"1333\",\"3111\",10l, TimeUnit.SECONDS);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718101540-1a7eqx9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718101540-1a7eqx9","updated":"20220727084030"},"Children":[{"Type":"NodeText","Data":"应用场景"}]},{"ID":"20220727084032-uzrsniv","Type":"NodeBlockquote","Properties":{"id":"20220727084032-uzrsniv","updated":"20220727084047"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220727084033-0fmc5e9","Type":"NodeParagraph","Properties":{"id":"20220727084033-0fmc5e9","updated":"20220727084036"},"Children":[{"Type":"NodeText","Data":"缓存"}]},{"ID":"20220727084036-ohlah27","Type":"NodeParagraph","Properties":{"id":"20220727084036-ohlah27","updated":"20220727084040"},"Children":[{"Type":"NodeText","Data":"任务队列"}]},{"ID":"20220727084040-qrfrix4","Type":"NodeParagraph","Properties":{"id":"20220727084040-qrfrix4","updated":"20220727084043"},"Children":[{"Type":"NodeText","Data":"消息队列"}]},{"ID":"20220727084043-ak3bhob","Type":"NodeParagraph","Properties":{"id":"20220727084043-ak3bhob","updated":"20220727084047"},"Children":[{"Type":"NodeText","Data":"分布式锁"}]}]},{"ID":"20220727084257-3qbz432","Type":"NodeHeading","HeadingLevel":