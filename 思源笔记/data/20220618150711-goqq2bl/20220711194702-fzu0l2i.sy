                 :collapse-transition=\"false\"\n                 :collapse=\"isCollapse\"\n        \u003e\n          \u003cdiv style=\"height: 60px; line-height: 60px; text-align: center\"\u003e\n            \u003cimg src=\"../assets/1.png\" alt=\"\" style=\"width: 50px; position: relative; top: 10px; margin-right: 5px \"\u003e\n            \u003cb style=\"color: white\" v-show=\"logoTextShow\"\u003e后台管理系统\u003c/b\u003e\n          \u003c/div\u003e\n          \u003cel-submenu index=\"1\"\u003e\n            \u003ctemplate slot=\"title\"\u003e\u003ci class=\"el-icon-message\"\u003e\u003c/i\u003e\n              \u003cspan slot=\"title\"\u003e导航一\u003c/span\u003e\n            \u003c/template\u003e\n            \u003cel-menu-item-group\u003e\n              \u003ctemplate slot=\"title\"\u003e分组一\u003c/template\u003e\n              \u003cel-menu-item index=\"1-1\"\u003e选项1\u003c/el-menu-item\u003e\n              \u003cel-menu-item index=\"1-2\"\u003e选项2\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-menu-item-group title=\"分组2\"\u003e\n              \u003cel-menu-item index=\"1-3\"\u003e选项3\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-submenu index=\"1-4\"\u003e\n              \u003ctemplate slot=\"title\"\u003e选项4\u003c/template\u003e\n              \u003cel-menu-item index=\"1-4-1\"\u003e选项4-1\u003c/el-menu-item\u003e\n            \u003c/el-submenu\u003e\n          \u003c/el-submenu\u003e\n          \u003cel-submenu index=\"2\"\u003e\n            \u003ctemplate slot=\"title\"\u003e\u003ci class=\"el-icon-menu\"\u003e\u003c/i\u003e\n              \u003cspan slot=\"title\"\u003e导航二\u003c/span\u003e\n\n            \u003c/template\u003e\n            \u003cel-menu-item-group\u003e\n              \u003ctemplate slot=\"title\"\u003e分组一\u003c/template\u003e\n              \u003cel-menu-item index=\"2-1\"\u003e选项1\u003c/el-menu-item\u003e\n              \u003cel-menu-item index=\"2-2\"\u003e选项2\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-menu-item-group title=\"分组2\"\u003e\n              \u003cel-menu-item index=\"2-3\"\u003e选项3\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-submenu index=\"2-4\"\u003e\n              \u003ctemplate slot=\"title\"\u003e选项4\u003c/template\u003e\n              \u003cel-menu-item index=\"2-4-1\"\u003e选项4-1\u003c/el-menu-item\u003e\n            \u003c/el-submenu\u003e\n          \u003c/el-submenu\u003e\n          \u003cel-submenu index=\"3\"\u003e\n            \u003ctemplate slot=\"title\"\u003e\u003ci class=\"el-icon-setting\"\u003e\u003c/i\u003e\n              \u003cspan slot=\"title\"\u003e导航三\u003c/span\u003e\n\n            \u003c/template\u003e\n            \u003cel-menu-item-group\u003e\n              \u003ctemplate slot=\"title\"\u003e分组一\u003c/template\u003e\n              \u003cel-menu-item index=\"3-1\"\u003e选项1\u003c/el-menu-item\u003e\n              \u003cel-menu-item index=\"3-2\"\u003e选项2\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-menu-item-group title=\"分组2\"\u003e\n              \u003cel-menu-item index=\"3-3\"\u003e选项3\u003c/el-menu-item\u003e\n            \u003c/el-menu-item-group\u003e\n            \u003cel-submenu index=\"3-4\"\u003e\n              \u003ctemplate slot=\"title\"\u003e选项4\u003c/template\u003e\n              \u003cel-menu-item index=\"3-4-1\"\u003e选项4-1\u003c/el-menu-item\u003e\n            \u003c/el-submenu\u003e\n          \u003c/el-submenu\u003e\n        \u003c/el-menu\u003e\n      \u003c/el-aside\u003e\n\n      \u003cel-container\u003e\n        \u003cel-header style=\"font-size: 12px; border-bottom: 1px solid #ccc; line-height: 60px; display: flex\"\u003e\n          \u003cdiv style=\"flex: 1; font-size: 18px\"\u003e\n            \u003cspan :class=\"collapseBtnClass\" style=\"cursor: pointer\" @click=\"collapse\"\u003e\u003c/span\u003e\n          \u003c/div\u003e\n          \u003cel-dropdown style=\"width: 70px; cursor: pointer\"\u003e\n            \u003cspan\u003e王小虎\u003c/span\u003e\u003ci class=\"el-icon-arrow-down\" style=\"margin-left: 5px\"\u003e\u003c/i\u003e\n            \u003cel-dropdown-menu slot=\"dropdown\"\u003e\n              \u003cel-dropdown-item\u003e个人信息\u003c/el-dropdown-item\u003e\n              \u003cel-dropdown-item\u003e退出\u003c/el-dropdown-item\u003e\n            \u003c/el-dropdown-menu\u003e\n          \u003c/el-dropdown\u003e\n\n        \u003c/el-header\u003e\n\n        \u003cel-main\u003e\n          \u003cel-breadcrumb separator=\"/\"\u003e\n            \u003cel-breadcrumb-item :to=\"{ path: '/' }\"\u003e首页\u003c/el-breadcrumb-item\u003e\n            \u003cel-breadcrumb-item\u003e\u003ca href=\"/\"\u003e用户管理\u003c/a\u003e\u003c/el-breadcrumb-item\u003e\n\n          \u003c/el-breadcrumb\u003e\n\n          \u003cdiv style=\"padding: 10px 0\"\u003e\n            \u003cel-input style=\"width: 200px\" placeholder=\"请输入名称搜索\" suffix-icon=\"el-icon-search\" v-model=\"username\"\u003e\u003c/el-input\u003e\n            \u003cel-input style=\"width: 200px\" placeholder=\"请输入地址搜索\" suffix-icon=\"el-icon-search\" v-model=\"address\"\u003e\u003c/el-input\u003e\n            \u003cel-button class=\"ml-5\" type=\"primary\" @click=\"load\"\u003e搜索\u003c/el-button\u003e\n\n          \u003c/div\u003e\n\n          \u003cdiv style=\"margin: 10px 0\"\u003e\n            \u003cel-button type=\"primary\"\u003e新增\u003ci class=\"el-icon-circle-plus-outline\"\u003e\u003c/i\u003e \u003c/el-button\u003e\n            \u003cel-button type=\"danger\"\u003e批量删除\u003ci class=\"el-icon-remove-outline\"\u003e\u003c/i\u003e \u003c/el-button\u003e\n            \u003cel-button type=\"primary\"\u003e导入\u003ci class=\"el-icon-bottom\"\u003e\u003c/i\u003e \u003c/el-button\u003e\n            \u003cel-button type=\"primary\"\u003e导出\u003ci class=\"el-icon-top\"\u003e\u003c/i\u003e \u003c/el-button\u003e\n          \u003c/div\u003e\n\n          \u003cel-table :data=\"tableData\" border stripe\u003e\n            \u003cel-table-column prop=\"id\" label=\"编号\" width=\"140\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column prop=\"username\" label=\"用户名\" width=\"140\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column prop=\"nickname\" label=\"昵称\" width=\"140\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column prop=\"email\" label=\"邮箱\" width=\"140\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column prop=\"phone\" label=\"电话\" width=\"120\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column prop=\"address\" label=\"地址\" width=\"140\"\u003e\n            \u003c/el-table-column\u003e\n            \u003cel-table-column label=\"操作\"\u003e\n              \u003ctemplate slot-scope=\"scope\"\u003e\n                \u003cel-button type=\"success\"\u003e编辑 \u003ci class=\"el-icon-edit\"\u003e\u003c/i\u003e \u003c/el-button\u003e\n                \u003cel-button type=\"danger\"\u003e删除\u003ci class=\"el-icon-remove-outline\"\u003e\u003c/i\u003e\u003c/el-button\u003e\n              \u003c/template\u003e\n            \u003c/el-table-column\u003e\n          \u003c/el-table\u003e\n          \u003cdiv style=\"padding: 10px 0\"\u003e\n            \u003cel-pagination\n                @size-change=\"handleSizeChange\"\n                @current-change=\"handleCurrentChange\"\n                :page-page=\"pageNum\"\n                :page-sizes=\"[2, 5, 10, 15]\"\n                :page-size=\"pageSize\"\n                layout=\"total, sizes, prev, pager, next, jumper\"\n                :total=\"total\"\u003e\n            \u003c/el-pagination\u003e\n          \u003c/div\u003e\n        \u003c/el-main\u003e\n      \u003c/el-container\u003e\n    \u003c/el-container\u003e\n  \u003c/div\u003e\n\u003c/template\u003e\n\n\u003cscript\u003e\n\n\nexport default {\n  name: 'HomeView',\n\n  data(){\n\n    return{\n      tableData:[],\n      total: 0,\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      msg:\"hello,三米粥铺\",\n      collapseBtnClass: 'el-icon-s-fold',\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true\n    }\n  },\n  created(){\n    //请求分页查询\n    this.load()\n  },\n\n  methods:{\n    collapse(){ // 点击收缩按钮出发\n      this.isCollapse = !this.isCollapse\n      if(this.isCollapse){\n        // !this.isCollapse\n        this.sideWidth = 64\n        this.collapseBtnClass = 'el-icon-s-unfold'\n\n      }else {\n        this.sideWidth = 200\n        this.collapseBtnClass = 'el-icon-s-fold'\n      }\n    },\n    load(){\n      fetch(\"http://localhost:8081/limit?pageNum=\"+this.pageNum+\"\u0026pageSize=\"+this.pageSize+\"\u0026userName=\"+this.username+\"\u0026address=\"+this.address).then(res =\u003e res.json()).then(res =\u003e {\n        console.log(res)\n\n        this.tableData = res.userData\n        this.total = res.countNum\n\n\n      })\n    },\n    handleSizeChange(pageSize){\n      console.log(pageSize)\n      this.pageSize = pageSize\n      this.load()\n    },\n    handleCurrentChange(pageNum){\n      console.log(pageNum)\n      this.pageNum = pageNum\n      this.load()\n    }\n  }\n}\n\u003c/script\u003e\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018213816-ijlvg5w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018213816-ijlvg5w","updated":"20221018213953"},"Children":[{"Type":"NodeText","Data":"配置文件（application.yml）"}]},{"ID":"20221018204608-ambppqk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018204608-ambppqk","updated":"20221018213503"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"server:\n  port: 8081\nspring:\n  mvc:\n    view:\n      prefix: classpath:/templates/\n      suffix: .html\n  thymeleaf:\n    mode: HTML\n    encoding: utf-8\n    cache: false\n  datasource:\n    driver-class-name: com.mysql.cj.jdbc.Driver\n    url: jdbc:mysql://localhost:3306/springboot?serverTimezone=Asia/Shanghai\u0026useUnicode=true\u0026characterEncoding=utf-8\u0026zeroDateTimeBehavior=convertToNull\u0026useSSL=false\u0026allowPublicKeyRetrieval=true\n    username: root\n    password: root\n  devtools:\n    restart:\n      enabled: true\n  freemarker:\n    cache: false\nmybatis:\n  configuration:\n    map-underscore-to-camel-case: true # 开启驼峰命名\n    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl # 输出sql语句\n  mapper-locations: classpath:mapper/*.xml  # xml配置路径\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018213431-43yv0wd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018213431-43yv0wd","updated":"20221018214040"},"Children":[{"Type":"NodeText","Data":"实体类"}]},{"ID":"20221018214042-ml1stz5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214042-ml1stz5","updated":"20221018214050"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot.entity;\n\nimport lombok.AllArgsConstructor;\nimport lombok.Data;\nimport lombok.NoArgsConstructor;\n\n@Data\n@NoArgsConstructor  // 生成无参构造\n@AllArgsConstructor // 生成有参构造\npublic class User {\n    private Integer id;\n    private String username;\n    private String password;\n    private String nickname;\n    private String email;\n    private String phone;\n    private String address;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214051-4gl7xmt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214051-4gl7xmt","updated":"20221018214055"},"Children":[{"Type":"NodeText","Data":"mapper层"}]},{"ID":"20221018214123-tcmqgak","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214123-tcmqgak","updated":"20221020200713"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot.mapper;\n\nimport com.xia.springboot.entity.User;\nimport org.apache.ibatis.annotations.Mapper;\n\nimport java.util.List;\n\n@Mapper\npublic interface UserMapper {\n\n    List\u003cUser\u003e findAll();\n\n    int add(User user);\n\n    int deleteUser(Integer id);\n\n    void updateUser(User user);\n\n    List\u003cUser\u003e searchByPage(Integer pageNum, Integer pageSize, String userName,String address);\n\n    int count();\n\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214126-ilkl6hz","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214126-ilkl6hz","updated":"20221018214137"},"Children":[{"Type":"NodeText","Data":"service层"}]},{"ID":"20221018214139-j3m8lhl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221018214139-j3m8lhl","updated":"20221018214144"},"Children":[{"Type":"NodeText","Data":"service接口"}]},{"ID":"20221018214202-xrdsxet","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214202-xrdsxet","updated":"20221020200723"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot.service;\n\nimport com.xia.springboot.entity.User;\nimport java.util.List;\n\npublic interface UserService {\n    List\u003cUser\u003e findAll();\n\n    int add(User user);\n\n    int deleteUser(Integer id);\n\n    void updateUser(User user);\n\n    List\u003cUser\u003e searchByPage(Integer pageNum, Integer pageSize, String userName,String address);\n\n    int count();\n\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214205-i4ghb5o","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221018214205-i4ghb5o","updated":"20221018214209"},"Children":[{"Type":"NodeText","Data":"service实现"}]},{"ID":"20221018214221-0itdm7b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214221-0itdm7b","updated":"20221020201152"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot.service.impl;\n\nimport com.xia.springboot.entity.User;\nimport com.xia.springboot.mapper.UserMapper;\nimport com.xia.springboot.service.UserService;\nimport org.springframework.beans.factory.annotation.Autowired;\nimport org.springframework.stereotype.Service;\n\nimport java.util.HashMap;\nimport java.util.List;\n\n@Service\npublic class UserServiceImpl implements UserService {\n\n    @Autowired\n    private UserMapper userMapper;\n\n    @Override // 计算行数\n    public int count() {\n        return userMapper.count();\n    }\n\n\n    @Override // 查所有\n    public List\u003cUser\u003e findAll() {\n        return userMapper.findAll();\n    }\n\n    @Override // 添加用户\n    public int add(User user) {\n        return userMapper.add(user);\n    }\n\n    @Override // 删除用户\n    public int deleteUser(Integer id) {\n        return userMapper.deleteUser(id);\n    }\n\n    @Override // 更新用户\n    public void updateUser(User user) {\n        userMapper.updateUser(user);\n    }\n\n    @Override // 分页查询 参数含义分别为：起始页，每页数量，用户名（用于模糊查询），地址（用于模糊查询）\n    public List\u003cUser\u003e searchByPage(Integer pageNum, Integer pageSize,String userName,String address) {\n        pageNum = (pageNum-1)*pageSize; // 实际的起始页，因为下标从0开始\n        return userMapper.searchByPage(pageNum, pageSize, userName,address);\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214410-kh7blvi","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221018214410-kh7blvi","updated":"20221020110140"},"Children":[{"Type":"NodeText","Data":"分页查询"}]},{"ID":"20221020110141-oi2lhcr","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20221020110141-oi2lhcr","updated":"20221020110153"},"Children":[{"Type":"NodeText","Data":"思路"}]},{"ID":"20221020110154-r0uckam","Type":"NodeBlockquote","Properties":{"id":"20221020110154-r0uckam","updated":"20221020110819"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221020110155-06ib12g","Type":"NodeParagraph","Properties":{"id":"20221020110155-06ib12g","updated":"20221020110217"},"Children":[{"Type":"NodeText","Data":"分页用MySQL中的limit函数，如"}]},{"ID":"20221020110217-1uby1pb","Type":"NodeParagraph","Properties":{"id":"20221020110217-1uby1pb","updated":"20221020110226"},"Children":[{"Type":"NodeText","Data":"SELECT * FROM springboot."},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"sys_user"},{"Type":"NodeText","Data":" LIMIT 3,2"}]},{"ID":"20221020110338-7r4r0w4","Type":"NodeParagraph","Properties":{"id":"20221020110338-7r4r0w4","updated":"20221020110605"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"​LIMIT pageNum, pageSize"}]},{"ID":"20221020110231-76ci0nq","Type":"NodeParagraph","Properties":{"id":"20221020110231-76ci0nq","updated":"20221020110559"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"3表示从第三页，2表示每页显示数量"}]},{"ID":"20221020110330-eufnom1","Type":"NodeParagraph","Properties":{"id":"20221020110330-eufnom1","updated":"20221020110424"},"Children":[{"Type":"NodeText","Data":"因为数据是从下标0开始的，所以pageNum需要重新计算，即"}]},{"ID":"20221020110424-9u6r4b5","Type":"NodeParagraph","Properties":{"id":"20221020110424-9u6r4b5","updated":"20221020110503"},"Children":[{"Type":"NodeText","Data":"pageNum = （pageNum - 1）* pageSize "}]},{"ID":"20221020110506-fz651it","Type":"NodeParagraph","Properties":{"id":"20221020110506-fz651it","updated":"20221020110544"},"Children":[{"Type":"NodeText","Data":"= （3-1)*2 = 4 即第三的显示是从数据下标为4的开始的"}]},{"ID":"20221020110729-i6a5mgu","Type":"NodeParagraph","Properties":{"id":"20221020110729-i6a5mgu"}},{"ID":"20221020110547-lg1qwq9","Type":"NodeParagraph","Properties":{"id":"20221020110547-lg1qwq9","updated":"20221020110850"},"Children":[{"Type":"NodeText","Data":"比如：数据有18条，现在收到前端的分页要求为（4，3），意为从第四页开始，计算"}]},{"ID":"20221020110709-ixhdije","Type":"NodeParagraph","Properties":{"id":"20221020110709-ixhdije","updated":"20221020110723"},"Children":[{"Type":"NodeText","Data":"pageNum = （4-1）*3 = 9"}]},{"ID":"20221020110723-z91x640","Type":"NodeParagraph","Properties":{"id":"20221020110723-z91x640","updated":"20221020110750"},"Children":[{"Type":"NodeText","Data":"所以可知数据从下标为9的开始显示，每页显示3条"}]},{"ID":"20221020110750-2gmglh0","Type":"NodeParagraph","Properties":{"id":"20221020110750-2gmglh0","updated":"20221020110755"},"Children":[{"Type":"NodeText","Data":"0，1，2"}]},{"ID":"20221020110755-8xsd0px","Type":"NodeParagraph","Properties":{"id":"20221020110755-8xsd0px","updated":"20221020110759"},"Children":[{"Type":"NodeText","Data":"3，4，5"}]},{"ID":"20221020110759-85k09r7","Type":"NodeParagraph","Properties":{"id":"20221020110759-85k09r7","updated":"20221020110804"},"Children":[{"Type":"NodeText","Data":"6，7，8"}]},{"ID":"20221020110804-qer6on6","Type":"NodeParagraph","Properties":{"id":"20221020110804-qer6on6","updated":"20221020110830"},"Children":[{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"9"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"},{"Type":"NodeText","Data":"，10，11"}]},{"ID":"20221020110808-0sy4pfc","Type":"NodeParagraph","Properties":{"id":"20221020110808-0sy4pfc","updated":"20221020110811"},"Children":[{"Type":"NodeText","Data":"12，13，14"}]},{"ID":"20221020110812-zc2ykyb","Type":"NodeParagraph","Properties":{"id":"20221020110812-zc2ykyb","updated":"20221020110815"},"Children":[{"Type":"NodeText","Data":"15，16，17"}]},{"ID":"20221020110815-c4dcfw3","Type":"NodeParagraph","Properties":{"id":"20221020110815-c4dcfw3","updated":"20221020110819"}}]},{"ID":"20221018214233-4j8giig","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214233-4j8giig","updated":"20221018214239"},"Children":[{"Type":"NodeText","Data":"controller层"}]},{"ID":"20221018214242-xrk7lfr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214242-xrk7lfr","updated":"20221020201310"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot.controller;\n\nimport com.xia.springboot.entity.User;\nimport com.xia.springboot.mapper.UserMapper;\nimport com.xia.springboot.service.UserService;\nimport org.springframework.beans.factory.annotation.Autowired;\nimport org.springframework.web.bind.annotation.*;\n\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\n\n@RestController\npublic class UserController {\n\n    @Autowired\n    private UserService userService;\n\n    @GetMapping(\"/\") //查\n    public List\u003cUser\u003e index(){\n        return userService.findAll();\n    }\n\n    @PostMapping //增\n    public int addUser(@RequestBody User user){\n        return userService.add(user);\n    }\n\n    @DeleteMapping(\"{id}\") //删\n    public int deleteUser(@PathVariable Integer id){\n        return userService.deleteUser(id);\n    }\n\n    @PutMapping(\"/user\") //改\n    public void updateUser(@RequestBody User user){\n        userService.updateUser(user);\n    }\n\n    @GetMapping(\"/limit\") //分页查询@RequestParam 在url中表示为 pageNum=？\n    public Map\u003cString, Object\u003e selectByNum(@RequestParam Integer pageNum,\n                                           @RequestParam Integer pageSize,\n                                           @RequestParam String userName,\n                                           @RequestParam String address){\n        HashMap\u003cString, Object\u003e map = new HashMap\u003c\u003e();\n        int countNum = userService.count();\n        List\u003cUser\u003e userData = userService.searchByPage(pageNum,pageSize,userName,address);\n\n        map.put(\"userData\",userData);\n        map.put(\"countNum\",countNum);\n\n        return map;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214447-69xpkof","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214447-69xpkof","updated":"20221018214451"},"Children":[{"Type":"NodeText","Data":"xml"}]},{"ID":"20221018214453-xl7y4ky","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214453-xl7y4ky","updated":"20221020201900"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF8\" ?\u003e\n\u003c!DOCTYPE mapper\n        PUBLIC \"-//mybatis.org//DTD Mapper 3.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-3-mapper.dtd\"\u003e\n\n\u003cmapper namespace=\"com.xia.springboot.mapper.UserMapper\"\u003e\n\n    \u003cselect id=\"findAll\" resultType=\"com.xia.springboot.entity.User\"\u003e\n        select * from springboot.sys_user\n    \u003c/select\u003e\n\n    \u003cinsert id=\"add\" parameterType=\"com.xia.springboot.entity.User\"\u003e\n        insert into springboot.sys_user (username,password,nickname,email,phone,address) values (#{username},#{password},#{nickname},#{email},#{phone},#{address})\n    \u003c/insert\u003e\n\n    \u003cdelete id=\"deleteUser\" parameterType=\"integer\"\u003e\n        delete from springboot.sys_user where id=#{id}\n    \u003c/delete\u003e\n  \n    \u003cupdate id=\"updateUser\"\u003e\n        update springboot.sys_user\n        \u003cset\u003e\n            \u003cif test=\"username != null\"\u003e \u003c!--如果出现查出为空值，避免把原值覆盖--\u003e\n                username = #{username},\n            \u003c/if\u003e\n            \u003cif test=\"password != null\"\u003e\n                password = #{password},\n            \u003c/if\u003e\n            \u003cif test=\"nickname != null\"\u003e\n                nickname = #{nickname},\n            \u003c/if\u003e\n            \u003cif test=\"phone != null\"\u003e\n                phone = #{phone},\n            \u003c/if\u003e\n            \u003cif test=\"address != null\"\u003e\n                address = #{address}\n            \u003c/if\u003e\n        \u003c/set\u003e\n        \u003cwhere\u003e\n            id = #{id}\n        \u003c/where\u003e\n    \u003c/update\u003e\n\n    \u003cselect id=\"searchByPage\" resultType=\"com.xia.springboot.entity.User\"\u003e\u003c!--分页查询--\u003e\n        select * from springboot.sys_user\n            \u003cif test=\"userName != '' or address != '' \"\u003e  \n\u003c!--因为前端中设置的初始值为'',所以先判断是否有存在'',如果模糊查找的数据都有值则进入where语句，没有直接回显所有数据--\u003e\n                \u003cwhere\u003e\n                    \u003cchoose\u003e\n                        \u003cwhen test=\"userName != null and address == null\"\u003e\n\u003c!--注意，这里的userName要和service接口中的变量名称一模一样，而username不用，因为这代表sql语句中的username--\u003e\n                            username like concat(\"%\",#{userName},\"%\")\n                        \u003c/when\u003e\n                        \u003cwhen test=\"userName == null and address != null\"\u003e\n                            address like concat(\"%\",#{address},\"%\")\n                        \u003c/when\u003e\n                        \u003cwhen test=\"userName != null and address != null\"\u003e\n                            username like concat(\"%\",#{userName},\"%\") and address like concat(\"%\",#{address},\"%\")\n                        \u003c/when\u003e\n                    \u003c/choose\u003e\n                \u003c/where\u003e\n            \u003c/if\u003e\n            order by id\n            limit #{pageNum},#{pageSize}\n    \u003c/select\u003e\n  \n    \u003cselect id=\"count\" resultType=\"integer\"\u003e\n        select count(*) from springboot.sys_user\n    \u003c/select\u003e\n\n\n\u003c/mapper\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214246-lldyhw8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214246-lldyhw8","updated":"20221018214251"},"Children":[{"Type":"NodeText","Data":"启动类"}]},{"ID":"20221018214322-lhia0xa","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221018214322-lhia0xa"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.springboot;\n\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\n\n@SpringBootApplication\npublic class Application {\n    public static void main(String[] args) {\n        SpringApplication.run(Application.class, args);\n    }\n  \n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221018214325-87lmasx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221018214325-87lmasx","updated":"20221018214350"},"Children":[{"Type":"NodeText","Data":"结果"}]},{"ID":"20221018214408-0jug1dv","Type":"NodeParagraph","Properties":{"id":"20221018214408-0jug1dv","updated":"20221020201932"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221020201932-hcah7my.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221020201934-d0eq5lq","Type":"NodeParagraph","Properties":{"id":"20221020201934-d0eq5lq"}}]}