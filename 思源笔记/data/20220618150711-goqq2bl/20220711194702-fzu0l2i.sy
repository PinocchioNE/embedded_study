3085640-f8d85ox","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220713085640-f8d85ox","updated":"20220713105420"},"Children":[{"Type":"NodeText","Data":"实现方法"}]},{"ID":"20220713105423-1v09oqc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220713105423-1v09oqc","updated":"20220713105516"},"Children":[{"Type":"NodeText","Data":"接口和实现类"}]},{"ID":"20220713105516-foorj96","Type":"NodeParagraph","Properties":{"id":"20220713105516-foorj96","updated":"20220713105517"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220713105517-lcub7xz.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220713105434-rzjavky","Type":"NodeParagraph","Properties":{"id":"20220713105434-rzjavky","updated":"20220713105605"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220713105605-knixcgy.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220713085306-625wd7q","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220713085306-625wd7q","updated":"20220713122310"},"Children":[{"Type":"NodeText","Data":"CommandLineRunner接口ApplcationRunner接口"}]},{"ID":"20220713122311-0iqw9eb","Type":"NodeParagraph","Properties":{"id":"20220713122311-0iqw9eb","updated":"20220713171832"},"Children":[{"Type":"NodeText","Data":"这两个接口都有一个run方法，执行时间在容器对象创建好后，自动执行run（）方法"}]},{"ID":"20220713171832-p2vq00b","Type":"NodeParagraph","Properties":{"id":"20220713171832-p2vq00b","updated":"20220713171850"},"Children":[{"Type":"NodeText","Data":"可以完成自定义的在容器对象创建好的一些操作"}]},{"ID":"20220713182116-44ulxv4","Type":"NodeParagraph","Properties":{"id":"20220713182116-44ulxv4","updated":"20220713182132"},"Children":[{"Type":"NodeText","Data":"run方法是在容器对象创建好后执行的"}]},{"ID":"20220713171851-7iqjlee","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713171851-7iqjlee","updated":"20220713172307"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@FunctionalInterface\npublic interface CommandLineRunner {\n    void run(String... args) throws Exception;\n}\n\n\n\n@FunctionalInterface\npublic interface ApplicationRunner {\n    void run(ApplicationArguments args) throws Exception;\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713122151-p5jwbca","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220713122151-p5jwbca","updated":"20220713182430"},"Children":[{"Type":"NodeText","Data":"第三章 SpringBoot和web组件"}]},{"ID":"20220713182434-az670f4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220713182434-az670f4","updated":"20220713182523"},"Children":[{"Type":"NodeText","Data":"拦截器"}]},{"ID":"20220713182512-lprgyby","Type":"NodeParagraph","Properties":{"id":"20220713182512-lprgyby","updated":"20220713182744"},"Children":[{"Type":"NodeText","Data":"拦截器是SpringMVC中的一种对象，能拦截对Controller的请求"}]},{"ID":"20220713182745-lwly1x1","Type":"NodeParagraph","Properties":{"id":"20220713182745-lwly1x1","updated":"20220713182821"},"Children":[{"Type":"NodeText","Data":"拦截器框架中有系统的拦截器，还可以自定义拦截器，实现对请求预先处理"}]},{"ID":"20220713182823-kz840z6","Type":"NodeParagraph","Properties":{"id":"20220713182823-kz840z6"}},{"ID":"20220713182823-7ox5gds","Type":"NodeParagraph","Properties":{"id":"20220713182823-7ox5gds","updated":"20220713182830"},"Children":[{"Type":"NodeText","Data":"实现自定义拦截器："}]},{"ID":"20220713182850-jy5ra58","Type":"NodeParagraph","Properties":{"id":"20220713182850-jy5ra58","updated":"20220713182914"},"Children":[{"Type":"NodeText","Data":"1.创建类实现SpringMVC框架的HandlerInterceptor接口"}]},{"ID":"20220713183011-qq5tj3z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713183011-qq5tj3z","updated":"20220713194247"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public interface HandlerInterceptor {\n  \n    // 主要是preHandle这个方法\n    default boolean preHandle(HttpServletRequest request, HttpServletResponse response, Object handler) throws Exception {\n        return true;\n    }\n\n    default void postHandle(HttpServletRequest request, HttpServletResponse response, Object handler, @Nullable ModelAndView modelAndView) throws Exception {\n    }\n\n    default void afterCompletion(HttpServletRequest request, HttpServletResponse response, Object handler, @Nullable Exception ex) throws Exception {\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713183130-izahn6c","Type":"NodeParagraph","Properties":{"id":"20220713183130-izahn6c","updated":"20220713194258"},"Children":[{"Type":"NodeText","Data":"原先需在SpringMVC的配置文件中，声明拦截器"}]},{"ID":"20220713183153-vvkkfrp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713183153-vvkkfrp","updated":"20220713194208"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003cmvc:interceptors\u003e\n\t\u003cmvc:interceptor\u003e\n\t\t\u003cmvc: path=\"url\"/\u003e\n\t\t\u003cbean class=\"拦截器类全限定名称\"/\u003e\n\t\u003c/mvc:interceptor\u003e\n\u003c/mvc:interceptors\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713193211-zuq93jw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220713193211-zuq93jw","updated":"20220713194406"},"Children":[{"Type":"NodeText","Data":"SpringBoot中注册拦截器："}]},{"ID":"20220713194521-ol9yiib","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220713194521-ol9yiib","updated":"20220713194525"},"Children":[{"Type":"NodeText","Data":"1.自定义拦截器"}]},{"ID":"20220713194526-m3tipt0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713194526-m3tipt0"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 自定义拦截器\n */\npublic class LoginInterceptor implements HandlerInterceptor {\n    /**\n     *\n     * @param request\n     * @param response\n     * @param handler:被拦截的控制器对象\n     * @return boolean\n     *      true: 请求能被Controller处理\n     *      false：请求被截断\n     * @throws Exception\n     */\n    @Override\n    public boolean preHandle(HttpServletRequest request, HttpServletResponse response, Object handler) throws Exception {\n        System.out.println(\"执行了LoginInterceptor的preHandle\");\n        return true;\n    }\n}"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713193211-4iy80h8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220713193211-4iy80h8","updated":"20220713194613"},"Children":[{"Type":"NodeText","Data":"2.注册拦截器，指定哪些拦截哪些不拦截"}]},{"ID":"20220713194537-5olqouf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713194537-5olqouf","updated":"20220713194542"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class MyAppConfig implements WebMvcConfigurer {\n\n    //添加拦截器对象，注入到容器中\n    @Override\n    public void addInterceptors(InterceptorRegistry registry) {\n        //创建拦截器对象\n        LoginInterceptor interceptor = new LoginInterceptor();\n\n        //指定拦截器的请求url地址,这个意思是只要是user开头的都拦截\n        String path [] = {\"/user/**\"};\n        //指定不拦截的地址\n        String excludePath [] = {\"/user/login\"};\n        registry.addInterceptor(interceptor).addPathPatterns(path).excludePathPatterns(excludePath);\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713194537-uudm70y","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220713194537-uudm70y","updated":"20220713194851"},"Children":[{"Type":"NodeText","Data":"3.控制器"}]},{"ID":"20220713194853-uc5krkr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713194853-uc5krkr"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Controller\npublic class BootController {\n\n    @RequestMapping(\"/user/account\")\n    @ResponseBody\n    public String userAccount(){\n        return \"访问user/account地址\";\n    }\n\n    @RequestMapping(\"/user/login\")\n    @ResponseBody\n    public String userLogin(){\n        return \"访问user/login地址\";\n    }\n}"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713194537-ayq9sea","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220713194537-ayq9sea","updated":"20220713194928"},"Children":[{"Type":"NodeText","Data":"4.执行结果"}]},{"ID":"20220713193211-zoft2mw","Type":"NodeParagraph","Properties":{"id":"20220713193211-zoft2mw","updated":"20220713193211"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220713193211-kgaj823.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220713193213-u0mysr9","Type":"NodeParagraph","Properties":{"id":"20220713193213-u0mysr9","updated":"20220713195024"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"这里可以看到控制台输出了拦截记录"}]},{"ID":"20220713195004-9nncw0w","Type":"NodeParagraph","Properties":{"id":"20220713195004-9nncw0w","updated":"20220713195004"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220713193852-ly85msj.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220713193213-mi26uiy","Type":"NodeParagraph","Properties":{"id":"20220713193213-mi26uiy","updated":"20220713195026"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"login没有拦截所以输出正常"}]},{"ID":"20220713193958-xh85f28","Type":"NodeParagraph","Properties":{"id":"20220713193958-xh85f28","updated":"20220713193959"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220713193959-8zu1ylc.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220713193958-rs63jz3","Type":"NodeParagraph","Properties":{"id":"20220713193958-rs63jz3"}},{"ID":"20220713193855-1je9a5j","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220713193855-1je9a5j","updated":"20220713195332"},"Children":[{"Type":"NodeText","Data":"Servlet"}]},{"ID":"20220713195334-xrp9nst","Type":"NodeParagraph","Properties":{"id":"20220713195334-xrp9nst","updated":"20220713202527"},"Children":[{"Type":"NodeText","Data":"1."},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"创建Servlet类"}]},{"ID":"20220713202446-wffau5h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713202446-wffau5h"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//创建Servlet类\npublic class MyServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        super.doGet(req, resp);\n    }\n\n    @Override\n    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        //使用HttpServletResponse输出数据，应答结果\n        resp.setContentType(\"text/html;charset=utf-8\");\n        PrintWriter out = resp.getWriter();\n        out.println(\"执行的是Servlet\");\n        out.flush();\n        out.close();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713202452-npnzfow","Type":"NodeParagraph","Properties":{"id":"20220713202452-npnzfow","updated":"20220713202530"},"Children":[{"Type":"NodeText","Data":"2."},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"配置定义"}]},{"ID":"20220713202510-0re8648","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220713202510-0re8648"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class WebApplicationConfig {\n\n    //定义方法，注册Servlet对象\n    @Bean\n    public ServletRegistrationBean servletRegistrationBean(){\n\n        //public ServletRegistrationBean(T servlet, String... urlMappings)\n        //第一个参数是Servlet对象，第二个是url地址\n        ServletRegistrationBean bean = new ServletRegistrationBean(new MyServlet(),\"/myservlet\");\n        return bean;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713202524-w7rbt3t","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220713202524-w7rbt3t","updated":"20220713203050"},"Children":[{"Type":"NodeText","Data":"过滤器Filter"}]},{"ID":"20220713202933-un32f8n","Type":"NodeParagraph","Properties":{"id":"20220713202933-un32f8n","updated":"20220713203014"},"Children":[{"Type":"NodeText","Data":"FilterRegistrationBean用来注册Filter对象"}]},{"ID":"20220713203201-44xssrt","Type":"NodeParagraph","Properties":{"id":"20220713203201-44xssrt","updated":"20220713203241"},"Children":[{"Type":"NodeText","Data":"Filter是Servlet规范中的过滤器，可以处理请求，对请求的参数、属性进行调整，常常在过滤器中处理字符编码"}]},{"ID":"20220713203241-6bklnnc","Type":"NodeParagraph","Properties":{"id":"20220713203241-6bklnnc","updated":"20220713203250"},"Children":[{"Type":"NodeText","Data":"在框架中使用过滤器："}]},{"ID":"20220713203018-c4g4i2f","Type":"NodeParagraph","Properties":{"id":"20220713203018-c4g4i2f","updated":"20220714094701"},"Children":[{"Type":"NodeText","Data":"1.创建自定义过滤器类"}]},{"ID":"20220714094658-340deb1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714094658-340deb1"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//自定义过滤器\npublic class MyFilter implements Filter {\n    @Override\n    public void doFilter(ServletRequest servletRequest, ServletResponse servletResponse, FilterChain filterChain) throws IOException, ServletException {\n        System.out.println(\"执行了MyFilter，doFilter\");\n        filterChain.doFilter(servletRequest,servletResponse);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220713203313-w1e6fke","Type":"NodeParagraph","Properties":{"id":"20220713203313-w1e6fke","updated":"20220714094706"},"Children":[{"Type":"NodeText","Data":"2.注册Filter过滤器对象"}]},{"ID":"20220714094731-aojy21a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714094731-aojy21a"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class WebApplicationConfig {\n    @Bean\n    public FilterRegistrationBean filterRegistrationBean(){\n        FilterRegistrationBean bean = new FilterRegistrationBean();\n        bean.setFilter(new MyFilter());\n        bean.addUrlPatterns(\"/user/*\");\n        return bean;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714094814-sox2hqz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220714094814-sox2hqz","updated":"20220714094933"},"Children":[{"Type":"NodeText","Data":"字符集过滤器"}]},{"ID":"20220714094942-cec63i2","Type":"NodeParagraph","Properties":{"id":"20220714094942-cec63i2","updated":"20220714135117"},"Children":[{"Type":"NodeText","Data":"CharacterEncodingFilter：解决post请求中乱码的问题，网页默认编码是"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ISO-8859-1"}]},{"ID":"20220714095206-d8koxk5","Type":"NodeParagraph","Properties":{"id":"20220714095206-d8koxk5","updated":"20220714095234"},"Children":[{"Type":"NodeText","Data":"再SpringMVC框架中是在web.xml注册过滤器，配置属性"}]},{"ID":"20220714142723-8v3e43f","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220714142723-8v3e43f","updated":"20220714142725"},"Children":[{"Type":"NodeText","Data":"方法一"}]},{"ID":"20220714095235-sedul5c","Type":"NodeParagraph","Properties":{"id":"20220714095235-sedul5c","updated":"20220714140104"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"1.Servlet类"}]},{"ID":"20220714140101-k8ewm0a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714140101-k8ewm0a"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class MyServlet extends HttpServlet {\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        doPost(req, resp);\n    }\n\n    @Override\n    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n        resp.setContentType(\"text/html\");\n        PrintWriter out = resp.getWriter();\n        out.println(\"====在servlet输出中文====\");\n        out.flush();\n        out.close();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714095235-bl4428n","Type":"NodeParagraph","Properties":{"id":"20220714095235-bl4428n","updated":"20220714140214"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"2.构建配置文件"}]},{"ID":"20220714140140-gfrtw14","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714140140-gfrtw14","updated":"20220714140145"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class WebSystemConfig {\n\n    @Bean\n    //注册Servlet\n    public ServletRegistrationBean servletRegistrationBean(){\n        MyServlet myServlet = new MyServlet();\n        ServletRegistrationBean bean = new ServletRegistrationBean(myServlet,\"/myservlet\");\n        return bean;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714140106-xxq7gk0","Type":"NodeParagraph","Properties":{"id":"20220714140106-xxq7gk0","updated":"20220714140307"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"结果，可以看到字符和中文都是乱码"}]},{"ID":"20220714135915-ry0ae0w","Type":"NodeParagraph","Properties":{"id":"20220714135915-ry0ae0w","updated":"20220714135915"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714135915-y9673gi.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714140018-8eue3rg","Type":"NodeParagraph","Properties":{"id":"20220714140018-8eue3rg","updated":"20220714140308"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"3.对servlet增加字符集过滤器"}]},{"ID":"20220714140255-7mk260n","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714140255-7mk260n"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class WebSystemConfig {\n\n    @Bean\n    //注册Servlet\n    public ServletRegistrationBean servletRegistrationBean(){\n        MyServlet myServlet = new MyServlet();\n        ServletRegistrationBean bean = new ServletRegistrationBean(myServlet,\"/myservlet\");\n        return bean;\n    }\n\n    //注册filter\n    @Bean\n    public FilterRegistrationBean filterRegistrationBean(){\n        FilterRegistrationBean bean = new FilterRegistrationBean();\n\n        //使用框架中的过滤器类\n        CharacterEncodingFilter filter = new CharacterEncodingFilter();\n        //指定使用的编码方式\n        filter.setEncoding(\"utf-8\");\n        //指定request，response都是用encoding的值\n        filter.setForceEncoding(true);\n\n        bean.setFilter(filter);\n        //指定过滤的url地址\n        bean.addUrlPatterns(\"/*\");\n\n        return bean;\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714140019-gviv6l8","Type":"NodeParagraph","Properties":{"id":"20220714140019-gviv6l8","updated":"20220714140340"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"结果，可以看到中文还是乱码"}]},{"ID":"20220714140020-lssjef4","Type":"NodeParagraph","Properties":{"id":"20220714140020-lssjef4","updated":"20220714140020"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714140020-tnp1j3s.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714140752-0ae80a9","Type":"NodeParagraph","Properties":{"id":"20220714140752-0ae80a9","updated":"20220714142716"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"4.在配置文件中将encoding关闭即false就可以使用自己的过滤器了"}]},{"ID":"20220714140805-cx3czp0","Type":"NodeParagraph","Properties":{"id":"20220714140805-cx3czp0","updated":"20220714140806"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714140805-pquv8k3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714140835-l3tuu32","Type":"NodeParagraph","Properties":{"id":"20220714140835-l3tuu32","updated":"20220714141009"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"更改后的结果，并且查看响应头可以看到编码为utf-8了"}]},{"ID":"20220714140853-em0xe1z","Type":"NodeParagraph","Properties":{"id":"20220714140853-em0xe1z","updated":"20220714140930"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714140853-zedtxti.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714140930-4u009rd.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714140854-ri3pbx0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220714140854-ri3pbx0","updated":"20220714142741"},"Children":[{"Type":"NodeText","Data":"方法二"}]},{"ID":"20220714142743-8mno5ee","Type":"NodeParagraph","Properties":{"id":"20220714142743-8mno5ee","updated":"20220714143042"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"配置类中就不自己构建过滤器了"}]},{"ID":"20220714142952-kcpcyoc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714142952-kcpcyoc","updated":"20220714143019"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Configuration\npublic class WebSystemConfig {\n\n    @Bean\n    //注册Servlet\n    public ServletRegistrationBean servletRegistrationBean(){\n        MyServlet myServlet = new MyServlet();\n        ServletRegistrationBean bean = new ServletRegistrationBean(myServlet,\"/myservlet\");\n        return bean;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714143016-z1ynkrx","Type":"NodeParagraph","Properties":{"id":"20220714143016-z1ynkrx","updated":"20220714143127"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"直接在properties中将response和request的字符强制转为utf-8"}]},{"ID":"20220714143135-u2ea88u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714143135-u2ea88u","updated":"20220714143241"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw=="},{"Type":"NodeCodeBlockCode","Data":"#系统的过滤器生效\nserver.servlet.encoding.enabled=true\n#指定使用的编码方式\nserver.servlet.encoding.charset=utf-8\n#强制request，response都是用charset属性的值\nserver.servlet.encoding.force=true\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714143153-1ue08qs","Type":"NodeParagraph","Properties":{"id":"20220714143153-1ue08qs","updated":"20220714143427"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"结果"}]},{"ID":"20220714143304-h72989r","Type":"NodeParagraph","Properties":{"id":"20220714143304-h72989r","updated":"20220714143322"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714143303-ghwyqxj.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714143329-ijy703b","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220714143329-ijy703b","updated":"20220714143437"},"Children":[{"Type":"NodeText","Data":"第四章 ORM操作MySQL"}]},{"ID":"20220714143440-zm3267g","Type":"NodeParagraph","Properties":{"id":"20220714143440-zm3267g","updated":"20220714144453"},"Children":[{"Type":"NodeText","Data":"使用MyBatis框架操作数据，在SpringBoot框架集成MyBatis"}]},{"ID":"20220714144454-pi6n6n5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220714144454-pi6n6n5","updated":"20220714144457"},"Children":[{"Type":"NodeText","Data":"使用步骤："}]},{"ID":"20220714144457-h76o1b1","Type":"NodeParagraph","Properties":{"id":"20220714144457-h76o1b1","updated":"20220714144524"},"Children":[{"Type":"NodeText","Data":"1.mybatis起步依赖：完成mybatis对象自动配置，对象放在容器中"}]},{"ID":"20220714144524-xajdkiy","Type":"NodeParagraph","Properties":{"id":"20220714144524-xajdkiy","updated":"20220714144554"},"Children":[{"Type":"NodeText","Data":"2.pom.xml指定把src/main/java目录中的xml文件包含到classpath中"}]},{"ID":"20220714144554-8d6ke3y","Type":"NodeParagraph","Properties":{"id":"20220714144554-8d6ke3y","updated":"20220714144604"},"Children":[{"Type":"NodeText","Data":"3.创建实体类Student"}]},{"ID":"20220714144633-n4d46d4","Type":"NodeParagraph","Properties":{"id":"20220714144633-n4d46d4","updated":"20220714144652"},"Children":[{"Type":"NodeText","Data":"4.创建Dao接口StudentDao，创建一个查询学生的方法"}]},{"ID":"20220714144652-qdon409","Type":"NodeParagraph","Properties":{"id":"20220714144652-qdon409","updated":"20220714144712"},"Children":[{"Type":"NodeText","Data":"5.创建Dao接口对应的Mapper文件，xml文件，写sql语句"}]},{"ID":"20220714144713-85uqu11","Type":"NodeParagraph","Properties":{"id":"20220714144713-85uqu11","updated":"20220714144813"},"Children":[{"Type":"NodeText","Data":"6.创建Service层对象，创建StudentService接口和他的实现类，取Dao对象的方法，完成数据库的操作"}]},{"ID":"20220714144813-mw921e2","Type":"NodeParagraph","Properties":{"id":"20220714144813-mw921e2","updated":"20220714144827"},"Children":[{"Type":"NodeText","Data":"7.创建Controller对象，访问Service"}]},{"ID":"20220714144827-yh5bp72","Type":"NodeParagraph","Properties":{"id":"20220714144827-yh5bp72","updated":"20220714144853"},"Children":[{"Type":"NodeText","Data":"8.写application.properties文件，配置数据库的连接信息"}]},{"ID":"20220714144909-3yn1y3b","Type":"NodeParagraph","Properties":{"id":"20220714144909-3yn1y3b"}},{"ID":"20220714193846-k0ayej0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220714193846-k0ayej0","updated":"20220714193855"},"Children":[{"Type":"NodeText","Data":"第一种方式：@Mapper"}]},{"ID":"20220714193855-bwyxyw4","Type":"NodeParagraph","Properties":{"id":"20220714193855-bwyxyw4","updated":"20220714193940"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"@Mapper：放在dao接口的上面，每个接口都需要使用这个注解"}]},{"ID":"20220714193933-4evc3av","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714193933-4evc3av","updated":"20220714193937"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 告诉MyBatis这是Dao接口，创建此接口的代理对象\n * 位置：在类的上面\n */\n@Mapper\npublic interface StudentDao {\n\n    Student selectById(@Param(\"stuId\") Integer id);\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714194246-so2tp5f","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220714194246-so2tp5f","updated":"20220714202443"},"Children":[{"Type":"NodeText","Data":"第二种方法：@MapperScan"}]},{"ID":"20220714202750-kzs8zir","Type":"NodeParagraph","Properties":{"id":"20220714202750-kzs8zir","updated":"20220714203520"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"业务实现逻辑"},{"Type":"NodeText","Data":"，最主要的就是不用再给dao层一个一个添加mapper了，直接在启动类上增加@MapperScan，就可以自动扫描包下的所有xml文件"}]},{"ID":"20220714202931-uqxpg8r","Type":"NodeParagraph","Properties":{"id":"20220714202931-uqxpg8r","updated":"20220714203413"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714202932-8qfzx89.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714203413-5xz6ef5.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714202831-2i85s7a","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714202831-2i85s7a","updated":"20220714202847"},"Children":[{"Type":"NodeText","Data":"1.实体类"}]},{"ID":"20220714202856-9ze9rb7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714202856-9ze9rb7"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.model;\n\npublic class Student {\n    private Integer id;\n    private String name;\n    private Integer age;\n\n    public Integer getId() {\n        return id;\n    }\n\n    public void setId(Integer id) {\n        this.id = id;\n    }\n\n    public String getName() {\n        return name;\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public Integer getAge() {\n        return age;\n    }\n\n    public void setAge(Integer age) {\n        this.age = age;\n    }\n\n    @Override\n    public String toString() {\n        return \"Student{\" +\n                \"id=\" + id +\n                \", name='\" + name + '\\'' +\n                \", age=\" + age +\n                '}';\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714202900-ofwlgfz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714202900-ofwlgfz","updated":"20220714202958"},"Children":[{"Type":"NodeText","Data":"2.dao层以及xml文件"}]},{"ID":"20220714203012-cpzjl7y","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220714203012-cpzjl7y","updated":"20220714203027"},"Children":[{"Type":"NodeText","Data":"1）通过年龄查找"}]},{"ID":"20220714203027-to3rmke","Type":"NodeParagraph","Properties":{"id":"20220714203027-to3rmke","updated":"20220714203039"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"接口"}]},{"ID":"20220714203041-0tktxd1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203041-0tktxd1"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.dao;\n\nimport com.xia.model.Student;\nimport org.apache.ibatis.annotations.Param;\n\n\n/**\n * 告诉MyBatis这是Dao接口，创建此接口的代理对象\n * 位置：在类的上面\n */\n\npublic interface SchoolDao {\n\n    Student selectByAge(@Param(\"stuAge\") Integer age);\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203049-apxcpq4","Type":"NodeParagraph","Properties":{"id":"20220714203049-apxcpq4","updated":"20220714203054"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"xml文件"}]},{"ID":"20220714203056-lx31u06","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203056-lx31u06","updated":"20220714203100"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF8\"?\u003e\n\u003c!DOCTYPE mapper\n        PUBLIC \"-//mybatis.org//DTD Mapper 3.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-3-mapper.dtd\"\u003e\n\u003cmapper namespace=\"com.xia.dao.SchoolDao\"\u003e\n    \u003c!--定义sql语句--\u003e\n    \u003cselect id=\"selectByAge\" resultType=\"com.xia.model.Student\"\u003e\n        select id,name,age from student where age=#{stuAge}\n    \u003c/select\u003e\n\n\n\u003c/mapper\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203101-6n8x606","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220714203101-6n8x606","updated":"20220714203108"},"Children":[{"Type":"NodeText","Data":"2）通过id查找"}]},{"ID":"20220714203126-fywmede","Type":"NodeParagraph","Properties":{"id":"20220714203126-fywmede","updated":"20220714203131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"接口"}]},{"ID":"20220714203120-ohc2qez","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203120-ohc2qez","updated":"20220714203123"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.dao;\n\nimport com.xia.model.Student;\nimport org.apache.ibatis.annotations.Mapper;\nimport org.apache.ibatis.annotations.Param;\n\n\n/**\n * 告诉MyBatis这是Dao接口，创建此接口的代理对象\n * 位置：在类的上面\n */\n\npublic interface StudentDao {\n\n    Student selectById(@Param(\"stuId\") Integer id);\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203132-74n4g0v","Type":"NodeParagraph","Properties":{"id":"20220714203132-74n4g0v","updated":"20220714203140"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"xml文件"}]},{"ID":"20220714203142-q8sta7b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203142-q8sta7b","updated":"20220714203149"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF8\"?\u003e\n\u003c!DOCTYPE mapper\n        PUBLIC \"-//mybatis.org//DTD Mapper 3.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-3-mapper.dtd\"\u003e\n\u003cmapper namespace=\"com.xia.dao.StudentDao\"\u003e\n    \u003c!--定义sql语句--\u003e\n    \u003cselect id=\"selectById\" resultType=\"com.xia.model.Student\"\u003e\n        select id,name,age from student where id=#{stuId}\n    \u003c/select\u003e\n\n\n\u003c/mapper\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203150-mp98zd6","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714203150-mp98zd6","updated":"20220714203207"},"Children":[{"Type":"NodeText","Data":"3.服务层接口"}]},{"ID":"20220714203217-30yulcv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203217-30yulcv","updated":"20220714203219"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.service;\n\nimport com.xia.model.Student;\n\npublic interface StudentService {\n\n    Student queryStudent(Integer id);\n    Student AgeStudent(Integer age);\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203221-bctmxru","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714203221-bctmxru","updated":"20220714203230"},"Children":[{"Type":"NodeText","Data":"4.服务层实现类"}]},{"ID":"20220714203238-1sylq22","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203238-1sylq22","updated":"20220714203242"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.service.impl;\n\nimport com.xia.dao.SchoolDao;\nimport com.xia.dao.StudentDao;\nimport com.xia.model.Student;\nimport com.xia.service.StudentService;\nimport org.springframework.stereotype.Service;\n\nimport javax.annotation.Resource;\n\n\n@Service\npublic class StudentServiceImpl implements StudentService {\n    @Resource\n    private StudentDao studentDao;\n    @Resource\n    private SchoolDao schoolDao;\n\n    @Override\n    public Student queryStudent(Integer id) {\n        Student student = studentDao.selectById(id);\n        return student;\n    }\n\n    @Override\n    public Student AgeStudent(Integer age) {\n        Student selectByAge = schoolDao.selectByAge(age);\n        return selectByAge;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203244-ae42713","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714203244-ae42713","updated":"20220714203301"},"Children":[{"Type":"NodeText","Data":"5.控制层实现类"}]},{"ID":"20220714203305-6xcz2d0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203305-6xcz2d0"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia.controller;\n\nimport com.xia.model.Student;\nimport com.xia.service.StudentService;\nimport org.springframework.stereotype.Controller;\nimport org.springframework.web.bind.annotation.RequestMapping;\nimport org.springframework.web.bind.annotation.ResponseBody;\n\nimport javax.annotation.Resource;\n\n\n@Controller\npublic class StudentController {\n\n    @Resource\n    private StudentService studentService;\n\n\n    @RequestMapping(\"/student/query\")\n    @ResponseBody\n    public String queryStudent(Integer id){\n        Student student = studentService.queryStudent(id);\n        return student.toString();\n    }\n\n    @RequestMapping(\"/student/age\")\n    @ResponseBody\n    public String AgeStudent(Integer age){\n        Student student = studentService.AgeStudent(age);\n        return student.toString();\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203309-453j77e","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714203309-453j77e","updated":"20220714203338"},"Children":[{"Type":"NodeText","Data":"6.启动类"}]},{"ID":"20220714203340-0rqif6g","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220714203340-0rqif6g"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.xia;\n\nimport org.mybatis.spring.annotation.MapperScan;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\n/**\n * @MapperScan:找到Dao接口和Mapper文件\n * basePackages：Dao接口所在的包名\n */\n@SpringBootApplication\n@MapperScan(basePackages = {\"com.Xia.dao\"})\npublic class SpringbootMapperApplication {\n\n\tpublic static void main(String[] args) {\n\t\tSpringApplication.run(SpringbootMapperApplication.class, args);\n\t}\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220714203527-vmrfxpz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220714203527-vmrfxpz","updated":"20220714203534"},"Children":[{"Type":"NodeText","Data":"7.结果"}]},{"ID":"20220714203536-ymq4u42","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220714203536-ymq4u42","updated":"20220714203543"},"Children":[{"Type":"NodeText","Data":"1）按id查找"}]},{"ID":"20220714203602-679s4zc","Type":"NodeParagraph","Properties":{"id":"20220714203602-679s4zc","updated":"20220714203615"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714203614-0jq0lfm.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714203547-x88i21s","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220714203547-x88i21s","updated":"20220714203601"},"Children":[{"Type":"NodeText","Data":"2）按年龄查找"}]},{"ID":"20220714203620-1i8a28e","Type":"NodeParagraph","Properties":{"id":"20220714203620-1i8a28e","updated":"20220714203651"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220714203651-432zblh.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220714203653-jubum4t","Type":"NodeHeading","HeadingLevel":3,"P