":"20220715092140"},"Children":[{"Type":"NodeText","Data":"\t1）Spring框架中的@Transactional"}]},{"ID":"20220715092140-v4qrdze","Type":"NodeParagraph","Properties":{"id":"20220715092140-v4qrdze","updated":"20220715092204"},"Children":[{"Type":"NodeText","Data":"\t2）aspectj框架可以在xml配置文件中，声明事务控制的内容"}]},{"ID":"20220715092723-bv5hcpw","Type":"NodeParagraph","Properties":{"id":"20220715092723-bv5hcpw"}},{"ID":"20220715092724-o2wwyui","Type":"NodeParagraph","Properties":{"id":"20220715092724-o2wwyui","updated":"20220715092738"},"Children":[{"Type":"NodeText","Data":"SpringBoot中使用事务：上面的两种方式都可以"}]},{"ID":"20220715092738-37ybo3w","Type":"NodeParagraph","Properties":{"id":"20220715092738-37ybo3w","updated":"20220715092828"},"Children":[{"Type":"NodeText","Data":"1）在业务方法的上面加入@Transactional，加入注解后，方法有事务功能了"}]},{"ID":"20220715092829-j7pv65w","Type":"NodeParagraph","Properties":{"id":"20220715092829-j7pv65w","updated":"20220715092857"},"Children":[{"Type":"NodeText","Data":"2）明确的在  主启动类 的上面，加入EnableTransactionManager"}]},{"ID":"20220715092928-p12szuq","Type":"NodeParagraph","Properties":{"id":"20220715092928-p12szuq"}},{"ID":"20220715150455-fdfdtrr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220715150455-fdfdtrr","updated":"20220715150535"},"Children":[{"Type":"NodeText","Data":"逆向工程"}]},{"ID":"20220715150539-xv88i2m","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220715150539-xv88i2m","updated":"20220715150602"},"Children":[{"Type":"NodeText","Data":"1.配置pom.xml"}]},{"ID":"20220715150602-2afxjf5","Type":"NodeParagraph","Properties":{"id":"20220715150602-2afxjf5","updated":"20220715150815"},"Children":[{"Type":"NodeText","Data":"在pom.xml中的build添加项目路径和mybatis-generator-maven-plugin插件"}]},{"ID":"20220715150748-4x32jo7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220715150748-4x32jo7","updated":"20220715150843"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cbuild\u003e\n\t\u003c!--路径--\u003e\n        \u003cresources\u003e\n            \u003cresource\u003e\n                \u003cdirectory\u003esrc/main/resources\u003c/directory\u003e\n                \u003cincludes\u003e\n                    \u003cinclude\u003e**/*.*\u003c/include\u003e\n                \u003c/includes\u003e\n            \u003c/resource\u003e\n        \u003c/resources\u003e\n\n        \u003cplugins\u003e\n            \u003cplugin\u003e\n                \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n                \u003cartifactId\u003espring-boot-maven-plugin\u003c/artifactId\u003e\n            \u003c/plugin\u003e\n            \u003c!--mybatis代码自动生成插件--\u003e\n            \u003cplugin\u003e\n                \u003cgroupId\u003eorg.mybatis.generator\u003c/groupId\u003e\n                \u003cartifactId\u003emybatis-generator-maven-plugin\u003c/artifactId\u003e\n                \u003cversion\u003e1.3.6\u003c/version\u003e\n                \u003cconfiguration\u003e\n                    \u003c!--配置文件的位置:在项目的根目录下，和src平级--\u003e\n                    \u003cconfigurationFile\u003e../shiwu/GeneratorMapper.xml\u003c/configurationFile\u003e\n                    \u003cverbose\u003etrue\u003c/verbose\u003e\n                    \u003coverwrite\u003etrue\u003c/overwrite\u003e\n                \u003c/configuration\u003e\n            \u003c/plugin\u003e\n        \u003c/plugins\u003e\n    \u003c/build\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220715150912-iff9x72","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220715150912-iff9x72","updated":"20220715150939"},"Children":[{"Type":"NodeText","Data":"GeneratorMapper.xml文件"}]},{"ID":"20220715150949-shufqbv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220715150949-shufqbv","updated":"20220715163510"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003c!DOCTYPE generatorConfiguration\n        PUBLIC \"-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN\"\n        \"http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd\"\u003e\n\n\u003cgeneratorConfiguration\u003e\n\n    \u003c!-- 指定连接数据库的JDBC驱动包所在位置，指定到你本机的完整路径 --\u003e\n    \u003cclassPathEntry location=\"D:\\JavaSpringBoot\\shiwu\\mysql-connector-java-8.0.29.jar\"/\u003e\n\n    \u003c!-- 配置table表信息内容体，targetRuntime指定采用MyBatis3的版本 --\u003e\n    \u003ccontext id=\"tables\" targetRuntime=\"MyBatis3\"\u003e\n\n        \u003c!-- 抑制生成注释，由于生成的注释都是英文的，可以不让它生成 --\u003e\n        \u003ccommentGenerator\u003e\n            \u003cproperty name=\"suppressAllComments\" value=\"true\" /\u003e\n        \u003c/commentGenerator\u003e\n\n        \u003c!-- 配置数据库连接信息 --\u003e\n\t\u003c!--修改处0：数据库链接地址--\u003e\n        \u003cjdbcConnection driverClass=\"com.mysql.cj.jdbc.Driver\"\n                        connectionURL=\"jdbc:mysql://localhost:3306/springdb\"\n                        userId=\"root\"\n                        password=\"root\"\u003e\n            \u003c!--这是为了避免出现因数据库中存在相同表名导致传参失败--\u003e\n            \u003cproperty name=\"nullCatalogMeansCurrent\" value=\"true\"/\u003e\n        \u003c/jdbcConnection\u003e\n\n        \u003c!-- 生成model类，targetPackage指定model类的包名， targetProject指定生成的model放在eclipse的哪个工程下面--\u003e\n\t\u003c!--修改处1：targetPackage和targetProject--\u003e\n        \u003cjavaModelGenerator targetPackage=\"com.xia.model\"   \n                            targetProject=\"D:\\JavaSpringBoot\\shiwu\\src\\main\\java\"\u003e\n            \u003cproperty name=\"enableSubPackages\" value=\"false\" /\u003e\n            \u003cproperty name=\"trimStrings\" value=\"false\" /\u003e\n        \u003c/javaModelGenerator\u003e\n\n        \u003c!-- 生成MyBatis的Mapper.xml文件，targetPackage指定mapper.xml文件的包名， targetProject指定生成的mapper.xml放在eclipse的哪个工程下面 --\u003e\n\t\u003c!--修改处2：targetPackage--\u003e\n        \u003csqlMapGenerator targetPackage=\"mapper\" targetProject=\"src/main/resources\"\u003e\n            \u003cproperty name=\"enableSubPackages\" value=\"false\" /\u003e\n        \u003c/sqlMapGenerator\u003e\n\n        \u003c!-- 生成MyBatis的Mapper接口类文件,targetPackage指定Mapper接口类的包名， targetProject指定生成的Mapper接口放在eclipse的哪个工程下面 --\u003e\n\t\u003c!--修改处3：targetPackage--\u003e\n        \u003cjavaClientGenerator type=\"XMLMAPPER\" targetPackage=\"com.xia.dao\" targetProject=\"src/main/java\"\u003e\n            \u003cproperty name=\"enableSubPackages\" value=\"false\" /\u003e\n        \u003c/javaClientGenerator\u003e\n\n        \u003c!-- 数据库表名及对应的Java模型类名 --\u003e\n\t\u003c!--修改处4：tablename，domainObjectName--\u003e\n        \u003ctable tableName=\"student\" domainObjectName=\"Student\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n\n        \u003ctable tableName=\"b_bid_info\" domainObjectName=\"BidInfo\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n\n\n        \u003ctable tableName=\"b_income_record\" domainObjectName=\"IncomeRecord\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n\n\n        \u003ctable tableName=\"b_recharge_record\" domainObjectName=\"RechargeRecord\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n\n\n        \u003ctable tableName=\"u_user\" domainObjectName=\"User\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n\n\n        \u003ctable tableName=\"u_finance_account\" domainObjectName=\"FinanceAccount\"\n               enableCountByExample=\"false\"\n               enableUpdateByExample=\"false\"\n               enableDeleteByExample=\"false\"\n               enableSelectByExample=\"false\"\n               selectByExampleQueryId=\"false\"/\u003e\n    \u003c/context\u003e\n\n\u003c/generatorConfiguration\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220715151750-vuvrsi4","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220715151750-vuvrsi4","updated":"20220715152059"},"Children":[{"Type":"NodeText","Data":"从maven仓库将mysql的jar包导入至根目录"}]},{"ID":"20220715152052-wldo3o6","Type":"NodeParagraph","Properties":{"id":"20220715152052-wldo3o6","updated":"20220715152052"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715152052-1rnlsv9.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715152105-wks07bo","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220715152105-wks07bo","updated":"20220715152353"},"Children":[{"Type":"NodeText","Data":"利用maven的插件逆向生成工程"}]},{"ID":"20220827192123-8vau70x","Type":"NodeParagraph","Properties":{"id":"20220827192123-8vau70x","updated":"20220827192124"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220827192124-tqh7565.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715152500-63hymqf","Type":"NodeParagraph","Properties":{"id":"20220715152500-63hymqf","updated":"20220715152547"},"Children":[{"Type":"NodeText","Data":"可以从图中看出，项目根据数据库自动生成dao层model层以及mapper层"}]},{"ID":"20220715152355-jgiygb2","Type":"NodeParagraph","Properties":{"id":"20220715152355-jgiygb2","updated":"20220715152457"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715152457-3imiu14.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715152459-gb2xdmk","Type":"NodeParagraph","Properties":{"id":"20220715152459-gb2xdmk","updated":"20220715165745"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"在服务层实现类中增加@Transactional事务支持，当出现异常可以回滚事务"}]},{"ID":"20220715165618-h3o1u1z","Type":"NodeParagraph","Properties":{"id":"20220715165618-h3o1u1z","updated":"20220715165618"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715165618-79s2w5n.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715165954-3lkcmuf","Type":"NodeParagraph","Properties":{"id":"20220715165954-3lkcmuf","updated":"20220715170018"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"删除异常事件后，添加成功"}]},{"ID":"20220715165954-5nfqrmh","Type":"NodeParagraph","Properties":{"id":"20220715165954-5nfqrmh","updated":"20220715165954"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715165954-abxknd1.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715170125-rs8qic3","Type":"NodeParagraph","Properties":{"id":"20220715170125-rs8qic3","updated":"20220715170146"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"可以看到事务添加，并且回滚成功"}]},{"ID":"20220715170147-zfkjw30","Type":"NodeParagraph","Properties":{"id":"20220715170147-zfkjw30","updated":"20220715170148"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715170148-7ityvw4.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715170400-al969lo","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220715170400-al969lo","updated":"20220715174436"},"Children":[{"Type":"NodeText","Data":"第五章 接口架构风格 - RESTful"}]},{"ID":"20220715174441-mj9bx8j","Type":"NodeParagraph","Properties":{"id":"20220715174441-mj9bx8j","updated":"20220715174539"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"接口(API):"},{"Type":"NodeText","Data":"可以指访问servlet，controller的url，调用其他程序的函数"}]},{"ID":"20220715174540-7tqma19","Type":"NodeParagraph","Properties":{"id":"20220715174540-7tqma19","updated":"20220715175017"},"Children":[{"Type":"NodeText","Data":"RESTful架构风格"}]},{"ID":"20220715175019-gmozadd","Type":"NodeParagraph","Properties":{"id":"20220715175019-gmozadd","updated":"20220715175214"},"Children":[{"Type":"NodeText","Data":"1）"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"REST:"},{"Type":"NodeText","Data":"（英文：Representational State Transfer，中文：表现层状态转移）"}]},{"ID":"20220715175107-3urxxf8","Type":"NodeParagraph","Properties":{"id":"20220715175107-3urxxf8","updated":"20220715175218"},"Children":[{"Type":"NodeText","Data":"     是一种接口的架构风格和设计理念，"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"不是标准"}]},{"ID":"20220715175147-ni0hpfj","Type":"NodeParagraph","Properties":{"id":"20220715175147-ni0hpfj","updated":"20220715175213"},"Children":[{"Type":"NodeText","Data":"     "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"优点："},{"Type":"NodeText","Data":"更简洁，更有层次"}]},{"ID":"20220715175201-n0xisar","Type":"NodeParagraph","Properties":{"id":"20220715175201-n0xisar","updated":"20220715180646"},"Children":[{"Type":"NodeText","Data":"2）"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"REST中的要素："}]},{"ID":"20220715175256-9beatll","Type":"NodeParagraph","Properties":{"id":"20220715175256-9beatll","updated":"20220715180219"},"Children":[{"Type":"NodeText","Data":"     用REST表示资源和对资源的操作，在互联网中，表示一个资源或者一个操作"}]},{"ID":"20220715180221-ps1m0g9","Type":"NodeParagraph","Properties":{"id":"20220715180221-ps1m0g9","updated":"20220715180235"},"Children":[{"Type":"NodeText","Data":"     资源使用url表示"}]},{"ID":"20220715180235-0yei2n2","Type":"NodeParagraph","Properties":{"id":"20220715180235-0yei2n2","updated":"20220715180246"},"Children":[{"Type":"NodeText","Data":"     资源是用名词表示的"}]},{"ID":"20220715180247-25ekupf","Type":"NodeParagraph","Properties":{"id":"20220715180247-25ekupf"}},{"ID":"20220715180247-t0cdht7","Type":"NodeParagraph","Properties":{"id":"20220715180247-t0cdht7","updated":"20220715180638"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"对资源进行的操作："}]},{"ID":"20220715180257-n7efa5m","Type":"NodeParagraph","Properties":{"id":"20220715180257-n7efa5m","updated":"20220715180640"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"用户："}]},{"ID":"20220715180324-jmwq5o1","Type":"NodeParagraph","Properties":{"id":"20220715180324-jmwq5o1","updated":"20220715180336"},"Children":[{"Type":"NodeText","Data":"\t\t查询资源：通过url找到资源"}]},{"ID":"20220715180336-cq8jfsu","Type":"NodeParagraph","Properties":{"id":"20220715180336-cq8jfsu","updated":"20220715180641"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"程序员："}]},{"ID":"20220715180342-bd8smck","Type":"NodeParagraph","Properties":{"id":"20220715180342-bd8smck","updated":"20220715180352"},"Children":[{"Type":"NodeText","Data":"\t\t创建资源：添加资源"}]},{"ID":"20220715180352-gcss354","Type":"NodeParagraph","Properties":{"id":"20220715180352-gcss354","updated":"20220715180401"},"Children":[{"Type":"NodeText","Data":"\t\t更新资源：更新、编辑"}]},{"ID":"20220715180401-x6jh59w","Type":"NodeParagraph","Properties":{"id":"20220715180401-x6jh59w","updated":"20220715180406"},"Children":[{"Type":"NodeText","Data":"\t\t删除资源：去除"}]},{"ID":"20220715180524-tutkpp3","Type":"NodeParagraph","Properties":{"id":"20220715180524-tutkpp3"}},{"ID":"20220715180649-fn4of3t","Type":"NodeParagraph","Properties":{"id":"20220715180649-fn4of3t","updated":"20220715181511"},"Children":[{"Type":"NodeText","Data":"使用http中的动作（请求方式），"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"表示对资源的操作（CRUD）"},{"Type":"NodeText","Data":"，在网页中默认不允许直接使用PUT和DELETE方式，所以一般用post方式进行代替"}]},{"ID":"20220715181651-6ecjsga","Type":"NodeParagraph","Properties":{"id":"20220715181651-6ecjsga","updated":"20220715181733"},"Children":[{"Type":"NodeText","Data":"在url中，使用名词表示资源，以及访问资源的信息，在url中，使用“/”分隔资源的信息"}]},{"ID":"20220715181651-koxk1dc","Type":"NodeParagraph","Properties":{"id":"20220715181651-koxk1dc","updated":"20220715181819"},"Children":[{"Type":"NodeText","Data":"例如："},{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"http://localhost:9001/mytrans/addStudent?name=%E5%B2%9B%E7%94%B0%E5%BA%84%E5%8F%B8\u0026tid=20","TextMarkTextContent":"localhost:9001/mytrans/student/1001"}]},{"ID":"20220715180726-xsuvmhr","Type":"NodeParagraph","Properties":{"id":"20220715180726-xsuvmhr","updated":"20220715181539"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"GET:"},{"Type":"NodeText","Data":"查询资源  -- sql select"}]},{"ID":"20220715180733-711h9xo","Type":"NodeParagraph","Properties":{"id":"20220715180733-711h9xo","updated":"20220715181536"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"POST:"},{"Type":"NodeText","Data":"创建资源  --sql insert"}]},{"ID":"20220715181848-rwc09j0","Type":"NodeParagraph","Properties":{"id":"20220715181848-rwc09j0","updated":"20220715181939"},"Children":[{"Type":"NodeText","Data":"\t\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"处理单个资源："},{"Type":"NodeText","Data":"localhost:9001/mytrans/student/1001"}]},{"ID":"20220715181859-qcj6vlt","Type":"NodeParagraph","Properties":{"id":"20220715181859-qcj6vlt","updated":"20220715181937"},"Children":[{"Type":"NodeText","Data":"\t\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"处理多个资源（加复数）："},{"Type":"NodeText","Data":"localhost:9001/mytrans/students/1001/1002"}]},{"ID":"20220715181527-d239eve","Type":"NodeParagraph","Properties":{"id":"20220715181527-d239eve","updated":"20220715181527"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715181527-sgj5r8x.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715180736-qp939z7","Type":"NodeParagraph","Properties":{"id":"20220715180736-qp939z7","updated":"20220715181534"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"PUT:"},{"Type":"NodeText","Data":"更新资源  --sql update"}]},{"ID":"20220715181513-nmunswf","Type":"NodeParagraph","Properties":{"id":"20220715181513-nmunswf","updated":"20220715181513"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715181513-lghjho2.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715180739-hqzes4l","Type":"NodeParagraph","Properties":{"id":"20220715180739-hqzes4l","updated":"20220715181542"},"Children":[{"Type":"NodeText","Data":"\t"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"DELETE:"},{"Type":"NodeText","Data":"删除资源  -- sql delete"}]},{"ID":"20220715181542-bshbusr","Type":"NodeParagraph","Properties":{"id":"20220715181542-bshbusr","updated":"20220715182451"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220715182451-g7atvfs.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220715182452-jlv00qh","Type":"NodeParagraph","Properties":{"id":"20220715182452-jlv00qh","updated":"20220716092812"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"总结：使用url表示资源，使用http动作操作资源"}]},{"ID":"20220716092813-9jklsyd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220716092813-9jklsyd","updated":"20220716093146"},"Children":[{"Type":"NodeText","Data":"注解"}]},{"ID":"20220716093554-5w35u3n","Type":"NodeParagraph","Properties":{"id":"20220716093554-5w35u3n","updated":"20220716093615"},"Children":[{"Type":"NodeText","Data":"@PathVariable：从url中获取数据"}]},{"ID":"20220716093615-mu6wbfm","Type":"NodeParagraph","Properties":{"id":"20220716093615-mu6wbfm","updated":"20220716093702"},"Children":[{"Type":"NodeText","Data":"@GetMapping：支持的get请求方式，等同于@RequesetMapping（method=RequestMethod.GET）"}]},{"ID":"20220716093705-vyvhqfj","Type":"NodeParagraph","Properties":{"id":"20220716093705-vyvhqfj","updated":"20220716093734"},"Children":[{"Type":"NodeText","Data":"@PostMapping：支持的post请求方式，等同于@RequesetMapping（method=RequestMethod.POST）"}]},{"ID":"20220716093735-tn3lm6l","Type":"NodeParagraph","Properties":{"id":"20220716093735-tn3lm6l","updated":"20220716093811"},"Children":[{"Type":"NodeText","Data":"@PutMapping：支持put请求方式，等同于@RequesetMapping（method=RequestMethod.PUT）"}]},{"ID":"20220716093812-3txm57f","Type":"NodeParagraph","Properties":{"id":"20220716093812-3txm57f","updated":"20220716093849"},"Children":[{"Type":"NodeText","Data":"@DeleteMapping：支持delete请求方式，等同于@RequesetMapping（method=RequestMethod.DELETE）"}]},{"ID":"20220716093903-483mos3","Type":"NodeParagraph","Properties":{"id":"20220716093903-483mos3","updated":"20220716094052"},"Children":[{"Type":"NodeText","Data":"@RestController：复合注解，是@Controller和ResponseBody组合，在类上面使用，表示当前类的所有方法都加入了@ResponseBody"}]},{"ID":"20220716100847-9167eaw","Type":"NodeParagraph","Properties":{"id":"20220716100847-9167eaw"}},{"ID":"20220716100847-ya9tv9g","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220716100847-ya9tv9g","updated":"20220716101029"},"Children":[{"Type":"NodeText","Data":"@GetMapping"}]},{"ID":"20220716101116-e16rvz4","Type":"NodeBlockquote","Properties":{"id":"20220716101116-e16rvz4","updated":"20220716101152"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220716101117-mw3c4i4","Type":"NodeParagraph","Properties":{"id":"20220716101117-mw3c4i4","updated":"20220716101152"},"Children":[{"Type":"NodeText","Data":"其中，参数studentId就是在网页中输入的路径变量，如1001、1002"}]}]},{"ID":"20220716101046-8sf7obk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220716101046-8sf7obk","updated":"20220716101057"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@RestController\npublic class MyRestController {\n    //学习注解的使用\n\n    //查询id=1001的学生\n    /**\n     * @PathVariable(路径变量)：获取url中的数据\n     *      属性：value：路径变量名，value=也可以省略\n     *      位置：放在控制器方法的形参前面\n     *      localhost:9001/myboot/student/1001\n     */\n    @GetMapping(\"/student/{stuId}\")\n    public String queryStudent(@PathVariable(value = \"stuId\") Integer studentId){\n        return \"查询学生StudentId=\"+studentId;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220716101101-i1x7twy","Type":"NodeParagraph","Properties":{"id":"20220716101101-i1x7twy","updated":"20220716101106"},"Children":[{"Type":"NodeText","Data":"结果"}]},{"ID":"20220716100847-kqd7xal","Type":"NodeParagraph","Properties":{"id":"20220716100847-kqd7xal","updated":"20220716100918"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220716100847-jedyuhe.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220716100918-lsrjvuf.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220716100907-cc9rm10","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220716100907-cc9rm10","updated":"20220716102047"},"Children":[{"Type":"NodeText","Data":"@PostMapping"}]},{"ID":"20220716105848-l4cluv6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220716105848-l4cluv6"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 创建资源Post请求方式\n     * localhost:9001/myboot/student/student/zhangsan/20\n     */\n    @PostMapping(\"/student/{name}/{age}\")\n    public String createStudent(@PathVariable(\"name\") String name,\n                                @PathVariable(\"age\") Integer age){\n        return \"创建资源 student：name=\"+name+\"#age=\"+age;\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220716105901-fbmdfik","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220716105901-fbmdfik","updated":"20220716105905"},"Children":[{"Type":"NodeText","Data":"@PutMapping"}]},{"ID":"20220716105915-drjen13","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220716105915-drjen13"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 更新资源Post请求方式\n     * localhost:9001/myboot/student/zhangsan/20\n     */\n    @PutMapping (\"/student/{id}/{age}\")\n    public String updateStudent(@PathVariable(\"id\") Integer id,\n                                @PathVariable(\"age\") Integer age){\n        return \"更新资源 student：id=\"+id+\"#age=\"+age;\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220716105927-zyihbpp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220716105927-zyihbpp","updated":"20220716105927"},"Children":[{"Type":"NodeText","Data":"@DeleteMapping"}]},{"ID":"20220716105935-3vtaile","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220716105935-3vtaile"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 删除资源\n     */\n    @DeleteMapping(\"/student/{id}\")\n    public String deleteStudent(@PathVariable(\"id\") Integer id){\n        return \"删除资源,执行delete,id=\"+id;\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220716111625-tz9zom8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220716111625-tz9zom8","updated":"20220716111647"},"Children":[{"Type":"NodeText","Data":"在页面中或者ajax中，实现支持put，delete请求"}]},{"ID":"20220716111657-z7b3hzm","Type":"NodeParagraph","Properties":{"id":"20220716111657-z7b3hzm","updated":"20220716111721"},"Children":[{