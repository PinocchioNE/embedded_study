ated":"20220827212430"},"Children":[{"Type":"NodeText","Data":"4.在service的Imp中实现上述方法，并将mapper中的文件映射进来  需要加入@Service @Resource"}]},{"ID":"20220827212241-0bfnf38","Type":"NodeParagraph","Properties":{"id":"20220827212241-0bfnf38","updated":"20220827212917"},"Children":[{"Type":"NodeText","Data":"5.在控制层中调用上述方法 需要加入：@Controller @Resource @ RequestMapping() @ResponseBody"}]},{"ID":"20220827212929-4xdnoxk","Type":"NodeParagraph","Properties":{"id":"20220827212929-4xdnoxk","updated":"20220827213012"},"Children":[{"Type":"NodeText","Data":"6.启动类 需要加入：@SpringBootApplication @MapperScan(value = \"com/Xia/Spboot/mapper\")  \u003c---mapper位置"}]}]},{"ID":"20220827212921-svlz3ij","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220827212921-svlz3ij","updated":"20220827213029"},"Children":[{"Type":"NodeText","Data":"具体实现"}]},{"ID":"20220827213023-cveqy3r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220827213023-cveqy3r","updated":"20220827213204"},"Children":[{"Type":"NodeText","Data":"1.实体类"}]},{"ID":"20220827213053-nn30rx9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220827213053-nn30rx9","updated":"20220827213114"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.Spboot.pojo;\n\npublic class Student {\n    private Integer id;\n\n    private String name;\n\n    private String phone;\n\n    private Integer age;\n\n    public Integer getId() {\n        return id;\n    }\n\n    public void setId(Integer id) {\n        this.id = id;\n    }\n\n    public String getName() {\n        return name;\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public String getPhone() {\n        return phone;\n    }\n\n    public void setPhone(String phone) {\n        this.phone = phone;\n    }\n\n    public Integer getAge() {\n        return age;\n    }\n\n    public void setAge(Integer age) {\n        this.age = age;\n    }\n\n    public Student(Integer id, String name, String phone, Integer age) {\n        this.id = id;\n        this.name = name;\n        this.phone = phone;\n        this.age = age;\n    }\n\n    public Student(){}\n\n    @Override\n    public String toString() {\n        return \"Student{\" +\n                \"id=\" + id +\n                \", name='\" + name + '\\'' +\n                \", phone='\" + phone + '\\'' +\n                \", age=\" + age +\n                '}';\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827213115-gosaxur","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220827213115-gosaxur","updated":"20220827213217"},"Children":[{"Type":"NodeText","Data":"2.mapper接口"}]},{"ID":"20220827213145-5dr9bay","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220827213145-5dr9bay","updated":"20220827213152"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.Spboot.mapper;\n\n\nimport com.Xia.Spboot.pojo.Student;\nimport org.apache.ibatis.annotations.Mapper;\nimport org.apache.ibatis.annotations.Select;\n\nimport java.util.List;\n\n//数据访问层\n@Mapper\npublic interface StudentMapper {\n\n    @Select(\"select * from student where id=#{id}\")\n    List\u003cStudent\u003e findById(int id);\n\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827213145-xgsi5to","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220827213145-xgsi5to","updated":"20220827213221"},"Children":[{"Type":"NodeText","Data":"3.方法接口"}]},{"ID":"20220827213117-fxou11z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220827213117-fxou11z","updated":"20220827213132"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==