eDubbo"}]},{"ID":"20220719151903-z65h79i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719151903-z65h79i","updated":"20220719151955"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@SpringBootApplication\n@EnableDubbo\npublic class ConsumerApplication {\n\n    public static void main(String[] args) {\n        SpringApplication.run(ConsumerApplication.class, args);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719151754-ypykvpn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719151754-ypykvpn","updated":"20220719152055"},"Children":[{"Type":"NodeText","Data":"4.执行"}]},{"ID":"20220719151754-o80b8il","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719151754-o80b8il","updated":"20220719152116"},"Children":[{"Type":"NodeText","Data":"（1）打开zookeeper"}]},{"ID":"20220719152251-qhya4um","Type":"NodeParagraph","Properties":{"id":"20220719152251-qhya4um","updated":"20220719152259"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719144701-uguw2oa.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719152117-43dltad","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719152117-43dltad","updated":"20220719153607"},"Children":[{"Type":"NodeText","Data":"（2）启动提供者"}]},{"ID":"20220719152301-87aj8my","Type":"NodeParagraph","Properties":{"id":"20220719152301-87aj8my","updated":"20220719152322"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719152322-sm617ob.png"},{"T