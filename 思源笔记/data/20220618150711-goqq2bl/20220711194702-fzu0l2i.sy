arker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":" @Value(\"${server.port}\")\nprivate Integer port\n//相当于是从配置文件中找到port的值然后赋值给port\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]}]},{"ID":"20220719195919-a3vobcd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719195919-a3vobcd","updated":"20220719200253"},"Children":[{"Type":"NodeText","Data":"@Autowired"}]},{"ID":"20220719200255-har2i0x","Type":"NodeBlockquote","Properties":{"id":"20220719200255-har2i0x","updated":"20220719200404"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719200258-5rswc8q","Type":"NodeParagraph","Properties":{"id":"20220719200258-5rswc8q","updated":"20220719200403"},"Children":[{"Type":"NodeText","Data":"引用类型赋值自动注入，支持byName，byType。默认是byType，放在属性的上面，也可以放在构造方法的上面，推荐是放在构造方法的上面"}]}]},{"ID":"20220719200404-ksb2xmk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719200404-ksb2xmk","updated":"20220719200626"},"Children":[{"Type":"NodeText","Data":"@Qualifier"}]},{"ID":"20220719200629-ove9dxf","Type":"NodeBlockquote","Properties":{"id":"20220719200629-ove9dxf","updated":"20220719200649"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719200630-9rxu4ey","Type":"NodeParagraph","Properties":{"id":"20220719200630-9rxu4ey","updated":"20220719200649"},"Children":[{"Type":"NodeText","Data":"给引用类型赋值，使用byName方式"}]}]},{"ID":"20220719195758-ii4w8q5","Type":"NodeParagraph","Properties":{"id":"20220719195758-ii4w8q5","updated":"20220719200908"},"Children":[{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"@Autowired和@Qualifier都是Spring框架提供的"}]},{"ID":"20220719200711-06xdg5i","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719200711-06xdg5i","updated":"20220719200715"},"Children":[{"Type":"NodeText","Data":"@Resource"}]},{"ID":"20220719200717-lcqqqy0","Type":"NodeBlockquote","Properties":{"id":"20220719200717-lcqqqy0","updated":"20220719200846"},"Children":[{"Type":"Nod