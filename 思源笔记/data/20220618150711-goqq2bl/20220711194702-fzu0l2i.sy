loseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718102926-y49mncb.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"，解压至没有中文的目录"}]},{"ID":"20220718103121-g7emg8h","Type":"NodeBlockquote","Properties":{"id":"20220718103121-g7emg8h","updated":"20220718103133"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220718103122-zj62k9s","Type":"NodeParagraph","Properties":{"id":"20220718103122-zj62k9s","updated":"20220718103133"},"Children":[{"Type":"NodeText","Data":"先启动服务端，再启动客户端"}]}]},{"ID":"20220718102927-umcs81e","Type":"NodeParagraph","Properties":{"id":"20220718102927-umcs81e","updated":"20220718103115"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718103115-qye66o2.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718103701-bboph8o","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718103701-bboph8o","updated":"20220718104007"},"Children":[{"Type":"NodeText","Data":"2.启动redis可视化界面客户端"}]},{"ID":"20220718103920-2l767vg","Type":"NodeParagraph","Properties":{"id":"20220718103920-2l767vg","updated":"20220718103940"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718103939-ovi31bv.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718103118-ba7ht20","Type":"NodeParagraph","Properties":{"id":"20220718103118-ba7ht20","updated":"20220718103658"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718103658-i73vqin.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718103742-018rts6","Type":"NodeParagraph","Properties":{"id":"20220718103742-018rts6","updated":"20220718103759"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718103758-hv35prm.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718104332-r6jmpm3","Type":"NodeParagraph","Properties":{"id":"20220718104332-r6jmpm3"}},{"ID":"20220718105314-2c5d2o7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718105314-2c5d2o7","updated":"20220718105557"},"Children":[{"Type":"NodeText","Data":"RedisTemplate使用的lettuce客户端库"}]},{"ID":"20220718212434-va1s6jn","Type":"NodeBlockquote","Properties":{"id":"20220718212434-va1s6jn","updated":"20220718212602"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220718212437-v0xowgq","Type":"NodeParagraph","Properties":{"id":"20220718212437-v0xowgq","updated":"20220718212602"},"Children":[{"Type":"NodeText","Data":"只有使用了这个依赖才能在程序中调用RedisTemplate和StringRedisTemplate "}]}]},{"ID":"20220718105332-rqcvoxn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220718105332-rqcvoxn","updated":"20220718105526"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--redis起步依赖：直接在项目中使用RedisTemplate(StringRedisTemplate)--\u003e\n\u003cdependency\u003e\n\t\u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n\t\u003cartifactId\u003espring-boot-starter-data-redis\u003c/artifactId\u003e\n\u003c/dependency\u003e\n\ndata-redis使用的lettuce客户端库\n\n在程序中使用RedisTemplate类的方法操作redis数据，实际就是调用的lettuce客户端中的方法\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718105425-3u0angr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718105425-3u0angr","updated":"20220718205226"},"Children":[{"Type":"NodeText","Data":"（RedisTemplate）向Redis添加数据并查看"}]},{"ID":"20220718164126-o5gg1pm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718164126-o5gg1pm","updated":"20220718164137"},"Children":[{"Type":"NodeText","Data":"properties文件"}]},{"ID":"20220718164139-l4eusrd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220718164139-l4eusrd","updated":"20220718164201"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw=="},{"Type":"NodeCodeBlockCode","Data":"server.port=9001\nserver.servlet.context-path=/myredis\n\n#指定redis（host，ip，password）\nspring.redis.host=localhost\nspring.redis.port=6379\n#spring.redis.password=xxx     有就写没有就不写\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718164037-8poo6go","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718164037-8poo6go","updated":"20220718164108"},"Children":[{"Type":"NodeText","Data":"controller层"}]},{"ID":"20220718164058-cnbktry","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220718164058-cnbktry","updated":"20220718164102"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@RestController\npublic class RedisController {\n\n    /**\n     * 注入RedisTemplate\n     *\n     * RedisTemplate 泛型\n     *\n     * RedisTemplate\u003cString, String\u003e\n     * RedisTemplate\u003cObject,Object\u003e\n     * RedisTemplate\n     *\n     * 注意：RedisTemplate对象的名称redisTemplate\n     */\n    @Resource\n    private RedisTemplate redisTemplate;\n\n    //添加数据到redis\n    @PostMapping(\"/redis/addstring\")\n    public String addToRedis(String name,String value){\n\n        //操作Redis中string类型的数据，先获取ValueOperations对象\n        ValueOperations valueOperations = redisTemplate.opsForValue();\n\n        //添加数据到redis\n        valueOperations.set(\"myname\",\"lisi\");\n\n        return \"向redis添加string类型的数据\";\n    }\n\n    //从redis获取数据\n    @GetMapping(\"/redis/getk\")\n    public String getData(String k){\n        ValueOperations valueOperations = redisTemplate.opsForValue();\n        Object v = valueOperations.get(k);\n        return \"key是\"+k+\",他的值是：\"+v;\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718164204-9hfweih","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718164204-9hfweih","updated":"20220718164238"},"Children":[{"Type":"NodeText","Data":"在postman中查看测试结果"}]},{"ID":"20220726191852-8kuzrt5","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220726191852-8kuzrt5","updated":"20220726191859"},"Children":[{"Type":"NodeText","Data":"postman使用方法"}]},{"ID":"20220726191901-v6m94yg","Type":"NodeParagraph","Properties":{"id":"20220726191901-v6m94yg","updated":"20220726191905"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"postname使用方法.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/postname使用方法-20220726191904-3z998yi.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718164245-z11uzce","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220718164245-z11uzce","updated":"20220718164251"},"Children":[{"Type":"NodeText","Data":"1.添加数据"}]},{"ID":"20220718164240-3vupirm","Type":"NodeParagraph","Properties":{"id":"20220718164240-3vupirm","updated":"20220718164240"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718164240-lulczmn.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718164242-chtu4bm","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220718164242-chtu4bm","updated":"20220718164301"},"Children":[{"Type":"NodeText","Data":"2.查询数据"}]},{"ID":"20220718164303-1lrd1r6","Type":"NodeParagraph","Properties":{"id":"20220718164303-1lrd1r6","updated":"20220718164324"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718164324-5tvoj5p.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718164326-gd73e8a","Type":"NodeParagraph","Properties":{"id":"20220718164326-gd73e8a"}},{"ID":"20220718205101-xwqlfoy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718205101-xwqlfoy","updated":"20220718205212"},"Children":[{"Type":"NodeText","Data":"(StringRedisTemplate)向Redis添加数据并查看"}]},{"ID":"20220718205101-tjq7rto","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718205101-tjq7rto","updated":"20220718205441"},"Children":[{"Type":"NodeText","Data":"1.RESTful风格"}]},{"ID":"20220718205304-976muk8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220718205304-976muk8","updated":"20220718205321"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@RestController\npublic class RedisController {\n\n    @Resource\n    private StringRedisTemplate stringRedisTemplate;\n\n    //RESTful风格\n    @PostMapping(\"/redis/{k}/{v}\")\n    public String addStringKV(@PathVariable String k,\n                              @PathVariable String v){\n        //使用StringRedisTemplate对象\n        stringRedisTemplate.opsForValue().set(k,v);\n        return \"使用使用StringRedisTemplate对象\";\n    }\n\n    @GetMapping(\"/redis/getstr/{k}\")\n    public String getStringValue(@PathVariable String k){\n\n        String v = stringRedisTemplate.opsForValue().get(k);\n        return \"k的value：\"+v;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718205101-iji3fb8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718205101-iji3fb8","updated":"20220718205444"},"Children":[{"Type":"NodeText","Data":"2.在postman中添加数据"}]},{"ID":"20220718205104-e1terx3","Type":"NodeParagraph","Properties":{"id":"20220718205104-e1terx3","updated":"20220718205336"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718205101-v1yka0d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718205104-ydnlacx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718205104-ydnlacx","updated":"20220718205456"},"Children":[{"Type":"NodeText","Data":"3.查看redis中的缓存结果"}]},{"ID":"20220718205104-d8shxoj","Type":"NodeParagraph","Properties":{"id":"20220718205104-d8shxoj","updated":"20220718205118"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718205117-3ztjs7u.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718212026-ga95mwu","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718212026-ga95mwu","updated":"20220718212130"},"Children":[{"Type":"NodeText","Data":"对比StringRedisTemplate和RedisTemplate "}]},{"ID":"20220718212132-q5bscn5","Type":"NodeParagraph","Properties":{"id":"20220718212132-q5bscn5","updated":"20220718212243"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"StringRedisTemplate："},{"Type":"NodeText","Data":"把k，v作为String处理，使用的是String的序列化，可读性好"}]},{"ID":"20220718212133-ry2dfwh","Type":"NodeParagraph","Properties":{"id":"20220718212133-ry2dfwh","updated":"20220718212245"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"RedisTemplate ："},{"Type":"NodeText","Data":"把k，v经过了序列化存到redis。k，v是序列化的内容，不能直接识别"}]},{"ID":"20220719092925-433m9h0","Type":"NodeBlockquote","Properties":{"id":"20220719092925-433m9h0","updated":"20220719092951"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719092927-0ve9phj","Type":"NodeParagraph","Properties":{"id":"20220719092927-0ve9phj","updated":"20220719092951"},"Children":[{"Type":"NodeText","Data":"区别是前者的k和v都是字符，而后者是对象形式的"}]}]},{"ID":"20220719102536-dat0lyo","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220719102536-dat0lyo","updated":"20220719102600"},"Children":[{"Type":"NodeText","Data":"IDEA生成序列化版本号"}]},{"ID":"20220719102602-vdculs6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719102602-vdculs6","updated":"20220719102632"},"Children":[{"Type":"NodeText","Data":"1.在设置中修改"}]},{"ID":"20220719102633-jexuks6","Type":"NodeParagraph","Properties":{"id":"20220719102633-jexuks6","updated":"20220719102634"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719102448-ido86kq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719102603-2hr5o63","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719102603-2hr5o63","updated":"20220719102654"},"Children":[{"Type":"NodeText","Data":"2.在实体类中使用"}]},{"ID":"20220719102654-22ev1q9","Type":"NodeBlockquote","Properties":{"id":"20220719102654-22ev1q9","updated":"20220719102820"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719102659-ctrz6iw","Type":"NodeParagraph","Properties":{"id":"20220719102659-ctrz6iw","updated":"20220719102718"},"Children":[{"Type":"NodeText","Data":"先实现序列化接口"}]},{"ID":"20220719102718-2cw6aqj","Type":"NodeParagraph","Properties":{"id":"20220719102718-2cw6aqj","updated":"20220719102820"},"Children":[{"Type":"NodeText","Data":"再在类名上使用alt+entry"}]}]},{"ID":"20220719102824-64ujib8","Type":"NodeParagraph","Properties":{"id":"20220719102824-64ujib8","updated":"20220719102824"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719102824-z28dbw8.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718205105-8oz1d1d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718205105-8oz1d1d","updated":"20220718210300"},"Children":[{"Type":"NodeText","Data":"Redis序列化"}]},{"ID":"20220718210303-5o9egjd","Type":"NodeParagraph","Properties":{"id":"20220718210303-5o9egjd","updated":"20220718210354"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"序列化："},{"Type":"NodeText","Data":"把对象转化为可传输的字节序列过程称为序列化"}]},{"ID":"20220718210322-mxxvsol","Type":"NodeParagraph","Properties":{"id":"20220718210322-mxxvsol","updated":"20220718210355"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"反序列化："},{"Type":"NodeText","Data":"把字节序列还原为对象的过程称为反序列化"}]},{"ID":"20220718210356-01m2l6p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718210356-01m2l6p","updated":"20220718210409"},"Children":[{"Type":"NodeText","Data":"为什么需要序列化？"}]},{"ID":"20220718210411-vm60tsx","Type":"NodeParagraph","Properties":{"id":"20220718210411-vm60tsx","updated":"20220718210703"},"Children":[{"Type":"NodeText","Data":"序列化的目的是为了对象可以"},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"跨平台存储和进行网络传输"},{"Type":"NodeText","Data":"，而及逆行跨平台存储和网络传输的方式就是IO，而我们的IO支持的数据格式就是字节数组，必须在把对象转成字节数组的时候就指定一种规则"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（序列化）"},{"Type":"NodeText","Data":"，那么我们从IO流里读出数据的时候再以这种规则把对象还原回来"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（反序列化）"}]},{"ID":"20220718210625-jze3wnr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220718210625-jze3wnr","updated":"20220718210755"},"Children":[{"Type":"NodeText","Data":"序列化方式"}]},{"ID":"20220718210757-7bguxlw","Type":"NodeParagraph","Properties":{"id":"20220718210757-7bguxlw","updated":"20220718211911"},"Children":[{"Type":"NodeText","Data":"JDK(不支持跨语言，方便，但性能最差)，JSON,XML,Hessian，Kryo（不支持跨语言，性能好，速度块，适合高并发），Thrift，Protofbuff"}]},{"ID":"20220718214023-23c5kf1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718214023-23c5kf1","updated":"20220718214031"},"Children":[{"Type":"NodeText","Data":"序列化操作"}]},{"ID":"20220718214023-q7s0ksa","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220718214023-q7s0ksa","updated":"20220802164311"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     *设置RedisTemplate序列化\n     * 可以设置key的序列化，可以设置vlaue的序列化\n     * 可以同时设置key和value的序列化\n     */\n    @PostMapping(\"/redis/addstr\")\n    public String addString(String k, String v){\n        //使用RedisTemplate\n        //设置key使用String的序列化\n        redisTemplate.setKeySerializer(new StringRedisSerializer());\n\n        //设置value的序列化\n        redisTemplate.setValueSerializer(new StringRedisSerializer());\n\n        redisTemplate.opsForValue().set(k, v);\n\n        return \"定义RedisTemplate对象的key,value的序列化\";\n    }\n\n    @PostMapping(\"/redis/addstring\")\n    public String addToRedis(String name,String value){\n\n        //操作Redis中string类型的数据，先获取ValueOperations对象\n        ValueOperations valueOperations = redisTemplate.opsForValue();\n\n        //添加数据到redis\n        valueOperations.set(\"myname\",\"lisi\");\n\n        return \"向redis添加string类型的数据\";\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220718214023-74dio7e","Type":"NodeBlockquote","Properties":{"id":"20220718214023-74dio7e","updated":"20220718214122"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220718214050-zer6ms5","Type":"NodeParagraph","Properties":{"id":"20220718214050-zer6ms5","updated":"20220718214122"},"Children":[{"Type":"NodeText","Data":"可以看到查看到的结果没有其他字符编码，而是经过序列化处理后的字符串"}]}]},{"ID":"20220718214003-awcl70k","Type":"NodeParagraph","Properties":{"id":"20220718214003-awcl70k","updated":"20220718214003"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220718214003-z0xq76y.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220718214401-uxy1evy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220718214401-uxy1evy","updated":"20220719092330"},"Children":[{"Type":"NodeText","Data":"Json序列化"}]},{"ID":"20220719092332-2uwxs63","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719092332-2uwxs63","updated":"20220719092354"},"Children":[{"Type":"NodeText","Data":"1.把java对象转为json存储"}]},{"ID":"20220719092355-4wub6ff","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719092355-4wub6ff"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 使用json序列胡啊，把java对象转为json存储\n     * @return\n     */\n    @PostMapping(\"/redis/addjson\")\n    public String addJson(){\n        Student student = new Student();\n        student.setId(1001);\n        student.setName(\"zhangsan\");\n        student.setAge(20);\n\n        redisTemplate.setKeySerializer(new StringRedisSerializer());\n        //把值作为json序列化\n        redisTemplate.setValueSerializer(new Jackson2JsonRedisSerializer(Student.class));\n\n        redisTemplate.opsForValue().set(\"mystudent\",student);\n\n        return \"json序列化\";\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719092359-7zthlzt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719092359-7zthlzt","updated":"20220719092502"},"Children":[{"Type":"NodeText","Data":"2.postman输入"}]},{"ID":"20220719092513-zfni90r","Type":"NodeParagraph","Properties":{"id":"20220719092513-zfni90r","updated":"20220719092513"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719092513-01yt6oy.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719092515-xmy1iyc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719092515-xmy1iyc","updated":"20220719092529"},"Children":[{"Type":"NodeText","Data":"3.redis中查看结果"}]},{"ID":"20220719092550-nxrdls6","Type":"NodeBlockquote","Properties":{"id":"20220719092550-nxrdls6","updated":"20220719092555"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719092552-0l9bvlq","Type":"NodeParagraph","Properties":{"id":"20220719092552-0l9bvlq","updated":"20220719092555"},"Children":[{"Type":"NodeText","Data":"序列化成功"}]}]},{"ID":"20220719092530-vtz50gf","Type":"NodeParagraph","Properties":{"id":"20220719092530-vtz50gf","updated":"20220719092549"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719092549-m4cp7mi.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719092522-wovttfu","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220719092522-wovttfu","updated":"20220719092614"},"Children":[{"Type":"NodeText","Data":"Json反序列化"}]},{"ID":"20220719092616-skzexgh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719092616-skzexgh","updated":"20220719092758"},"Children":[{"Type":"NodeText","Data":"1.把json数据转为java对象"}]},{"ID":"20220719092805-5bbhm2u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719092805-5bbhm2u"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    @PostMapping (\"/redis/getjson\")\n    public String getJson(){\n\n        redisTemplate.setKeySerializer(new StringRedisSerializer());\n        //把值作为json序列化\n        redisTemplate.setValueSerializer(new Jackson2JsonRedisSerializer(Student.class));\n\n        Object obj = redisTemplate.opsForValue().get(\"mystudent\");\n\n        return \"json反序列化\"+obj;\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719092653-20kv8ea","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719092653-20kv8ea","updated":"20220719092847"},"Children":[{"Type":"NodeText","Data":"2.postman查看"}]},{"ID":"20220719092654-x51phb1","Type":"NodeParagraph","Properties":{"id":"20220719092654-x51phb1","updated":"20220719092840"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719092840-2jbsblr.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220721155401-mzj7c1e","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220721155401-mzj7c1e","updated":"20220721155409"},"Children":[{"Type":"NodeText","Data":"缓存穿透"}]},{"ID":"20220721155411-vxzcymy","Type":"NodeBlockquote","Properties":{"id":"20220721155411-vxzcymy","updated":"20220721155725"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220721155412-qds92th","Type":"NodeParagraph","Properties":{"id":"20220721155412-qds92th","updated":"20220721155612"},"Children":[{"Type":"NodeText","Data":"指当使用redis时，防止有人恶意查找数据库中不存在的数据，比如1秒内查一个不存在的数据100万次，那数据库就崩溃了，所以当"}]},{"ID":"20220721155719-ahi5882","Type":"NodeParagraph","Properties":{"id":"20220721155719-ahi5882"},"Children":[{"Type":"NodeText","Data":"第一次查到不存在的数据时要在redis中添加对应的键值对，给下一次查询该不存在的数据时使用"}]}]},{"ID":"20220721155725-o7u5qz8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220721155725-o7u5qz8","updated":"20220721155730"},"Children":[{"Type":"NodeText","Data":"实体类"}]},{"ID":"20220721155737-29i3qkz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220721155737-29i3qkz"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    public Student(){\n\n    }\n\n    public  Student(Integer id, String name, String phone, Integer age) {\n        this.id = id;\n        this.name = name;\n        this.phone = phone;\n        this.age = age;\n    }\n\n    public static Student defaultStudent(){\n        Student student = new Student();\n        student.setId(0);\n        student.setName(\"-\");\n        student.setPhone(\"-\");\n        student.setAge(0);\n        return student;\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220721155736-py3m0mn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220721155736-py3m0mn","updated":"20220721155751"},"Children":[{"Type":"NodeText","Data":"缓存穿透"}]},{"ID":"20220721155638-clbvv35","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220721155638-clbvv35"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 缓存穿透\n     * @param id\n     * @return\n     */\n    @Override\n    public Student queryStudent(Integer id) {\n\n        //从redis查询student，使用Json存储对象\n        redisTemplate.setKeySerializer(new StringRedisSerializer());\n        //值存为json\n        redisTemplate.setValueSerializer(new Jackson2JsonRedisSerializer\u003cStudent\u003e(Student.class));\n\n        final String USER_KEY = \"STUDENT:\";\n\n\n        Student student = null;\n        if(id != null){\n            //student：1001\n            String key = USER_KEY+id;\n            student = (Student) redisTemplate.opsForValue().get(key);\n            System.out.println(id+\",从redis查询数据\"+student);\n            if(student == null){\n                //从mybatis查询\n                student = studentDao.selectById(id);\n                System.out.println(id+\",从数据库查询数据\"+student);\n                if(student != null){\n                    //存到redis\n                    redisTemplate.opsForValue().set(key, student); //该格式表示永久存活\n                }else {\n                    //数据库查不到，在redis添加一个此id默认值,解决缓存穿透\n                    redisTemplate.opsForValue().set(key,Student.defaultStudent());\n                }\n            }\n\n        }\n\n        return student;\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220804133307-r0h82lp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220804133307-r0h82lp","updated":"20220804133319"},"Children":[{"Type":"NodeText","Data":"Spring Cache"}]},{"ID":"20220804133320-x09kfie","Type":"NodeBlockquote","Properties":{"id":"20220804133320-x09kfie","updated":"20220804133457"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220804133428-ts001yn","Type":"NodeParagraph","Properties":{"id":"20220804133428-ts001yn","updated":"20220804133429"},"Children":[{"Type":"NodeText","Data":"Spring cache是一个框架，实现了基于注解的缓存功能，只需要简单地加一个注解，就能实现缓存功能。\nSpring Cache提供了一层抽象，底层可以切换不同的cache实现。具体就是通过CacheManager接口来统一不同的缓存技术。\nCacheManager是Spring提供的各种缓存技术抽象接口。"}]}]},{"ID":"20220804133457-j1ktnrx","Type":"NodeParagraph","Properties":{"id":"20220804133457-j1ktnrx","updated":"20220804133501"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220804133457-2t75ayf.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20220804133541-ijbwcsi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220804133541-ijbwcsi","updated":"20220804133552"},"Children":[{"Type":"NodeText","Data":"Spring Cache常用注解"}]},{"ID":"20220804133554-91p5c5b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220804133554-91p5c5b","updated":"20220804133944"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Enablecaching\t\t//开启缓存注解功能\n@Cacheable\t\t//在方法执行前spring先查看缓存中是否有数据，如果有数据，则直接返回缓存数据;若没有数据，调用方法并将方法返回值放到缓存中\n@CachePut\t\t//将方法的返回值放到缓存中\n@CacheEvict\t\t//将一条或多条数据从缓存中删除\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220804143757-9ejnmqf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220804143757-9ejnmqf","updated":"20220804143804"},"Children":[{"Type":"NodeText","Data":"导入maven"}]},{"ID":"20220804143850-dtppwl3","Type":"NodeBlockquote","Properties":{"id":"20220804143850-dtppwl3","updated":"20220804143859"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220804143852-rlhfcs1","Type":"NodeParagraph","Properties":{"id":"20220804143852-rlhfcs1","updated":"20220804143859"},"Children":[{"Type":"NodeText","Data":"使用redis缓存技术"}]}]},{"ID":"20220804143807-vz3nklp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220804143807-vz3nklp","updated":"20220804143830"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-starter-cache\u003c/artifactId\u003e\n        \u003c/dependency\u003e\n\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-starter-data-redis\u003c/artifactId\u003e\n        \u003c/dependency\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220804143904-7fqktgd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220804143904-7fqktgd","updated":"20220804144052"},"Children":[{"Type":"NodeText","Data":"配置application.yml"}]},{"ID":"20220804144152-zh39r2b","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220804144152-zh39r2b","updated":"20220804144205"},"Children":[{"Type":"NodeText","Data":"redis缓存设置有效期（可选）"}]},{"ID":"20220804144053-g53z57l","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220804144053-g53z57l","updated":"20220804144408"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"spring:\n  reids:\n    host: localhost\n    port: 6379\n    #password\n    database: 0  # 操作的是0号数据库，默认第一个数据库为0号和数组一样\n  cache: #设置缓存redis的有效期限\n    redis:\n      time-to-live: 18000000  # 设置有效期时间\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220804143904-f8im55t","Type":"NodeParagraph","Properties":{"id":"20220804143904-f8im55t"}},{"ID":"20220719093043-w6yvr1w","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220719093043-w6yvr1w","updated":"20220719093058"},"Children":[{"Type":"NodeText","Data":"第七章 SpringBoot集成Dubbo"}]},{"ID":"20220719150845-kvoffdf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220719150845-kvoffdf","updated":"20220719150954"},"Children":[{"Type":"NodeText","Data":"Dubbo和SpringBoot结合项目应用"}]},{"ID":"20220719093101-ygf4acb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719093101-ygf4acb","updated":"20220719151107"},"Children":[{"Type":"NodeText","Data":"1.Dubbo和Zookeeper依赖"}]},{"ID":"20220719102447-jm4o2yf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719102447-jm4o2yf","updated":"20220719151111"},"Children":[{"Type":"NodeText","Data":"创建序列化maven项目接口"}]},{"ID":"20220719102447-ctuxsxk","Type":"NodeParagraph","Properties":{"id":"20220719102447-ctuxsxk","updated":"20220719104410"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719104410-1n15uhq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719104411-6vfrtm3","Type":"NodeParagraph","Properties":{"id":"20220719104411-6vfrtm3","updated":"20220719104421"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"在pom中找到gav"}]},{"ID":"20220719104422-yf536dp","Type":"NodeParagraph","Properties":{"id":"20220719104422-yf536dp","updated":"20220719104434"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719104434-08s14bn.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719104605-uafh66a","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719104605-uafh66a","updated":"20220719153627"},"Children":[{"Type":"NodeText","Data":"2.创建提供者的SpringBoot项目"}]},{"ID":"20220719151452-x22vd2o","Type":"NodeParagraph","Properties":{"id":"20220719151452-x22vd2o","updated":"20220719151701"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"项目结构"}]},{"ID":"20220719151442-fcle41n","Type":"NodeParagraph","Properties":{"id":"20220719151442-fcle41n","updated":"20220719151443"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719151442-q2uosbe.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719151449-z1sqqsw","Type":"NodeParagraph","Properties":{"id":"20220719151449-z1sqqsw","updated":"20220719151449"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"导入公共项目的gav依赖、dubbo依赖和zookeeper依赖"}]},{"ID":"20220719151305-4z9fq7i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719151305-4z9fq7i","updated":"20220719151535"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c!--加入公共项目的gav--\u003e\n\u003cdependency\u003e\n\t\u003cgroupId\u003eorg.example\u003c/groupId\u003e\n\t\u003cartifactId\u003eInterfaceApi\u003c/artifactId\u003e\n\t\u003cversion\u003e1.0-SNAPSHOT\u003c/version\u003e\n\u003c/dependency\u003e\n\n\u003c!--dubbo依赖--\u003e\n\u003cdependency\u003e\n\t\u003cgroupId\u003eorg.apache.dubbo\u003c/groupId\u003e\n\t\u003cartifactId\u003edubbo-spring-boot-starter\u003c/artifactId\u003e\n\t\u003cversion\u003e2.7.8\u003c/version\u003e\n\u003c/dependency\u003e\n\n\u003c!--zookeeper依赖--\u003e\n\u003cdependency\u003e\n\t\u003cgroupId\u003eorg.apache.dubbo\u003c/groupId\u003e\n\t\u003cartifactId\u003edubbo-dependencies-zookeeper\u003c/artifactId\u003e\n\t\u003cversion\u003e2.7.8\u003c/version\u003e\n\t\u003ctype\u003epom\u003c/type\u003e\n\t\u003cexclusions\u003e\n\t\t\u003cexclusion\u003e\n\t\t\t\u003cgroupId\u003eorg.slf4j\u003c/groupId\u003e\n\t\t\t\u003cartifactId\u003eslf4j-log4j12\u003c/artifactId\u003e\n\t\t\u003c/exclusion\u003e\n\t\u003c/exclusions\u003e\n\u003c/dependency\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719124244-dbtvnl8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719124244-dbtvnl8","updated":"20220719151413"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Component\n@DubboService(interfaceClass = StudentService.class,version = \"1.0\",timeout = 5000)\npublic class StudentServiceImpl implements StudentService {\n    @Override\n    public Student queryStudent(Integer id) {\n        Student student = new Student();\n\n        if(1001 == id){\n            student.setId(1001);\n            student.setName(\"1001-张三\");\n            student.setAge(20);\n        }else if(1002 == id){\n            student.setId(1002);\n            student.setName(\"1002-李四\");\n            student.setAge(21);\n        }\n        return student;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719124249-o79ek8j","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719124249-o79ek8j","updated":"20220719151213"},"Children":[{"Type":"NodeText","Data":"配置文件"}]},{"ID":"20220719124307-a6q6s6q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719124307-a6q6s6q","updated":"20220719151205"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw=="},{"Type":"NodeCodeBlockCode","Data":"#配置服务名称 dubbo:application name = \"名称\"\nspring.application.name=studentservice-provider\n\n#配置扫描的包，扫描的@DubboService\ndubbo.scan.base-packages=com.xia.service\n\n#配置dubbo协议\n#dubbo.protocol.name=dubbo\n#dubbo.protocol.port=20881\n\n#注册中心\ndubbo.registries.address=zookeeper://localhost:2181\n#可以更改端口号，避免出现占用问题\nserver.port=9003\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719124314-db0gtg7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719124314-db0gtg7","updated":"20220719151510"},"Children":[{"Type":"NodeText","Data":"启动项中添加dubbo启动依赖"}]},{"ID":"20220719125112-h9yxdn3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220719125112-h9yxdn3","updated":"20220719125119"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * @EnableDubbo（包含下面两种注释）  启用dubbo\n * @EnableDubboConfig\n * @DubboComponentScan\n */\n@SpringBootApplication\n@EnableDubbo\npublic class SpringBootServiceProvideApplication {\n\n\tpublic static void main(String[] args) {\n\t\tSpringApplication.run(SpringBootServiceProvideApplication.class, args);\n\t}\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220719151549-odg590u","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220719151549-odg590u","updated":"20220719151624"},"Children":[{"Type":"NodeText","Data":"3.创建消费者提供者的SpringBoot项目"}]},{"ID":"20220719151640-7a3ocdl","Type":"NodeParagraph","Properties":{"id":"20220719151640-7a3ocdl","updated":"20220719151648"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"项目结构"}]},{"ID":"20220719151549-hvr7de4","Type":"NodeParagraph","Properties":{"id":"20220719151549-hvr7de4","updated":"20220719151639"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220719151639-7mhlxzp.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220719151704-ha473i5","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220719151704-ha473i5","updated":"20220719151719"},"Children":[{"Type":"NodeText","Data":"依赖"}]},{"ID":"20220719151722-ssztzwn","Type":"NodeBlockquote","Properties":{"id":"20220719151722-ssztzwn","updated":"20220719151728"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220719151723-bh9kyyp","Type":"NodeParagraph","Properties":{"i