maven.apache.org/xsd/maven-4.0.0.xsd\"\u003e\n    \u003cmodelVersion\u003e4.0.0\u003c/modelVersion\u003e\n    \u003cparent\u003e\n        \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n        \u003cartifactId\u003espring-boot-starter-parent\u003c/artifactId\u003e\n        \u003cversion\u003e2.7.3\u003c/version\u003e\n        \u003crelativePath/\u003e \u003c!-- lookup parent from repository --\u003e\n    \u003c/parent\u003e\n    \u003cgroupId\u003ecom.Xia\u003c/groupId\u003e\n    \u003cartifactId\u003eSpringBootStudy\u003c/artifactId\u003e\n    \u003cversion\u003e0.0.1-SNAPSHOT\u003c/version\u003e\n    \u003cname\u003eSpringBootStudy\u003c/name\u003e\n    \u003cdescription\u003eSpringBootStudy\u003c/description\u003e\n    \u003cproperties\u003e\n        \u003cjava.version\u003e1.8\u003c/java.version\u003e\n    \u003c/properties\u003e\n    \u003cdependencies\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-starter-web\u003c/artifactId\u003e\n        \u003c/dependency\u003e\n\n\n        \u003c!--mysql驱动--\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003emysql\u003c/groupId\u003e\n            \u003cartifactId\u003emysql-connector-java\u003c/artifactId\u003e\n            \u003cversion\u003e8.0.27\u003c/version\u003e\n        \u003c/dependency\u003e\n\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-starter-test\u003c/artifactId\u003e\n            \u003cscope\u003etest\u003c/scope\u003e\n        \u003c/dependency\u003e\n        \u003c!--        mybatis--\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.mybatis.spring.boot\u003c/groupId\u003e\n            \u003cartifactId\u003emybatis-spring-boot-starter\u003c/artifactId\u003e\n            \u003cversion\u003e1.3.2\u003c/version\u003e\n        \u003c/dependency\u003e\n        \u003c!--        获取页面session对象request对象response对象 HttpServletXXX jar包--\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003ejavax.servlet\u003c/groupId\u003e\n            \u003cartifactId\u003ejavax.servlet-api\u003c/artifactId\u003e\n            \u003cversion\u003e3.0.1\u003c/version\u003e\n        \u003c/dependency\u003e\n        \u003c!--热部署--\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-devtools\u003c/artifactId\u003e\n            \u003coptional\u003etrue\u003c/optional\u003e\n            \u003cscope\u003eruntime\u003c/scope\u003e\n        \u003c/dependency\u003e\n        \u003cdependency\u003e\n            \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n            \u003cartifactId\u003espring-boot-starter-thymeleaf\u003c/artifactId\u003e\n        \u003c/dependency\u003e\n    \u003c/dependencies\u003e\n\n    \u003cbuild\u003e\n        \u003c!--路径--\u003e\n        \u003cresources\u003e\n            \u003cresource\u003e\n                \u003cdirectory\u003esrc/main/resources\u003c/directory\u003e\n                \u003cincludes\u003e\n                    \u003cinclude\u003e**/*.*\u003c/include\u003e\n                \u003c/includes\u003e\n            \u003c/resource\u003e\n        \u003c/resources\u003e\n\n        \u003cplugins\u003e\n            \u003cplugin\u003e\n                \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n                \u003cartifactId\u003espring-boot-maven-plugin\u003c/artifactId\u003e\n                \u003cversion\u003e2.7.3\u003c/version\u003e\n            \u003c/plugin\u003e\n            \u003c!--mybatis代码自动生成插件--\u003e\n            \u003cplugin\u003e\n                \u003cgroupId\u003eorg.mybatis.generator\u003c/groupId\u003e\n                \u003cartifactId\u003emybatis-generator-maven-plugin\u003c/artifactId\u003e\n                \u003cversion\u003e1.3.6\u003c/version\u003e\n                \u003cconfiguration\u003e\n                    \u003c!--配置文件的位置:在项目的根目录下，和src平级--\u003e\n                    \u003cconfigurationFile\u003e../SpringBootStudy/GeneratorMapper.xml\u003c/configurationFile\u003e\n                    \u003cverbose\u003etrue\u003c/verbose\u003e\n                    \u003coverwrite\u003etrue\u003c/overwrite\u003e\n                \u003c/configuration\u003e\n            \u003c/plugin\u003e\n        \u003c/plugins\u003e\n    \u003c/build\u003e\n\u003c/project\u003e\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827211619-2j0ef2j","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220827211619-2j0ef2j","updated":"20220827211626"},"Children":[{"Type":"NodeText","Data":"application.yml"}]},{"ID":"20220827211628-6tuu0ct","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220827211628-6tuu0ct","updated":"20220827211650"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"server:\n  port: 8081\nspring:\n  mvc:\n    view:\n      prefix: classpath:/templates/\n      suffix: .html\n  thymeleaf:\n    mode: HTML\n    encoding: utf-8\n    cache: false\n  datasource:\n      driver-class-name: com.mysql.cj.jdbc.Driver\n      url: jdbc:mysql://localhost:3306/springdb?serverTimezone=Asia/Shanghai\u0026useUnicode=true\u0026characterEncoding=utf-8\u0026zeroDateTimeBehavior=convertToNull\u0026useSSL=false\u0026allowPublicKeyRetrieval=true\n      username: root\n      password: root\n  devtools:\n    restart:\n      enabled: true  \n  freemarker:\n    cache: false   \nmybatis:\n  configuration:\n    map-underscore-to-camel-case: true \n    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl \n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220827211643-uubf60p","Type":"NodeHeading","HeadingLevel":2,"Propert