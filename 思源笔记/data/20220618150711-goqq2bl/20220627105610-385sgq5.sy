{"ID":"20220627105610-385sgq5","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220627105610-385sgq5","title":"瑞吉外卖（黑马）","type":"doc","updated":"20220905150205"},"Children":[{"ID":"20220627105610-bna11bg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627105610-bna11bg","updated":"20220627120415"},"Children":[{"Type":"NodeText","Data":"技术路线"}]},{"ID":"20220627120416-m6u554x","Type":"NodeParagraph","Properties":{"id":"20220627120416-m6u554x","updated":"20220627120417"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627120417-q45dc69.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220627120412-cbt7f4s","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220627120412-cbt7f4s","updated":"20220627120508"},"Children":[{"Type":"NodeText","Data":"功能架构"}]},{"ID":"20220627120519-cy19ow8","Type":"NodeParagraph","Properties":{"id":"20220627120519-cy19ow8","updated":"20220627120520"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627120519-n4feps9.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220627120522-ix5uver","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627120522-ix5uver","updated":"20220627133931"},"Children":[{"Type":"NodeText","Data":" 配置"}]},{"ID":"20220627133934-oemkvxc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220627133934-oemkvxc","updated":"20220627133943"},"Children":[{"Type":"NodeText","Data":"1.pom.xml"}]},{"ID":"20220627133943-p46ioc0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220627133943-p46ioc0","updated":"20220627134005"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\n\u003cproject xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n  xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\"\u003e\n  \u003cmodelVersion\u003e4.0.0\u003c/modelVersion\u003e\n\n  \u003cparent\u003e\n    \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n    \u003cartifactId\u003espring-boot-starter-parent\u003c/artifactId\u003e\n    \u003cversion\u003e2.4.5\u003c/version\u003e\n    \u003crelativePath/\u003e \u003c!-- lookup parent from repository --\u003e\n  \u003c/parent\u003e\n\n  \u003cgroupId\u003eorg.Xia\u003c/groupId\u003e\n  \u003cartifactId\u003ereggie-take-out\u003c/artifactId\u003e\n  \u003cversion\u003e1.0-SNAPSHOT\u003c/version\u003e\n  \u003cpackaging\u003ewar\u003c/packaging\u003e\n\n  \u003cproperties\u003e\n    \u003cjava.version\u003e1.8\u003c/java.version\u003e\n  \u003c/properties\u003e\n\n  \u003cname\u003ereggie-take-out Maven Webapp\u003c/name\u003e\n  \u003c!-- FIXME change it to the project's website --\u003e\n  \u003curl\u003ehttp://www.example.com\u003c/url\u003e\n\n  \u003cdependencies\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n      \u003cartifactId\u003espring-boot-starter\u003c/artifactId\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n      \u003cartifactId\u003espring-boot-starter-test\u003c/artifactId\u003e\n      \u003cscope\u003etest\u003c/scope\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n      \u003cartifactId\u003espring-boot-starter-web\u003c/artifactId\u003e\n      \u003cscope\u003ecompile\u003c/scope\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003ecom.baomidou\u003c/groupId\u003e\n      \u003cartifactId\u003emybatis-plus-boot-starter\u003c/artifactId\u003e\n      \u003cversion\u003e3.4.2\u003c/version\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003eorg.projectlombok\u003c/groupId\u003e\n      \u003cartifactId\u003elombok\u003c/artifactId\u003e\n      \u003cversion\u003e1.18.20\u003c/version\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003ecom.alibaba\u003c/groupId\u003e\n      \u003cartifactId\u003efastjson\u003c/artifactId\u003e\n      \u003cversion\u003e1.2.76\u003c/version\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003ecommons-lang\u003c/groupId\u003e\n      \u003cartifactId\u003ecommons-lang\u003c/artifactId\u003e\n      \u003cversion\u003e2.6\u003c/version\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003emysql\u003c/groupId\u003e\n      \u003cartifactId\u003emysql-connector-java\u003c/artifactId\u003e\n      \u003cscope\u003eruntime\u003c/scope\u003e\n    \u003c/dependency\u003e\n\n    \u003cdependency\u003e\n      \u003cgroupId\u003ecom.alibaba\u003c/groupId\u003e\n      \u003cartifactId\u003edruid-spring-boot-starter\u003c/artifactId\u003e\n      \u003cversion\u003e1.1.23\u003c/version\u003e\n    \u003c/dependency\u003e\n\n  \u003c/dependencies\u003e\n\n  \u003cbuild\u003e\n    \u003cplugins\u003e\n      \u003cplugin\u003e\n        \u003cgroupId\u003eorg.springframework.boot\u003c/groupId\u003e\n        \u003cartifactId\u003espring-boot-maven-plugin\u003c/artifactId\u003e\n        \u003cversion\u003e2.4.5\u003c/version\u003e\n      \u003c/plugin\u003e\n    \u003c/plugins\u003e\n  \u003c/build\u003e\n\n\u003c/project\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220627120806-qqi7j2w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220627120806-qqi7j2w","updated":"20220627140102"},"Children":[{"Type":"NodeText","Data":"2.resources"}]},{"ID":"20220627140110-7umwe2r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220627140110-7umwe2r","updated":"20220627140236"},"Children":[{"Type":"NodeText","Data":"（1）application.yml"}]},{"ID":"20220627134035-q9l3ea1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220627134035-q9l3ea1","updated":"20220627134107"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Z28="},{"Type":"NodeCodeBlockCode","Data":"server:\n  port: 8080\nspring:\n  application:\n    #配置应用名称，可选\n    name: reggie-take-out\n  datasource:\n    druid:\n      driver-class-name: com.mysql.cj.jdbc.Driver\n      url: jdbc:mysql://localhost:3306/reggie?serverTimezone=Asia/Shanghai\u0026useUnicode=true\u0026characterEncoding=utf-8\u0026zeroDateTimeBehavior=convertToNull\u0026useSSL=false\u0026allowPublicKeyRetrieval=true\n      username: root\n      password: root\nmybatis-plus:\n  configuration:\n    #在映射实体或者属性时，将数据库中表名和字段名中的下划线去掉，按照驼峰命名法映射\n    map-underscore-to-camel-case: true\n    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl\n  global-config:\n    db-config:\n      id-type: ASSIGN_ID\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220627140057-x7j6feq","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220627140057-x7j6feq","updated":"20220627205126"},"Children":[{"Type":"NodeText","Data":"（2）前端代码（down的zip）"}]},{"ID":"20220627140222-z8jk6x8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220627140222-z8jk6x8"},"Children":[{"Type":"NodeText","Data":"（3）前端代码映射配置文件"}]},{"ID":"20220627140245-kqb9pyx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220627140245-kqb9pyx","updated":"20220627140250"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.reggie.config;\n\n//因为html需要在static或public类下，但该项目是直接导入的前端直接查找会出现404，所以需要写一个配置类，用于映射路径\n\nimport lombok.extern.slf4j.Slf4j;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.web.servlet.config.annotation.ResourceHandlerRegistry;\nimport org.springframework.web.servlet.config.annotation.WebMvcConfigurer;\n\n@Slf4j\n@Configuration\npublic class WebMvcConfig implements WebMvcConfigurer {\n    /*\n    设置静态资源映射\n     */\n    @Override\n    public void addResourceHandlers(ResourceHandlerRegistry registry) {\n        log.info(\"开始静态资源映射...\");\n        //classpath代表resources路径\n        registry.addResourceHandler(\"/backend/**\").addResourceLocations(\"classpath:/backend/\");\n        registry.addResourceHandler(\"/front/**\").addResourceLocations(\"classpath:/front/\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220627140251-3rpq5bv","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627140251-3rpq5bv","updated":"20220627140328"},"Children":[{"Type":"NodeText","Data":"SpringBoot启动类"}]},{"ID":"20220627140346-6ivd3he","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220627140346-6ivd3he","updated":"20220630084554"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.reggie;\n//启动类 用于启动springboot\n\nimport lombok.extern.slf4j.Slf4j;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\nimport org.springframework.boot.web.servlet.ServletComponentScan;\n\n//输出日志\n@Slf4j\n@SpringBootApplication\n@ServletComponentScan  //扫描过滤器中的WebFilter\npublic class ReggieApplication {\n    public static void main(String[] args) {\n        SpringApplication.run(ReggieApplication.class,args);\n        log.info(\"项目启动成功...\");\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220627140349-75lj0ru","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627140349-75lj0ru","updated":"20220627140401"},"Children":[{"Type":"NodeText","Data":"暂时的前端页面效果"}]},{"ID":"20220627140406-n45gj5z","Type":"NodeParagraph","Properties":{"id":"20220627140406-n45gj5z","updated":"20220627140424"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627140424-a8gke2l.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220627140425-4f7cvco","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627140425-4f7cvco","updated":"20220627140455"},"Children":[{"Type":"NodeText","Data":"后台系统的登录功能"}]},{"ID":"20220627140456-q0is4kf","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220627140456-q0is4kf","updated":"20220627141747"},"Children":[{"Type":"NodeText","Data":"需求分析"}]},{"ID":"20220627141749-ifml8rh","Type":"NodeParagraph","Properties":{"id":"20220627141749-ifml8rh","updated":"20220627141750"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627141750-0irp7ba.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220627141752-jt5e19o","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220627141752-jt5e19o","updated":"20220627155129"},"Children":[{"Type":"NodeText","Data":"代码开发"}]},{"ID":"20220627155131-jl0xcsv","Type":"NodeParagraph","Properties":{"id":"20220627155131-jl0xcsv","updated":"20220627155144"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627155144-dbn58di.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628104407-i4xht0s","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628104407-i4xht0s","updated":"20220628104410"},"Children":[{"Type":"NodeText","Data":"员工登录"}]},{"ID":"20220627204831-wkbu8ec","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220627204831-wkbu8ec","updated":"20220627204914"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Slf4j\n@RestController\n@RequestMapping(\"/employee\")\npublic class EmployeeController {\n\n\n    @Autowired\n    private EmployeeService employeeService;\n\n    /**\n     * 员工登录\n     * @param request\n     * @param employee\n     * @return\n     */\n    @PostMapping(\"/login\")\n    public R\u003cEmployee\u003e login(HttpServletRequest request, @RequestBody Employee employee){\n\n        //1、将页面提交的密码password进行md5加密处理\n        String password = employee.getPassword();\n        password = DigestUtils.md5DigestAsHex(password.getBytes());\n\n        //2.根据页面提交的用户名username查询数据库\n        LambdaQueryWrapper\u003cEmployee\u003e queryWrapper = new LambdaQueryWrapper\u003c\u003e();\n        queryWrapper.eq(Employee::getUsername,employee.getUsername());\n        Employee emp = employeeService.getOne(queryWrapper);\n\n\n        //3.如果没有查询到则返回登录失败结果\n        if (emp == null){\n            return R.error(\"无该用户，登陆失败\");\n        }\n\n        //4.密码比对，如果不一致则返回登录失败结果\n        if(!emp.getPassword().equals(password)){\n            return R.error(\"密码错误，登录失败\");\n        }\n\n        //5.查看员工状态，如果为已禁用状态，则返回员工已禁用结果\n        if(emp.getStatus() == 0){\n            return R.error(\"账号已禁用\");\n        }\n\n        //6.登录成功，将员工id存入Session并返回登录成功结果\n        request.getSession().setAttribute(\"employee\",emp.getId());\n        return R.success(emp);\n    }\n\n    /**\n     * 员工退出\n     * @param request\n     * @return\n     */\n    @PostMapping(\"/logout\")\n    public R\u003cString\u003e logout(HttpServletRequest request){\n        //清理session中保存的当前登录员工的if\n        request.getSession().removeAttribute(\"employee\");\n        return R.success(\"退出成功\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220627204831-lxpx3od","Type":"NodeParagraph","Properties":{"id":"20220627204831-lxpx3od"}},{"ID":"20220627155330-2xpvngt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220627155330-2xpvngt","updated":"20220627204145"},"Children":[{"Type":"NodeText","Data":"业务开发"}]},{"ID":"20220627204147-148baxz","Type":"NodeParagraph","Properties":{"id":"20220627204147-148baxz","updated":"20220627204202"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220627204156-7qqm5ev.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220627204200-rw0ohhp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220627204200-rw0ohhp","updated":"20220628104529"},"Children":[{"Type":"NodeText","Data":"完善登录功能(如何防止直接登录进入管理系统而跳过登录界面)"}]},{"ID":"20220627204431-4vjgzor","Type":"NodeParagraph","Properties":{"id":"20220627204431-4vjgzor","updated":"20220627204505"},"Children":[{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"过滤器​​"}]},{"ID":"20220627204435-4wf3oqj","Type":"NodeParagraph","Properties":{"id":"20220627204435-4wf3oqj","updated":"20220627204518"},"Children":[{"Type":"NodeText","Data":"实现步骤："}]},{"ID":"20220627204518-ln7nron","Type":"NodeParagraph","Properties":{"id":"20220627204518-ln7nron","updated":"20220627204538"},"Children":[{"Type":"NodeText","Data":"1.创建自定义过滤器LoginCheckFilter"}]},{"ID":"20220627204522-0zo2aq7","Type":"NodeParagraph","Properties":{"id":"20220627204522-0zo2aq7","updated":"20220627204604"},"Children":[{"Type":"NodeText","Data":"2.在启动类上加入注解@ServletComponentScan"}]},{"ID":"20220627204523-vy4uhfu","Type":"NodeParagraph","Properties":{"id":"20220627204523-vy4uhfu","updated":"20220627204616"},"Children":[{"Type":"NodeText","Data":"3.完善过滤器的处理逻辑"}]},{"ID":"20220628104252-o3zzqio","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628104252-o3zzqio","updated":"20220628104305"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"过滤器"},{"Type":"NodeText","Data":"​"}]},{"ID":"20220628104210-f1w5qws","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628104210-f1w5qws","updated":"20220628104240"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 检查用户是否已经完成登录\n */\n@WebFilter(filterName=\"loginCheckFilter\", urlPatterns = \"/*\")//意为过滤目录下的所有请求\n@Slf4j\npublic class LoginCheckFilter implements Filter {\n\n    //路径匹配符，支持通配符\n    public static final AntPathMatcher PATH_MATCHER = new AntPathMatcher();\n\n    @Override\n    public void doFilter(ServletRequest servletRequest, ServletResponse servletResponse, FilterChain filterChain) throws IOException, ServletException {\n        HttpServletRequest request = (HttpServletRequest) servletRequest;\n        HttpServletResponse response = (HttpServletResponse) servletResponse;\n\n        //1.获取本次请求的URL\n        String requestURI = request.getRequestURI();//   /backend/index.html\n\n        log.info(\"拦截到请求：{}\",requestURI);\n\n        //定义不需要处理的请求路径\n        java.lang.String[] urls = new java.lang.String[]{\n          \"/employee/login\",\n                \"/employee/logout\",\n                \"/backend/**\",\n                \"/front/**\"\n        };\n\n        //2.判断本次请求是否需要处理\n        boolean check = check(urls, requestURI);\n\n        //3.如果不需要处理，则直接放行\n        if(check){\n            log.info(\"本次请求{}不需要处理\",requestURI);\n            filterChain.doFilter(request, response);\n            return;\n        }\n\n        //4.判断登录状态，如果已经登录，则直接放行\n        if(request.getSession().getAttribute(\"employee\")!=null){\n            log.info(\"用户已登录，用户id为：{}\",request.getSession().getAttribute(\"employee\"));\n            filterChain.doFilter(request, response);\n            return;\n        }\n\n        log.info(\"用户未登录\");\n        //5.如果未登录则返回未登录结果，通过输出流方式向客户端页面响应数据\n        response.getWriter().write(JSON.toJSONString(R.error(\"NOTLOGIN\")));\n        return;\n    }\n\n    /**\n     * 路径匹配，检查本次请求是否需要方形\n     * @param urls\n     * @param requestURI\n     * @return\n     */\n    public boolean check(String[] urls,String requestURI){\n        for (String url : urls) {\n            boolean match = PATH_MATCHER.match(url, requestURI);\n            if (match){\n                return true;\n            }\n        }\n        return false;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628104231-c54ckx2","Type":"NodeParagraph","Properties":{"id":"20220628104231-c54ckx2","updated":"20220628104232"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628104232-qx5cl8y.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628104233-f91882a","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628104233-f91882a","updated":"20220628104317"},"Children":[{"Type":"NodeText","Data":"启动类"}]},{"ID":"20220628104327-01i5mft","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628104327-01i5mft"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//输出日志\n@Slf4j\n@SpringBootApplication\n@ServletComponentScan  //扫描过滤器中的WebFilter\npublic class ReggieApplication {\n    public static void main(String[] args) {\n        SpringApplication.run(ReggieApplication.class,args);\n        log.info(\"项目启动成功...\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628104442-vpzcott","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220628104442-vpzcott","updated":"20220628104447"},"Children":[{"Type":"NodeText","Data":"新增员工"}]},{"ID":"20220628104459-rtfpg0f","Type":"NodeParagraph","Properties":{"id":"20220628104459-rtfpg0f","updated":"20220628104459"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628104459-z50ttml.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628104503-gfd8dmj","Type":"NodeParagraph","Properties":{"id":"20220628104503-gfd8dmj","updated":"20220628104842"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628104842-gfhgqdy.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628105634-l3ma14n","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628105634-l3ma14n","updated":"20220628105643"},"Children":[{"Type":"NodeText","Data":"代码开发思路"}]},{"ID":"20220628105647-0hxkv9m","Type":"NodeParagraph","Properties":{"id":"20220628105647-0hxkv9m","updated":"20220628105703"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628105703-cij7kdl.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628185110-o9fdaal","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628185110-o9fdaal"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 新增员工\n     * @param employee\n     * @return\n     */\n    @PostMapping\n    public R\u003cString\u003e save(HttpServletRequest request, @RequestBody Employee employee){\n        log.info(\"新增员工信息:{}\",employee.toString());\n\n        //设置初始密码123456，并进行 md5 加密处理\n        employee.setPassword(DigestUtils.md5DigestAsHex(\"123456\".getBytes()));\n\n        employee.setCreateTime(LocalDateTime.now());//设置创建时间\n        employee.setUpdateTime(LocalDateTime.now());//设置更新时间\n\n        //获取当前登录用户的id\n        Long empID = (long)request.getSession().getAttribute(\"employee\");\n\n        employee.setCreateUser(empID);\n        employee.setUpdateUser(empID);\n\n        employeeService.save(employee);\n\n        return null;\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628185128-x4jbbv8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628185128-x4jbbv8","updated":"20220628185427"},"Children":[{"Type":"NodeText","Data":"防止异常（例如用户名重复）"}]},{"ID":"20220628185206-7xnvzfx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628185206-7xnvzfx"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 全局异常处理\n */\n@ControllerAdvice(annotations = {RestController.class, Controller.class})\n@ResponseBody\n@Slf4j\npublic class GlobalExceptionHandler {\n    /**\n     * 异常处理方法\n     * @return\n     */\n    @ExceptionHandler(SQLIntegrityConstraintViolationException.class)\n    public R\u003cString\u003e exceptionHandler(SQLIntegrityConstraintViolationException ex){\n        log.error(ex.getMessage());\n\n        if(ex.getMessage().contains(\"Duplicate entry\")){\n            String[] split = ex.getMessage().split(\" \");\n            String msg = split[2] + \"已存在\";\n            return R.error(msg);\n\n        }\n        return R.error(\"未知错误\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628185404-ds6oq76","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220628185404-ds6oq76","updated":"20220628185406"},"Children":[{"Type":"NodeText","Data":"分页查询"}]},{"ID":"20220628185409-stuany8","Type":"NodeParagraph","Properties":{"id":"20220628185409-stuany8","updated":"20220628185411"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628185411-v7mb8k2.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628185429-kbbhsdo","Type":"NodeParagraph","Properties":{"id":"20220628185429-kbbhsdo","updated":"20220628185558"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628185557-rsq4l6q.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628185600-0un30p1","Type":"NodeParagraph","Properties":{"id":"20220628185600-0un30p1"}},{"ID":"20220628202810-odrz0kf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628202810-odrz0kf"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 员工信息分页查询\n     * @param page\n     * @param pageSize\n     * @param name\n     * @return\n     */\n    @GetMapping(\"/page\")\n    public R\u003cPage\u003e page(int page, int pageSize, String name){\n        log.info(\"page = {}, pageSize = {}, name = {}\",page, pageSize, name);\n\n        //构造分页构造器\n        Page pageInfo = new Page(page, pageSize);\n        //构造条件构造器\n        LambdaQueryWrapper\u003cEmployee\u003e queryWrapper = new LambdaQueryWrapper();\n        //添加过滤条件\n        queryWrapper.like(StringUtils.hasText(name),Employee::getName,name);\n        //添加排序条件\n        queryWrapper.orderByDesc(Employee::getUpdateTime);\n\n        //执行查询\n        employeeService.page(pageInfo,queryWrapper);\n        return R.success(pageInfo);\n    }\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628202825-czpjpjg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220628202825-czpjpjg","updated":"20220628202837"},"Children":[{"Type":"NodeText","Data":"启用/禁用员工账号"}]},{"ID":"20220628202841-hq3jokn","Type":"NodeParagraph","Properties":{"id":"20220628202841-hq3jokn","updated":"20220628202843"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628202843-lyt860p.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628203319-646sz9v","Type":"NodeParagraph","Properties":{"id":"20220628203319-646sz9v","updated":"20220628203319"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628203319-jjs064a.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628213059-jblayuq","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628213059-jblayuq","updated":"20220628213108"},"Children":[{"Type":"NodeText","Data":"对象映射器"}]},{"ID":"20220628213025-xcf9o4z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628213025-xcf9o4z"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"package com.Xia.reggie.common;\n\nimport com.fasterxml.jackson.databind.DeserializationFeature;\nimport com.fasterxml.jackson.databind.ObjectMapper;\nimport com.fasterxml.jackson.databind.module.SimpleModule;\nimport com.fasterxml.jackson.databind.ser.std.ToStringSerializer;\nimport com.fasterxml.jackson.datatype.jsr310.deser.LocalDateDeserializer;\nimport com.fasterxml.jackson.datatype.jsr310.deser.LocalDateTimeDeserializer;\nimport com.fasterxml.jackson.datatype.jsr310.deser.LocalTimeDeserializer;\nimport com.fasterxml.jackson.datatype.jsr310.ser.LocalDateSerializer;\nimport com.fasterxml.jackson.datatype.jsr310.ser.LocalDateTimeSerializer;\nimport com.fasterxml.jackson.datatype.jsr310.ser.LocalTimeSerializer;\nimport java.math.BigInteger;\nimport java.time.LocalDate;\nimport java.time.LocalDateTime;\nimport java.time.LocalTime;\nimport java.time.format.DateTimeFormatter;\nimport static com.fasterxml.jackson.databind.DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES;\n\n/**\n * 对象映射器:基于jackson将Java对象转为json，或者将json转为Java对象\n * 将JSON解析为Java对象的过程称为 [从JSON反序列化Java对象]\n * 从Java对象生成JSON的过程称为 [序列化Java对象到JSON]\n */\npublic class  JacksonObjectMapper extends ObjectMapper {\n\n    public static final String DEFAULT_DATE_FORMAT = \"yyyy-MM-dd\";\n    public static final String DEFAULT_DATE_TIME_FORMAT = \"yyyy-MM-dd HH:mm:ss\";\n    public static final String DEFAULT_TIME_FORMAT = \"HH:mm:ss\";\n\n    public JacksonObjectMapper() {\n        super();\n        //收到未知属性时不报异常\n        this.configure(FAIL_ON_UNKNOWN_PROPERTIES, false);\n\n        //反序列化时，属性不存在的兼容处理\n        this.getDeserializationConfig().withoutFeatures(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES);\n\n\n        SimpleModule simpleModule = new SimpleModule()\n                .addDeserializer(LocalDateTime.class, new LocalDateTimeDeserializer(DateTimeFormatter.ofPattern(DEFAULT_DATE_TIME_FORMAT)))\n                .addDeserializer(LocalDate.class, new LocalDateDeserializer(DateTimeFormatter.ofPattern(DEFAULT_DATE_FORMAT)))\n                .addDeserializer(LocalTime.class, new LocalTimeDeserializer(DateTimeFormatter.ofPattern(DEFAULT_TIME_FORMAT)))\n\n                .addSerializer(BigInteger.class, ToStringSerializer.instance)\n                .addSerializer(Long.class, ToStringSerializer.instance)\n                .addSerializer(LocalDateTime.class, new LocalDateTimeSerializer(DateTimeFormatter.ofPattern(DEFAULT_DATE_TIME_FORMAT)))\n                .addSerializer(LocalDate.class, new LocalDateSerializer(DateTimeFormatter.ofPattern(DEFAULT_DATE_FORMAT)))\n                .addSerializer(LocalTime.class, new LocalTimeSerializer(DateTimeFormatter.ofPattern(DEFAULT_TIME_FORMAT)));\n\n        //注册功能模块 例如，可以添加自定义序列化器和反序列化器\n        this.registerModule(simpleModule);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628213030-z8tnm0f","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220628213030-z8tnm0f","updated":"20220628213048"},"Children":[{"Type":"NodeText","Data":"MVC配置"}]},{"ID":"20220628213052-ii60hvw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220628213052-ii60hvw"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 扩展mvc框架的消息转换器\n     * @param converters\n     */\n    @Override\n    public void extendMessageConverters(List\u003cHttpMessageConverter\u003c?\u003e\u003e converters) {\n        log.info(\"扩展消息转换器...\");\n        //创建消息转换器对象\n        MappingJackson2HttpMessageConverter messageConverter = new MappingJackson2HttpMessageConverter();\n        //设置对象转换器，底层使用Jackson将Java对象转为json\n        messageConverter.setObjectMapper(new JacksonObjectMapper());\n        //将上面的消息转换器对象追加到mvc框架的转换器集合中\n        converters.add(0,messageConverter);\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220628213053-vcg932s","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220628213053-vcg932s","updated":"20220628213123"},"Children":[{"Type":"NodeText","Data":"编辑员工信息"}]},{"ID":"20220628213131-c3yc2vp","Type":"NodeParagraph","Properties":{"id":"20220628213131-c3yc2vp","updated":"20220628213132"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628213132-nf1jlk2.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220628213224-4190xec","Type":"NodeParagraph","Properties":{"id":"20220628213224-4190xec","updated":"20220629083020"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220628213224-idp09dc.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":" "}]},{"ID":"20220629083400-pid9qa4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629083400-pid9qa4"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    @PutMapping\n    public R\u003cString\u003e update(HttpServletRequest request,@RequestBody Employee employee){\n        log.info(employee.toString());\n\n        Long empID = (Long) request.getSession().getAttribute(\"employee\");\n        employee.setUpdateTime(LocalDateTime.now());\n        employee.setUpdateUser(empID);\n        employeeService.updateById(employee);\n\n        return R.success(\"员工信息修改成功\");\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629083440-71ppjk5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220629083440-71ppjk5","updated":"20220629083458"},"Children":[{"Type":"NodeText","Data":"公共字段自动填充"}]},{"ID":"20220629083414-q65cs1r","Type":"NodeParagraph","Properties":{"id":"20220629083414-q65cs1r","updated":"20220629083434"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629083434-ejz03j3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629100458-3k3hlfr","Type":"NodeParagraph","Properties":{"id":"20220629100458-3k3hlfr","updated":"20220629100509"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629100509-rkswxv2.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629100510-m4asuje","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220629100510-m4asuje","updated":"20220629103640"},"Children":[{"Type":"NodeText","Data":"BaseContext"}]},{"ID":"20220629103632-xa7cqy0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629103632-xa7cqy0"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 基于ThreadLocal封装工具类，用户保存和获取当前登录用户id\n */\npublic class BaseContext {\n        private static ThreadLocal\u003cLong\u003e threadLocal = new ThreadLocal\u003c\u003e();\n\n        /**\n         * 设置值\n         * @param id\n         */\n        public static void setCurrentId(Long id){\n                threadLocal.set(id);\n        }\n\n        /**\n         * 获取值\n         * @return\n         */\n        public static Long getCurrentId(){\n                return threadLocal.get();\n        }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629103645-3no00h8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220629103645-3no00h8","updated":"20220629103757"},"Children":[{"Type":"NodeText","Data":"获取id"}]},{"ID":"20220629103753-7mrukoo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629103753-7mrukoo"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"        //4.判断登录状态，如果已经登录，则直接放行\n        if(request.getSession().getAttribute(\"employee\")!=null){\n            log.info(\"用户已登录，用户id为：{}\",request.getSession().getAttribute(\"employee\"));\n\n            Long empId = (Long) request.getSession().getAttribute(\"employee\");\n            BaseContext.setCurrentId(empId);\n\n            long id = Thread.currentThread().getId();\n            log.info(\"线程id为:{}\",id);\n\n            filterChain.doFilter(request, response);\n            return;\n        }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629103841-g1seazo","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220629103841-g1seazo","updated":"20220629103846"},"Children":[{"Type":"NodeText","Data":"新增分类"}]},{"ID":"20220629103836-lscx2r0","Type":"NodeParagraph","Properties":{"id":"20220629103836-lscx2r0","updated":"20220629103837"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629103837-85fapk9.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629103850-mhc19wf","Type":"NodeParagraph","Properties":{"id":"20220629103850-mhc19wf","updated":"20220629104303"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629104303-h0e1esg.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629104305-d1zjs1t","Type":"NodeParagraph","Properties":{"id":"20220629104305-d1zjs1t"}},{"ID":"20220629134321-111a43x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629134321-111a43x"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@RestController\n@RequestMapping(\"/category\")\n@Slf4j\npublic class CategoryController {\n\n    @Autowired\n    private CategoryService categoryService;\n\n\n    /**\n     * 新增分类\n     * @param category\n     * @return\n     */\n    @PostMapping\n    public R\u003cString\u003e save(@RequestBody Category category){\n        log.info(\"category:{}\",category);\n        categoryService.save(category);\n        return R.success(\"新增分类成功\");\n\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629134351-ionzx17","Type":"NodeParagraph","Properties":{"id":"20220629134351-ionzx17","updated":"20220629134352"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629134352-1jjcxhw.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629150340-w2adgd9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629150340-w2adgd9"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 菜品分类查询\n     * @param page\n     * @param pageSize\n     * @return\n     */\n    @GetMapping(\"/page\")\n    public R\u003cPage\u003e page(int page, int pageSize){\n        //分页构造器\n        Page\u003cCategory\u003e pageInfo = new Page\u003c\u003e(page, pageSize);\n        //条件构造器\n        LambdaQueryWrapper\u003cCategory\u003e queryWrapper = new LambdaQueryWrapper\u003c\u003e();\n        //添加排序条件，根据sort进行排序\n        queryWrapper.orderByAsc(Category::getSort);\n\n        //进行分页查询\n        categoryService.page(pageInfo, queryWrapper);\n\n        return R.success(pageInfo);\n    }\n}"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629150354-zhc7cdm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220629150354-zhc7cdm","updated":"20220629150400"},"Children":[{"Type":"NodeText","Data":"删除分类"}]},{"ID":"20220629150345-lil71v7","Type":"NodeParagraph","Properties":{"id":"20220629150345-lil71v7","updated":"20220629150350"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629150350-64wxxuf.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629153206-uldaldf","Type":"NodeParagraph","Properties":{"id":"20220629153206-uldaldf","updated":"20220629153207"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629153206-72cxem9.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629153211-2h4rqtd","Type":"NodeParagraph","Properties":{"id":"20220629153211-2h4rqtd"}},{"ID":"20220629164923-5x4jzvr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629164923-5x4jzvr"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Service\npublic class CategoryServiceImpl extends ServiceImpl \u003cCategoryMapper, Category\u003e implements CategoryService {\n\n    @Autowired\n    private DishService dishService;\n\n    @Autowired\n    private SetmealService setmealService;\n    /**\n     * 根据id删除分类，删除之气那需要进行判断\n     * @param id\n     */\n    public void remove(Long id){\n        LambdaQueryWrapper\u003cDish\u003e dishlambdaQueryWrapper = new LambdaQueryWrapper\u003c\u003e();\n        //添加查询条件i，根据分类id进行查询\n        dishlambdaQueryWrapper.eq(Dish::getCategoryId,id);\n        int count1 = dishService.count(dishlambdaQueryWrapper);\n\n\n        //查询当前分类是否关联了菜品，如果已经关联，抛出一个业务异常\n        if(count1 \u003e 0){\n            //已经关联了，抛出一个业务异常\n            throw new CustomException(\"当前分类下关联了菜品，不能删除\");\n        }\n\n        //查询当前分类是否关联了套餐，如果已经关联，抛出一个业务异常\n        LambdaQueryWrapper\u003cSetmeal\u003e setmeallambdaQueryWrapper = new LambdaQueryWrapper\u003c\u003e();\n        setmeallambdaQueryWrapper.eq(Setmeal::getCategoryId,id);\n        int count2 = setmealService.count(setmeallambdaQueryWrapper);\n        if(count2 \u003e 0){\n            //已经关联套餐，抛出一个业务一场\n            throw new CustomException(\"当前分类下关联了套餐，不能删除\");\n\n        }\n\n        //正常删除分癸\n        super.removeById(id);\n    }\n}"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629164925-wa40wxt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220629164925-wa40wxt","updated":"20220629164956"},"Children":[{"Type":"NodeText","Data":"修改分类"}]},{"ID":"20220629164958-0igi5d3","Type":"NodeParagraph","Properties":{"id":"20220629164958-0igi5d3","updated":"20220629164959"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220629164959-unprl32.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220629165037-2wjacnm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220629165037-2wjacnm"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 修改分类\n     * @param category\n     * @return\n     */\n    public R\u003cString\u003e update(@RequestBody Category category){\n        log.info(\"修改分类信息\");\n\n        categoryService.updateById(category);\n\n        return R.success(\"修改分类成功\");\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220629165043-jddggcz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220629165043-jddggcz","updated":"20220630084353"},"Children":[{"Type":"NodeText","Data":"菜品管理业务开发"}]},{"ID":"20220630084357-so9jk4t","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220630084357-so9jk4t","updated":"20220630084418"},"Children":[{"Type":"NodeText","Data":"文件上传下载"}]},{"ID":"20220630194751-3k02msd","Type":"NodeParagraph","Properties":{"id":"20220630194751-3k02msd","updated":"20220630194754"},"Children":[{"Type":"NodeText","Data":"增加路径"}]},{"ID":"20220630194754-752ca3q","Type":"NodeParagraph","Properties":{"id":"20220630194754-752ca3q","updated":"20220630194755"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220630194755-349v3nk.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220630194731-j0nvg1k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220630194731-j0nvg1k"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 文件上传\n     * @param file\n     * @return\n     */\n    @PostMapping(\"/upload\")\n    public R\u003cString\u003e upload(MultipartFile file){\n        log.info(file.toString());\n\n        //原始文件名\n        String originalFilename = file.getOriginalFilename();\n        String suffix = originalFilename.substring(originalFilename.lastIndexOf(\".\"));\n\n\n        //使用UUID重新生成文件名，防止文件名重复造成文件覆盖\n        String fileName = UUID.randomUUID().toString() + suffix; //dsfg.jpg\n\n\n        //创建一个目录对象\n        File dir = new File(basePath);\n        //判断当前目录是否存在\n        if(!dir.exists()){\n            //目录不存在，需要创建\n            dir.mkdirs();\n        }\n        try {\n            //将临时文件转存到指定位置\n            file.transferTo(new File(basePath+originalFilename));\n        } catch (IOException e) {\n            e.printStackTrace();\n        }\n\n        return null;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220630200734-srvtcks","Type":"NodeParagraph","Properties":{"id":"20220630200734-srvtcks"}},{"ID":"20220630200805-v3cp2vx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220630200805-v3cp2vx"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 上传下载\n     * @param name\n     * @param response\n     */\n    public void download(String name, HttpServletResponse response){\n        //输入流，通过输入流读取文件内容\n        try {\n            FileInputStream fileInputStream = new FileInputStream(new File(basePath + name));\n        //输出流，通过输出流将文件写回浏览器，在浏览器战士图片\n            ServletOutputStream outputStream = response.getOutputStream();\n\n            response.setContentType(\"image/jpeg\");\n\n            int len = 0;\n            byte[] bytes = new byte[1024];\n            while ((len = fileInputStream.read(bytes)) != -1){\n                outputStream.write(bytes,0,len);\n                outputStream.flush();\n            }\n\n            //关闭资源\n            outputStream.close();\n            fileInputStream.close();\n\n        } catch (Exception e) {\n            e.printStackTrace();\n        }\n\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220630084418-b1zluta","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220630084418-b1zluta","updated":"20220630084423"},"Children":[{"Type":"NodeText","Data":"新增菜品"}]},{"ID":"20220630203836-espw8ui","Type":"NodeParagraph","Properties":{"id":"20220630203836-espw8ui","updated":"20220630203837"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220630203836-jrufm4v.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220630203852-9lzqreq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220630203852-9lzqreq"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 根据条件查询分类数据\n     * @param category\n     * @return\n     */\n    @GetMapping(\"/list\")\n    private R\u003cList\u003cCategory\u003e\u003e list(Category category){\n        //条件构造器\n        LambdaQueryWrapper\u003cCategory\u003e queryWrapper = new LambdaQueryWrapper\u003c\u003e();\n        //添加条件\n        queryWrapper.eq(category.getType()!=null,Category::getType,category.getType());\n        //添加排序条件\n        queryWrapper.orderByAsc(Category::getSort).orderByDesc(Category::getUpdateTime);\n\n        List\u003cCategory\u003e list = categoryService.list(queryWrapper);\n\n        return R.success(list);\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220630084741-6g5dnnc","Type":"NodeParagraph","Properties":{"id":"20220630084741-6g5dnnc","updated":"20220706083825"},"Children":[{"Type":"NodeText","Data":"控制层"}]},{"ID":"20220706083543-rze3eb1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706083543-rze3eb1","updated":"20220706083755"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 菜品管理\n */\n@Slf4j\n@RequestMapping(\"/dish\")\n@RestController\npublic class DishController {\n    @Autowired\n    private DishService dishService;\n\n    @Autowired\n    private DishFlavorService dishFlavorService;\n\n    /**\n     * 新增菜品\n     * @param dishDto\n     * @return\n     */\n    @PostMapping\n    public R\u003cString\u003e save(@RequestBody DishDto dishDto){\n        log.info(dishDto.toString());\n\n        dishService.saveWithFlavor(dishDto);\n\n        return R.success(\"新增菜品成功\");\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706083724-49g5myb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706083724-49g5myb","updated":"20220706083807"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public interface DishService extends IService\u003cDish\u003e {\n\n    //新增菜品，同时插入菜品对应的口味数据，需要操作两张表：dish、dish_flavor\n    public void saveWithFlavor(DishDto dishDto);\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706083608-rbi3zr6","Type":"NodeParagraph","Properties":{"id":"20220706083608-rbi3zr6","updated":"20220706083632"},"Children":[{"Type":"NodeText","Data":"实现层"}]},{"ID":"20220706083626-37wpryx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706083626-37wpryx"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Service\n@Slf4j\npublic class DishServiceImpl extends ServiceImpl\u003cDishMapper, Dish\u003e implements DishService {\n\n    @Autowired\n    private DishFlavorService dishFlavorService;\n\n    /**\n     * 新增菜品，同时保存对应的口味数据\n     * @param dishDto\n     */\n    @Transactional\n    public void saveWithFlavor(DishDto dishDto) {\n        //保存菜品的基本信息到菜品表dish\n        this.save(dishDto);\n\n        Long dishId = dishDto.getId();//菜品id\n\n        //菜品口味\n        List\u003cDishFlavor\u003e flavors = dishDto.getFlavors();\n\n        flavors = flavors.stream().map((item) -\u003e {\n            item.setDishId(dishId);\n            return item;\n        }).collect(Collectors.toList());\n\n\n        //保存到菜品口味数据到菜品口味表dish_flavor\n        dishFlavorService.saveBatch(dishDto.getFlavors());\n\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706083953-e6xy5d7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220706083953-e6xy5d7","updated":"20220706084003"},"Children":[{"Type":"NodeText","Data":"菜品信息分页查询"}]},{"ID":"20220706101218-x7yyl2v","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706101218-x7yyl2v"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":" /**\n     * 分页查询\n     * @param page\n     * @param pageSize\n     * @param name\n     * @return\n     */\n    @GetMapping(\"/page\")\n    public R\u003cPage\u003e pageR(int page,int pageSize,String name){\n\n        //构造分页构造器对象\n        Page\u003cDish\u003e pageInfo = new Page\u003c\u003e(page, pageSize);\n\n        Page\u003cDishDto\u003e dishDtoPage = new Page\u003c\u003e();\n\n        //条件构造器\n        LambdaQueryWrapper\u003cDish\u003e queryWrapper = new LambdaQueryWrapper\u003c\u003e();\n\n        //添加过滤条件\n        queryWrapper.like(name!=null,Dish::getName,name);\n\n        //添加排序条件\n        queryWrapper.orderByDesc(Dish::getUpdateTime);\n\n        //执行分页查询\n        dishService.page(pageInfo,queryWrapper);\n\n        //对象拷贝\n        BeanUtils.copyProperties(pageInfo,dishDtoPage,\"records\");\n\n        List\u003cDish\u003e records = pageInfo.getRecords();\n\n        List\u003cDishDto\u003e list = records.stream().map((item) -\u003e {\n            DishDto dishDto = new DishDto();\n            BeanUtils.copyProperties(item, dishDto);\n            Long categoryId = item.getCategoryId();//分类id\n            //根据id查询分类对象\n            Category category = categoryService.getById(categoryId);\n\n            if(category != null){\n                String categoryName = category.getName();\n                dishDto.setCategoryName(categoryName);\n            }\n\n\n            return dishDto;\n        }).collect(Collectors.toList());\n\n        dishDtoPage.setRecords(list);\n\n        return R.success(dishDtoPage);\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220630084430-rh8nyie","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220630084430-rh8nyie","updated":"20220630084432"},"Children":[{"Type":"NodeText","Data":"修改菜品"}]},{"ID":"20220706084006-ytiur3t","Type":"NodeParagraph","Properties":{"id":"20220706084006-ytiur3t","updated":"20220706145421"},"Children":[{"Type":"NodeText","Data":"接口"}]},{"ID":"20220706145425-2p15mjv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706145425-2p15mjv","updated":"20220706145432"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    //更新菜品信息，同时更新对应的口味信息\n    public void updateWithFlavor(DishDto dishDto);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706145432-3k343xy","Type":"NodeParagraph","Properties":{"id":"20220706145432-3k343xy","updated":"20220706145442"},"Children":[{"Type":"NodeText","Data":"控制层"}]},{"ID":"20220706145447-wzmabhi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706145447-wzmabhi"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 修改菜品\n     * @param dishDto\n     * @return\n     */\n    @PutMapping\n    public R\u003cString\u003e update(@RequestBody DishDto dishDto){\n        log.info(dishDto.toString());\n\n        dishService.updateWithFlavor(dishDto);\n\n        return R.success(\"新增菜品成功\");\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706145451-m8zvcm6","Type":"NodeParagraph","Properties":{"id":"20220706145451-m8zvcm6","updated":"20220706145514"},"Children":[{"Type":"NodeText","Data":"服务层"}]},{"ID":"20220706145515-lceatou","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220706145515-lceatou"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    @Transactional\n    public void updateWithFlavor(DishDto dishDto) {\n        //更新dish表基本信息\n        this.updateById(dishDto);\n        //清理当前菜品对应口味数据---dish_flavor表的delete操作\n        LambdaQueryWrapper\u003cDishFlavor\u003e queryWrapper = new LambdaQueryWrapper();\n        queryWrapper.eq(DishFlavor::getDishId,dishDto.getId());\n        dishFlavorService.remove(queryWrapper);\n\n        //添加当前提交过来的口味数据---dish_flavor表的insert操作\n        List\u003cDishFlavor\u003e flavors = dishDto.getFlavors();\n\n        flavors = flavors.stream().map((item) -\u003e {\n            item.setDishId(dishDto.getId());\n            return item;\n        }).collect(Collectors.toList());\n\n        dishFlavorService.saveBatch(flavors);\n    }"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706145606-eumv2l5","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220706145606-eumv2l5","updated":"20220706145623"},"Children":[{"Type":"NodeText","Data":"套餐管理业务开发"}]},{"ID":"20220707092004-luovb2h","Type":"NodeParagraph","Properties":{"id":"20220707092004-luovb2h","updated":"20220707092005"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220707092005-1eiahnw.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220707092506-rjm5wyf","Type":"NodeParagraph","Properties":{"id":"20220707092506-rjm5wyf","updated":"20220707092506"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220707092506-evj7wlr.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220706145625-630a978","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220706145625-630a978","updated":"20220706145732"},"Children":[{"Type":"NodeText","Data":"新增套餐"}]},{"ID":"20220710154512-xl1gucp","Type":"NodeParagraph","Properties":{"id":"20220710154512-xl1gucp","updated":"20220710154526"},"Children":[{"Type":"NodeText","Data":"控制层"}]},{"ID":"20220710154527-xnr7nek","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220710154527-xnr7nek","updated":"20220710154603"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@RestController\n@RequestMapping(\"/setmeal\")\n@Slf4j\npublic class SetmealController {\n\n    @Autowired\n    private SetmealService setmealService;\n\n    @Autowired\n    private SetmealDishService setmealDishService;\n\n    /**\n     * 新增套餐\n     * @param setmealDto\n     * @return\n     */\n    @PostMapping\n    public R\u003cString\u003e save(@RequestBody SetmealDto setmealDto){\n        log.info(\"套餐信息：{}\",setmealDto);\n\n        setmealService.saveWithDish(setmealDto);\n\n        return R.success(\"新增套餐成功\");\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220710154532-5y5b9v6","Type":"NodeParagraph","Properties":{"id":"20220710154532-5y5b9v6","updated":"20220710154537"},"Children":[{"Type":"NodeText","Data":"服务层"}]},{"ID":"20220710154547-5l82zw0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220710154547-5l82zw0","updated":"20220710154605"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Service\n@Slf4j\npublic class SetmealServiceImpl extends ServiceImpl\u003cSetmealMapper, Setmeal\u003e implements SetmealService {\n\n    @Autowired\n    private SetmealDishService setmealDishService;\n\n    @Transactional\n    public void saveWithDish(SetmealDto setmealDto){\n        //保存套餐的基本信息，操作setmeal，执行insert操作\n        this.save(setmealDto);\n\n        List\u003cSetmealDish\u003e setmealDishes = setmealDto.getSetmealDishes();\n        setmealDishes.stream().map((item)-\u003e{\n            item.setSetmealId(setmealDto.getId());\n            return item;\n        }).collect(Collectors.toList());\n        //保存套餐和菜品的关联信息，操作setmeal_dish执行insert操作\n        setmealDishService.saveBatch(setmealDishes);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220710154533-rwtdw6g","Type":"NodeParagraph","Properties":{"id":"20220710154533-rwtdw6g","updated":"20220710154557"},"Children":[{"Type":"NodeText","Data":"接口"}]},{"ID":"20220710154558-sgodh6p","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220710154558-sgodh6p","updated":"20220710154607"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public interface SetmealService extends IService\u003cSetmeal\u003e {\n\n    /**\n     * 新增套餐，同时需要保存套餐和菜品的关联关系\n     * @param setmealDto\n     */\n    public void saveWithDish(SetmealDto setmealDto);\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220706145733-mlkojkz","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220706145733-mlkojkz","updated":"20220706145740"},"Children":[{"Type":"NodeText","Data":"套餐信息分页查询"}]},{"ID":"20220706145740-38gyxvq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220706145740-38gyxvq","updated":"20220706145744"},"Children":[{"Type":"NodeText","Data":"删除套餐"}]},{"ID":"20220710154504-ic93dm8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220710154504-ic93dm8","updated":"20220711140818"},"Children":[{"Type":"NodeText","Data":"导入用户地址簿相关功能代码"}]},{"ID":"20220711140819-dpr98u3","Type":"NodeParagraph","Properties":{"id":"20220711140819-dpr98u3"}},{"ID":"20220904153541-4n8rywr","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220904153541-4n8rywr","updated":"20220904153558"},"Children":[{"Type":"NodeText","Data":"使用Mybatis重构项目"}]},{"ID":"20220904153600-ag934lb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220904153600-ag934lb","updated":"20220904153611"},"Children":[{"Type":"NodeText","Data":"配置文件"}]},{"ID":"20220904153638-s63pge7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904153638-s63pge7","updated":"20220904153801"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"server:\n  port: 8080\nspring:\n#  reids:\n#    host: localhost\n#    port: 6379\n#    #password\n#    database: 0  # 操作的是0号数据库，默认第一个数据库为0号和数组一样\n#  cache:\n#    redis:\n#      time-to-live: 18000000\n  application:\n    #配置应用名称，可选\n    name: DepartmentStoreSaleSystem # 就是项目的名字即根文件夹名称\n  datasource:\n    druid:\n      driver-class-name: com.mysql.cj.jdbc.Driver\n      url: jdbc:mysql://localhost:3306/reggie?serverTimezone=Asia/Shanghai\u0026useUnicode=true\u0026characterEncoding=utf-8\u0026zeroDateTimeBehavior=convertToNull\u0026useSSL=false\u0026allowPublicKeyRetrieval=true\n      username: root\n      password: root\n\n#mybatis-plus:\n#  configuration:\n#    #在映射实体或者属性时，将数据库中表名和字段名中的下划线去掉，按照驼峰命名法映射\n#    #比如user_name---\u003eUserName\n#    map-underscore-to-camel-case: true\n#    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl\n#  global-config:\n#    db-config:\n#      id-type: ASSIGN_ID\nmybatis: # 配置mybatis\n  mapper-Locations: classpath:mapper/*.xml #mapper映射目录 这里mapper就是文件夹名\n  type-aliases-package: com.xia.departmentstoresalesystem.entity # 实体类的文件夹\n  configuration:\n    map-underscore-to-camel-case: true #开启驼峰映射\n\nreggie:\n  path: D:\\\\reggie\\\\\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904153805-t1043sn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220904153805-t1043sn","updated":"20220904163341"},"Children":[{"Type":"NodeText","Data":"用户登录，SQL查找对应字段并进行匹配"}]},{"ID":"20220904154033-a9muw84","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904154033-a9muw84","updated":"20220904154156"},"Children":[{"Type":"NodeText","Data":"mapper接口"}]},{"ID":"20220904154106-q1cn143","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904154106-q1cn143","updated":"20220904154129"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Mapper\npublic interface employeeMapper {\n    //查询用户\n    public Employee queryAll(Employee employee);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205623-2weddpo","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904205623-2weddpo","updated":"20220904205626"},"Children":[{"Type":"NodeText","Data":"xml"}]},{"ID":"20220904205629-ctfvvlg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904205629-ctfvvlg","updated":"20220904205642"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cselect id=\"queryAll\" resultType=\"com.xia.departmentstoresalesystem.entity.Employee\"\u003e\n        select * from reggie.employee where username=#{username}\n    \u003c/select\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904154037-cvnfnk4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904154037-cvnfnk4","updated":"20220904154153"},"Children":[{"Type":"NodeText","Data":"service接口"}]},{"ID":"20220904154130-9kei3sx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904154130-9kei3sx","updated":"20220904154159"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public interface employeeService {\n    public Employee queryAll(Employee employee);\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904154054-kwfr1j2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904154054-kwfr1j2","updated":"20220904205612"},"Children":[{"Type":"NodeText","Data":"serviceImpl"}]},{"ID":"20220904154212-dg8hm5j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904154212-dg8hm5j","updated":"20220904154213"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Service\n@Transactional\npublic class employeeServiceImpl implements employeeService {\n    @Autowired\n    employeeMapper employeeMapper;\n    @Override\n    public Employee queryAll(Employee employee) {\n        return employeeMapper.queryAll(employee);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904154100-g5ylicm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904154100-g5ylicm","updated":"20220904163141"},"Children":[{"Type":"NodeText","Data":"employeeController"}]},{"ID":"20220904154227-5q5kvez","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904154227-5q5kvez","updated":"20220904155108"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"@Controller\n@RequestMapping(\"/employee\")\n@ResponseBody\npublic class employeeController {\n    @Autowired\n    employeeService employeeservice;\n    /**\n     * 员工登录\n     * @param employee\n     * @param request\n     * @return\n     */\n    @PostMapping(\"/login\")\n    public R\u003cEmployee\u003e login(@RequestBody Employee employee, HttpServletRequest request){\n        String password = employee.getPassword();//这里的RequestBody作用是将页面中输入的密码以json格式传给后端\n        password = DigestUtils.md5DigestAsHex(password.getBytes());//加密\n        Employee employ = new Employee(); // new一个新的employee\n        employ.setUsername(employee.getUsername()); // 将页面中获取到的username写入对象\n        Employee employeeResult = employeeservice.queryAll(employ); // 查询数据库中对应的username字段行\n\n        if(employeeResult==null){\n            return R.error(\"用户不存在\");\n        }\n        if(!Objects.equals(employeeResult.getPassword(), password)){\n             return R.error(\"密码不正确\");\n        }\n        if(employeeResult.getStatus()==0){\n            return R.error(\"用户不可用\");\n        }\n        System.out.println(\"密码正确\");\n        request.getSession().setAttribute(\"employee\", employeeResult.getId()); //将用户id存入session\n        return R.success(employeeResult);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904163058-ev4amw1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220904163058-ev4amw1","updated":"20220904163101"},"Children":[{"Type":"NodeText","Data":"退出功能"}]},{"ID":"20220904163119-6fj0b7k","Type":"NodeBlockquote","Properties":{"id":"20220904163119-6fj0b7k","updated":"20220904163152"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220904163149-5d2t4os","Type":"NodeParagraph","Properties":{"id":"20220904163149-5d2t4os","updated":"20220904163152"},"Children":[{"Type":"NodeText","Data":"写在employeeController"}]}]},{"ID":"20220904163154-ffixmve","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904163154-ffixmve","updated":"20220904163200"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    /**\n     * 退出功能\n     * @param request\n     * @return\n     */\n    @PostMapping(\"/logout\")\n    public R\u003cString\u003e logout(HttpServletRequest request){\n        //将存在页面session中的信息清除，并返回R.success，因为success会令status为让code等于1，而前端中index有判断code为1会跳转至登陆界面\n        request.getSession().removeAttribute(\"employee\");\n        return R.success(\"退出成功\");\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904172956-ux1lt8t","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220904172956-ux1lt8t","updated":"20220904173009"},"Children":[{"Type":"NodeText","Data":"后台管理用户"}]},{"ID":"20220904173010-cir33j4","Type":"NodeParagraph","Properties":{"id":"20220904173010-cir33j4","updated":"20220904173210"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 17%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220904173011-w3de69k.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 17%;\"}"}]},{"ID":"20220904173135-tvu6yjm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904173135-tvu6yjm","updated":"20220904182657"},"Children":[{"Type":"NodeText","Data":"完善登录功能——过滤器"}]},{"ID":"20220904173142-anh8s8b","Type":"NodeParagraph","Properties":{"id":"20220904173142-anh8s8b","updated":"20220904173525"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 33%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220904173143-rcj8cx8.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 33%;\"}"},{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 67%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220904173508-9bbqxup.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 67%;\"}"}]},{"ID":"20220904173024-dms0d82","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904173024-dms0d82","updated":"20220904182703"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//检查用户是否已经完成登录,注意要在启动类上添加@ServletComponentScan\n@Slf4j\n@WebFilter(filterName = \"LoginCheckFilter\",urlPatterns = \"/*\") //表示所有请求都拦截\npublic class LoginCheckFilter implements Filter{\n    //路径匹配器，支持通配符\n    public static final AntPathMatcher PATH_MATCHER =  new AntPathMatcher();\n    @Override\n    public void doFilter(ServletRequest servletRequest, ServletResponse servletResponse, FilterChain filterChain) throws IOException, ServletException {\n        HttpServletRequest request = (HttpServletRequest) servletRequest;\n        HttpServletResponse response = (HttpServletResponse) servletResponse;\n        //1.获取本次请求的URI\n        String requestURI = request.getRequestURI();\n        String[] urls = new String[]{\n            \"/employee/login\",\n            \"/employee/logout\",\n            \"/backend/**\",\n            \"/front/**\"\n        }; //不需要处理的请求路径\n\n        //2.判断本次请求是否需要处理\n        boolean check = check(urls, requestURI);\n        //3. 如果不需要处理，则直接放行\n        if(check){\n            log.info(\"本次请求{}不需要处理\",requestURI);\n            filterChain.doFilter(request, response);\n            return;\n        }\n        //4.判断登陆状态，如果已登录，则直接放行\n        if(request.getSession().getAttribute(\"employee\")!= null){\n            log.info(\"用户已登录，用户id为{}\",request.getSession().getAttribute(\"employee\"));//获取session中的id\n            filterChain.doFilter(request,response);\n            return;\n        }\n        log.info(\"用户未登录\");\n        //5.如果未登录则返回未登录结果，通过输出流方式向客户端页面响应数据\n        response.getWriter().write(JSON.toJSONString(R.error(\"NOTLOGIN\")));\n        return; //跳转回登陆界面\n    }\n    // 路径匹配，检查本次请求是否需要放行\n    public boolean check(String[] urls,String requestURI){\n        for (String url:urls){\n            boolean match = PATH_MATCHER.match(url, requestURI);\n            if(match){\n                return true;\n            }\n        }\n        return false;\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904182659-pig3hdd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904182659-pig3hdd","updated":"20220904182716"},"Children":[{"Type":"NodeText","Data":"新增员工"}]},{"ID":"20220904182717-67nl1es","Type":"NodeParagraph","Properties":{"id":"20220904182717-67nl1es","updated":"20220904191121"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 67%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220904191116-9trblh4.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 67%;\"}"}]},{"ID":"20220904205556-ne1446b","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904205556-ne1446b","updated":"20220904205735"},"Children":[{"Type":"NodeText","Data":"mapper"}]},{"ID":"20220904205819-udq9qqz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904205819-udq9qqz","updated":"20220904210039"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"//新增员工\nvoid addEmployee(Employee employee);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205816-r0hke03","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904205816-r0hke03","updated":"20220904205817"},"Children":[{"Type":"NodeText","Data":"xml"}]},{"ID":"20220904205835-v54xg3j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904205835-v54xg3j","updated":"20220904210212"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cinsert id=\"addEmployee\" parameterType=\"com.xia.departmentstoresalesystem.entity.Employee\"\u003e\n        insert into reggie.employee(id,username,name,phone,sex,id_number,password,create_time,update_time,create_user,update_user)\n        values(#{id},#{username},#{name},#{phone},#{sex},#{idNumber},#{password},#{createTime},#{updateTime},#{createUser},#{updateUser})\n    \u003c/insert\u003e\n\u003c!--注意，valuse字段和实体类一样，上面一行的和sql字段一样--\u003e\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205737-ekgxn5z","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904205737-ekgxn5z","updated":"20220904205742"},"Children":[{"Type":"NodeText","Data":"service接口"}]},{"ID":"20220904205837-fhppb86","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904205837-fhppb86","updated":"20220904210047"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"void addEmployee(Employee employee);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205743-bdr0hq4","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904205743-bdr0hq4","updated":"20220904205746"},"Children":[{"Type":"NodeText","Data":"serviceImpl"}]},{"ID":"20220904210055-5isqni8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904210055-5isqni8","updated":"20220904210055"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    //添加员工\n    @Override\n    public void addEmployee(Employee employee) {\n        employeeMapper.addEmployee(employee);\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205747-1wgovlb","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904205747-1wgovlb","updated":"20220904205811"},"Children":[{"Type":"NodeText","Data":"controller"}]},{"ID":"20220904210100-uq4rbt9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904210100-uq4rbt9","updated":"20220904210109"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    @PostMapping()\n    public R\u003cString\u003e addEmployee(@RequestBody Employee employee, HttpServletRequest request){\n        log.info(\"新增员工，员工信息{}\",employee.toString());\n        String password = DigestUtils.md5DigestAsHex(\"123456\".getBytes());\n        employee.setPassword(password);\n        employee.setCreateTime(LocalDateTime.now());\n        employee.setUpdateTime(LocalDateTime.now());\n        Long ID = (Long) request.getSession().getAttribute(\"employee\");//获取创建者的id\n        long randomNum = System.currentTimeMillis(); // 用于定义用户id\n        employee.setId(randomNum);\n        employee.setCreateUser(ID);\n        employee.setUpdateUser(ID);\n        employeeservice.addEmployee(employee);\n        return R.success(\"添加成功\");\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904205813-9y44qtr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904205813-9y44qtr","updated":"20220904210411"},"Children":[{"Type":"NodeText","Data":"全局异常——避免名字重复"}]},{"ID":"20220904210320-3tkkw3a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904210320-3tkkw3a","updated":"20220904210332"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 全局异常处理\n */\n@ControllerAdvice(annotations = {RestController.class, Controller.class})\n@ResponseBody\n@Slf4j\npublic class GlobalExceptionHandler {\n    /**\n     * 异常处理方法\n     * @return\n     */\n    @ExceptionHandler(SQLIntegrityConstraintViolationException.class)\n    public R\u003cString\u003e exceptionHandler(SQLIntegrityConstraintViolationException ex){\n        log.error(ex.getMessage());\n\n        if(ex.getMessage().contains(\"Duplicate entry\")){\n            String[] split = ex.getMessage().split(\" \");\n            String msg = split[2] + \"已存在\";\n            return R.error(msg);\n\n        }\n        return R.error(\"未知错误\");\n    }\n\n    /**\n     * 异常处理方法\n     * @return\n     */\n    @ExceptionHandler(CustomException.class)\n    public R\u003cString\u003e exceptionHandler(CustomException ex){\n        log.error(ex.getMessage());\n        return R.error(ex.getMessage());\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904210330-egtr8nc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904210330-egtr8nc","updated":"20220904210348"},"Children":[{"Type":"NodeText","Data":"自定义业务类"}]},{"ID":"20220904210349-sloxx9w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220904210349-sloxx9w","updated":"20220904210353"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 自定义业务异常类\n */\npublic class CustomException extends RuntimeException{\n    public CustomException(String message){\n        super(message);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220904210356-axd50pg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220904210356-axd50pg","updated":"20220904210604"},"Children":[{"Type":"NodeText","Data":"员工信息分页查询"}]},{"ID":"20220904210608-gq3nu2z","Type":"NodeParagraph","Properties":{"id":"20220904210608-gq3nu2z","updated":"20220904210616"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220904210608-zhbxkc7.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20220904210617-dw6utbc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220904210617-dw6utbc","updated":"20220905145040"},"Children":[{"Type":"NodeText","Data":"1.构建通用分页类"}]},{"ID":"20220905145159-vndrbde","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905145159-vndrbde","updated":"20220905145658"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class PageBean\u003cT\u003e {\n    private Integer pageno;  //第几页\n    private Integer pagesize; //每页条数\n    private List\u003cT\u003e datas;\n    private Integer totalno; //总共几页\n    private Integer totalsize; //总的条数\n// 用于判断回显的页码\n    public PageBean(Integer pageno, Integer pagesize) {\n        if(pageno\u003c=0){\n            this.pageno = 1;\n        }else{\n            this.pageno = pageno;\n        }\n        if(pagesize\u003c=0){\n            this.pagesize = 10;\n        }else{\n            this.pagesize = pagesize;\n        }\n        this.pageno = pageno;\n        this.pagesize = pagesize;\n    }\n\n    public Integer getPageno() {\n        return pageno;\n    }\n\n    public void setPageno(Integer pageno) {\n        this.pageno = pageno;\n    }\n\n    public Integer getPagesize() {\n        return pagesize;\n    }\n\n    public void setPagesize(Integer pagesize) {\n        this.pagesize = pagesize;\n    }\n\n    public List getDatas() {\n        return datas;\n    }\n\n    public void setDatas(List datas) {\n        this.datas = datas;\n    }\n\n    public Integer getTotalno() {\n        return totalno;\n    }\n\n    public void setTotalno(Integer totalno) {\n        this.totalno = totalno;\n    }\n\n    public Integer getTotalsize() {\n        return totalsize;\n    }\n// 用于判断需要的页数，思路：用查询到的总数余数每页可显示数量 给出总页数\n    public void setTotalsize(Integer totalsize) {\n        this.totalno = (totalsize%pagesize==0)?(totalsize/pagesize):(totalsize/pagesize+1);\n        this.totalsize = totalsize;\n    }\n\n    /**\n     * 开始索引，如果第二页那索引开始位置就是第一页的数量(索引从0开始的)\n     */\n    public Integer getStartIndex(){\n        return (this.pageno-1)*this.pagesize;\n    }\n   \n    @Override\n    public String toString() {\n        return \"PageBean{\" +\n                \"pageno=\" + pageno +\n                \", pagesize=\" + pagesize +\n                \", datas=\" + datas +\n                \", totalno=\" + totalno +\n                \", totalsize=\" + totalsize +\n                '}';\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905145042-vlc110f","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220905145042-vlc110f","updated":"20220905145057"},"Children":[{"Type":"NodeText","Data":"2.mapper接口"}]},{"ID":"20220905145740-ec4rr2m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905145740-ec4rr2m","updated":"20220905145757"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    //界面回显所有用户\n    List\u003cEmployee\u003e queryEmployee(Map\u003cString, Object\u003e map);\n    //搜索栏的功能 用于查找总共数量\n    int queryCount(Map\u003cString, Object\u003e map);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905150135-8j5en21","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220905150135-8j5en21","updated":"20220905150143"},"Children":[{"Type":"NodeText","Data":"3.xml"}]},{"ID":"20220905150159-eqc01py","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905150159-eqc01py","updated":"20220905150205"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s"},{"Type":"NodeCodeBlockCode","Data":"    \u003cselect id=\"queryEmployee\" resultType=\"com.xia.departmentstoresalesystem.entity.Employee\"\u003e\n       select id,username,name,password,phone,sex,id_number,status,create_time,update_time,create_user,update_user from reggie.employee\n           \u003cwhere\u003e\n            \u003cif test=\"name!=null\"\u003e and name LIKE concat(\"%\",#{name},\"%\")\u003c/if\u003e\n           \u003c/where\u003e\n       order by update_time DESC\n       limit #{startIndex},#{pageSize}\n    \u003c/select\u003e\n\n    \u003cselect id=\"queryCount\" resultType=\"int\"\u003e\n        select count(*) from reggie.employee\n        \u003cwhere\u003e\n            \u003cif test=\"name!=null\"\u003e and name LIKE concat(\"%\",#{name},\"%\")\u003c/if\u003e\n        \u003c/where\u003e\n    \u003c/select\u003e\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905145057-41suj8a","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220905145057-41suj8a","updated":"20220905150147"},"Children":[{"Type":"NodeText","Data":"4.service接口"}]},{"ID":"20220905145807-5y23gdh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905145807-5y23gdh","updated":"20220905145809"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    PageBean\u003cEmployee\u003e queryPage(Map\u003cString, Object\u003e map);\n    int queryCount(Map\u003cString, Object\u003e map);\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905145106-wh35mnp","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220905145106-wh35mnp","updated":"20220905150148"},"Children":[{"Type":"NodeText","Data":"5.实现service"}]},{"ID":"20220905145811-bm1j6vw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905145811-bm1j6vw","updated":"20220905145854"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    // 回显所有用户\n    @Override\n    public PageBean\u003cEmployee\u003e queryPage(Map\u003cString, Object\u003e map) {\n        PageBean\u003cEmployee\u003e pageBean = new PageBean\u003c\u003e((Integer) map.get(\"page\"), (Integer) map.get(\"pageSize\"));\n        Integer startIndex = pageBean.getStartIndex();\n        map.put(\"startIndex\",startIndex);\n        List\u003cEmployee\u003e datas = employeeMapper.queryEmployee(map);\n        pageBean.setDatas(datas);\n\n        Integer totalsize = employeeMapper.queryCount(map);\n        pageBean.setTotalsize(totalsize);\n        return pageBean;\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905145120-3jmjfyw","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220905145120-3jmjfyw","updated":"20220905150150"},"Children":[{"Type":"NodeText","Data":"6.controller"}]},{"ID":"20220905145131-2ndj5wt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220905145131-2ndj5wt","updated":"20220905150737"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"    //分页查询\n    @GetMapping(\"/page\")\n    public R\u003cHashMap\u003cString, Object\u003e\u003e findAll(@RequestParam(value = \"page\")Integer page,\n                                     @RequestParam(value = \"pageSize\")Integer pageSize,\n                                      String name){\n        HashMap\u003cString, Object\u003e map = new HashMap\u003c\u003e();\n        map.put(\"page\",page);//从前端获取分页数量\n        map.put(\"pageSize\",pageSize);//从前端获取每页显示条数\n        if(StringUtils.hasText(name)){//判断搜索框中是否有name输入\n            map.put(\"name\",name);\n        }\n        PageBean\u003cEmployee\u003e pageBean = employeeservice.queryPage(map);//调用sql语句搜索合适的值\n        HashMap\u003cString, Object\u003e result = new HashMap\u003c\u003e();\n//        result.put(\"total\",pageBean.getPagesize());\n        result.put(\"records\",pageBean.getDatas());//将数据写入map传给前端\n        log.info(result.toString());\n        return R.success(result);\n    }\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220905150739-tjosot8","Type":"NodeParagraph","Properties":{"id":"20220905150739-tjosot8","updated":"20220905150842"},"Children":[{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"这里的result.put传的key是\u0026quot;records\u0026quot;是因为前端这里要求的是records"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]},{"ID":"20220905150825-q8auyek","Type":"NodeParagraph","Properties":{"id":"20220905150825-q8auyek","updated":"20220905150826"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220905150826-3ikjt52.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220905145034-j7ufhpz","Type":"NodeParagraph","Properties":{"id":"20220905145034-j7ufhpz","updated":"20220905150327"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220905150327-qph2pn5.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220905150328-j23lvwg","Type":"NodeParagraph","Properties":{"id":"20220905150328-j23lvwg","updated":"20220905181109"}},{"ID":"20220905204421-ijcxru8","Type":"NodeParagraph","Properties":{"id":"20220905204421-ijcxru8"}}]}