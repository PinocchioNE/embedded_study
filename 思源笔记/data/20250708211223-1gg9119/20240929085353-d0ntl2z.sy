"20241206165139"},"Children":[{"ID":"20241206165139-reikhq9","Type":"NodeParagraph","Properties":{"id":"20241206165139-reikhq9","updated":"20241206165139"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ceil_mode=True"},{"Type":"NodeText","Data":"​**：使用 **向上取整** 来计算输出特征图的尺寸。当输入的尺寸不能被池化窗口大小整除时，输出的尺寸会向上取整，即输出尺寸会比 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"floor_mode=False"},{"Type":"NodeText","Data":"​ 时更大。"}]}]},{"ID":"20241206165139-yd7xjar","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241206165139-yd7xjar","updated":"20241206165139"},"Children":[{"ID":"20241206165139-d0pn561","Type":"NodeParagraph","Properties":{"id":"20241206165139-d0pn561","updated":"20241206165139"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ceil_mode=False"},{"Type":"NodeText","Data":"​**（默认）：使用 **向下取整** 来计算输出特征图的尺寸。如果输入尺寸不能被池化窗口整除，输出的尺寸会向下取整。"}]}]}]}]},{"ID":"20241206165146-7pl7gho","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241206165146-7pl7gho","updated":"20250605111347"},"Children":[{"Type":"NodeText","Data":"Transpose是什么操作 perm参数什么意思"}]},{"ID":"20241206165200-j7anxkn","Type":"NodeBlockquote","Properties":{"id":"20241206165200-j7anxkn","updated":"20241206165734"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241206165202-cnnf7qr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241206165202-cnnf7qr","updated":"20241206165202"},"Children":[{"Type":"NodeText","Data":"**Transpose 操作**"}]},{"ID":"20241206165202-n9f4dhh","Type":"NodeParagraph","Properties":{"id":"20241206165202-n9f4dhh","updated":"20241206165202"},"Children":[{"Type":"NodeText","Data":"转置操作的目的是改变张量的维度顺序。例如，假设有一个形状为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(2, 3, 4)"},{"Type":"NodeText","Data":" 的张量，转置后可以得到不同的形状。通过调整各维度的顺序，可以重新组织张量的结构，以便在后续操作中适应网络的需求。"}]},{"ID":"20241206165202-936s5xb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241206165202-936s5xb","updated":"20241206165734"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"perm"},{"Type":"NodeText","Data":"​ 参数的含义**"}]},{"ID":"20241206165202-53vbhjf","Type":"NodeParagraph","Properties":{"id":"20241206165202-53vbhjf","updated":"20241206165202"},"Children":[{"Type":"NodeText","Data":"在转置操作中，"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"perm"},{"Type":"NodeText","Data":"​ 是一个关键参数，它指定了如何重排张量的维度。"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"perm"},{"Type":"NodeText","Data":"​ 是一个由整数构成的列表或数组，其中每个整数表示一个维度的索引，按照新的顺序排列。"}]},{"ID":"20241206165202-9x36voh","Type":"NodeList","ListData":{},"Properties":{"id":"20241206165202-9x36voh","updated":"20241206165734"},"Children":[{"ID":"20241206165202-yn3h55w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241206165202-yn3h55w","updated":"20241206165734"},"Children":[{"ID":"20241206165202-70tkkuw","Type":"NodeParagraph","Properties":{"id":"20241206165202-70tkkuw","updated":"20241206165202"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"perm"},{"Type":"NodeText","Data":"​ 参数**：是一个表示轴（维度）重排的整数列表，列表的长度应与输入张量的维度数量一致。"}]},{"ID":"20241206165202-45h37p0","Type":"NodeList","ListData":{},"Properties":{"id":"20241206165202-45h37p0","updated":"20241206165734"},"Children":[{"ID":"20241206165202-m0kvbc4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241206165202-m0kvbc4","updated":"20241206165202"},"Children":[{"ID":"20241206165202-niay2b8","Type":"NodeParagraph","Properties":{"id":"20241206165202-niay2b8","updated":"20241206165202"},"Children":[{"Type":"NodeText","Data":"例如，对于一个形状为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(2, 3, 4)"},{"Type":"NodeText","Data":" 的张量，如果 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"perm=[2, 0, 1]"},{"Type":"NodeText","Data":"​，则表示将原来的维度顺序 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(0, 1, 2)"},{"Type":"NodeText","Data":" 调整为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(2, 0, 1)"},{"Type":"NodeText","Data":"。"}]}]},{"ID":"20241206165202-evsrvp4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241206165202-evsrvp4","updated":"20241206165734"},"Children":[{"ID":"20241206165202-mkripsg","Type":"NodeParagraph","Properties":{"id":"20241206165202-mkripsg","updated":"20241206165734"},"Children":[{"Type":"NodeText","Data":"这会将张量的第 0 维与第 2 维交换，得到形状为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(4, 2, 3)"},{"Type":"NodeText","Data":" 的新张量。———（2，0，1）表示第二维的4调整到第一维，第零维的2调整到第一维，第一维的3调整到第二维"}]}]}]}]}]}]},{"ID":"20241206172022-roo3td2","Type":"NodeParagraph","Properties":{"id":"20241206172022-roo3td2","updated":"20241206172022"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20241206172021-uj9jncm.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20241224163137-4hsdcaf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241224163137-4hsdcaf","updated":"20250605111347"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA=="},{"Type":"NodeCodeBlockCode","Data":"Validating runs/train/exp/weights/best.pt...\nFusing layers...\nModel summary: 157 layers, 7023610 parameters, 0 gradients, 15.8 GFLOPs\n                 Class     Images  Instance