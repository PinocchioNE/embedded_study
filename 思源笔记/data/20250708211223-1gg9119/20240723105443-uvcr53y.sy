6"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hyp.scratch-low.yaml"},{"Type":"NodeText","Data":"​** 适用于较小或简单的数据集，提供较低的颜色和形状变换强度。"}]}]},{"ID":"20241030091606-zwxu8vw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030091606-zwxu8vw","updated":"20241030091606"},"Children":[{"ID":"20241030091606-sgutbit","Type":"NodeParagraph","Properties":{"id":"20241030091606-sgutbit","updated":"20241030091606"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hyp.scratch-high.yaml"},{"Type":"NodeText","Data":"​** 适用于较复杂或大的数据集，增强力度较高，包括更强的颜色变化和其他数据增强。"}]}]}]},{"ID":"20241030091545-0upiowa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241030091545-0upiowa","updated":"20241030092243"},"Children":[{"Type":"NodeText","Data":"方法"}]},{"ID":"20241030092233-iedu30q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241030092233-iedu30q","updated":"20241030092243"},"Children":[{"Type":"NodeText","Data":"修改颜色范围"}]},{"ID":"20241030091527-eqoicup","Type":"NodeParagraph","Properties":{"id":"20241030091527-eqoicup","updated":"20241030091527"},"Children":[{"Type":"NodeText","Data":"调整 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_h"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_s"},{"Type":"NodeText","Data":"​ 和 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_v"},{"Type":"NodeText","Data":"​ 的具体值取决于你希望模型对颜色的敏感程度。通常可以从较小的增幅开始测试，然后逐步调大，以找到合适的效果。以下是建议的调整范围："}]},{"ID":"20241030091527-gu7r41k","Type":"NodeList","ListData":{},"Properties":{"id":"20241030091527-gu7r41k","updated":"20241030091527"},"Children":[{"ID":"20241030091527-ks53ydg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030091527-ks53ydg","updated":"20241030091527"},"Children":[{"ID":"20241030091527-j8u9pur","Type":"NodeParagraph","Properties":{"id":"20241030091527-j8u9pur","updated":"20241030091527"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_h"},{"Type":"NodeText","Data":"​**（色调变化范围）：控制色调的随机变化幅度。可以尝试从 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.015"},{"Type":"NodeText","Data":"​** 调高到 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.02"},{"Type":"NodeText","Data":"​ - "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.05"},{"Type":"NodeText","Data":"​**，这会增加模型对色调差异的敏感性。"}]}]},{"ID":"20241030091527-no4h4nm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030091527-no4h4nm","updated":"20241030091527"},"Children":[{"ID":"20241030091527-8cuo59n","Type":"NodeParagraph","Properties":{"id":"20241030091527-8cuo59n","updated":"20241030091527"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_s"},{"Type":"NodeText","Data":"​**（饱和度变化范围）：控制饱和度的随机变化幅度。建议尝试从 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.7"},{"Type":"NodeText","Data":"​** 增加到 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.8"},{"Type":"NodeText","Data":"​ - "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"1.0"},{"Type":"NodeText","Data":"​**，以加强模型对颜色饱和度的关注。"}]}]},{"ID":"20241030091527-vpdow01","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030091527-vpdow01","updated":"20241030091527"},"Children":[{"ID":"20241030091527-1joswh5","Type":"NodeParagraph","Properties":{"id":"20241030091527-1joswh5","updated":"20241030091527"},"Children":[{"Type":"NodeText","Data":"**"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hsv_v"},{"Type":"NodeText","Data":"​**（亮度变化范围）：控制亮度的随机变化幅度。可以从 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.4"},{"Type":"NodeText","Data":"​** 增加到 **"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.5"},{"Type":"NodeText","Data":"​ - "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"0.6"},{"Type":"NodeText","Data":"​**，以强化亮度的影响。"}]}]}]},{"ID":"20241030091527-1jatapr","Type":"NodeParagraph","Properties":{"id":"20241030091527-1jatapr","updated":"20241030091527"},"Children":[{"Type":"NodeText","Data":"例如，更新后的参数设置如下："}]},{"ID":"20241030091527-pe0i3le","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241030091527-pe0i3le","updated":"20241030091527"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"hsv_h: 0.03  # 色调变化幅度\nhsv_s: 0.9   # 饱和度变化幅度\nhsv_v: 0.5   # 亮度变化幅度\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241030091528-9hs13fl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241030091528-9hs13fl","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"修改损失值"}]},{"ID":"20241030092245-wo782gu","Type":"NodeParagraph","Properties":{"id":"20241030092245-wo782gu","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"在 YOLOv5 中，损失函数的类别损失（"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​）权重控制模型对类别分类误差的重视程度。通过调整 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 参数的值，可以让模型在训练过程中对类别的准确性更加敏感，这在颜色分类等任务中尤其有帮助。"}]},{"ID":"20241030092245-od213r8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20241030092245-od213r8","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 参数的作用"}]},{"ID":"20241030092245-e6m17uj","Type":"NodeList","ListData":{},"Properties":{"id":"20241030092245-e6m17uj","updated":"20241030092245"},"Children":[{"ID":"20241030092245-dwruefa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030092245-dwruefa","updated":"20241030092245"},"Children":[{"ID":"20241030092245-n8obhnw","Type":"NodeParagraph","Properties":{"id":"20241030092245-n8obhnw","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"**类别损失**："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 参数是类别损失的权重，主要用于衡量模型在**区分不同类别**时的表现。"}]}]},{"ID":"20241030092245-fcpihyf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030092245-fcpihyf","updated":"20241030092245"},"Children":[{"ID":"20241030092245-356p4pt","Type":"NodeParagraph","Properties":{"id":"20241030092245-356p4pt","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"**提高类别区分**：当增大 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 权重时，模型在训练中会更专注于降低类别预测的误差。也就是说，它会更注重不同类别（如地毯和地板）的准确区分，这在颜色分类、纹理识别等任务中特别有用。"}]}]},{"ID":"20241030092245-wzc9ut8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030092245-wzc9ut8","updated":"20241030092245"},"Children":[{"ID":"20241030092245-rbimbvy","Type":"NodeParagraph","Properties":{"id":"20241030092245-rbimbvy","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"**减少偏差**：在颜色分类任务中，颜色差异可能不是位置或对象形状的直接特征，所以增大类别损失可以帮助模型更好地通过颜色特征来区分不同类别，而不是仅关注位置或形状。"}]}]}]},{"ID":"20241030092245-sdfoo6v","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20241030092245-sdfoo6v","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"什么时候适合调整 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 参数？"}]},{"ID":"20241030092245-7ipcwmi","Type":"NodeList","ListData":{},"Properties":{"id":"20241030092245-7ipcwmi","updated":"20241030092245"},"Children":[{"ID":"20241030092245-mis9kvi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030092245-mis9kvi","updated":"20241030092245"},"Children":[{"ID":"20241030092245-5zforny","Type":"NodeParagraph","Properties":{"id":"20241030092245-5zforny","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"**颜色特征为主**：如果你的分类任务主要依赖颜色特征，适当增加 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 权重，让模型更关注类别区分。"}]}]},{"ID":"20241030092245-kv0ljht","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030092245-kv0ljht","updated":"20241030092245"},"Children":[{"ID":"20241030092245-dwh2x40","Type":"NodeParagraph","Properties":{"id":"20241030092245-dwh2x40","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"**类别复杂度**：如果类别之间的差异难以区分（如颜色相似或仅有细微差别），增加 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 可以帮助模型更好地区分这些类别。"}]}]}]},{"ID":"20241030092245-y6lq8td","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20241030092245-y6lq8td","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"如何调整 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"cls"},{"Type":"NodeText","Data":"​ 值？"}]},{"ID":"20241030092245-ghbcrwy","Type":"NodeParagraph","Properties":{"id":"20241030092245-ghbcrwy","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"可以从默认值逐步增加，推荐范围通常在 **0.5 到 1.0** 之间。例如："}]},{"ID":"20241030092245-jh77h1w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241030092245-jh77h1w","updated":"20241030092245"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eWFtbA=="},{"Type":"NodeCodeBlockCode","Data":"cls: 0.6  # 类别损失权重\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241030092245-wa58mrh","Type":"NodeParagraph","Properties":{"id":"20241030092245-wa58mrh","updated":"20241030092245"},"Children":[{"Type":"NodeText","Data":"然后在训练中观察效果。如果增大后模型在类别区分上效果提升，则可以保持这个权重，反之则适当减少。"}]},{"ID":"20241030112510-qethjic","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20241030112510-qethjic","updated":"20241205110713"},"Children":[{"Type":"NodeText","Data":"**使用 Mosaic 数据增强**"}]},{"ID":"20241030112510-l1iwb85","Type":"NodeList","ListData":{},"Properties":{"id":"20241030112510-l1iwb85","updated":"20241030112510"},"Children":[{"ID":"20241030112510-ca6rxtd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030112510-ca6rxtd","updated":"20241030112510"},"Children":[{"ID":"20241030112510-i3lqygj","Type":"NodeParagraph","Properties":{"id":"20241030112510-i3lqygj","updated":"20241030112510"},"Children":[{"Type":"NodeText","Data":"YOLOv5 支持 Mosaic 数据增强，通过在一张图像中融合多个图像，能够提升模型在颜色、形状和背景多样性方面的适应性。"}]}]},{"ID":"20241030112510-u8gdr4d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20241030112510-u8gdr4d","updated":"20241030112510"},"Children":[{"ID":"20241030112510-miwzyn9","Type":"NodeParagraph","Properties":{"id":"20241030112510-miwzyn9","updated":"20241030112510"},"Children":[{"Type":"NodeText","Data":"可以在 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"hyp.scratch-*.yaml"},{"Type":"NodeText","Data":"​ 文件中查看和调整 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"mosaic"},{"Type":"NodeText","Data":"​ 参数（例如从 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"1.0"},{"Type":"NodeText","Data":"​ 调至 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"1.5"},{"Type":"NodeText","Data":"​），以增加增强概率和多样性。"}]}]}]},{"ID":"20241205110701-i99g1xl","Type":"NodeParagraph","Properties":{"id":"20241205110701-i99g1xl","updated":"20241205110701"}},{"ID":"20241205110701-nfygl7o","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241205110701-nfygl7o","upd