eBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018142230-lmqsewq","updated":"20241018142251"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"export LD_PRELOAD=$CONDA_PREFIX/lib/libstdc++.so\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018142252-4bsgm6m","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241018142252-4bsgm6m","updated":"20241018144039"},"Children":[{"Type":"NodeText","Data":"安装pytorch"}]},{"ID":"20241018143808-klbsfwz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018143808-klbsfwz","updated":"20241018143809"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"pip install -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple torch==1.13.0 torchvision==0.14.0 torchaudio==0.13.0\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018144044-jhuja2u","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241018144044-jhuja2u","updated":"20241021133109"},"Children":[{"Type":"NodeText","Data":"卸载pytorch"}]},{"ID":"20241018153646-quvz470","Type":"NodeBlockquote","Properties":{"id":"20241018153646-quvz470","updated":"20241018153648"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241018153648-k9reeuu","Type":"NodeParagraph","Properties":{"id":"20241018153648-k9reeuu","updated":"20241018153648"},"Children":[{"Type":"NodeText","Data":"pip uninstall torch torchvision torchaudio -y"}]}]},{"ID":"20241018153650-qhbl3oe","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241018153650-qhbl3oe","updated":"20241022100432"},"Children":[{"Type":"NodeText","Data":"查看系统版本"}]},{"ID":"20241021133110-odoxafj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241021133110-odoxafj","updated":"20241021133141"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"(dirtyIdentify) [Pinocchio@AIOT-ENV dockerlabelimg]$ uname -m\nx86_64\n\nx86_64 表示是 AMD 或 Intel 的 64 位架构。\narmv7l 表示是 ARM 32 位架构。\naarch64 表示是 ARM 64 位架构。\n\n(dirtyIdentify) [Pinocchio@AIOT-ENV dockerlabelimg]$ cat /etc/os-release\nNAME=\"CentOS Linux\"\nVERSION=\"7 (Core)\"\nID=\"centos\"\nID_LIKE=\"rhel fedora\"\nVERSION_ID=\"7\"\nPRETTY_NAME=\"CentOS Linux 7 (Core)\"\nANSI_COLOR=\"0;31\"\nCPE_NAME=\"cpe:/o:centos:centos:7\"\nHOME_URL=\"https://www.centos.org/\"\nBUG_REPORT_URL=\"https://bugs.centos.org/\"\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018160738-pstssde","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241018160738-pstssde","updated":"20241022170634"},"Children":[{"Type":"NodeText","Data":"docker最新安装ubuntu vnc labelimg流程"}]},{"ID":"20241022170008-prfwovy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022170008-prfwovy","updated":"20241022170634"},"Children":[{"Type":"NodeText","Data":"docker新的国内源"}]},{"ID":"20241022100433-1ma8pnp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241022100433-1ma8pnp","updated":"20241022100434"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"\"registry-mirrors\": [\n\"https://docker.m.daocloud.io\",\n\"https://dockerproxy.com\",\n\"https://docker.mirrors.ustc.edu.cn\",\n\"https://docker.nju.edu.cn\"\n]\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241022170634-heyyc6l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022170634-heyyc6l","updated":"20241022170733"},"Children":[{"Type":"NodeText","Data":"安装ubuntu"}]},{"ID":"20241022170634-a0ep9c3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241022170634-a0ep9c3","updated":"20241022170634"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"1. 安装Docker并从官方仓库拉取Ubuntu 20.04的镜像\ndocker pull ubuntu:20.04\n\n2. 运行容器\ndocker run -it --name ubuntu ubuntu:20.04 /bin/bash\n\n#这里–name [ubuntu] 名字自取\n\n3. 更换apt源\n参考：docker中ubuntu容器更换apt源\n\nsed -i s@/archive.ubuntu.com/@/mirrors.aliyun.com/@g /etc/apt/sources.list\nsed -i s@/security.ubuntu.com/@/mirrors.aliyun.com/@g /etc/apt/sources.list\napt clean\napt-get update -y\n1\n2\n3\n4\n4. 在容器内安装X11\napt-get update\napt-get install -y xorg\n1\n2\n5. 将容器打包为镜像\ndocker commit -m \"ubuntu with x11(xorg)\" -a zobot 680862fa0d6b ubuntu_x11:1.0\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241022170631-njhxgpd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022170631-njhxgpd","updated":"20241022170827"},"Children":[{"Type":"NodeText","Data":"如何每次将更新后的容器作为镜像打包"}]},{"ID":"20241022170737-jggvnue","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241022170737-jggvnue","updated":"20241022170827"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"docker commit e57e989821ab ubuntu_vnc:3.0\ndocker commit 当前运行的容器名称 新的镜像名称以及版本号\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241022170019-tx825gg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022170019-tx825gg","updated":"20241022172226"},"Children":[{"Type":"NodeText","Data":"如何运行容器的同时将端口进行映射"}]},{"ID":"20241022170043-qylflck","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241022170043-qylflck","updated":"20241022172226"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"docker run -v /home/Pinocchio/dockerlabel/docker_data_volume/:/home -it -p 5901:5901 --name debug_vnc ubuntu_vnc:3.0 /bin/bash -c \"export USER=root \u0026\u0026 exec /bin/bash\"\n\ndocker run -v 挂载目录（前面是宿主机，后面是docker） -it -p 映射端口 --name 容器名字（自定义）镜像名称:版本号 /bin/bash -c 添加管理员\n\n注意镜像版本号可能不一样 要查看 docker images\ndocker ps -a查看容器\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241022132151-970np4x","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022132151-970np4x","updated":"20241023095410"},"Children":[{"Type":"NodeText","Data":"端口设置"}]},{"ID":"20241022134909-5bydqps","Type":"NodeParagraph","Properties":{"id":"20241022134909-5bydqps","updated":"20241022134926"},"Children":[{"Type":"NodeText","Data":"注意：name得是宿主机的主机名 whoami查看"}]},{"ID":"20241022134926-793al3i","Type":"NodeParagraph","Properties":{"id":"20241022134926-793al3i","updated":"20241022134934"},"Children":[{"Type":"NodeText","Data":"ip地址也是宿主机的主机名"}]},{"ID":"20241022134906-eha76nu","Type":"NodeParagraph","Properties":{"id":"20241022134906-eha76nu","updated":"20241022134906"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20241022134906-99vsid8.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20241022132152-st6sk0u","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241022132152-st6sk0u","updated":"20241023095531"},"Children":[{"Type":"NodeText","Data":"不停止容器"}]},{"ID":"20241023095412-oczfkok","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241023095412-oczfkok","updated":"20241023095419"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"使用 Ctrl + P 和 Ctrl + Q：\n\n当你在容器的命令行界面中时，按下 Ctrl + P，然后立即按 Ctrl + Q。这将使你暂时退出容器的终端而不停止容器。容器将在后台继续运行。\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241023095421-ugxwc7a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241023095421-ugxwc7a","updated":"20241023095549"},"Children":[{"Type":"NodeText","Data":"再次进入容器"}]},{"ID":"20241023095532-ow7ulau","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241023095532-ow7ulau","updated":"20241023095549"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"docker exec -it \u003c容器名称或ID\u003e /bin/bash\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241023095421-0p3a4tu","Type":"NodeParagraph","Properties":{"id":"20241023095421-0p3a4tu","updated":"20241023095421"}},{"ID":"20241022132152-9lam8qy","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241022132152-9lam8qy","updated":"20241023093910"},"Children":[{"Type":"NodeText","Data":"git访问超时"}]},{"ID":"20241022154222-b89fztj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241022154222-b89fztj","updated":"20241022154303"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241022132152-eu9agz6","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241022132152-eu9agz6","updated":"20241113164615"},"Children":[{"Type":"NodeText","Data":"vnc问题"}]},{"ID":"20241113164329-0brrmen","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241113164329-0brrmen","updated":"20241113164615"},"Children":[{"Type":"NodeText","Data":"如果服务器被关闭如何再进入（先看看容器有没有停掉）"}]},{"ID":"20241113164347-krs40qa","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241113164347-krs40qa","updated":"20241113164400"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Da