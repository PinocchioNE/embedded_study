"Data":"```"}]},{"ID":"20241018165108-nz9tbnd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241018165108-nz9tbnd","updated":"20241018170510"},"Children":[{"Type":"NodeText","Data":"清华源下载需求包"}]},{"ID":"20241018165136-9056l4h","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018165136-9056l4h","updated":"20241018170510"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"pip install -r requirements.txt -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018165145-schpby8","Type":"NodeBlockquote","Properties":{"id":"20241018165145-schpby8","updated":"20241018165250"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241018165146-m5jx7um","Type":"NodeParagraph","Properties":{"id":"20241018165146-m5jx7um","updated":"20241018165209"},"Children":[{"Type":"NodeText","Data":"注意 这里的pytorch会安装最新版本的，但是不符合使用的cuda版本"}]},{"ID":"20241018165210-qpwfonw","Type":"NodeParagraph","Properties":{"id":"20241018165210-qpwfonw","updated":"20241018165246"},"Children":[{"Type":"NodeText","Data":"所以要后面重新下"}]}]},{"ID":"20241018165250-w1diwx3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241018165250-w1diwx3","updated":"20241018165314"},"Children":[{"Type":"NodeText","Data":"卸载pytorch"}]},{"ID":"20241018165302-vwfg0j0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018165302-vwfg0j0","updated":"20241018165305"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"pip uninstall torch torchvision torchaudio -y\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018165307-7dcs0n3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241018165307-7dcs0n3","updated":"20241018165917"},"Children":[{"Type":"NodeText","Data":"安装1.13.0版本"}]},{"ID":"20241018165315-xzb21g5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018165315-xzb21g5","updated":"20241018165322"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"pip install -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple torch==1.13.0 torchvision==0.14.0 torchaudio==0.13.0\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018165323-p22bqy9","Type":"NodeBlockquote","Properties":{"id":"20241018165323-p22bqy9","updated":"20241018165425"},"Children":[{"ID":"20241018165425-2lzidzs","Type":"NodeParagraph","Properties":{"id":"20241018165425-2lzidzs","updated":"20241018165425"},"Children":[{"Type":"NodeText","Data":"因为pytorch版本依赖 所以先卸载numpy再装1.23.5"}]},{"Type":"NodeBlockquoteMarker","Data":"\u003e"}]},{"ID":"20241018165324-c0zdh7b","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241018165324-c0zdh7b","updated":"20241018170554"},"Children":[{"Type":"NodeText","Data":"装好后测试环境"}]},{"ID":"20241018165920-guti9qb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241018165920-guti9qb","updated":"20241018170554"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"import torch\nprint(torch.cuda.is_available())\nprint(torch.__version__)\nprint(torch.version.cuda)\nprint(torch.cuda.is_available())\nprint(\"CUDA available:\", torch.cuda.is_available())\nprint(\"CUDA device count:\", torch.cuda.device_count())\nprint(\"Current CUDA device:\", torch.cuda.current_device())\nprint(\"CUDA device name:\", torch.cuda.get_device_name(0))\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241018161500-n2f9jto","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241018161500-n2f9jto","updated":"20241127142128"},"Children":[{"Type":"NodeText","Data":"要符合公司cuda版本"}]},{"ID":"20241018165008-kwi8ncp","Type":"NodeParagraph","Properties":{"id":"20241018165008-kwi8ncp","updated":"20241018165008"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20241018165008-dmxgz6c.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20241018165010-4le6x4f","Type":"NodeBlockquote","Properties":{"id":"20241018165010-4le6x4f","updated":"20241018165049"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241018165011-lgqbzu0","Type":"NodeParagraph","Properties":{"id":"20241018165011-lgqbzu0","updated":"20241018165049"},"Children":[{"Type":"NodeText","Data":"cuda 11.5 所以nvcc版本也要11.5 并且pytorch版本要降低 使用1.13.0"}]}]},{"ID":"20241018165959-lrcjrpt","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241018165959-lrcjrpt","updated":"20241129164405"},"Children":[{"Type":"NodeText","Data":"linux链接.so库一直失败"}]},{"ID":"20241127142131-rt25guc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241127142131-rt25guc","updated":"20241129164405"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"chmod +x pytorch_convert_v2.cpython-38-x86_64-linux-gnu.so\n# 要给库权限\n\n如果还是报错找不到对应的.so\n1.ldd yourfile.so    # yourfile.so代表找不到的库\n\n2.vim ~/.bashrc\n\n\n3.export LD_LIBRARY_PATH=/path/to/your/libs:$LD_LIBRARY_PATH  # LD_LIBRARY_PATH=/path/to/your/libs表示要链接的库的位置\n\n4.source ~/.bashrc\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241128103028-cufq85l","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241128103028-cufq85l","updated":"20241129140440"},"Children":[{"Type":"NodeText","Data":"公司cuda配套的torchkit"}]},{"ID":"20241128153025-xuopkc8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241128153025-xuopkc8","updated":"20241128153053"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"1.先nvidia-smi查看cuda版本\nconda install pytorch torchvision torchaudio pytorch-cuda=12.4 -c pytorch -c nvidia\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241129140428-3v3ja2n","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241129140428-3v3ja2n","updated":"20241129140516"},"Children":[{"Type":"NodeText","Data":"查GLIBC有哪些版本"}]},{"ID":"20241129140453-adk12vr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241129140453-adk12vr","updated":"20241129140516"},"Children":[{"Type":"NodeText","Data":"1.找lib在哪里"}]},{"ID":"20241129140500-xqki8r5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241129140500-xqki8r5","updated":"20241129140502"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"sudo find / -name \"libc.so.6\" 2\u003e/dev/null\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241129140503-wa0mlap","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241129140503-wa0mlap","updated":"20241205104058"},"Children":[{"Type":"NodeText","Data":"2.strings查找GLIBC位置"}]},{"ID":"20241129140518-vuyaxr4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241129140518-vuyaxr4","updated":"20241129140554"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"strings /lib/x86_64-linux-gnu/libc.so.6 | grep GLIBC_\n// 注意后面的/lib/x86_64-linux-gnu/libc.so.6要根据实际查出来的路径修改\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241205104054-rs6e6ap","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241205104054-rs6e6ap","updated":"20241205104106"},"Children":[{"Type":"NodeText","Data":"杀进程"}]},{"ID":"20241205104059-o0naopd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241205104059-o0naopd","updated":"20241205104106"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"kill -9 pid\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]}]}