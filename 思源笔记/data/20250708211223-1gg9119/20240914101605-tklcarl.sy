241129093021-7lqc0ib","updated":"20241129093021"},"Children":[{"Type":"NodeText","Data":"\t串口传输较慢"}]},{"ID":"20241129093021-zl7w0y6","Type":"NodeParagraph","Properties":{"id":"20241129093021-zl7w0y6","updated":"20241129093021"},"Children":[{"Type":"NodeText","Data":"3、修改model目录下config中的类别信息\n\tvi config.json\n\t找到 \"class_num\":  词条，修改值为5（模型支持的检测种类）"}]}]},{"ID":"20241205092853-27s478f","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20241205092853-27s478f","updated":"20241205095853"},"Children":[{"Type":"NodeText","Data":"量化流程"}]},{"ID":"20241205095828-qstq0jx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241205095828-qstq0jx","updated":"20241205095853"},"Children":[{"Type":"NodeText","Data":"量化流程的虚拟环境为 AMicro"}]},{"ID":"20241205092853-r4a2aiz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241205092853-r4a2aiz","updated":"20241205092853"},"Children":[{"Type":"NodeText","Data":"1.conda环境"}]},{"ID":"20241205092853-z0crfg1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241205092853-z0crfg1","updated":"20241205092853"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"torchvision安装0.12.0版本（会自动装torch 1.11.0） cudatoolkit 10.2.89\n\n\nwget https://mirrors.tuna.tsinghua.edu.cn/anaconda/archive/Anaconda3-5.3.1-Linux-x86_64.sh\n\nbash Anaconda3-5.3.1-Linux-x86_64.sh\n\nconda create -n quant python=3.8\n\nsource ~/anaconda3/bin/activate ~/anaconda3/envs/quant \n\n#conda install torch=1.10.0 torchvision=0.11.0 cudatoolkit=10.2 -c pytorch #这些要按上面的版本来\n\nconda install opencv-python  # pip install opencv-python\n\nconda install matplotlib # pip install matplotlib\n\nconda install pydot-ng  # pip install pydot-ng\n\nconda install graphviz  # pip install graphviz\n\npip install tqdm\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241205092853-q9vgm6v","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241205092853-q9vgm6v","updated":"20241205092853"},"Children":[{"Type":"NodeText","Data":"2.链接库"}]},{"ID":"20241205092853-a2bicjx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241205092853-a2bicjx","updated":"20241205092853"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"1.ldd yourfile.so    # yourfile.so代表找不到的库   量化的lib文件在/home/lbm/lb_torch_qdk/lbtoolkit/lib\n\n2.vim ~/.bashrc\n\n3.export LD_LIBRARY_PATH=/path/to/your/libs:$LD_LIBRARY_PATH  # LD_LIBRARY_PATH=/path/to/your/libs表示要链接的库的位置 加在最后一行\n\n4.source ~/.bashrc\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241205092853-6hzr6y4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241205092853-6hzr6y4","updated":"20241217102029"},"Children":[{"Type":"NodeText","Data":"3.run.py  图片400张左右"}]},{"ID":"20241217101942-qqe0s4z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241217101942-qqe0s4z","updated":"20241217102029"},"Children":[{"Type":"NodeText","Data":"量化位置"}]},{"ID":"20241217101952-n52d0xr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20241217101952-n52d0xr","updated":"20241217102009"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw=="},{"Type":"NodeCodeBlockCode","Data":"(AMicro) [Pinocchio@AIOT-ENV yolov5s]$ pwd\n/home/Pinocchio/PythonProject/AMicro/lbm/lb_torch_qdk/example/onnx/yolov5s\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20241217102020-68alc6c","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241217102020-68alc6c","updated":"20241217102052"},"Children":[{"Type":"NodeText","Data":"替换onnx模型"}]},{"ID":"20241217102033-rwlc1hm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20241217102033-rwlc1hm","updated":"20241217102218"},"Children":[{"Type":"NodeText