e":"NodeText","Data":"​"}]},{"ID":"20241205095806-1pjpsj2","Type":"NodeParagraph","Properties":{"id":"20241205095806-1pjpsj2","updated":"20241205095806"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"20241205-095805"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/20241205-095805-20241205095806-gekpdn8.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeText","Data":"​"}]},{"ID":"20241205093328-218tezg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20241205093328-218tezg","updated":"20241217160554"},"Children":[{"Type":"NodeText","Data":"9.更换模型操作"}]},{"ID":"20241205093328-hz92avi","Type":"NodeBlockquote","Properties":{"id":"20241205093328-hz92avi","updated":"20241217160554"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20241205093328-nt8dop7","Type":"NodeParagraph","Properties":{"id":"20241205093328-nt8dop7","updated":"20241205093328"},"Children":[{"Type":"NodeText","Data":"更换模型操作\n0、kill正在运行的识别程序\nkillall5\ncd /firmware/bin\n获取权限\nremount_fw.sh rw\n1、进入到model目录下\ncd /firmware/arobot/model"}]},{"ID":"20241205093328-gkiivws","Type":"NodeParagraph","Properties":{"id":"20241205093328-gkiivws","updated":"20241205093454"},"Children":[{"Type":"NodeText","Data":"2、使用新模型替换旧模型（需要将新模型改成与旧模型名字一致）\n2-1、提前改好新模型名字(checkpoint.bin、checkpoint.ezb)用checkpoint.bin、checkpoint.lbm替换，ezb是之前的老程序的模型文件，用lbm替换，"}]},{"ID":"20241205093501-vzmknp3","Type":"NodeParagraph","Properties":{"id":"20241205093501-vzmknp3","updated":"20241217160453"},"Children":[{"Type":"NodeText","Data":"2-2、删除旧模型，传入新模型、"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"text","TextMarkTextContent":"并且修改config.json中checkpoint.ezb的路径位置"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"},{"Type":"NodeText","Data":" "}]},{"ID":"20241205093328-0r5oa1b","Type":"NodeParagraph","Properties":{"id":"20241205093328-0r5oa1b","updated":"20241205093328"},"Children":[{"Type":"NodeText","Data":"串口传输较慢"}]},{"ID":"20241205093328-ziki8nz","Type":"NodeParagraph","Properties":{"id":"20241205093328-ziki8nz","updated":"20241205093328"},"Children":[{"Type":"NodeText","Data":"3、修改model目录下config中的类别信息\nvi config.json\n找到 \"class_num\":  词条，修改值为5（模型支持的检测种类）"}]},{"ID":"20241217160502-meuazx7","Type":"NodeParagraph","Properties":{"id":"20241217160502-meuazx7","updated":"20241217160554"},"Children":[{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"text","TextMarkTextContent":"checkpoint.ezb"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"},{"Type":"NodeText","Data":"的路径名字改成"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"text","TextMarkTextContent":"checkpoint.lbm"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]}]},{"ID":"20241205093344-a922hri","Type":"NodeParagraph","Properties":{"id":"20241205093344-a922hri","updated":"20241205093344"}}]}