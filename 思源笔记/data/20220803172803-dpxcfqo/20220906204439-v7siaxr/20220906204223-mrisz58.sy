pe":"code","TextMarkTextContent":"MappedStatement"},{"Type":"NodeText","Data":" ，举例： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"com.mybatis3.mappers. StudentDao.findStudentById"},{"Type":"NodeText","Data":" ，可以唯一找到 namespace 为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"com.mybatis3.mappers. StudentDao"},{"Type":"NodeText","Data":" 下面 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"id = findStudentById"},{"Type":"NodeText","Data":" 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"MappedStatement"},{"Type":"NodeText","Data":" 。在 MyBatis 中，每一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;select\u0026gt;"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;insert\u0026gt;"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;update\u0026gt;"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;delete\u0026gt;"},{"Type":"NodeText","Data":" 标签，都会被解析为一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"MappedStatement"},{"Type":"NodeText","Data":" 对象。","Properties":{"id":""}}]},{"ID":"20220906204242-xwaur07","Type":"NodeParagraph","Properties":{"id":"20220906204242-xwaur07","updated":"20220906204242"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"s","TextMarkTextContent":"Dao 接口里的方法，是不能重载的，因为是全限名+方法名的保存和寻找策略。"}]