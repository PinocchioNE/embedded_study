ntent":"param2"},{"Type":"NodeText","Data":"四个 key 值，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"id"},{"Type":"NodeText","Data":"和","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"name"},{"Type":"NodeText","Data":"属性都可以获取到，动态 sql 正常执行。","Properties":{"id":""}}]}]}]},{"ID":"20220906204276-0f8dqic","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204276-0f8dqic","updated":"20220906204276"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 是如何进行分页的？分页插件的原理是什么？","Properties":{"id":""}}]},{"ID":"20220906204277-zyshre0","Type":"NodeParagraph","Properties":{"id":"20220906204277-zyshre0","updated":"20220906204277"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204278-xs9j7r3","Type":"NodeParagraph","Properties":{"id":"20220906204278-xs9j7r3","updated":"20220906204278"},"Children":[{"Type":"NodeText","Data":"答：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"(1)"},{"Type":"NodeText","Data":" MyBatis 使用 RowBounds 对象进行分页，它是针对 ResultSet 结果集执行的内存分页，而非物理分页；","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"(2)"},{"Type":"NodeText","Data":" 可以在 sql 内直接书写带有物理分页的参数来完成物理分页功能，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"(3)"},{"Type":"NodeText","Data":" 也可以使用分页插件来完成物理分页。","Properties":{"id":""}}]},{"ID":"20220906204279-pvrvvzc","Type":"NodeParagraph","Properties":{"id":"20220906204279-pvrvvzc","updated":"20220906204279"},"Children":[{"Type":"NodeText","Data":"分页插件的基本原理是使用 MyBatis 提供的插件接口，实现自定义插件，在插件的拦截方法内拦截待执行的 sql，然后重写 sql，根据 dialect 方言，添加对应的物理分页语句和物理分页参数。","Properties":{"id":""}}]},{"ID":"20220906204280-ykcnmb3","Type":"NodeParagraph","Properties":{"id":"20220906204280-ykcnmb3","updated":"20220906204280"},"Children":[{"Type":"NodeText","Data":"举例： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"select _ from student"},{"Type":"NodeText","Data":" ，拦截 sql 后重写为： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"select t._ from （select \\* from student）t limit 0，10"}]},{"ID":"20220906204281-0zdwegk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204281-0zdwegk","updated":"20220906204281"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"简述 MyBatis 的插件运行原理，以及如何编写一个插件。","Properties":{"id":""}}]},{"ID":"20220906204282-r2ulz03","Type":"NodeParagraph","Properties":{"id":"20220906204282-r2ulz03","updated":"20220906204282"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204283-8f9o39i","Type":"NodeParagraph","Properties":{"id":"20220906204283-8f9o39i","updated":"20220906204283"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 仅可以编写针对 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ParameterHandler"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ResultSetHandler"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"StatementHandler"},{"Type":"NodeText","Data":" 、 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Executor"},{"Type":"NodeText","Data":" 这 4 种接口的插件，MyBatis 使用 JDK 的动态代理，为需要拦截的接口生成代理对象以实现接口方法拦截功能，每当执行这 4 种接口对象的方法时，就会进入拦截方法，具体就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"InvocationHandler"},{"Type":"NodeText","Data":" 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"invoke()"},{"Type":"NodeText","Data":" 方法，当然，只会拦截那些你指定需要拦截的方法。","Properties":{"id":""}}]},{"ID":"20220906204284-s38zbcn","Type":"NodeParagraph","Properties":{"id":"20220906204284-s38zbcn","updated":"20220906204284"},"Children":[{"Type":"NodeText","Data":"实现 MyBatis 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Interceptor"},{"Type":"NodeText","Data":" 接口并复写 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"intercept()"},{"Type":"NodeText","Data":" 方法，然后在给插件编写注解，指定要拦截哪一个接口的哪些方法即可，记住，别忘了在配置文件中配置你编写的插件。","Properties":{"id":""}}]},{"ID":"20220906204285-smxjven","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204285-smxjven","updated":"20220906204285"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 执行批量插入，能返回数据库主键列表吗？","Properties":{"id":""}}]},{"ID":"20220906204286-g8z3wk3","Type":"NodeParagraph","Properties":{"id":"20220906204286-g8z3wk3","updated":"20220906204286"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204287-qblg92u","Type":"NodeParagraph","Properties":{"id":"20220906204287-qblg92u","updated":"20220906204287"},"Children":[{"Type":"NodeText","Data":"答：能，JDBC 都能，MyBatis 当然也能。","Properties":{"id":""}}]},{"ID":"20220906204288-rvxtqzq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204288-rvxtqzq","updated":"20220906204288"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 动态 sql 是做什么的？都有哪些动态 sql？能简述一下动态 sql 的执行原理不？","Properties":{"id":""}}]},{"ID":"20220906204289-s8zyofk","Type":"NodeParagraph","Properties":{"id":"20220906204289-s8zyofk","updated":"20220906204289"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204290-j4gvgrf","Type":"NodeParagraph","Properties":{"id":"20220906204290-j4gvgrf","updated":"20220906204290"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 动态 sql 可以让我们在 xml 映射文件内，以标签的形式编写动态 sql，完成逻辑判断和动态拼接 sql 的功能。其执行原理为，使用 OGNL 从 sql 参数对象中计算表达式的值，根据表达式的值动态拼接 sql，以此来完成动态 sql 的功能。","Properties":{"id":""}}]},{"ID":"20220906204291-z06esfa","Type":"NodeParagraph","Properties":{"id":"20220906204291-z06esfa","updated":"20220906204291"},"Children":[{"Type":"NodeText","Data":"MyBatis 提供了 9 种动态 sql 标签:","Properties":{"id":""}}]},{"ID":"20220906204292-cmgb8ir","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204292-cmgb8ir","updated":"20220906204292"},"Children":[{"ID":"20220906204293-1bactt4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204293-1bactt4","updated":"20220906204293"},"Children":[{"ID":"20220906204294-tyjepbx","Type":"NodeParagraph","Properties":{"id":"20220906204294-tyjepbx","updated":"20220906204294"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;if\u0026gt;\u0026lt;/if\u0026gt;"}]}]},{"ID":"20220906204295-1gfk3r0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204295-1gfk3r0","updated":"20220906204295"},"Children":[{"ID":"20220906204296-0yn0j3g","Type":"NodeParagraph","Properties":{"id":"20220906204296-0yn0j3g","updated":"20220906204296"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;where\u0026gt;\u0026lt;/where\u0026gt;(trim,set)"}]}]},{"ID":"20220906204297-jpvnhjm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204297-jpvnhjm","updated":"20220906204297"},"Children":[{"ID":"20220906204298-tl6dx2p","Type":"NodeParagraph","Properties":{"id":"20220906204298-tl6dx2p","updated":"20220906204298"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;choose\u0026gt;\u0026lt;/choose\u0026gt;（when, otherwise）"}]}]},{"ID":"20220906204299-s3uh56d","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204299-s3uh56d","updated":"20220906204299"},"Children":[{"ID":"20220906204300-g86e7hd","Type":"NodeParagraph","Properties":{"id":"20220906204300-g86e7hd","updated":"20220906204300"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;foreach\u0026gt;\u0026lt;/foreach\u0026gt;"}]}]},{"ID":"20220906204301-a4w2x0b","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204301-a4w2x0b","updated":"20220906204301"},"Children":[{"ID":"20220906204302-6tpglws","Type":"NodeParagraph","Properties":{"id":"20220906204302-6tpglws","updated":"20220906204302"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;bind/\u0026gt;"}]}]}]},{"ID":"20220906204303-okwyulc","Type":"NodeParagraph","Properties":{"id":"20220906204303-okwyulc","updated":"20220906204303"},"Children":[{"Type":"NodeText","Data":"关于 MyBatis 动态 SQL 的详细介绍，请看这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://segmentfault.com/a/1190000039335704","TextMarkTextContent":"Mybatis 系列全解（八）：Mybatis 的 9 大动态 SQL 标签你知道几个？"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204304-ng7hiik","Type":"NodeParagraph","Properties":{"id":"20220906204304-ng7hiik","updated":"20220906204304"},"Children":[{"Type":"NodeText","Data":"关于这些动态 SQL 的具体使用方法，请看这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://cloud.tencent.com/developer/article/1943349","TextMarkTextContent":"Mybatis【13】-- Mybatis 动态 sql 标签怎么使用？"}]},{"ID":"20220906204305-nktb728","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204305-nktb728","updated":"20220906204305"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 是如何将 sql 执行结果封装为目标对象并返回的？都有哪些映射形式？","Properties":{"id":""}}]},{"ID":"20220906204306-k4p3u1z","Type":"NodeParagraph","Properties":{"id":"20220906204306-k4p3u1z","updated":"20220906204306"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204307-3wsrmi0","Type":"NodeParagraph","Properties":{"id":"20220906204307-3wsrmi0","updated":"20220906204307"},"Children":[{"Type":"NodeText","Data":"答：第一种是使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;resultMap\u0026gt;"},{"Type":"NodeText","Data":" 标签，逐一定义列名和对象属性名之间的映射关系。第二种是使用 sql 列的别名功能，将列别名书写为对象属性名，比如 T_NAME AS NAME，对象属性名一般是 name，小写，但是列名不区分大小写，MyBatis 会忽略列名大小写，智能找到与之对应对象属性名，你甚至可以写成 T_NAME AS NaMe，MyBatis 一样可以正常工作。","Properties":{"id":""}}]},{"ID":"20220906204308-e0bfh20","Type":"NodeParagraph","Properties":{"id":"20220906204308-e0bfh20","updated":"20220906204308"},"Children":[{"Type":"NodeText","Data":"有了列名与属性名的映射关系后，MyBatis 通过反射创建对象，同时使用反射给对象的属性逐一赋值并返回，那些找不到映射关系的属性，是无法完成赋值的。","Properties":{"id":""}}]},{"ID":"20220906204309-0z6srvg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204309-0z6srvg","updated":"20220906204309"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 能执行一对一、一对多的关联查询吗？都有哪些实现方式，以及它们之间的区别。","Properties":{"id":""}}]},{"ID":"20220906204310-ebaa5pe","Type":"NodeParagraph","Properties":{"id":"20220906204310-ebaa5pe","updated":"20220906204310"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204311-ee2tpy3","Type":"NodeParagraph","Properties":{"id":"20220906204311-ee2tpy3","updated":"20220906204311"},"Children":[{"Type":"NodeText","Data":"答：能，MyBatis 不仅可以执行一对一、一对多的关联查询，还可以执行多对一，多对多的关联查询，多对一查询，其实就是一对一查询，只需要把 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"selectOne()"},{"Type":"NodeText","Data":" 修改为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"selectList()"},{"Type":"NodeText","Data":" 即可；多对多查询，其实就是一对多查询，只需要把 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"selectOne()"},{"Type":"NodeText","Data":" 修改为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"selectList()"},{"Type":"NodeText","Data":" 即可。","Properties":{"id":""}}]},{"ID":"20220906204312-yoi30bc","Type":"NodeParagraph","Properties":{"id":"20220906204312-yoi30bc","updated":"20220906204312"},"Children":[{"Type":"NodeText","Data":"关联对象查询，有两种实现方式，一种是单独发送一个 sql 去查询关联对象，赋给主对象，然后返回主对象。另一种是使用嵌套查询，嵌套查询的含义为使用 join 查询，一部分列是 A 对象的属性值，另外一部分列是关联对象 B 的属性值，好处是只发一个 sql 查询，就可以把主对象和其关联对象查出来。","Properties":{"id":""}}]},{"ID":"20220906204313-2wqy5yo","Type":"NodeParagraph","Properties":{"id":"20220906204313-2wqy5yo","updated":"20220906204313"},"Children":[{"Type":"NodeText","Data":"那么问题来了，join 查询出来 100 条记录，如何确定主对象是 5 个，而不是 100 个？其去重复的原理是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;resultMap\u0026gt;"},{"Type":"NodeText","Data":" 标签内的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;id\u0026gt;"},{"Type":"NodeText","Data":" 子标签，指定了唯一确定一条记录的 id 列，MyBatis 根据 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;id\u0026gt;"},{"Type":"NodeText","Data":" 列值来完成 100 条记录的去重复功能， ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;id\u0026gt;"},{"Type":"NodeText","Data":" 可以有多个，代表了联合主键的语意。","Properties":{"id":""}}]},{"ID":"20220906204314-2cssmmt","Type":"NodeParagraph","Properties":{"id":"20220906204314-2cssmmt","updated":"20220906204314"},"Children":[{"Type":"NodeText","Data":"同样主对象的关联对象，也是根据这个原理去重复的，尽管一般情况下，只有主对象会有重复记录，关联对象一般不会重复。","Properties":{"id":""}}]},{"ID":"20220906204315-k5hh5do","Type":"NodeParagraph","Properties":{"id":"20220906204315-k5hh5do","updated":"20220906204315"},"Children":[{"Type":"NodeText","Data":"举例：下面 join 查询出来 6 条记录，一、二列是 Teacher 对象列，第三列为 Student 对象列，MyBatis 去重复处理后，结果为 1 个老师 6 个学生，而不是 6 个老师 6 个学生。","Properties":{"id":""}}]},{"ID":"20220906204316-9s21ryh","Type":"NodeTable","Data":"| t_id | t_name  | s_id |\n| ---- | ------- | ---- |\n| 1    | teacher | 38   |\n| 1    | teacher | 39   |\n| 1    | teacher | 40   |\n| 1    | teacher | 41   |\n| 1    | teacher | 42   |\n| 1    | teacher | 43   |","TableAligns":[0,0,0],"Properties":{"id":"20220906204316-9s21ryh","updated":"20220906204316"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"t_id","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"t_name","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"s_id","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"38","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"39","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"40","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"41","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"42","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"1","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"teacher","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"43","Properties":{"id":""}}]}]}]},{"ID":"20220906204317-j1r1191","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204317-j1r1191","updated":"20220906204317"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 是否支持延迟加载？如果支持，它的实现原理是什么？","Properties":{"id":""}}]},{"ID":"20220906204318-nupnu8m","Type":"NodeParagraph","Properties":{"id":"20220906204318-nupnu8m","updated":"20220906204318"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204319-l5tmcfu","Type":"NodeParagraph","Properties":{"id":"20220906204319-l5tmcfu","updated":"20220906204319"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 仅支持 association 关联对象和 collection 关联集合对象的延迟加载，association 指的就是一对一，collection 指的就是一对多查询。在 MyBatis 配置文件中，可以配置是否启用延迟加载 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"lazyLoadingEnabled=true|false。"}]},{"ID":"20220906204320-te0i9jg","Type":"NodeParagraph","Properties":{"id":"20220906204320-te0i9jg","updated":"20220906204320"},"Children":[{"Type":"NodeText","Data":"它的原理是，使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"CGLIB"},{"Type":"NodeText","Data":" 创建目标对象的代理对象，当调用目标方法时，进入拦截器方法，比如调用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"a.getB().getName()"},{"Type":"NodeText","Data":" ，拦截器 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"invoke()"},{"Type":"NodeText","Data":" 方法发现 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"a.getB()"},{"Type":"NodeText","Data":" 是 null 值，那么就会单独发送事先保存好的查询关联 B 对象的 sql，把 B 查询上来，然后调用 a.setB(b)，于是 a 的对象 b 属性就有值了，接着完成 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"a.getB().getName()"},{"Type":"NodeText","Data":" 方法的调用。这就是延迟加载的基本原理。","Properties":{"id":""}}]},{"ID":"20220906204321-sluzroj","Type":"NodeParagraph","Properties":{"id":"20220906204321-sluzroj","updated":"20220906204321"},"Children":[{"Type":"NodeText","Data":"当然了，不光是 MyBatis，几乎所有的包括 Hibernate，支持延迟加载的原理都是一样的。","Properties":{"id":""}}]},{"ID":"20220906204322-0gt04eh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204322-0gt04eh","updated":"20220906204322"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 的 xml 映射文件中，不同的 xml 映射文件，id 是否可以重复？","Properties":{"id":""}}]},{"ID":"20220906204323-g81468j","Type":"NodeParagraph","Properties":{"id":"20220906204323-g81468j","updated":"20220906204323"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204324-5n9us9j","Type":"NodeParagraph","Properties":{"id":"20220906204324-5n9us9j","updated":"20220906204324"},"Children":[{"Type":"NodeText","Data":"答：不同的 xml 映射文件，如果配置了 namespace，那么 id 可以重复；如果没有配置 namespace，那么 id 不能重复；毕竟 namespace 不是必须的，只是最佳实践而已。","Properties":{"id":""}}]},{"ID":"20220906204325-x1by20e","Type":"NodeParagraph","Properties":{"id":"20220906204325-x1by20e","updated":"20220906204325"},"Children":[{"Type":"NodeText","Data":"原因就是 namespace+id 是作为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Map\u0026lt;String, MappedStatement\u0026gt;"},{"Type":"NodeText","Data":" 的 key 使用的，如果没有 namespace，就剩下 id，那么，id 重复会导致数据互相覆盖。有了 namespace，自然 id 就可以重复，namespace 不同，namespace+id 自然也就不同。","Properties":{"id":""}}]},{"ID":"20220906204326-p8uf74j","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204326-p8uf74j","updated":"20220906204326"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 中如何执行批处理？","Properties":{"id":""}}]},{"ID":"20220906204327-t7k5x27","Type":"NodeParagraph","Properties":{"id":"20220906204327-t7k5x27","updated":"20220906204327"},"Children":[{"Type":"NodeText","Data":"注：我出的。","Properties":{"id":""}}]},{"ID":"20220906204328-fpx5437","Type":"NodeParagraph","Properties":{"id":"20220906204328-fpx5437","updated":"20220906204328"},"Children":[{"Type":"NodeText","Data":"答：使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BatchExecutor"},{"Type":"NodeText","Data":" 完成批处理。","Properties":{"id":""}}]},{"ID":"20220906204329-j5x1t1y","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204329-j5x1t1y","updated":"20220906204329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 都有哪些 Executor 执行器？它们之间的区别是什么？","Properties":{"id":""}}]},{"ID":"20220906204330-ugojef1","Type":"NodeParagraph","Properties":{"id":"20220906204330-ugojef1","updated":"20220906204330"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204331-tf6lf36","Type":"NodeParagraph","Properties":{"id":"20220906204331-tf6lf36","updated":"20220906204331"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 有三种基本的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Executor"},{"Type":"NodeText","Data":" 执行器：","Properties":{"id":""}}]},{"ID":"20220906204332-ptmw6iz","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204332-ptmw6iz","updated":"20220906204332"},"Children":[{"ID":"20220906204333-l5ql8ks","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204333-l5ql8ks","updated":"20220906204333"},"Children":[{"ID":"20220906204334-suvejio","Type":"NodeParagraph","Properties":{"id":"20220906204334-suvejio","updated":"20220906204334"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"SimpleExecutor"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"："},{"Type":"NodeText","Data":" 每执行一次 update 或 select，就开启一个 Statement 对象，用完立刻关闭 Statement 对象。","Properties":{"id":""}}]}]},{"ID":"20220906204335-sqv9ich","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204335-sqv9ich","updated":"20220906204335"},"Children":[{"ID":"20220906204336-b821kex","Type":"NodeParagraph","Properties":{"id":"20220906204336-b821kex","updated":"20220906204336"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"ReuseExecutor"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"："},{"Type":"NodeText","Data":" 执行 update 或 select，以 sql 作为 key 查找 Statement 对象，存在就使用，不存在就创建，用完后，不关闭 Statement 对象，而是放置于 Map\u003cString, Statement\u003e内，供下一次使用。简言之，就是重复使用 Statement 对象。","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"BatchExecutor"},{"Type":"NodeText","Data":" 执行 update（没有 select，JDBC 批处理不支持 select），将所有 sql 都添加到批处理中（addBatch()），等待统一执行（executeBatch()），它缓存了多个 Statement 对象，每个 Statement 对象都是 addBatch()完毕后，等待逐一执行 executeBatch()批处理。与 JDBC 批处理相同。","Properties":{"id":""}}]}]}]},{"ID":"20220906204337-sycor8t","Type":"NodeParagraph","Properties":{"id":"20220906204337-sycor8t","updated":"20220906204337"},"Children":[{"Type":"NodeText","Data":"作用范围：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Executor"},{"Type":"NodeText","Data":" 的这些特点，都严格限制在 SqlSession 生命周期范围内。","Properties":{"id":""}}]},{"ID":"20220906204338-zj560jp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204338-zj560jp","updated":"20220906204338"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 中如何指定使用哪一种 Executor 执行器？","Properties":{"id":""}}]},{"ID":"20220906204339-cc4g04o","Type":"NodeParagraph","Properties":{"id":"20220906204339-cc4g04o","updated":"20220906204339"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204340-qpq4ye4","Type":"NodeParagraph","Properties":{"id":"20220906204340-qpq4ye4","updated":"20220906204340"},"Children":[{"Type":"NodeText","Data":"答：在 MyBatis 配置文件中，可以指定默认的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ExecutorType"},{"Type":"NodeText","Data":" 执行器类型，也可以手动给 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"DefaultSqlSessionFactory"},{"Type":"NodeText","Data":" 的创建 SqlSession 的方法传递 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ExecutorType"},{"Type":"NodeText","Data":" 类型参数。","Properties":{"id":""}}]},{"ID":"20220906204341-k0y6ts9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204341-k0y6ts9","updated":"20220906204341"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 是否可以映射 Enum 枚举类？","Properties":{"id":""}}]},{"ID":"20220906204342-v1xs6hw","Type":"NodeParagraph","Properties":{"id":"20220906204342-v1xs6hw","updated":"20220906204342"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204343-ngliikc","Type":"NodeParagraph","Properties":{"id":"20220906204343-ngliikc","updated":"20220906204343"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 可以映射枚举类，不单可以映射枚举类，MyBatis 可以映射任何对象到表的一列上。映射方式为自定义一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TypeHandler"},{"Type":"NodeText","Data":" ，实现 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TypeHandler"},{"Type":"NodeText","Data":" 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"setParameter()"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"getResult()"},{"Type":"NodeText","Data":" 接口方法。 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TypeHandler"},{"Type":"NodeText","Data":" 有两个作用：","Properties":{"id":""}}]},{"ID":"20220906204344-e8w7inn","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204344-e8w7inn","updated":"20220906204344"},"Children":[{"ID":"20220906204345-s8faw43","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204345-s8faw43","updated":"20220906204345"},"Children":[{"ID":"20220906204346-v8d4acy","Type":"NodeParagraph","Properties":{"id":"20220906204346-v8d4acy","updated":"20220906204346"},"Children":[{"Type":"NodeText","Data":"一是完成从 javaType 至 jdbcType 的转换；","Properties":{"id":""}}]}]},{"ID":"20220906204347-oy0x7ge","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204347-oy0x7ge","updated":"20220906204347"},"Children":[{"ID":"20220906204348-hqkg7pf","Type":"NodeParagraph","Properties":{"id":"20220906204348-hqkg7pf","updated":"20220906204348"},"Children":[{"Type":"NodeText","Data":"二是完成 jdbcType 至 javaType 的转换，体现为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"setParameter()"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"getResult()"},{"Type":"NodeText","Data":" 两个方法，分别代表设置 sql 问号占位符参数和获取列查询结果。","Properties":{"id":""}}]}]}]},{"ID":"20220906204349-hjjzaz4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204349-hjjzaz4","updated":"20220906204349"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyBatis 映射文件中，如果 A 标签通过 include 引用了 B 标签的内容，请问，B 标签能否定义在 A 标签的后面，还是说必须定义在 A 标签的前面？","Properties":{"id":""}}]},{"ID":"20220906204350-hbvtcfj","Type":"NodeParagraph","Properties":{"id":"20220906204350-hbvtcfj","updated":"20220906204350"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204351-b22ujr7","Type":"NodeParagraph","Properties":{"id":"20220906204351-b22ujr7","updated":"20220906204351"},"Children":[{"Type":"NodeText","Data":"答：虽然 MyBatis 解析 xml 映射文件是按照顺序解析的，但是，被引用的 B 标签依然可以定义在任何地方，MyBatis 都可以正确识别。","Properties":{"id":""}}]},{"ID":"20220906204352-vvtxk1m","Type":"NodeParagraph","Properties":{"id":"20220906204352-vvtxk1m","updated":"20220906204352"},"Children":[{"Type":"NodeText","Data":"原理是，MyBatis 解析 A 标签，发现 A 标签引用了 B 标签，但是 B 标签尚未解析到，尚不存在，此时，MyBatis 会将 A 标签标记为未解析状态，然后继续解析余下的标签，包含 B 标签，待所有标签解析完毕，MyBatis 会重新解析那些被标记为未解析的标签，此时再解析 A 标签时，B 标签已经存在，A 标签也就可以正常解析完成了。","Properties":{"id":""}}]},{"ID":"20220906204353-gvxrq64","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204353-gvxrq64","updated":"20220906204353"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"简述 MyBatis 的 xml 映射文件和 MyBatis 内部数据结构之间的映射关系？","Properties":{"id":""}}]},{"ID":"20220906204354-9tme9a6","Type":"NodeParagraph","Properties":{"id":"20220906204354-9tme9a6","updated":"20220906204354"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204355-kte3tde","Type":"NodeParagraph","Properties":{"id":"20220906204355-kte3tde","updated":"20220906204355"},"Children":[{"Type":"NodeText","Data":"答：MyBatis 将所有 xml 配置信息都封装到 All-In-One 重量级对象 Configuration 内部。在 xml 映射文件中， ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;parameterMap\u0026gt;"},{"Type":"NodeText","Data":" 标签会被解析为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ParameterMap"},{"Type":"NodeText","Data":" 对象，其每个子元素会被解析为 ParameterMapping 对象。 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;resultMap\u0026gt;"},{"Type":"NodeText","Data":" 标签会被解析为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ResultMap"},{"Type":"NodeText","Data":" 对象，其每个子元素会被解析为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ResultMapping"},{"Type":"NodeText","Data":" 对象。每一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"\u0026lt;select\u0026gt;、\u0026lt;insert\u0026gt;、\u0026lt;update\u0026gt;、\u0026lt;delete\u0026gt;"},{"Type":"NodeText","Data":" 标签均会被解析为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"MappedStatement"},{"Type":"NodeText","Data":" 对象，标签内的 sql 会被解析为 BoundSql 对象。","Properties":{"id":""}}]},{"ID":"20220906204356-caktjbj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204356-caktjbj","updated":"20220906204356"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么说 MyBatis 是半自动 ORM 映射工具？它与全自动的区别在哪里？","Properties":{"id":""}}]},{"ID":"20220906204357-5nrcjl5","Type":"NodeParagraph","Properties":{"id":"20220906204357-5nrcjl5","updated":"20220906204357"},"Children":[{"Type":"NodeText","Data":"注：我出的","Properties":{"id":""}}]},{"ID":"20220906204358-wq79kwt","Type":"NodeParagraph","Properties":{"id":"20220906204358-wq79kwt","updated":"20220906204358"},"Children":[{"Type":"NodeText","Data":"答：Hibernate 属于全自动 ORM 映射工具，使用 Hibernate 查询关联对象或者关联集合对象时，可以根据对象关系模型直接获取，所以它是全自动的。而 MyBatis 在查询关联对象或关联集合对象时，需要手动编写 sql 来完成，所以，称之为半自动 ORM 映射工具。","Properties":{"id":""}}]},{"ID":"20220906204359-0vbbnfb","Type":"NodeParagraph","Properties":{"id":"20220906204359-0vbbnfb","updated":"20220906204359"},"Children":[{"Type":"NodeText","Data":"面试题看似都很简单，但是想要能正确回答上来，必定是研究过源码且深入的人，而不是仅会使用的人或者用的很熟的人，以上所有面试题及其答案所涉及的内容，在我的 MyBatis 系列博客中都有详细讲解和原理分析。","Properties":{"id":""}}]}]}