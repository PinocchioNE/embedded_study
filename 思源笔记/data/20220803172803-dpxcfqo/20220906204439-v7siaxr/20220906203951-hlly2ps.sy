roperties":{"id":""}}]},{"ID":"20220906203957-0kuuvlm","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203957-0kuuvlm","updated":"20220906203957"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"关系型数据库介绍","Properties":{"id":""}}]},{"ID":"20220906203958-9g32glp","Type":"NodeParagraph","Properties":{"id":"20220906203958-9g32glp","updated":"20220906203958"},"Children":[{"Type":"NodeText","Data":"顾名思义，关系型数据库就是一种建立在关系模型的基础上的数据库。关系模型表明了数据库中所存储的数据之间的联系（一对一、一对多、多对多）。","Properties":{"id":""}}]},{"ID":"20220906203959-twzhdlp","Type":"NodeParagraph","Properties":{"id":"20220906203959-twzhdlp","updated":"20220906203959"},"Children":[{"Type":"NodeText","Data":"关系型数据库中，我们的数据都被存放在了各种表中（比如用户表），表中的每一行就存放着一条数据（比如一个用户的信息）。","Properties":{"id":""}}]},{"ID":"20220906203960-nb4lp2j","Type":"NodeParagraph","Properties":{"id":"20220906203960-nb4lp2j","updated":"20220906203960"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/5e3c1a71724a38245aa43b02_99bf70d46cc247be878de9d3a88f0c44.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203961-ouaenxu","Type":"NodeParagraph","Properties":{"id":"20220906203961-ouaenxu","updated":"20220906203961"},"Children":[{"Type":"NodeText","Data":"大部分关系型数据库都使用 SQL 来操作数据库中的数据。并且，大部分关系型数据库都支持事务的四大特性(ACID)。","Properties":{"id":""}}]},{"ID":"20220906203962-3ispwla","Type":"NodeParagraph","Properties":{"id":"20220906203962-3ispwla","updated":"20220906203962"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"有哪些常见的关系型数据库呢？"}]