roperties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/image-20220510105837786.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203998-d24svvx","Type":"NodeParagraph","Properties":{"id":"20220906203998-d24svvx","updated":"20220906203998"},"Children":[{"Type":"NodeText","Data":"如果你只想查看数据库中某个表使用的存储引擎的话，可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"show table status from db_name where name='table_name'"},{"Type":"NodeText","Data":"命令。","Properties":{"id":""}}]},{"ID":"20220906203999-2cju93v","Type":"NodeParagraph","Properties":{"id":"20220906203999-2cju93v","updated":"20220906203999"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"查看表的存储引擎","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/image-20220510110549140.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204000-96bx8c8","Type":"NodeParagraph","Properties":{"id":"20220906204000-96bx8c8","updated":"20220906204000"},"Children":[{"Type":"NodeText","Data":"如果你想要深入了解每个存储引擎以及它们之间的区别，推荐你去阅读以下 MySQL 官方文档对应的介绍(面试不会问这么细，了解即可)：","Properties":{"id":""}}]},{"ID":"20220906204001-fafj6jb","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204001-fafj6jb","updated":"20220906204001"},"Children":[{"ID":"20220906204002-5qu8d18","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204002-5qu8d18","updated":"20220906204002"},"Children":[{"ID":"20220906204003-zfkkvci","Type":"NodeParagraph","Properties":{"id":"20220906204003-zfkkvci","updated":"20220906204003"},"Children":[{"Type":"NodeText","Data":"InnoDB 存储引擎详细介绍：https://dev.mysql.com/doc/refman/8.0/en/innodb-storage-engine.html 。","Properties":{"id":""}}]}]},{"ID":"20220906204004-etcyv91","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204004-etcyv91","updated":"20220906204004"},"Children":[{"ID":"20220906204005-jm00k4u","Type":"NodeParagraph","Properties":{"id":"20220906204005-jm00k4u","updated":"20220906204005"},"Children":[{"Type":"NodeText","Data":"其他存储引擎详细介绍：https://dev.mysql.com/doc/refman/8.0/en/storage-engines.html 。","Properties":{"id":""}}]}]}]},{"ID":"20220906204006-so9ascx","Type":"NodeParagraph","Properties":{"id":"20220906204006-so9ascx","updated":"20220906204006"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/image-20220510155143458.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204007-9sb4y56","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204007-9sb4y56","updated":"20220906204007"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 存储引擎架构了解吗？","Properties":{"id":""}}]},{"ID":"20220906204008-ivk0iev","Type":"NodeParagraph","Properties":{"id":"20220906204008-ivk0iev","updated":"20220906204008"},"Children":[{"Type":"NodeText","Data":"MySQL 存储引擎采用的是插件式架构，支持多种存储引擎，我们甚至可以为不同的数据库表设置不同的存储引擎以适应不同场景的需要。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"存储引擎是基于表的，而不是数据库。"}]},{"ID":"20220906204009-1hqhlb8","Type":"NodeParagraph","Properties":{"id":"20220906204009-1hqhlb8","updated":"20220906204009"},"Children":[{"Type":"NodeText","Data":"并且，你还可以根据 MySQL 定义的存储引擎实现标准接口来编写一个属于自己的存储引擎。这些非官方提供的存储引擎可以称为第三方存储引擎，区别于官方存储引擎。像目前最常用的 InnoDB 其实刚开始就是一个第三方存储引擎，后面由于过于优秀，其被 Oracle 直接收购了。","Properties":{"id":""}}]},{"ID":"20220906204010-muujz5r","Type":"NodeParagraph","Properties":{"id":"20220906204010-muujz5r","updated":"20220906204010"},"Children":[{"Type":"NodeText","Data":"MySQL 官方文档也有介绍到如何编写一个自定义存储引擎，地址：https://dev.mysql.com/doc/internals/en/custom-engine.html 。","Properties":{"id":""}}]},{"ID":"20220906204011-v0u8pez","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204011-v0u8pez","updated":"20220906204011"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyISAM 和 InnoDB 的区别是什么？","Properties":{"id":""}}]},{"ID":"20220906204012-xltec9p","Type":"NodeParagraph","Properties":{"id":"20220906204012-xltec9p","updated":"20220906204012"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210327145248960.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204013-bcecmt3","Type":"NodeParagraph","Properties":{"id":"20220906204013-bcecmt3","updated":"20220906204013"},"Children":[{"Type":"NodeText","Data":"MySQL 5.5 之前，MyISAM 引擎是 MySQL 的默认存储引擎，可谓是风光一时。","Properties":{"id":""}}]},{"ID":"20220906204014-8nhhfcc","Type":"NodeParagraph","Properties":{"id":"20220906204014-8nhhfcc","updated":"20220906204014"},"Children":[{"Type":"NodeText","Data":"虽然，MyISAM 的性能还行，各种特性也还不错（比如全文索引、压缩、空间函数等）。但是，MyISAM 不支持事务和行级锁，而且最大的缺陷就是崩溃后无法安全恢复。","Properties":{"id":""}}]},{"ID":"20220906204015-77clpwd","Type":"NodeParagraph","Properties":{"id":"20220906204015-77clpwd","updated":"20220906204015"},"Children":[{"Type":"NodeText","Data":"MySQL 5.5.5 之前，MyISAM 是 MySQL 的默认存储引擎。5.5.5 版本之后，InnoDB 是 MySQL 的默认存储引擎。","Properties":{"id":""}}]},{"ID":"20220906204016-ykb8m5n","Type":"NodeParagraph","Properties":{"id":"20220906204016-ykb8m5n","updated":"20220906204016"},"Children":[{"Type":"NodeText","Data":"言归正传！咱们下面还是来简单对比一下两者：","Properties":{"id":""}}]},{"ID":"20220906204017-os7txc3","Type":"NodeParagraph","Properties":{"id":"20220906204017-os7txc3","updated":"20220906204017"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1.是否支持行级锁"}]},{"ID":"20220906204018-rgoedlj","Type":"NodeParagraph","Properties":{"id":"20220906204018-rgoedlj","updated":"20220906204018"},"Children":[{"Type":"NodeText","Data":"MyISAM 只有表级锁(table-level locking)，而 InnoDB 支持行级锁(row-level locking)和表级锁,默认为行级锁。","Properties":{"id":""}}]},{"ID":"20220906204019-0wkx31t","Type":"NodeParagraph","Properties":{"id":"20220906204019-0wkx31t","updated":"20220906204019"},"Children":[{"Type":"NodeText","Data":"也就说，MyISAM 一锁就是锁住了整张表，这在并发写的情况下是多么滴憨憨啊！这也是为什么 InnoDB 在并发写的时候，性能更牛皮了！","Properties":{"id":""}}]},{"ID":"20220906204020-zmomm2q","Type":"NodeParagraph","Properties":{"id":"20220906204020-zmomm2q","updated":"20220906204020"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2.是否支持事务"}]},{"ID":"20220906204021-0ofbth0","Type":"NodeParagraph","Properties":{"id":"20220906204021-0ofbth0","updated":"20220906204021"},"Children":[{"Type":"NodeText","Data":"MyISAM 不提供事务支持。","Properties":{"id":""}}]},{"ID":"20220906204022-ooem6ni","Type":"NodeParagraph","Properties":{"id":"20220906204022-ooem6ni","updated":"20220906204022"},"Children":[{"Type":"NodeText","Data":"InnoDB 提供事务支持，实现了 SQL 标准定义了四个隔离级别，具有提交(commit)和回滚(rollback)事务的能力。并且，InnoDB 默认使用的 REPEATABLE-READ（可重读）隔离级别是可以解决幻读问题发生的（基于 MVCC 和 Next-Key Lock）。","Properties":{"id":""}}]},{"ID":"20220906204023-zfwp8no","Type":"NodeParagraph","Properties":{"id":"20220906204023-zfwp8no","updated":"20220906204023"},"Children":[{"Type":"NodeText","Data":"关于 MySQL 事务的详细介绍，可以看看我写的这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/database/mysql/transaction-isolation-level.html","TextMarkTextContent":"MySQL 事务隔离级别详解"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204024-k1xip85","Type":"NodeParagraph","Properties":{"id":"20220906204024-k1xip85","updated":"20220906204024"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"3.是否支持外键"}]},{"ID":"20220906204025-641rqxa","Type":"NodeParagraph","Properties":{"id":"20220906204025-641rqxa","updated":"20220906204025"},"Children":[{"Type":"NodeText","Data":"MyISAM 不支持，而 InnoDB 支持。","Properties":{"id":""}}]},{"ID":"20220906204026-li73p2g","Type":"NodeParagraph","Properties":{"id":"20220906204026-li73p2g","updated":"20220906204026"},"Children":[{"Type":"NodeText","Data":"外键对于维护数据一致性非常有帮助，但是对性能有一定的损耗。因此，通常情况下，我们是不建议在实际生产项目中使用外键的，在业务代码中进行约束即可！","Properties":{"id":""}}]},{"ID":"20220906204027-0a25ah6","Type":"NodeParagraph","Properties":{"id":"20220906204027-0a25ah6","updated":"20220906204027"},"Children":[{"Type":"NodeText","Data":"阿里的《Java 开发手册》也是明确规定禁止使用外键的。","Properties":{"id":""}}]},{"ID":"20220906204028-wzzjgza","Type":"NodeParagraph","Properties":{"id":"20220906204028-wzzjgza","updated":"20220906204028"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/image-20220510090309427.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204029-ljsua7h","Type":"NodeParagraph","Properties":{"id":"20220906204029-ljsua7h","updated":"20220906204029"},"Children":[{"Type":"NodeText","Data":"不过，在代码中进行约束的话，对程序员的能力要求更高，具体是否要采用外键还是要根据你的项目实际情况而定。","Properties":{"id":""}}]},{"ID":"20220906204030-yyt2ujy","Type":"NodeParagraph","Properties":{"id":"20220906204030-yyt2ujy","updated":"20220906204030"},"Children":[{"Type":"NodeText","Data":"总结：一般我们也是不建议在数据库层面使用外键的，应用层面可以解决。不过，这样会对数据的一致性造成威胁。具体要不要使用外键还是要根据你的项目来决定。","Properties":{"id":""}}]},{"ID":"20220906204031-l633h9u","Type":"NodeParagraph","Properties":{"id":"20220906204031-l633h9u","updated":"20220906204031"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"4.是否支持数据库异常崩溃后的安全恢复"}]},{"ID":"20220906204032-6bdhzkd","Type":"NodeParagraph","Properties":{"id":"20220906204032-6bdhzkd","updated":"20220906204032"},"Children":[{"Type":"NodeText","Data":"MyISAM 不支持，而 InnoDB 支持。","Properties":{"id":""}}]},{"ID":"20220906204033-qcu2dk5","Type":"NodeParagraph","Properties":{"id":"20220906204033-qcu2dk5","updated":"20220906204033"},"Children":[{"Type":"NodeText","Data":"使用 InnoDB 的数据库在异常崩溃后，数据库重新启动的时候会保证数据库恢复到崩溃前的状态。这个恢复的过程依赖于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"redo log"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204034-65sbdpm","Type":"NodeParagraph","Properties":{"id":"20220906204034-65sbdpm","updated":"20220906204034"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"5.是否支持 MVCC"}]},{"ID":"20220906204035-8w8qlbk","Type":"NodeParagraph","Properties":{"id":"20220906204035-8w8qlbk","updated":"20220906204035"},"Children":[{"Type":"NodeText","Data":"MyISAM 不支持，而 InnoDB 支持。","Properties":{"id":""}}]},{"ID":"20220906204036-53gb2r3","Type":"NodeParagraph","Properties":{"id":"20220906204036-53gb2r3","updated":"20220906204036"},"Children":[{"Type":"NodeText","Data":"讲真，这个对比有点废话，毕竟 MyISAM 连行级锁都不支持。MVCC 可以看作是行级锁的一个升级，可以有效减少加锁操作，提高性能。","Properties":{"id":""}}]},{"ID":"20220906204037-m4921jo","Type":"NodeParagraph","Properties":{"id":"20220906204037-m4921jo","updated":"20220906204037"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"6.索引实现不一样。"}]},{"ID":"20220906204038-ugc98dy","Type":"NodeParagraph","Properties":{"id":"20220906204038-ugc98dy","updated":"20220906204038"},"Children":[{"Type":"NodeText","Data":"虽然 MyISAM 引擎和 InnoDB 引擎都是使用 B+Tree 作为索引结构，但是两者的实现方式不太一样。","Properties":{"id":""}}]},{"ID":"20220906204039-tvyoplo","Type":"NodeParagraph","Properties":{"id":"20220906204039-tvyoplo","updated":"20220906204039"},"Children":[{"Type":"NodeText","Data":"InnoDB 引擎中，其数据文件本身就是索引文件。相比 MyISAM，索引文件和数据文件是分离的，其表数据文件本身就是按 B+Tree 组织的一个索引结构，树的叶节点 data 域保存了完整的数据记录。","Properties":{"id":""}}]},{"ID":"20220906204040-q6ord6w","Type":"NodeParagraph","Properties":{"id":"20220906204040-q6ord6w","updated":"20220906204040"},"Children":[{"Type":"NodeText","Data":"详细区别，推荐你看看我写的这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/database/mysql/mysql-index.html","TextMarkTextContent":"MySQL 索引详解"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204041-cu504l4","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204041-cu504l4","updated":"20220906204041"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MyISAM 和 InnoDB 如何选择？","Properties":{"id":""}}]},{"ID":"20220906204042-h7t4rkn","Type":"NodeParagraph","Properties":{"id":"20220906204042-h7t4rkn","updated":"20220906204042"},"Children":[{"Type":"NodeText","Data":"大多数时候我们使用的都是 InnoDB 存储引擎，在某些读密集的情况下，使用 MyISAM 也是合适的。不过，前提是你的项目不介意 MyISAM 不支持事务、崩溃恢复等缺点（可是~我们一般都会介意啊！）。","Properties":{"id":""}}]},{"ID":"20220906204043-va6bzfs","Type":"NodeParagraph","Properties":{"id":"20220906204043-va6bzfs","updated":"20220906204043"},"Children":[{"Type":"NodeText","Data":"《MySQL 高性能》上面有一句话这样写到:","Properties":{"id":""}}]},{"ID":"20220906204044-jn2rw40","Type":"NodeBlockquote","Properties":{"id":"20220906204044-jn2rw40","updated":"20220906204044"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204045-2gf17v0","Type":"NodeParagraph","Properties":{"id":"20220906204045-2gf17v0","updated":"20220906204045"},"Children":[{"Type":"NodeText","Data":"不要轻易相信“MyISAM 比 InnoDB 快”之类的经验之谈，这个结论往往不是绝对的。在很多我们已知场景中，InnoDB 的速度都可以让 MyISAM 望尘莫及，尤其是用到了聚簇索引，或者需要访问的数据都可以放入内存的应用。","Properties":{"id":""}}]}]},{"ID":"20220906204046-z0vwdj8","Type":"NodeParagraph","Properties":{"id":"20220906204046-z0vwdj8","updated":"20220906204046"},"Children":[{"Type":"NodeText","Data":"一般情况下我们选择 InnoDB 都是没有问题的，但是某些情况下你并不在乎可扩展能力和并发能力，也不需要事务支持，也不在乎崩溃后的安全恢复问题的话，选择 MyISAM 也是一个不错的选择。但是一般情况下，我们都是需要考虑到这些问题的。","Properties":{"id":""}}]},{"ID":"20220906204047-cm08stw","Type":"NodeParagraph","Properties":{"id":"20220906204047-cm08stw","updated":"20220906204047"},"Children":[{"Type":"NodeText","Data":"因此，对于咱们日常开发的业务系统来说，你几乎找不到什么理由再使用 MyISAM 作为自己的 MySQL 数据库的存储引擎。","Properties":{"id":""}}]},{"ID":"20220906204048-1mk455g","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e   \n    \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/gongzhonghaoxuanchuan.png\" style=\"margin: 0 auto;\" /\u003e  \n\u003c/div\u003e","HtmlBlockType":6,"Properties":{"id":"20220906204048-1mk455g","updated":"20220906204048"}},{"ID":"20220906204049-4phu0y5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204049-4phu0y5","updated":"20220906204049"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 查询缓存","Properties":{"id":""}}]},{"ID":"20220906204050-i69nh5a","Type":"NodeParagraph","Properties":{"id":"20220906204050-i69nh5a","updated":"20220906204050"},"Children":[{"Type":"NodeText","Data":"执行查询语句的时候，会先查询缓存。不过，MySQL 8.0 版本后移除，因为这个功能不太实用","Properties":{"id":""}}]},{"ID":"20220906204051-j6161pm","Type":"NodeParagraph","Properties":{"id":"20220906204051-j6161pm","updated":"20220906204051"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"my.cnf"},{"Type":"NodeText","Data":" 加入以下配置，重启 MySQL 开启查询缓存","Properties":{"id":""}}]},{"ID":"20220906204052-cbxzmke","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHJvcGVydGllcw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204052-cbxzmke","updated":"20220906204052"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"query_cache_type=1\nquery_cache_size=600000\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204053-ctcukbw","Type":"NodeParagraph","Properties":{"id":"20220906204053-ctcukbw","updated":"20220906204053"},"Children":[{"Type":"NodeText","Data":"MySQL 执行以下命令也可以开启查询缓存","Properties":{"id":""}}]},{"ID":"20220906204054-f1b7a44","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHJvcGVydGllcw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204054-f1b7a44","updated":"20220906204054"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHJvcGVydGllcw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"set global  query_cache_type=1;\nset global  query_cache_size=600000;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204055-4a0l28z","Type":"NodeParagraph","Properties":{"id":"20220906204055-4a0l28z","updated":"20220906204055"},"Children":[{"Type":"NodeText","Data":"如上，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"开启查询缓存后在同样的查询条件以及数据情况下，会直接在缓存中返回结果"},{"Type":"NodeText","Data":"。这里的查询条件包括查询本身、当前要查询的数据库、客户端协议版本号等一些可能影响结果的信息。（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"查询缓存不命中的情况：（1）"},{"Type":"NodeText","Data":"）因此任何两个查询在任何字符上的不同都会导致缓存不命中。此外，（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"查询缓存不命中的情况：（2）"},{"Type":"NodeText","Data":"）如果查询中包含任何用户自定义函数、存储函数、用户变量、临时表、MySQL 库中的系统表，其查询结果也不会被缓存。","Properties":{"id":""}}]},{"ID":"20220906204056-pxkam2k","Type":"NodeParagraph","Properties":{"id":"20220906204056-pxkam2k","updated":"20220906204056"},"Children":[{"Type":"NodeText","Data":"（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"查询缓存不命中的情况：（3）"},{"Type":"NodeText","Data":"）","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缓存建立之后"},{"Type":"NodeText","Data":"，MySQL 的查询缓存系统会跟踪查询中涉及的每张表，如果这些表（数据或结构）发生变化，那么和这张表相关的所有缓存数据都将失效。","Properties":{"id":""}}]},{"ID":"20220906204057-lyg5xfe","Type":"NodeParagraph","Properties":{"id":"20220906204057-lyg5xfe","updated":"20220906204057"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缓存虽然能够提升数据库的查询性能，但是缓存同时也带来了额外的开销，每次查询后都要做一次缓存操作，失效后还要销毁。"},{"Type":"NodeText","Data":" 因此，开启查询缓存要谨慎，尤其对于写密集的应用来说更是如此。如果开启，要注意合理控制缓存空间大小，一般来说其大小设置为几十 MB 比较合适。此外，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"还可以通过 sql_cache 和 sql_no_cache 来控制某个查询语句是否需要缓存："}]},{"ID":"20220906204058-h8ejfgk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204058-h8ejfgk","updated":"20220906204058"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"select sql_no_cache count(*) from usr;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204059-wy568tv","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204059-wy568tv","updated":"20220906204059"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 事务","Properties":{"id":""}}]},{"ID":"20220906204060-wrszd5m","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204060-wrszd5m","updated":"20220906204060"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"何谓事务？","Properties":{"id":""}}]},{"ID":"20220906204061-r0sfad8","Type":"NodeParagraph","Properties":{"id":"20220906204061-r0sfad8","updated":"20220906204061"},"Children":[{"Type":"NodeText","Data":"我们设想一个场景，这个场景中我们需要插入多条相关联的数据到数据库，不幸的是，这个过程可能会遇到下面这些问题：","Properties":{"id":""}}]},{"ID":"20220906204062-94fqlkk","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204062-94fqlkk","updated":"20220906204062"},"Children":[{"ID":"20220906204063-y6z9hau","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204063-y6z9hau","updated":"20220906204063"},"Children":[{"ID":"20220906204064-yl9rzrr","Type":"NodeParagraph","Properties":{"id":"20220906204064-yl9rzrr","updated":"20220906204064"},"Children":[{"Type":"NodeText","Data":"数据库中途突然因为某些原因挂掉了。","Properties":{"id":""}}]}]},{"ID":"20220906204065-71ftvt4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204065-71ftvt4","updated":"20220906204065"},"Children":[{"ID":"20220906204066-cue55yc","Type":"NodeParagraph","Properties":{"id":"20220906204066-cue55yc","updated":"20220906204066"},"Children":[{"Type":"NodeText","Data":"客户端突然因为网络原因连接不上数据库了。","Properties":{"id":""}}]}]},{"ID":"20220906204067-4sbwulo","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204067-4sbwulo","updated":"20220906204067"},"Children":[{"ID":"20220906204068-bp25lp6","Type":"NodeParagraph","Properties":{"id":"20220906204068-bp25lp6","updated":"20220906204068"},"Children":[{"Type":"NodeText","Data":"并发访问数据库时，多个线程同时写入数据库，覆盖了彼此的更改。","Properties":{"id":""}}]}]},{"ID":"20220906204069-uuyj7nk","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204069-uuyj7nk","updated":"20220906204069"},"Children":[{"ID":"20220906204070-p1a790m","Type":"NodeParagraph","Properties":{"id":"20220906204070-p1a790m","updated":"20220906204070"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204071-qx8yr90","Type":"NodeParagraph","Properties":{"id":"20220906204071-qx8yr90","updated":"20220906204071"},"Children":[{"Type":"NodeText","Data":"上面的任何一个问题都可能会导致数据的不一致性。为了保证数据的一致性，系统必须能够处理这些问题。事务就是我们抽象出来简化这些问题的首选机制。事务的概念起源于数据库，目前，已经成为一个比较广泛的概念。","Properties":{"id":""}}]},{"ID":"20220906204072-6rgvdv1","Type":"NodeParagraph","Properties":{"id":"20220906204072-6rgvdv1","updated":"20220906204072"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"何为事务？"},{"Type":"NodeText","Data":" 一言蔽之，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"事务是逻辑上的一组操作，要么都执行，要么都不执行。"}]},{"ID":"20220906204073-k7ihfpb","Type":"NodeParagraph","Properties":{"id":"20220906204073-k7ihfpb","updated":"20220906204073"},"Children":[{"Type":"NodeText","Data":"事务最经典也经常被拿出来说例子就是转账了。假如小明要给小红转账 1000 元，这个转账会涉及到两个关键操作，这两个操作必须都成功或者都失败。","Properties":{"id":""}}]},{"ID":"20220906204074-63unq21","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204074-63unq21","updated":"20220906204074"},"Children":[{"ID":"20220906204075-awncajg","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204075-awncajg","updated":"20220906204075"},"Children":[{"ID":"20220906204076-erkmz3h","Type":"NodeParagraph","Properties":{"id":"20220906204076-erkmz3h","updated":"20220906204076"},"Children":[{"Type":"NodeText","Data":"将小明的余额减少 1000 元","Properties":{"id":""}}]}]},{"ID":"20220906204077-a8xt1de","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204077-a8xt1de","updated":"20220906204077"},"Children":[{"ID":"20220906204078-y927d5v","Type":"NodeParagraph","Properties":{"id":"20220906204078-y927d5v","updated":"20220906204078"},"Children":[{"Type":"NodeText","Data":"将小红的余额增加 1000 元。","Properties":{"id":""}}]}]}]},{"ID":"20220906204079-o71pkv4","Type":"NodeParagraph","Properties":{"id":"20220906204079-o71pkv4","updated":"20220906204079"},"Children":[{"Type":"NodeText","Data":"事务会把这两个操作就可以看成逻辑上的一个整体，这个整体包含的操作要么都成功，要么都要失败。这样就不会出现小明余额减少而小红的余额却并没有增加的情况。","Properties":{"id":""}}]},{"ID":"20220906204080-rk9vaxc","Type":"NodeParagraph","Properties":{"id":"20220906204080-rk9vaxc","updated":"20220906204080"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"事务示意图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/%E4%BA%8B%E5%8A%A1%E7%A4%BA%E6%84%8F%E5%9B%BE.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204081-lu3nyfi","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204081-lu3nyfi","updated":"20220906204081"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"何谓数据库事务？","Properties":{"id":""}}]},{"ID":"20220906204082-8sq775k","Type":"NodeParagraph","Properties":{"id":"20220906204082-8sq775k","updated":"20220906204082"},"Children":[{"Type":"NodeText","Data":"大多数情况下，我们在谈论事务的时候，如果没有特指","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"分布式事务"},{"Type":"NodeText","Data":"，往往指的就是","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数据库事务"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204083-arjixp0","Type":"NodeParagraph","Properties":{"id":"20220906204083-arjixp0","updated":"20220906204083"},"Children":[{"Type":"NodeText","Data":"数据库事务在我们日常开发中接触的最多了。如果你的项目属于单体架构的话，你接触到的往往就是数据库事务了。","Properties":{"id":""}}]},{"ID":"20220906204084-jdlcwys","Type":"NodeParagraph","Properties":{"id":"20220906204084-jdlcwys","updated":"20220906204084"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"那数据库事务有什么作用呢？"}]},{"ID":"20220906204085-9yxhhcr","Type":"NodeParagraph","Properties":{"id":"20220906204085-9yxhhcr","updated":"20220906204085"},"Children":[{"Type":"NodeText","Data":"简单来说，数据库事务可以保证多个对数据库的操作（也就是 SQL 语句）构成一个逻辑上的整体。构成这个逻辑上的整体的这些数据库操作遵循：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"要么全部执行成功,要么全部不执行"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204086-m6git89","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204086-m6git89","updated":"20220906204086"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 开启一个事务\nSTART TRANSACTION;\n# 多条 SQL 语句\nSQL1,SQL2...\n### 提交事务\nCOMMIT;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204087-jpjnjrx","Type":"NodeParagraph","Properties":{"id":"20220906204087-jpjnjrx","updated":"20220906204087"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"数据库事务示意图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/%E6%95%B0%E6%8D%AE%E5%BA%93%E4%BA%8B%E5%8A%A1%E7%A4%BA%E6%84%8F%E5%9B%BE.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204088-aydkiam","Type":"NodeParagraph","Properties":{"id":"20220906204088-aydkiam","updated":"20220906204088"},"Children":[{"Type":"NodeText","Data":"另外，关系型数据库（例如：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"MySQL"},{"Type":"NodeText","Data":"、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SQL Server"},{"Type":"NodeText","Data":"、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Oracle"},{"Type":"NodeText","Data":" 等）事务都有 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"ACID"},{"Type":"NodeText","Data":" 特性：","Properties":{"id":""}}]},{"ID":"20220906204089-ilcfwvw","Type":"NodeParagraph","Properties":{"id":"20220906204089-ilcfwvw","updated":"20220906204089"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"ACID","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/ACID.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204090-ax2oqam","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204090-ax2oqam","updated":"20220906204090"},"Children":[{"ID":"20220906204091-v0yyu96","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204091-v0yyu96","updated":"20220906204091"},"Children":[{"ID":"20220906204092-jj255ta","Type":"NodeParagraph","Properties":{"id":"20220906204092-jj255ta","updated":"20220906204092"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"原子性"},{"Type":"NodeText","Data":"（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Atomicity"},{"Type":"NodeText","Data":"） ： 事务是最小的执行单位，不允许分割。事务的原子性确保动作要么全部完成，要么完全不起作用；","Properties":{"id":""}}]}]},{"ID":"20220906204093-eh99d4n","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204093-eh99d4n","updated":"20220906204093"},"Children":[{"ID":"20220906204094-l5phzg1","Type":"NodeParagraph","Properties":{"id":"20220906204094-l5phzg1","updated":"20220906204094"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"一致性"},{"Type":"NodeText","Data":"（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Consistency"},{"Type":"NodeText","Data":"）： 执行事务前后，数据保持一致，例如转账业务中，无论事务是否成功，转账者和收款人的总额应该是不变的；","Properties":{"id":""}}]}]},{"ID":"20220906204095-039foar","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204095-039foar","updated":"20220906204095"},"Children":[{"ID":"20220906204096-1677wrz","Type":"NodeParagraph","Properties":{"id":"20220906204096-1677wrz","updated":"20220906204096"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"隔离性"},{"Type":"NodeText","Data":"（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Isolation"},{"Type":"NodeText","Data":"）： 并发访问数据库时，一个用户的事务不被其他事务所干扰，各并发事务之间数据库是独立的；","Properties":{"id":""}}]}]},{"ID":"20220906204097-iijfx2q","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204097-iijfx2q","updated":"20220906204097"},"Children":[{"ID":"20220906204098-hd1ryx7","Type":"NodeParagraph","Properties":{"id":"20220906204098-hd1ryx7","updated":"20220906204098"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"持久性"},{"Type":"NodeText","Data":"（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Durabilily"},{"Type":"NodeText","Data":"）： 一个事务被提交之后。它对数据库中数据的改变是持久的，即使数据库发生故障也不应该对其有任何影响。","Properties":{"id":""}}]}]}]},{"ID":"20220906204099-gwae97p","Type":"NodeParagraph","Properties":{"id":"20220906204099-gwae97p","updated":"20220906204099"},"Children":[{"Type":"NodeText","Data":"🌈 这里要额外补充一点：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"只有保证了事务的持久性、原子性、隔离性之后，一致性才能得到保障。也就是说 A、I、D 是手段，C 是目的！"},{"Type":"NodeText","Data":" 想必大家也和我一样，被 ACID 这个概念被误导了很久! 我也是看周志明老师的公开课","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://time.geekbang.org/opencourse/intro/100064201","TextMarkTextContent":"《周志明的软件架构课》"},{"Type":"NodeText","Data":"才搞清楚的（多看好书！！！）。","Properties":{"id":""}}]},{"ID":"20220906204100-bj5ykrl","Type":"NodeParagraph","Properties":{"id":"20220906204100-bj5ykrl","updated":"20220906204100"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"AID-\u003eC","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/AID-%3EC.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204101-xskt3yx","Type":"NodeParagraph","Properties":{"id":"20220906204101-xskt3yx","updated":"20220906204101"},"Children":[{"Type":"NodeText","Data":"另外，DDIA 也就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://book.douban.com/subject/30329536/","TextMarkTextContent":"《Designing Data-Intensive Application（数据密集型应用系统设计）》"},{"Type":"NodeText","Data":" 的作者在他的这本书中如是说：","Properties":{"id":""}}]},{"ID":"20220906204102-1huw1zk","Type":"NodeBlockquote","Properties":{"id":"20220906204102-1huw1zk","updated":"20220906204102"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204103-0k22slp","Type":"NodeParagraph","Properties":{"id":"20220906204103-0k22slp","updated":"20220906204103"},"Children":[{"Type":"NodeText","Data":"Atomicity, isolation, and durability are properties of the database, whereas consis‐","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"tency (in the ACID sense) is a property of the application. The application may rely","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"on the database’s atomicity and isolation properties in order to achieve consistency,","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"but it’s not up to the database alone.","Properties":{"id":""}}]},{"ID":"20220906204104-4ljw4ba","Type":"NodeParagraph","Properties":{"id":"20220906204104-4ljw4ba","updated":"20220906204104"},"Children":[{"Type":"NodeText","Data":"翻译过来的意思是：原子性，隔离性和持久性是数据库的属性，而一致性（在 ACID 意义上）是应用程序的属性。应用可能依赖数据库的原子性和隔离属性来实现一致性，但这并不仅取决于数据库。因此，字母 C 不属于 ACID 。","Properties":{"id":""}}]}]},{"ID":"20220906204105-rzyhvpe","Type":"NodeParagraph","Properties":{"id":"20220906204105-rzyhvpe","updated":"20220906204105"},"Children":[{"Type":"NodeText","Data":"《Designing Data-Intensive Application（数据密集型应用系统设计）》这本书强推一波，值得读很多遍！豆瓣有接近 90% 的人看了这本书之后给了五星好评。另外，中文翻译版本已经在 Github 开源，地址：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Vonng/ddia","TextMarkTextContent":"https://github.com/Vonng/ddia"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204106-fgk3tqh","Type":"NodeParagraph","Properties":{"id":"20220906204106-fgk3tqh","updated":"20220906204106"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210526162552353.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204107-61ue1v1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204107-61ue1v1","updated":"20220906204107"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"并发事务带来了哪些问题?","Properties":{"id":""}}]},{"ID":"20220906204108-gwhqd1f","Type":"NodeParagraph","Properties":{"id":"20220906204108-gwhqd1f","updated":"20220906204108"},"Children":[{"Type":"NodeText","Data":"在典型的应用程序中，多个事务并发运行，经常会操作相同的数据来完成各自的任务（多个用户对同一数据进行操作）。并发虽然是必须的，但可能会导致以下的问题。","Properties":{"id":""}}]},{"ID":"20220906204109-uun0xqr","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204109-uun0xqr","updated":"20220906204109"},"Children":[{"ID":"20220906204110-cd7rlks","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204110-cd7rlks","updated":"20220906204110"},"Children":[{"ID":"20220906204111-azwt8sv","Type":"NodeParagraph","Properties":{"id":"20220906204111-azwt8sv","updated":"20220906204111"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"脏读（Dirty read）:"},{"Type":"NodeText","Data":" 当一个事务正在访问数据并且对数据进行了修改，而这种修改还没有提交到数据库中，这时另外一个事务也访问了这个数据，然后使用了这个数据。因为这个数据是还没有提交的数据，那么另外一个事务读到的这个数据是“脏数据”，依据“脏数据”所做的操作可能是不正确的。","Properties":{"id":""}}]}]},{"ID":"20220906204112-r4zlwhz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204112-r4zlwhz","updated":"20220906204112"},"Children":[{"ID":"20220906204113-4cavxsi","Type":"NodeParagraph","Properties":{"id":"20220906204113-4cavxsi","updated":"20220906204113"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"丢失修改（Lost to modify）:"},{"Type":"NodeText","Data":" 指在一个事务读取一个数据时，另外一个事务也访问了该数据，那么在第一个事务中修改了这个数据后，第二个事务也修改了这个数据。这样第一个事务内的修改结果就被丢失，因此称为丢失修改。 例如：事务 1 读取某表中的数据 A=20，事务 2 也读取 A=20，事务 1 修改 A=A-1，事务 2 也修改 A=A-1，最终结果 A=19，事务 1 的修改被丢失。","Properties":{"id":""}}]}]},{"ID":"20220906204114-3soznm6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204114-3soznm6","updated":"20220906204114"},"Children":[{"ID":"20220906204115-k1rcfv7","Type":"NodeParagraph","Properties":{"id":"20220906204115-k1rcfv7","updated":"20220906204115"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不可重复读（Unrepeatable read）:"},{"Type":"NodeText","Data":" 指在一个事务内多次读同一数据。在这个事务还没有结束时，另一个事务也访问该数据。那么，在第一个事务中的两次读数据之间，由于第二个事务的修改导致第一个事务两次读取的数据可能不太一样。这就发生了在一个事务内两次读到的数据是不一样的情况，因此称为不可重复读。","Properties":{"id":""}}]}]},{"ID":"20220906204116-s8xr8ii","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204116-s8xr8ii","updated":"20220906204116"},"Children":[{"ID":"20220906204117-yh2xix7","Type":"NodeParagraph","Properties":{"id":"20220906204117-yh2xix7","updated":"20220906204117"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"幻读（Phantom read）:"},{"Type":"NodeText","Data":" 幻读与不可重复读类似。它发生在一个事务（T1）读取了几行数据，接着另一个并发事务（T2）插入了一些数据时。在随后的查询中，第一个事务（T1）就会发现多了一些原本不存在的记录，就好像发生了幻觉一样，所以称为幻读。","Properties":{"id":""}}]}]}]},{"ID":"20220906204118-xg9ol8l","Type":"NodeParagraph","Properties":{"id":"20220906204118-xg9ol8l","updated":"20220906204118"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不可重复读和幻读有什么区别呢？"}]},{"ID":"20220906204119-urfmeuf","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204119-urfmeuf","updated":"20220906204119"},"Children":[{"ID":"20220906204120-m2mx9be","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204120-m2mx9be","updated":"20220906204120"},"Children":[{"ID":"20220906204121-qttmjjm","Type":"NodeParagraph","Properties":{"id":"20220906204121-qttmjjm","updated":"20220906204121"},"Children":[{"Type":"NodeText","Data":"不可重复读的重点是内容修改或者记录减少比如多次读取一条记录发现其中某些记录的值被修改；","Properties":{"id":""}}]}]},{"ID":"20220906204122-oouj8ku","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204122-oouj8ku","updated":"20220906204122"},"Children":[{"ID":"20220906204123-5fda5rn","Type":"NodeParagraph","Properties":{"id":"20220906204123-5fda5rn","updated":"20220906204123"},"Children":[{"Type":"NodeText","Data":"幻读的重点在于记录新增比如多次执行同一条查询语句（DQL）时，发现查到的记录增加了。","Properties":{"id":""}}]}]}]},{"ID":"20220906204124-9rorvwy","Type":"NodeParagraph","Properties":{"id":"20220906204124-9rorvwy","updated":"20220906204124"},"Children":[{"Type":"NodeText","Data":"幻读其实可以看作是不可重复读的一种特殊情况，单独把区分幻读的原因主要是解决幻读和不可重复读的方案不一样。","Properties":{"id":""}}]},{"ID":"20220906204125-4mulisa","Type":"NodeParagraph","Properties":{"id":"20220906204125-4mulisa","updated":"20220906204125"},"Children":[{"Type":"NodeText","Data":"举个例子：执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"update"},{"Type":"NodeText","Data":" 操作的时候，可以直接对记录加锁，保证事务安全。而执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"insert"},{"Type":"NodeText","Data":" 操作的时候，由于记录锁（Record Lock）只能锁住已经存在的记录，为了避免插入新记录，需要依赖间隙锁（Gap Lock）。也就是说执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"insert"},{"Type":"NodeText","Data":" 操作的时候需要依赖 Next-Key Lock（Record Lock+Gap Lock） 进行加锁来保证不出现幻读。","Properties":{"id":""}}]},{"ID":"20220906204126-84ezxnt","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204126-84ezxnt","updated":"20220906204126"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"SQL 标准定义了哪些事务隔离级别?","Properties":{"id":""}}]},{"ID":"20220906204127-5gxw4cm","Type":"NodeParagraph","Properties":{"id":"20220906204127-5gxw4cm","updated":"20220906204127"},"Children":[{"Type":"NodeText","Data":"SQL 标准定义了四个隔离级别：","Properties":{"id":""}}]},{"ID":"20220906204128-us6rrit","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204128-us6rrit","updated":"20220906204128"},"Children":[{"ID":"20220906204129-tskzjvn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204129-tskzjvn","updated":"20220906204129"},"Children":[{"ID":"20220906204130-71ojcy0","Type":"NodeParagraph","Properties":{"id":"20220906204130-71ojcy0","updated":"20220906204130"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"READ-UNCOMMITTED(读取未提交)"},{"Type":"NodeText","Data":" ： 最低的隔离级别，允许读取尚未提交的数据变更，可能会导致脏读、幻读或不可重复读。","Properties":{"id":""}}]}]},{"ID":"20220906204131-bh40cmg","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204131-bh40cmg","updated":"20220906204131"},"Children":[{"ID":"20220906204132-097v4tt","Type":"NodeParagraph","Properties":{"id":"20220906204132-097v4tt","updated":"20220906204132"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"READ-COMMITTED(读取已提交)"},{"Type":"NodeText","Data":" ： 允许读取并发事务已经提交的数据，可以阻止脏读，但是幻读或不可重复读仍有可能发生。","Properties":{"id":""}}]}]},{"ID":"20220906204133-m786ezu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204133-m786ezu","updated":"20220906204133"},"Children":[{"ID":"20220906204134-7i7yr2k","Type":"NodeParagraph","Properties":{"id":"20220906204134-7i7yr2k","updated":"20220906204134"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"REPEATABLE-READ(可重复读)"},{"Type":"NodeText","Data":" ： 对同一字段的多次读取结果都是一致的，除非数据是被本身事务自己所修改，可以阻止脏读和不可重复读，但幻读仍有可能发生。","Properties":{"id":""}}]}]},{"ID":"20220906204135-chjj32e","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204135-chjj32e","updated":"20220906204135"},"Children":[{"ID":"20220906204136-5iqj8q2","Type":"NodeParagraph","Properties":{"id":"20220906204136-5iqj8q2","updated":"20220906204136"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"SERIALIZABLE(可串行化)"},{"Type":"NodeText","Data":" ： 最高的隔离级别，完全服从 ACID 的隔离级别。所有的事务依次逐个执行，这样事务之间就完全不可能产生干扰，也就是说，该级别可以防止脏读、不可重复读以及幻读。","Properties":{"id":""}}]}]}]},{"ID":"20220906204137-gr82fm4","Type":"NodeThematicBreak","Properties":{"id":"20220906204137-gr82fm4","updated":"20220906204137"}},{"ID":"20220906204138-nsitmp7","Type":"NodeTable","Data":"|     隔离级别     | 脏读 | 不可重复读 | 幻读 |\n| :--------------: | :--: | :--------: | :--: |\n| READ-UNCOMMITTED |  √   |     √      |  √   |\n|  READ-COMMITTED  |  ×   |     √      |  √   |\n| REPEATABLE-READ  |  ×   |     ×      |  √   |\n|   SERIALIZABLE   |  ×   |     ×      |  ×   |","TableAligns":[2,2,2,2],"Properties":{"id":"20220906204138-nsitmp7","updated":"20220906204138"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"隔离级别","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"脏读","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"不可重复读","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"幻读","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[2,2,2,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"READ-UNCOMMITTED","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[2,2,2,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"READ-COMMITTED","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[2,2,2,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"REPEATABLE-READ","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"√","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[2,2,2,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"SERIALIZABLE","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"×","Properties":{"id":""}}]}]}]},{"ID":"20220906204139-z9xo4tl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204139-z9xo4tl","updated":"20220906204139"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 的隔离级别是基于锁实现的吗？","Properties":{"id":""}}]},{"ID":"20220906204140-zcbaq44","Type":"NodeParagraph","Properties":{"id":"20220906204140-zcbaq44","updated":"20220906204140"},"Children":[{"Type":"NodeText","Data":"MySQL 的隔离级别基于锁和 MVCC 机制共同实现的。","Properties":{"id":""}}]},{"ID":"20220906204141-iva6btl","Type":"NodeParagraph","Properties":{"id":"20220906204141-iva6btl","updated":"20220906204141"},"Children":[{"Type":"NodeText","Data":"SERIALIZABLE 隔离级别，是通过锁来实现的。除了 SERIALIZABLE 隔离级别，其他的隔离级别都是基于 MVCC 实现。","Properties":{"id":""}}]},{"ID":"20220906204142-7ba0i1c","Type":"NodeParagraph","Properties":{"id":"20220906204142-7ba0i1c","updated":"20220906204142"},"Children":[{"Type":"NodeText","Data":"不过， SERIALIZABLE 之外的其他隔离级别可能也需要用到锁机制，就比如 REPEATABLE-READ 在当前读情况下需要使用加锁读来保证不会出现幻读。","Properties":{"id":""}}]},{"ID":"20220906204143-emw5emf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204143-emw5emf","updated":"20220906204143"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 的默认隔离级别是什么?","Properties":{"id":""}}]},{"ID":"20220906204144-dummzdd","Type":"NodeParagraph","Properties":{"id":"20220906204144-dummzdd","updated":"20220906204144"},"Children":[{"Type":"NodeText","Data":"MySQL InnoDB 存储引擎的默认支持的隔离级别是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"REPEATABLE-READ（可重读）"},{"Type":"NodeText","Data":"。我们可以通过","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SELECT @@tx_isolation;"},{"Type":"NodeText","Data":"命令来查看，MySQL 8.0 该命令改为","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SELECT @@transaction_isolation;"}]},{"ID":"20220906204145-z65a4d6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204145-z65a4d6","updated":"20220906204145"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"mysql\u003e SELECT @@tx_isolation;\n+-----------------+\n| @@tx_isolation  |\n+-----------------+\n| REPEATABLE-READ |\n+-----------------+\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204146-hetynij","Type":"NodeParagraph","Properties":{"id":"20220906204146-hetynij","updated":"20220906204146"},"Children":[{"Type":"NodeText","Data":"关于 MySQL 事务隔离级别的详细介绍，可以看看我写的这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/database/mysql/transaction-isolation-level.html","TextMarkTextContent":"MySQL 事务隔离级别详解"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204147-y112qz6","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e   \n    \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/gongzhonghaoxuanchuan.png\" style=\"margin: 0 auto;\" /\u003e  \n\u003c/div\u003e","HtmlBlockType":6,"Properties":{"id":"20220906204147-y112qz6","updated":"20220906204147"}},{"ID":"20220906204148-dznkv52","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204148-dznkv52","updated":"20220906204148"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 锁","Properties":{"id":""}}]},{"ID":"20220906204149-xtyiwoo","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204149-xtyiwoo","updated":"20220906204149"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"表级锁和行级锁了解吗？有什么区别？","Properties":{"id":""}}]},{"ID":"20220906204150-zek98h7","Type":"NodeParagraph","Properties":{"id":"20220906204150-zek98h7","updated":"20220906204150"},"Children":[{"Type":"NodeText","Data":"MyISAM 仅仅支持表级锁(table-level locking)，一锁就锁整张表，这在并发写的情况下性非常差。","Properties":{"id":""}}]},{"ID":"20220906204151-7l4ider","Type":"NodeParagraph","Properties":{"id":"20220906204151-7l4ider","updated":"20220906204151"},"Children":[{"Type":"NodeText","Data":"InnoDB 不光支持表级锁(table-level locking)，还支持行级锁(row-level locking)，默认为行级锁。行级锁的粒度更小，仅对相关的记录上锁即可（对一行或者多行记录加锁），所以对于并发写入操作来说， InnoDB 的性能更高。","Properties":{"id":""}}]},{"ID":"20220906204152-qwcfsb3","Type":"NodeParagraph","Properties":{"id":"20220906204152-qwcfsb3","updated":"20220906204152"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"表级锁和行级锁对比"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204153-nnjoqg5","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204153-nnjoqg5","updated":"20220906204153"},"Children":[{"ID":"20220906204154-13c3ucm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204154-13c3ucm","updated":"20220906204154"},"Children":[{"ID":"20220906204155-lk9mk23","Type":"NodeParagraph","Properties":{"id":"20220906204155-lk9mk23","updated":"20220906204155"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"表级锁："},{"Type":"NodeText","Data":" MySQL 中锁定粒度最大的一种锁，是针对非索引字段加的锁，对当前操作的整张表加锁，实现简单，资源消耗也比较少，加锁快，不会出现死锁。其锁定粒度最大，触发锁冲突的概率最高，并发度最低，MyISAM 和 InnoDB 引擎都支持表级锁。","Properties":{"id":""}}]}]},{"ID":"20220906204156-m6zatcz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204156-m6zatcz","updated":"20220906204156"},"Children":[{"ID":"20220906204157-eu8vxo9","Type":"NodeParagraph","Properties":{"id":"20220906204157-eu8vxo9","updated":"20220906204157"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"行级锁："},{"Type":"NodeText","Data":" MySQL 中锁定粒度最小的一种锁，是针对索引字段加的锁，只针对当前操作的行记录进行加锁。 行级锁能大大减少数据库操作的冲突。其加锁粒度最小，并发度高，但加锁的开销也最大，加锁慢，会出现死锁。","Properties":{"id":""}}]}]}]},{"ID":"20220906204158-8vx14qw","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204158-8vx14qw","updated":"20220906204158"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"行级锁的使用有什么注意事项？","Properties":{"id":""}}]},{"ID":"20220906204159-tnpzg1r","Type":"NodeParagraph","Properties":{"id":"20220906204159-tnpzg1r","updated":"20220906204159"},"Children":[{"Type":"NodeText","Data":"InnoDB 的行锁是针对索引字段加的锁，表级锁是针对非索引字段加的锁。当我们执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"UPDATE"},{"Type":"NodeText","Data":"、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"DELETE"},{"Type":"NodeText","Data":" 语句时，如果 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"WHERE"},{"Type":"NodeText","Data":"条件中字段没有命中唯一索引或者索引失效的话，就会导致扫描全表对表中的所有行记录进行加锁。这个在我们日常工作开发中经常会遇到，一定要多多注意！！！","Properties":{"id":""}}]},{"ID":"20220906204160-yhf21gg","Type":"NodeParagraph","Properties":{"id":"20220906204160-yhf21gg","updated":"20220906204160"},"Children":[{"Type":"NodeText","Data":"不过，很多时候即使用了索引也有可能会走全表扫描，这是因为 MySQL 优化器的原因。","Properties":{"id":""}}]},{"ID":"20220906204161-9hrsgkg","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204161-9hrsgkg","updated":"20220906204161"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"共享锁和排他锁呢？","Properties":{"id":""}}]},{"ID":"20220906204162-jhujcvl","Type":"NodeParagraph","Properties":{"id":"20220906204162-jhujcvl","updated":"20220906204162"},"Children":[{"Type":"NodeText","Data":"不论是表级锁还是行级锁，都存在共享锁（Share Lock，S 锁）和排他锁（Exclusive Lock，X 锁）这两类：","Properties":{"id":""}}]},{"ID":"20220906204163-k3u1jwc","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204163-k3u1jwc","updated":"20220906204163"},"Children":[{"ID":"20220906204164-s6l5mxp","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204164-s6l5mxp","updated":"20220906204164"},"Children":[{"ID":"20220906204165-ghxay2q","Type":"NodeParagraph","Properties":{"id":"20220906204165-ghxay2q","updated":"20220906204165"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"共享锁（S 锁）"},{"Type":"NodeText","Data":" ：又称读锁，事务在读取记录的时候获取共享锁，允许多个事务同时获取（锁兼容）。","Properties":{"id":""}}]}]},{"ID":"20220906204166-wb7yf9w","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204166-wb7yf9w","updated":"20220906204166"},"Children":[{"ID":"20220906204167-at7uaau","Type":"NodeParagraph","Properties":{"id":"20220906204167-at7uaau","updated":"20220906204167"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"排他锁（X 锁）"},{"Type":"NodeText","Data":" ：又称写锁/独占锁，事务在修改记录的时候获取排他锁，不允许多个事务同时获取。如果一个记录已经被加了排他锁，那其他事务不能再对这条事务加任何类型的锁（锁不兼容）。","Properties":{"id":""}}]}]}]},{"ID":"20220906204168-2loksul","Type":"NodeParagraph","Properties":{"id":"20220906204168-2loksul","updated":"20220906204168"},"Children":[{"Type":"NodeText","Data":"排他锁与任何的锁都不兼容，共享锁仅和共享锁兼容。","Properties":{"id":""}}]},{"ID":"20220906204169-nelu2zx","Type":"NodeTable","Data":"|      | S 锁   | X 锁 |\n| :--- | :----- | :--- |\n| S 锁 | 不冲突 | 冲突 |\n| X 锁 | 冲突   | 冲突 |","TableAligns":[1,1,1],"Properties":{"id":"20220906204169-nelu2zx","updated":"20220906204169"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""}},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"S 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"X 锁","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"S 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"不冲突","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"冲突","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"X 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"冲突","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"冲突","Properties":{"id":""}}]}]}]},{"ID":"20220906204170-lpsv3ck","Type":"NodeParagraph","Properties":{"id":"20220906204170-lpsv3ck","updated":"20220906204170"},"Children":[{"Type":"NodeText","Data":"由于 MVCC 的存在，对于一般的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SELECT"},{"Type":"NodeText","Data":" 语句，InnoDB 不会加任何锁。不过， 你可以通过以下语句显式加共享锁或排他锁。","Properties":{"id":""}}]},{"ID":"20220906204171-rs903ty","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204171-rs903ty","updated":"20220906204171"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 共享锁\nSELECT ... LOCK IN SHARE MODE;\n# 排他锁\nSELECT ... FOR UPDATE;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204172-9fwovbr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204172-9fwovbr","updated":"20220906204172"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"意向锁有什么作用？","Properties":{"id":""}}]},{"ID":"20220906204173-dqrxqs0","Type":"NodeParagraph","Properties":{"id":"20220906204173-dqrxqs0","updated":"20220906204173"},"Children":[{"Type":"NodeText","Data":"如果需要用到表锁的话，如何判断表中的记录没有行锁呢？一行一行遍历肯定是不行，性能太差。我们需要用到一个叫做意向锁的东东来快速判断是否可以对某个表使用表锁。","Properties":{"id":""}}]},{"ID":"20220906204174-1us0q2j","Type":"NodeParagraph","Properties":{"id":"20220906204174-1us0q2j","updated":"20220906204174"},"Children":[{"Type":"NodeText","Data":"意向锁是表级锁，共有两种：","Properties":{"id":""}}]},{"ID":"20220906204175-p9zj0zt","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204175-p9zj0zt","updated":"20220906204175"},"Children":[{"ID":"20220906204176-ixu31m7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204176-ixu31m7","updated":"20220906204176"},"Children":[{"ID":"20220906204177-gnetyqx","Type":"NodeParagraph","Properties":{"id":"20220906204177-gnetyqx","updated":"20220906204177"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"意向共享锁（Intention Shared Lock，IS 锁）"},{"Type":"NodeText","Data":"：事务有意向对表中的某些加共享锁（S 锁），加共享锁前必须先取得该表的 IS 锁。","Properties":{"id":""}}]}]},{"ID":"20220906204178-oeh403u","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204178-oeh403u","updated":"20220906204178"},"Children":[{"ID":"20220906204179-786aqoc","Type":"NodeParagraph","Properties":{"id":"20220906204179-786aqoc","updated":"20220906204179"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"意向排他锁（Intention Exclusive Lock，IX 锁）"},{"Type":"NodeText","Data":"：事务有意向对表中的某些记录加排他锁（X 锁），加排他锁之前必须先取得该表的 IX 锁。","Properties":{"id":""}}]}]}]},{"ID":"20220906204180-xve05kw","Type":"NodeParagraph","Properties":{"id":"20220906204180-xve05kw","updated":"20220906204180"},"Children":[{"Type":"NodeText","Data":"意向锁是有数据引擎自己维护的，用户无法手动操作意向锁，在为数据行加共享 / 排他锁之前，InooDB 会先获取该数据行所在在数据表的对应意向锁。","Properties":{"id":""}}]},{"ID":"20220906204181-2y0np8m","Type":"NodeParagraph","Properties":{"id":"20220906204181-2y0np8m","updated":"20220906204181"},"Children":[{"Type":"NodeText","Data":"意向锁之间是互相兼容的。","Properties":{"id":""}}]},{"ID":"20220906204182-drr5cuc","Type":"NodeTable","Data":"|       | IS 锁 | IX 锁 |\n| ----- | ----- | ----- |\n| IS 锁 | 兼容  | 兼容  |\n| IX 锁 | 兼容  | 兼容  |","TableAligns":[0,0,0],"Properties":{"id":"20220906204182-drr5cuc","updated":"20220906204182"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""}},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IS 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IX 锁","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IS 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"兼容","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"兼容","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IX 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"兼容","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"兼容","Properties":{"id":""}}]}]}]},{"ID":"20220906204183-r88k5l1","Type":"NodeParagraph","Properties":{"id":"20220906204183-r88k5l1","updated":"20220906204183"},"Children":[{"Type":"NodeText","Data":"意向锁和共享锁和排它锁互斥（这里指的是表级别的共享锁和排他锁，意向锁不会与行级的共享锁和排他锁互斥）。","Properties":{"id":""}}]},{"ID":"20220906204184-9r8i009","Type":"NodeTable","Data":"|      | IS 锁 | IX 锁 |\n| ---- | ----- | ----- |\n| S 锁 | 兼容  | 互斥  |\n| X 锁 | 互斥  | 互斥  |","TableAligns":[0,0,0],"Properties":{"id":"20220906204184-9r8i009","updated":"20220906204184"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""}},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IS 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"IX 锁","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"S 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"兼容","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"互斥","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"X 锁","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"互斥","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"互斥","Properties":{"id":""}}]}]}]},{"ID":"20220906204185-9byl045","Type":"NodeParagraph","Properties":{"id":"20220906204185-9byl045","updated":"20220906204185"},"Children":[{"Type":"NodeText","Data":"《MySQL 技术内幕 InnoDB 存储引擎》这本书对应的描述应该是笔误了。","Properties":{"id":""}}]},{"ID":"20220906204186-e60f5hg","Type":"NodeParagraph","Properties":{"id":"20220906204186-e60f5hg","updated":"20220906204186"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/mysql/image-20220511171419081.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204187-o4d1ntk","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204187-o4d1ntk","updated":"20220906204187"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"InnoDB 有哪几类行锁？","Properties":{"id":""}}]},{"ID":"20220906204188-oss7jwc","Type":"NodeParagraph","Properties":{"id":"20220906204188-oss7jwc","updated":"20220906204188"},"Children":[{"Type":"NodeText","Data":"MySQL InnoDB 支持三种行锁定方式：","Properties":{"id":""}}]},{"ID":"20220906204189-k1rzjnx","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204189-k1rzjnx","updated":"20220906204189"},"Children":[{"ID":"20220906204190-ztnu89i","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204190-ztnu89i","updated":"20220906204190"},"Children":[{"ID":"20220906204191-zi6w98s","Type":"NodeParagraph","Properties":{"id":"20220906204191-zi6w98s","updated":"20220906204191"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"记录锁（Record Lock）"},{"Type":"NodeText","Data":" ：也被称为记录锁，属于单个行记录上的锁。","Properties":{"id":""}}]}]},{"ID":"20220906204192-bb4kb2r","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204192-bb4kb2r","updated":"20220906204192"},"Children":[{"ID":"20220906204193-cwwk19u","Type":"NodeParagraph","Properties":{"id":"20220906204193-cwwk19u","updated":"20220906204193"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"间隙锁（Gap Lock）"},{"Type":"NodeText","Data":" ：锁定一个范围，不包括记录本身。","Properties":{"id":""}}]}]},{"ID":"20220906204194-loh8c86","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204194-loh8c86","updated":"20220906204194"},"Children":[{"ID":"20220906204195-933iedj","Type":"NodeParagraph","Properties":{"id":"20220906204195-933iedj","updated":"20220906204195"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"临键锁（Next-key Lock）"},{"Type":"NodeText","Data":" ：Record Lock+Gap Lock，锁定一个范围，包含记录本身。记录锁只能锁住已经存在的记录，为了避免插入新记录，需要依赖间隙锁。","Properties":{"id":""}}]}]}]},{"ID":"20220906204196-slwbu7d","Type":"NodeParagraph","Properties":{"id":"20220906204196-slwbu7d","updated":"20220906204196"},"Children":[{"Type":"NodeText","Data":"InnoDB 的默认隔离级别 RR（可重读）是可以解决幻读问题发生的，主要有下面两种情况：","Properties":{"id":""}}]},{"ID":"20220906204197-6dpsnr2","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204197-6dpsnr2","updated":"20220906204197"},"Children":[{"ID":"20220906204198-vn4h1zl","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204198-vn4h1zl","updated":"20220906204198"},"Children":[{"ID":"20220906204199-4t1pqqj","Type":"NodeParagraph","Properties":{"id":"20220906204199-4t1pqqj","updated":"20220906204199"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"快照读"},{"Type":"NodeText","Data":"（一致性非锁定读） ：由 MVCC 机制来保证不出现幻读。","Properties":{"id":""}}]}]},{"ID":"20220906204200-q3fqpue","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204200-q3fqpue","updated":"20220906204200"},"Children":[{"ID":"20220906204201-dn7woms","Type":"NodeParagraph","Properties":{"id":"20220906204201-dn7woms","updated":"20220906204201"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"当前读"},{"Type":"NodeText","Data":" （一致性锁定读）： 使用 Next-Key Lock 进行加锁来保证不出现幻读。","Properties":{"id":""}}]}]}]},{"ID":"20220906204202-hmz2gfr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204202-hmz2gfr","updated":"20220906204202"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"当前读和快照读有什么区别？","Properties":{"id":""}}]},{"ID":"20220906204203-f3zdbld","Type":"NodeParagraph","Properties":{"id":"20220906204203-f3zdbld","updated":"20220906204203"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"快照读"},{"Type":"NodeText","Data":"（一致性非锁定读）就是单纯的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SELECT"},{"Type":"NodeText","Data":" 语句，但不包括下面这两类 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SELECT"},{"Type":"NodeText","Data":" 语句：","Properties":{"id":""}}]},{"ID":"20220906204204-845yw6d","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204204-845yw6d","updated":"20220906204204"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"SELECT ... FOR UPDATE\nSELECT ... LOCK IN SHARE MODE\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204205-v5iwrae","Type":"NodeParagraph","Properties":{"id":"20220906204205-v5iwrae","updated":"20220906204205"},"Children":[{"Type":"NodeText","Data":"快照即记录的历史版本，每行记录可能存在多个历史版本（多版本技术）。","Properties":{"id":""}}]},{"ID":"20220906204206-gmbefmm","Type":"NodeParagraph","Properties":{"id":"20220906204206-gmbefmm","updated":"20220906204206"},"Children":[{"Type":"NodeText","Data":"快照读的情况下，如果读取的记录正在执行 UPDATE/DELETE 操作，读取操作不会因此去等待记录上 X 锁的释放，而是会去读取行的一个快照。","Properties":{"id":""}}]},{"ID":"20220906204207-fpnmcq5","Type":"NodeParagraph","Properties":{"id":"20220906204207-fpnmcq5","updated":"20220906204207"},"Children":[{"Type":"NodeText","Data":"只有在事务隔离级别 RC(读取已提交) 和 RR（可重读）下，InnoDB 才会使用一致性非锁定读：","Properties":{"id":""}}]},{"ID":"20220906204208-nrb4veb","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204208-nrb4veb","updated":"20220906204208"},"Children":[{"ID":"20220906204209-lzr5n76","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204209-lzr5n76","updated":"20220906204209"},"Children":[{"ID":"20220906204210-vs5hw8v","Type":"NodeParagraph","Properties":{"id":"20220906204210-vs5hw8v","updated":"20220906204210"},"Children":[{"Type":"NodeText","Data":"在 RC 级别下，对于快照数据，一致性非锁定读总是读取被锁定行的最新一份快照数据。","Properties":{"id":""}}]}]},{"ID":"20220906204211-4wxazlj","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204211-4wxazlj","updated":"20220906204211"},"Children":[{"ID":"20220906204212-e2fvrqa","Type":"NodeParagraph","Properties":{"id":"20220906204212-e2fvrqa","updated":"20220906204212"},"Children":[{"Type":"NodeText","Data":"在 RR 级别下，对于快照数据，一致性非锁定读总是读取本事务开始时的行数据版本。","Properties":{"id":""}}]}]}]},{"ID":"20220906204213-l0wtqxp","Type":"NodeParagraph","Properties":{"id":"20220906204213-l0wtqxp","updated":"20220906204213"},"Children":[{"Type":"NodeText","Data":"快照读比较适合对于数据一致性要求不是特别高且追求极致性能的业务场景。","Properties":{"id":""}}]},{"ID":"20220906204214-cv92dkb","Type":"NodeParagraph","Properties":{"id":"20220906204214-cv92dkb","updated":"20220906204214"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"当前读"},{"Type":"NodeText","Data":" （一致性锁定读）就是给行记录加 X 锁或 S 锁。","Properties":{"id":""}}]},{"ID":"20220906204215-versl5q","Type":"NodeParagraph","Properties":{"id":"20220906204215-versl5q","updated":"20220906204215"},"Children":[{"Type":"NodeText","Data":"当前读的一些常见 SQL 语句类型如下：","Properties":{"id":""}}]},{"ID":"20220906204216-6covb45","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204216-6covb45","updated":"20220906204216"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 对读的记录加一个X锁\nSELECT...FOR UPDATE\n# 对读的记录加一个S锁\nSELECT...LOCK IN SHARE MODE\n# 对修改的记录加一个X锁\nINSERT...\nUPDATE...\nDELETE...\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204217-2o0t6l2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204217-2o0t6l2","updated":"20220906204217"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"参考","Properties":{"id":""}}]},{"ID":"20220906204218-2e92dvb","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204218-2e92dvb","updated":"20220906204218"},"Children":[{"ID":"20220906204219-awozoxt","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204219-awozoxt","updated":"20220906204219"},"Children":[{"ID":"20220906204220-huksa5u","Type":"NodeParagraph","Properties":{"id":"20220906204220-huksa5u","updated":"20220906204220"},"Children":[{"Type":"NodeText","Data":"《高性能 MySQL》第 7 章 MySQL 高级特性","Properties":{"id":""}}]}]},{"ID":"20220906204221-bw8yncz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45