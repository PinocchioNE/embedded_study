arkType":"strong","TextMarkTextContent":"优化器："},{"Type":"NodeText","Data":" 按照 MySQL 认为最优的方案去执行。","Properties":{"id":""}}]}]},{"ID":"20220906203982-rjpqea7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203982-rjpqea7","updated":"20220906203982"},"Children":[{"ID":"20220906203983-dgxo1el","Type":"NodeParagraph","Properties":{"id":"20220906203983-dgxo1el","updated":"20220906203983"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"执行器："},{"Type":"NodeText","Data":" 执行语句，然后从存储引擎返回数据。 执行语句之前会先判断是否有权限，如果没有权限的话，就会报错。","Properties":{"id":""}}]}]},{"ID":"20220906203984-llug5q2","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203984-llug5q2","updated":"20220906203984"},"Children":[{"ID":"20220906203985-igq8g3t","Type":"NodeParagraph","Properties":{"id":"20220906203985-igq8g3t","updated":"20220906203985"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"插件式存储引擎"},{"Type":"NodeText","Data":" ： 主要负责数据的存储和读取，采用的是插件式架构，支持 InnoDB、MyISAM、Memory 等多种存储引擎。","Properties":{"id":""}}]}]}]},{"ID":"20220906203986-4qnbkgc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203986-4qnbkgc","updated":"20220906203986"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MySQL 存储引擎","Properties":{"id":""}}]},{"ID":"20220906203987-ays0grf","Type":"NodeParagraph","Properties":{"id":"20220906203987-ays0grf","updated":"20220906203987"},"Children":[{"Type":"NodeText","Data":"MySQL 核心在于存储引擎，想要深入学习 MySQL，必定要深入研究 MySQL 存储引擎。","Properties":{"id":""}}]},{"ID":"20220906203988-1rfn1ai","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203988-1rfn1ai","updated":"20220906203988"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":