,"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204224-kuxdqn2","Type":"NodeParagraph","Properties":{"id":"20220906204224-kuxdqn2","updated":"20220906204224"},"Children":[{"Type":"NodeText","Data":"这些场景往往都要求我们在某个特定的时间去做某个事情。","Properties":{"id":""}}]},{"ID":"20220906204225-c4s27ij","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204225-c4s27ij","updated":"20220906204225"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"单机定时任务技术选型有哪些？","Properties":{"id":""}}]},{"ID":"20220906204226-cwhe634","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204226-cwhe634","updated":"20220906204226"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Timer","Properties":{"id":""}}]},{"ID":"20220906204227-8dkoxl0","Type":"NodeParagraph","Properties":{"id":"20220906204227-8dkoxl0","updated":"20220906204227"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"java.util.Timer"},{"Type":"NodeText","Data":"是 JDK 1.3 开始就已经支持的一种定时任务的实现方式。","Properties":{"id":""}}]},{"ID":"20220906204228-0qiw0wp","Type":"NodeParagraph","Properties":{"id":"20220906204228-0qiw0wp","updated":"20220906204228"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 内部使用一个叫做 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TaskQueue"},{"Type":"NodeText","Data":" 的类存放定时任务，它是一个基于最小堆实现的优先级队列。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TaskQueue"},{"Type":"NodeText","Data":" 会按照任务距离下一次执行时间的大小将任务排序，保证在堆顶的任务最先执行。这样在需要执行任务时，每次只需要取出堆顶的任务运行即可！","Properties":{"id":""}}]},{"ID":"20220906204229-6l6pe0p","Type":"NodeParagraph","Properties":{"id":"20220906204229-6l6pe0p","updated":"20220906204229"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 使用起来比较简单，通过下面的方式我们就能创建一个 1s 之后执行的定时任务。","Properties":{"id":""}}]},{"ID":"20220906204230-1h9t17m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204230-1h9t17m","updated":"20220906204230"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// 示例代码：\nTimerTask task = new TimerTask() {\n    public void run() {\n        System.out.println(\"当前时间: \" + new Date() + \"n\" +\n                \"线程名称: \" + Thread.currentThread().getName());\n    }\n};\nSystem.out.println(\"当前时间: \" + new Date() + \"n\" +\n        \"线程名称: \" + Thread.currentThread().getName());\nTimer timer = new Timer(\"Timer\");\nlong delay = 1000L;\ntimer.schedule(task, delay);\n\n\n//输出：\n当前时间: Fri May 28 15:18:47 CST 2021n线程名称: main\n当前时间: Fri May 28 15:18:48 CST 2021n线程名称: Timer\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204231-nmv2uyr","Type":"NodeParagraph","Properties":{"id":"20220906204231-nmv2uyr","updated":"20220906204231"},"Children":[{"Type":"NodeText","Data":"不过其缺陷较多，比如一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 一个线程，这就导致 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 的任务的执行只能串行执行，一个任务执行时间过长的话会影响其他任务（性能非常差），再比如发生异常时任务直接停止（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 只捕获了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"InterruptedException"},{"Type":"NodeText","Data":" ）。","Properties":{"id":""}}]},{"ID":"20220906204232-lzpfxaq","Type":"NodeParagraph","Properties":{"id":"20220906204232-lzpfxaq","updated":"20220906204232"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 类上的有一段注释是这样写的：","Properties":{"id":""}}]},{"ID":"20220906204233-mtmf5t0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"SkFWQQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204233-mtmf5t0","updated":"20220906204233"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"SkFWQQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":" * This class does not offer real-time guarantees: it schedules\n * tasks using the \u003ctt\u003eObject.wait(long)\u003c/tt\u003e method.\n *Java 5.0 introduced the {@code java.util.concurrent} package and\n * one of the concurrency utilities therein is the {@link\n * java.util.concurrent.ScheduledThreadPoolExecutor\n * ScheduledThreadPoolExecutor} which is a thread pool for repeatedly\n * executing tasks at a given rate or delay.  It is effectively a more\n * versatile replacement for the {@code Timer}/{@code TimerTask}\n * combination, as it allows multiple service threads, accepts various\n * time units, and doesn't require subclassing {@code TimerTask} (just\n * implement {@code Runnable}).  Configuring {@code\n * ScheduledThreadPoolExecutor} with one thread makes it equivalent to\n * {@code Timer}.\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204234-4igx3jp","Type":"NodeParagraph","Properties":{"id":"20220906204234-4igx3jp","updated":"20220906204234"},"Children":[{"Type":"NodeText","Data":"大概的意思就是： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledThreadPoolExecutor"},{"Type":"NodeText","Data":" 支持多线程执行定时任务并且功能更强大，是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 的替代品。","Properties":{"id":""}}]},{"ID":"20220906204235-k7hi3rk","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204235-k7hi3rk","updated":"20220906204235"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ScheduledExecutorService","Properties":{"id":""}}]},{"ID":"20220906204236-bqn1iu3","Type":"NodeParagraph","Properties":{"id":"20220906204236-bqn1iu3","updated":"20220906204236"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledExecutorService"},{"Type":"NodeText","Data":" 是一个接口，有多个实现类，比较常用的是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledThreadPoolExecutor"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204237-4g1h54k","Type":"NodeParagraph","Properties":{"id":"20220906204237-4g1h54k","updated":"20220906204237"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/javaguide/20210607154324712.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204238-sa46fdy","Type":"NodeParagraph","Properties":{"id":"20220906204238-sa46fdy","updated":"20220906204238"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledThreadPoolExecutor"},{"Type":"NodeText","Data":" 本身就是一个线程池，支持任务并发执行。并且，其内部使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"DelayQueue"},{"Type":"NodeText","Data":" 作为任务队列。","Properties":{"id":""}}]},{"ID":"20220906204239-lafkdlf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204239-lafkdlf","updated":"20220906204239"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// 示例代码：\nTimerTask repeatedTask = new TimerTask() {\n    @SneakyThrows\n    public void run() {\n        System.out.println(\"当前时间: \" + new Date() + \"n\" +\n                \"线程名称: \" + Thread.currentThread().getName());\n    }\n};\nSystem.out.println(\"当前时间: \" + new Date() + \"n\" +\n        \"线程名称: \" + Thread.currentThread().getName());\nScheduledExecutorService executor = Executors.newScheduledThreadPool(3);\nlong delay  = 1000L;\nlong period = 1000L;\nexecutor.scheduleAtFixedRate(repeatedTask, delay, period, TimeUnit.MILLISECONDS);\nThread.sleep(delay + period * 5);\nexecutor.shutdown();\n//输出：\n当前时间: Fri May 28 15:40:46 CST 2021n线程名称: main\n当前时间: Fri May 28 15:40:47 CST 2021n线程名称: pool-1-thread-1\n当前时间: Fri May 28 15:40:48 CST 2021n线程名称: pool-1-thread-1\n当前时间: Fri May 28 15:40:49 CST 2021n线程名称: pool-1-thread-2\n当前时间: Fri May 28 15:40:50 CST 2021n线程名称: pool-1-thread-2\n当前时间: Fri May 28 15:40:51 CST 2021n线程名称: pool-1-thread-2\n当前时间: Fri May 28 15:40:52 CST 2021n线程名称: pool-1-thread-2\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204240-u4aprwx","Type":"NodeParagraph","Properties":{"id":"20220906204240-u4aprwx","updated":"20220906204240"},"Children":[{"Type":"NodeText","Data":"不论是使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Timer"},{"Type":"NodeText","Data":" 还是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledExecutorService"},{"Type":"NodeText","Data":" 都无法使用 Cron 表达式指定任务执行的具体时间。","Properties":{"id":""}}]},{"ID":"20220906204241-1nsnzhm","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204241-1nsnzhm","updated":"20220906204241"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring Task","Properties":{"id":""}}]},{"ID":"20220906204242-2kfpdas","Type":"NodeParagraph","Properties":{"id":"20220906204242-2kfpdas","updated":"20220906204242"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210528145056880.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204243-h91c7dr","Type":"NodeParagraph","Properties":{"id":"20220906204243-h91c7dr","updated":"20220906204243"},"Children":[{"Type":"NodeText","Data":"我们直接通过 Spring 提供的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"@Scheduled"},{"Type":"NodeText","Data":" 注解即可定义定时任务，非常方便！","Properties":{"id":""}}]},{"ID":"20220906204244-zrdkbp7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204244-zrdkbp7","updated":"20220906204244"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"/**\n * cron：使用Cron表达式。　每分钟的1，2秒运行\n */\n@Scheduled(cron = \"1-2 * * * * ? \")\npublic void reportCurrentTimeWithCronExpression() {\n  log.info(\"Cron Expression: The time is now {}\", dateFormat.format(new Date()));\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204245-r1mo66o","Type":"NodeParagraph","Properties":{"id":"20220906204245-r1mo66o","updated":"20220906204245"},"Children":[{"Type":"NodeText","Data":"我在大学那会做的一个 SSM 的企业级项目，就是用的 Spring Task 来做的定时任务。","Properties":{"id":""}}]},{"ID":"20220906204246-csz91mo","Type":"NodeParagraph","Properties":{"id":"20220906204246-csz91mo","updated":"20220906204246"},"Children":[{"Type":"NodeText","Data":"并且，Spring Task 还是支持 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Cron 表达式"},{"Type":"NodeText","Data":" 的。Cron 表达式主要用于定时作业(定时任务)系统定义执行时间或执行频率的表达式，非常厉害，你可以通过 Cron 表达式进行设置定时任务每天或者每个月什么时候执行等等操作。咱们要学习定时任务的话，Cron 表达式是一定是要重点关注的。推荐一个在线 Cron 表达式生成器：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"http://cron.qqe2.com/","TextMarkTextContent":"http://cron.qqe2.com/"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204247-d7jvy6y","Type":"NodeParagraph","Properties":{"id":"20220906204247-d7jvy6y","updated":"20220906204247"},"Children":[{"Type":"NodeText","Data":"但是，Spring 自带的定时调度只支持单机，并且提供的功能比较单一。之前写过一篇文章:","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://mp.weixin.qq.com/s?__biz=Mzg2OTA0Njk0OA==\u0026mid=2247485563\u0026idx=1\u0026sn=7419341f04036a10b141b74624a3f8c9\u0026chksm=cea247b0f9d5cea6440759e6d49b4e77d06f4c99470243a10c1463834e873ca90266413fbc92\u0026token=2133161636\u0026lang=zh_CN#rd","TextMarkTextContent":"《5 分钟搞懂如何在 Spring Boot 中 Schedule Tasks》"},{"Type":"NodeText","Data":" ，不了解的小伙伴可以参考一下。","Properties":{"id":""}}]},{"ID":"20220906204248-1lw35vz","Type":"NodeParagraph","Properties":{"id":"20220906204248-1lw35vz","updated":"20220906204248"},"Children":[{"Type":"NodeText","Data":"Spring Task 底层是基于 JDK 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ScheduledThreadPoolExecutor"},{"Type":"NodeText","Data":" 线程池来实现的。","Properties":{"id":""}}]},{"ID":"20220906204249-35edt2d","Type":"NodeParagraph","Properties":{"id":"20220906204249-35edt2d","updated":"20220906204249"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优缺点总结："}]},{"ID":"20220906204250-hn5cywq","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204250-hn5cywq","updated":"20220906204250"},"Children":[{"ID":"20220906204251-sclf1hf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204251-sclf1hf","updated":"20220906204251"},"Children":[{"ID":"20220906204252-u298wik","Type":"NodeParagraph","Properties":{"id":"20220906204252-u298wik","updated":"20220906204252"},"Children":[{"Type":"NodeText","Data":"优点： 简单，轻量，支持 Cron 表达式","Properties":{"id":""}}]}]},{"ID":"20220906204253-cq99vlu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204253-cq99vlu","updated":"20220906204253"},"Children":[{"ID":"20220906204254-epxkuk1","Type":"NodeParagraph","Properties":{"id":"20220906204254-epxkuk1","updated":"20220906204254"},"Children":[{"Type":"NodeText","Data":"缺点 ：功能单一","Properties":{"id":""}}]}]}]},{"ID":"20220906204255-kz6hm1x","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204255-kz6hm1x","updated":"20220906204255"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"时间轮","Properties":{"id":""}}]},{"ID":"20220906204256-teon5lu","Type":"NodeParagraph","Properties":{"id":"20220906204256-teon5lu","updated":"20220906204256"},"Children":[{"Type":"NodeText","Data":"Kafka、Dubbo、ZooKeeper、Netty 、Caffeine 、Akka 中都有对时间轮的实现。","Properties":{"id":""}}]},{"ID":"20220906204257-h7ujo4g","Type":"NodeParagraph","Properties":{"id":"20220906204257-h7ujo4g","updated":"20220906204257"},"Children":[{"Type":"NodeText","Data":"时间轮简单来说就是一个环形的队列（底层一般基于数组实现），队列中的每一个元素（时间格）都可以存放一个定时任务列表。","Properties":{"id":""}}]},{"ID":"20220906204258-80kjkps","Type":"NodeParagraph","Properties":{"id":"20220906204258-80kjkps","updated":"20220906204258"},"Children":[{"Type":"NodeText","Data":"时间轮中的每个时间格代表了时间轮的基本时间跨度或者说时间精度，加入时间一秒走一个时间格的话，那么这个时间轮的最高精度就是 1 秒（也就是说 3 s 和 3.9s 会在同一个时间格中）。","Properties":{"id":""}}]},{"ID":"20220906204259-wxrl2ll","Type":"NodeParagraph","Properties":{"id":"20220906204259-wxrl2ll","updated":"20220906204259"},"Children":[{"Type":"NodeText","Data":"下图是一个有 12 个时间格的时间轮，转完一圈需要 12 s。当我们需要新建一个 3s 后执行的定时任务，只需要将定时任务放在下标为 3 的时间格中即可。当我们需要新建一个 9s 后执行的定时任务，只需要将定时任务放在下标为 9 的时间格中即可。","Properties":{"id":""}}]},{"ID":"20220906204260-faceujy","Type":"NodeParagraph","Properties":{"id":"20220906204260-faceujy","updated":"20220906204260"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/javaguide/20210607171334861.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204261-ugi7d3w","Type":"NodeParagraph","Properties":{"id":"20220906204261-ugi7d3w","updated":"20220906204261"},"Children":[{"Type":"NodeText","Data":"那当我们需要创建一个 13s 后执行的定时任务怎么办呢？这个时候可以引入一叫做 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"圈数/轮数"},{"Type":"NodeText","Data":" 的概念，也就是说这个任务还是放在下标为 3 的时间格中， 不过它的圈数为 2 。","Properties":{"id":""}}]},{"ID":"20220906204262-okvjh3x","Type":"NodeParagraph","Properties":{"id":"20220906204262-okvjh3x","updated":"20220906204262"},"Children":[{"Type":"NodeText","Data":"除了增加圈数这种方法之外，还有一种 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"多层次时间轮"},{"Type":"NodeText","Data":" （类似手表），Kafka 采用的就是这种方案。","Properties":{"id":""}}]},{"ID":"20220906204263-hjufb0u","Type":"NodeParagraph","Properties":{"id":"20220906204263-hjufb0u","updated":"20220906204263"},"Children":[{"Type":"NodeText","Data":"针对下图的时间轮，我来举一个例子便于大家理解。","Properties":{"id":""}}]},{"ID":"20220906204264-8ixqlmy","Type":"NodeParagraph","Properties":{"id":"20220906204264-8ixqlmy","updated":"20220906204264"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/javaguide/20210607193042151.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204265-i8ty7c8","Type":"NodeParagraph","Properties":{"id":"20220906204265-i8ty7c8","updated":"20220906204265"},"Children":[{"Type":"NodeText","Data":"上图的时间轮，第 1 层的时间精度为 1 ，第 2 层的时间精度为 20 ，第 3 层的时间精度为 400。假如我们需要添加一个 350s 后执行的任务 A 的话（当前时间是 0s），这个任务会被放在第 2 层（因为第二层的时间跨度为 20*","Properties":{"id":""}},{"Type":"NodeText","Data":"20=400\u003e350）的第 350/20=17 个时间格子。","Properties":{"id":""}}]},{"ID":"20220906204266-6jq9zjz","Type":"NodeParagraph","Properties":{"id":"20220906204266-6jq9zjz","updated":"20220906204266"},"Children":[{"Type":"NodeText","Data":"当第一层转了 17 圈之后，时间过去了 340s ，第 2 层的指针此时来到第 17 个时间格子。此时，第 2 层第 17 个格子的任务会被移动到第 1 层。","Properties":{"id":""}}]},{"ID":"20220906204267-8phk3mj","Type":"NodeParagraph","Properties":{"id":"20220906204267-8phk3mj","updated":"20220906204267"},"Children":[{"Type":"NodeText","Data":"任务 A 当前是 10s 之后执行，因此它会被移动到第 1 层的第 10 个时间格子。","Properties":{"id":""}}]},{"ID":"20220906204268-n3mgj0j","Type":"NodeParagraph","Properties":{"id":"20220906204268-n3mgj0j","updated":"20220906204268"},"Children":[{"Type":"NodeText","Data":"这里在层与层之间的移动也叫做时间轮的升降级。参考手表来理解就好！","Properties":{"id":""}}]},{"ID":"20220906204269-t80izst","Type":"NodeParagraph","Properties":{"id":"20220906204269-t80izst","updated":"20220906204269"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210607195206797.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204270-99tjilr","Type":"NodeParagraph","Properties":{"id":"20220906204270-99tjilr","updated":"20220906204270"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"时间轮比较适合任务数量比较多的定时任务场景，它的任务写入和执行的时间复杂度都是 0（1）。"}]},{"ID":"20220906204271-xefq3l3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204271-xefq3l3","updated":"20220906204271"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分布式定时任务技术选型有哪些？","Properties":{"id":""}}]},{"ID":"20220906204272-oib3cdu","Type":"NodeParagraph","Properties":{"id":"20220906204272-oib3cdu","updated":"20220906204272"},"Children":[{"Type":"NodeText","Data":"上面提到的一些定时任务的解决方案都是在单机下执行的，适用于比较简单的定时任务场景比如每天凌晨备份一次数据。","Properties":{"id":""}}]},{"ID":"20220906204273-rs5883c","Type":"NodeParagraph","Properties":{"id":"20220906204273-rs5883c","updated":"20220906204273"},"Children":[{"Type":"NodeText","Data":"如果我们需要一些高级特性比如支持任务在分布式场景下的分片和高可用的话，我们就需要用到分布式任务调度框架了。","Properties":{"id":""}}]},{"ID":"20220906204274-5hbdwzz","Type":"NodeParagraph","Properties":{"id":"20220906204274-5hbdwzz","updated":"20220906204274"},"Children":[{"Type":"NodeText","Data":"通常情况下，一个定时任务的执行往往涉及到下面这些角色：","Properties":{"id":""}}]},{"ID":"20220906204275-z8nqpx6","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204275-z8nqpx6","updated":"20220906204275"},"Children":[{"ID":"20220906204276-6cs7if0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204276-6cs7if0","updated":"20220906204276"},"Children":[{"ID":"20220906204277-w621b91","Type":"NodeParagraph","Properties":{"id":"20220906204277-w621b91","updated":"20220906204277"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"任务"},{"Type":"NodeText","Data":" ： 首先肯定是要执行的任务，这个任务就是具体的业务逻辑比如定时发送文章。","Properties":{"id":""}}]}]},{"ID":"20220906204278-gwzqlve","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204278-gwzqlve","updated":"20220906204278"},"Children":[{"ID":"20220906204279-6f0xc5z","Type":"NodeParagraph","Properties":{"id":"20220906204279-6f0xc5z","updated":"20220906204279"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"调度器"},{"Type":"NodeText","Data":" ：其次是调度中心，调度中心主要负责任务管理，会分配任务给执行器。","Properties":{"id":""}}]}]},{"ID":"20220906204280-0javx8x","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204280-0javx8x","updated":"20220906204280"},"Children":[{"ID":"20220906204281-2tdc0ch","Type":"NodeParagraph","Properties":{"id":"20220906204281-2tdc0ch","updated":"20220906204281"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"执行器"},{"Type":"NodeText","Data":" ： 最后就是执行器，执行器接收调度器分派的任务并执行。","Properties":{"id":""}}]}]}]},{"ID":"20220906204282-jc6m63u","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204282-jc6m63u","updated":"20220906204282"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Quartz","Properties":{"id":""}}]},{"ID":"20220906204283-xfb685m","Type":"NodeParagraph","Properties":{"id":"20220906204283-xfb685m","updated":"20220906204283"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/2021052814502425.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204284-ljiqfk1","Type":"NodeParagraph","Properties":{"id":"20220906204284-ljiqfk1","updated":"20220906204284"},"Children":[{"Type":"NodeText","Data":"一个很火的开源任务调度框架，完全由","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Java"},{"Type":"NodeText","Data":"写成。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quartz"},{"Type":"NodeText","Data":" 可以说是 Java 定时任务领域的老大哥或者说参考标准，其他的任务调度框架基本都是基于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quartz"},{"Type":"NodeText","Data":" 开发的，比如当当网的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"elastic-job"},{"Type":"NodeText","Data":"就是基于","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"quartz"},{"Type":"NodeText","Data":"二次开发之后的分布式调度解决方案。","Properties":{"id":""}}]},{"ID":"20220906204285-oqfazqf","Type":"NodeParagraph","Properties":{"id":"20220906204285-oqfazqf","updated":"20220906204285"},"Children":[{"Type":"NodeText","Data":"使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quartz"},{"Type":"NodeText","Data":" 可以很方便地与 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Spring"},{"Type":"NodeText","Data":" 集成，并且支持动态添加任务和集群。但是，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quartz"},{"Type":"NodeText","Data":" 使用起来也比较麻烦，API 繁琐。","Properties":{"id":""}}]},{"ID":"20220906204286-222myqv","Type":"NodeParagraph","Properties":{"id":"20220906204286-222myqv","updated":"20220906204286"},"Children":[{"Type":"NodeText","Data":"并且，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quzrtz"},{"Type":"NodeText","Data":" 并没有内置 UI 管理控制台，不过你可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/zhaopeiym/quartzui","TextMarkTextContent":"quartzui"},{"Type":"NodeText","Data":" 这个开源项目来解决这个问题。","Properties":{"id":""}}]},{"ID":"20220906204287-jipu3tu","Type":"NodeParagraph","Properties":{"id":"20220906204287-jipu3tu","updated":"20220906204287"},"Children":[{"Type":"NodeText","Data":"另外，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Quartz"},{"Type":"NodeText","Data":" 虽然也支持分布式任务。但是，它是在数据库层面，通过数据库的锁机制做的，有非常多的弊端比如系统侵入性严重、节点负载不均衡。有点伪分布式的味道。","Properties":{"id":""}}]},{"ID":"20220906204288-22keo6a","Type":"NodeParagraph","Properties":{"id":"20220906204288-22keo6a","updated":"20220906204288"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优缺点总结："}]},{"ID":"20220906204289-txmotrr","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204289-txmotrr","updated":"20220906204289"},"Children":[{"ID":"20220906204290-0xeksbu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204290-0xeksbu","updated":"20220906204290"},"Children":[{"ID":"20220906204291-j04bxhv","Type":"NodeParagraph","Properties":{"id":"20220906204291-j04bxhv","updated":"20220906204291"},"Children":[{"Type":"NodeText","Data":"优点： 可以与 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Spring"},{"Type":"NodeText","Data":" 集成，并且支持动态添加任务和集群。","Properties":{"id":""}}]}]},{"ID":"20220906204292-me51owr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204292-me51owr","updated":"20220906204292"},"Children":[{"ID":"20220906204293-p3cfj2d","Type":"NodeParagraph","Properties":{"id":"20220906204293-p3cfj2d","updated":"20220906204293"},"Children":[{"Type":"NodeText","Data":