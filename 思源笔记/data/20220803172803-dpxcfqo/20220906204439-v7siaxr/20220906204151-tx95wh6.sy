ies":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"认证 (Authentication)："},{"Type":"NodeText","Data":" 你是谁。","Properties":{"id":""}}]}]},{"ID":"20220906204160-9ckee70","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204160-9ckee70","updated":"20220906204160"},"Children":[{"ID":"20220906204161-jnhhwd2","Type":"NodeParagraph","Properties":{"id":"20220906204161-jnhhwd2","updated":"20220906204161"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"授权 (Authorization)："},{"Type":"NodeText","Data":" 你有权限干什么。","Properties":{"id":""}}]}]}]},{"ID":"20220906204162-614gqr5","Type":"NodeParagraph","Properties":{"id":"20220906204162-614gqr5","updated":"20220906204162"},"Children":[{"Type":"NodeText","Data":"稍微正式点（啰嗦点）的说法就是 ：","Properties":{"id":""}}]},{"ID":"20220906204163-hrbfod8","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204163-hrbfod8","updated":"20220906204163"},"Children":[{"ID":"20220906204164-3hkz6ch","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204164-3hkz6ch","updated":"20220906204164"},"Children":[{"ID":"20220906204165-yyqqj4b","Type":"NodeParagraph","Properties":{"id":"20220906204165-yyqqj4b","updated":"20220906204165"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Authentication（认证）"},{"Type":"NodeText","Data":" 是验证您的身份的凭据（例如用户名/用户 ID 和密码），通过这个凭据，系统得以知道你就是你，也就是说系统存在你这个用户。所以，Authentication 被称为身份/用户验证。","Properties":{"id":""}}]}]},{"ID":"20220906204166-e7eli4g","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204166-e7eli4g","updated":"20220906204166"},"Children":[{"ID":"20220906204167-01u36qq"