pe":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"@CookieValue"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 注解获取特定的 cookie 的值"}]},{"ID":"20220906204207-zf6ye24","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204207-zf6ye24","updated":"20220906204207"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"@GetMapping(\"/\")\npublic String readCookie(@CookieValue(value = \"username\", defaultValue = \"Atta\") String username) {\n    return \"Hey! My username is \" + username;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204208-bfwd1u9","Type":"NodeParagraph","Properties":{"id":"20220906204208-bfwd1u9","updated":"20220906204208"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"3) 读取所有的 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"Cookie"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 值"}]},{"ID":"20220906204209-1zdox5g","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204209-1zdox5g","updated":"20220906204209"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"@GetMapping(\"/all-cookies\")\npublic String readAllCookies(HttpServletRequest request) {\n\n    Cookie[] cookies = request.getCookies();\n    if (cookies != null) {\n        return Arrays.stream(cookies)\n                .map(c -\u003e c.getName() + \"=\" + c.getValue()).collect(Collectors.joining(\", \"));\n    }\n\n    return \"No cookies\";\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204210-f9xg7gj","Type":"NodeParagraph","Properties":{"id":"20220906204210-f9xg7gj","updated":"20220906204210"},"Children":[{"Type":"NodeText","Data":"更多关于如何在 Spring Boot 中使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 的内容可以查看这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://attacomsian.com/blog/cookies-spring-boot","TextMarkTextContent":"How to use cookies in Spring Boot"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204211-wszh5w4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204211-wszh5w4","updated":"20220906204211"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Cookie 和 Session 有什么区别？","Properties":{"id":""}}]},{"ID":"20220906204212-5h7y3ad","Type":"NodeParagraph","Properties":{"id":"20220906204212-5h7y3ad","updated":"20220906204212"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"Session"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 的主要作用就是通过服务端记录用户的状态。"},{"Type":"NodeText","Data":" 典型的场景是购物车，当你要添加商品到购物车的时候，系统不知道是哪个用户操作的，因为 HTTP 协议是无状态的。服务端给特定的用户创建特定的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Se