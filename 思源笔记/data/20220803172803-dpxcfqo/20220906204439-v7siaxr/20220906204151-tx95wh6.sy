tps://img-blog.csdnimg.cn/20210604161032412.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204172-r1iedki","Type":"NodeParagraph","Properties":{"id":"20220906204172-r1iedki","updated":"20220906204172"},"Children":[{"Type":"NodeText","Data":"这两个一般在我们的系统中被结合在一起使用，目的就是为了保护我们系统的安全性。","Properties":{"id":""}}]},{"ID":"20220906204173-nefpbot","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204173-nefpbot","updated":"20220906204173"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"RBAC 模型了解吗？","Properties":{"id":""}}]},{"ID":"20220906204174-ejrxnqu","Type":"NodeParagraph","Properties":{"id":"20220906204174-ejrxnqu","updated":"20220906204174"},"Children":[{"Type":"NodeText","Data":"系统权限控制最常采用的访问控制模型就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"RBAC 模型"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204175-ieniddk","Type":"NodeParagraph","Properties":{"id":"20220906204175-ieniddk","updated":"20220906204175"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"什么是 RBAC 呢？"}]},{"ID":"20220906204176-0idj6i8","Type":"NodeParagraph","Properties":{"id":"20220906204176-0idj6i8","updated":"20220906204176"},"Children":[{"Type":"NodeText","Data":"RBAC 即基于角色的权限访问控制（Role-Based Access Control）。这是一种通过角色关联权限，角色同时又关联用户的授权的方式。","Properties":{"id":""}}]},{"ID":"20220906204177-5np4igb","Type":"NodeParagraph","Properties":{"id":"20220906204177-5np4igb","updated":"20220906204177"},"Children":[{"Type":"NodeText","Data":"简单地说：一个用户可以拥有若干角色，每一个角色又可以被分配若干权限，这样就构造成“用户-角色-权限” 的授权模型。在这种模型中，用户与角色、角色与权限之间构成了多对多的关系，如下图","Properties":{"id":""}}]},{"ID":"20220906204178-dg7j9sw","Type":"NodeParagraph","Properties":{"id":"20220906204178-dg7j9sw","updated":"20220906204178"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"RBAC 权限模型示意图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/security/design-of-authority-system/rbac.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204179-4vc410q","Type":"NodeParagraph","Properties":{"id":"20220906204179-4vc410q","updated":"20220906204179"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"在 RBAC 中，权限与角色相关联，用户通过成为适当角色的成员而得到这些角色的权限。这就极大地简化了权限的管理。"}]},{"ID":"20220906204180-j0xv3s9","Type":"NodeParagraph","Properties":{"id":"20220906204180-j0xv3s9","updated":"20220906204180"},"Children":[{"Type":"NodeText","Data":"本系统的权限设计相关的表如下（一共 5 张表，2 张用户建立表之间的联系）：","Properties":{"id":""}}]},{"ID":"20220906204181-fctbz9j","Type":"NodeParagraph","Properties":{"id":"20220906204181-fctbz9j","updated":"20220906204181"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/2020-11/%E6%95%B0%E6%8D%AE%E5%BA%93%E8%AE%BE%E8%AE%A1-%E6%9D%83%E9%99%90.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204182-a30bbrq","Type":"NodeParagraph","Properties":{"id":"20220906204182-a30bbrq","updated":"20220906204182"},"Children":[{"Type":"NodeText","Data":"通过这个权限模型，我们可以创建不同的角色并为不同的角色分配不同的权限范围（菜单）。","Properties":{"