Type":"NodeText","Data":" 的关键业务一定要确保客户端开启了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]},{"ID":"20220906204239-spu02mi","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204239-spu02mi","updated":"20220906204239"},"Children":[{"ID":"20220906204240-6gtgl1x","Type":"NodeParagraph","Properties":{"id":"20220906204240-6gtgl1x","updated":"20220906204240"},"Children":[{"Type":"NodeText","Data":"注意 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Session"},{"Type":"NodeText","Data":" 的过期时间。","Properties":{"id":""}}]}]}]},{"ID":"20220906204241-xo0gxzo","Type":"NodeParagraph","Properties":{"id":"20220906204241-xo0gxzo","updated":"20220906204241"},"Children":[{"Type":"NodeText","Data":"另外，Spring Session 提供了一种跨多个应用程序或实例管理用户会话信息的机制。如果想详细了解可以查看下面几篇很不错的文章：","Properties":{"id":""}}]},{"ID":"20220906204242-7syd8a4","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204242-7syd8a4","updated":"20220906204242"},"Children":[{"ID":"20220906204243-ky8uoa5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204243-ky8uoa5","updated":"20220906204243"},"Children":[{"ID":"20220906204244-wp46bg4","Type":"NodeParagraph","Properties":{"id":"20220906204244-wp46bg4","updated":"20220906204244"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://codeboje.de/spring-Session-tutorial/","TextMarkTextContent":"Getting Started with Spring Session"}]}]},{"ID":"20220906204245-3zp737b","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204245-3zp737b","updated":"20220906204245"},"Children":[{"ID":"20220906204246-g2tmw17","Type":"NodeParagraph","Properties":{"id":"20220906204246-g2tmw17","updated":"20220906204246"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://www.baeldung.com/spring-Session","TextMarkTextContent":"Guide to Spring Session"}]}]},{"ID":"20220906204247-lj1r743","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204247-lj1r743","updated":"20220906204247"},"Children":[{"ID":"20220906204248-pnz8pin","Type":"NodeParagraph","Properties":{"id":"20220906204248-pnz8pin","updated":"20220906204248"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://medium.com/@gvnix/sticky-Sessions-with-spring-Session-redis-bdc6f7438cc3","TextMarkTextContent":"Sticky Sessions with Spring Session \u0026amp; Redis"}]}]}]},{"ID":"20220906204249-pgtxj40","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204249-pgtxj40","updated":"20220906204249"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"多服务器节点下 Session-Cookie 方案如何做？","Properties":{"id":""}}]},{"ID":"20220906204250-ddtk35s","Type":"NodeParagraph","Properties":{"id":"20220906204250-ddtk35s","updated":"20220906204250"},"Children":[{"Type":"NodeText","Data":"Session-Cookie 方案在单体环境是一个非常好的身份认证方案。但是，当服务器水平拓展成多节点时，Session-Cookie 方案就要面临挑战了。","Properties":{"id":""}}]},{"ID":"20220906204251-f6jhbz1","Type":"NodeParagraph","Properties":{"id":"20220906204251-f6jhbz1","updated":"20220906204251"},"Children":[{"Type":"NodeText","Data":"举个例子：假如我们部署了两份相同的服务 A，B，用户第一次登陆的时候 ，Nginx 通过负载均衡机制将用户请求转发到 A 服务器，此时用户的 Session 信息保存在 A 服务器。结果，用户第二次访问的时候 Nginx 将请求路由到 B 服务器，由于 B 服务器没有保存 用户的 Session 信息，导致用户需要重新进行登陆。","Properties":{"id":""}}]},{"ID":"20220906204252-jsecqm4","Type":"NodeParagraph","Properties":{"id":"20220906204252-jsecqm4","updated":"20220906204252"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我们应该如何避免上面这种情况的出现呢？"}]},{"ID":"20220906204253-gc8suo5","Type":"NodeParagraph","Properties":{"id":"20220906204253-gc8suo5","updated":"20220906204253"},"Children":[{"Type":"NodeText","Data":"有几个方案可供大家参考：","Properties":{"id":""}}]},{"ID":"20220906204254-g2rmsrv","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204254-g2rmsrv","updated":"20220906204254"},"Children":[{"ID":"20220906204255-2olo7k7","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204255-2olo7k7","updated":"20220906204255"},"Children":[{"ID":"20220906204256-p99r09n","Type":"NodeParagraph","Properties":{"id":"20220906204256-p99r09n","updated":"20220906204256"},"Children":[{"Type":"NodeText","Data":"某个用户的所有请求都通过特性的哈希策略分配给同一个服务器处理。这样的话，每个服务器都保存了一部分用户的 Session 信息。服务器宕机，其保存的所有 Session 信息就完全丢失了。","Properties":{"id":""}}]}]},{"ID":"20220906204257-ykregh7","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204257-ykregh7","updated":"20220906204257"},"Children":[{"ID":"20220906204258-h2181lm","Type":"NodeParagraph","Properties":{"id":"20220906204258-h2181lm","updated":"20220906204258"},"Children":[{"Type":"NodeText","Data":"每一个服务器保存的 Session 信息都是互相同步的，也就是说每一个服务器都保存了全量的 Session 信息。每当一个服务器的 Session 信息发生变化，我们就将其同步到其他服务器。这种方案成本太大，并且，节点越多时，同步成本也越高。","Properties":{"id":""}}]}]},{"ID":"20220906204259-fbcdown","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204259-fbcdown","updated":"20220906204259"},"Children":[{"ID":"20220906204260-jqmonko","Type":"NodeParagraph","Properties":{"id":"20220906204260-jqmonko","updated":"20220906204260"},"Children":[{"Type":"NodeText","Data":"单独使用一个所有服务器都能访问到的数据节点（比如缓存）来存放 Session 信息。为了保证高可用，数据节点尽量要避免是单点。","Properties":{"id":""}}]}]}]},{"ID":"20220906204261-zquh14n","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204261-zquh14n","updated":"20220906204261"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如果没有 Cookie 的话 Session 还能用吗？","Properties":{"id":""}}]},{"ID":"20220906204262-ni82gel","Type":"NodeParagraph","Properties":{"id":"20220906204262-ni82gel","updated":"20220906204262"},"Children":[{"Type":"NodeText","Data":"这是一道经典的面试题！","Properties":{"id":""}}]},{"ID":"20220906204263-pbeg452","Type":"NodeParagraph","Properties":{"id":"20220906204263-pbeg452","updated":"20220906204263"},"Children":[{"Type":"NodeText","Data":"一般是通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 来保存 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionID"},{"Type":"NodeText","Data":" ，假如你使用了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 保存 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionID"},{"Type":"NodeText","Data":" 的方案的话， 如果客户端禁用了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":"，那么 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Session"},{"Type":"NodeText","Data":" 就无法正常工作。","Properties":{"id":""}}]},{"ID":"20220906204264-enx5r03","Type":"NodeParagraph","Properties":{"id":"20220906204264-enx5r03","updated":"20220906204264"},"Children":[{"Type":"NodeText","Data":"但是，并不是没有 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 之后就不能用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Session"},{"Type":"NodeText","Data":" 了，比如你可以将 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionID"},{"Type":"NodeText","Data":" 放在请求的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"url"},{"Type":"NodeText","Data":" 里面","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"https://javaguide.cn/?Session_id=xxx"},{"Type":"NodeText","Data":" 。这种方案的话可行，但是安全性和用户体验感降低。当然，为了你也可以对 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionID"},{"Type":"NodeText","Data":" 进行一次加密之后再传入后端。","Properties":{"id":""}}]},{"ID":"20220906204265-245406z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204265-245406z","updated":"20220906204265"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么 Cookie 无法防止 CSRF 攻击，而 Token 可以？","Properties":{"id":""}}]},{"ID":"20220906204266-rbpr61b","Type":"NodeParagraph","Properties":{"id":"20220906204266-rbpr61b","updated":"20220906204266"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"CSRF(Cross Site Request Forgery)"},{"Type":"NodeText","Data":" 一般被翻译为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"跨站请求伪造"},{"Type":"NodeText","Data":" 。那么什么是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"跨站请求伪造"},{"Type":"NodeText","Data":" 呢？说简单用你的身份去发送一些对你不友好的请求。举个简单的例子：","Properties":{"id":""}}]},{"ID":"20220906204267-iekxpyu","Type":"NodeParagraph","Properties":{"id":"20220906204267-iekxpyu","updated":"20220906204267"},"Children":[{"Type":"NodeText","Data":"小壮登录了某网上银行，他来到了网上银行的帖子区，看到一个帖子下面有一个链接写着“科学理财，年盈利率过万”，小壮好奇的点开了这个链接，结果发现自己的账户少了 10000 元。这是这么回事呢？原来黑客在链接中藏了一个请求，这个请求直接利用小壮的身份给银行发送了一个转账请求,也就是通过你的 Cookie 向银行发出请求。","Properties":{"id":""}}]},{"ID":"20220906204268-kmid9ml","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"aHRtbA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204268-kmid9ml","updated":"20220906204268"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"aHRtbA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003ca src=http://www.mybank.com/Transfer?bankId=11\u0026money=10000\u003e科学理财，年盈利率过万\u003c/\u003e\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204269-ln5b8oi","Type":"NodeParagraph","Properties":{"id":"20220906204269-ln5b8oi","updated":"20220906204269"},"Children":[{"Type":"NodeText","Data":"上面也提到过，进行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Session"},{"Type":"NodeText","Data":" 认证的时候，我们一般使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 来存储 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":",当我们登陆后后端生成一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":" 放在 Cookie 中返回给客户端，服务端通过 Redis 或者其他存储工具记录保存着这个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":"，客户端登录以后每次请求都会带上这个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":"，服务端通过这个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":" 来标示你这个人。如果别人通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 拿到了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":" 后就可以代替你的身份访问系统了。","Properties":{"id":""}}]},{"ID":"20220906204270-kwmpo1c","Type":"NodeParagraph","Properties":{"id":"20220906204270-kwmpo1c","updated":"20220906204270"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Session"},{"Type":"NodeText","Data":" 认证中 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 中的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SessionId"},{"Type":"NodeText","Data":" 是由浏览器发送到服务端的，借助这个特性，攻击者就可以通过让用户误点攻击链接，达到攻击效果。","Properties":{"id":""}}]},{"ID":"20220906204271-c5yicag","Type":"NodeParagraph","Properties":{"id":"20220906204271-c5yicag","updated":"20220906204271"},"Children":[{"Type":"NodeText","Data":"但是，我们使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Token"},{"Type":"NodeText","Data":" 的话就不会存在这个问题，在我们登录成功获得 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Token"},{"Type":"NodeText","Data":" 之后，一般会选择存放在 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"localStorage"},{"Type":"NodeText","Data":" （浏览器本地存储）中。然后我们在前端通过某些方式会给每个发到后端的请求加上这个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Token"},{"Type":"NodeText","Data":",这样就不会出现 CSRF 漏洞的问题。因为，即使有个你点击了非法链接发送了请求到服务端，这个非法请求是不会携带 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Token"},{"Type":"NodeText","Data":" 的，所以这个请求将是非法的。","Properties":{"id":""}}]},{"ID":"20220906204272-9a2epjv","Type":"NodeParagraph","Properties":{"id":"20220906204272-9a2epjv","updated":"20220906204272"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210615161108272.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204273-kfxu0x1","Type":"NodeParagraph","Properties":{"id":"20220906204273-kfxu0x1","updated":"20220906204273"},"Children":[{"Type":"NodeText","Data":"需要注意的是：不论是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 还是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Token"},{"Type":"NodeText","Data":" 都无法避免 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"跨站脚本攻击（Cross Site Scripting）XSS"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204274-jdslblb","Type":"NodeBlockquote","Properties":{"id":"20220906204274-jdslblb","updated":"20220906204274"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204275-hqqqmdo","Type":"NodeParagraph","Properties":{"id":"20220906204275-hqqqmdo","updated":"20220906204275"},"Children":[{"Type":"NodeText","Data":"跨站脚本攻击（Cross Site Scripting）缩写为 CSS 但这会与层叠样式表（Cascading Style Sheets，CSS）的缩写混淆。因此，有人将跨站脚本攻击缩写为 XSS。","Properties":{"id":""}}]}]},{"ID":"20220906204276-eyex6q0","Type":"NodeParagraph","Properties":{"id":"20220906204276-eyex6q0","updated":"20220906204276"},"Children":[{"Type":"NodeText","Data":"XSS 中攻击者会用各种方式将恶意代码注入到其他用户的页面中。就可以通过脚本盗用信息比如 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cookie"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204277-o93wrbw","Type":"NodeParagraph","Properties":{"id":"20220906204277-o93wrbw","updated":"20220906204277"},"Children":[{"Type":"NodeText","Data":"推荐阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://tech.meituan.com/2018/10/11/fe-security-csrf.html","TextMarkTextContent":"如何防止 CSRF 攻击？—美团技术团队"}]},{"ID":"20220906204278-alw52nn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204278-alw52nn","updated":"20220906204278"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 JWT?JWT 由哪些部分组成？","Properties":{"id":""}}]},{"ID":"20220906204279-amf2td2","Type":"NodeParagraph","Properties":{"id":"20220906204279-amf2td2","updated":"20220906204279"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/system-design/security/jwt-intro.html","TextMarkTextContent":"JWT 基础概念详解"}]},{"ID":"20220906204280-plngb7i","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204280-plngb7i","updated":"20220906204280"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何基于 JWT 进行身份验证？ 如何防止 JWT 被篡改？","Properties":{"id":""}}]},{"ID":"20220906204281-mna8i4l","Type":"NodeParagraph","Properties":{"id":"20220906204281-mna8i4l","updated":"20220906204281"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/system-design/security/jwt-intro.html","TextMarkTextContent":"JWT 基础概念详解"}]},{"ID":"20220906204282-0d0qyxz","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204282-0d0qyxz","updated":"20220906204282"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 SSO?","Properties":{"id":""}}]},{"ID":"20220906204283-bvukxkx","Type":"NodeParagraph","Properties":{"id":"20220906204283-bvukxkx","updated":"20220906204283"},"Children":[{"Type":"NodeText","Data":"SSO(Single Sign On)即单点登录说的是用户登陆多个子系统的其中一个就有权访问与其相关的其他系统。举个例子我们在登陆了京东金融之后，我们同时也成功登陆京东的京东超市、京东国际、京东生鲜等子系统。","Properties":{"id":""}}]},{"ID":"20220906204284-zsxuycg","Type":"NodeParagraph","Properties":{"id":"20220906204284-zsxuycg","updated":"20220906204284"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"SSO 示意图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/security/sso.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204285-jbo00gs","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204285-jbo00gs","updated":"20220906204285"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"SSO 有什么好处？","Properties":{"id":""}}]},{"ID":"20220906204286-4tu2gpu","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204286-4tu2gpu","updated":"20220906204286"},"Children":[{"ID":"20220906204287-pdsuxr0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204287-pdsuxr0","updated":"20220906204287"},"Children":[{"ID":"20220906204288-xuaih44","Type":"NodeParagraph","Properties":{"id":"20220906204288-xuaih44","updated":"20220906204288"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"用户角度"},{"Type":"NodeText","Data":" :用户能够做到一次登录多次使用，无需记录多套用户名和密码，省心。","Properties":{"id":""}}]}]},{"ID":"20220906204289-9lxsqy4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204289-9lxsqy4","updated":"20220906204289"},"Children":[{"ID":"20220906204290-qfxneea","Type":"NodeParagraph","Properties":{"id":"20220906204290-qfxneea","updated":"20220906204290"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"系统管理员角度"},{"Type":"NodeText","Data":" : 管理员只需维护好一个统一的账号中心就可以了，方便。","Properties":{"id":""}}]}]},{"ID":"20220906204291-oz1u95g","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204291-oz1u95g","updated":"20220906204291"},"Children":[{"ID":"20220906204292-u7sy63u","Type":"NodeParagraph","Properties":{"id":"20220906204292-u7sy63u","updated":"20220906204292"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"新系统开发角度:"},{"Type":"NodeText","Data":" 新系统开发时只需直接对接统一的账号中心即可，简化开发流程，省时。","Properties":{"id":""}}]}]}]},{"ID":"20220906204293-h61o0g0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204293-h61o0g0","updated":"20220906204293"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何设计实现一个 SSO 系统?","Properties":{"id":""}}]},{"ID":"20220906204294-fcpghlc","Type":"NodeParagraph","Properties":{"id":"20220906204294-fcpghlc","updated":"20220906204294"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/system-design/security/sso-intro.html","TextMarkTextContent":"SSO 单点登录详解"}]},{"ID":"20220906204295-bthcf0t","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204295-bthcf0t","updated":"20220906204295"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 OAuth 2.0？","Properties":{"id":""}}]},{"ID":"20220906204296-2feqn3n","Type":"NodeParagraph","Properties":{"id":"20220906204296-2feqn3n","updated":"20220906204296"},"Children":[{"Type":"NodeText","Data":"OAuth 是一个行业的标准授权协议，主要用来授权第三方应用获取有限的权限。而 OAuth 2.0 是对 OAuth 1.0 的完全重新设计，OAuth 2.0 更快，更容易实现，OAuth 1.0 已经被废弃。详情请见：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://tools.ietf.org/html/rfc6749","TextMarkTextContent":"rfc6749"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204297-k9zfan4","Type":"NodeParagraph","Properties":{"id":"20220906204297-k9zfan4","updated":"20220906204297"},"Children":[{"Type":"NodeText","Data":"实际上它就是一种授权机制，它的最终目的是为第三方应用颁发一个有时效性的令牌 Token，使得第三方应用能够通过该令牌获取相关的资源。","Properties":{"id":""}}]},{"ID":"20220906204298-kinzjsa","Type":"NodeParagraph","Properties":{"id":"20220906204298-kinzjsa","updated":"20220906204298"},"Children":[{"Type":"NodeText","Data":"OAuth 2.0 比较常用的场景就是第三方登录，当你的网站接入了第三方登录的时候一般就是使用的 OAuth 2.0 协议。","Properties":{"id":""}}]},{"ID":"20220906204299-wvfortq","Type":"NodeParagraph","Properties":{"id":"20220906204299-wvfortq","updated":"20220906204299"},"Children":[{"Type":"NodeText","Data":"另外，现在 OAuth 2.0 也常见于支付场景（微信支付、支付宝支付）和开发平台（微信开放平台、阿里开放平台等等）。","Properties":{"id":""}}]},{"ID":"20220906204300-ex9py6e","Type":"NodeParagraph","Properties":{"id":"20220906204300-ex9py6e","updated":"20220906204300"},"Children":[{"Type":"NodeText","Data":"下图是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://api.slack.com/legacy/oauth","TextMarkTextContent":"Slack OAuth 2.0 第三方登录"},{"Type":"NodeText","Data":"的示意图：","Properties":{"id":""}}]},{"ID":"20220906204301-dqlqkkk","Type":"NodeParagraph","Properties":{"id":"20220906204301-dqlqkkk","updated":"20220906204301"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210615151716340.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204302-q70pfh9","Type":"NodeParagraph","Properties":{"id":"20220906204302-q70pfh9","updated":"20220906204302"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"推荐阅读："}]},{"ID":"20220906204303-yore7eo","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204303-yore7eo","updated":"20220906204303"},"Children":[{"ID":"20220906204304-6r4g8jn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204304-6r4g8jn","updated":"20220906204304"},"Children":[{"ID":"20220906204305-7anrjou","Type":"NodeParagraph","Properties":{"id":"20220906204305-7anrjou