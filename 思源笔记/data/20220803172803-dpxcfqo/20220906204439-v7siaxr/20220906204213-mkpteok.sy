{"ID":"20220906204213-mkpteok","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220906204213-mkpteok","title":"d-0数据库基础","type":"doc","updated":"20220906204213"},"Children":[{"ID":"20220906204214-dy7iu6s","Type":"NodeThematicBreak","Properties":{"id":"20220906204214-dy7iu6s","updated":"20220906204214"}},{"ID":"20220906204215-5pnxrae","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220906204215-5pnxrae","updated":"20220906204215"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"4. 数据库","Properties":{"id":""}}]},{"ID":"20220906204216-gtgt5ee","Type":"NodeBlockquote","Properties":{"id":"20220906204216-gtgt5ee","updated":"20220906204216"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204217-njr3gy6","Type":"NodeParagraph","Properties":{"id":"20220906204217-njr3gy6","updated":"20220906204217"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/","TextMarkTextContent":"JavaGuide"},{"Type":"NodeText","Data":" ：「Java学习+面试指南」一份涵盖大部分 Java 程序员所需要掌握的核心知识。准备 Java 面试，首选 JavaGuide！","Properties":{"id":""}}]}]},{"ID":"20220906204218-keh2z4j","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e\n    \u003cp\u003e\n        \u003ca href=\"https://www.yuque.com/docs/share/8a30ffb5-83f3-40f9-baf9-38de68b906dc\"\u003e\n            \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/xingqiu/xingqiu.png\" style=\"margin: 0 auto; width: 850px;\" /\u003e\n        \u003c/a\u003e\n    \u003c/p\u003e\n    \u003cp\u003e\n        \u003ca href=\"https://github.com/Snailclimb/JavaGuide-Interview\"\u003eGithub\u003c/a\u003e |\n        \u003ca href=\"https://gitee.com/SnailClimb/JavaGuide-Interview\"\u003eGitee\u003c/a\u003e\n    \u003c/p\u003e  \n\u003c/div\u003e","HtmlBlockType":6,"Properties":{"id":"20220906204218-keh2z4j","updated":"20220906204218"}},{"ID":"20220906204219-myuz200","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906204219-myuz200","updated":"20220906204219"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"4.1 数据库基础","Properties":{"id":""}}]},{"ID":"20220906204220-61jpro8","Type":"NodeParagraph","Properties":{"id":"20220906204220-61jpro8","updated":"20220906204220"},"Children":[{"Type":"NodeText","Data":"数据库知识基础，这部分内容一定要理解记忆。虽然这部分内容只是理论知识，但是非常重要，这是后面学习 MySQL 数据库的基础。PS: 这部分内容由于涉及太多概念性内容，所以参考了维基百科和百度百科相应的介绍。","Properties":{"id":""}}]},{"ID":"20220906204221-jfcmv7v","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204221-jfcmv7v","updated":"20220906204221"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是数据库, 数据库管理系统, 数据库系统, 数据库管理员?","Properties":{"id":""}}]},{"ID":"20220906204222-ovs2des","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204222-ovs2des","updated":"20220906204222"},"Children":[{"ID":"20220906204223-lruuo06","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204223-lruuo06","updated":"20220906204223"},"Children":[{"ID":"20220906204224-9lysb06","Type":"NodeParagraph","Properties":{"id":"20220906204224-9lysb06","updated":"20220906204224"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数据库"},{"Type":"NodeText","Data":" : 数据库(DataBase 简称 DB)就是信息的集合或者说数据库是由数据库管理系统管理的数据的集合。","Properties":{"id":""}}]}]},{"ID":"20220906204225-r0cef4n","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204225-r0cef4n","updated":"20220906204225"},"Children":[{"ID":"20220906204226-qorq2u8","Type":"NodeParagraph","Properties":{"id":"20220906204226-qorq2u8","updated":"20220906204226"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数据库管理系统"},{"Type":"NodeText","Data":" : 数据库管理系统(Database Management System 简称 DBMS)是一种操纵和管理数据库的大型软件，通常用于建立、使用和维护数据库。","Properties":{"id":""}}]}]},{"ID":"20220906204227-mdqyy5i","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204227-mdqyy5i","updated":"20220906204227"},"Children":[{"ID":"20220906204228-r684gd4","Type":"NodeParagraph","Properties":{"id":"20220906204228-r684gd4","updated":"20220906204228"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数据库系统"},{"Type":"NodeText","Data":" : 数据库系统(Data Base System，简称 DBS)通常由软件、数据库和数据管理员(DBA)组成。","Properties":{"id":""}}]}]},{"ID":"20220906204229-i0sct6x","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204229-i0sct6x","updated":"20220906204229"},"Children":[{"ID":"20220906204230-3nbs0vo","Type":"NodeParagraph","Properties":{"id":"20220906204230-3nbs0vo","updated":"20220906204230"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数据库管理员"},{"Type":"NodeText","Data":" : 数据库管理员(Database Administrator, 简称 DBA)负责全面管理和控制数据库系统。","Properties":{"id":""}}]}]}]},{"ID":"20220906204231-849r48h","Type":"NodeParagraph","Properties":{"id":"20220906204231-849r48h","updated":"20220906204231"},"Children":[{"Type":"NodeText","Data":"数据库系统基本构成如下图所示：","Properties":{"id":""}}]},{"ID":"20220906204232-szc5sw8","Type":"NodeParagraph","Properties":{"id":"20220906204232-szc5sw8","updated":"20220906204232"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"数据库系统基本构成","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/e21120184e63406526a4e873cacd23f2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204233-000khd4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204233-000khd4","updated":"20220906204233"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是元组, 码, 候选码, 主码, 外码, 主属性, 非主属性？","Properties":{"id":""}}]},{"ID":"20220906204234-oq6vcnh","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204234-oq6vcnh","updated":"20220906204234"},"Children":[{"ID":"20220906204235-7nlhs75","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204235-7nlhs75","updated":"20220906204235"},"Children":[{"ID":"20220906204236-63imcdz","Type":"NodeParagraph","Properties":{"id":"20220906204236-63imcdz","updated":"20220906204236"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"元组"},{"Type":"NodeText","Data":" ： 元组（tuple）是关系数据库中的基本概念，关系是一张表，表中的每行（即数据库中的每条记录）就是一个元组，每列就是一个属性。 在二维表里，元组也称为行。","Properties":{"id":""}}]}]},{"ID":"20220906204237-qzf8hoi","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204237-qzf8hoi","updated":"20220906204237"},"Children":[{"ID":"20220906204238-neq5tuj","Type":"NodeParagraph","Properties":{"id":"20220906204238-neq5tuj","updated":"20220906204238"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"码"},{"Type":"NodeText","Data":" ：码就是能唯一标识实体的属性，对应表中的列。","Properties":{"id":""}}]}]},{"ID":"20220906204239-nu9t6c8","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204239-nu9t6c8","updated":"20220906204239"},"Children":[{"ID":"20220906204240-ovcc73d","Type":"NodeParagraph","Properties":{"id":"20220906204240-ovcc73d","updated":"20220906204240"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"候选码"},{"Type":"NodeText","Data":" ： 若关系中的某一属性或属性组的值能唯一的标识一个元组，而其任何、子集都不能再标识，则称该属性组为候选码。例如：在学生实体中，“学号”是能唯一的区分学生实体的，同时又假设“姓名”、“班级”的属性组合足以区分学生实体，那么{学号}和{姓名，班级}都是候选码。","Properties":{"id":""}}]}]},{"ID":"20220906204241-8o19jql","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204241-8o19jql","updated":"20220906204241"},"Children":[{"ID":"20220906204242-z7dnjm1","Type":"NodeParagraph","Properties":{"id":"20220906204242-z7dnjm1","updated":"20220906204242"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"主码"},{"Type":"NodeText","Data":" : 主码也叫主键。主码是从候选码中选出来的。 一个实体集中只能有一个主码，但可以有多个候选码。","Properties":{"id":""}}]}]},{"ID":"20220906204243-1zmjazw","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204243-1zmjazw","updated":"20220906204243"},"Children":[{"ID":"20220906204244-wzhohmx","Type":"NodeParagraph","Properties":{"id":"20220906204244-wzhohmx","updated":"20220906204244"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"外码"},{"Type":"NodeText","Data":" : 外码也叫外键。如果一个关系中的一个属性是另外一个关系中的主码则这个属性为外码。","Properties":{"id":""}}]}]},{"ID":"20220906204245-yhsv0wx","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204245-yhsv0wx","updated":"20220906204245"},"Children":[{"ID":"20220906204246-eb5iia3","Type":"NodeParagraph","Properties":{"id":"20220906204246-eb5iia3","updated":"20220906204246"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"主属性"},{"Type":"NodeText","Data":" ： 候选码中出现过的属性称为主属性。比如关系 工人（工号，身份证号，姓名，性别，部门）. 显然工号和身份证号都能够唯一标示这个关系，所以都是候选码。工号、身份证号这两个属性就是主属性。如果主码是一个属性组，那么属性组中的属性都是主属性。","Properties":{"id":""}}]}]},{"ID":"20220906204247-n55zswo","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204247-n55zswo","updated":"20220906204247"},"Children":[{"ID":"20220906204248-6r8d51h","Type":"NodeParagraph","Properties":{"id":"20220906204248-6r8d51h","updated":"20220906204248"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"非主属性："},{"Type":"NodeText","Data":" 不包含在任何一个候选码中的属性称为非主属性。比如在关系——学生（学号，姓名，年龄，性别，班级）中，主码是“学号”，那么其他的“姓名”、“年龄”、“性别”、“班级”就都可以称为非主属性。","Properties":{"id":""}}]}]}]},{"ID":"20220906204249-u8le6gw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204249-u8le6gw","updated":"20220906204249"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"主键和外键有什么区别?","Properties":{"id":""}}]},{"ID":"20220906204250-9efxmvt","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204250-9efxmvt","updated":"20220906204250"},"Children":[{"ID":"20220906204251-8ws7aa1","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204251-8ws7aa1","updated":"20220906204251"},"Children":[{"ID":"20220906204252-y3k6wl6","Type":"NodeParagraph","Properties":{"id":"20220906204252-y3k6wl6","updated":"20220906204252"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"主键(主码)"},{"Type":"NodeText","Data":" ：主键用于唯一标识一个元组，不能有重复，不允许为空。一个表只能有一个主键。","Properties":{"id":""}}]}]},{"ID":"20220906204253-d1p1hzk","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204253-d1p1hzk","updated":"20220906204253"},"Children":[{"ID":"20220906204254-1tfx7cd","Type":"NodeParagraph","Properties":{"id":"20220906204254-1tfx7cd","updated":"20220906204254"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"外键(外码)"},{"Type":"NodeText","Data":" ：外键用来和其他表建立联系用，外键是另一表的主键，外键是可以有重复的，可以是空值。一个表可以有多个外键。","Properties":{"id":""}}]}]}]},{"ID":"20220906204255-ct5uhyh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204255-ct5uhyh","updated":"20220906204255"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么不推荐使用外键与级联？","Properties":{"id":""}}]},{"ID":"20220906204256-bgv7utr","Type":"NodeParagraph","Properties":{"id":"20220906204256-bgv7utr","updated":"20220906204256"},"Children":[{"Type":"NodeText","Data":"对于外键和级联，阿里巴巴开发手册这样说到：","Properties":{"id":""}}]},{"ID":"20220906204257-dfy3h10","Type":"NodeBlockquote","Properties":{"id":"20220906204257-dfy3h10","updated":"20220906204257"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204258-8qcv6i6","Type":"NodeParagraph","Properties":{"id":"20220906204258-8qcv6i6","updated":"20220906204258"},"Children":[{"Type":"NodeText","Data":"【强制】不得使用外键与级联，一切外键概念必须在应用层解决。","Properties":{"id":""}}]},{"ID":"20220906204259-uyuqrvt","Type":"NodeParagraph","Properties":{"id":"20220906204259-uyuqrvt","updated":"20220906204259"},"Children":[{"Type":"NodeText","Data":"说明: 以学生和成绩的关系为例，学生表中的 student_id 是主键，那么成绩表中的 student_id 则为外键。如果更新学生表中的 student_id，同时触发成绩表中的 student_id 更新，即为级联更新。外键与级联更新适用于单机低并发，不适合分布式、高并发集群; 级联更新是强阻塞，存在数据库更新风暴的风 险; 外键影响数据库的插入速度","Properties":{"id":""}}]}]},{"ID":"20220906204260-sd1osnh","Type":"NodeParagraph","Properties":{"id":"20220906204260-sd1osnh","updated":"20220906204260"},"Children":[{"Type":"NodeText","Data":"为什么不要用外键呢？大部分人可能会这样回答：","Properties":{"id":""}}]},{"ID":"20220906204261-npuhy2w","Type":"NodeBlockquote","Properties":{"id":"20220906204261-npuhy2w","updated":"20220906204261"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204262-z4dzceb","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204262-z4dzceb","updated":"20220906204262"},"Children":[{"ID":"20220906204263-6heh3ju","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204263-6heh3ju","updated":"20220906204263"},"Children":[{"ID":"20220906204264-ghhcubg","Type":"NodeParagraph","Properties":{"id":"20220906204264-ghhcubg","updated":"20220906204264"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"增加了复杂性："},{"Type":"NodeText","Data":" a. 每次做DELETE 或者UPDATE都必须考虑外键约束，会导致开发的时候很痛苦, 测试数据极为不方便; b. 外键的主从关系是定的，假如那天需求有变化，数据库中的这个字段根本不需要和其他表有关联的话就会增加很多麻烦。","Properties":{"id":""}}]}]},{"ID":"20220906204265-b8xpk3c","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204265-b8xpk3c","updated":"20220906204265"},"Children":[{"ID":"20220906204266-ncna34e","Type":"NodeParagraph","Properties":{"id":"20220906204266-ncna34e","updated":"20220906204266"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"增加了额外工作"},{"Type":"NodeText","Data":"： 数据库需要增加维护外键的工作，比如当我们做一些涉及外键字段的增，删，更新操作之后，需要触发相关操作去检查，保证数据的的一致性和正确性，这样会不得不消耗资源；（个人觉得这个不是不用外键的原因，因为即使你不使用外键，你在应用层面也还是要保证的。所以，我觉得这个影响可以忽略不计。）","Properties":{"id":""}}]}]},{"ID":"20220906204267-imhaaol","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":3},"Properties":{"id":"20220906204267-imhaaol","updated":"20220906204267"},"Children":[{"ID":"20220906204268-npzci7e","Type":"NodeParagraph","Properties":{"id":"20220906204268-npzci7e","updated":"20220906204268"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"对分库分表不友好"},{"Type":"NodeText","Data":" ：因为分库分表下外键是无法生效的。","Properties":{"id":""}}]}]},{"ID":"20220906204269-e2xk0zc","Type":"NodeListItem","Data":"5","ListData":{"Typ":1,"Tight":true,"Start":5,"Delimiter":46,"Padding":3,"Marker":"NQ==","Num":4},"Properties":{"id":"20220906204269-e2xk0zc","updated":"20220906204269"},"Children":[{"ID":"20220906204270-qfq2f1q","Type":"NodeParagraph","Properties":{"id":"20220906204270-qfq2f1q","updated":"20220906204270"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]}]},{"ID":"20220906204271-1k6zxmv","Type":"NodeParagraph","Properties":{"id":"20220906204271-1k6zxmv","updated":"20220906204271"},"Children":[{"Type":"NodeText","Data":"我个人觉得上面这种回答不是特别的全面，只是说了外键存在的一个常见的问题。实际上，我们知道外键也是有很多好处的，比如：","Properties":{"id":""}}]},{"ID":"20220906204272-7lo4m79","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204272-7lo4m79","updated":"20220906204272"},"Children":[{"ID":"20220906204273-f8xgf9r","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204273-f8xgf9r","updated":"20220906204273"},"Children":[{"ID":"20220906204274-qenoho9","Type":"NodeParagraph","Properties":{"id":"20220906204274-qenoho9","updated":"20220906204274"},"Children":[{"Type":"NodeText","Data":"保证了数据库数据的一致性和完整性；","Properties":{"id":""}}]}]},{"ID":"20220906204275-7w2xk9j","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204275-7w2xk9j","updated":"20220906204275"},"Children":[{"ID":"20220906204276-1emcvlm","Type":"NodeParagraph","Properties":{"id":"20220906204276-1emcvlm","updated":"20220906204276"},"Children":[{"Type":"NodeText","Data":"级联操作方便，减轻了程序代码量；","Properties":{"id":""}}]}]},{"ID":"20220906204277-cpfoflj","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204277-cpfoflj","updated":"20220906204277"},"Children":[{"ID":"20220906204278-jtq2p2g","Type":"NodeParagraph","Properties":{"id":"20220906204278-jtq2p2g","updated":"20220906204278"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204279-si05p75","Type":"NodeParagraph","Properties":{"id":"20220906204279-si05p75","updated":"20220906204279"},"Children":[{"Type":"NodeText","Data":"所以说，不要一股脑的就抛弃了外键这个概念，既然它存在就有它存在的道理，如果系统不涉及分库分表，并发量不是很高的情况还是可以考虑使用外键的。","Properties":{"id":""}}]},{"ID":"20220906204280-jbacah3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204280-jbacah3","updated":"20220906204280"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 ER 图？","Properties":{"id":""}}]},{"ID":"20220906204281-x8w7hln","Type":"NodeBlockquote","Properties":{"id":"20220906204281-x8w7hln","updated":"20220906204281"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204282-midtmdd","Type":"NodeParagraph","Properties":{"id":"20220906204282-midtmdd","updated":"20220906204282"},"Children":[{"Type":"NodeText","Data":"我们做一个项目的时候一定要试着画 ER 图来捋清数据库设计，这个也是面试官问你项目的时候经常会被问道的。","Properties":{"id":""}}]}]},{"ID":"20220906204283-wdpkk72","Type":"NodeParagraph","Properties":{"id":"20220906204283-wdpkk72","updated":"20220906204283"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"E-R 图"},{"Type":"NodeText","Data":" 也称实体-联系图(Entity Relationship Diagram)，提供了表示实体类型、属性和联系的方法，用来描述现实世界的概念模型。 它是描述现实世界关系概念模型的有效方法。 是表示概念关系模型的一种方式。","Properties":{"id":""}}]},{"ID":"20220906204284-slfycqt","Type":"NodeParagraph","Properties":{"id":"20220906204284-slfycqt","updated":"20220906204284"},"Children":[{"Type":"NodeText","Data":"下图是一个学生选课的 ER 图，每个学生可以选若干门课程，同一门课程也可以被若干人选择，所以它们之间的关系是多对多（M: N）。另外，还有其他两种关系是：1 对 1（1:1）、1 对多（1: N）。","Properties":{"id":""}}]},{"ID":"20220906204285-pmpzmuw","Type":"NodeParagraph","Properties":{"id":"20220906204285-pmpzmuw","updated":"20220906204285"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"ER图示例","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/4717673e36966e0e4b33fccfd753f6ea.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204286-kunkkdr","Type":"NodeParagraph","Properties":{"id":"20220906204286-kunkkdr","updated":"20220906204286"},"Children":[{"Type":"NodeText","Data":"我们试着将上面的 ER 图转换成数据库实际的关系模型(实际设计中，我们通常会将任课教师也作为一个实体来处理)：","Properties":{"id":""}}]},{"ID":"20220906204287-kub8mdp","Type":"NodeParagraph","Properties":{"id":"20220906204287-kub8mdp","updated":"20220906204287"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"关系模型","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/5897753dfb301dfa3a814ab06e718a5e.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204288-uszfa04","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204288-uszfa04","updated":"20220906204288"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库范式了解吗?","Properties":{"id":""}}]},{"ID":"20220906204289-vtw1y9g","Type":"NodeParagraph","Properties":{"id":"20220906204289-vtw1y9g","updated":"20220906204289"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1NF(第一范式)"}]},{"ID":"20220906204290-gtusi5v","Type":"NodeParagraph","Properties":{"id":"20220906204290-gtusi5v","updated":"20220906204290"},"Children":[{"Type":"NodeText","Data":"属性（对应于表中的字段）不能再被分割，也就是这个字段只能是一个值，不能再分为多个其他的字段了。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1NF 是所有关系型数据库的最基本要求"},{"Type":"NodeText","Data":" ，也就是说关系型数据库中创建的表一定满足第一范式。","Properties":{"id":""}}]},{"ID":"20220906204291-4gw1kr4","Type":"NodeParagraph","Properties":{"id":"20220906204291-4gw1kr4","updated":"20220906204291"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2NF(第二范式)"}]},{"ID":"20220906204292-qc7ygf9","Type":"NodeParagraph","Properties":{"id":"20220906204292-qc7ygf9","updated":"20220906204292"},"Children":[{"Type":"NodeText","Data":"2NF 在 1NF 的基础之上，消除了非主属性对于码的部分函数依赖。如下图所示，展示了第一范式到第二范式的过渡。第二范式在第一范式的基础上增加了一个列，这个列称为主键，非主属性都依赖于主键。","Properties":{"id":""}}]},{"ID":"20220906204293-j4068zs","Type":"NodeParagraph","Properties":{"id":"20220906204293-j4068zs","updated":"20220906204293"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"第二范式","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/bd1d31be3779342427fc9e462bf7f05c.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204294-de97hpu","Type":"NodeParagraph","Properties":{"id":"20220906204294-de97hpu","updated":"20220906204294"},"Children":[{"Type":"NodeText","Data":"一些重要的概念：","Properties":{"id":""}}]},{"ID":"20220906204295-0c55t1q","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204295-0c55t1q","updated":"20220906204295"},"Children":[{"ID":"20220906204296-mwx82hl","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204296-mwx82hl","updated":"20220906204296"},"Children":[{"ID":"20220906204297-5cwcfpz","Type":"NodeParagraph","Properties":{"id":"20220906204297-5cwcfpz","updated":"20220906204297"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"函数依赖（functional dependency）"},{"Type":"NodeText","Data":" ：若在一张表中，在属性（或属性组）X 的值确定的情况下，必定能确定属性 Y 的值，那么就可以说 Y 函数依赖于 X，写作 X → Y。","Properties":{"id":""}}]}]},{"ID":"20220906204298-wkwnp4m","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204298-wkwnp4m","updated":"20220906204298"},"Children":[{"ID":"20220906204299-3g03zg8","Type":"NodeParagraph","Properties":{"id":"20220906204299-3g03zg8","updated":"20220906204299"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"部分函数依赖（partial functional dependency）"},{"Type":"NodeText","Data":" ：如果 X→Y，并且存在 X 的一个真子集 X0，使得 X0→Y，则称 Y 对 X 部分函数依赖。比如学生基本信息表 R 中（学号，身份证号，姓名）当然学号属性取值是唯一的，在 R 关系中，（学号，身份证号）-\u003e（姓名），（学号）-\u003e（姓名），（身份证号）-\u003e（姓名）；所以姓名部分函数依赖与（学号，身份证号）；","Properties":{"id":""}}]}]},{"ID":"20220906204300-iofb9ll","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204300-iofb9ll","updated":"20220906204300"},"Children":[{"ID":"20220906204301-dtyvvp7","Type":"NodeParagraph","Properties":{"id":"20220906204301-dtyvvp7","updated":"20220906204301"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"完全函数依赖(Full functional dependency)"},{"Type":"NodeText","Data":" ：在一个关系中，若某个非主属性数据项依赖于全部关键字称之为完全函数依赖。比如学生基本信息表 R（学号，班级，姓名）假设不同的班级学号有相同的，班级内学号不能相同，在 R 关系中，（学号，班级）-\u003e（姓名），但是（学号）-\u003e(姓名)不成立，（班级）-\u003e(姓名)不成立，所以姓名完全函数依赖与（学号，班级）；","Properties":{"id":""}}]}]},{"ID":"20220906204302-kkwx85u","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204302-kkwx85u","updated":"20220906204302"},"Children":[{"ID":"20220906204303-2hdhz55","Type":"NodeParagraph","Properties":{"id":"20220906204303-2hdhz55","updated":"20220906204303"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"传递函数依赖"},{"Type":"NodeText","Data":" ： 在关系模式 R(U)中，设 X，Y，Z 是 U 的不同的属性子集，如果 X 确定 Y、Y 确定 Z，且有 X 不包含 Y，Y 不确定 X，（X∪Y）∩Z=空集合，则称 Z 传递函数依赖(transitive functional dependency) 于 X。传递函数依赖会导致数据冗余和异常。传递函数依赖的 Y 和 Z 子集往往同属于某一个事物，因此可将其合并放到一个表中。比如在关系 R(学号 , 姓名, 系名，系主任)中，学号 → 系名，系名 → 系主任，所以存在非主属性系主任对于学号的传递函数依赖。。","Properties":{"id":""}}]}]}]},{"ID":"20220906204304-914dwtw","Type":"NodeParagraph","Properties":{"id":"20220906204304-914dwtw","updated":"20220906204304"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"3NF(第三范式)"}]},{"ID":"20220906204305-altltg2","Type":"NodeParagraph","Properties":{"id":"20220906204305-altltg2","updated":"20220906204305"},"Children":[{"Type":"NodeText","Data":"3NF 在 2NF 的基础之上，消除了非主属性对于码的传递函数依赖 。符合 3NF 要求的数据库设计，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"基本"},{"Type":"NodeText","Data":"上解决了数据冗余过大，插入异常，修改异常，删除异常的问题。比如在关系 R(学号 , 姓名, 系名，系主任)中，学号 → 系名，系名 → 系主任，所以存在非主属性系主任对于学号的传递函数依赖，所以该表的设计，不符合 3NF 的要求。","Properties":{"id":""}}]},{"ID":"20220906204306-2s900kt","Type":"NodeParagraph","Properties":{"id":"20220906204306-2s900kt","updated":"20220906204306"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"总结"}]},{"ID":"20220906204307-w5x6hg0","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204307-w5x6hg0","updated":"20220906204307"},"Children":[{"ID":"20220906204308-gfjx1uy","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204308-gfjx1uy","updated":"20220906204308"},"Children":[{"ID":"20220906204309-p8tmedn","Type":"NodeParagraph","Properties":{"id":"20220906204309-p8tmedn","updated":"20220906204309"},"Children":[{"Type":"NodeText","Data":"1NF：属性不可再分。","Properties":{"id":""}}]}]},{"ID":"20220906204310-25lqal6","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204310-25lqal6","updated":"20220906204310"},"Children":[{"ID":"20220906204311-wkqvzog","Type":"NodeParagraph","Properties":{"id":"20220906204311-wkqvzog","updated":"20220906204311"},"Children":[{"Type":"NodeText","Data":"2NF：1NF 的基础之上，消除了非主属性对于码的部分函数依赖。","Properties":{"id":""}}]}]},{"ID":"20220906204312-yc2a866","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204312-yc2a866","updated":"20220906204312"},"Children":[{"ID":"20220906204313-7ug8v1c","Type":"NodeParagraph","Properties":{"id":"20220906204313-7ug8v1c","updated":"20220906204313"},"Children":[{"Type":"NodeText","Data":"3NF：3NF 在 2NF 的基础之上，消除了非主属性对于码的传递函数依赖 。","Properties":{"id":""}}]}]}]},{"ID":"20220906204314-40q987w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204314-40q987w","updated":"20220906204314"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是存储过程?","Properties":{"id":""}}]},{"ID":"20220906204315-g88g5ud","Type":"NodeParagraph","Properties":{"id":"20220906204315-g88g5ud","updated":"20220906204315"},"Children":[{"Type":"NodeText","Data":"我们可以把存储过程看成是一些 SQL 语句的集合，中间加了点逻辑控制语句。存储过程在业务比较复杂的时候是非常实用的，比如很多时候我们完成一个操作可能需要写一大串 SQL 语句，这时候我们就可以写有一个存储过程，这样也方便了我们下一次的调用。存储过程一旦调试完成通过后就能稳定运行，另外，使用存储过程比单纯 SQL 语句执行要快，因为存储过程是预编译过的。","Properties":{"id":""}}]},{"ID":"20220906204316-urfl2vw","Type":"NodeParagraph","Properties":{"id":"20220906204316-urfl2vw","updated":"20220906204316"},"Children":[{"Type":"NodeText","Data":"存储过程在互联网公司应用不多，因为存储过程难以调试和扩展，而且没有移植性，还会消耗数据库资源。","Properties":{"id":""}}]},{"ID":"20220906204317-lbg3jha","Type":"NodeParagraph","Properties":{"id":"20220906204317-lbg3jha","updated":"20220906204317"},"Children":[{"Type":"NodeText","Data":"阿里巴巴 Java 开发手册里要求禁止使用存储过程。","Properties":{"id":""}}]},{"ID":"20220906204318-szvjx6v","Type":"NodeParagraph","Properties":{"id":"20220906204318-szvjx6v","updated":"20220906204318"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"阿里巴巴Java开发手册: 禁止存储过程","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/0fa082bc4d4f919065767476a41b2156.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204319-1msyo7u","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204319-1msyo7u","updated":"20220906204319"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"drop、delete 与 truncate 区别？","Properties":{"id":""}}]},{"ID":"20220906204320-3ijrs0j","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204320-3ijrs0j","updated":"20220906204320"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"用法不同","Properties":{"id":""}}]},{"ID":"20220906204321-zkg7ab7","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204321-zkg7ab7","updated":"20220906204321"},"Children":[{"ID":"20220906204322-nkoiw3v","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204322-nkoiw3v","updated":"20220906204322"},"Children":[{"ID":"20220906204323-gehihni","Type":"NodeParagraph","Properties":{"id":"20220906204323-gehihni","updated":"20220906204323"},"Children":[{"Type":"NodeText","Data":"drop(丢弃数据): ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"drop table 表名"},{"Type":"NodeText","Data":" ，直接将表都删除掉，在删除表的时候使用。","Properties":{"id":""}}]}]},{"ID":"20220906204324-u0xtb8g","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204324-u0xtb8g","updated":"20220906204324"},"Children":[{"ID":"20220906204325-gp75a7r","Type":"NodeParagraph","Properties":{"id":"20220906204325-gp75a7r","updated":"20220906204325"},"Children":[{"Type":"NodeText","Data":"truncate (清空数据) : ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"truncate table 表名"},{"Type":"NodeText","Data":" ，只删除表中的数据，再插入数据的时候自增长 id 又从 1 开始，在清空表中数据的时候使用。","Properties":{"id":""}}]}]},{"ID":"20220906204326-0d8alsr","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204326-0d8alsr","updated":"20220906204326"},"Children":[{"ID":"20220906204327-dvcodyi","Type":"NodeParagraph","Properties":{"id":"20220906204327-dvcodyi","updated":"20220906204327"},"Children":[{"Type":"NodeText","Data":"delete（删除数据） : ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"delete from 表名 where 列名=值"},{"Type":"NodeText","Data":"，删除某一行的数据，如果不加 where 子句和","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"truncate table 表名"},{"Type":"NodeText","Data":"作用类似。","Properties":{"id":""}}]}]}]},{"ID":"20220906204328-ntmh9yu","Type":"NodeParagraph","Properties":{"id":"20220906204328-ntmh9yu","updated":"20220906204328"},"Children":[{"Type":"NodeText","Data":"truncate 和不带 where 子句的 delete、以及 drop 都会删除表内的数据，但是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"truncate 和 delete 只删除数据不删除表的结构(定义)，执行 drop 语句，此表的结构也会删除，也就是执行 drop 之后对应的表不复存在。"}]},{"ID":"20220906204329-0njlawl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204329-0njlawl","updated":"20220906204329"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"属于不同的数据库语言","Properties":{"id":""}}]},{"ID":"20220906204330-x6dr7tt","Type":"NodeParagraph","Properties":{"id":"20220906204330-x6dr7tt","updated":"20220906204330"},"Children":[{"Type":"NodeText","Data":"truncate 和 drop 属于 DDL(数据定义语言)语句，操作立即生效，原数据不放到 rollback segment 中，不能回滚，操作不触发 trigger。而 delete 语句是 DML (数据库操作语言)语句，这个操作会放到 rollback segement 中，事务提交之后才生效。","Properties":{"id":""}}]},{"ID":"20220906204331-ereqjjx","Type":"NodeParagraph","Properties":{"id":"20220906204331-ereqjjx","updated":"20220906204331"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"DML 语句和 DDL 语句区别："}]},{"ID":"20220906204332-1q6tvjt","Type":"NodeList","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204332-1q6tvjt","updated":"20220906204332"},"Children":[{"ID":"20220906204333-93h8q26","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204333-93h8q26","updated":"20220906204333"},"Children":[{"ID":"20220906204334-wiosnxn","Type":"NodeParagraph","Properties":{"id":"20220906204334-wiosnxn","updated":"20220906204334"},"Children":[{"Type":"NodeText","Data":"DML 是数据库操作语言（Data Manipulation Language）的缩写，是指对数据库中表记录的操作，主要包括表记录的插入（insert）、更新（update）、删除（delete）和查询（select），是开发人员日常使用最频繁的操作。","Properties":{"id":""}}]}]},{"ID":"20220906204335-1zsfphj","Type":"NodeListItem","Data":"*","ListData":{"Tight":true,"BulletChar":42,"Padding":2,"Marker":"Kg==","Num":-1},"Properties":{"id":"20220906204335-1zsfphj","updated":"20220906204335"},"Children":[{"ID":"20220906204336-xwtyip4","Type":"NodeParagraph","Properties":{"id":"20220906204336-xwtyip4","updated":"20220906204336"},"Children":[{"Type":"NodeText","Data":"DDL （Data Definition Language）是数据定义语言的缩写，简单来说，就是对数据库内部的对象进行创建、删除、修改的操作语言。它和 DML 语言的最大区别是 DML 只是对表内部数据的操作，而不涉及到表的定义、结构的修改，更不会涉及到其他对象。DDL 语句更多的被数据库管理员（DBA）所使用，一般的开发人员很少使用。","Properties":{"id":""}}]}]}]},{"ID":"20220906204337-1np8oip","Type":"NodeBlockquote","Properties":{"id":"20220906204337-1np8oip","updated":"20220906204337"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204338-2t13652","Type":"NodeParagraph","Properties":{"id":"20220906204338-2t13652","updated":"20220906204338"},"Children":[{"Type":"NodeText","Data":"由于","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"select"},{"Type":"NodeText","Data":"不会对表进行破坏，所以有的地方也会把","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"select"},{"Type":"NodeText","Data":"单独区分开叫做数据库查询语言DQL（Data Query Language）","Properties":{"id":""}}]}]},{"ID":"20220906204339-9k1mlpt","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204339-9k1mlpt","updated":"20220906204339"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"执行速度不同","Properties":{"id":""}}]},{"ID":"20220906204340-8ll0mhq","Type":"NodeParagraph","Properties":{"id":"20220906204340-8ll0mhq","updated":"20220906204340"},"Children":[{"Type":"NodeText","Data":"一般来说：drop \u003e truncate \u003e delete（这个我没有设计测试过）。","Properties":{"id":""}}]},{"ID":"20220906204341-67a0snd","Type":"NodeBlockquote","Properties":{"id":"20220906204341-67a0snd","updated":"20220906204341"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204342-e1k666c","Type":"NodeParagraph","Properties":{"id":"20220906204342-e1k666c","updated":"20220906204342"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":"命令执行的时候会产生数据库的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"binlog"},{"Type":"NodeText","Data":"日志，而日志记录是需要消耗时间的，但是也有个好处方便数据回滚恢复。","Properties":{"id":""}}]},{"ID":"20220906204343-ufodexh","Type":"NodeParagraph","Properties":{"id":"20220906204343-ufodexh","updated":"20220906204343"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"truncate"},{"Type":"NodeText","Data":"命令执行的时候不会产生数据库日志，因此比","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":"要快。除此之外，还会把表的自增值重置和索引恢复到初始大小等。","Properties":{"id":""}}]},{"ID":"20220906204344-ef0czuz","Type":"NodeParagraph","Properties":{"id":"20220906204344-ef0czuz","updated":"20220906204344"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"drop"},{"Type":"NodeText","Data":"命令会把表占用的空间全部释放掉。","Properties":{"id":""}}]},{"ID":"20220906204345-ldmpxlh","Type":"NodeParagraph","Properties":{"id":"20220906204345-ldmpxlh","updated":"20220906204345"},"Children":[{"Type":"NodeText","Data":"Tips：你应该更多地关注在使用场景上，而不是执行效率。","Properties":{"id":""}}]}]},{"ID":"20220906204346-x1fsge3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204346-x1fsge3","updated":"20220906204346"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库设计通常分为哪几步?","Properties":{"id":""}}]},{"ID":"20220906204347-nt1bo7t","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204347-nt1bo7t","updated":"20220906204347"},"Children":[{"ID":"20220906204348-avifgjy","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204348-avifgjy","updated":"20220906204348"},"Children":[{"ID":"20220906204349-5uousyu","Type":"NodeParagraph","Properties":{"id":"20220906204349-5uousyu","updated":"20220906204349"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"需求分析"},{"Type":"NodeText","Data":" : 分析用户的需求，包括数据、功能和性能需求。","Properties":{"id":""}}]}]},{"ID":"20220906204350-grklzan","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204350-grklzan","updated":"20220906204350"},"Children":[{"ID":"20220906204351-5ensu7k","Type":"NodeParagraph","Properties":{"id":"20220906204351-5ensu7k","updated":"20220906204351"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"T