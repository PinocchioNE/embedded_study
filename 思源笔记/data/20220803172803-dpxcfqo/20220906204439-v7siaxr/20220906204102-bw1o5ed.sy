:[{"Type":"NodeText","Data":"5 种不同的 Version(版本)值分别对应的含义（参考","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/%E9%80%9A%E7%94%A8%E5%94%AF%E4%B8%80%E8%AF%86%E5%88%AB%E7%A0%81","TextMarkTextContent":"维基百科对于 UUID 的介绍"},{"Type":"NodeText","Data":"）：","Properties":{"id":""}}]},{"ID":"20220906204228-ef77hki","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204228-ef77hki","updated":"20220906204228"},"Children":[{"ID":"20220906204229-awr88iu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204229-awr88iu","updated":"20220906204229"},"Children":[{"ID":"20220906204230-bg8wvus","Type":"NodeParagraph","Properties":{"id":"20220906204230-bg8wvus","updated":"20220906204230"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"版本 1"},{"Type":"NodeText","Data":" : UUID 是根据时间和节点 ID（通常是 MAC 地址）生成；","Properties":{"id":""}}]}]},{"ID":"20220906204231-f9uq4eo","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204231-f9uq4eo","updated":"20220906204231"},"Children":[{"ID":"20220906204232-1qhp1ye","Type":"NodeParagraph","Properties":{"id":"20220906204232-1qhp1ye","updated":"20220906204232"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"版本 2"},{"Type":"NodeText","Data":" : UUID 是根据标识符（通常是组或用户 ID）、时间和节点 ID 生成；","Properties":{"id":""}}]}]},{"ID":"20220906204233-fnruk8u","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204233-fnruk8u","updated":"20220906204233"},"Children":[{"ID":"20220906204234-cqiy58s","Type":"NodeParagraph","Properties":{"id":"20220906204234-cqiy58s","updated":"20220906204234"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"版本 3、版本 5"},{"Type":"NodeText","Data":" : 版本 5 - 确定性 UUID 通过散列（hashing）名字空间（namespace）标识符和名称生成；","Properties":{"id":""}}]}]},{"ID":"20220906204235-3z6rcos","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204235-3z6rcos","updated":"20220906204235"},"Children":[{"ID":"20220906204236-hnsj7jm","Type":"NodeParagraph","Properties":{"id":"20220906204236-hnsj7jm","updated":"20220906204236"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"版本 4"},{"Type":"NodeText","Data":" : UUID 使用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/随机性","TextMarkTextContent":"随机性"},{"Type":"NodeText","Data":"或","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/伪随机性","TextMarkTextContent":"伪随机性"},{"Type":"NodeText","Data":"生成。","Properties":{"id":""}}]}]}]},{"ID":"20220906204237-atfhtcp","Type":"NodeParagraph","Properties":{"id":"20220906204237-atfhtcp","updated":"20220906204237"},"Children":[{"Type":"NodeText","Data":"下面是 Version 1 版本下生成的 UUID 的示例：","Properties":{"id":""}}]},{"ID":"20220906204238-a5x87ec","Type":"NodeParagraph","Properties":{"id":"20220906204238-a5x87ec","updated":"20220906204238"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Version 1 版本下生成的 UUID 的示例","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/version1-uuid.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204239-wu6w4dd","Type":"NodeParagraph","Properties":{"id":"20220906204239-wu6w4dd","updated":"20220906204239"},"Children":[{"Type":"NodeText","Data":"JDK 中通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"UUID"},{"Type":"NodeText","Data":" 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"randomUUID()"},{"Type":"NodeText","Data":" 方法生成的 UUID 的版本默认为 4。","Properties":{"id":""}}]},{"ID":"20220906204240-psalnop","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204240-psalnop","updated":"20220906204240"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"UUID uuid = UUID.randomUUID();\nint version = uuid.version();// 4\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204241-oi4qqgu","Type":"NodeParagraph","Properties":{"id":"20220906204241-oi4qqgu","updated":"20220906204241"},"Children":[{"Type":"NodeText","Data":"另外，Variant(变体)也有 4 种不同的值，这种值分别对应不同的含义。这里就不介绍了，貌似平时也不怎么需要关注。","Properties":{"id":""}}]},{"ID":"20220906204242-tkiikth","Type":"NodeParagraph","Properties":{"id":"20220906204242-tkiikth","updated":"20220906204242"},"Children":[{"Type":"NodeText","Data":"需要用到的时候，去看看维基百科对于 UUID 的 Variant(变体) 相关的介绍即可。","Properties":{"id":""}}]},{"ID":"20220906204243-io3uewd","Type":"NodeParagraph","Properties":{"id":"20220906204243-io3uewd","updated":"20220906204243"},"Children":[{"Type":"NodeText","Data":"从上面的介绍中可以看出，UUID 可以保证唯一性，因为其生成规则包括 MAC 地址、时间戳、名字空间（Namespace）、随机或伪随机数、时序等元素，计算机基于这些规则生成的 UUID 是肯定不会重复的。","Properties":{"id":""}}]},{"ID":"20220906204244-zf61f33","Type":"NodeParagraph","Properties":{"id":"20220906204244-zf61f33","updated":"20220906204244"},"Children":[{"Type":"NodeText","Data":"虽然，UUID 可以做到全局唯一性，但是，我们一般很少会使用它。","Properties":{"id":""}}]},{"ID":"20220906204245-ofrmekn","Type":"NodeParagraph","Properties":{"id":"20220906204245-ofrmekn","updated":"20220906204245"},"Children":[{"Type":"NodeText","Data":"比如使用 UUID 作为 MySQL 数据库主键的时候就非常不合适：","Properties":{"id":""}}]},{"ID":"20220906204246-wwezxi3","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204246-wwezxi3","updated":"20220906204246"},"Children":[{"ID":"20220906204247-aocop5p","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204247-aocop5p","updated":"20220906204247"},"Children":[{"ID":"20220906204248-rfr8011","Type":"NodeParagraph","Properties":{"id":"20220906204248-rfr8011","updated":"20220906204248"},"Children":[{"Type":"NodeText","Data":"数据库主键要尽量越短越好，而 UUID 的消耗的存储空间比较大（32 个字符串，128 位）。","Properties":{"id":""}}]}]},{"ID":"20220906204249-k37nd28","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204249-k37nd28","updated":"20220906204249"},"Children":[{"ID":"20220906204250-tl7d4g8","Type":"NodeParagraph","Properties":{"id":"20220906204250-tl7d4g8","updated":"20220906204250"},"Children":[{"Type":"NodeText","Data":"UUID 是无顺序的，InnoDB 引擎下，数据库主键的无序性会严重影响数据库性能。","Properties":{"id":""}}]}]}]},{"ID":"20220906204251-q7s8rlj","Type":"NodeParagraph","Properties":{"id":"20220906204251-q7s8rlj","updated":"20220906204251"},"Children":[{"Type":"NodeText","Data":"最后，我们再简单分析一下 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"UUID 的优缺点"},{"Type":"NodeText","Data":" （面试的时候可能会被问到的哦！） :","Properties":{"id":""}}]},{"ID":"20220906204252-j1vmqj7","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204252-j1vmqj7","updated":"20220906204252"},"Children":[{"ID":"20220906204253-2eb7flj","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204253-2eb7flj","updated":"20220906204253"},"Children":[{"ID":"20220906204254-we54ql2","Type":"NodeParagraph","Properties":{"id":"20220906204254-we54ql2","updated":"20220906204254"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优点"},{"Type":"NodeText","Data":" ：生成速度比较快、简单易用","Properties":{"id":""}}]}]},{"ID":"20220906204255-y9r5cgv","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204255-y9r5cgv","updated":"20220906204255"},"Children":[{"ID":"20220906204256-zyquigu","Type":"NodeParagraph","Properties":{"id":"20220906204256-zyquigu","updated":"20220906204256"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺点"},{"Type":"NodeText","Data":" ： 存储消耗空间大（32 个字符串，128 位） 、 不安全（基于 MAC 地址生成 UUID 的算法会造成 MAC 地址泄露)、无序（非自增）、没有具体业务含义、需要解决重复 ID 问题（当机器时间不对的情况下，可能导致会产生重复 ID）","Properties":{"id":""}}]}]}]},{"ID":"20220906204257-yfsjcuz","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204257-yfsjcuz","updated":"20220906204257"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Snowflake(雪花算法)","Properties":{"id":""}}]},{"ID":"20220906204258-8u0tg3c","Type":"NodeParagraph","Properties":{"id":"20220906204258-8u0tg3c","updated":"20220906204258"},"Children":[{"Type":"NodeText","Data":"Snowflake 是 Twitter 开源的分布式 ID 生成算法。Snowflake 由 64 bit 的二进制数字组成，这 64bit 的二进制被分成了几部分，每一部分存储的数据都有特定的含义：","Properties":{"id":""}}]},{"ID":"20220906204259-mci0dmf","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204259-mci0dmf","updated":"20220906204259"},"Children":[{"ID":"20220906204260-dbglciw","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204260-dbglciw","updated":"20220906204260"},"Children":[{"ID":"20220906204261-aqo6zo8","Type":"NodeParagraph","Properties":{"id":"20220906204261-aqo6zo8","updated":"20220906204261"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"第 0 位"},{"Type":"NodeText","Data":"： 符号位（标识正负），始终为 0，没有用，不用管。","Properties":{"id":""}}]}]},{"ID":"20220906204262-uydaulc","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204262-uydaulc","updated":"20220906204262"},"Children":[{"ID":"20220906204263-ntr3hfl","Type":"NodeParagraph","Properties":{"id":"20220906204263-ntr3hfl","updated":"20220906204263"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"第 1~41 位"},{"Type":"NodeText","Data":" ：一共 41 位，用来表示时间戳，单位是毫秒，可以支撑 2 ^41 毫秒（约 69 年）","Properties":{"id":""}}]}]},{"ID":"20220906204264-046q6gi","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204264-046q6gi","updated":"20220906204264"},"Children":[{"ID":"20220906204265-fbyf7cl","Type":"NodeParagraph","Properties":{"id":"20220906204265-fbyf7cl","updated":"20220906204265"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"第 42~52 位"},{"Type":"NodeText","Data":" ：一共 10 位，一般来说，前 5 位表示机房 ID，后 5 位表示机器 ID（实际项目中可以根据实际情况调整）。这样就可以区分不同集群/机房的节点。","Properties":{"id":""}}]}]},{"ID":"20220906204266-7635dno","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204266-7635dno","updated":"20220906204266"},"Children":[{"ID":"20220906204267-obhgtna","Type":"NodeParagraph","Properties":{"id":"20220906204267-obhgtna","updated":"20220906204267"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"第 53~64 位"},{"Type":"NodeText","Data":" ：一共 12 位，用来表示序列号。 序列号为自增值，代表单台机器每毫秒能够产生的最大 ID 数(2^12 = 4096),也就是说单台机器每毫秒最多可以生成 4096 个 唯一 ID。","Properties":{"id":""}}]}]}]},{"ID":"20220906204268-4jorncv","Type":"NodeParagraph","Properties":{"id":"20220906204268-4jorncv","updated":"20220906204268"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Snowflake 示意图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/snowflake-distributed-id-schematic-diagram.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204269-g3sbyb2","Type":"NodeParagraph","Properties":{"id":"20220906204269-g3sbyb2","updated":"20220906204269"},"Children":[{"Type":"NodeText","Data":"如果你想要使用 Snowflake 算法的话，一般不需要你自己再造轮子。有很多基于 Snowflake 算法的开源实现比如美团 的 Leaf、百度的 UidGenerator，并且这些开源实现对原有的 Snowflake 算法进行了优化。","Properties":{"id":""}}]},{"ID":"20220906204270-45ywooz","Type":"NodeParagraph","Properties":{"id":"20220906204270-45ywooz","updated":"20220906204270"},"Children":[{"Type":"NodeText","Data":"另外，在实际项目中，我们一般也会对 Snowflake 算法进行改造，最常见的就是在 Snowflake 算法生成的 ID 中加入业务类型信息。","Properties":{"id":""}}]},{"ID":"20220906204271-1fv69db","Type":"NodeParagraph","Properties":{"id":"20220906204271-1fv69db","updated":"20220906204271"},"Children":[{"Type":"NodeText","Data":"我们再来看看 Snowflake 算法的优缺点 ：","Properties":{"id":""}}]},{"ID":"20220906204272-afm3jgi","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204272-afm3jgi","updated":"20220906204272"},"Children":[{"ID":"20220906204273-ml8y2eb","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204273-ml8y2eb","updated":"20220906204273"},"Children":[{"ID":"20220906204274-2zgr8p6","Type":"NodeParagraph","Properties":{"id":"20220906204274-2zgr8p6","updated":"20220906204274"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优点"},{"Type":"NodeText","Data":" ：生成速度比较快、生成的 ID 有序递增、比较灵活（可以对 Snowflake 算法进行简单的改造比如加入业务 ID）","Properties":{"id":""}}]}]},{"ID":"20220906204275-0xzszcw","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204275-0xzszcw","updated":"20220906204275"},"Children":[{"ID":"20220906204276-t8agiko","Type":"NodeParagraph","Properties":{"id":"20220906204276-t8agiko","updated":"20220906204276"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺点"},{"Type":"NodeText","Data":" ： 需要解决重复 ID 问题（依赖时间，当机器时间不对的情况下，可能导致会产生重复 ID）。","Properties":{"id":""}}]}]}]},{"ID":"20220906204277-q6gq16q","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204277-q6gq16q","updated":"20220906204277"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"开源框架","Properties":{"id":""}}]},{"ID":"20220906204278-2ahxxjk","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204278-2ahxxjk","updated":"20220906204278"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"UidGenerator(百度)","Properties":{"id":""}}]},{"ID":"20220906204279-cpsoods","Type":"NodeParagraph","Properties":{"id":"20220906204279-cpsoods","updated":"20220906204279"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/baidu/uid-generator","TextMarkTextContent":"UidGenerator"},{"Type":"NodeText","Data":" 是百度开源的一款基于 Snowflake(雪花算法)的唯一 ID 生成器。","Properties":{"id":""}}]},{"ID":"20220906204280-j7q4x7q","Type":"NodeParagraph","Properties":{"id":"20220906204280-j7q4x7q","updated":"20220906204280"},"Children":[{"Type":"NodeText","Data":"不过，UidGenerator 对 Snowflake(雪花算法)进行了改进，生成的唯一 ID 组成如下。","Properties":{"id":""}}]},{"ID":"20220906204281-sxsqmyt","Type":"NodeParagraph","Properties":{"id":"20220906204281-sxsqmyt","updated":"20220906204281"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/uidgenerator-distributed-id-schematic-diagram.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204282-vyf02dv","Type":"NodeParagraph","Properties":{"id":"20220906204282-vyf02dv","updated":"20220906204282"},"Children":[{"Type":"NodeText","Data":"可以看出，和原始 Snowflake(雪花算法)生成的唯一 ID 的组成不太一样。并且，上面这些参数我们都可以自定义。","Properties":{"id":""}}]},{"ID":"20220906204283-ifhsah2","Type":"NodeParagraph","Properties":{"id":"20220906204283-ifhsah2","updated":"20220906204283"},"Children":[{"Type":"NodeText","Data":"UidGenerator 官方文档中的介绍如下：","Properties":{"id":""}}]},{"ID":"20220906204284-wijuseg","Type":"NodeParagraph","Properties":{"id":"20220906204284-wijuseg","updated":"20220906204284"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/uidgenerator-introduction-official-documents.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204285-aj0e8p2","Type":"NodeParagraph","Properties":{"id":"20220906204285-aj0e8p2","updated":"20220906204285"},"Children":[{"Type":"NodeText","Data":"自 18 年后，UidGenerator 就基本没有再维护了，我这里也不过多介绍。想要进一步了解的朋友，可以看看 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/baidu/uid-generator/blob/master/README.zh_cn.md","TextMarkTextContent":"UidGenerator 的官方介绍"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204286-d6jz1ih","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204286-d6jz1ih","updated":"20220906204286"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Leaf(美团)","Properties":{"id":""}}]},{"ID":"20220906204287-dewz27h","Type":"NodeParagraph","Properties":{"id":"20220906204287-dewz27h","updated":"20220906204287"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong a","TextMarkAHref":"https://github.com/Meituan-Dianping/Leaf","TextMarkTextContent":"Leaf"},{"Type":"NodeText","Data":" 是美团开源的一个分布式 ID 解决方案 。这个项目的名字 Leaf（树叶） 起源于德国哲学家、数学家莱布尼茨的一句话： “There are no two identical leaves in the world”（世界上没有两片相同的树叶） 。这名字起得真心挺不错的，有点文艺青年那味了！","Properties":{"id":""}}]},{"ID":"20220906204288-qo15rig","Type":"NodeParagraph","Properties":{"id":"20220906204288-qo15rig","updated":"20220906204288"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210422145229617.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204289-rm4on04","Type":"NodeParagraph","Properties":{"id":"20220906204289-rm4on04","updated":"20220906204289"},"Children":[{"Type":"NodeText","Data":"Leaf 提供了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"号段模式"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Snowflake(雪花算法)"},{"Type":"NodeText","Data":" 这两种模式来生成分布式 ID。并且，它支持双号段，还解决了雪花 ID 系统时钟回拨问题。不过，时钟问题的解决需要弱依赖于 Zookeeper 。","Properties":{"id":""}}]},{"ID":"20220906204290-n9xcb13","Type":"NodeParagraph","Properties":{"id":"20220906204290-n9xcb13","updated":"20220906204290"},"Children":[{"Type":"NodeText","Data":"Leaf 的诞生主要是为了解决美团各个业务线生成分布式 ID 的方法多种多样以及不可靠的问题。","Properties":{"id":""}}]},{"ID":"20220906204291-7ap8a71","Type":"NodeParagraph","Properties":{"id":"20220906204291-7ap8a71","updated":"20220906204291"},"Children":[{"Type":"NodeText","Data":"Leaf 对原有的号段模式进行改进，比如它这里增加了双号段避免获取 DB 在获取号段的时候阻塞请求获取 ID 的线程。简单来说，就是我一个号段还没用完之前，我自己就主动提前去获取下一个号段（图片来自于美团官方文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://tech.meituan.com/2017/04/21/mt-leaf.html","TextMarkTextContent":"《Leaf——美团点评分布式 ID 生成系统》"},{"Type":"NodeText","Data":"）。","Properties":{"id":""}}]},{"ID":"20220906204292-ln5s9xe","Type":"NodeParagraph","Properties":{"id":"20220906204292-ln5s9xe","updated":"20220906204292"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/20210422144846724.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204293-kesowuy","Type":"NodeParagraph","Properties":{"id":"20220906204293-kesowuy","updated":"20220906204293"},"Children":[{"Type":"NodeText","Data":"根据项目 README 介绍，在 4C8G VM 基础上，通过公司 RPC 方式调用，QPS 压测结果近 5w/s，TP999 1ms。","Properties":{"id":""}}]},{"ID":"20220906204294-6p2ps59","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204294-6p2ps59","updated":"20220906204294"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Tinyid(滴滴)","Properties":{"id":""}}]},{"ID":"20220906204295-eyayzr8","Type":"NodeParagraph","Properties":{"id":"20220906204295-eyayzr8","updated":"20220906204295"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/didi/tinyid","TextMarkTextContent":"Tinyid"},{"Type":"NodeText","Data":" 是滴滴开源的一款基于数据库号段模式的唯一 ID 生成器。","Properties":{"id":""}}]},{"ID":"20220906204296-106sxr7","Type":"NodeParagraph","Properties":{"id":"20220906204296-106sxr7","updated":"20220906204296"},"Children":[{"Type":"NodeText","Data":"数据库号段模式的原理我们在上面已经介绍过了。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Tinyid 有哪些亮点呢？"}]},{"ID":"20220906204297-k0lsz3q","Type":"NodeParagraph","Properties":{"id":"20220906204297-k0lsz3q","updated":"20220906204297"},"Children":[{"Type":"NodeText","Data":"为了搞清楚这个问题，我们先来看看基于数据库号段模式的简单架构方案。（图片来自于 Tinyid 的官方 wiki:","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/didi/tinyid/wiki/tinyid%E5%8E%9F%E7%90%86%E4%BB%8B%E7%BB%8D","TextMarkTextContent":"《Tinyid 原理介绍》"},{"Type":"NodeText","Data":"）","Properties":{"id":""}}]},{"ID":"20220906204298-r8zezjb","Type":"NodeParagraph","Properties":{"id":"20220906204298-r8zezjb","updated":"20220906204298"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://oscimg.oschina.net/oscnet/up-4afc0e45c0c86ba5ad645d023dce11e53c2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204299-mms5ke6","Type":"NodeParagraph","Properties":{"id":"20220906204299-mms5ke6","updated":"20220906204299"},"Children":[{"Type":"NodeText","Data":"在这种架构模式下，我们通过 HTTP 请求向发号器服务申请唯一 ID。负载均衡 router 会把我们的请求送往其中的一台 tinyid-server。","Properties":{"id":""}}]},{"ID":"20220906204300-inlvpkr","Type":"NodeParagraph","Properties":{"id":"20220906204300-inlvpkr","updated":"20220906204300"},"Children":[{"Type":"NodeText","Data":"这种方案有什么问题呢？在我看来（Tinyid 官方 wiki 也有介绍到），主要由下面这 2 个问题：","Properties":{"id":""}}]},{"ID":"20220906204301-vf3tvo9","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204301-vf3tvo9","updated":"20220906204301"},"Children":[{"ID":"20220906204302-2mnv2ee","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204302-2mnv2ee","updated":"20220906204302"},"Children":[{"ID":"20220906204303-h987ji9","Type":"NodeParagraph","Properties":{"id":"20220906204303-h987ji9","updated":"20220906204303"},"Children":[{"Type":"NodeText","Data":"获取新号段的情况下，程序获取唯一 ID 的速度比较慢。","Properties":{"id":""}}]}]},{"ID":"20220906204304-4a0majt","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204304-4a0majt","updated":"20220906204304"},"Children":[{"ID":"20220906204305-kc1xw93","Type":"NodeParagraph","Properties":{"id":"20220906204305-kc1xw93","updated":"20220906204305"},"Children":[{"Type":"NodeText","Data":"需要保证 DB 高可用，这个是比较麻烦且耗费资源的。","Properties":{"id":""}}]}]}]},{"ID":"20220906204306-9aaqp6y","Type":"NodeParagraph","Properties":{"id":"20220906204306-9aaqp6y","updated":"20220906204306"},"Children":[{"Type":"NodeText","Data":"除此之外，HTTP 调用也存在网络开销。","Properties":{"id":""}}]},{"ID":"20220906204307-ejq3kn2","Type":"NodeParagraph","Properties":{"id":"20220906204307-ejq3kn2","updated":"20220906204307"},"Children":[{"Type":"NodeText","Data":"Tinyid 的原理比较简单，其架构如下图所示：","Properties":{"id":""}}]},{"ID":"20220906204308-j588lja","Type":"NodeParagraph","Properties":{"id":"20220906204308-j588lja","updated":"20220906204308"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://oscimg.oschina.net/oscnet/up-53f74cd615178046d6c04fe50513fee74ce.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204309-jxtowsj","Type":"NodeParagraph","Properties":{"id":"20220906204309-jxtowsj","updated":"20220906204309"},"Children":[{"Type":"NodeText","Data":"相比于基于数据库号段模式的简单架构方案，Tinyid 方案主要做了下面这些优化：","Properties":{"id":""}}]},{"ID":"20220906204310-3wr98ig","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204310-3wr98ig","updated":"20220906204310"},"Children":[{"ID":"20220906204311-0qn3srd","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204311-0qn3srd","updated":"20220906204311"},"Children":[{"ID":"20220906204312-prkrffi","Type":"NodeParagraph","Properties":{"id":"20220906204312-prkrffi","updated":"20220906204312"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"双号段缓存"},{"Type":"NodeText","Data":" ：为了避免在获取新号段的情况下，程序获取唯一 ID 的速度比较慢。 Tinyid 中的号段在用到一定程度的时候，就会去异步加载下一个号段，保证内存中始终有可用号段。","Properties":{"id":""}}]}]},{"ID":"20220906204313-fj9l4kp","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204313-fj9l4kp","updated":"20220906204313"},"Children":[{"ID":"20220906204314-8et4tx1","Type":"NodeParagraph","Properties":{"id":"20220906204314-8et4tx1","updated":"20220906204314"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"增加多 db 支持"},{"Type":"NodeText","Data":" ：支持多个 DB，并且，每个 DB 都能生成唯一 ID，提高了可用性。","Properties":{"id":""}}]}]},{"ID":"20220906204315-qlh6r1a","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204315-qlh6r1a","updated":"20220906204315"},"Children":[{"ID":"20220906204316-75vfl7c","Type":"NodeParagraph","Properties":{"id":"20220906204316-75vfl7c","updated":"20220906204316"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"增加 tinyid-client"},{"Type":"NodeText","Data":" ：纯本地操作，无 HTTP 请求消耗，性能和可用性都有很大提升。","Properties":{"id":""}}]}]}]},{"ID":"20220906204317-gc2if40","Type":"NodeParagraph","Properties":{"id":"20220906204317-gc2if40","updated":"20220906204317"},"Children":[{"Type":"NodeText","Data":"Tinyid 的优缺点这里就不分析了，结合数据库号段模式的优缺点和 Tinyid 的原理就能知道。","Properties":{"id":""}}]},{"ID":"20220906204318-dm2tj4p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204318-dm2tj4p","updated":"20220906204318"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220906204319-qnxt1dj","Type":"NodeParagraph","Properties":{"id":"20220906204319-qnxt1dj","updated":"20220906204319"},"Children":[{"Type":"NodeText","Data":"通过这篇文章，我基本上已经把最常见的分布式 ID 生成方案都总结了一波。除了上面介绍的方式之外，像 ZooKeeper 这类中间件也可以帮助我们生成唯一 ID。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"没有银弹，一定要结合实际项目来选择最适合自己的方案。"}]},{"ID":"20220906204320-qhi4nhq","Type":"NodeThematicBreak","Properties":{"id":"20220906204320-qhi4nhq","updated":"20220906204320"}}]}