{"ID":"20220906204102-bw1o5ed","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220906204102-bw1o5ed","title":"g-2分布式id","type":"doc","updated":"20220906204102"},"Children":[{"ID":"20220906204103-r1y7get","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906204103-r1y7get","updated":"20220906204103"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"7.3 分布式 id","Properties":{"id":""}}]},{"ID":"20220906204104-vycg61d","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204104-vycg61d","updated":"20220906204104"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分布式 ID 介绍","Properties":{"id":""}}]},{"ID":"20220906204105-nhn0781","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204105-nhn0781","updated":"20220906204105"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 ID？","Properties":{"id":""}}]},{"ID":"20220906204106-5q5ur3h","Type":"NodeParagraph","Properties":{"id":"20220906204106-5q5ur3h","updated":"20220906204106"},"Children":[{"Type":"NodeText","Data":"日常开发中，我们需要对系统中的各种数据使用 ID 唯一表示，比如用户 ID 对应且仅对应一个人，商品 ID 对应且仅对应一件商品，订单 ID 对应且仅对应一个订单。","Properties":{"id":""}}]},{"ID":"20220906204107-sho3ts8","Type":"NodeParagraph","Properties":{"id":"20220906204107-sho3ts8","updated":"20220906204107"},"Children":[{"Type":"NodeText","Data":"我们现实生活中也有各种 ID，比如身份证 ID 对应且仅对应一个人、地址 ID 对应且仅对应","Properties":{"id":""}}]},{"ID":"20220906204108-wp3hzo0","Type":"NodeParagraph","Properties":{"id":"20220906204108-wp3hzo0","updated":"20220906204108"},"Children":[{"Type":"NodeText","Data":"简单来说，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"ID 就是数据的唯一标识"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204109-486ccic","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204109-486ccic","updated":"20220906204109"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是分布式 ID？","Properties":{"id":""}}]},{"ID":"20220906204110-1dzvlm9","Type":"NodeParagraph","Properties":{"id":"20220906204110-1dzvlm9","updated":"20220906204110"},"Children":[{"Type":"NodeText","Data":"分布式 ID 是分布式系统下的 ID。分布式 ID 不存在与现实生活中，属于计算机系统中的一个概念。","Properties":{"id":""}}]},{"ID":"20220906204111-qadvra0","Type":"NodeParagraph","Properties":{"id":"20220906204111-qadvra0","updated":"20220906204111"},"Children":[{"Type":"NodeText","Data":"我简单举一个分库分表的例子。","Properties":{"id":""}}]},{"ID":"20220906204112-y8svmre","Type":"NodeParagraph","Properties":{"id":"20220906204112-y8svmre","updated":"20220906204112"},"Children":[{"Type":"NodeText","Data":"我司的一个项目，使用的是单机 MySQL 。但是，没想到的是，项目上线一个月之后，随着使用人数越来越多，整个系统的数据量将越来越大。单机 MySQL 已经没办法支撑了，需要进行分库分表（推荐 Sharding-JDBC）。","Properties":{"id":""}}]},{"ID":"20220906204113-bpw7tgk","Type":"NodeParagraph","Properties":{"id":"20220906204113-bpw7tgk","updated":"20220906204113"},"Children":[{"Type":"NodeText","Data":"在分库之后， 数据遍布在不同服务器上的数据库，数据库的自增主键已经没办法满足生成的主键唯一了。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我们如何为不同的数据节点生成全局唯一主键呢？"}]},{"ID":"20220906204114-oi1n38i","Type":"NodeParagraph","Properties":{"id":"20220906204114-oi1n38i","updated":"20220906204114"},"Children":[{"Type":"NodeText","Data":"这个时候就需要生成","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"分布式 ID"},{"Type":"NodeText","Data":"了。","Properties":{"id":""}}]},{"ID":"20220906204115-n3hm8cy","Type":"NodeParagraph","Properties":{"id":"20220906204115-n3hm8cy","updated":"20220906204115"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/id-after-the-sub-table-not-conflict.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204116-bfmc7ep","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204116-bfmc7ep","updated":"20220906204116"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分布式 ID 需要满足哪些要求?","Properties":{"id":""}}]},{"ID":"20220906204117-a73w4kc","Type":"NodeParagraph","Properties":{"id":"20220906204117-a73w4kc","updated":"20220906204117"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/distributed-id-requirements.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204118-gfhhl1m","Type":"NodeParagraph","Properties":{"id":"20220906204118-gfhhl1m","updated":"20220906204118"},"Children":[{"Type":"NodeText","Data":"分布式 ID 作为分布式系统中必不可少的一环，很多地方都要用到分布式 ID。","Properties":{"id":""}}]},{"ID":"20220906204119-esx0j5j","Type":"NodeParagraph","Properties":{"id":"20220906204119-esx0j5j","updated":"20220906204119"},"Children":[{"Type":"NodeText","Data":"一个最基本的分布式 ID 需要满足下面这些要求：","Properties":{"id":""}}]},{"ID":"20220906204120-szz2d2j","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204120-szz2d2j","updated":"20220906204120"},"Children":[{"ID":"20220906204121-n9tylc3","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204121-n9tylc3","updated":"20220906204121"},"Children":[{"ID":"20220906204122-dj5b0jh","Type":"NodeParagraph","Properties":{"id":"20220906204122-dj5b0jh","updated":"20220906204122"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"全局唯一"},{"Type":"NodeText","Data":" ：ID 的全局唯一性肯定是首先要满足的！","Properties":{"id":""}}]}]},{"ID":"20220906204123-0aeb9t8","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204123-0aeb9t8","updated":"20220906204123"},"Children":[{"ID":"20220906204124-8yb02ac","Type":"NodeParagraph","Properties":{"id":"20220906204124-8yb02ac","updated":"20220906204124"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"高性能"},{"Type":"NodeText","Data":" ： 分布式 ID 的生成速度要快，对本地资源消耗要小。","Properties":{"id":""}}]}]},{"ID":"20220906204125-xerxpah","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204125-xerxpah","updated":"20220906204125"},"Children":[{"ID":"20220906204126-40flqis","Type":"NodeParagraph","Properties":{"id":"20220906204126-40flqis","updated":"20220906204126"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"高可用"},{"Type":"NodeText","Data":" ：生成分布式 ID 的服务要保证可用性无限接近于 100%。","Properties":{"id":""}}]}]},{"ID":"20220906204127-xqp2ylh","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204127-xqp2ylh","updated":"20220906204127"},"Children":[{"ID":"20220906204128-cqt7k8z","Type":"NodeParagraph","Properties":{"id":"20220906204128-cqt7k8z","updated":"20220906204128"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"方便易用"},{"Type":"NodeText","Data":" ：拿来即用，使用方便，快速接入！","Properties":{"id":""}}]}]}]},{"ID":"20220906204129-ms75eyl","Type":"NodeParagraph","Properties":{"id":"20220906204129-ms75eyl","updated":"20220906204129"},"Children":[{"Type":"NodeText","Data":"除了这些之外，一个比较好的分布式 ID 还应保证：","Properties":{"id":""}}]},{"ID":"20220906204130-l1x4ffk","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204130-l1x4ffk","updated":"20220906204130"},"Children":[{"ID":"20220906204131-gct3337","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204131-gct3337","updated":"20220906204131"},"Children":[{"ID":"20220906204132-m2d4kwc","Type":"NodeParagraph","Properties":{"id":"20220906204132-m2d4kwc","updated":"20220906204132"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"安全"},{"Type":"NodeText","Data":" ：ID 中不包含敏感信息。","Properties":{"id":""}}]}]},{"ID":"20220906204133-uxqbany","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204133-uxqbany","updated":"20220906204133"},"Children":[{"ID":"20220906204134-2sqe7pq","Type":"NodeParagraph","Properties":{"id":"20220906204134-2sqe7pq","updated":"20220906204134"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"有序递增"},{"Type":"NodeText","Data":" ：如果要把 ID 存放在数据库的话，ID 的有序性可以提升数据库写入速度。并且，很多时候 ，我们还很有可能会直接通过 ID 来进行排序。","Properties":{"id":""}}]}]},{"ID":"20220906204135-ctkbkp0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204135-ctkbkp0","updated":"20220906204135"},"Children":[{"ID":"20220906204136-wdpjb2c","Type":"NodeParagraph","Properties":{"id":"20220906204136-wdpjb2c","updated":"20220906204136"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"有具体的业务含义"},{"Type":"NodeText","Data":" ：生成的 ID 如果能有具体的业务含义，可以让定位问题以及开发更透明化（通过 ID 就能确定是哪个业务）。","Properties":{"id":""}}]}]},{"ID":"20220906204137-01kl8cg","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204137-01kl8cg","updated":"20220906204137"},"Children":[{"ID":"20220906204138-k4wglpv","Type":"NodeParagraph","Properties":{"id":"20220906204138-k4wglpv","updated":"20220906204138"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"独立部署"},{"Type":"NodeText","Data":" ：也就是分布式系统单独有一个发号器服务，专门用来生成分布式 ID。这样就生成 ID 的服务可以和业务相关的服务解耦。不过，这样同样带来了网络调用消耗增加的问题。总的来说，如果需要用到分布式 ID 的场景比较多的话，独立部署的发号器服务还是很有必要的。","Properties":{"id":""}}]}]}]},{"ID":"20220906204139-h44jovs","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204139-h44jovs","updated":"20220906204139"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分布式 ID 常见解决方案有哪些？","Properties":{"id":""}}]},{"ID":"20220906204140-i9ozzgv","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204140-i9ozzgv","updated":"20220906204140"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库","Properties":{"id":""}}]},{"ID":"20220906204141-wwl5pc6","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204141-wwl5pc6","updated":"20220906204141"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库主键自增","Properties":{"id":""}}]},{"ID":"20220906204142-2t2ys8p","Type":"NodeParagraph","Properties":{"id":"20220906204142-2t2ys8p","updated":"20220906204142"},"Children":[{"Type":"NodeText","Data":"这种方式就比较简单直白了，就是通过关系型数据库的自增主键产生来唯一的 ID。","Properties":{"id":""}}]},{"ID":"20220906204143-hz02igk","Type":"NodeParagraph","Properties":{"id":"20220906204143-hz02igk","updated":"20220906204143"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"数据库主键自增","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/system-design/distributed-system/the-primary-key-of-the-database-increases-automatically.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204144-tz9278m","Type":"NodeParagraph","Properties":{"id":"20220906204144-tz9278m","updated":"20220906204144"},"Children":[{"Type":"NodeText","Data":"以 MySQL 举例，我们通过下面的方式即可。","Properties":{"id":""}}]},{"ID":"20220906204145-b8c3l0f","Type":"NodeParagraph","Properties":{"id":"20220906204145-b8c3l0f","updated":"20220906204145"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1.创建一个数据库表。"}]},{"ID":"20220906204146-47ortxt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204146-47ortxt","updated":"20220906204146"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"CREATE TABLE `sequence_id` (\n  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,\n  `stub` char(10) NOT NULL DEFAULT '',\n  PRIMARY KEY (`id`),\n  UNIQUE KEY `stub` (`stub`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204147-zt7elot","Type":"NodeParagraph","Properties":{"id":"20220906204147-zt7elot","updated":"20220906204147"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"stub"},{"Type":"NodeText","Data":" 字段无意义，只是为了占位，便于我们插入或者修改数据。并且，给 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"stub"},{"Type":"NodeText","Data":" 字段创建了唯一索引，保证其唯一性。","Properties":{"id":""}}]},{"ID":"20220906204148-14mh6qh","Type":"NodeParagraph","Properties":{"id":"20220906204148-14mh6qh","updated":"20220906204148"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2.通过 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"replace into"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 来插入数据。"}]},{"ID":"20220906204149-xwj7jhz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204149-xwj7jhz","updated":"20220906204149"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"BEGIN;\nREPLACE INTO sequence_id (stub) VALUES ('stub');\nSELECT LAST_INSERT_ID();\nCOMMIT;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204150-aogklar","Type":"NodeParagraph","Properties":{"id":"20220906204150-aogklar","updated":"20220906204150"},"Children":[{"Type":"NodeText","Data":"插入数据这里，我们没有使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"insert into"},{"Type":"NodeText","Data":" 而是使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"replace into"},{"Type":"NodeText","Data":" 来插入数据，具体步骤是这样的：","Properties":{"id":""}}]},{"ID":"20220906204151-de3qtaz","Type":"NodeParagraph","Properties":{"id":"20220906204151-de3qtaz","updated":"20220906204151"},"Children":[{"Type":"NodeText","Data":"1)第一步： 尝试把数据插入到表中。","Properties":{"id":""}}]},{"ID":"20220906204152-j03i0xz","Type":"NodeParagraph","Properties":{"id":"20220906204152-j03i0xz","updated":"20220906204152"},"Children":[{"Type":"NodeText","Data":"2)第二步： 如果主键或唯一索引字段出现重复数据错误而插入失败时，先从表中删除含有重复关键字值的冲突行，然后再次尝试把数据插入到表中。","Properties":{"id":""}}]},{"ID":"20220906204153-lbks41t","Type":"NodeParagraph","Properties":{"id":"20220906204153-lbks41t","updated":"20220906204153"},"Children":[{"Type":"NodeText","Data":"这种方式的优缺点也比较明显：","Properties":{"id":""}}]},{"ID":"20220906204154-7w7a7pt","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204154-7w7a7pt","updated":"20220906204154"},"Children":[{"ID":"20220906204155-6b8olff","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204155-6b8olff","updated":"20220906204155"},"Children":[{"ID":"20220906204156-py14fmj","Type":"NodeParagraph","Properties":{"id":"20220906204156-py14fmj","updated":"20220906204156"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优点"},{"Type":"NodeText","Data":" ：实现起来比较简单、ID 有序递增、存储消耗空间小","Properties":{"id":""}}]}]},{"ID":"20220906204157-u9al2sl","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204157-u9al2sl","updated":"20220906204157"},"Children":[{"ID":"20220906204158-i8rk32r","Type":"NodeParagraph","Properties":{"id":"20220906204158-i8rk32r","updated":"20220906204158"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺点"},{"Type":"NodeText","Data":" ： 支持的并发量不大、存在数据库单点问题（可以使用数据库集群解决，不过增加了复杂度）、ID 没有具体业务含义、安全问题（比如根据订单 ID 的递增规律就能推算出每天的订单量，商业机密啊！ ）、每次获取 ID 都要访问一次数据库（增加了对数据库的压力，获取速度也慢）","Properties":{"id":""}}]}]}]},{"ID":"20220906204159-0i60p46","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204159-0i60p46","updated":"20220906204159"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"数据库号段模式","Properties":{"id":""}}]},{"ID":"20220906204160-ynlaxop","Type":"NodeParagraph","Properties":{"id":"20220906204160-ynlaxop","updated":"20220906204160"},"Children":[{"Type":"NodeText","Data":"数据库主键自增这种模式，每次获取 ID 都要访问一次数据库，ID 需求比较大的时候，肯定是不行的。","Properties":{"id":""}}]},{"ID":"20220906204161-08g1o6n","Type":"NodeParagraph","Properties":{"id":"20220906204161-08g1o6n","updated":"20220906204161"},"Children":[{"Type":"NodeText","Data":"如果我们可以批量获取，然后存在在内存里面，需要用到的时候，直接从内存里面拿就舒服了！这也就是我们说的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"基于数据库的号段模式来生成分布式 ID。"}]},{"ID":"20220906204162-8g6ffit","Type":"NodeParagraph","Properties":{"id":"20220906204162-8g6ffit","updated":"20220906204162"},"Children":[{"Type":"NodeText","Data":"数据库的号段模式也是目前比较主流的一种分布式 ID 生成方式。像滴滴开源的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/didi/tinyid/wiki/tinyid%E5%8E%9F%E7%90%86%E4%BB%8B%E7%BB%8D","TextMarkTextContent":"Tinyid"},{"Type":"NodeText","Data":" 就是基于这种方式来做的。不过，TinyId 使用了双号段缓存、增加多 db 支持等方式来进一步优化。","Properties":{"id":""}}]},{"ID":"20220906204163-2pt8m2n","Type":"NodeParagraph","Properties":{"id":"20220906204163-2pt8m2n","updated":"20220906204163"},"Children":[{"Type":"NodeText","Data":"以 MySQL 举例，我们通过下面的方式即可。","Properties":{"id":""}}]},{"ID":"20220906204164-2mtbkwf","Type":"NodeParagraph","Properties":{"id":"20220906204164-2mtbkwf","updated":"20220906204164"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1.创建一个数据库表。"}]},{"ID":"20220906204165-hrnrm9s","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"c3Fs","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204165-hrnrm9s","updated":"20220906204165"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"CREATE TABLE `sequence_id_generator` (\n  `id` int(10) NOT NULL,\n  `current_max_id` bigint(20) NOT NULL COMMENT '当前最大id',\n  `step` int(10) NOT NULL COMMENT '号段的长度',\n  `version` int(20) NOT NULL COMMENT '版本号',\n  `biz_type`    int(20) NOT NULL COMMENT '业务类型',\n   PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204166-aglvbq5","Type":"NodeParagraph","Properties":{"id":"20220906204166-aglvbq5","updated":"20220906204166"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"current_max_id"},{"Type":"NodeText","Data":" 字段和","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"step"},{"Type":"NodeText","Data":"字段主要用于获取批量 ID，获取的批量 id 为： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"current_max_id ~ current_max_id+step"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID"