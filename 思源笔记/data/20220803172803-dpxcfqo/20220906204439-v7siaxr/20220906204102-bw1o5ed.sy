04216-tnazvbm","updated":"20220906204216"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"优点"},{"Type":"NodeText","Data":" ： 性能不错并且生成的 ID 是有序递增的","Properties":{"id":""}}]}]},{"ID":"20220906204217-b0z8v1w","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204217-b0z8v1w","updated":"20220906204217"},"Children":[{"ID":"20220906204218-1img81c","Type":"NodeParagraph","Properties":{"id":"20220906204218-1img81c","updated":"20220906204218"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺点"},{"Type":"NodeText","Data":" ： 需要解决重复 ID 问题（当机器时间不对的情况下，可能导致会产生重复 ID） 、有安全性问题（ID 生成有规律性）","Properties":{"id":""}}]}]}]},{"ID":"20220906204219-gpu823p","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204219-gpu823p","updated":"20220906204219"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"算法","Properties":{"id":""}}]},{"ID":"20220906204220-ti4awl6","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204220-ti4awl6","updated":"20220906204220"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"UUID","Properties":{"id":""}}]},{"ID":"20220906204221-kgccaqx","Type":"NodeParagraph","Properties":{"id":"20220906204221-kgccaqx","updated":"20220906204221"},"Children":[{"Type":"NodeText","Data":"UUID 是 Universally Unique Identifier（通用唯一标识符） 的缩写。UUID 包含 32 个 16 进制数字（8-4-4-4-12）。","Properties":{"id":""}}]},{"ID":"20220906204222-119l42h","Type":"NodeParagraph","Properties":{"id":"20220906204222-119l42h","updated":"20220906204222"},"Children":[{"Type":"NodeText","Data":"JDK 就提供了现成的生成 UUID 的方法，一行代码就行了。","Properties":{"id":""}}]},{"ID":"20220906204223-yuba6x9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen"