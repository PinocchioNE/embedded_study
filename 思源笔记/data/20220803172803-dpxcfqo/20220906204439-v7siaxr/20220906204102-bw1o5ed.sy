ockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"127.0.0.1:6379\u003e set sequence_id_biz_type 1\nOK\n127.0.0.1:6379\u003e incr sequence_id_biz_type\n(integer) 2\n127.0.0.1:6379\u003e get sequence_id_biz_type\n\"2\"\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204191-lnzp4bn","Type":"NodeParagraph","Properties":{"id":"20220906204191-lnzp4bn","updated":"20220906204191"},"Children":[{"Type":"NodeText","Data":"为了提高可用性和并发，我们可以使用 Redis Cluster。Redis Cluster 是 Redis 官方提供的 Redis 集群解决方案（3.0+版本）。","Properties":{"id":""}}]},{"ID":"20220906204192-fhxrbwa","Type":"NodeParagraph","Properties":{"id":"20220906204192-fhxrbwa","updated":"20220906204192"},"Children":[{"Type":"NodeText","Data":"除了 Redis Cluster 之外，你也可以使用开源的 Redis 集群方案","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/CodisLabs/codis","TextMarkTextContent":"Codis"},{"Type":"NodeText","Data":" （大规模集群比如上百个节点的时候比较推荐）。","Properties":{"id":""}}]},{"ID":"20220906204193-ix5jvn0","Type":"NodeParagraph","Properties":{"id":"20220906204193-ix5jvn0","updated":"20220906204193"},"Children":[{"Type":"NodeText","Data":"除了高可用和并发之外，我们知道 Redis 基于内存，我们需要持久化数据，避免重启机器或者机器故障后数据丢失。Redis 支持两种不同的持久化方式：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"快照（snapshotting，RDB）"},{"Type":"NodeText","Data":"、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"只追加文件（append-only file, AOF）"},{"Type":"NodeText","Data":"。 并且，Redis 4.0 开始支持 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"RDB 和 AOF 的混合持久化"},{"Type":"NodeText","Data":"（默认关闭，可以通过配置项 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextC