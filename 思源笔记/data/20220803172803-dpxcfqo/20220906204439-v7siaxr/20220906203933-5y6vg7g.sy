ties":{"id":"20220906204075-vierks1","updated":"20220906204075"},"Children":[{"Type":"NodeText","Data":"CSMA/CD 协议","Properties":{"id":""}}]}]},{"ID":"20220906204076-ukftvse","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204076-ukftvse","updated":"20220906204076"},"Children":[{"ID":"20220906204077-3y10n8y","Type":"NodeParagraph","Properties":{"id":"20220906204077-3y10n8y","updated":"20220906204077"},"Children":[{"Type":"NodeText","Data":"MAC 协议","Properties":{"id":""}}]}]},{"ID":"20220906204078-4iuqg81","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204078-4iuqg81","updated":"20220906204078"},"Children":[{"ID":"20220906204079-pgce682","Type":"NodeParagraph","Properties":{"id":"20220906204079-pgce682","updated":"20220906204079"},"Children":[{"Type":"NodeText","Data":"以太网技术","Properties":{"id":""}}]}]},{"ID":"20220906204080-duhmapi","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204080-duhmapi","updated":"20220906204080"},"Children":[{"ID":"20220906204081-h2qkx3r","Type":"NodeParagraph","Properties":{"id":"20220906204081-h2qkx3r","updated":"20220906204081"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204082-us6jwd4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204082-us6jwd4","updated":"20220906204082"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么网络要分层？","Properties":{"id":""}}]},{"ID":"20220906204083-ifiq5f6","Type":"NodeParagraph","Properties":{"id":"20220906204083-ifiq5f6","updated":"20220906204083"},"Children":[{"Type":"NodeText","Data":"说到分层，我们先从我们平时使用框架开发一个后台程序来说，我们往往会按照每一层做不同的事情的原则将系统分为三层（复杂的系统分层会更多）:","Properties":{"id":""}}]},{"ID":"20220906204084-47yflc7","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204084-47yflc7","updated":"20220906204084"},"Children":[{"ID":"20220906204085-9x3nfph","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204085-9x3nfph","updated":"20220906204085"},"Children":[{"ID":"20220906204086-hpgljt6","Type":"NodeParagraph","Properties":{"id":"20220906204086-hpgljt6","updated":"20220906204086"},"Children":[{"Type":"NodeText","Data":"Repository（数据库操作）","Properties":{"id":""}}]}]},{"ID":"20220906204087-ry63wmp","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204087-ry63wmp","updated":"20220906204087"},"Children":[{"ID":"20220906204088-iijwah5","Type":"NodeParagraph","Properties":{"id":"20220906204088-iijwah5","updated":"20220906204088"},"Children":[{"Type":"NodeText","Data":"Service（业务操作）","Properties":{"id":""}}]}]},{"ID":"20220906204089-nr8yyfs","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204089-nr8yyfs","updated":"20220906204089"},"Children":[{"ID":"20220906204090-0353uxv","Type":"NodeParagraph","Properties":{"id":"20220906204090-0353uxv","updated":"20220906204090"},"Children":[{"Type":"NodeText","Data":"Controller（前后端数据交互）","Properties":{"id":""}}]}]}]},{"ID":"20220906204091-0fh3xnx","Type":"NodeParagraph","Properties":{"id":"20220906204091-0fh3xnx","updated":"20220906204091"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"复杂的系统需要分层，因为每一层都需要专注于一类事情。网络分层的原因也是一样，每一层只专注于做一类事情。"}]},{"ID":"20220906204092-ak33o92","Type":"NodeParagraph","Properties":{"id":"20220906204092-ak33o92","updated":"20220906204092"},"Children":[{"Type":"NodeText","Data":"好了，再来说回：“为什么网络要分层？”。我觉得主要有 3 方面的原因：","Properties":{"id":""}}]},{"ID":"20220906204093-ez69nrc","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204093-ez69nrc","updated":"20220906204093"},"Children":[{"ID":"20220906204094-jtdgn59","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204094-jtdgn59","updated":"20220906204094"},"Children":[{"ID":"20220906204095-jegsi3h","Type":"NodeParagraph","Properties":{"id":"20220906204095-jegsi3h","updated":"20220906204095"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"各层之间相互独立"},{"Type":"NodeText","Data":"：各层之间相互独立，各层之间不需要关心其他层是如何实现的，只需要知道自己如何调用下层提供好的功能就可以了（可以简单理解为接口调用）","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"。这个和我们对开发时系统进行分层是一个道理。"}]}]},{"ID":"20220906204096-ms0n7q3","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204096-ms0n7q3","updated":"20220906204096"},"Children":[{"ID":"20220906204097-5wy5ub2","Type":"NodeParagraph","Properties":{"id":"20220906204097-5wy5ub2","updated":"20220906204097"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"提高了整体灵活性"},{"Type":"NodeText","Data":" ：每一层都可以使用最适合的技术来实现，你只需要保证你提供的功能以及暴露的接口的规则没有改变就行了。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这个和我们平时开发系统的时候要求的高内聚、低耦合的原则也是可以对应上的。"}]}]},{"ID":"20220906204098-jw7i4ak","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204098-jw7i4ak","updated":"20220906204098"},"Children":[{"ID":"20220906204099-6vo3gj7","Type":"NodeParagraph","Properties":{"id":"20220906204099-6vo3gj7","updated":"20220906204099"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"大问题化小"},{"Type":"NodeText","Data":" ： 分层可以将复杂的网络间题分解为许多比较小的、界线比较清晰简单的小问题来处理和解决。这样使得复杂的计算机网络系统变得易于设计，实现和标准化。 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这个和我们平时开发的时候，一般会将系统功能分解，然后将复杂的问题分解为容易理解的更小的问题是相对应的，这些较小的问题具有更好的边界（目标和接口）定义。"}]}]}]},{"ID":"20220906204100-2uykvg4","Type":"NodeParagraph","Properties":{"id":"20220906204100-2uykvg4","updated":"20220906204100"},"Children":[{"Type":"NodeText","Data":"我想到了计算机世界非常非常有名的一句话，这里分享一下：","Properties":{"id":""}}]},{"ID":"20220906204101-svz1y1f","Type":"NodeBlockquote","Properties":{"id":"20220906204101-svz1y1f","updated":"20220906204101"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204102-57x43ct","Type":"NodeParagraph","Properties":{"id":"20220906204102-57x43ct","updated":"20220906204102"},"Children":[{"Type":"NodeText","Data":"计算机科学领域的任何问题都可以通过增加一个间接的中间层来解决，计算机整个体系从上到下都是按照严格的层次结构设计的。","Properties":{"id":""}}]}]},{"ID":"20220906204103-myg2n1v","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204103-myg2n1v","updated":"20220906204103"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"TCP 与 UDP 的区别（重要）","Properties":{"id":""}}]},{"ID":"20220906204104-db3d7sn","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204104-db3d7sn","updated":"20220906204104"},"Children":[{"ID":"20220906204105-05av8kh","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204105-05av8kh","updated":"20220906204105"},"Children":[{"ID":"20220906204106-gq4y2l7","Type":"NodeParagraph","Properties":{"id":"20220906204106-gq4y2l7","updated":"20220906204106"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"是否面向连接"},{"Type":"NodeText","Data":" ：UDP 在传送数据之前不需要先建立连接。而 TCP 提供面向连接的服务，在传送数据之前必须先建立连接，数据传送结束后要释放连接。","Properties":{"id":""}}]}]},{"ID":"20220906204107-yfucgcq","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204107-yfucgcq","updated":"20220906204107"},"Children":[{"ID":"20220906204108-parsv35","Type":"NodeParagraph","Properties":{"id":"20220906204108-parsv35","updated":"20220906204108"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"是否是可靠传输"},{"Type":"NodeText","Data":"：远地主机在收到 UDP 报文后，不需要给出任何确认，并且不保证数据不丢失，不保证是否顺序到达。TCP 提供可靠的传输服务，TCP 在传递数据之前，会有三次握手来建立连接，而且在数据传递时，有确认、窗口、重传、拥塞控制机制。通过 TCP 连接传输的数据，无差错、不丢失、不重复、并且按序到达。","Properties":{"id":""}}]}]},{"ID":"20220906204109-w2hokjt","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204109-w2hokjt","updated":"20220906204109"},"Children":[{"ID":"20220906204110-mke3qts","Type":"NodeParagraph","Properties":{"id":"20220906204110-mke3qts","updated":"20220906204110"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"是否有状态"},{"Type":"NodeText","Data":" ：这个和上面的“是否可靠传输”相对应。TCP 传输是有状态的，这个有状态说的是 TCP 会去记录自己发送消息的状态比如消息是否发送了、是否被接收了等等。为此 ，TCP 需要维持复杂的连接状态表。而 UDP 是无状态服务，简单来说就是不管发出去之后的事情了（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这很渣男！"},{"Type":"NodeText","Data":"）。","Properties":{"id":""}}]}]},{"ID":"20220906204111-ca9plpd","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204111-ca9plpd","updated":"20220906204111"},"Children":[{"ID":"20220906204112-vqts0xq","Type":"NodeParagraph","Properties":{"id":"20220906204112-vqts0xq","updated":"20220906204112"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"传输效率"},{"Type":"NodeText","Data":" ：由于使用 TCP 进行传输的时候多了连接、确认、重传等机制，所以 TCP 的传输效率要比 UDP 低很多。","Properties":{"id":""}}]}]},{"ID":"20220906204113-bb7fawn","Type":"NodeListItem","Data":"5","ListData":{"Typ":1,"Tight":true,"Start":5,"Delimiter":46,"Padding":3,"Marker":"NQ==","Num":5},"Properties":{"id":"20220906204113-bb7fawn","updated":"20220906204113"},"Children":[{"ID":"20220906204114-udnmnap","Type":"NodeParagraph","Properties":{"id":"20220906204114-udnmnap","updated":"20220906204114"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"传输形式"},{"Type":"NodeText","Data":" ： TCP 是面向字节流的，UDP 是面向报文的。","Properties":{"id":""}}]}]},{"ID":"20220906204115-lci0alt","Type":"NodeListItem","Data":"6","ListData":{"Typ":1,"Tight":true,"Start":6,"Delimiter":46,"Padding":3,"Marker":"Ng==","Num":6},"Properties":{"id":"20220906204115-lci0alt","updated":"20220906204115"},"Children":[{"ID":"20220906204116-p7ckza6","Type":"NodeParagraph","Properties":{"id":"20220906204116-p7ckza6","updated":"20220906204116"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"首部开销"},{"Type":"NodeText","Data":" ：TCP 首部开销（20 ～ 60 字节）比 UDP 首部开销（8 字节）要大。","Properties":{"id":""}}]}]},{"ID":"20220906204117-4xx1nsn","Type":"NodeListItem","Data":"7","ListData":{"Typ":1,"Tight":true,"Start":7,"Delimiter":46,"Padding":3,"Marker":"Nw==","Num":7},"Properties":{"id":"20220906204117-4xx1nsn","updated":"20220906204117"},"Children":[{"ID":"20220906204118-3lltwtw","Type":"NodeParagraph","Properties":{"id":"20220906204118-3lltwtw","updated":"20220906204118"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"是否提供广播或多播服务"},{"Type":"NodeText","Data":" ：TCP 只支持点对点通信，UDP 支持一对一、一对多、多对一、多对多；","Properties":{"id":""}}]}]},{"ID":"20220906204119-qr147mu","Type":"NodeListItem","Data":"8","ListData":{"Typ":1,"Tight":true,"Start":8,"Delimiter":46,"Padding":3,"Marker":"OA==","Num":8},"Properties":{"id":"20220906204119-qr147mu","updated":"20220906204119"},"Children":[{"ID":"20220906204120-so9b9kh","Type":"NodeParagraph","Properties":{"id":"20220906204120-so9b9kh","updated":"20220906204120"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204121-cbkizgn","Type":"NodeParagraph","Properties":{"id":"20220906204121-cbkizgn","updated":"20220906204121"},"Children":[{"Type":"NodeText","Data":"我把上面总结的内容通过表格形式展示出来了！确定不点个赞嘛？","Properties":{"id":""}}]},{"ID":"20220906204122-wj728r9","Type":"NodeTable","Data":"|                        | TCP            | UDP        |\n| ---------------------- | -------------- | ---------- |\n| 是否面向连接           | 是             | 否         |\n| 是否可靠               | 是             | 否         |\n| 是否有状态             | 是             | 否         |\n| 传输效率               | 较慢           | 较快       |\n| 传输形式               | 字节流         | 数据报文段 |\n| 首部开销               | 20 ～ 60 bytes | 8 bytes    |\n| 是否提供广播或多播服务 | 否             | 是         |","TableAligns":[0,0,0],"Properties":{"id":"20220906204122-wj728r9","updated":"20220906204122"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":{"id":""}},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"TCP","Properties":{"id":""}}]},{"Type":"NodeTableCell","Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"UDP","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0,0],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","Properties":