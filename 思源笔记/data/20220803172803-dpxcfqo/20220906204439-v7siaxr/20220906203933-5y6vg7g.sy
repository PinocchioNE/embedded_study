觉区别也不大。","Properties":{"id":""}}]}]},{"ID":"20220906204127-66oe7qn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204127-66oe7qn","updated":"20220906204127"},"Children":[{"ID":"20220906204128-bjd1zor","Type":"NodeParagraph","Properties":{"id":"20220906204128-bjd1zor","updated":"20220906204128"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"TCP 用于对传输准确性要求特别高的场景"},{"Type":"NodeText","Data":"，比如文件传输、发送和接收邮件、远程登录等等。","Properties":{"id":""}}]}]}]},{"ID":"20220906204129-hxk4gho","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204129-hxk4gho","updated":"20220906204129"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"使用 TCP 的协议有哪些?使用 UDP 的协议有哪些?","Properties":{"id":""}}]},{"ID":"20220906204130-fhdgge7","Type":"NodeParagraph","Properties":{"id":"20220906204130-fhdgge7","updated":"20220906204130"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"运行于 TCP 协议之上的协议"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204131-gu7hj64","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204131-gu7hj64","updated":"20220906204131"},"Children":[{"ID":"20220906204132-6jnsqc3","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204132-6jnsqc3","updated":"20220906204132"},"Children":[{"ID":"20220906204133-n2562si","Type":"NodeParagraph","Properties":{"id":"20220906204133-n2562si","updated":"20220906204133"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"HTTP 协议"},{"Type":"NodeText","Data":" ：超文本传输协议（HTTP，HyperText Transfer Protocol)主要是为 Web 浏览器与 Web 服务器之间的通信而设计的。当我们使用浏览器浏览网页的时候，我们网页就是通过 HTTP 请求进行加载的。","Properties":{"id":""}}]}]},{"ID":"20220906204134-f636xcq","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204134-f636xcq","updated":"20220906204134"},"Children":[{"ID":"20220906204135-nwmrwyu","Type":"NodeParagraph","Properties":{"id":"20220906204135-nwmrwyu","updated":"20220906204135"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"HTTPS 协议"},{"Type":"NodeText","Data":" ：更安全的超文本传输协议(HTTPS,Hypertext Transfer Protocol Secure)，身披 SSL 外衣的 HTTP 协议","Properties":{"id":""}}]}]},{"ID":"20220906204136-uqjsqdt","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204136-uqjsqdt","updated":"20220906204136"},"Children":[{"ID":"20220906204137-spfblk9","Type":"NodeParagraph","Properties":{"id":"20220906204137-spfblk9","updated":"20220906204137"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"FTP 协议"},{"Type":"NodeText","Data":"：文件传输协议 FTP（File Transfer Protocol），提供文件传输服务，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"基于 TCP"},{"Type":"NodeText","Data":" 实现可靠的传输。使用 FTP 传输文件的好处是可以屏蔽操作系统和文件存储方式。","Properties":{"id":""}}]}]},{"ID":"20220906204138-h651ojb","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204138-h651ojb","updated":"20220906204138"},"Children":[{"ID":"20220906204139-jrl4zex","Type":"NodeParagraph","Properties":{"id":"20220906204139-jrl4zex","updated":"20220906204139"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"SMTP 协议"},{"Type":"NodeText","Data":"：简单邮件传输协议（SMTP，Simple Mail Transfer Protocol）的缩写，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"基于 TCP 协议"},{"Type":"NodeText","Data":"，用来发送电子邮件。注意 ⚠️：接受邮件的协议不是 SMTP 而是 POP3 协议。","Properties":{"id":""}}]}]},{"ID":"20220906204140-q7tncge","Type":"NodeListItem","Data":"5","ListData":{"Typ":1,"Tight":true,"Start":5,"Delimiter":46,"Padding":3,"Marker":"NQ==","Num":5},"Properties":{"id":"20220906204140-q7tncge","updated":"20220906204140"},"Children":[{"ID":"20220906204141-meletfn","Type":"NodeParagraph","Properties":{"id":"20220906204141-meletfn","updated":"20220906204141"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"POP3/IMAP 协议"},{"Type":"NodeText","Data":"： POP3 和 IMAP 两者都是负责邮件接收的协议。","Properties":{"id":""}}]}]},{"ID":"20220906204142-j28rjbg","Type":"NodeListItem","Data":"6","ListData":{"Typ":1,"Tight":true,"Start":6,"Delimiter":46,"Padding":3,"Marker":"Ng==","Num":6},"Properties":{"id":"20220906204142-j28rjbg","updated":"20220906204142"},"Children":[{"ID":"20220906204143-0q631lj","Type":"NodeParagraph","Properties":{"id":"20220906204143-0q631lj","updated":"20220906204143"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Telent 协议"},{"Type":"NodeText","Data":"：远程登陆协议，通过一个终端登陆到其他服务器。被一种称为 SSH 的非常安全的协议所取代。","Properties":{"id":""}}]}]},{"ID":"20220906204144-ar7lo47","Type":"NodeListItem","Data":"7","ListData":{"Typ":1,"Tight":true,"Start":7,"Delimiter":46,"Padding":3,"Marker":"Nw==","Num":7},"Properties":{"id":"20220906204144-ar7lo47","updated":"20220906204144"},"Children":[{"ID":"20220906204145-x55w4ny","Type":"NodeParagraph","Properties":{"id":"20220906204145-x55w4ny","updated":"20220906204145"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"SSH 协议"},{"Type":"NodeText","Data":" : SSH（ Secure Shell）是目前较可靠，专为远程登录会话和其他网络服务提供安全性的协议。利用 SSH 协议可以有效防止远程管理过程中的信息泄露问题。SSH 建立在可靠的传输协议 TCP 之上。","Properties":{"id":""}}]}]},{"ID":"20220906204146-9kkcbbv","Type":"NodeListItem","Data":"8","ListData":{"Typ":1,"Tight":true,"Start":8,"Delimiter":46,"Padding":3,"Marker":"OA==","Num":8},"Properties":{"id":"20220906204146-9kkcbbv","updated":"20220906204146"},"Children":[{"ID":"20220906204147-kaxo8dx","Type":"NodeParagraph","Properties":{"id":"20220906204147-kaxo8dx","updated":"20220906204147"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906204148-uzgiljl","Type":"NodeParagraph","Properties":{"id":"20220906204148-uzgiljl","updated":"20220906204148"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"运行于 UDP 协议之上的协议"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204149-jusjori","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204149-jusjori","updated":"20220906204149"},"Children":[{"ID":"20220906204150-xvvv9fq","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204150-xvvv9fq","updated":"20220906204150"},"Children":[{"ID":"20220906204151-3ert2jv","Type":"NodeParagraph","Properties":{"id":"20220906204151-3ert2jv","updated":"20220906204151"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"DHCP 协议"},{"Type":"NodeText","Data":"：动态主机配置协议，动态配置 IP 地址","Properties":{"id":""}}]}]},{"ID":"20220906204152-88iak6a","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204152-88iak6a","updated":"20220906204152"},"Children":[{"ID":"20220906204153-7oox9pt","Type":"NodeParagraph","Properties":{"id":"20220906204153-7oox9pt","updated":"20220906204153"},"Child