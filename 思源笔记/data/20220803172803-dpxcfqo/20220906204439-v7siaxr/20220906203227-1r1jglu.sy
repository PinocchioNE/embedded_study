eTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"switch"},{"Type":"NodeText","Data":" 中匹配不到任何情况时，可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"default"},{"Type":"NodeText","Data":" 来编写默认匹配的情况。","Properties":{"id":""}}]}]},{"ID":"20220906203326-8r1soh2","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203326-8r1soh2","updated":"20220906203326"},"Children":[{"ID":"20220906203327-45pvdov","Type":"NodeParagraph","Properties":{"id":"20220906203327-45pvdov","updated":"20220906203327"},"Children":[{"Type":"NodeText","Data":"在类，方法和变量修饰符中，从 JDK8 开始引入了默认方法，可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"default"},{"Type":"NodeText","Data":" 关键字来定义一个方法的默认实现。","Properties":{"id":""}}]}]},{"ID":"20220906203328-r7hda58","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203328-r7hda58","updated":"20220906203328"},"Children":[{"ID":"20220906203329-22jj4dw","Type":"NodeParagraph","Properties":{"id":"20220906203329-22jj4dw","updated":"20220906203329"},"Children":[{"Type":"NodeText","Data":"在访问控制中，如果一个方法前没有任何修饰符，则默认会有一个修饰符 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"default"},{"Type":"NodeText","Data":"，但是这个修饰符加上了就会报错。","Properties":{"id":""}}]}]}]}]},{"ID":"20220906203330-p2kx6uj","Type":"NodeParagraph","Properties":{"id":"20220906203330-p2kx6uj","updated":"20220906203330"},"Children":[{"Type":"NodeText","Data":"⚠️ 注意 ：虽然 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"true"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"false"},{"Type":"NodeText","Data":", 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"null"},{"Type":"NodeText","Data":" 看起来像关键字但实际上他们是字面值，同时你也不可以作为标识符来使用。","Properties":{"id":""}}]},{"ID":"20220906203331-y7lll2y","Type":"NodeParagraph","Properties":{"id":"20220906203331-y7lll2y","updated":"20220906203331"},"Children":[{"Type":"NodeText","Data":"官方文档：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://docs.oracle.com/javase/tutorial/java/nutsandbolts/_keywords.html","TextMarkTextContent":"https://docs.oracle.com/javase/tutorial/java/nutsandbolts/_keywords.html"}]},{"ID":"20220906203332-1ucetza","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203332-1ucetza","updated":"20220906203332"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"自增自减运算符","Properties":{"id":""}}]},{"ID":"20220906203333-7y7t7sh","Type":"NodeParagraph","Properties":{"id":"20220906203333-7y7t7sh","updated":"20220906203333"},"Children":[{"Type":"NodeText","Data":"在写代码的过程中，常见的一种情况是需要某个整数类型变量增加 1 或减少 1，Java 提供了一种特殊的运算符，用于这种表达式，叫做自增运算符（++)和自减运算符（--）。","Properties":{"id":""}}]},{"ID":"20220906203334-6xtqkdh","Type":"NodeParagraph","Properties":{"id":"20220906203334-6xtqkdh","updated":"20220906203334"},"Children":[{"Type":"NodeText","Data":"++ 和 -- 运算符可以放在变量之前，也可以放在变量之后，当运算符放在变量之前时(前缀)，先自增/减，再赋值；当运算符放在变量之后时(后缀)，先赋值，再自增/减。例如，当 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"b = ++a"},{"Type":"NodeText","Data":" 时，先自增（自己增加 1），再赋值（赋值给 b）；当 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"b = a++"},{"Type":"NodeText","Data":" 时，先赋值(赋值给 b)，再自增（自己增加 1）。也就是，++a 输出的是 a+1 的值，a++输出的是 a 值。用一句口诀就是：“符号在前就先加/减，符号在后就后加/减”。","Properties":{"id":""}}]},{"ID":"20220906203335-34xl055","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203335-34xl055","updated":"20220906203335"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"成员变量与局部变量的区别？","Properties":{"id":""}}]},{"ID":"20220906203336-fjpp8a8","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203336-fjpp8a8","updated":"20220906203336"},"Children":[{"ID":"20220906203337-844n8qi","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203337-844n8qi","updated":"20220906203337"},"Children":[{"ID":"20220906203338-9jfekbn","Type":"NodeParagraph","Properties":{"id":"20220906203338-9jfekbn","updated":"20220906203338"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"语法形式"},{"Type":"NodeText","Data":" ：从语法形式上看，成员变量是属于类的，而局部变量是在代码块或方法中定义的变量或是方法的参数；成员变量可以被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"public"},{"Type":"NodeText","Data":",","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"private"},{"Type":"NodeText","Data":",","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 等修饰符所修饰，而局部变量不能被访问控制修饰符及 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 所修饰；但是，成员变量和局部变量都能被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"final"},{"Type":"NodeText","Data":" 所修饰。","Properties":{"id":""}}]}]},{"ID":"20220906203339-0klwbco","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203339-0klwbco","updated":"20220906203339"},"Children":[{"ID":"20220906203340-0fj683y","Type":"NodeParagraph","Properties":{"id":"20220906203340-0fj683y","updated":"20220906203340"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"存储方式"},{"Type":"NodeText","Data":" ：从变量在内存中的存储方式来看,如果成员变量是使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 修饰的，那么这个成员变量是属于类的，如果没有使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 修饰，这个成员变量是属于实例的。而对象存在于堆内存，局部变量则存在于栈内存。","Properties":{"id":""}}]}]},{"ID":"20220906203341-ukyucvq","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203341-ukyucvq","updated":"20220906203341"},"Children":[{"ID":"20220906203342-fbla8mz","Type":"NodeParagraph","Properties":{"id":"20220906203342-fbla8mz","updated":"20220906203342"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"生存时间"},{"Type":"NodeText","Data":" ：从变量在内存中的生存时间上看，成员变量是对象的一部分，它随着对象的创建而存在，而局部变量随着方法的调用而自动生成，随着方法的调用结束而消亡。","Properties":{"id":""}}]}]},{"ID":"20220906203343-91t7rqa","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203343-91t7rqa","updated":"20220906203343"},"Children":[{"ID":"20220906203344-d18ec8h","Type":"NodeParagraph","Properties":{"id":"20220906203344-d18ec8h","updated":"20220906203344"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"默认值"},{"Type":"NodeText","Data":" ：从变量是否有默认值来看，成员变量如果没有被赋初始值，则会自动以类型的默认值而赋值（一种情况例外:被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"final"},{"Type":"NodeText","Data":" 修饰的成员变量也必须显式地赋值），而局部变量则不会自动赋值。","Properties":{"id":""}}]}]}]},{"ID":"20220906203345-tkxqlxb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203345-tkxqlxb","updated":"20220906203345"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"静态变量有什么作用？","Properties":{"id":""}}]},{"ID":"20220906203346-ue9ohv7","Type":"NodeParagraph","Properties":{"id":"20220906203346-ue9ohv7","updated":"20220906203346"},"Children":[{"Type":"NodeText","Data":"静态变量可以被类的所有实例共享。无论一个类创建了多少个对象，它们都共享同一份静态变量。","Properties":{"id":""}}]},{"ID":"20220906203347-6e4wjxh","Type":"NodeParagraph","Properties":{"id":"20220906203347-6e4wjxh","updated":"20220906203347"},"Children":[{"Type":"NodeText","Data":"通常情况下，静态变量会被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"final"},{"Type":"NodeText","Data":" 关键字修饰成为常量。","Properties":{"id":""}}]},{"ID":"20220906203348-3a5vtyf","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203348-3a5vtyf","updated":"20220906203348"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"字符型常量和字符串常量的区别?","Properties":{"id":""}}]},{"ID":"20220906203349-5c2bzmn","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203349-5c2bzmn","updated":"20220906203349"},"Children":[{"ID":"20220906203350-0r5w5ka","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203350-0r5w5ka","updated":"20220906203350"},"Children":[{"ID":"20220906203351-y006wy5","Type":"NodeParagraph","Properties":{"id":"20220906203351-y006wy5","updated":"20220906203351"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"形式"},{"Type":"NodeText","Data":" : 字符常量是单引号引起的一个字符，字符串常量是双引号引起的 0 个或若干个字符。","Properties":{"id":""}}]}]},{"ID":"20220906203352-v7od75d","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203352-v7od75d","updated":"20220906203352"},"Children":[{"ID":"20220906203353-zxkq4ax","Type":"NodeParagraph","Properties":{"id":"20220906203353-zxkq4ax","updated":"20220906203353"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"含义"},{"Type":"NodeText","Data":" : 字符常量相当于一个整型值( ASCII 值),可以参加表达式运算; 字符串常量代表一个地址值(该字符串在内存中存放位置)。","Properties":{"id":""}}]}]},{"ID":"20220906203354-jh7rpo1","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203354-jh7rpo1","updated":"20220906203354"},"Children":[{"ID":"20220906203355-5yv6idf","Type":"NodeParagraph","Properties":{"id":"20220906203355-5yv6idf","updated":"20220906203355"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"占内存大小"},{"Type":"NodeText","Data":" ： 字符常量只占 2 个字节; 字符串常量占若干个字节。","Properties":{"id":""}}]}]}]},{"ID":"20220906203356-sbw5zx7","Type":"NodeParagraph","Properties":{"id":"20220906203356-sbw5zx7","updated":"20220906203356"},"Children":[{"Type":"NodeText","Data":"(","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"注意： "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"char"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 在 Java 中占两个字节"},{"Type":"NodeText","Data":")","Properties":{"id":""}}]},{"ID":"20220906203357-54exj1m","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203357-54exj1m","updated":"20220906203357"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"静态方法和实例方法有何不同？","Properties":{"id":""}}]},{"ID":"20220906203358-e7fqwmk","Type":"NodeParagraph","Properties":{"id":"20220906203358-e7fqwmk","updated":"20220906203358"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1、调用方式"}]},{"ID":"20220906203359-scxv75z","Type":"NodeParagraph","Properties":{"id":"20220906203359-scxv75z","updated":"20220906203359"},"Children":[{"Type":"NodeText","Data":"在外部调用静态方法时，可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"类名.方法名"},{"Type":"NodeText","Data":" 的方式，也可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"对象.方法名"},{"Type":"NodeText","Data":" 的方式，而实例方法只有后面这种方式。也就是说，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"调用静态方法可以无需创建对象"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906203360-cfctkc0","Type":"NodeParagraph","Properties":{"id":"20220906203360-cfctkc0","updated":"20220906203360"},"Children":[{"Type":"NodeText","Data":"不过，需要注意的是一般不建议使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"对象.方法名"},{"Type":"NodeText","Data":" 的方式来调用静态方法。这种方式非常容易造成混淆，静态方法不属于类的某个对象而是属于这个类。","Properties":{"id":""}}]},{"ID":"20220906203361-wyjq2a7","Type":"NodeParagraph","Properties":{"id":"20220906203361-wyjq2a7","updated":"20220906203361"},"Children":[{"Type":"NodeText","Data":"因此，一般建议使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"类名.方法名"},{"Type":"NodeText","Data":" 的方式来调用静态方法。","Properties":{"id":""}}]},{"ID":"20220906203362-1dvzy93","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203362-1dvzy93","updated":"20220906203362"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class Person {\n    public void method() {\n      //......\n    }\n\n    public static void staicMethod(){\n      //......\n    }\n    public static void main(String[] args) {\n        Person person = new Person();\n        // 调用实例方法\n        person.method();\n        // 调用静态方法\n        Person.staicMethod()\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203363-moe6sva","Type":"NodeParagraph","Properties":{"id":"20220906203363-moe6sva","updated":"20220906203363"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2、访问类成员是否存在限制"}]},{"ID":"20220906203364-5runub3","Type":"NodeParagraph","Properties":{"id":"20220906203364-5runub3","updated":"20220906203364"},"Children":[{"Type":"NodeText","Data":"静态方法在访问本类的成员时，只允许访问静态成员（即静态成员变量和静态方法），不允许访问实例成员（即实例成员变量和实例方法），而实例方法不存在这个限制。","Properties":{"id":""}}]},{"ID":"20220906203365-dumc8f0","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203365-dumc8f0","updated":"20220906203365"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"重载和重写有什么区别？","Properties":{"id":""}}]},{"ID":"20220906203366-ntse0mb","Type":"NodeBlockquote","Properties":{"id":"20220906203366-ntse0mb","updated":"20220906203366"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203367-3nhyfoa","Type":"NodeParagraph","Properties":{"id":"20220906203367-3nhyfoa","updated":"20220906203367"},"Children":[{"Type":"NodeText","Data":"重载就是同样的一个方法能够根据输入数据的不同，做出不同的处理","Properties":{"id":""}}]},{"ID":"20220906203368-tuaaark","Type":"NodeParagraph","Properties":{"id":"20220906203368-tuaaark","updated":"20220906203368"},"Children":[{"Type":"NodeText","Data":"重写就是当子类继承自父类的相同方法，输入数据一样，但要做出有别于父类的响应时，你就要覆盖父类方法","Properties":{"id":""}}]}]},{"ID":"20220906203369-674zpli","Type":"NodeParagraph","Properties":{"id":"20220906203369-674zpli","updated":"20220906203369"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"重载"}]},{"ID":"20220906203370-9bbqran","Type":"NodeParagraph","Properties":{"id":"20220906203370-9bbqran","updated":"20220906203370"},"Children":[{"Type":"NodeText","Data":"发生在同一个类中（或者父类和子类之间），方法名必须相同，参数类型不同、个数不同、顺序不同，方法返回值和访问修饰符可以不同。","Properties":{"id":""}}]},{"ID":"20220906203371-zfsqzpr","Type":"NodeParagraph","Properties":{"id":"20220906203371-zfsqzpr","updated":"20220906203371"},"Children":[{"Type":"NodeText","Data":"《Java 核心技术》这本书是这样介绍重载的：","Properties":{"id":""}}]},{"ID":"20220906203372-6y3b8mr","Type":"NodeBlockquote","Properties":{"id":"20220906203372-6y3b8mr","updated":"20220906203372"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203373-lh84eyr","Type":"NodeParagraph","Properties":{"id":"20220906203373-lh84eyr","updated":"20220906203373"},"Children":[{"Type":"NodeText","Data":"如果多个方法(比如 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"StringBuilder"},{"Type":"NodeText","Data":" 的构造方法)有相同的名字、不同的参数， 便产生了重载。","Properties":{"id":""}}]},{"ID":"20220906203374-tle64w2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203374-tle64w2","updated":"20220906203374"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"StringBuilder sb = new StringBuilder();\nStringBuilder sb2 = new StringBuilder(\"HelloWorld\");\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203375-il5tl07","Type":"NodeParagraph","Properties":{"id":"20220906203375-il5tl07","updated":"20220906203375"},"Children":[{"Type":"NodeText","Data":"编译器必须挑选出具体执行哪个方法，它通过用各个方法给出的参数类型与特定方法调用所使用的值类型进行匹配来挑选出相应的方法。 如果编译器找不到匹配的参数， 就会产生编译时错误， 因为根本不存在匹配， 或者没有一个比其他的更好(这个过程被称为重载解析(overloading resolution))。","Properties":{"id":""}}]},{"ID":"20220906203376-xogodge","Type":"NodeParagraph","Properties":{"id":"20220906203376-xogodge","updated":"20220906203376"},"Children":[{"Type":"NodeText","Data":"Java 允许重载任何方法， 而不只是构造器方法。","Properties":{"id":""}}]}]},{"ID":"20220906203377-v20yzsm","Type":"NodeParagraph","Properties":{"id":"20220906203377-v20yzsm","updated":"20220906203377"},"Children":[{"Type":"NodeText","Data":"综上：重载就是同一个类中多个同名方法根据不同的传参来执行不同的逻辑处理。","Properties":{"id":""}}]},{"ID":"20220906203378-vvijyqu","Type":"NodeParagraph","Properties":{"id":"20220906203378-vvijyqu","updated":"20220906203378"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"重写"}]},{"ID":"20220906203379-lykblhx","Type":"NodeParagraph","Properties":{"id":"20220906203379-lykblhx","updated":"20220906203379"},"Children":[{"Type":"NodeText","Data":"重写发生在运行期，是子类对父类的允许访问的方法的实现过程进行重新编写。","Properties":{"id":""}}]},{"ID":"20220906203380-sigs04e","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203380-sigs04e","updated":"20220906203380"},"Children":[{"ID":"20220906203381-adrkux4","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203381-adrkux4","updated":"20220906203381"},"Children":[{"ID":"20220906203382-9lxv73f","Type":"NodeParagraph","Properties":{"id":"20220906203382-9lxv73f","updated":"20220906203382"},"Children":[{"Type":"NodeText","Data":"方法名、参数列表必须相同，子类方法返回值类型应比父类方法返回值类型更小或相等，抛出的异常范围小于等于父类，访问修饰符范围大于等于父类。","Properties":{"id":""}}]}]},{"ID":"20220906203383-aoit8d9","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203383-aoit8d9","updated":"20220906203383"},"Children":[{"ID":"20220906203384-j97slcw","Type":"NodeParagraph","Properties":{"id":"20220906203384-j97slcw","updated":"20220906203384"},"Children":[{"Type":"NodeText","Data":"如果父类方法访问修饰符为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"private/final/static"},{"Type":"NodeText","Data":" 则子类就不能重写该方法，但是被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 修饰的方法能够被再次声明。","Properties":{"id":""}}]}]},{"ID":"20220906203385-ixr8xv1","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203385-ixr8xv1","updated":"20220906203385"},"Children":[{"ID":"20220906203386-y6cwzhm","Type":"NodeParagraph","Properties":{"id":"20220906203386-y6cwzhm","updated":"20220906203386"},"Children":[{"Type":"NodeText","Data":"构造方法无法被重写","Properties":{"id":""}}]}]}]},{"ID":"20220906203387-kkcdxzp","Type":"NodeParagraph","Properties":{"id":"20220906203387-kkcdxzp","updated":"20220906203387"},"Children":[{"Type":"NodeText","Data":"综上：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"重写就是子类对父类方法的重新改造，外部样子不能改变，内部逻辑可以改变。"}]},{"ID":"20220906203388-zj416w5","Type":"NodeTable","Data":"| 区别点     | 重载方法 | 重写方法                                                     |\n| :--------- | :------- | :----------------------------------------------------------- |\n| 发生范围   | 同一个类 | 子类                                                         |\n| 参数列表   | 必须修改 | 一定不能修改                                                 |\n| 返回类型   | 可修改   | 子类方法返回值类型应比父类方法返回值类型更小或相等           |\n| 异常       | 可修改   | 子类方法声明抛出的异常类应比父类方法声明抛出的异常类更小或相等； |\n| 访问修饰符 | 可修改   | 一定不能做更严格的限制（可以降低限制）                       |\n| 发生阶段   | 编译期   | 运行期                                                       |","TableAligns":[1,1,1],"Properties":{"id":"20220906203388-zj416w5","updated":"20220906203388"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"区别点","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"重载方法","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"重写方法","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"发生范围","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"同一个类","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"子类","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"参数列表","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"必须修改","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"一定不能修改","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"返回类型","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"可修改","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"子类方法返回值类型应比父类方法返回值类型更小或相等","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"异常","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"可修改","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"子类方法声明抛出的异常类应比父类方法声明抛出的异常类更小或相等；","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"访问修饰符","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"可修改","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"一定不能做更严格的限制（可以降低限制）","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,1,1],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"发生阶段","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"编译期","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"运行期","Properties":{"id":""}}]}]}]},{"ID":"20220906203389-410q6ed","Type":"NodeParagraph","Properties":{"id":"20220906203389-410q6ed","updated":"20220906203389"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"方法的重写要遵循“两同两小一大”"},{"Type":"NodeText","Data":"（以下内容摘录自《疯狂 Java 讲义》，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Snailclimb/JavaGuide/issues/892","TextMarkTextContent":"issue#892"},{"Type":"NodeText","Data":" ）：","Properties":{"id":""}}]},{"ID":"20220906203390-732b9g4","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203390-732b9g4","updated":"20220906203390"},"Children":[{"ID":"20220906203391-816w60d","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203391-816w60d","updated":"20220906203391"},"Children":[{"ID":"20220906203392-4zkyixz","Type":"NodeParagraph","Properties":{"id":"20220906203392-4zkyixz","updated":"20220906203392"},"Children":[{"Type":"NodeText","Data":"“两同”即方法名相同、形参列表相同；","Properties":{"id":""}}]}]},{"ID":"20220906203393-bdw4mob","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203393-bdw4mob","updated":"20220906203393"},"Children":[{"ID":"20220906203394-1rb1zwf","Type":"NodeParagraph","Properties":{"id":"20220906203394-1rb1zwf","updated":"20220906203394"},"Children":[{"Type":"NodeText","Data":"“两小”指的是子类方法返回值类型应比父类方法返回值类型更小或相等，子类方法声明抛出的异常类应比父类方法声明抛出的异常类更小或相等；","Properties":{"id":""}}]}]},{"ID":"20220906203395-67m43x6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203395-67m43x6","updated":"20220906203395"},"Children":[{"ID":"20220906203396-l6v9ef6","Type":"NodeParagraph","Properties":{"id":"20220906203396-l6v9ef6","updated":"20220906203396"},"Children":[{"Type":"NodeText","Data":"“一大”指的是子类方法的访问权限应比父类方法的访问权限更大或相等。","Properties":{"id":""}}]}]}]},{"ID":"20220906203397-65dr0u0","Type":"NodeParagraph","Properties":{"id":"20220906203397-65dr0u0","updated":"20220906203397"},"Children":[{"Type":"NodeText","Data":"⭐️ 关于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"重写的返回值类型"},{"Type":"NodeText","Data":" 这里需要额外多说明一下，上面的表述不太清晰准确：如果方法的返回类型是 void 和基本数据类型，则返回值重写时不可修改。但是如果方法的返回值是引用类型，重写时是可以返回该引用类型的子类的。","Properties":{"id":""}}]},{"ID":"20220906203398-azwik92","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203398-azwik92","updated":"20220906203398"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class Hero {\n    public String name() {\n        return \"超级英雄\";\n    }\n}\npublic class SuperMan extends Hero{\n    @Override\n    public String name() {\n        return \"超人\";\n    }\n    public Hero hero() {\n        return new Hero();\n    }\n}\n\npublic class SuperSuperMan extends SuperMan {\n    public String name() {\n        return \"超级超级英雄\";\n    }\n\n    @Override\n    public SuperMan hero() {\n        return new SuperMan();\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203399-nxuh9qb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203399-nxuh9qb","updated":"20220906203399"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是可变长参数？","Properties":{"id":""}}]},{"ID":"20220906203400-awvy11o","Type":"NodeParagraph","Properties":{"id":"20220906203400-awvy11o","updated":"20220906203400"},"Children":[{"Type":"NodeText","Data":"从 Java5 开始，Java 支持定义可变长参数，所谓可变长参数就是允许在调用方法时传入不定长度的参数。就比如下面的这个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"printVariable"},{"Type":"NodeText","Data":" 方法就可以接受 0 个或者多个参数。","Properties":{"id":""}}]},{"ID":"20220906203401-xklrjul","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203401-xklrjul","updated":"20220906203401"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public static void method1(String... args) {\n   //......\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203402-wfaaop6","Type":"NodeParagraph","Properties":{"id":"20220906203402-wfaaop6","updated":"20220906203402"},"Children":[{"Type":"NodeText","Data":"另外，可变参数只能作为函数的最后一个参数，但其前面可以有也可以没有任何其他参数。","Properties":{"id":""}}]},{"ID":"20220906203403-87ldd62","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203403-87ldd62","updated":"20220906203403"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public static void method2(String arg1, String... args) {\n   //......\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203404-tiq3g9l","Type":"NodeParagraph","Properties":{"id":"20220906203404-tiq3g9l","updated":"20220906203404"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"遇到方法重载的情况怎么办呢？会优先匹配固定参数还是可变参数的方法呢？"}]},{"ID":"20220906203405-m7htqmt","Type":"NodeParagraph","Properties":{"id":"20220906203405-m7htqmt","updated":"20220906203405"},"Children":[{"Type":"NodeText","Data":"答案是会优先匹配固定参数的方法，因为固定参数的方法匹配度更高。","Properties":{"id":""}}]},{"ID":"20220906203406-e6ktyk3","Type":"NodeParagraph","Properties":{"id":"20220906203406-e6ktyk3","updated":"20220906203406"},"Children":[{"Type":"NodeText","Data":"我们通过下面这个例子来证明一下。","Properties":{"id":""}}]},{"ID":"20220906203407-5ycr0ht","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203407-5ycr0ht","updated":"20220906203407"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"/**\n * 微信搜 JavaGuide 回复\"面试突击\"即可免费领取个人原创的 Java 面试手册\n *\n * @author Guide哥\n * @date 2021/12/13 16:52\n **/\npublic class VariableLengthArgument {\n\n    public static void printVariable(String... args) {\n        for (String s : args) {\n            System.out.println(s);\n        }\n    }\n\n    public static void printVariable(String arg1, String arg2) {\n        System.out.println(arg1 + arg2);\n    }\n\n    public static void main(String[] args) {\n        printVariable(\"a\", \"b\");\n        printVariable(\"a\", \"b\", \"c\", \"d\");\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203408-w9i62rz","Type":"NodeParagraph","Properties":{"id":"20220906203408-w9i62rz","updated":"20220906203408"},"Children":[{"Type":"NodeText","Data":"输出：","Properties":{"id":""}}]},{"ID":"20220906203409-oqlryta","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203409-oqlryta","updated":"20220906203409"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"ab\na\nb\nc\nd\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203410-e4y8c2c","Type":"NodeParagraph","Properties":{"id":"20220906203410-e4y8c2c","updated":"20220906203410"},"Children":[{"Type":"NodeText","Data":"另外，Java 的可变参数编译后实际会被转换成一个数组，我们看编译后生成的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"class"},{"Type":"NodeText","Data":"文件就可以看出来了。","Properties":{"id":""}}]},{"ID":"20220906203411-ymht9wn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203411-ymht9wn","updated":"20220906203411"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class V