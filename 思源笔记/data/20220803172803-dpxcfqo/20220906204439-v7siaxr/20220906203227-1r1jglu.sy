extMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-with-resources"},{"Type":"NodeText","Data":"语句让我们更容易编写必须要关闭的资源的代码，若采用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-finally"},{"Type":"NodeText","Data":"则几乎做不到这点。","Properties":{"id":""}}]}]},{"ID":"20220906203858-19a4a4y","Type":"NodeParagraph","Properties":{"id":"20220906203858-19a4a4y","updated":"20220906203858"},"Children":[{"Type":"NodeText","Data":"Java 中类似于","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"InputStream"},{"Type":"NodeText","Data":"、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"OutputStream"},{"Type":"NodeText","Data":" 、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Scanner"},{"Type":"NodeText","Data":" 、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"PrintWriter"},{"Type":"NodeText","Data":"等的资源都需要我们调用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"close()"},{"Type":"NodeText","Data":"方法来手动关闭，一般情况下我们都是通过","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-catch-finally"},{"Type":"NodeText","Data":"语句来实现这个需求，如下：","Properties":{"id":""}}]},{"ID":"20220906203859-y77soax","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203859-y77soax","updated":"20220906203859"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"//读取文本文件的内容\nScanner scanner = null;\ntry {\n    scanner = new Scanner(new File(\"D://read.txt\"));\n    while (scanner.hasNext()) {\n        System.out.println(scanner.nextLine());\n    }\n} catch (FileNotFoundException e) {\n    e.printStackTrace();\n} finally {\n    if (scanner != null) {\n        scanner.close();\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203860-j5a4uqm","Type":"NodeParagraph","Properties":{"id":"20220906203860-j5a4uqm","updated":"20220906203860"},"Children":[{"Type":"NodeText","Data":"使用 Java 7 之后的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-with-resources"},{"Type":"NodeText","Data":" 语句改造上面的代码:","Properties":{"id":""}}]},{"ID":"20220906203861-3ehla65","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203861-3ehla65","updated":"20220906203861"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"try (Scanner scanner = new Scanner(new File(\"test.txt\"))) {\n    while (scanner.hasNext()) {\n        System.out.println(scanner.nextLine());\n    }\n} catch (FileNotFoundException fnfe) {\n    fnfe.printStackTrace();\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203862-8x0sbk6","Type":"NodeParagraph","Properties":{"id":"20220906203862-8x0sbk6","updated":"20220906203862"},"Children":[{"Type":"NodeText","Data":"当然多个资源需要关闭的时候，使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-with-resources"},{"Type":"NodeText","Data":" 实现起来也非常简单，如果你还是用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-catch-finally"},{"Type":"NodeText","Data":"可能会带来很多问题。","Properties":{"id":""}}]},{"ID":"20220906203863-3hf8omg","Type":"NodeParagraph","Properties":{"id":"20220906203863-3hf8omg","updated":"20220906203863"},"Children":[{"Type":"NodeText","Data":"通过使用分号分隔，可以在","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try-with-resources"},{"Type":"NodeText","Data":"块中声明多个资源。","Properties":{"id":""}}]},{"ID":"20220906203864-3bu809u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203864-3bu809u","updated":"20220906203864"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"try (BufferedInputStream bin = new BufferedInputStream(new FileInputStream(new File(\"test.txt\")));\n     BufferedOutputStream bout = new BufferedOutputStream(new FileOutputStream(new File(\"out.txt\")))) {\n    int b;\n    while ((b = bin.read()) != -1) {\n        bout.write(b);\n    }\n}\ncatch (IOException e) {\n    e.printStackTrace();\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203865-v1shhlj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203865-v1shhlj","updated":"20220906203865"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"异常使用有哪些需要注意的地方？","Properties":{"id":""}}]},{"ID":"20220906203866-98fq7w7","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203866-98fq7w7","updated":"20220906203866"},"Children":[{"ID":"20220906203867-m9p4w3g","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203867-m9p4w3g","updated":"20220906203867"},"Children":[{"ID":"20220906203868-nb33xvg","Type":"NodeParagraph","Properties":{"id":"20220906203868-nb33xvg","updated":"20220906203868"},"Children":[{"Type":"NodeText","Data":"不要把异常定义为静态变量，因为这样会导致异常栈信息错乱。每次手动抛出异常，我们都需要手动 new 一个异常对象抛出。","Properties":{"id":""}}]}]},{"ID":"20220906203869-1uy92ua","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203869-1uy92ua","updated":"20220906203869"},"Children":[{"ID":"20220906203870-gg6w4xp","Type":"NodeParagraph","Properties":{"id":"20220906203870-gg6w4xp","updated":"20220906203870"},"Children":[{"Type":"NodeText","Data":"抛出的异常信息一定要有意义。","Properties":{"id":""}}]}]},{"ID":"20220906203871-tzg6zgz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203871-tzg6zgz","updated":"20220906203871"},"Children":[{"ID":"20220906203872-78qnfp0","Type":"NodeParagraph","Properties":{"id":"20220906203872-78qnfp0","updated":"20220906203872"},"Children":[{"Type":"NodeText","Data":"建议抛出更加具体的异常比如字符串转换为数字格式错误的时候应该抛出","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"NumberFormatException"},{"Type":"NodeText","Data":"而不是其父类","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"IllegalArgumentException"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]},{"ID":"20220906203873-ieubbe4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203873-ieubbe4","updated":"20220906203873"},"Children":[{"ID":"20220906203874-w9c9ccw","Type":"NodeParagraph","Properties":{"id":"20220906203874-w9c9ccw","updated":"20220906203874"},"Children":[{"Type":"NodeText","Data":"使用日志打印异常之后就不要再抛出异常了（两者不要同时存在一段代码逻辑中）。","Properties":{"id":""}}]}]},{"ID":"20220906203875-yjq3bjq","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203875-yjq3bjq","updated":"20220906203875"},"Children":[{"ID":"20220906203876-57l4da4","Type":"NodeParagraph","Properties":{"id":"20220906203876-57l4da4","updated":"20220906203876"},"Children":[{"Type":"NodeText","Data":"......","Properties":{"id":""}}]}]}]},{"ID":"20220906203877-532wed9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203877-532wed9","updated":"20220906203877"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"何谓反射？","Properties":{"id":""}}]},{"ID":"20220906203878-o1anwwt","Type":"NodeParagraph","Properties":{"id":"20220906203878-o1anwwt","updated":"20220906203878"},"Children":[{"Type":"NodeText","Data":"如果说大家研究过框架的底层原理或者咱们自己写过框架的话，一定对反射这个概念不陌生。反射之所以被称为框架的灵魂，主要是因为它赋予了我们在运行时分析类以及执行类中方法的能力。通过反射你可以获取任意一个类的所有属性和方法，你还可以调用这些方法和属性。","Properties":{"id":""}}]},{"ID":"20220906203879-mzu4bra","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203879-mzu4bra","updated":"20220906203879"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"反射的优缺点？","Properties":{"id":""}}]},{"ID":"20220906203880-8jcy0wq","Type":"NodeParagraph","Properties":{"id":"20220906203880-8jcy0wq","updated":"20220906203880"},"Children":[{"Type":"NodeText","Data":"反射可以让我们的代码更加灵活、为各种框架提供开箱即用的功能提供了便利。","Properties":{"id":""}}]},{"ID":"20220906203881-zpj5vg0","Type":"NodeParagraph","Properties":{"id":"20220906203881-zpj5vg0","updated":"20220906203881"},"Children":[{"Type":"NodeText","Data":"不过，反射让我们在运行时有了分析操作类的能力的同时，也增加了安全问题，比如可以无视泛型参数的安全检查（泛型参数的安全检查发生在编译时）。另外，反射的性能也要稍差点，不过，对于框架来说实际是影响不大的。","Properties":{"id":""}}]},{"ID":"20220906203882-tob34at","Type":"NodeParagraph","Properties":{"id":"20220906203882-tob34at","updated":"20220906203882"},"Children":[{"Type":"NodeText","Data":"相关阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://stackoverflow.com/questions/1392351/java-reflection-why-is-it-so-slow","TextMarkTextContent":"Java Reflection: Why is it so slow?"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906203883-ueto01r","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203883-ueto01r","updated":"20220906203883"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"反射的应用场景？","Properties":{"id":""}}]},{"ID":"20220906203884-3719ls0","Type":"NodeParagraph","Properties":{"id":"20220906203884-3719ls0","updated":"20220906203884"},"Children":[{"Type":"NodeText","Data":"像咱们平时大部分时候都是在写业务代码，很少会接触到直接使用反射机制的场景。但是！这并不代表反射没有用。相反，正是因为反射，你才能这么轻松地使用各种框架。像 Spring/Spring Boot、MyBatis 等等框架中都大量使用了反射机制。","Properties":{"id":""}}]},{"ID":"20220906203885-nfn566k","Type":"NodeParagraph","Properties":{"id":"20220906203885-nfn566k","updated":"20220906203885"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这些框架中也大量使用了动态代理，而动态代理的实现也依赖反射。"}]},{"ID":"20220906203886-mboh693","Type":"NodeParagraph","Properties":{"id":"20220906203886-mboh693","updated":"20220906203886"},"Children":[{"Type":"NodeText","Data":"比如下面是通过 JDK 实现动态代理的示例代码，其中就使用了反射类 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Method"},{"Type":"NodeText","Data":" 来调用指定的方法。","Properties":{"id":""}}]},{"ID":"20220906203887-ji9h9z3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203887-ji9h9z3","updated":"20220906203887"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class DebugInvocationHandler implements InvocationHandler {\n    /**\n     * 代理类中的真实对象\n     */\n    private final Object target;\n\n    public DebugInvocationHandler(Object target) {\n        this.target = target;\n    }\n\n    public Object invoke(Object proxy, Method method, Object[] args) throws InvocationTargetException, IllegalAccessException {\n        System.out.println(\"before method \" + method.getName());\n        Object result = method.invoke(target, args);\n        System.out.println(\"after method \" + method.getName());\n        return result;\n    }\n}\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203888-wkubuyv","Type":"NodeParagraph","Properties":{"id":"20220906203888-wkubuyv","updated":"20220906203888"},"Children":[{"Type":"NodeText","Data":"另外，像 Java 中的一大利器 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"注解"},{"Type":"NodeText","Data":" 的实现也用到了反射。","Properties":{"id":""}}]},{"ID":"20220906203889-c9k2v2h","Type":"NodeParagraph","Properties":{"id":"20220906203889-c9k2v2h","updated":"20220906203889"},"Children":[{"Type":"NodeText","Data":"为什么你使用 Spring 的时候 ，一个","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"@Component"},{"Type":"NodeText","Data":"注解就声明了一个类为 Spring Bean 呢？为什么你通过一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"@Value"},{"Type":"NodeText","Data":"注解就读取到配置文件中的值呢？究竟是怎么起作用的呢？","Properties":{"id":""}}]},{"ID":"20220906203890-zz5a4vc","Type":"NodeParagraph","Properties":{"id":"20220906203890-zz5a4vc","updated":"20220906203890"},"Children":[{"Type":"NodeText","Data":"这些都是因为你可以基于反射分析类，然后获取到类/属性/方法/方法的参数上的注解。你获取到注解之后，就可以做进一步的处理。","Properties":{"id":""}}]},{"ID":"20220906203891-itzyicl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203891-itzyicl","updated":"20220906203891"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"何谓 SPI?","Properties":{"id":""}}]},{"ID":"20220906203892-hep98su","Type":"NodeParagraph","Properties":{"id":"20220906203892-hep98su","updated":"20220906203892"},"Children":[{"Type":"NodeText","Data":"SPI 即 Service Provider Interface ，字面意思就是：“服务提供者的接口”，我的理解是：专门提供给服务提供者或者扩展框架功能的开发者去使用的一个接口。","Properties":{"id":""}}]},{"ID":"20220906203893-asotq4y","Type":"NodeParagraph","Properties":{"id":"20220906203893-asotq4y","updated":"20220906203893"},"Children":[{"Type":"NodeText","Data":"SPI 将服务接口和具体的服务实现分离开来，将服务调用方和服务实现者解耦，能够提升程序的扩展性、可维护性。修改或者替换服务实现并不需要修改调用方。","Properties":{"id":""}}]},{"ID":"20220906203894-se4qa8x","Type":"NodeParagraph","Properties":{"id":"20220906203894-se4qa8x","updated":"20220906203894"},"Children":[{"Type":"NodeText","Data":"很多框架都使用了 Java 的 SPI 机制，比如：Spring 框架、数据库加载驱动、日志接口、以及 Dubbo 的扩展实现等等。","Properties":{"id":""}}]},{"ID":"20220906203895-vhoi2ft","Type":"NodeParagraph","Properties":{"id":"20220906203895-vhoi2ft","updated":"20220906203895"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/spi/22e1830e0b0e4115a882751f6c417857tplv-k3u1fbpfcp-zoom-1.jpeg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203896-rkz62to","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203896-rkz62to","updated":"20220906203896"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"SPI 和 API 有什么区别？","Properties":{"id":""}}]},{"ID":"20220906203897-b1rw16c","Type":"NodeParagraph","Properties":{"id":"20220906203897-b1rw16c","updated":"20220906203897"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"那 SPI 和 API 有啥区别？"}]},{"ID":"20220906203898-lhkkc98","Type":"NodeParagraph","Properties":{"id":"20220906203898-lhkkc98","updated":"20220906203898"},"Children":[{"Type":"NodeText","Data":"说到 SPI 就不得不说一下 API 了，从广义上来说它们都属于接口，而且很容易混淆。下面先用一张图说明一下：","Properties":{"id":""}}]},{"ID":"20220906203899-fr2z7e3","Type":"NodeParagraph","Properties":{"id":"20220906203899-fr2z7e3","updated":"20220906203899"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/spi/1ebd1df862c34880bc26b9d494535b3dtplv-k3u1fbpfcp-watermark.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203900-ba6h20k","Type":"NodeParagraph","Properties":{"id":"20220906203900-ba6h20k","updated":"20220906203900"},"Children":[{"Type":"NodeText","Data":"一般模块之间都是通过通过接口进行通讯，那我们在服务调用方和服务实现方（也称服务提供者）之间引入一个“接口”。","Properties":{"id":""}}]},{"ID":"20220906203901-my177sp","Type":"NodeParagraph","Properties":{"id":"20220906203901-my177sp","updated":"20220906203901"},"Children":[{"Type":"NodeText","Data":"当实现方提供了接口和实现，我们可以通过调用实现方的接口从而拥有实现方给我们提供的能力，这就是 API ，这种接口和实现都是放在实现方的。","Properties":{"id":""}}]},{"ID":"20220906203902-m6x2psb","Type":"NodeParagraph","Properties":{"id":"20220906203902-m6x2psb","updated":"20220906203902"},"Children":[{"Type":"NodeText","Data":"当接口存在于调用方这边时，就是 SPI ，由接口调用方确定接口规则，然后由不同的厂商去根绝这个规则对这个接口进行实现，从而提供服务。","Properties":{"id":""}}]},{"ID":"20220906203903-cv81tma","Type":"NodeParagraph","Properties":{"id":"20220906203903-cv81tma","updated":"20220906203903"},"Children":[{"Type":"NodeText","Data":"举个通俗易懂的例子：公司 H 是一家科技公司，新设计了一款芯片，然后现在需要量产了，而市面上有好几家芯片制造业公司，这个时候，只要 H 公司指定好了这芯片生产的标准（定义好了接口标准），那么这些合作的芯片公司（服务提供者）就按照标准交付自家特色的芯片（提供不同方案的实现，但是给出来的结果是一样的）。","Properties":{"id":""}}]},{"ID":"20220906203904-58g1dtx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203904-58g1dtx","updated":"20220906203904"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"SPI 的优缺点？","Properties":{"id":""}}]},{"ID":"20220906203905-3a4xupf","Type":"NodeParagraph","Properties":{"id":"20220906203905-3a4xupf","updated":"20220906203905"},"Children":[{"Type":"NodeText","Data":"通过 SPI 机制能够大大地提高接口设计的灵活性，但是 SPI 机制也存在一些缺点，比如：","Properties":{"id":""}}]},{"ID":"20220906203906-kitarbo","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203906-kitarbo","updated":"20220906203906"},"Children":[{"ID":"20220906203907-87rwyq4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203907-87rwyq4","updated":"20220906203907"},"Children":[{"ID":"20220906203908-u5ug8zx","Type":"NodeParagraph","Properties":{"id":"20220906203908-u5ug8zx","updated":"20220906203908"},"Children":[{"Type":"NodeText","Data":"需要遍历加载所有的实现类，不能做到按需加载，这样效率还是相对较低的。","Properties":{"id":""}}]}]},{"ID":"20220906203909-k6ni2ug","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203909-k6ni2ug","updated":"20220906203909"},"Children":[{"ID":"20220906203910-9v7m2p9","Type":"NodeParagraph","Properties":{"id":"20220906203910-9v7m2p9","updated":"20220906203910"},"Children":[{"Type":"NodeText","Data":"当多个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ServiceLoader"},{"Type":"NodeText","Data":" 同时 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"load"},{"Type":"NodeText","Data":" 时，会有并发问题。","Properties":{"id":""}}]}]}]},{"ID":"20220906203911-ezstujb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203911-ezstujb","updated":"20220906203911"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是序列化?什么是反序列化?","Properties":{"id":""}}]},{"ID":"20220906203912-ysdh27k","Type":"NodeParagraph","Properties":{"id":"20220906203912-ysdh27k","updated":"20220906203912"},"Children":[{"Type":"NodeText","Data":"如果我们需要持久化 Java 对象比如将 Java 对象保存在文件中，或者在网络传输 Java 对象，这些场景都需要用到序列化。","Properties":{"id":""}}]},{"ID":"20220906203913-866r550","Type":"NodeParagraph","Properties":{"id":"20220906203913-866r550","updated":"20220906203913"},"Children":[{"Type":"NodeText","Data":"简单来说：","Properties":{"id":""}}]},{"ID":"20220906203914-rue127u","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203914-rue127u","updated":"20220906203914"},"Children":[{"ID":"20220906203915-i09unuz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203915-i09unuz","updated":"20220906203915"},"Children":[{"ID":"20220906203916-o3xkfvr","Type":"NodeParagraph","Properties":{"id":"20220906203916-o3xkfvr","updated":"20220906203916"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"序列化"},{"Type":"NodeText","Data":"： 将数据结构或对象转换成二进制字节流的过程","Properties":{"id":""}}]}]},{"ID":"20220906203917-4r5x61h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203917-4r5x61h","updated":"20220906203917"},"Children":[{"ID":"20220906203918-bk8xw9i","Type":"NodeParagraph","Properties":{"id":"20220906203918-bk8xw9i","updated":"20220906203918"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"反序列化"},{"Type":"NodeText","Data":"：将在序列化过程中所生成的二进制字节流转换成数据结构或者对象的过程","Properties":{"id":""}}]}]}]},{"ID":"20220906203919-qfj8rab","Type":"NodeParagraph","Properties":{"id":"20220906203919-qfj8rab","updated":"20220906203919"},"Children":[{"Type":"NodeText","Data":"对于 Java 这种面向对象编程语言来说，我们序列化的都是对象（Object）也就是实例化后的类(Class)，但是在 C++这种半面向对象的语言中，struct(结构体)定义的是数据结构类型，而 class 对应的是对象类型。","Properties":{"id":""}}]},{"ID":"20220906203920-tekjq1m","Type":"NodeParagraph","Properties":{"id":"20220906203920-tekjq1m","updated":"20220906203920"},"Children":[{"Type":"NodeText","Data":"维基百科是如是介绍序列化的：","Properties":{"id":""}}]},{"ID":"20220906203921-3wzfv4o","Type":"NodeBlockquote","Properties":{"id":"20220906203921-3wzfv4o","updated":"20220906203921"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203922-ne7el4v","Type":"NodeParagraph","Properties":{"id":"20220906203922-ne7el4v","updated":"20220906203922"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"序列化"},{"Type":"NodeText","Data":"（serialization）在计算机科学的数据处理中，是指将数据结构或对象状态转换成可取用格式（例如存成文件，存于缓冲，或经由网络中发送），以留待后续在相同或另一台计算机环境中，能恢复原先状态的过程。依照序列化格式重新获取字节的结果时，可以利用它来产生与原始对象相同语义的副本。对于许多对象，像是使用大量引用的复杂对象，这种序列化重建的过程并不容易。面向对象中的对象序列化，并不概括之前原始对象所关系的函数。这种过程也称为对象编组（marshalling）。从一系列字节提取数据结构的反向操作，是反序列化（也称为解编组、deserialization、unmarshalling）。","Properties":{"id":""}}]}]},{"ID":"20220906203923-wi3d25s","Type":"NodeParagraph","Properties":{"id":"20220906203923-wi3d25s","updated":"20220906203923"},"Children":[{"Type":"NodeText","Data":"综上：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"序列化的主要目的是通过网络传输对象或者说是将对象存储到文件系统、数据库、内存中。"}]},{"ID":"20220906203924-uj0qiqn","Type":"NodeParagraph","Properties":{"id":"20220906203924-uj0qiqn","updated":"20220906203924"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://my-blog-to-use.oss-cn-beijing.aliyuncs.com/2020-8/a478c74d-2c48-40ae-9374-87aacf05188c.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203925-3ahk4oa","Type":"NodeHTMLBlock","Data":"\u003cp style=\"text-align:right;font-size:13px;color:gray\"\u003ehttps://www.corejavaguru.com/java/serialization/interview-questions-1\u003c/p\u003e","HtmlBlockType":6,"Properties":{"id":"20220906203925-3ahk4oa","updated":"20220906203925"}},{"ID":"20220906203926-hy7l6oy","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203926-hy7l6oy","updated":"20220906203926"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如果有些字段不想进行序列化怎么办？","Properties":{"id":""}}]},{"ID":"20220906203927-zg698mi","Type":"NodeParagraph","Properties":{"id":"20220906203927-zg698mi","updated":"20220906203927"},"Children":[{"Type":"NodeText","Data":"对于不想进行序列化的变量，使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 关键字修饰。","Properties":{"id":""}}]},{"ID":"20220906203928-prf50su","Type":"NodeParagraph","Properties":{"id":"20220906203928-prf50su","updated":"20220906203928"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 关键字的作用是：阻止实例中那些用此关键字修饰的的变量序列化；当对象被反序列化时，被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 修饰的变量值不会被持久化和恢复。","Properties":{"id":""}}]},{"ID":"20220906203929-42b5q27","Type":"NodeParagraph","Properties":{"id":"20220906203929-42b5q27","updated":"20220906203929"},"Children":[{"Type":"NodeText","Data":"关于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 还有几点注意：","Properties":{"id":""}}]},{"ID":"20220906203930-2im4ye8","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203930-2im4ye8","updated":"20220906203930"},"Children":[{"ID":"20220906203931-w2fq1dr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203931-w2fq1dr","updated":"20220906203931"},"Children":[{"ID":"20220906203932-v4axwak","Type":"NodeParagraph","Properties":{"id":"20220906203932-v4axwak","updated":"20220906203932"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 只能修饰变量，不能修饰类和方法。","Properties":{"id":""}}]}]},{"ID":"20220906203933-ukqbvnt","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203933-ukqbvnt","updated":"20220906203933"},"Children":[{"ID":"20220906203934-vm4warw","Type":"NodeParagraph","Properties":{"id":"20220906203934-vm4warw","updated":"20220906203934"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 修饰的变量，在反序列化后变量值将会被置成类型的默认值。例如，如果是修饰 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"int"},{"Type":"NodeText","Data":" 类型，那么反序列后结果就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"0"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]},{"ID":"20220906203935-prslprc","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203935-prslprc","updated":"20220906203935"},"Children":[{"ID":"20220906203936-ugvhpje","Type":"NodeParagraph","Properties":{"id":"20220906203936-ugvhpje","updated":"20220906203936"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"static"},{"Type":"NodeText","Data":" 变量因为不属于任何对象(Object)，所以无论有没有 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"transient"},{"Type":"NodeText","Data":" 关键字修饰，均不会被序列化。","Properties":{"id":""}}]}]}]},{"ID":"20220906203937-u3bnutj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203937-u3bnutj","updated":"20220906203937"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Java IO 流了解吗？","Properties":{"id":""}}]},{"ID":"20220906203938-gwx35x7","Type":"NodeParagraph","Properties":{"id":"20220906203938-gwx35x7","updated":"20220906203938"},"Children":[{"Type":"NodeText","Data":"IO 即 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Input/Output"},{"Type":"NodeText","Data":"，输入和输出。数据输入到计算机内存的过程即输入，反之输出到外部存储（比如数据库，文件，远程主机）的过程即输出。数据传输过程类似于水流，因此称为 IO 流。IO 流在 Java 中分为输入流和输出流，而根据数据的处理方式又分为字节流和字符流。","Properties":{"id":""}}]},{"ID":"20220906203939-cgn0k9s","Type":"NodeParagraph","Properties":{"id":"20220906203939-cgn0k9s","updated":"20220906203939"},"Children":[{"Type":"NodeText","Data":"Java IO 流的 40 多个类都是从如下 4 个抽象类基类中派生出来的。","Properties":{"id":""}}]},{"ID":"20220906203940-3gh4jja","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203940-3gh4jja","updated":"20220906203940"},"Children":[{"ID":"20220906203941-kyxtq1h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203941-kyxtq1h","updated":"20220906203941"},"Children":[{"ID":"20220906203942-d0hg2m7","Type":"NodeParagraph","Properties":{"id":"20220906203942-d0hg2m7","updated":"20220906203942"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"InputStream"},{"Type":"NodeText","Data":"/","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Reader"},{"Type":"NodeText","Data":": 所有的输入流的基类，前者是字节输入流，后者是字符输入流。","Properties":{"id":""}}]}]},{"ID":"20220906203943-slz8bz7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203943-slz8bz7","updated":"20220906203943"},"Children":[{"ID":"20220906203944-19tvcwu","Type":"NodeParagraph","Properties":{"id":"20220906203944-19tvcwu","updated":"20220906203944"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"OutputStream"},{"Type":"NodeText","Data":"/","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Writer"},{"Type":"NodeText","Data":": 所有输出流的基类，前者是字节输出流，后者是字符输出流。","Properties":{"id":""}}]}]}]},{"ID":"20220906203945-1ta4gfl","Type":"NodeParagraph","Properties":{"id":"20220906203945-1ta4gfl","updated":"20220906203945"},"Children":[{"Type":"NodeText","Data":"相关阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/java/io/io-basis.html#io-%E6%B5%81%E7%AE%80%E4%BB%8B","TextMarkTextContent":"Java IO 基础知识总结"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906203946-l55d1gg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203946-l55d1gg","updated":"20220906203946"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"I/O 流为什么要分为字节流和字符流呢?","Properties":{"id":""}}]},{"ID":"20220906203947-a0ed091","Type":"NodeParagraph","Properties":{"id":"20220906203947-a0ed091","updated":"20220906203947"},"Children":[{"Type":"NodeText","Data":"问题本质想问：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不管是文件读写还是网络发送接收，信息的最小存储单元都是字节，那为什么 I/O 流操作要分为字节流操作和字符流操作呢？"}]},{"ID":"20220906203948-rh3uy9j","Type":"NodeParagraph","Properties":{"id":"20220906203948-rh3uy9j","updated":"20220906203948"},"Children":[{"Type":"NodeText","Data":"个人认为主要有两点原因：","Properties":{"id":""}}]},{"ID":"20220906203949-zu8cyih","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203949-zu8cyih","updated":"20220906203949"},"Children":[{"ID":"20220906203950-kd75gct","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203950-kd75gct","updated":"20220906203950"},"Children":[{"ID":"20220906203951-i6jx29b","Type":"NodeParagraph","Properties":{"id":"20220906203951-i6jx29b","updated":"20220906203951"},"Children":[{"Type":"NodeText","Data":"字符流是由 Java 虚拟机将字节转换得到的，这个过程还算是比较耗时；","Properties":{"id":""}}]}]},{"ID":"20220906203952-7tt2fly","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"