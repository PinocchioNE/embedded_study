nceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203832-b1r6hjk","updated":"20220906203832"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public static void main(String[] args) {\n    System.out.println(f(2));\n}\n\npublic static int f(int value) {\n    try {\n        return value * value;\n    } finally {\n        if (value == 2) {\n            return 0;\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203833-8unya7o","Type":"NodeParagraph","Properties":{"id":"20220906203833-8unya7o","updated":"20220906203833"},"Children":[{"Type":"NodeText","Data":"输出：","Properties":{"id":""}}]},{"ID":"20220906203834-fwk1ym1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203834-fwk1ym1","updated":"20220906203834"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"0\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203835-34nun0u","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203835-34nun0u","updated":"20220906203835"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"finally 中的代码一定会执行吗？","Properties":{"id":""}}]},{"ID":"20220906203836-de2kcdb","Type":"NodeParagraph","Properties":{"id":"20220906203836-de2kcdb","updated":"20220906203836"},"Children":[{"Type":"NodeText","Data":"不一定的！在某些情况下，finally 中的代码不会被执行。","Properties":{"id":""}}]},{"ID":"20220906203837-nlhynfl","Type":"NodeParagraph","Properties":{"id":"20220906203837-nlhynfl","updated":"20220906203837"},"Children":[{"Type":"NodeText","Data":"就比如说 finally 之前虚拟机被终止运行的话，finally 中的代码就不会被执行。","Properties":{"id":""}}]},{"ID":"20220906203838-ddas2xs","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203838-ddas2xs","updated":"20220906203838"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"try {\n    System.out.println(\"Try to do something\");\n    throw new RuntimeException(\"RuntimeException\");\n} catch (Exception e) {\n    System.out.println(\"Catch Exception -\u003e \" + e.getMessage());\n    // 终止当前正在运行的Java虚拟机\n    System.exit(1);\n} finally {\n    System.out.println(\"Finally\");\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203839-phrp7eq","Type":"NodeParagraph","Properties":{"id":"20220906203839-phrp7eq","updated":"20220906203839"},"Children":[{"Type":"NodeText","Data":"输出：","Properties":{"id":""}}]},{"ID":"20220906203840-j4c557o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203840-j4c557o","updated":"20220906203840"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"Try to do something\nCatch Exception -\u003e Ru