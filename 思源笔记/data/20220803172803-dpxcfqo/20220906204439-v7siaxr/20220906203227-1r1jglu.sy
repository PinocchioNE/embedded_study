{"ID":"20220906203227-1r1jglu","Spec":"1","Type":"NodeDocument","Properties":{"id":"20220906203227-1r1jglu","title":"b-1Java基础","type":"doc","updated":"20220906203227"},"Children":[{"ID":"20220906203228-5wxz98s","Type":"NodeThematicBreak","Properties":{"id":"20220906203228-5wxz98s","updated":"20220906203228"}},{"ID":"20220906203229-8kjrcno","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220906203229-8kjrcno","updated":"20220906203229"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"2. Java","Properties":{"id":""}}]},{"ID":"20220906203230-ov7kkes","Type":"NodeBlockquote","Properties":{"id":"20220906203230-ov7kkes","updated":"20220906203230"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203231-gyni8kh","Type":"NodeParagraph","Properties":{"id":"20220906203231-gyni8kh","updated":"20220906203231"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/","TextMarkTextContent":"JavaGuide"},{"Type":"NodeText","Data":" ：「Java学习+面试指南」一份涵盖大部分 Java 程序员所需要掌握的核心知识。准备 Java 面试，首选 JavaGuide！","Properties":{"id":""}}]}]},{"ID":"20220906203232-5sbc8bh","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e\n    \u003cp\u003e\n        \u003ca href=\"https://www.yuque.com/docs/share/8a30ffb5-83f3-40f9-baf9-38de68b906dc\"\u003e\n            \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/xingqiu/xingqiu.png\" style=\"margin: 0 auto; width: 850px;\" /\u003e\n        \u003c/a\u003e\n    \u003c/p\u003e\n    \u003cp\u003e\n        \u003ca href=\"https://github.com/Snailclimb/JavaGuide-Interview\"\u003eGithub\u003c/a\u003e |\n        \u003ca href=\"https://gitee.com/SnailClimb/JavaGuide-Interview\"\u003eGitee\u003c/a\u003e\n    \u003c/p\u003e  \n\u003c/div\u003e","HtmlBlockType":6,"Properties":{"id":"20220906203232-5sbc8bh","updated":"20220906203232"}},{"ID":"20220906203233-36n1fml","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906203233-36n1fml","updated":"20220906203233"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"2.1. Java 基础","Properties":{"id":""}}]},{"ID":"20220906203234-ku1f3q8","Type":"NodeBlockquote","Properties":{"id":"20220906203234-ku1f3q8","updated":"20220906203234"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203235-yo9cypy","Type":"NodeParagraph","Properties":{"id":"20220906203235-yo9cypy","updated":"20220906203235"},"Children":[{"Type":"NodeText","Data":"这部分内容摘自 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/","TextMarkTextContent":"JavaGuide"},{"Type":"NodeText","Data":" 下面几篇文章：","Properties":{"id":""}}]},{"ID":"20220906203236-muk86iz","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203236-muk86iz","updated":"20220906203236"},"Children":[{"ID":"20220906203237-01xzm1b","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203237-01xzm1b","updated":"20220906203237"},"Children":[{"ID":"20220906203238-aaqgi70","Type":"NodeParagraph","Properties":{"id":"20220906203238-aaqgi70","updated":"20220906203238"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/java/basis/java-basic-questions-01.html","TextMarkTextContent":"Java基础常见面试题总结(上)"}]}]},{"ID":"20220906203239-kj4hvc7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203239-kj4hvc7","updated":"20220906203239"},"Children":[{"ID":"20220906203240-wyc8mte","Type":"NodeParagraph","Properties":{"id":"20220906203240-wyc8mte","updated":"20220906203240"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/java/basis/java-basic-questions-02.html","TextMarkTextContent":"Java基础常见面试题总结(中)"}]}]},{"ID":"20220906203241-ki1nctx","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203241-ki1nctx","updated":"20220906203241"},"Children":[{"ID":"20220906203242-4nxqxk0","Type":"NodeParagraph","Properties":{"id":"20220906203242-4nxqxk0","updated":"20220906203242"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/java/basis/java-basic-questions-03.html","TextMarkTextContent":"Java基础常见面试题总结(下)"}]}]}]}]},{"ID":"20220906203243-th83a5p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203243-th83a5p","updated":"20220906203243"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JVM vs JDK vs JRE","Properties":{"id":""}}]},{"ID":"20220906203244-8xk1024","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203244-8xk1024","updated":"20220906203244"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JVM","Properties":{"id":""}}]},{"ID":"20220906203245-dlnvtgb","Type":"NodeParagraph","Properties":{"id":"20220906203245-dlnvtgb","updated":"20220906203245"},"Children":[{"Type":"NodeText","Data":"Java 虚拟机（JVM）是运行 Java 字节码的虚拟机。JVM 有针对不同系统的特定实现（Windows，Linux，macOS），目的是使用相同的字节码，它们都会给出相同的结果。字节码和不同系统的 JVM 实现是 Java 语言“一次编译，随处可以运行”的关键所在。","Properties":{"id":""}}]},{"ID":"20220906203246-0myacr1","Type":"NodeParagraph","Properties":{"id":"20220906203246-0myacr1","updated":"20220906203246"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"JVM 并不是只有一种！只要满足 JVM 规范，每个公司、组织或者个人都可以开发自己的专属 JVM。"},{"Type":"NodeText","Data":" 也就是说我们平时接触到的 HotSpot VM 仅仅是是 JVM 规范的一种实现而已。","Properties":{"id":""}}]},{"ID":"20220906203247-yvv9s6z","Type":"NodeParagraph","Properties":{"id":"20220906203247-yvv9s6z","updated":"20220906203247"},"Children":[{"Type":"NodeText","Data":"除了我们平时最常用的 HotSpot VM 外，还有 J9 VM、Zing VM、JRockit VM 等 JVM 。维基百科上就有常见 JVM 的对比：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://en.wikipedia.org/wiki/Comparison_of_Java_virtual_machines","TextMarkTextContent":"Comparison of Java virtual machines"},{"Type":"NodeText","Data":" ，感兴趣的可以去看看。并且，你可以在 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://docs.oracle.com/javase/specs/index.html","TextMarkTextContent":"Java SE Specifications"},{"Type":"NodeText","Data":" 上找到各个版本的 JDK 对应的 JVM 规范。","Properties":{"id":""}}]},{"ID":"20220906203248-qhqfke9","Type":"NodeParagraph","Properties":{"id":"20220906203248-qhqfke9","updated":"20220906203248"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/JavaSeSpecifications.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203249-p9qrzzx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203249-p9qrzzx","updated":"20220906203249"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDK 和 JRE","Properties":{"id":""}}]},{"ID":"20220906203250-8oajf4q","Type":"NodeParagraph","Properties":{"id":"20220906203250-8oajf4q","updated":"20220906203250"},"Children":[{"Type":"NodeText","Data":"JDK 是 Java Development Kit 缩写，它是功能齐全的 Java SDK。它拥有 JRE 所拥有的一切，还有编译器（javac）和工具（如 javadoc 和 jdb）。它能够创建和编译程序。","Properties":{"id":""}}]},{"ID":"20220906203251-52983mc","Type":"NodeParagraph","Properties":{"id":"20220906203251-52983mc","updated":"20220906203251"},"Children":[{"Type":"NodeText","Data":"JRE 是 Java 运行时环境。它是运行已编译 Java 程序所需的所有内容的集合，包括 Java 虚拟机（JVM），Java 类库，java 命令和其他的一些基础构件。但是，它不能用于创建新程序。","Properties":{"id":""}}]},{"ID":"20220906203252-a71f4n4","Type":"NodeParagraph","Properties":{"id":"20220906203252-a71f4n4","updated":"20220906203252"},"Children":[{"Type":"NodeText","Data":"如果你只是为了运行一下 Java 程序的话，那么你只需要安装 JRE 就可以了。如果你需要进行一些 Java 编程方面的工作，那么你就需要安装 JDK 了。但是，这不是绝对的。有时，即使您不打算在计算机上进行任何 Java 开发，仍然需要安装 JDK。例如，如果要使用 JSP 部署 Web 应用程序，那么从技术上讲，您只是在应用程序服务器中运行 Java 程序。那你为什么需要 JDK 呢？因为应用程序服务器会将 JSP 转换为 Java servlet，并且需要使用 JDK 来编译 servlet。","Properties":{"id":""}}]},{"ID":"20220906203253-dkf5pz6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203253-dkf5pz6","updated":"20220906203253"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是字节码?采用字节码的好处是什么?","Properties":{"id":""}}]},{"ID":"20220906203254-sbkhujh","Type":"NodeParagraph","Properties":{"id":"20220906203254-sbkhujh","updated":"20220906203254"},"Children":[{"Type":"NodeText","Data":"在 Java 中，JVM 可以理解的代码就叫做字节码（即扩展名为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":".class"},{"Type":"NodeText","Data":" 的文件），它不面向任何特定的处理器，只面向虚拟机。Java 语言通过字节码的方式，在一定程度上解决了传统解释型语言执行效率低的问题，同时又保留了解释型语言可移植的特点。所以， Java 程序运行时相对来说还是高效的（不过，和 C++，Rust，Go 等语言还是有一定差距的），而且，由于字节码并不针对一种特定的机器，因此，Java 程序无须重新编译便可在多种不同操作系统的计算机上运行。","Properties":{"id":""}}]},{"ID":"20220906203255-1qmnc76","Type":"NodeParagraph","Properties":{"id":"20220906203255-1qmnc76","updated":"20220906203255"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Java 程序从源代码到运行的过程如下图所示："}]},{"ID":"20220906203256-gm7igd8","Type":"NodeParagraph","Properties":{"id":"20220906203256-gm7igd8","updated":"20220906203256"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Java程序转变为机器代码的过程","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/java-code-to-machine-code.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203257-8bh02cc","Type":"NodeParagraph","Properties":{"id":"20220906203257-8bh02cc","updated":"20220906203257"},"Children":[{"Type":"NodeText","Data":"我们需要格外注意的是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":".class-\u0026gt;机器码"},{"Type":"NodeText","Data":" 这一步。在这一步 JVM 类加载器首先加载字节码文件，然后通过解释器逐行解释执行，这种方式的执行速度会相对比较慢。而且，有些方法和代码块是经常需要被调用的(也就是所谓的热点代码)，所以后面引进了 JIT（just-in-time compilation） 编译器，而 JIT 属于运行时编译。当 JIT 编译器完成第一次编译后，其会将字节码对应的机器码保存下来，下次可以直接使用。而我们知道，机器码的运行效率肯定是高于 Java 解释器的。这也解释了我们为什么经常会说 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Java 是编译与解释共存的语言"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906203258-036y4uw","Type":"NodeBlockquote","Properties":{"id":"20220906203258-036y4uw","updated":"20220906203258"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203259-keukdvh","Type":"NodeParagraph","Properties":{"id":"20220906203259-keukdvh","updated":"20220906203259"},"Children":[{"Type":"NodeText","Data":"HotSpot 采用了惰性评估(Lazy Evaluation)的做法，根据二八定律，消耗大部分系统资源的只有那一小部分的代码（热点代码），而这也就是 JIT 所需要编译的部分。JVM 会根据代码每次被执行的情况收集信息并相应地做出一些优化，因此执行的次数越多，它的速度就越快。JDK 9 引入了一种新的编译模式 AOT(Ahead of Time Compilation)，它是直接将字节码编译成机器码，这样就避免了 JIT 预热等各方面的开销。JDK 支持分层编译和 AOT 协作使用。","Properties":{"id":""}}]}]},{"ID":"20220906203260-gqny609","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203260-gqny609","updated":"20220906203260"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么不全部使用 AOT 呢？","Properties":{"id":""}}]},{"ID":"20220906203261-zsob4sc","Type":"NodeParagraph","Properties":{"id":"20220906203261-zsob4sc","updated":"20220906203261"},"Children":[{"Type":"NodeText","Data":"AOT 可以提前编译节省启动时间，那为什么不全部使用这种编译方式呢？","Properties":{"id":""}}]},{"ID":"20220906203262-m0rsbdk","Type":"NodeParagraph","Properties":{"id":"20220906203262-m0rsbdk","updated":"20220906203262"},"Children":[{"Type":"NodeText","Data":"长话短说，这和 Java 语言的动态特性有千丝万缕的联系了。举个例子，CGLIB 动态代理使用的是 ASM 技术，而这种技术大致原理是运行时直接在内存中生成并加载修改后的字节码文件也就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":".class"},{"Type":"NodeText","Data":" 文件，如果全部使用 AOT 提前编译，也就不能使用 ASM 技术了。为了支持类似的动态特性，所以选择使用 JIT 即时编译器。","Properties":{"id":""}}]},{"ID":"20220906203263-ljta89q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203263-ljta89q","updated":"20220906203263"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么说 Java 语言“编译与解释并存”？","Properties":{"id":""}}]},{"ID":"20220906203264-yytxpod","Type":"NodeParagraph","Properties":{"id":"20220906203264-yytxpod","updated":"20220906203264"},"Children":[{"Type":"NodeText","Data":"其实这个问题我们讲字节码的时候已经提到过，因为比较重要，所以我们这里再提一下。","Properties":{"id":""}}]},{"ID":"20220906203265-agix9ff","Type":"NodeParagraph","Properties":{"id":"20220906203265-agix9ff","updated":"20220906203265"},"Children":[{"Type":"NodeText","Data":"我们可以将高级编程语言按照程序的执行方式分为两种：","Properties":{"id":""}}]},{"ID":"20220906203266-wy7hoid","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203266-wy7hoid","updated":"20220906203266"},"Children":[{"ID":"20220906203267-isyfd0d","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203267-isyfd0d","updated":"20220906203267"},"Children":[{"ID":"20220906203268-k5cms7r","Type":"NodeParagraph","Properties":{"id":"20220906203268-k5cms7r","updated":"20220906203268"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"编译型"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/%E7%B7%A8%E8%AD%AF%E8%AA%9E%E8%A8%80","TextMarkTextContent":"编译型语言"},{"Type":"NodeText","Data":" 会通过","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/%E7%B7%A8%E8%AD%AF%E5%99%A8","TextMarkTextContent":"编译器"},{"Type":"NodeText","Data":"将源代码一次性翻译成可被该平台执行的机器码。一般情况下，编译语言的执行速度比较快，开发效率比较低。常见的编译性语言有 C、C++、Go、Rust 等等。","Properties":{"id":""}}]}]},{"ID":"20220906203269-ngycxhf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203269-ngycxhf","updated":"20220906203269"},"Children":[{"ID":"20220906203270-qzuywi9","Type":"NodeParagraph","Properties":{"id":"20220906203270-qzuywi9","updated":"20220906203270"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"解释型"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/%E7%9B%B4%E8%AD%AF%E8%AA%9E%E8%A8%80","TextMarkTextContent":"解释型语言"},{"Type":"NodeText","Data":"会通过","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/直譯器","TextMarkTextContent":"解释器"},{"Type":"NodeText","Data":"一句一句的将代码解释（interpret）为机器代码后再执行。解释型语言开发效率比较快，执行速度比较慢。常见的解释性语言有 Python、JavaScript、PHP 等等。","Properties":{"id":""}}]}]}]},{"ID":"20220906203271-6gep489","Type":"NodeParagraph","Properties":{"id":"20220906203271-6gep489","updated":"20220906203271"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"编译型语言和解释型语言","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/compiled-and-interpreted-languages.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203272-s1wjlr5","Type":"NodeParagraph","Properties":{"id":"20220906203272-s1wjlr5","updated":"20220906203272"},"Children":[{"Type":"NodeText","Data":"根据维基百科介绍：","Properties":{"id":""}}]},{"ID":"20220906203273-o876mq6","Type":"NodeBlockquote","Properties":{"id":"20220906203273-o876mq6","updated":"20220906203273"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203274-5nqg4br","Type":"NodeParagraph","Properties":{"id":"20220906203274-5nqg4br","updated":"20220906203274"},"Children":[{"Type":"NodeText","Data":"为了改善编译语言的效率而发展出的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/即時編譯","TextMarkTextContent":"即时编译"},{"Type":"NodeText","Data":"技术，已经缩小了这两种语言间的差距。这种技术混合了编译语言与解释型语言的优点，它像编译语言一样，先把程序源代码编译成","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/字节码","TextMarkTextContent":"字节码"},{"Type":"NodeText","Data":"。到执行期时，再将字节码直译，之后执行。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/Java","TextMarkTextContent":"Java"},{"Type":"NodeText","Data":"与","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/LLVM","TextMarkTextContent":"LLVM"},{"Type":"NodeText","Data":"是这种技术的代表产物。","Properties":{"id":""}}]},{"ID":"20220906203275-t0jq09s","Type":"NodeParagraph","Properties":{"id":"20220906203275-t0jq09s","updated":"20220906203275"},"Children":[{"Type":"NodeText","Data":"相关阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://tech.meituan.com/2020/10/22/java-jit-practice-in-meituan.html","TextMarkTextContent":"基本功 | Java 即时编译器原理解析及实践"}]}]},{"ID":"20220906203276-r6o2nyf","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e   \n    \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/gongzhonghaoxuanchuan.png\" style=\"margin: 0 auto;\" /\u003e  \n\u003c/div\u003e","HtmlBlockType":6,"Properties":{"id":"20220906203276-r6o2nyf","updated":"20220906203276"}},{"ID":"20220906203277-d8uv658","Type":"NodeParagraph","Properties":{"id":"20220906203277-d8uv658","updated":"20220906203277"},"Children":[{"Type":"NodeText","Data":"这是因为 Java 语言既具有编译型语言的特征，也具有解释型语言的特征。因为 Java 程序要经过先编译，后解释两个步骤，由 Java 编写的程序需要先经过编译步骤，生成字节码（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":".class"},{"Type":"NodeText","Data":" 文件），这种字节码必须由 Java 解释器来解释执行。","Properties":{"id":""}}]},{"ID":"20220906203278-rizdfed","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203278-rizdfed","updated":"20220906203278"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Oracle JDK vs OpenJDK","Properties":{"id":""}}]},{"ID":"20220906203279-rrtywdg","Type":"NodeParagraph","Properties":{"id":"20220906203279-rrtywdg","updated":"20220906203279"},"Children":[{"Type":"NodeText","Data":"可能在看这个问题之前很多人和我一样并没有接触和使用过 OpenJDK 。那么 Oracle JDK 和 OpenJDK 之间是否存在重大差异？下面我通过收集到的一些资料，为你解答这个被很多人忽视的问题。","Properties":{"id":""}}]},{"ID":"20220906203280-sp6a9vf","Type":"NodeParagraph","Properties":{"id":"20220906203280-sp6a9vf","updated":"20220906203280"},"Children":[{"Type":"NodeText","Data":"对于 Java 7，没什么关键的地方。OpenJDK 项目主要基于 Sun 捐赠的 HotSpot 源代码。此外，OpenJDK 被选为 Java 7 的参考实现，由 Oracle 工程师维护。关于 JVM，JDK，JRE 和 OpenJDK 之间的区别，Oracle 博客帖子在 2012 年有一个更详细的答案：","Properties":{"id":""}}]},{"ID":"20220906203281-cb0lk00","Type":"NodeBlockquote","Properties":{"id":"20220906203281-cb0lk00","updated":"20220906203281"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203282-7xaftcc","Type":"NodeParagraph","Properties":{"id":"20220906203282-7xaftcc","updated":"20220906203282"},"Children":[{"Type":"NodeText","Data":"问：OpenJDK 存储库中的源代码与用于构建 Oracle JDK 的代码之间有什么区别？","Properties":{"id":""}}]},{"ID":"20220906203283-18kdzyg","Type":"NodeParagraph","Properties":{"id":"20220906203283-18kdzyg","updated":"20220906203283"},"Children":[{"Type":"NodeText","Data":"答：非常接近 - 我们的 Oracle JDK 版本构建过程基于 OpenJDK 7 构建，只添加了几个部分，例如部署代码，其中包括 Oracle 的 Java 插件和 Java WebStart 的实现，以及一些闭源的第三方组件，如图形光栅化器，一些开源的第三方组件，如 Rhino，以及一些零碎的东西，如附加文档或第三方字体。展望未来，我们的目的是开源 Oracle JDK 的所有部分，除了我们考虑商业功能的部分。","Properties":{"id":""}}]}]},{"ID":"20220906203284-1isvamf","Type":"NodeParagraph","Properties":{"id":"20220906203284-1isvamf","updated":"20220906203284"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"总结："},{"Type":"NodeText","Data":"（提示：下面括号内的内容是基于原文补充说明的，因为原文太过于晦涩难懂，用人话重新解释了下，如果你看得懂里面的术语，可以忽略括号解释的内容）","Properties":{"id":""}}]},{"ID":"20220906203285-ja8a6bu","Type":"NodeList","ListData":{"Typ":1,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203285-ja8a6bu","updated":"20220906203285"},"Children":[{"ID":"20220906203286-njpdpo4","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203286-njpdpo4","updated":"20220906203286"},"Children":[{"ID":"20220906203287-e3zqqee","Type":"NodeParagraph","Properties":{"id":"20220906203287-e3zqqee","updated":"20220906203287"},"Children":[{"Type":"NodeText","Data":"Oracle JDK 大概每 6 个月发一次主要版本（从 2014 年 3 月 JDK 8 LTS 发布到 2017 年 9 月 JDK 9 发布经历了长达 3 年多的时间，所以并不总是 6 个月），而 OpenJDK 版本大概每三个月发布一次。但这不是固定的，我觉得了解这个没啥用处。详情参见：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://blogs.oracle.com/java-platform-group/update-and-faq-on-the-java-se-release-cadence","TextMarkTextContent":"https://blogs.oracle.com/java-platform-group/update-and-faq-on-the-java-se-release-cadence"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]}]},{"ID":"20220906203288-16xw9x7","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203288-16xw9x7","updated":"20220906203288"},"Children":[{"ID":"20220906203289-jtytmbf","Type":"NodeParagraph","Properties":{"id":"20220906203289-jtytmbf","updated":"20220906203289"},"Children":[{"Type":"NodeText","Data":"OpenJDK 是一个参考模型并且是完全开源的，而 Oracle JDK 是 OpenJDK 的一个实现，并不是完全开源的；（个人观点：众所周知，JDK 原来是 SUN 公司开发的，后来 SUN 公司又卖给了 Oracle 公司，Oracle 公司以 Oracle 数据库而著名，而 Oracle 数据库又是闭源的，这个时候 Oracle 公司就不想完全开源了，但是原来的 SUN 公司又把 JDK 给开源了，如果这个时候 Oracle 收购回来之后就把他给闭源，必然会引其很多 Java 开发者的不满，导致大家对 Java 失去信心，那 Oracle 公司收购回来不就把 Java 烂在手里了吗！然后，Oracle 公司就想了个骚操作，这样吧，我把一部分核心代码开源出来给你们玩，并且我要和你们自己搞的 JDK 区分下，你们叫 OpenJDK，我叫 Oracle JDK，我发布我的，你们继续玩你们的，要是你们搞出来什么好玩的东西，我后续发布 Oracle JDK 也会拿来用一下，一举两得！）OpenJDK 开源项目：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/openjdk/jdk","TextMarkTextContent":"https://github.com/openjdk/jdk"}]}]},{"ID":"20220906203290-z5vseu9","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203290-z5vseu9","updated":"20220906203290"},"Children":[{"ID":"20220906203291-b94lrww","Type":"NodeParagraph","Properties":{"id":"20220906203291-b94lrww","updated":"20220906203291"},"Children":[{"Type":"NodeText","Data":"Oracle JDK 比 OpenJDK 更稳定（肯定啦，Oracle JDK 由 Oracle 内部团队进行单独研发的，而且发布时间比 OpenJDK 更长，质量更有保障）。OpenJDK 和 Oracle JDK 的代码几乎相同（OpenJDK 的代码是从 Oracle JDK 代码派生出来的，可以理解为在 Oracle JDK 分支上拉了一条新的分支叫 OpenJDK，所以大部分代码相同），但 Oracle JDK 有更多的类和一些错误修复。因此，如果您想开发企业/商业软件，我建议您选择 Oracle JDK，因为它经过了彻底的测试和稳定。某些情况下，有些人提到在使用 OpenJDK 可能会遇到了许多应用程序崩溃的问题，但是，只需切换到 Oracle JDK 就可以解决问题；","Properties":{"id":""}}]}]},{"ID":"20220906203292-70fdby7","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906203292-70fdby7","updated":"20220906203292"},"Children":[{"ID":"20220906203293-89ssc8x","Type":"NodeParagraph","Properties":{"id":"20220906203293-89ssc8x","updated":"20220906203293"},"Children":[{"Type":"NodeText","Data":"在响应性和 JVM 性能方面，Oracle JDK 与 OpenJDK 相比提供了更好的性能；","Properties":{"id":""}}]}]},{"ID":"20220906203294-3howg3g","Type":"NodeListItem","Data":"5","ListData":{"Typ":1,"Tight":true,"Start":5,"Delimiter":46,"Padding":3,"Marker":"NQ==","Num":5},"Properties":{"id":"20220906203294-3howg3g","updated":"20220906203294"},"Children":[{"ID":"20220906203295-4yudeh9","Type":"NodeParagraph","Properties":{"id":"20220906203295-4yudeh9","updated":"20220906203295"},"Children":[{"Type":"NodeText","Data":"Oracle JDK 不会为即将发布的版本提供长期支持（如果是 LTS 长期支持版本的话也会，比如 JDK 8，但并不是每个版本都是 LTS 版本），用户每次都必须通过更新到最新版本获得支持来获取最新版本；","Properties":{"id":""}}]}]},{"ID":"20220906203296-7z7gkpp","Type":"NodeListItem","Data":"6","ListData":{"Typ":1,"Tight":true,"Start":6,"Delimiter":46,"Padding":3,"Marker":"Ng==","Num":6},"Properties":{"id":"20220906203296-7z7gkpp","updated":"20220906203296"},"Children":[{"ID":"20220906203297-y2zj4cu","Type":"NodeParagraph","Properties":{"id":"20220906203297-y2zj4cu","updated":"20220906203297"},"Children":[{"Type":"NodeText","Data":"Oracle JDK 使用 BCL/OTN 协议获得许可，而 OpenJDK 根据 GPL v2 许可获得许可。","Properties":{"id":""}}]}]}]},{"ID":"20220906203298-8fitbu9","Type":"NodeBlockquote","Properties":{"id":"20220906203298-8fitbu9","updated":"20220906203298"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203299-a4mm1u9","Type":"NodeParagraph","Properties":{"id":"20220906203299-a4mm1u9","updated":"20220906203299"},"Children":[{"Type":"NodeText","Data":"既然 Oracle JDK 这么好，那为什么还要有 OpenJDK？","Properties":{"id":""}}]},{"ID":"20220906203300-tfaj1sd","Type":"NodeParagraph","Properties":{"id":"20220906203300-tfaj1sd","updated":"20220906203300"},"Children":[{"Type":"NodeText","Data":"答：","Properties":{"id":""}}]},{"ID":"20220906203301-vjngvkh","Type":"NodeList","ListData":{"Typ":1,"Start":1,"Delimiter":46,"Padding":4,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203301-vjngvkh","updated":"20220906203301"},"Children":[{"ID":"20220906203302-jcek44a","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Start":1,"Delimiter":46,"Padding":4,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203302-jcek44a","updated":"20220906203302"},"Children":[{"ID":"20220906203303-nx3ccf7","Type":"NodeParagraph","Properties":{"id":"20220906203303-nx3ccf7","updated":"20220906203303"},"Children":[{"Type":"NodeText","Data":"OpenJDK 是开源的，开源意味着你可以对它根据你自己的需要进行修改、优化，比如 Alibaba 基于 OpenJDK 开发了 Dragonwell8：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/alibaba/dragonwell8","TextMarkTextContent":"https://github.com/alibaba/dragonwell8"}]}]},{"ID":"20220906203304-bt74ss9","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":4,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203304-bt74ss9","updated":"20220906203304"},"Children":[{"ID":"20220906203305-pazvti8","Type":"NodeParagraph","Properties":{"id":"20220906203305-pazvti8","updated":"20220906203305"},"Children":[{"Type":"NodeText","Data":"OpenJDK 是商业免费的（这也是为什么通过 yum 包管理器上默认安装的 JDK 是 OpenJDK 而不是 Oracle JDK）。虽然 Oracle JDK 也是商业免费（比如 JDK 8），但并不是所有版本都是免费的。","Properties":{"id":""}}]}]},{"ID":"20220906203306-xw2pz77","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":4,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203306-xw2pz77","updated":"20220906203306"},"Children":[{"ID":"20220906203307-u45naoa","Type":"NodeParagraph","Properties":{"id":"20220906203307-u45naoa","updated":"20220906203307"},"Children":[{"Type":"NodeText","Data":"OpenJDK 更新频率更快。Oracle JDK 一般是每 6 个月发布一个新版本，而 OpenJDK 一般是每 3 个月发布一个新版本。（现在你知道为啥 Oracle JDK 更稳定了吧，先在 OpenJDK 试试水，把大部分问题都解决掉了才在 Oracle JDK 上发布）","Properties":{"id":""}}]}]}]},{"ID":"20220906203308-da8qjsy","Type":"NodeParagraph","Properties":{"id":"20220906203308-da8qjsy","updated":"20220906203308"},"Children":[{"Type":"NodeText","Data":"基于以上这些原因，OpenJDK 还是有存在的必要的！","Properties":{"id":""}}]}]},{"ID":"20220906203309-9tawbmp","Type":"NodeParagraph","Properties":{"id":"20220906203309-9tawbmp","updated":"20220906203309"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"oracle jdk release cadence","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/basis/oracle-jdk-release-cadence.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203310-nu1r8bx","Type":"NodeParagraph","Properties":{"id":"20220906203310-nu1r8bx","updated":"20220906203310"},"Children":[{"Type":"NodeText","Data":"🌈 拓展一下：","Properties":{"id":""}}]},{"ID":"20220906203311-1qrh9gm","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203311-1qrh9gm","updated":"20220906203311"},"Children":[{"ID":"20220906203312-edkssyz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203312-edkssyz","updated":"20220906203312"},"Children":[{"ID":"20220906203313-nk88li8","Type":"NodeParagraph","Properties":{"id":"20220906203313-nk88li8","updated":"20220906203313"},"Children":[{"Type":"NodeText","Data":"BCL 协议（Oracle Binary Code License Agreement）： 可以使用 JDK（支持商用），但是不能进行修改。","Properties":{"id":""}}]}]},{"ID":"20220906203314-1aq10lf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203314-1aq10lf","updated":"20220906203314"},"Children":[{"ID":"20220906203315-vb405x5","Type":"NodeParagraph","Properties":{"id":"20220906203315-vb405x5","updated":"20220906203315"},"Children":[{"Type":"NodeText","Data":"OTN 协议（Oracle Technology Network License Agreement）： 11 及之后新发布的 JDK 用的都是这个协议，可以自己私下用，但是商用需要付费。","Properties":{"id":""}}]}]}]},{"ID":"20220906203316-n5x9kkt","Type":"NodeParagraph","Properties":{"id":"20220906203316-n5x9kkt","updated":"20220906203316"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/20210425151835918.png","Properties":{"id":""}},{"