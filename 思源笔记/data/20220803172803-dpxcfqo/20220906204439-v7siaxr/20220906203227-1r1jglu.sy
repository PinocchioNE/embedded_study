kFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203820-iiu6x2u","Type":"NodeParagraph","Properties":{"id":"20220906203820-iiu6x2u","updated":"20220906203820"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"注意：不要在 finally 语句块中使用 return!"},{"Type":"NodeText","Data":" 当 try 语句和 finally 语句中都有 return 语句时，try 语句块中的 return 语句会被忽略。这是因为 try 语句中的 return 返回值会先被暂存在一个本地变量中，当执行到 finally 语句中的 return 之后，这个本地变量的值就变为了 finally 语句中的 return 返回值。","Properties":{"id":""}}]},{"ID":"20220906203821-5y25p0f","Type":"NodeParagraph","Properties":{"id":"20220906203821-5y25p0f","updated":"20220906203821"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://docs.oracle.com/javase/specs/jvms/se7/html/jvms-4.html#jvms-4.10.2.5","TextMarkTextContent":"jvm 官方文档"},{"Type":"NodeText","Data":"中有明确提到：","Properties":{"id":""}}]},{"ID":"20220906203822-fxejafr","Type":"NodeBlockquote","Properties":{"id":"20220906203822-fxejafr","updated":"20220906203822"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203823-r1q6kpw","Type":"NodeParagraph","Properties":{"id":"20220906203823-r1q6kpw","updated":"20220906203823"},"Children":[{"Type":"NodeText","Data":"If the ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"try"},{"Type":"NodeText","Data":" clause executes a _return_, the compiled code does the following:","Properties":{"id":""}}]},{"ID":"20220906203824-34hlwzo","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203824-34hlwzo","updated":"20220906203824"},"Children":[{"ID":"20220906203825-ol9ndf0","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203825-ol9ndf0","updated":"20220906203825"},