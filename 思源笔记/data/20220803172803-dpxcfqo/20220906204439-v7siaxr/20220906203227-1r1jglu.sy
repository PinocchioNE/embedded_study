":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"   L1\n\n    LINENUMBER 8 L1\n\n    ALOAD 0\n\n    BIPUSH 10\n\n    INVOKESTATIC java/lang/Integer.valueOf (I)Ljava/lang/Integer;\n\n    PUTFIELD AutoBoxTest.i : Ljava/lang/Integer;\n\n   L2\n\n    LINENUMBER 9 L2\n\n    ALOAD 0\n\n    ALOAD 0\n\n    GETFIELD AutoBoxTest.i : Ljava/lang/Integer;\n\n    INVOKEVIRTUAL java/lang/Integer.intValue ()I\n\n    PUTFIELD AutoBoxTest.n : I\n\n    RETURN\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203479-yokfdmb","Type":"NodeParagraph","Properties":{"id":"20220906203479-yokfdmb","updated":"20220906203479"},"Children":[{"Type":"NodeText","Data":"从字节码中，我们发现装箱其实就是调用了 包装类的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"valueOf()"},{"Type":"NodeText","Data":"方法，拆箱其实就是调用了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"xxxValue()"},{"Type":"NodeText","Data":"方法。","Properties":{"id":""}}]},{"ID":"20220906203480-wmhjwsr","Type":"NodeParagraph","Properties":{"id":"20220906203480-wmhjwsr","updated":"20220906203480"},"Children":[{"Type":"NodeText","Data":"因此，","Properties":{"id":""}}]},{"ID":"20220906203481-abz3l2i","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203481-abz3l2i","updated":"20220906203481"},"Children":[{"ID":"20220906203482-9o9erws","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203482-9o9erws","updated":"20220906203482"},"Children":[{"ID":"20220906203483-duc6v32","Type":"NodeParagraph","Properties":{"id":"20220906203483-duc6v32","updated":"20220906203483"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Integer i = 10"},{"Type":"NodeText","Data":" 等价于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Integer i = Integer.valueOf(10)"}]}]},{"ID":"20220906203484-3kd6zzr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203484-3kd6zzr","updated":"20220906203484"},"Children":[{"ID":"20220906203485-wt02yc3","Type":"NodeParagraph","Properties":{"id":"20220906203485-wt02yc3","updated":"20220906203485"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"int n = i"},{"Type":"NodeText","Data":" 等价于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"int n = i.intValue()"},{"Type":"NodeText","Data":";","Properties":{"id":""}}]}]}]},{"ID":"20220906203486-z07lufq","Type":"NodeParagraph","Properties":{"id":"20220906203486-z07lufq","updated":"20220906203486"},"Children":[{"Type":"NodeText","Data":"注意：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"如果频繁拆装箱的话，也会严重影响系统的性能。我们应该尽量避免不必要的拆装箱操作。"}]},{"ID":"20220906203487-yv4fqo3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203487-yv4fqo3","updated":"20220906203487"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"private static long sum() {\n    // 应该使用 long 而不是 Long\n    Long sum = 0L;\n    for (long i = 0; i \u003c= Integer.MAX_VALUE; i++)\n        sum += i;\n    return sum;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203488-7bb9whb","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203488-7bb9whb","updated":"20220906203488"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么浮点数运算的时候会有精度丢失的风险？","Properties":{"id":""}}]},{"ID":"20220906203489-z0aqm6i","Type":"NodeParagraph","Properties":{"id":"20220906203489-z0aqm6i","updated":"20220906203489"},"Children":[{"Type":"NodeText","Data":"浮点数运算精度丢失代码演示：","Properties":{"id":""}}]},{"ID":"20220906203490-ifym10i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203490-ifym10i","updated":"20220906203490"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"float a = 2.0f - 1.9f;\nfloat b = 1.8f - 1.7f;\nSystem.out.println(a);// 0.100000024\nSystem.out.println(b);// 0.099999905\nSystem.out.println(a == b);// false\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203491-tgvyfdu","Type":"NodeParagraph","Properties":{"id":"20220906203491-tgvyfdu","updated":"20220906203491"},"Children":[{"Type":"NodeText","Data":"为什么会出现这个问题呢？","Properties":{"id":""}}]},{"ID":"20220906203492-4bccofu","Type":"NodeParagraph","Properties":{"id":"20220906203492-4bccofu","updated":"20220906203492"},"Children":[{"Type":"NodeText","Data":"这个和计算机保存浮点数的机制有很大关系。我们知道计算机是二进制的，而且计算机在表示一个数字时，宽度是有限的，无限循环的小数存储在计算机时，只能被截断，所以就会导致小数精度发生损失的情况。这也就是解释了为什么浮点数没有办法用二进制精确表示。","Properties":{"id":""}}]},{"ID":"20220906203493-1vrl1jc","Type":"NodeParagraph","Properties":{"id":"20220906203493-1vrl1jc","updated":"20220906203493"},"Children":[{"Type":"NodeText","Data":"就比如说十进制下的 0.2 就没办法精确转换成二进制小数：","Properties":{"id":""}}]},{"ID":"20220906203494-oohmg78","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203494-oohmg78","updated":"20220906203494"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// 0.2 转换为二进制数的过程为，不断乘以 2，直到不存在小数为止，\n// 在这个计算过程中，得到的整数部分从上到下排列就是二进制的结果。\n0.2 * 2 = 0.4 -\u003e 0\n0.4 * 2 = 0.8 -\u003e 0\n0.8 * 2 = 1.6 -\u003e 1\n0.6 * 2 = 1.2 -\u003e 1\n0.2 * 2 = 0.4 -\u003e 0（发生循环）\n...\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203495-413d1op","Type":"NodeParagraph","Properties":{"id":"20220906203495-413d1op","updated":"20220906203495"},"Children":[{"Type":"NodeText","Data":"关于浮点数的更多内容，建议看一下","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"http://kaito-kidd.com/2018/08/08/computer-system-float-point/","TextMarkTextContent":"计算机系统基础（四）浮点数"},{"Type":"NodeText","Data":"这篇文章。","Properties":{"id":""}}]},{"ID":"20220906203496-q4h4jye","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203496-q4h4jye","updated":"20220906203496"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何解决浮点数运算的精度丢失问题？","Properties":{"id":""}}]},{"ID":"20220906203497-hysmhkl","Type":"NodeParagraph","Properties":{"id":"20220906203497-hysmhkl","updated":"20220906203497"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BigDecimal"},{"Type":"NodeText","Data":" 可以实现对浮点数的运算，不会造成精度丢失。通常情况下，大部分需要浮点数精确运算结果的业务场景（比如涉及到钱的场景）都是通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BigDecimal"},{"Type":"NodeText","Data":" 来做的。","Properties":{"id":""}}]},{"ID":"20220906203498-5ykhs15","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203498-5ykhs15","updated":"20220906203498"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"BigDecimal a = new BigDecimal(\"1.0\");\nBigDecimal b = new BigDecimal(\"0.9\");\nBigDecimal c = new BigDecimal(\"0.8\");\n\nBigDecimal x = a.subtract(b);\nBigDecimal y = b.subtract(c);\n\nSystem.out.println(x); /* 0.1 */\nSystem.out.println(y); /* 0.1 */\nSystem.out.println(Objects.equals(x, y)); /* true */\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203499-trxraor","Type":"NodeParagraph","Properties":{"id":"20220906203499-trxraor","updated":"20220906203499"},"Children":[{"Type":"NodeText","Data":"关于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BigDecimal"},{"Type":"NodeText","Data":" 的详细介绍，可以看看我写的这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/java/basis/bigdecimal.html","TextMarkTextContent":"BigDecimal 详解"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906203500-yvn5yw8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203500-yvn5yw8","updated":"20220906203500"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"超过 long 整型的数据应该如何表示？","Properties":{"id":""}}]},{"ID":"20220906203501-oman8oi","Type":"NodeParagraph","Properties":{"id":"20220906203501-oman8oi","updated":"20220906203501"},"Children":[{"Type":"NodeText","Data":"基本数值类型都有一个表达范围，如果超过这个范围就会有数值溢出的风险。","Properties":{"id":""}}]},{"ID":"20220906203502-7cqq280","Type":"NodeParagraph","Properties":{"id":"20220906203502-7cqq280","updated":"20220906203502"},"Children":[{"Type":"NodeText","Data":"在 Java 中，64 位 long 整型是最大的整数类型。","Properties":{"id":""}}]},{"ID":"20220906203503-bm3aplo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203503-bm3aplo","updated":"20220906203503"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"long l = Long.MAX_VALUE;\nSystem.out.println(l + 1); // -9223372036854775808\nSystem.out.println(l + 1 == Long.MIN_VALUE); // true\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203504-o6bwulw","Type":"NodeParagraph","Properties":{"id":"20220906203504-o6bwulw","updated":"20220906203504"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BigInteger"},{"Type":"NodeText","Data":" 内部使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"int[]"},{"Type":"NodeText","Data":" 数组来存储任意大小的整形数据。","Properties":{"id":""}}]},{"ID":"20220906203505-079w2gx","Type":"NodeParagraph","Properties":{"id":"20220906203505-079w2gx","updated":"20220906203505"},"Children":[{"Type":"NodeText","Data":"相对于常规整数类型的运算来说，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BigInteger"},{"Type":"NodeText","Data":" 运算的效率会相对较低。","Properties":{"id":""}}]},{"ID":"20220906203506-7ohegem","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203506-7ohegem","updated":"20220906203506"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如果一个类没有声明构造方法，该程序能正确执行吗?","Properties":{"id":""}}]},{"ID":"20220906203507-d2pqsfv","Type":"NodeParagraph","Properties":{"id":"20220906203507-d2pqsfv","updated":"20220906203507"},"Children":[{"Type":"NodeText","Data":"如果一个类没有声明构造方法，也可以执行！因为一个类即使没有声明构造方法也会有默认的不带参数的构造方法。如果我们自己添加了类的构造方法（无论是否有参），Java 就不会再添加默认的无参数的构造方法了，我们一直在不知不觉地使用构造方法，这也是为什么我们在创建对象的时候后面要加一个括号（因为要调用无参的构造方法）。如果我们重载了有参的构造方法，记得都要把无参的构造方法也写出来（无论是否用到），因为这可以帮助我们在创建对象的时候少踩坑。","Properties":{"id":""}}]},{"ID":"20220906203508-96laoo4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203508-96laoo4","updated":"20220906203508"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"构造方法有哪些特点？是否可被 override?","Properties":{"id":""}}]},{"ID":"20220906203509-m2upfb5","Type":"NodeParagraph","Properties":{"id":"20220906203509-m2upfb5","updated":"20220906203509"},"Children":[{"Type":"NodeText","Data":"构造方法特点如下：","Properties":{"id":""}}]},{"ID":"20220906203510-k7p73kz","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203510-k7p73kz","updated":"20220906203510"},"Children":[{"ID":"20220906203511-e0251sx","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203511-e0251sx","updated":"20220906203511"},"Children":[{"ID":"20220906203512-ck3to3u","Type":"NodeParagraph","Properties":{"id":"20220906203512-ck3to3u","updated":"20220906203512"},"Children":[{"Type":"NodeText","Data":"名字与类名相同。","Properties":{"id":""}}]}]},{"ID":"20220906203513-zchgwu0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203513-zchgwu0","updated":"20220906203513"},"Children":[{"ID":"20220906203514-hyw9ve1","Type":"NodeParagraph","Properties":{"id":"20220906203514-hyw9ve1","updated":"20220906203514"},"Children":[{"Type":"NodeText","Data":"没有返回值，但不能用 void 声明构造函数。","Properties":{"id":""}}]}]},{"ID":"20220906203515-mgd3pht","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203515-mgd3pht","updated":"20220906203515"},"Children":[{"ID":"20220906203516-8l0fhp1","Type":"NodeParagraph","Properties":{"id":"20220906203516-8l0fhp1","updated":"20220906203516"},"Children":[{"Type":"NodeText","Data":"生成类的对象时自动执行，无需调用。","Properties":{"id":""}}]}]}]},{"ID":"20220906203517-vlytjpb","Type":"NodeParagraph","Properties":{"id":"20220906203517-vlytjpb","updated":"20220906203517"},"Children":[{"Type":"NodeText","Data":"构造方法不能被 override（重写）,但是可以 overload（重载）,所以你可以看到一个类中有多个构造函数的情况。","Properties":{"id":""}}]},{"ID":"20220906203518-a702t7b","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203518-a702t7b","updated":"20220906203518"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"面向对象三大特征","Properties":{"id":""}}]},{"ID":"20220906203519-blrhhzn","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203519-blrhhzn","updated":"20220906203519"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"封装","Properties":{"id":""}}]},{"ID":"20220906203520-kk23b9i","Type":"NodeParagraph","Properties":{"id":"20220906203520-kk23b9i","updated":"20220906203520"},"Children":[{"Type":"NodeText","Data":"封装是指把一个对象的状态信息（也就是属性）隐藏在对象内部，不允许外部对象直接访问对象的内部信息。但是可以提供一些可以被外界访问的方法来操作属性。就好像我们看不到挂在墙上的空调的内部的零件信息（也就是属性），但是可以通过遥控器（方法）来控制空调。如果属性不想被外界访问，我们大可不必提供方法给外界访问。但是如果一个类没有提供给外界访问的方法，那么这个类也没有什么意义了。就好像如果没有空调遥控器，那么我们就无法操控空凋制冷，空调本身就没有意义了（当然现在还有很多其他方法 ，这里只是为了举例子）。","Properties":{"id":""}}]},{"ID":"20220906203521-v6rbojq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203521-v6rbojq","updated":"20220906203521"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class Student {\n    private int id;//id属性私有化\n    private String name;//name属性私有化\n\n    //获取id的方法\n    public int getId() {\n        return id;\n    }\n\n    //设置id的方法\n    public void setId(int id) {\n        this.id = id;\n    }\n\n    //获取name的方法\n    public String getName() {\n        return name;\n    }\n\n    //设置name的方法\n    public void setName(String name) {\n        this.name = name;\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203522-yeina8f","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203522-yeina8f","updated":"20220906203522"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"继承","Properties":{"id":""}}]},{"ID":"20220906203523-cvwhnc3","Type":"NodeParagraph","Properties":{"id":"20220906203523-cvwhnc3","updated":"20220906203523"},"Children":[{"Type":"NodeText","Data":"不同类型的对象，相互之间经常有一定数量的共同点。例如，小明同学、小红同学、小李同学，都共享学生的特性（班级、学号等）。同时，每一个对象还定义了额外的特性使得他们与众不同。例如小明的数学比较好，小红的性格惹人喜爱；小李的力气比较大。继承是使用已存在的类的定义作为基础建立新类的技术，新类的定义可以增加新的数据或新的功能，也可以用父类的功能，但不能选择性地继承父类。通过使用继承，可以快速地创建新的类，可以提高代码的重用，程序的可维护性，节省大量创建新类的时间 ，提高我们的开发效率。","Properties":{"id":""}}]},{"ID":"20220906203524-at66ewj","Type":"NodeParagraph","Properties":{"id":"20220906203524-at66ewj","updated":"20220906203524"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"关于继承如下 3 点请记住："}]},{"ID":"20220906203525-mtij9uw","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203525-mtij9uw","updated":"20220906203525"},"Children":[{"ID":"20220906203526-xafs93t","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203526-xafs93t","updated":"20220906203526"},"Children":[{"ID":"20220906203527-9spjf1e","Type":"NodeParagraph","Properties":{"id":"20220906203527-9spjf1e","updated":"20220906203527"},"Children":[{"Type":"NodeText","Data":"子类拥有父类对象所有的属性和方法（包括私有属性和私有方法），但是父类中的私有属性和方法子类是无法访问，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"只是拥有"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]},{"ID":"20220906203528-uvbgm5r","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203528-uvbgm5r","updated":"20220906203528"},"Children":[{"ID":"20220906203529-i2oibn2","Type":"NodeParagraph","Properties":{"id":"20220906203529-i2oibn2","updated":"20220906203529"},"Children":[{"Type":"NodeText","Data":"子类可以拥有自己属性和方法，即子类可以对父类进行扩展。","Properties":{"id":""}}]}]},{"ID":"20220906203530-zxfp1af","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203530-zxfp1af","updated":"20220906203530"},"Children":[{"ID":"20220906203531-22ltm5n","Type":"NodeParagraph","Properties":{"id":"20220906203531-22ltm5n","updated":"20220906203531"},"Children":[{"Type":"NodeText","Data":"子类可以用自己的方式实现父类的方法。（以后介绍）。","Properties":{"id":""}}]}]}]},{"ID":"20220906203532-u75vcj2","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203532-u75vcj2","updated":"20220906203532"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"多态","Properties":{"id":""}}]},{"ID":"20220906203533-5htcmbr","Type":"NodeParagraph","Properties":{"id":"20220906203533-5htcmbr","updated":"20220906203533"},"Children":[{"Type":"NodeText","Data":"多态，顾名思义，表示一个对象具有多种的状态，具体表现为父类的引用指向子类的实例。","Properties":{"id":""}}]},{"ID":"20220906203534-2wmyvrl","Type":"NodeParagraph","Properties":{"id":"20220906203534-2wmyvrl","updated":"20220906203534"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"多态的特点:"}]},{"ID":"20220906203535-a2kv23e","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203535-a2kv23e","updated":"20220906203535"},"Children":[{"ID":"20220906203536-ac37eta","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203536-ac37eta","updated":"20220906203536"},"Children":[{"ID":"20220906203537-rz0fjy7","Type":"NodeParagraph","Properties":{"id":"20220906203537-rz0fjy7","updated":"20220906203537"},"Children":[{"Type":"NodeText","Data":"对象类型和引用类型之间具有继承（类）/实现（接口）的关系；","Properties":{"id":""}}]}]},{"ID":"20220906203538-e7gear4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203538-e7gear4","updated":"20220906203538"},"Children":[{"ID":"20220906203539-w0xwljq","Type":"NodeParagraph","Properties":{"id":"20220906203539-w0xwljq","updated":"20220906203539"},"Children":[{"Type":"NodeText","Data":"引用类型变量发出的方法调用的到底是哪个类中的方法，必须在程序运行期间才能确定；","Properties":{"id":""}}]}]},{"ID":"20220906203540-vcp3xl0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203540-vcp3xl0","updated":"20220906203540"},"Children":[{"ID":"20220906203541-0x84gkx","Type":"NodeParagraph","Properties":{"id":"20220906203541-0x84gkx","updated":"20220906203541"},"Children":[{"Type":"NodeText","Data":"多态不能调用“只在子类存在但在父类不存在”的方法；","Properties":{"id":""}}]}]},{"ID":"20220906203542-sspln83","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203542-sspln83","updated":"20220906203542"},"Children":[{"ID":"20220906203543-58xgt58","Type":"NodeParagraph","Properties":{"id":"20220906203543-58xgt58","updated":"20220906203543"},"Children":[{"Type":"NodeText","Data":"如果子类重写了父类的方法，真正执行的是子类覆盖的方法，如果子类没有覆盖父类的方法，执行的是父类的方法。","Properties":{"id":""}}]}]}]},{"ID":"20220906203544-ji31r0n","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203544-ji31r0n","updated":"20220906203544"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"接口和抽象类有什么共同点和区别？","Properties":{"id":""}}]},{"ID":"20220906203545-38l0umr","Type":"NodeParagraph","Properties":{"id":"20220906203545-38l0umr","updated":"20220906203545"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"共同点"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906203546-nmu1yte","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203546-nmu1yte","updated":"20220906203546"},"Children":[{"ID":"20220906203547-703dwdm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203547-703dwdm","updated":"20220906203547"},"Children":[{"ID":"20220906203548-b0wmgbk","Type":"NodeParagraph","Properties":{"id":"20220906203548-b0wmgbk","updated":"20220906203548"},"Children":[{"Type":"NodeText","Data":"都不能被实例化。","Properties":{"id":""}}]}]},{"ID":"20220906203549-nddrfab","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203549-nddrfab","updated":"20220906203549"},"Children":[{"ID":"20220906203550-s1y7ath","Type":"NodeParagraph","Properties":{"id":"20220906203550-s1y7ath","updated":"20220906203550"},"Children":[{"Type":"NodeText","Data":"都可以包含抽象方法。","Properties":{"id":""}}]}]},{"ID":"20220906203551-t7y9ddx","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203551-t7y9ddx","updated":"20220906203551"},"Children":[{"ID":"20220906203552-nej3ikn","Type":"NodeParagraph","Properties":{"id":"20220906203552-nej3ikn","updated":"20220906203552"},"Children":[{"Type":"NodeText","Data":"都可以有默认实现的方法（Java 8 可以用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"default"},{"Type":"NodeText","Data":" 关键字在接口中定义默认方法）。","Properties":{"id":""}}]}]}]},{"ID":"20220906203553-h6ge51r","Type":"NodeParagraph","Properties":{"id":"20220906203553-h6ge51r","updated":"20220906203553"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"区别"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906203554-msquyot","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203554-msquyot","updated":"20220906203554"},"Children":[{"ID":"20220906203555-f2ghbq9","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203555-f2ghbq9","updated":"20220906203555"},"Children":[{"ID":"20220906203556-2xxkon5","Type":"NodeParagraph","Properties":{"id":"20220906203556-2xxkon5","updated":"20220906203556"},"Children":[{"Type":"NodeText","Data":"接口主要用于对类的行为进行约束，你实现了某个接口就具有了对应的行为。抽象类主要用于代码复用，强调的是所属关系。","Properties":{"id":""}}]}]},{"ID":"20220906203557-1dxy9p9","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203557-1dxy9p9","updated":"20220906203557"},"Children":[{"ID":"20220906203558-ghop64i","Type":"NodeParagraph","Properties":{"id":"20220906203558-ghop64i","updated":"20220906203558"},"Children":[{"Type":"NodeText","Data":"一个类只能继承一个类，但是可以实现多个接口。","Properties":{"id":""}}]}]},{"ID":"20220906203559-xucbxz4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203559-xucbxz4","updated":"20220906203559"},"Children":[{"ID":"20220906203560-ms1yco7","Type":"NodeParagraph","Properties":{"id":"20220906203560-ms1yco7","updated":"20220906203560"},"Children":[{"Type":"NodeText","Data":"接口中的成员变量只能是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"public static final"},{"Type":"NodeText","Data":" 类型的，不能被修改且必须有初始值，而抽象类的成员变量默认 default，可在子类中被重新定义，也可被重新赋值。","Properties":{"id":""}}]}]}]},{"ID":"20220906203561-no49enj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203561-no49enj","updated":"20220906203561"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"深拷贝和浅拷贝区别了解吗？什么是引用拷贝？","Properties":{"id":""}}]},{"ID":"20220906203562-y7bm2vr","Type":"NodeParagraph","Properties":{"id":"20220906203562-y7bm2vr","updated":"20220906203562"},"Children":[{"Type":"NodeText","Data":"关于深拷贝和浅拷贝区别，我这里先给结论：","Properties":{"id":""}}]},{"ID":"20220906203563-lxg4no1","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203563-lxg4no1","updated":"20220906203563"},"Children":[{"ID":"20220906203564-os4gvl5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203564-os4gvl5","updated":"20220906203564"},"Children":[{"ID":"20220906203565-81t0g7o","Type":"NodeParagraph","Properties":{"id":"20220906203565-81t0g7o","updated":"20220906203565"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"浅拷贝"},{"Type":"NodeText","Data":"：浅拷贝会在堆上创建一个新的对象（区别于引用拷贝的一点），不过，如果原对象内部的属性是引用类型的话，浅拷贝会直接复制内部对象的引用地址，也就是说拷贝对象和原对象共用同一个内部对象。","Properties":{"id":""}}]}]},{"ID":"20220906203566-jdsbx46","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203566-jdsbx46","updated":"20220906203566"},"Children":[{"ID":"20220906203567-i4xzk69","Type":"NodeParagraph","Properties":{"id":"20220906203567-i4xzk69","updated":"20220906203567"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"深拷贝"},{"Type":"NodeText","Data":" ：深拷贝会完全复制整个对象，包括这个对象所包含的内部对象。","Properties":{"id":""}}]}]}]},{"ID":"20220906203568-8vfaz2h","Type":"NodeParagraph","Properties":{"id":"20220906203568-8vfaz2h","updated":"20220906203568"},"Children":[{"Type":"NodeText","Data":"上面的结论没有完全理解的话也没关系，我们来看一个具体的案例！","Properties":{"id":""}}]},{"ID":"20220906203569-fixckef","Type":"NodeParagraph","Properties":{"id":"20220906203569-fixckef","updated":"20220906203569"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"浅拷贝"}]},{"ID":"20220906203570-kymmvyy","Type":"NodeParagraph","Properties":{"id":"20220906203570-kymmvyy","updated":"20220906203570"},"Children":[{"Type":"NodeText","Data":"浅拷贝的示例代码如下，我们这里实现了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Cloneable"},{"Type":"NodeText","Data":" 接口，并重写了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"clone()"},{"Type":"NodeText","Data":" 方法。","Properties":{"id":""}}]},{"ID":"20220906203571-x4ultlm","Type":"NodeParagraph","Properties":{"id":"20220906203571-x4ultlm","updated":"20220906203571"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"clone()"},{"Type":"NodeText","Data":" 方法的实现很简单，直接调用的是父类 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Object"},{"Type":"NodeText","Data":" 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"clone()"},{"Type":"NodeText","Data":" 方法。","Properties":{"id":""}}]},{"ID":"20220906203572-bqivw1x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203572-bqivw1x","updated":"20220906203572"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public class Address implements Cloneable{\n    private String name;\n    // 省略构造函数、Getter\u0026Setter方法\n    @Override\n    public Address clone() {\n        try {\n            return (Address) super.clone();\n        } catch (CloneNotSupportedException e) {\n            throw new AssertionError();\n        }\n    }\n}\n\npublic class Person implements Cloneable {\n    private Address address;\n    // 省略构造函数、Getter\u0026Setter方法\n    @Override\n    public Person clone() {\n        try {\n            Person person = (Person) super.clone();\n            return person;\n        } catch (CloneNotSupportedException e) {\n            throw new AssertionError();\n        }\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker",