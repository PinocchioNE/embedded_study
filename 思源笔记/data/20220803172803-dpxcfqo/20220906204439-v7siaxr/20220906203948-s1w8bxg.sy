结构类似，数组+链表/红黑二叉树。Java 8 在链表长度超过一定阈值（8）时将链表（寻址时间复杂度为 O(N)）转换为红黑树（寻址时间复杂度为 O(log(N))）。","Properties":{"id":""}}]},{"ID":"20220906204229-sknbzb3","Type":"NodeParagraph","Properties":{"id":"20220906204229-sknbzb3","updated":"20220906204229"},"Children":[{"Type":"NodeText","Data":"Java 8 中，锁粒度更细，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 只锁定当前链表或红黑二叉树的首节点，这样只要 hash 不冲突，就不会产生并发，就不会影响其他 Node 的读写，效率大幅提升。","Properties":{"id":""}}]},{"ID":"20220906204230-1w430kr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204230-1w430kr","updated":"20220906204230"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDK 1.7 和 JDK 1.8 的 ConcurrentHashMap 实现有什么不同？","Properties":{"id":""}}]},{"ID":"20220906204231-3bsxbsj","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204231-3bsxbsj","updated":"20220906204231"},"Children":[{"ID":"20220906204232-r1hpe6r","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204232-r1hpe6r","updated":"20220906204232"},"Children":[{"ID":"20220906204233-uhglnoj","Type":"NodeParagraph","Properties":{"id":"20220906204233-uhglnoj","updated":"20220906204233"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"线程安全实现方式"},{"Type":"NodeText","Data":" ：JDK 1.7 采用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Segment"},{"Type":"NodeText","Data":" 分段锁来保证安全， ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Segment"},{"Type":"NodeText","Data":" 是继承自 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ReentrantLock"},{"Type":"NodeText","Data":"。JDK1.8 放弃了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Segment"},{"Type":"NodeText","Data":" 分段锁的设计，采用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Node + CAS + synchronized"},{"Type":"NodeText","Data":" 保证线程安全，锁粒度更细，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 只锁定当前链表或红黑二叉树的首节点。","Properties":{"id":""}}]}]},{"ID":"20220906204234-jchmp3j","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204234-jchmp3j","updated":"20220906204234"},"Children":[{"ID":"20220906204235-16y64j7","Type":"NodeParagraph","Properties":{"id":"20220906204235-16y64j7","updated":"20220906204235"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Hash 碰撞解决方法"},{"Type":"NodeText","Data":" : JDK 1.7 采用拉链法，JDK1.8 采用拉链法结合红黑树（链表长度超过一定阈值时，将链表转换为红黑树）。","Properties":{"id":""}}]}]},{"ID":"20220906204236-rce9pau","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204236-rce9pau","updated":"20220906204236"},"Children":[{"ID":"20220906204237-4aw2vap","Type":"NodeParagraph","Properties":{"id":"20220906204237-4aw2vap","updated":"20220906204237"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"并发度"},{"Type":"NodeText","Data":" ：JDK 1.7 最大并发度是 Segment 的个数，默认是 16。JDK 1.8 最大并发度是 Node 数组的大小，并发度更大。","Properties":{"id":""}}]}]}]},{"ID":"20220906204238-t381pcg","Type":"NodeHTMLBlock","Data":"\u003cdiv align=\"center\"\u003e   \n    \u003cimg src=\"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/gith