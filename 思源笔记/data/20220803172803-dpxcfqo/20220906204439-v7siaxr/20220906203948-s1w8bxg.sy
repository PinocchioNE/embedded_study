eText","Data":"： JDK1.8 之前 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":" 由数组+链表组成的，数组是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":" 的主体，链表则是主要为了解决哈希冲突而存在的（“拉链法”解决冲突）。JDK1.8 以后在解决哈希冲突时有了较大的变化，当链表长度大于阈值（默认为 8）（将链表转换成红黑树前会判断，如果当前数组的长度小于 64，那么会选择先进行数组扩容，而不是转换为红黑树）时，将链表转化为红黑树，以减少搜索时间","Properties":{"id":""}}]}]},{"ID":"20220906204002-6rd7di4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204002-6rd7di4","updated":"20220906204002"},"Children":[{"ID":"20220906204003-5jkfbiu","Type":"NodeParagraph","Properties":{"id":"20220906204003-5jkfbiu","updated":"20220906204003"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"LinkedHashMap"},{"Type":"NodeText","Data":"： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"LinkedHashMap"},{"Type":"NodeText","Data":" 继承自 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":"，所以它的底层仍然是基于拉链式散列结构即由数组和链表或红黑树组成。另外，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"LinkedHashMap"},{"Type":"NodeText","Data":" 在上面结构的基础上，增加了一条双向链表，使得上面的结构可以保持键值对的插入顺序。同时通过对链表进行相应的操作，实现了访问顺序相关逻辑。详细可以查看：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://www.imooc.com/article/22931","TextMarkTextContent":"《LinkedHashMap 源码详细分析（JDK1.8）》"}]}]},{"ID":"20220906204004-cshjrzr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204004-cshjrzr","updated":"20220906204004"},"Children":[{"ID":"20220906204005-u5sldfk","Type":"NodeParagraph","Properties":{"id":"20220906204005-u5sldfk","updated":"20220906204005"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Hashtable"},{"Type":"NodeText","Data":"： 数组+链表组成的，数组是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Hashtable"},{"Type":"NodeText","Data":" 的主体，链表则是主要为了解决哈希冲突而存在的","Properties":{"id":""}}]}]},{"ID":"20220906204006-khs6xqa","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204006-khs6xqa","updated":"20220906204006"},"Children":[{"ID":"20220906204007-6qdflx3","Type":"NodeParagraph","Properties":{"id":"20220906204007-6qdflx3","updated":"20220906204007"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TreeMap"},{"Type":"NodeText","Data":"： 红黑树（自平衡的排序二叉树）","Properties":{"id":""}}]}]}]},{"ID":"20220906204008-5i9fxs6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204008-5i9fxs6","updated":"20220906204008"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何选用集合?","Properties":{"id":""}}]},{"ID":"20220906204009-gj3spq9","Type":"NodeParagraph","Properties":{"id":"20220906204009-gj3spq9","updated":"20220906204009"},"Children":[{"Type":"NodeText","Data":"主要根据集合的特点来选用，比如我们需要根据键值获取到元素值时就选用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Map"},{"Type":"NodeText","Data":" 接口下的集合，需要排序时选择 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TreeMap"},{"Type":"NodeText","Data":",不需要排序时就选择 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":",需要保证线程安全就选用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ConcurrentHashMap"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204010-aksexgo","Type":"NodeParagraph","Properties":{"id":"20220906204010-aksexgo","updated":"20220906204010"},"Children":[{"Type":"NodeText","Data":"当我们只需要存放元素值时，就选择实现","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Collection"},{"Type":"NodeText","Data":" 接口的集合，需要保证元素唯一时选择实现 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Set"},{"Type":"NodeText","Data":" 接口的集合比如 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"TreeSet"},{"Type":"NodeText","Data":" 或 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashSet"},{"Type":"NodeText","Data":"，不需要就选择实现 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"List"},{"Type":"NodeText","Data":" 接口的比如 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ArrayList"},{"Type":"NodeText","Data":" 或 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"LinkedList"},{"Type":"NodeText","Data":"，然后再根据实现这些接口的集合的特点来选用。","Properties":{"id":""}}]},{"ID":"20220906204011-j1oy6uh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204011-j1oy6uh","updated":"20220906204011"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"为什么要使用集合？","Properties":{"id":""}}]},{"ID":"20220906204012-mctc0q5","Type":"NodeParagraph","Properties":{"id":"20220906204012-mctc0q5","updated":"20220906204012"},"Children":[{"Type":"NodeText","Data":"当我们需要保存一组类型相同的数据的时候，我们应该是用一个容器来保存，这个容器就是数组，但是，使用数组存储对象具有一定的弊端，","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"因为我们在实际开发中，存储的数据的类型是多种多样的，于是，就出现了“集合”，集合同样也是用来存储多个数据的。","Properties":{"id":""}}]},{"ID":"20220906204013-0bh20im","Type":"NodeParagraph","Properties":{"id":"20220906204013-0bh20im","updated":"20220906204013"},"Children":[{"Type":"NodeText","Data":"数组的缺点是一旦声明之后，长度就不可变了；同时，声明数组时的数据类型也决定了该数组存储的数据的类型；而且，数组存储的数据是有序的、可重复的，特点单一。","Properties":{"id":""}},{"Type":"NodeSoftBreak","Data":"\n","Properties":{"id":""}},{"Type":"NodeText","Data":"但是集合提高了数据存储的灵活性，Java 集合不仅可以用来存储不同类型不同数量的对象，还可以保存具有映射关系的数据。","Properties":{"id":""}}]},{"ID":"20220906204014-a7aktvs","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204014-a7aktvs","updated":"20220906204014"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ArrayList 和 Vector 的区别?","Properties":{"id":""}}]},{"ID":"20220906204015-9kj1mvt","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204015-9kj1mvt","updated":"20220906204015"},"Children":[{"ID":"20220906204016-88to3xx","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204016-88to3xx","updated":"20220906204016"},"Children":[{"ID":"20220906204017-d42ps12","Type":"NodeParagraph","Properties":{"id":"20220906204017-d42ps12","updated":"20220906204017"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ArrayList"},{"Type":"NodeText","Data":" 是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"List"},{"Type":"NodeText","Data":" 的主要实现类，底层使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Proper