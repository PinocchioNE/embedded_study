ta":"的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"put()"},{"Type":"NodeText","Data":"方法，并且判断了一下返回值以确保是否有重复元素。直接看一下","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashSet"},{"Type":"NodeText","Data":"中的源码：","Properties":{"id":""}}]},{"ID":"20220906204152-f5b9vui","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204152-f5b9vui","updated":"20220906204152"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// Returns: true if this set did not already contain the specified element\n// 返回值：当 set 中没有包含 add 的元素时返回真\npublic boolean add(E e) {\n        return map.put(e, PRESENT)==null;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204153-tlixyrs","Type":"NodeParagraph","Properties":{"id":"20220906204153-tlixyrs","updated":"20220906204153"},"Children":[{"Type":"NodeText","Data":"而在","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":"的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"putVal()"},{"Type":"NodeText","Data":"方法中也能看到如下说明：","Properties":{"id":""}}]},{"ID":"20220906204154-mz0xbjk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204154-mz0xbjk","updated":"20220906204154"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// Returns : previous value, or null if none\n// 返回值：如果插入位置没有元素返回null，否则返回上一个元素\nfinal V putVal(int hash, K key, V value, boolean onlyIfAbsent,\n                   boolean evict) {\n...\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204155-t0y5fiy","Type":"NodeParagraph","Properties":{"id":"20220906204155-t0y5fiy","updated":"20220906204155"},"Children":[{"Type":"NodeText","Data":"也就是说，在 JDK1.8 中，实际上无论","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashSet"},{"Type":"NodeText","Data":"中是否已经存在了某元素，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashSet"},{"Type":"NodeText","Data":"都会直接插入，只是会在","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"add()"},{"Type":"NodeText","Data":"方法的返回值处告诉我们插入前是否存在相同元素。","Properties":{"id":""}}]},{"ID":"20220906204156-ptxeq0a","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204156-ptxeq0a","updated":"20220906204156"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"HashMap 的底层实现","Properties":{"id":""}}]},{"ID":"20220906204157-kpuqd2t","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204157-kpuqd2t","updated":"20220906204157"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDK1.8 之前","Properties":{"id":""}}]},{"ID":"20220906204158-kp8e6vm","Type":"NodeParagraph","Properties":{"id":"20220906204158-kp8e6vm","updated":"20220906204158"},"Children":[{"Type":"NodeText","Data":"JDK1.8 之前 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":" 底层是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"数组和链表"},{"Type":"NodeText","Data":" 结合在一起使用也就是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"链表散列"},{"Type":"NodeText","Data":"。HashMap 通过 key 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"hashcode"},{"Type":"NodeText","Data":" 经过扰动函数处理过后得到 hash 值，然后通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"(n - 1) \u0026amp; hash"},{"Type":"NodeText","Data":" 判断当前元素存放的位置（这里的 n 指的是数组的长度），如果当前位置存在元素的话，就判断该元素与要存入的元素的 hash 值以及 key 是否相同，如果相同的话，直接覆盖，不相同就通过拉链法解决冲突。","Properties":{"id":""}}]},{"ID":"20220906204159-2msi8la","Type":"NodeParagraph","Properties":{"id":"20220906204159-2msi8la","updated":"20220906204159"},"Children":[{"Type":"NodeText","Data":"所谓扰动函数指的就是 HashMap 的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"hash"},{"Type":"NodeText","Data":" 方法。使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"hash"},{"Type":"NodeText","Data":" 方法也就是扰动函数是为了防止一些实现比较差的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"hashCode()"},{"Type":"NodeText","Data":" 方法 换句话说使用扰动函数之后可以减少碰撞。","Properties":{"id":""}}]},{"ID":"20220906204160-k8cfp5j","Type":"NodeParagraph","Properties":{"id":"20220906204160-k8cfp5j","updated":"20220906204160"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"JDK 1.8 HashMap 的 hash 方法源码:"}]},{"ID":"20220906204161-lc7jhml","Type":"NodeParagraph","Properties":{"id":"20220906204161-lc7jhml","updated":"20220906204161"},"Children":[{"Type":"NodeText","Data":"JDK 1.8 的 hash 方法 相比于 JDK 1.7 hash 方法更加简化，但是原理不变。","Properties":{"id":""}}]},{"ID":"20220906204162-odnucy6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204162-odnucy6","updated":"20220906204162"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"    static final int hash(Object key) {\n      int h;\n      // key.hashCode()：返回散列值也就是hashcode\n      // ^ ：按位异或\n      // \u003e\u003e\u003e:无符号右移，忽略符号位，空位都以0补齐\n      return (key == null) ? 0 : (h = key.hashCode()) ^ (h \u003e\u003e\u003e 16);\n  }\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204163-lcxgwzh","Type":"NodeParagraph","Properties":{"id":"20220906204163-lcxgwzh","updated":"20220906204163"},"Children":[{"Type":"NodeText","Data":"对比一下 JDK1.7 的 HashMap 的 hash 方法源码.","Properties":{"id":""}}]},{"ID":"20220906204164-x3ppfum","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204164-x3ppfum","updated":"20220906204164"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"static int hash(int h) {\n    // This function ensures that hashCodes that differ only by\n    // constant multiples at each bit position have a bounded\n    // number of collisions (approximately 8 at default load factor).\n\n    h ^= (h \u003e\u003e\u003e 20) ^ (h \u003e\u003e\u003e 12);\n    return h ^ (h \u003e\u003e\u003e 7) ^ (h \u003e\u003e\u003e 4);\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204165-it4etgy","Type":"NodeParagraph","Properties":{"id":"20220906204165-it4etgy","updated":"20220906204165"},"Children":[{"Type":"NodeText","Data":"相比于 JDK1.8 的 hash 方法 ，JDK 1.7 的 hash 方法的性能会稍差一点点，因为毕竟扰动了 4 次。","Properties":{"id":""}}]},{"ID":"20220906204166-3ccgww2","Type":"NodeParagraph","Properties":{"id":"20220906204166-3ccgww2","updated":"20220906204166"},"Children":[{"Type":"NodeText","Data":"所谓 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"“拉链法”"},{"Type":"NodeText","Data":" 就是：将链表和数组相结合。也就是说创建一个链表数组，数组中每一格就是一个链表。若遇到哈希冲突，则将冲突的值加到链表中即可。","Properties":{"id":""}}]},{"ID":"20220906204167-1cbpkl6","Type":"NodeParagraph","Properties":{"id":"20220906204167-1cbpkl6","updated":"20220906204167"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"jdk1.8 之前的内部结构-HashMap","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/collection/jdk1.7_hashmap.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204168-3val3s3","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204168-3val3s3","updated":"20220906204168"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDK1.8 之后","Properties":{"id":""}}]},{"ID":"20220906204169-xez2mku","Type":"NodeParagraph","Properties":{"id":"20220906204169-xez2mku","updated":"20220906204169"},"Children":[{"Type":"NodeText","Data":"相比于之前的版本， JDK1.8 之后在解决哈希冲突时有了较大的变化，当链表长度大于阈值（默认为 8）（将链表转换成红黑树前会判断，如果当前数组的长度小于 64，那么会选择先进行数组扩容，而不是转换为红黑树）时，将链表转化为红黑树，以减少搜索时间。","Properties":{"id":""}}]},{"ID":"20220906204170-h2460zy","Type":"NodeParagraph","Properties":{"id":"20220906204170-h2460zy","updated":"20220906204170"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"jdk1.8之后的内部结构-HashMap","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/java/collection/jdk1.8_hashmap.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204171-5n4oadx","Type":"NodeBlockquote","Properties":{"id":"20220906204171-5n4oadx","updated":"20220906204171"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204172-wbohtu1","Type":"NodeParagraph","Properties":{"id":"20220906204172-wbohtu1","updated":"20220906204172"},"Children":[{"Type":"NodeText","Data":"TreeMap、TreeSet 以及 JDK1.8 之后的 HashMap 底层都用到了红黑树。红黑树就是为了解决二叉查找树的缺陷，因为二叉查找树在某些情况下会退化成一个线性结构。","Properties":{"id":""}}]}]},{"ID":"20220906204173-78p85st","Type":"NodeParagraph","Properties":{"id":"20220906204173-78p85st","updated":"20220906204173"},"Children":[{"Type":"NodeText","Data":"我们来结合源码分析一下 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HashMap"},{"Type":"NodeText","Data":" 链表到红黑树的转换。","Properties":{"id":""}}]},{"ID":"20220906204174-co4bs9r","Type":"NodeParagraph","Properties":{"id":"20220906204174-co4bs9r","updated":"20220906204174"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1、 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"putVal"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 方法中执行链表转红黑树的判断逻辑。"}]},{"ID":"20220906204175-w3cofk6","Type":"NodeParagraph","Properties":{"id":"20220906204175-w3cofk6","updated":"20220906204175"},"Children":[{"Type":"NodeText","Data":"链表的长度大于 8 的时候，就执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"treeifyBin"},{"Type":"NodeText","Data":" （转换红黑树）的逻辑。","Properties":{"id":""}}]},{"ID":"20220906204176-q5h9jyq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204176-q5h9jyq","updated":"20220906204176"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// 遍历链表\nfor (int binCount = 0; ; ++binCount) {\n    // 遍历到链表最后一个节点\n    if ((e = p.next) == null) {\n        p.next = newNode(hash, key, value, null);\n        // 如果链表元素个数大于等于TREEIFY_THRESHOLD（8）\n        if (binCount \u003e= TREEIFY_THRESHOLD - 1) // -1 for 1st\n            // 红黑树转换（并不会直接转换成红黑树）\n            treeifyBin(tab, hash);\n        break;\n    }\n    if (e.hash == hash \u0026\u0026\n        ((k = e.key) == key || (key != null \u0026\u0026 key.equals(k))))\n        break;\n    p = e;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204177-soa4a12","Type":"NodeParagraph","Properties":{"id":"20220906204177-soa4a12","updated":"20220906204177"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2、"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"treeifyBin"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 方法中判断是否真的转换为红黑树。"}]},{"ID":"20220906204178-l8pgosf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204178-l8pgosf","updated":"20220906204178"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"final void treeifyBin(Node\u003cK,V\u003e[] tab, int hash) {\n    int n, index; Node\u003cK,V\u003e e;\n    // 判断当前数组的长度是否小于 64\n    if (tab == null || (n = tab.length) \u003c MIN_TREEIFY_CAPACITY)\n        // 如果当前数组的长度小于 64，那么会选择先进行数组扩容\n        resize();\n    else if ((e = tab[index = (n - 1) \u0026 hash]) != null) {\n        // 否则才将列表转换为红黑树\n\n        TreeNode\u003cK,V\u003e hd = null, tl = null;\n        do {\n            TreeNode\u003cK,V\u003e p = replacementTreeNode(e, null);\n            if (tl == null)\n                hd = p;\n            else {\n                p.prev = tl;\n                tl.next = p;\n            }\n            tl = p;\n        } while ((e = e.next) != null);\n        if ((tab[index] = hd) != null)\n            hd.treeify(tab);\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204179-qvaqs28","Type":"NodeParagraph","Properties":{"id":"20220906204179-qvaqs28","updated":"20220906204179"},"Children":[{"Type":"NodeText","Data":"将链表转换成红黑树前会判断，如果当前数组的长度小于 64，那么会选择先进行数组扩容，而不是转换为红黑树。","Properties":{"id":""}}]},{"ID":"20220906204180-a0h5opu","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204180-a0h5opu","updated":"20220906204180"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"HashMap 的长度为什么是 2 的幂次方","Properties":{"id":""}}]},{"ID":"20220906204181-1yc8x1p","Type":"NodeParagraph","Properties":{"id":"20220906204181-1yc8x1p","updated":"20220906204181"},"Children":[{"Type":"NodeText","Data":"为了能让 HashMap 存取高效，尽量较少碰撞，也就是要尽量把数据分配均匀。我们上面也讲到了过了，Hash 值的范围值-2147483648 到 2147483647，前后加起来大概 40 亿的映射空间，只要哈希函数映射得比较均匀松散，一般应用是很难出现碰撞的。但问题是一个 40 亿长度的数组，内存是放不下的。所以这个散列值是不能直接拿来用的。用之前还要先做对数组的长度取模运算，得到的余数才能用来要存放的位置也就是对应的数组下标。这个数组下标的计算方法是“ ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"(n - 1) \u0026amp; hash"},{"Type":"NodeText","Data":"”。（n 代表数组长度）。这也就解释了 HashMap 的长度为什么是 2 的幂次方。","Properties":{"id":""}}]},{"ID":"20220906204182-aob84t6","Type":"NodeParagraph","Properties":{"id":"20220906204182-aob84t6","updated":"20220906204182"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这个算法应该如何设计呢？"}]},{"ID":"20220906204183-1sx8zbz","Type":"NodeParagraph","Properties":{"id":"20220906204183-1sx8zbz","updated":"20220906204183"},"Children":[{"Type":"NodeText","Data":"我们首先可能会想到采用%取余的操作来实现。但是，重点来了：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"“取余(%)操作中如果除数是 2 的幂次则等价于与其除数减一的与(\u0026amp;)操作（也就是说 hash%length==hash\u0026amp;(length-1)的前提是 length 是 2 的 n 次方；）。”"},{"Type":"NodeText","Data":" 并且 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"采用二进制位操作 \u0026amp;，相对于%能够提高运算效率，这就解释了 HashMap 的长度为什么是 2 的幂次方。"}]},{"ID":"20220906204184-k7vlmqe","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204184-k7vlmqe","updated":"20220906204184"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"HashMap 多线程操作导致死循环问题","Properties":{"id":""}}]},{"ID":"20220906204185-vfj2ccm","Type":"NodeParagraph","Properties":{"id":"20220906204185-vfj2ccm","updated":"20220906204185"},"Children":[{"Type":"NodeText","Data":"主要原因在于并发下的 Rehash 会造成元素之间会形成一个循环链表。不过，jdk 1.8 后解决了这个问题，但是还是不建议在多线程下使用 HashMap,因为多线程下使用 HashMap 还是会存在其他问题比如数据丢失。并发环境下推荐使用 ConcurrentHashMap 。","Properties":{"id":""}}]},{"ID":"20220906204186-zrbovqq","Type":"NodeParagraph","Properties":{"id":"20220906204186-zrbovqq","updated":"20220906204186"},"Children":[{"Type":"NodeText","Data":"详情请查看：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://coolshell.cn/articles/9606.html","TextMarkTextContent":"https://coolshell.cn/articles/9606.html"}]},{"ID":"20220906204187-o0bm0dv","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204187-o0bm0dv","updated":"20220906204187"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"HashMap 有哪几种常见的遍历方式?","Properties":{"id":""}}]},{"ID":"20220906204188-3joe91s","Type":"NodeParagraph","Properties":{"id":"20220906204188-3joe91s","updated":"20220906204188"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://mp.weixin.qq.com/s/zQBN3UvJDhRTKP6SzcZFKw","TextMarkTextContent":"HashMap 的 7 种遍历方式与性能分析！"}]},{"ID":"20220906204189-1v2gyyj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204189-1v2gyyj","updated":"20220906204189"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ConcurrentHashMap 和 Hashtable 的区别","Properties":{"id":""}}]},{"ID":"20220906204190-1fm4ecm","Type":"NodeParagraph","Properties":{"id":"20220906204190-1fm4ecm","updated":"20220906204190"},"Children"