[{"ID":"20220906203988-z29x5e4","Type":"NodeParagraph","Properties":{"id":"20220906203988-z29x5e4","updated":"20220906203988"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"避免"},{"Type":"NodeText","Data":"则是系统在分配资源时，根据资源的使用情况","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"提前做出预测"},{"Type":"NodeText","Data":"，从而","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"避免死锁的发生"}]}]},{"ID":"20220906203989-0rvsqvz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203989-0rvsqvz","updated":"20220906203989"},"Children":[{"ID":"20220906203990-idz42gr","Type":"NodeParagraph","Properties":{"id":"20220906203990-idz42gr","updated":"20220906203990"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"检测"},{"Type":"NodeText","Data":"是指系统设有","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"专门的机构"},{"Type":"NodeText","Data":"，当死锁发生时，该机构能够检测死锁的发生，并精确地确定与死锁有关的进程和资源。","Properties":{"id":""}}]}]},{"ID":"20220906203991-2m5sj4h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203991-2m5sj4h","updated":"20220906203991"},"Children":[{"ID":"20220906203992-d9zua11","Type":"NodeParagraph","Properties":{"id":"20220906203992-d9zua11","updated":"20220906203992"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"解除"},{"Type":"NodeText","Data":" 是与检测相配套的一种措施，用于","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"将进程从死锁状态下解脱出来"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]}]},{"ID":"20220906203993-6gow0xa","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220906203993-6gow0xa","updated":"20220906203993"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁的预防","Properties":{"id":""}}]},{"ID":"20220906203994-ugw56rs","Type":"NodeParagraph","Properties":{"id":"20220906203994-ugw56rs","updated":"20220906203994"},"Children":[{"Type":"NodeText","Data":"死锁四大必要条件上面都已经列出来了，很显然，只要破坏四个必要条件中的任何一个就能够预防死锁的发生。","Properties":{"id":""}}]},{"ID":"20220906203995-befihud","Type":"NodeParagraph","Properties":{"id":"20220906203995-befihud","updated":"20220906203995"},"Children":[{"Type":"NodeText","Data":"破坏第一个条件 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"互斥条件"},{"Type":"NodeText","Data":"：使得资源是可以同时访问的，这是种简单的方法，磁盘就可以用这种方法管理，但是我们要知道，有很多资源 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"往往是不能同时访问的"},{"Type":"NodeText","Data":" ，所以这种做法在大多数的场合是行不通的。","Properties":{"id":""}}]},{"ID":"20220906203996-6al3gpf","Type":"NodeParagraph","Properties":{"id":"20220906203996-6al3gpf","updated":"20220906203996"},"Children":[{"Type":"NodeText","Data":"破坏第三个条件 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"非抢占"},{"Type":"NodeText","Data":" ：也就是说可以采用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"剥夺式调度算法"},{"Type":"NodeText","Data":"，但剥夺式调度方法目前一般仅适用于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"主存资源"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"处理器资源"},{"Type":"NodeText","Data":" 的分配，并不适用于所以的资源，会导致 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"资源利用率下降"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906203997-i9wb6bd","Type":"NodeParagraph","Properties":{"id":"20220906203997-i9wb6bd","updated":"20220906203997"},"Children":[{"Type":"NodeText","Data":"所以一般比较实用的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"预防死锁的方法"},{"Type":"NodeText","Data":"，是通过考虑破坏第二个条件和第四个条件。","Properties":{"id":""}}]},{"ID":"20220906203998-prnzw9h","Type":"NodeParagraph","Properties":{"id":"20220906203998-prnzw9h","updated":"20220906203998"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1、静态分配策略"}]},{"ID":"20220906203999-amwypl0","Type":"NodeParagraph","Properties":{"id":"20220906203999-amwypl0","updated":"20220906203999"},"Children":[{"Type":"NodeText","Data":"静态分配策略可以破坏死锁产生的第二个条件（占有并等待）。所谓静态分配策略，就是指一个进程必须在执行前就申请到它所需要的全部资源，并且知道它所要的资源都得到满足之后才开始执行。进程要么占有所有的资源然后开始执行，要么不占有资源，不会出现占有一些资源等待一些资源的情况。","Properties":{"id":""}}]},{"ID":"20220906204000-lisv554","Type":"NodeParagraph","Properties":{"id":"20220906204000-lisv554","updated":"20220906204000"},"Children":[{"Type":"NodeText","Data":"静态分配策略逻辑简单，实现也很容易，但这种策略 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"严重地降低了资源利用率"},{"Type":"NodeText","Data":"，因为在每个进程所占有的资源中，有些资源是在比较靠后的执行时间里采用的，甚至有些资源是在额外的情况下才是用的，这样就可能造成了一个进程占有了一些 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"几乎不用的资源而使其他需要该资源的进程产生等待"},{"Type":"NodeText","Data":" 的情况。","Properties":{"id":""}}]},{"ID":"20220906204001-i02ef6b","Type":"NodeParagraph","Properties":{"id":"20220906204001-i02ef6b","updated":"20220906204001"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2、层次分配策略"}]},{"ID":"20220906204002-s9rmxn0","Type":"NodeParagraph","Properties":{"id":"20220906204002-s9rmxn0","updated":"20220906204002"},"Children":[{"Type":"NodeText","Data":"层次分配策略破坏了产生死锁的第四个条件(循环等待)。在层次分配策略下，所有的资源被分成了多个层次，一个进程得到某一次的一个资源后，它只能再申请较高一层的资源；当一个进程要释放某层的一个资源时，必须先释放所占用的较高层的资源，按这种策略，是不可能出现循环等待链的，因为那样的话，就出现了已经申请了较高层的资源，反而去申请了较低层的资源，不符合层次分配策略，证明略。","Properties":{"id":""}}]},{"ID":"20220906204003-30ob6pb","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220906204003-30ob6pb","updated":"20220906204003"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁的避免","Properties":{"id":""}}]},{"ID":"20220906204004-kl1zbyy","Type":"NodeParagraph","Properties":{"id":"20220906204004-kl1zbyy","updated":"20220906204004"},"Children":[{"Type":"NodeText","Data":"上面提到的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"破坏"},{"Type":"NodeText","Data":" 死锁产生的四个必要条件之一就可以成功 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"预防系统发生死锁"},{"Type":"NodeText","Data":" ，但是会导致 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"低效的进程运行"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"资源使用率"},{"Type":"NodeText","Data":" 。而死锁的避免相反，它的角度是允许系统中","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"同时存在四个必要条件"},{"Type":"NodeText","Data":" ，只要掌握并发进程中与每个进程有关的资源动态申请情况，做出 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"明智和合理的选择"},{"Type":"NodeText","Data":" ，仍然可以避免死锁，因为四大条件仅仅是产生死锁的必要条件。","Properties":{"id":""}}]},{"ID":"20220906204005-qyc6883","Type":"NodeParagraph","Properties":{"id":"20220906204005-qyc6883","updated":"20220906204005"},"Children":[{"Type":"NodeText","Data":"我们将系统的状态分为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"安全状态"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不安全状态"},{"Type":"NodeText","Data":" ，每当在未申请者分配资源前先测试系统状态，若把系统资源分配给申请者会产生死锁，则拒绝分配，否则接受申请，并为它分配资源。","Properties":{"id":""}}]},{"ID":"20220906204006-cfv5s6h","Type":"NodeBlockquote","Properties":{"id":"20220906204006-cfv5s6h","updated":"20220906204006"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204007-9sptf97","Type":"NodeParagraph","Properties":{"id":"20220906204007-9sptf97","updated":"20220906204007"},"Children":[{"Type":"NodeText","Data":"如果操作系统能够保证所有的进程在有限的时间内得到需要的全部资源，则称系统处于安全状态，否则说系统是不安全的。很显然，系统处于安全状态则不会发生死锁，系统若处于不安全状态则可能发生死锁。","Properties":{"id":""}}]}]},{"ID":"20220906204008-csbh08v","Type":"NodeParagraph","Properties":{"id":"20220906204008-csbh08v","updated":"20220906204008"},"Children":[{"Type":"NodeText","Data":"那么如何保证系统保持在安全状态呢？通过算法，其中最具有代表性的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"避免死锁算法"},{"Type":"NodeText","Data":" 就是 Dijkstra 的银行家算法，银行家算法用一句话表达就是：当一个进程申请使用资源的时候，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"银行家算法"},{"Type":"NodeText","Data":" 通过先 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"试探"},{"Type":"NodeText","Data":" 分配给该进程资源，然后通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"安全性算法"},{"Type":"NodeText","Data":" 判断分配后系统是否处于安全状态，若不安全则试探分配作废，让该进程继续等待，若能够进入到安全的状态，则就 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"真的分配资源给该进程"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204009-6qfj7b6","Type":"NodeParagraph","Properties":{"id":"20220906204009-6qfj7b6","updated":"20220906204009"},"Children":[{"Type":"NodeText","Data":"银行家算法详情可见：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://blog.csdn.net/qq_33414271/article/details/80245715","TextMarkTextContent":"《一句话+一张图说清楚——银行家算法》"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204010-1q7zdhs","Type":"NodeParagraph","Properties":{"id":"20220906204010-1q7zdhs","updated":"20220906204010"},"Children":[{"Type":"NodeText","Data":"操作系统教程树中讲述的银行家算法也比较清晰，可以一看.","Properties":{"id":""}}]},{"ID":"20220906204011-cgy2lt4","Type":"NodeParagraph","Properties":{"id":"20220906204011-cgy2lt4","updated":"20220906204011"},"Children":[{"Type":"NodeText","Data":"死锁的避免(银行家算法)改善解决了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"资源使用率低的问题"},{"Type":"NodeText","Data":" ，但是它要不断地检测每个进程对各类资源的占用和申请情况，以及做 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"安全性检查"},{"Type":"NodeText","Data":" ，需要花费较多的时间。","Properties":{"id":""}}]},{"ID":"20220906204012-aelzaf8","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220906204012-aelzaf8","updated":"20220906204012"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁的检测","Properties":{"id":""}}]},{"ID":"20220906204013-abwkhz2","Type":"NodeParagraph","Properties":{"id":"20220906204013-abwkhz2","updated":"20220906204013"},"Children":[{"Type":"NodeText","Data":"对资源的分配加以限制可以 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"预防和避免"},{"Type":"NodeText","Data":" 死锁的发生，但是都不利于各进程对系统资源的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"充分共享"},{"Type":"NodeText","Data":"。解决死锁问题的另一条途径是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"死锁检测和解除"},{"Type":"NodeText","Data":" (这里突然联想到了乐观锁和悲观锁，感觉死锁的检测和解除就像是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"乐观锁"},{"Type":"NodeText","Data":" ，分配资源时不去提前管会不会发生死锁了，等到真的死锁出现了再来解决嘛，而 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"死锁的预防和避免"},{"Type":"NodeText","Data":" 更像是悲观锁，总是觉得死锁会出现，所以在分配资源的时候就很谨慎)。","Properties":{"id":""}}]},{"ID":"20220906204014-nraa4qn","Type":"NodeParagraph","Properties":{"id":"20220906204014-nraa4qn","updated":"20220906204014"},"Children":[{"Type":"NodeText","Data":"这种方法对资源的分配不加以任何限制，也不采取死锁避免措施，但系统 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"定时地运行一个 “死锁检测”"},{"Type":"NodeText","Data":" 的程序，判断系统内是否出现死锁，如果检测到系统发生了死锁，再采取措施去解除它。","Properties":{"id":""}}]},{"ID":"20220906204015-3irwo6r","Type":"NodeParagraph","Properties":{"id":"20220906204015-3irwo6r","updated":"20220906204015"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"进程-资源分配图"}]},{"ID":"20220906204016-9192xyp","Type":"NodeParagraph","Properties":{"id":"20220906204016-9192xyp","updated":"20220906204016"},"Children":[{"Type":"NodeText","Data":"操作系统中的每一刻时刻的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"系统状态"},{"Type":"NodeText","Data":"都可以用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"进程-资源分配图"},{"Type":"NodeText","Data":"来表示，进程-资源分配图是描述进程和资源申请及分配关系的一种有向图，可用于","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"检测系统是否处于死锁状态"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204017-yhk7c1g","Type":"NodeParagraph","Properties":{"id":"20220906204017-yhk7c1g","updated":"20220906204017"},"Children":[{"Type":"NodeText","Data":"用一个方框表示每一个资源类，方框中的黑点表示该资源类中的各个资源，每个键进程用一个圆圈表示，用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"有向边"},{"Type":"NodeText","Data":" 来表示","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"进程申请资源和资源被分配的情况"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204018-6v6ofn5","Type":"NodeParagraph","Properties":{"id":"20220906204018-6v6ofn5","updated":"20220906204018"},"Children":[{"Type":"NodeText","Data":"图中 2-21 是","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"进程-资源分配图"},{"Type":"NodeText","Data":"的一个例子，其中共有三个资源类，每个进程的资源占有和申请情况已清楚地表示在图中。在这个例子中，由于存在 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"占有和等待资源的环路"},{"Type":"NodeText","Data":" ，导致一组进程永远处于等待资源的状态，发生了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"死锁"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204019-19g0i6i","Type":"NodeParagraph","Properties":{"id":"20220906204019-19g0i6i","updated":"20220906204019"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"进程-资源分配图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/cs-basics/operating-system/process-resource-allocation-diagram.jpg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204020-07hf4eh","Type":"NodeParagraph","Properties":{"id":"20220906204020-07hf4eh","updated":"20220906204020"},"Children":[{"Type":"NodeText","Data":"进程-资源分配图中存在环路并不一定是发生了死锁。因为循环等待资源仅仅是死锁发生的必要条件，而不是充分条件。图 2-22 便是一个有环路而无死锁的例子。虽然进程 P1 和进程 P3 分别占用了一个资源 R1 和一个资源 R2，并且因为等待另一个资源 R2 和另一个资源 R1 形成了环路，但进程 P2 和进程 P4 分别占有了一个资源 R1 和一个资源 R2，它们申请的资源得到了满足，在有限的时间里会归还资源，于是进程 P1 或 P3 都能获得另一个所需的资源，环路自动解除，系统也就不存在死锁状态了。","Properties":{"id":""}}]},{"ID":"20220906204021-dblsktw","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220906204021-dblsktw","updated":"20220906204021"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁检测步骤","Properties":{"id":""}}]},{"ID":"20220906204022-gzrkr50","Type":"NodeParagraph","Properties":{"id":"20220906204022-gzrkr50","updated":"20220906204022"},"Children":[{"Type":"NodeText","Data":"知道了死锁检测的原理，我们可以利用下列步骤编写一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"死锁检测"},{"Type":"NodeText","Data":" 程序，检测系统是否产生了死锁。","Properties":{"id":""}}]},{"ID":"20220906204023-rgohymf","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204023-rgohymf","updated":"20220906204023"},"Children":[{"ID":"20220906204024-fqcz3o2","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204024-fqcz3o2","updated":"20220906204024"},"Children":[{"ID":"20220906204025-4agwi5l","Type":"NodeParagraph","Properties":{"id":"20220906204025-4agwi5l","updated":"20220906204025"},"Children":[{"Type":"NodeText","Data":"如果进程-资源分配图中无环路，则此时系统没有发生死锁","Properties":{"id":""}}]}]},{"ID":"20220906204026-h1k1ng7","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204026-h1k1ng7","updated":"20220906204026"},"Children":[{"ID":"20220906204027-2olpvh4","Type":"NodeParagraph","Properties":{"id":"20220906204027-2olpvh4","updated":"20220906204027"},"Children":[{"Type":"NodeText","Data":"如果进程-资源分配图中有环路，且每个资源类仅有一个资源，则系统中已经发生了死锁。","Properties":{"id":""}}]}]},{"ID":"20220906204028-44xbbrr","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204028-44xbbrr","updated":"20220906204028"},"Children":[{"ID":"20220906204029-6a8nna1","Type":"NodeParagraph","Properties":{"id":"20220906204029-6a8nna1","updated":"20220906204029"},"Children":[{"Type":"NodeText","Data":"如果进程-资源分配图中有环路，且涉及到的资源类有多个资源，此时系统未必会发生死锁。如果能在进程-资源分配图中找出一个 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"既不阻塞又非独立的进程"},{"Type":"NodeText","Data":" ，该进程能够在有限的时间内归还占有的资源，也就是把边给消除掉了，重复此过程，直到能在有限的时间内 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"消除所有的边"},{"Type":"NodeText","Data":" ，则不会发生死锁，否则会发生死锁。(消除边的过程类似于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"拓扑排序"},{"Type":"NodeText","Data":")","Properties":{"id":""}}]}]}]},{"ID":"20220906204030-2oa0n6c","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220906204030-2oa0n6c","updated":"20220906204030"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### ","Properties":{"id":""}},{"Type":"NodeText","Data":"死锁的解除","Properties":{"id":""}}]},{"ID":"20220906204031-6uts4wf","Type":"NodeParagraph","Properties":{"id":"20220906204031-6uts4wf","updated":"20220906204031"},"Children":[{"Type":"NodeText","Data":"当死锁检测程序检测到存在死锁发生时，应设法让其解除，让系统从死锁状态中恢复过来，常用的解除死锁的方法有以下四种：","Properties":{"id":""}}]},{"ID":"20220906204032-lo32a20","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204032-lo32a20","updated":"20220906204032"},"Children":[{"ID":"20220906204033-ljxkf4v","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204033-ljxkf4v","updated":"20220906204033"},"Children":[{"ID":"20220906204034-vw5jt2l","Type":"NodeParagraph","Properties":{"id":"20220906204034-vw5jt2l","updated":"20220906204034"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"立即结束所有进程的执行，重新启动操作系统"},{"Type":"NodeText","Data":" ：这种方法简单，但以前所在的工作全部作废，损失很大。","Properties":{"id":""}}]}]},{"ID":"20220906204035-uv0ihp0","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204035-uv0ihp0","updated":"20220906204035"},"Children":[{"ID":"20220906204036-r6o6ig2","Type":"NodeParagraph","Properties":{"id":"20220906204036-r6o6ig2","updated":"20220906204036"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"撤销涉及死锁的所有进程，解除死锁后继续运行"},{"Type":"NodeText","Data":" ：这种方法能彻底打破","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"死锁的循环等待"},{"Type":"NodeText","Data":"条件，但将付出很大代价，例如有些进程可能已经计算了很长时间，由于被撤销而使产生的部分结果也被消除了，再重新执行时还要再次进行计算。","Properties":{"id":""}}]}]},{"ID":"20220906204037-eklfybx","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204037-eklfybx","updated":"20220906204037"},"Children":[{"ID":"20220906204038-9rdc2lt","Type":"NodeParagraph","Properties":{"id":"20220906204038-9rdc2lt","updated":"20220906204038"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"逐个撤销涉及死锁的进程，回收其资源直至死锁解除。"}]}]},{"ID":"20220906204039-4v7xxeh","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204039-4v7xxeh","updated":"20220906204039"},"Children":[{"ID":"20220906204040-wl0lz4n","Type":"NodeParagraph","Properties":{"id":"20220906204040-wl0lz4n","updated":"20220906204040"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"抢占资源"},{"Type":"NodeText","Data":" ：从涉及死锁的一个或几个进程中抢占资源，把夺得的资源再分配给涉及死锁的进程直至死锁解除。","Properties":{"id":""}}]}]}]},{"ID":"20220906204041-4vipdve","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204041-4vipdve","updated":"20220906204041"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"操作系统内存管理基础","Properties":{"id":""}}]},{"ID":"20220906204042-9e6brpg","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204042-9e6brpg","updated":"20220906204042"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"内存管理介绍","Properties":{"id":""}}]},{"ID":"20220906204043-6zvtlks","Type":"NodeParagraph","Properties":{"id":"20220906204043-6zvtlks","updated":"20220906204043"},"Children":[{"Type":"NodeText","Data":"👨‍💻 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":": ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"操作系统的内存管理主要是做什么？"}]},{"ID":"20220906204044-8gi4lz8","Type":"NodeParagraph","Properties":{"id":"20220906204044-8gi4lz8","updated":"20220906204044"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我："},{"Type":"NodeText","Data":" 操作系统的内存管理主要负责内存的分配与回收（malloc 函数：申请内存，free 函数：释放内存），另外地址转换也就是将逻辑地址转换成相应的物理地址等功能也是操作系统内存管理做的事情。","Properties":{"id":""}}]},{"ID":"20220906204045-bjzgf65","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204045-bjzgf65","updated":"20220906204045"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"常见的几种内存管理机制","Properties":{"id":""}}]},{"ID":"20220906204046-aj6p6k8","Type":"NodeParagraph","Properties":{"id":"20220906204046-aj6p6k8","updated":"20220906204046"},"Children":[{"Type":"NodeText","Data":"👨‍💻 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":": ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"操作系统的内存管理机制了解吗？内存管理有哪几种方式?"}]},{"ID":"20220906204047-xf8s7ip","Type":"NodeParagraph","Properties":{"id":"20220906204047-xf8s7ip","updated":"20220906204047"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我："},{"Type":"NodeText","Data":" 这个在学习操作系统的时候有了解过。","Properties":{"id":""}}]},{"ID":"20220906204048-lrbwp44","Type":"NodeParagraph","Properties":{"id":"20220906204048-lrbwp44","updated":"20220906204048"},"Children":[{"Type":"NodeText","Data":"简单分为","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"连续分配管理方式"},{"Type":"NodeText","Data":"和","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"非连续分配管理方式"},{"Type":"NodeText","Data":"这两种。连续分配管理方式是指为一个用户程序分配一个连续的内存空间，常见的如 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"块式管理"},{"Type":"NodeText","Data":" 。同样地，非连续分配管理方式允许一个程序使用的内存分布在离散或者说不相邻的内存中，常见的如","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"页式管理"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"段式管理"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204049-rru333n","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204049-rru333n","updated":"20220906204049"},"Children":[{"ID":"20220906204050-2pbo4si","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204050-2pbo4si","updated":"20220906204050"},"Children":[{"ID":"20220906204051-mfcd845","Type":"NodeParagraph","Properties":{"id":"20220906204051-mfcd845","updated":"20220906204051"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"块式管理"},{"Type":"NodeText","Data":" ： 远古时代的计算机操作系统的内存管理方式。将内存分为几个固定大小的块，每个块中只包含一个进程。如果程序运行需要内存的话，操作系统就分配给它一块，如果程序运行只需要很小的空间的话，分配的这块内存很大一部分几乎被浪费了。这些在每个块中未被利用的空间，我们称之为碎片。","Properties":{"id":""}}]}]},{"ID":"20220906204052-kj498hf","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204052-kj498hf","updated":"20220906204052"},"Children":[{"ID":"20220906204053-9snbq1n","Type":"NodeParagraph","Properties":{"id":"20220906204053-9snbq1n","updated":"20220906204053"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"页式管理"},{"Type":"NodeText","Data":" ：把主存分为大小相等且固定的一页一页的形式，页较小，相比于块式管理的划分粒度更小，提高了内存利用率，减少了碎片。页式管理通过页表对应逻辑地址和物理地址。","Properties":{"id":""}}]}]},{"ID":"20220906204054-0yqe3jw","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204054-0yqe3jw","updated":"20220906204054"},"Children":[{"ID":"20220906204055-qbrfqrh","Type":"NodeParagraph","Properties":{"id":"20220906204055-qbrfqrh","updated":"20220906204055"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"段式管理"},{"Type":"NodeText","Data":" ： 页式管理虽然提高了内存利用率，但是页式管理其中的页并无任何实际意义。 段式管理把主存分为一段段的，段是有实际意义的，每个段定义了一组逻辑信息，例如,有主程序段 MAIN、子程序段 X、数据段 D 及栈段 S 等。 段式管理通过段表对应逻辑地址和物理地址。","Properties":{"id":""}}]}]}]},{"ID":"20220906204056-it4o8jm","Type":"NodeParagraph","Properties":{"id":"20220906204056-it4o8jm","updated":"20220906204056"},"Children":[{"Type":"NodeText","Data":"简单来说：页是物理单位，段是逻辑单位。分页可以有效提高内存利用率，分段可以更好满足用户需求。","Properties":{"id":""}}]},{"ID":"20220906204057-wnf6rc8","Type":"NodeParagraph","Properties":{"id":"20220906204057-wnf6rc8","updated":"20220906204057"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ： 回答的还不错！不过漏掉了一个很重要的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"段页式管理机制"},{"Type":"NodeText","Data":" 。段页式管理机制结合了段式管理和页式管理的优点。简单来说段页式管理机制就是把主存先分成若干段，每个段又分成若干页，也就是说 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"段页式管理机制"},{"Type":"NodeText","Data":" 中段与段之间以及段的内部的都是离散的。","Properties":{"id":""}}]},{"ID":"20220906204058-fshgbzy","Type":"NodeParagraph","Properties":{"id":"20220906204058-fshgbzy","updated":"20220906204058"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：谢谢面试官！刚刚把这个给忘记了～","Properties":{"id":""}}]},{"ID":"20220906204059-ezbb0zi","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204059-ezbb0zi","updated":"20220906204059"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"快表和多级页表","Properties":{"id":""}}]},{"ID":"20220906204060-wg0do7o","Type":"NodeParagraph","Properties":{"id":"20220906204060-wg0do7o","updated":"20220906204060"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ： 页表管理机制中有两个很重要的概念：快表和多级页表，这两个东西分别解决了页表管理中很重要的两个问题。你给我简单介绍一下吧！","Properties":{"id":""}}]},{"ID":"20220906204061-f8aw6ce","Type":"NodeParagraph","Properties":{"id":"20220906204061-f8aw6ce","updated":"20220906204061"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：在分页内存管理中，很重要的两点是：","Properties":{"id":""}}]},{"ID":"20220906204062-qu8j7ri","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204062-qu8j7ri","updated":"20220906204062"},"Children":[{"ID":"20220906204063-y4994vp","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204063-y4994vp","updated":"20220906204063"},"Children":[{"ID":"20220906204064-hwtisj1","Type":"NodeParagraph","Properties":{"id":"20220906204064-hwtisj1","updated":"20220906204064"},"Children":[{"Type":"NodeText","Data":"虚拟地址到物理地址的转换要快。","Properties":{"id":""}}]}]},{"ID":"20220906204065-s7o1geg","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204065-s7o1geg","updated":"20220906204065"},"Children":[{"ID":"20220906204066-u2kloyn","Type":"NodeParagraph","Properties":{"id":"20220906204066-u2kloyn","updated":"20220906204066"},"Children":[{"Type":"NodeText","Data":"解决虚拟地址空间大，页表也会很大的问题。","Properties":{"id":""}}]}]}]},{"ID":"20220906204067-amleby1","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204067-amleby1","updated":"20220906204067"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"快表","Properties":{"id":""}}]},{"ID":"20220906204068-u28ltz5","Type":"NodeParagraph","Properties":{"id":"20220906204068-u28ltz5","updated":"20220906204068"},"Children":[{"Type":"NodeText","Data":"为了提高虚拟地址到物理地址的转换速度，操作系统在 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"页表方案"},{"Type":"NodeText","Data":" 基础之上引入了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"快表"},{"Type":"NodeText","Data":" 来加速虚拟地址到物理地址的转换。我们可以把快表理解为一种特殊的高速缓冲存储器（Cache），其中的内容是页表的一部分或者全部内容。作为页表的 Cache，它的作用与页表相似，但是提高了访问速率。由于采用页表做地址转换，读写内存数据时 CPU 要访问两次主存。有了快表，有时只要访问一次高速缓冲存储器，一次主存，这样可加速查找并提高指令执行速度。","Properties":{"id":""}}]},{"ID":"20220906204069-yfl40ik","Type":"NodeParagraph","Properties":{"id":"20220906204069-yfl40ik","updated":"20220906204069"},"Children":[{"Type":"NodeText","Data":"使用快表之后的地址转换流程是这样的：","Properties":{"id":""}}]},{"ID":"20220906204070-vtn9xty","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204070-vtn9xty","updated":"20220906204070"},"Children":[{"ID":"20220906204071-zssyihi","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204071-zssyihi","updated":"20220906204071"},"Children":[{"ID":"20220906204072-qd7q6u5","Type":"NodeParagraph","Properties":{"id":"20220906204072-qd7q6u5","updated":"20220906204072"},"Children":[{"Type":"NodeText","Data":"根据虚拟地址中的页号查快表；","Properties":{"id":""}}]}]},{"ID":"20220906204073-rac5zi2","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204073-rac5zi2","updated":"20220906204073"},"Children":[{"ID":"20220906204074-7oy4yut","Type":"NodeParagraph","Properties":{"id":"20220906204074-7oy4yut","updated":"20220906204074"},"Children":[{"Type":"NodeText","Data":"如果该页在快表中，直接从快表中读取相应的物理地址；","Properties":{"id":""}}]}]},{"ID":"20220906204075-quzqdnj","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204075-quzqdnj","updated":"20220906204075"},"Children":[{"ID":"20220906204076-g3hh3k1","Type":"NodeParagraph","Properties":{"id":"20220906204076-g3hh3k1","updated":"20220906204076"},"Children":[{"Type":"NodeText","Data":"如果该页不在快表中，就访问内存中的页表，再从页表中得到物理地址，同时将页表中的该映射表项添加到快表中；","Properties":{"id":""}}]}]},{"ID":"20220906204077-emlikt5","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204077-emlikt5","updated":"20220906204077"},"Children":[{"ID":"20220906204078-0dx7kiw","Type":"NodeParagraph","Properties":{"id":"20220906204078-0dx7kiw","updated":"20220906204078"},"Children":[{"Type":"NodeText","Data":"当快表填满后，又要登记新页时，就按照一定的淘汰策略淘汰掉快表中的一个页。","Properties":{"id":""}}]}]}]},{"ID":"20220906204079-l50tqgu","Type":"NodeParagraph","Properties":{"id":"20220906204079-l50tqgu","updated":"20220906204079"},"Children":[{"Type":"NodeText","Data":"看完了之后你会发现快表和我们平时经常在我们开发的系统使用的缓存（比如 Redis）很像，的确是这样的，操作系统中的很多思想、很多经典的算法，你都可以在我们日常开发使用的各种工具或者框架中找到它们的影子。","Properties":{"id":""}}]},{"ID":"20220906204080-yy9ddf1","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204080-yy9ddf1","updated":"20220906204080"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"多级页表","Properties":{"id":""}}]},{"ID":"20220906204081-ba2sa60","Type":"NodeParagraph","Properties":{"id":"20220906204081-ba2sa60","updated":"20220906204081"},"Children":[{"Type":"NodeText","Data":"引入多级页表的主要目的是为了避免把全部页表一直放在内存中占用过多空间，特别是那些根本就不需要的页表就不需要保留在内存中。","Properties":{"id":""}}]},{"ID":"20220906204082-b83e5h9","Type":"NodeParagraph","Properties":{"id":"20220906204082-b83e5h9","updated":"20220906204082"},"Children":[{"Type":"NodeText","Data":"多级页表属于时间换空间的典型场景。","Properties":{"id":""}}]},{"ID":"20220906204083-0q5j7o7","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204083-0q5j7o7","updated":"20220906204083"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220906204084-dlvxi22","Type":"NodeParagraph","Properties":{"id":"20220906204084-dlvxi22","updated":"20220906204084"},"Children":[{"Type":"NodeText","Data":"为了提高内存的空间性能，提出了多级页表的概念；但是提到空间性能是以浪费时间性能为基础的，因此为了补充损失的时间性能，提出了快表（即 TLB）的概念。 不论是快表还是多级页表实际上都利用到了程序的局部性原理，局部性原理在后面的虚拟内存这部分会介绍到。","Properties":{"id":""}}]},{"ID":"20220906204085-398pel1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204085-398pel1","updated":"20220906204085"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"分页机制和分段机制的共同点和区别","Properties":{"id":""}}]},{"ID":"20220906204086-kk44d9y","Type":"NodeParagraph","Properties":{"id":"20220906204086-kk44d9y","updated":"20220906204086"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"分页机制和分段机制有哪些共同点和区别呢？"}]},{"ID":"20220906204087-jcm8jcu","Type":"NodeParagraph","Properties":{"id":"20220906204087-jcm8jcu","updated":"20220906204087"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204088-0b0gkmm","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204088-0b0gkmm","updated":"20220906204088"},"Children":[{"ID":"20220906204089-khy2a1p","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204089-khy2a1p","updated":"20220906204089"},"Children":[{"ID":"20220906204090-ghp9pex","Type":"NodeParagraph","Properties":{"id":"20220906204090-ghp9pex","updated":"20220906204090"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"共同点"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204091-b85ewyj","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204091-b85ewyj","updated":"20220906204091"},"Children":[{"ID":"20220906204092-splpz49","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204092-splpz49","updated":"20220906204092"},"Children":[{"ID":"20220906204093-1apqaiv","Type":"NodeParagraph","Properties":{"id":"20220906204093-1apqaiv","updated":"20220906204093"},"Children":[{"Type":"NodeText","Data":"分页机制和分段机制都是为了提高内存利用率，减少内存碎片。","Properties":{"id":""}}]}]},{"ID":"20220906204094-muxe3u0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204094-muxe3u0","updated":"20220906204094"},"Children":[{"ID":"20220906204095-j1u2tvi","Type":"NodeParagraph","Properties":{"id":"20220906204095-j1u2tvi","updated":"20220906204095"},"Children":[{"Type":"NodeText","Data":"页和段都是离散存储的，所以两者都是离散分配内存的方式。但是，每个页和段中的内存是连续的。","Properties":{"id":""}}]}]}]}]},{"ID":"20220906204096-iwcn435","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204096-iwcn435","updated":"20220906204096"},"Children":[{"ID":"20220906204097-cy0nti5","Type":"NodeParagraph","Properties":{"id":"20220906204097-cy0nti5","updated":"20220906204097"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"区别"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204098-jr2vbzn","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204098-jr2vbzn","updated":"20220906204098"},"Children":[{"ID":"20220906204099-o6hj2np","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204099-o6hj2np","updated":"20220906204099"},"Children":[{"ID":"20220906204100-1jx1yqv","Type":"NodeParagraph","Properties":{"id":"20220906204100-1jx1yqv","updated":"20220906204100"},"Children":[{"Type":"NodeText","Data":"页的大小是固定的，由操作系统决定；而段的大小不固定，取决于我们当前运行的程序。","Properties":{"id":""}}]}]},{"ID":"20220906204101-7biz00q","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204101-7biz00q","updated":"20220906204101"},"Children":[{"ID":"20220906204102-vrol2bw","Type":"NodeParagraph","Properties":{"id":"20220906204102-vrol2bw","updated":"20220906204102"},"Children":[{"Type":"NodeText","Data":"分页仅仅是为了满足操作系统内存管理的需求，而段是逻辑信息的单位，在程序中可以体现为代码段，数据段，能够更好满足用户的需要。","Properties":{"id":""}}]}]}]}]}]},{"ID":"20220906204103-w5gmn79","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204103-w5gmn79","updated":"20220906204103"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"逻辑(虚拟)地址和物理地址","Properties":{"id":""}}]},{"ID":"20220906204104-j5qt3ah","Type":"NodeParagraph","Properties":{"id":"20220906204104-j5qt3ah","updated":"20220906204104"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：你刚刚还提到了","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"逻辑地址和物理地址"},{"Type":"NodeText","Data":"这两个概念，我不太清楚，你能为我解释一下不？","Properties":{"id":""}}]},{"ID":"20220906204105-6wpyz62","Type":"NodeParagraph","Properties":{"id":"20220906204105-6wpyz62","updated":"20220906204105"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我："},{"Type":"NodeText","Data":" em...好的嘛！我们编程一般只有可能和逻辑地址打交道，比如在 C 语言中，指针里面存储的数值就可以理解成为内存里的一个地址，这个地址也就是我们说的逻辑地址，逻辑地址由操作系统决定。物理地址指的是真实物理内存中地址，更具体一点来说就是内存地址寄存器中的地址。物理地址是内存单元真正的地址。","Properties":{"id":""}}]},{"ID":"20220906204106-xc9a0of","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204106-xc9a0of","updated":"20220906204106"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"CPU 寻址了解吗?为什么需要虚拟地址空间?","Properties":{"id":""}}]},{"ID":"20220906204107-ioi5137","Type":"NodeParagraph","Properties":{"id":"20220906204107-ioi5137","updated":"20220906204107"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"CPU 寻址了解吗?为什么需要虚拟地址空间?"}]},{"ID":"20220906204108-9xb4359","Type":"NodeParagraph","Properties":{"id":"20220906204108-9xb4359","updated":"20220906204108"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：这部分我真不清楚！","Properties":{"id":""}}]},{"ID":"20220906204109-s4l4nqk","Type":"NodeParagraph","Properties":{"id":"20220906204109-s4l4nqk","updated":"20220906204109"},"Children":[{"Type":"NodeText","Data":"于是面试完之后我默默去查阅了相关文档！留下了没有技术的泪水。。。","Properties":{"id":""}}]},{"ID":"20220906204110-t0gqnmy","Type":"NodeBlockquote","Properties":{"id":"20220906204110-t0gqnmy","updated":"20220906204110"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204111-9i14fp5","Type":"NodeParagraph","Properties":{"id":"20220906204111-9i14fp5","updated":"20220906204111"},"Children":[{"Type":"NodeText","Data":"这部分内容参考了 Microsoft 官网的介绍，地址：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://docs.microsoft.com/zh-cn/windows-hardware/drivers/gettingstarted/virtual-address-spaces?redirectedfrom=MSDN","TextMarkTextContent":"https://docs.microsoft.com/zh-cn/windows-hardware/drivers/gettingstarted/virtual-address-spaces?redirectedfrom=MSDN"}]}]},{"ID":"20220906204112-ywlhbqt","Type":"NodeParagraph","Properties":{"id":"20220906204112-ywlhbqt","updated":"20220906204112"},"Children":[{"Type":"NodeText","Data":"现代处理器使用的是一种称为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟寻址(Virtual Addressing)"},{"Type":"NodeText","Data":" 的寻址方式。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"使用虚拟寻址，CPU 需要将虚拟地址翻译成物理地址，这样才能访问到真实的物理内存。"},{"Type":"NodeText","Data":" 实际上完成虚拟地址转换为物理地址转换的硬件是 CPU 中含有一个被称为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"内存管理单元（Memory Management Unit, MMU）"},{"Type":"NodeText","Data":" 的硬件。如下图所示：","Properties":{"id":""}}]},{"ID":"20220906204113-hgsbc3n","Type":"NodeParagraph","Properties":{"id":"20220906204113-hgsbc3n","updated":"20220906204113"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"MMU_principle_updated","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://my-blog-to-use.oss-cn-beijing.aliyuncs.com/2019-11/2b27dac8cc647f8aac989da2d1166db2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204114-2q0y8he","Type":"NodeParagraph","Properties":{"id":"20220906204114-2q0y8he","updated":"20220906204114"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"为什么要有虚拟地址空间呢？"}]},{"ID":"20220906204115-jliylwh","Type":"NodeParagraph","Properties":{"id":"20220906204115-jliylwh","updated":"20220906204115"},"Children":[{"Type":"NodeText","Data":"先从没有虚拟地址空间的时候说起吧！没有虚拟地址空间的时候，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"程序直接访问和操作的都是物理内存"},{"Type":"NodeText","Data":" 。但是这样有什么问题呢？","Properties":{"id":""}}]},{"ID":"20220906204116-sgzzr20","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204116-sgzzr20","updated":"20220906204116"},"Children":[{"ID":"20220906204117-hkq42vh","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204117-hkq42vh","updated":"20220906204117"},"Children":[{"ID":"20220906204118-5nvfwr9","Type":"NodeParagraph","Properties":{"id":"20220906204118-5nvfwr9","updated":"20220906204118"},"Children":[{"Type":"NodeText","Data":"用户程序可以访问任意内存，寻址内存的每个字节，这样就很容易（有意或者无意）破坏操作系统，造成操作系统崩溃。","Properties":{"id":""}}]}]},{"ID":"20220906204119-76plj6a","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204119-76plj6a","updated":"20220906204119"},"Children":[{"ID":"20220906204120-y0o3vr3","Type":"NodeParagraph","Properties":{"id":"20220906204120-y0o3vr3","updated":"20220906204120"},"Children":[{"Type":"NodeText","Data":"想要同时运行多个程序特别困难，比如你想同时运行一个微信和一个 QQ 音乐都不行。为什么呢？举个简单的例子：微信在运行的时候给内存地址 1xxx 赋值后，QQ 音乐也同样给内存地址 1xxx 赋值，那么 QQ 音乐对内存的赋值就会覆盖微信之前所赋的值，这就造成了微信这个程序就会崩溃。","Properties":{"id":""}}]}]}]},{"ID":"20220906204121-mxmmwhu","Type":"NodeParagraph","Properties":{"id":"20220906204121-mxmmwhu","updated":"20220906204121"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"总结来说：如果直接把物理地址暴露出来的话会带来严重问题，比如可能对操作系统造成伤害以及给同时运行多个程序造成困难。"}]},{"ID":"20220906204122-7fsfd54","Type":"NodeParagraph","Properties":{"id":"20220906204122-7fsfd54","updated":"20220906204122"},"Children":[{"Type":"NodeText","Data":"通过虚拟地址访问内存有以下优势：","Properties":{"id":""}}]},{"ID":"20220906204123-rx4krmd","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204123-rx4krmd","updated":"20220906204123"},"Children":[{"ID":"20220906204124-uvx6h0i","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204124-uvx6h0i","updated":"20220906204124"},"Children":[{"ID":"20220906204125-3mxwd4j","Type":"NodeParagraph","Properties":{"id":"20220906204125-3mxwd4j","updated":"20220906204125"},"Children":[{"Type":"NodeText","Data":"程序可以使用一系列相邻的虚拟地址来访问物理内存中不相邻的大内存缓冲区。","Properties":{"id":""}}]}]},{"ID":"20220906204126-hg9d7zm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204126-hg9d7zm","updated":"20220906204126"},"Children":[{"ID":"20220906204127-qnpqyho","Type":"NodeParagraph","Properties":{"id":"20220906204127-qnpqyho","updated":"20220906204127"},"Children":[{"Type":"NodeText","Data":"程序可以使用一系列虚拟地址来访问大于可用物理内存的内存缓冲区。当物理内存的供应量变小时，内存管理器会将物理内存页（通常大小为 4 KB）保存到磁盘文件。数据或代码页会根据需要在物理内存与磁盘之间移动。","Properties":{"id":""}}]}]},{"ID":"20220906204128-8x2nv1t","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204128-8x2nv1t","updated":"20220906204128"},"Children":[{"ID":"20220906204129-ti7ocqn","Type":"NodeParagraph","Properties":{"id":"20220906204129-ti7ocqn","updated":"20220906204129"},"Children":[{"Type":"NodeText","Data":"不同进程使用的虚拟地址彼此隔离。一个进程中的代码无法更改正在由另一进程或操作系统使用的物理内存。","Properties":{"id":""}}]}]}]},{"ID":"20220906204130-dsxovc6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204130-dsxovc6","updated":"20220906204130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"虚拟内存","Properties":{"id":""}}]},{"ID":"20220906204131-1zdfylj","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204131-1zdfylj","updated":"20220906204131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是虚拟内存(Virtual Memory)?","Properties":{"id":""}}]},{"ID":"20220906204132-rwummyl","Type":"NodeParagraph","Properties":{"id":"20220906204132-rwummyl","updated":"20220906204132"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：再问你一个常识性的问题！","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"什么是虚拟内存(Virtual Memory)?"}]},{"ID":"20220906204133-jq95iim","Type":"NodeParagraph","Properties":{"id":"20220906204133-jq95iim","updated":"20220906204133"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：这个在我们平时使用电脑特别是 Windows 系统的时候太常见了。很多时候我们使用了很多占内存的软件，这些软件占用的内存可能已经远远超出了我们电脑本身具有的物理内存。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"为什么可以这样呢？"},{"Type":"NodeText","Data":" 正是因为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存"},{"Type":"NodeText","Data":" 的存在，通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存"},{"Type":"NodeText","Data":" 可以让程序可以拥有超过系统物理内存大小的可用内存空间。另外，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存为每个进程提供了一个一致的、私有的地址空间，它让每个进程产生了一种自己在独享主存的错觉（每个进程拥有一片连续完整的内存空间）"},{"Type":"NodeText","Data":"。这样会更加有效地管理内存并减少出错。","Properties":{"id":""}}]},{"ID":"20220906204134-yj7b97z","Type":"NodeParagraph","Properties":{"id":"20220906204134-yj7b97z","updated":"20220906204134"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存"},{"Type":"NodeText","Data":"是计算机系统内存管理的一种技术，我们可以手动设置自己电脑的虚拟内存。不要单纯认为虚拟内存只是“使用硬盘空间来扩展内存“的技术。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存的重要意义是它定义了一个连续的虚拟地址空间"},{"Type":"NodeText","Data":"，并且 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"把内存扩展到硬盘空间"},{"Type":"NodeText","Data":"。推荐阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://juejin.im/post/59f8691b51882534af254317","TextMarkTextContent":"《虚拟内存的那点事儿》"}]},{"ID":"20220906204135-zz7hylm","Type":"NodeParagraph","Properties":{"id":"20220906204135-zz7hylm","updated":"20220906204135"},"Children":[{"Type":"NodeText","Data":"维基百科中有几句话是这样介绍虚拟内存的。","Properties":{"id":""}}]},{"ID":"20220906204136-xr9hna0","Type":"NodeBlockquote","Properties":{"id":"20220906204136-xr9hna0","updated":"20220906204136"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204137-k5ddks8","Type":"NodeParagraph","Properties":{"id":"20220906204137-k5ddks8","updated":"20220906204137"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存"},{"Type":"NodeText","Data":" 使得应用程序认为它拥有连续的可用的内存（一个连续完整的地址空间），而实际上，它通常是被分隔成多个物理内存碎片，还有部分暂时存储在外部磁盘存储器上，在需要时进行数据交换。与没有使用虚拟内存技术的系统相比，使用这种技术的系统使得大型程序的编写变得更容易，对真正的物理内存（例如 RAM）的使用也更有效率。目前，大多数操作系统都使用了虚拟内存，如 Windows 家族的“虚拟内存”；Linux 的“交换空间”等。From:","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://zh.wikipedia.org/wiki/%E8%99%9A%E6%8B%9F%E5%86%85%E5%AD%98","TextMarkTextContent":"https://zh.wikipedia.org/wiki/虚拟内存"}]}]},{"ID":"20220906204138-qpvdexe","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204138-qpvdexe","updated":"20220906204138"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"局部性原理","Properties":{"id":""}}]},{"ID":"20220906204139-wzv9jqt","Type":"NodeParagraph","Properties":{"id":"20220906204139-wzv9jqt","updated":"20220906204139"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：要想更好地理解虚拟内存技术，必须要知道计算机中著名的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"局部性原理"},{"Type":"NodeText","Data":"。另外，局部性原理既适用于程序结构，也适用于数据结构，是非常重要的一个概念。","Properties":{"id":""}}]},{"ID":"20220906204140-1cfru6v","Type":"NodeParagraph","Properties":{"id":"20220906204140-1cfru6v","updated":"20220906204140"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：局部性原理是虚拟内存技术的基础，正是因为程序运行具有局部性原理，才可以只装入部分程序到内存就开始运行。","Properties":{"id":""}}]},{"ID":"20220906204141-bvhv5rx","Type":"NodeBlockquote","Properties":{"id":"20220906204141-bvhv5rx","updated":"20220906204141"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204142-uadkvf8","Type":"NodeParagraph","Properties":{"id":"20220906204142-uadkvf8","updated":"20220906204142"},"Children":[{"Type":"NodeText","Data":"以下内容摘自《计算机操作系统教程》 第 4 章存储器管理。","Properties":{"id":""}}]}]},{"ID":"20220906204143-t042vdu","Type":"NodeParagraph","Properties":{"id":"20220906204143-t042vdu","updated":"20220906204143"},"Children":[{"Type":"NodeText","Data":"早在 1968 年的时候，就有人指出我们的程序在执行的时候往往呈现局部性规律，也就是说在某个较短的时间段内，程序执行局限于某一小部分，程序访问的存储空间也局限于某个区域。","Properties":{"id":""}}]},{"ID":"20220906204144-stn1xbl","Type":"NodeParagraph","Properties":{"id":"20220906204144-stn1xbl","updated":"20220906204144"},"Children":[{"Type":"NodeText","Data":"局部性原理表现在以下两个方面：","Properties":{"id":""}}]},{"ID":"20220906204145-kzagp94","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204145-kzagp94","updated":"20220906204145"},"Children":[{"ID":"20220906204146-zp9vpqu","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204146-zp9vpqu","updated":"20220906204146"},"Children":[{"ID":"20220906204147-g1q1ha8","Type":"NodeParagraph","Properties":{"id":"20220906204147-g1q1ha8","updated":"20220906204147"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"时间局部性"},{"Type":"NodeText","Data":" ：如果程序中的某条指令一旦执行，不久以后该指令可能再次执行；如果某数据被访问过，不久以后该数据可能再次被访问。产生时间局部性的典型原因，是由于在程序中存在着大量的循环操作。","Properties":{"id":""}}]}]},{"ID":"20220906204148-s7hns7k","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204148-s7hns7k","updated":"20220906204148"},"Children":[{"ID":"20220906204149-spuowrt","Type":"NodeParagraph","Properties":{"id":"20220906204149-spuowrt","updated":"20220906204149"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"空间局部性"},{"Type":"NodeText","Data":" ：一旦程序访问了某个存储单元，在不久之后，其附近的存储单元也将被访问，即程序在一段时间内所访问的地址，可能集中在一定的范围之内，这是因为指令通常是顺序存放、顺序执行的，数据也一般是以向量、数组、表等形式簇聚存储的。","Properties":{"id":""}}]}]}]},{"ID":"20220906204150-9yc6uc8","Type":"NodeParagraph","Properties":{"id":"20220906204150-9yc6uc8","updated":"20220906204150"},"Children":[{"Type":"NodeText","Data":"时间局部性是通过将近来使用的指令和数据保存到高速缓存存储器中，并使用高速缓存的层次结构实现。空间局部性通常是使用较大的高速缓存，并将预取机制集成到高速缓存控制逻辑中实现。虚拟内存技术实际上就是建立了 “内存一外存”的两级存储器的结构，利用局部性原理实现髙速缓存。","Properties":{"id":""}}]},{"ID":"20220906204151-yljqipr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204151-yljqipr","updated":"20220906204151"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"虚拟存储器","Properties":{"id":""}}]},{"ID":"20220906204152-bnzfy3g","Type":"NodeBlockquote","Properties":{"id":"20220906204152-bnzfy3g","updated":"20220906204152"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204153-c1f31x7","Type":"NodeParagraph","Properties":{"id":"20220906204153-c1f31x7","updated":"20220906204153"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"勘误：虚拟存储器又叫做虚拟内存，都是 Virtual Memory 的翻译，属于同一个概念。"}]}]},{"ID":"20220906204154-ap0ntxp","Type":"NodeParagraph","Properties":{"id":"20220906204154-ap0ntxp","updated":"20220906204154"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"s","TextMarkTextContent":"都说了虚拟内存了。你再讲讲"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"s strong","TextMarkTextContent":"虚拟存储器"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"s","TextMarkTextContent":"把！"}]},{"ID":"20220906204155-qryonql","Type":"NodeParagraph","Properties":{"id":"20220906204155-qryonql","updated":"20220906204155"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204156-sfhtcg1","Type":"NodeBlockquote","Properties":{"id":"20220906204156-sfhtcg1","updated":"20220906204156"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204157-z3yf0x8","Type":"NodeParagraph","Properties":{"id":"20220906204157-z3yf0x8","updated":"20220906204157"},"Children":[{"Type":"NodeText","Data":"这部分内容来自：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://wizardforcel.gitbooks.io/wangdaokaoyan-os/content/13.html","TextMarkTextContent":"王道考研操作系统知识点整理"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]}]},{"ID":"20220906204158-6uy883t","Type":"NodeParagraph","Properties":{"id":"20220906204158-6uy883t","updated":"20220906204158"},"Children":[{"Type":"NodeText","Data":"基于局部性原理，在程序装入时，可以将程序的一部分装入内存，而将其他部分留在外存，就可以启动程序执行。由于外存往往比内存大很多，所以我们运行的软件的内存大小实际上是可以比计算机系统实际的内存大小大的。在程序执行过程中，当所访问的信息不在内存时，由操作系统将所需要的部分调入内存，然后继续执行程序。另一方面，操作系统将内存中暂时不使用的内容换到外存上，从而腾出空间存放将要调入内存的信息。这样，计算机好像为用户提供了一个比实际内存大得多的存储器——","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟存储器"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204159-ch1o694","Type":"NodeParagraph","Properties":{"id":"20220906204159-ch1o694","updated":"20220906204159"},"Children":[{"Type":"NodeText","Data":"实际上，我觉得虚拟内存同样是一种时间换空间的策略，你用 CPU 的计算时间，页的调入调出花费的时间，换来了一个虚拟的更大的空间来支持程序的运行。不得不感叹，程序世界几乎不是时间换空间就是空间换时间。","Properties":{"id":""}}]},{"ID":"20220906204160-otrbov8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204160-otrbov8","updated":"20220906204160"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"虚拟内存的技术实现","Properties":{"id":""}}]},{"ID":"20220906204161-c9hzw14","Type":"NodeParagraph","Properties":{"id":"20220906204161-c9hzw14","updated":"20220906204161"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存技术的实现呢？"}]},{"ID":"20220906204162-wenxgtn","Type":"NodeParagraph","Properties":{"id":"20220906204162-wenxgtn","updated":"20220906204162"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟内存的实现需要建立在离散分配的内存管理方式的基础上。"},{"Type":"NodeText","Data":" 虚拟内存的实现有以下三种方式：","Properties":{"id":""}}]},{"ID":"20220906204163-227x94b","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204163-227x94b","updated":"20220906204163"},"Children":[{"ID":"20220906204164-vvnwpv3","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204164-vvnwpv3","updated":"20220906204164"},"Children":[{"ID":"20220906204165-ke01trh","Type":"NodeParagraph","Properties":{"id":"20220906204165-ke01trh","updated":"20220906204165"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"请求分页存储管理"},{"Type":"NodeText","Data":" ：建立在分页管理之上，为了支持虚拟存储器功能而增加了请求调页功能和页面置换功能。请求分页是目前最常用的一种实现虚拟存储器的方法。请求分页存储管理系统中，在作业开始运行之前，仅装入当前要执行的部分段即可运行。假如在作业运行的过程中发现要访问的页面不在内存，则由处理器通知操作系统按照对应的页面置换算法将相应的页面调入到主存，同时操作系统也可以将暂时不用的页面置换到外存中。","Properties":{"id":""}}]}]},{"ID":"20220906204166-x6mxzmc","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204166-x6mxzmc","updated":"20220906204166"},"Children":[{"ID":"20220906204167-8gl8mi9","Type":"NodeParagraph","Properties":{"id":"20220906204167-8gl8mi9","updated":"20220906204167"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"请求分段存储管理"},{"Type":"NodeText","Data":" ：建立在分段存储管理之上，增加了请求调段功能、分段置换功能。请求分段储存管理方式就如同请求分页储存管理方式一样，在作业开始运行之前，仅装入当前要执行的部分段即可运行；在执行过程中，可使用请求调入中断动态装入要访问但又不在内存的程序段；当内存空间已满，而又需要装入新的段时，根据置换功能适当调出某个段，以便腾出空间而装入新的段。","Properties":{"id":""}}]}]},{"ID":"20220906204168-1hnli71","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204168-1hnli71","updated":"20220906204168"},"Children":[{"ID":"20220906204169-6cscujn","Type":"NodeParagraph","Properties":{"id":"20220906204169-6cscujn","updated":"20220906204169"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"请求段页式存储管理"}]}]}]},{"ID":"20220906204170-wpr9cpa","Type":"NodeParagraph","Properties":{"id":"20220906204170-wpr9cpa","updated":"20220906204170"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"这里多说一下？很多人容易搞混请求分页与分页存储管理，两者有何不同呢？"}]},{"ID":"20220906204171-t0jfe81","Type":"NodeParagraph","Properties":{"id":"20220906204171-t0jfe81","updated":"20220906204171"},"Children":[{"Type":"NodeText","Data":"请求分页存储管理建立在分页管理之上。他们的根本区别是是否将程序全部所需的全部地址空间都装入主存，这也是请求分页存储管理可以提供虚拟内存的原因，我们在上面已经分析过了。","Properties":{"id":""}}]},{"ID":"20220906204172-hltg98x","Type":"NodeParagraph","Properties":{"id":"20220906204172-hltg98x","updated":"20220906204172"},"Children":[{"Type":"NodeText","Data":"它们之间的根本区别在于是否将一作业的全部地址空间同时装入主存。请求分页存储管理不要求将作业全部地址空间同时装入主存。基于这一点，请求分页存储管理可以提供虚存，而分页存储管理却不能提供虚存。","Properties":{"id":""}}]},{"ID":"20220906204173-suradhi","Type":"NodeParagraph","Properties":{"id":"20220906204173-suradhi","updated":"20220906204173"},"Children":[{"Type":"NodeText","Data":"不管是上面那种实现方式，我们一般都需要：","Properties":{"id":""}}]},{"ID":"20220906204174-cxxkzr3","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204174-cxxkzr3","updated":"20220906204174"},"Children":[{"ID":"20220906204175-4eka008","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204175-4eka008","updated":"20220906204175"},"Children":[{"ID":"20220906204176-pedlfyw","Type":"NodeParagraph","Properties":{"id":"20220906204176-pedlfyw","updated":"20220906204176"},"Children":[{"Type":"NodeText","Data":"一定容量的内存和外存：在载入程序的时候，只需要将程序的一部分装入内存，而将其他部分留在外存，然后程序就可以执行了；","Properties":{"id":""}}]}]},{"ID":"20220906204177-lorh2fd","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204177-lorh2fd","updated":"20220906204177"},"Children":[{"ID":"20220906204178-8jyd99p","Type":"NodeParagraph","Properties":{"id":"20220906204178-8jyd99p","updated":"20220906204178"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺页中断"},{"Type":"NodeText","Data":"：如果","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"需执行的指令或访问的数据尚未在内存"},{"Type":"NodeText","Data":"（称为缺页或缺段），则由处理器通知操作系统将相应的页面或段","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"调入到内存"},{"Type":"NodeText","Data":"，然后继续执行程序；","Properties":{"id":""}}]}]},{"ID":"20220906204179-ds51uyb","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204179-ds51uyb","updated":"20220906204179"},"Children":[{"ID":"20220906204180-6byj6ky","Type":"NodeParagraph","Properties":{"id":"20220906204180-6byj6ky","updated":"20220906204180"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虚拟地址空间"},{"Type":"NodeText","Data":" ：逻辑地址到物理地址的变换。","Properties":{"id":""}}]}]}]},{"ID":"20220906204181-xun525z","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204181-xun525z","updated":"20220906204181"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"页面置换算法","Properties":{"id":""}}]},{"ID":"20220906204182-tt444mx","Type":"NodeParagraph","Properties":{"id":"20220906204182-tt444mx","updated":"20220906204182"},"Children":[{"Type":"NodeText","Data":"👨‍💻","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"面试官"},{"Type":"NodeText","Data":" ：虚拟内存管理很重要的一个概念就是页面置换算法。那你说一下 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"页面置换算法的作用?常见的页面置换算法有哪些?"}]},{"ID":"20220906204183-bmyu8dp","Type":"NodeParagraph","Properties":{"id":"20220906204183-bmyu8dp","updated":"20220906204183"},"Children":[{"Type":"NodeText","Data":"🙋 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"我"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906204184-adaokj2","Type":"NodeBlockquote","Properties":{"id":"20220906204184-adaokj2","updated":"20220906204184"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204185-sba1j46","Type":"NodeParagraph","Properties":{"id":"20220906204185-sba1j46","updated":"20220906204185"},"Children":[{"Type":"NodeText","Data":"这个题目经常作为笔试题出现，网上已经给出了很不错的回答，我这里只是总结整理了一下。","Properties":{"id":""}}]}]},{"ID":"20220906204186-3qzvwiy","Type":"NodeParagraph","Properties":{"id":"20220906204186-3qzvwiy","updated":"20220906204186"},"Children":[{"Type":"NodeText","Data":"地址映射过程中，若在页面中发现所要访问的页面不在内存中，则发生缺页中断 。","Properties":{"id":""}}]},{"ID":"20220906204187-gy54t5l","Type":"NodeBlockquote","Properties":{"id":"20220906204187-gy54t5l","updated":"20220906204187"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906204188-0elescq","Type":"NodeParagraph","Properties":{"id":"20220906204188-0elescq","updated":"20220906204188"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缺页中断"},{"Type":"NodeText","Data":" 就是要访问的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"页"},{"Type":"NodeText","Data":"不在主存，需要操作系统将其调入主存后再进行访问。 在这个时候，被内存映射的文件实际上成了一个分页交换文件。","Properties":{"id":""}}]}]},{"ID":"20220906204189-3ak7xf3","Type":"NodeParagraph","Properties":{"id":"20220906204189-3ak7xf3","updated":"20220906204189"},"Children":[{"Type":"NodeText","Data":"当发生缺页中断时，如果当前内存中并没有空闲的页面，操作系统就必须在内存选择一个页面将其移出内存，以便为即将调入的页面让出空间。用来选择淘汰哪一页的规则叫做页面置换算法，我们可以把页面置换算法看成是淘汰页面的规则。","Properties":{"id":""}}]},{"ID":"20220906204190-lxx4hy3","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204190-lxx4hy3","updated":"20220906204190"},"Children":[{"ID":"20220906204191-r79g602","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204191-r79g602","updated":"20220906204191"},"Children":[{"ID":"20220906204192-864zuk9","Type":"NodeParagraph","Properties":{"id":"20220906204192-864zuk9","updated":"20220906204192"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"OPT 页面置换算法（最佳页面置换算法）"},{"Type":"NodeText","Data":" ：最佳(Optimal, OPT)置换算法所选择的被淘汰页面将是以后永不使用的，或者是在最长时间内不再被访问的页面,这样可以保证获得最低的缺页率。但由于人们目前无法预知进程在内存下的若千页面中哪个是未来最长时间内不再被访问的，因而该算法无法实现。一般作为衡量其他置换算法的方法。","Properties":{"id":""}}]}]},{"ID":"20220906204193-apq2y64","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204193-apq2y64","updated":"20220906204193"},"Children":[{"ID":"20220906204194-zn5x069","Type":"NodeParagraph","Properties":{"id":"20220906204194-zn5x069","updated":"20220906204194"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"FIFO（First In First Out） 页面置换算法（先进先出页面置换算法）"},{"Type":"NodeText","Data":" : 总是淘汰最先进入内存的页面，即选择在内存中驻留时间最久的页面进行淘汰。","Properties":{"id":""}}]}]},{"ID":"20220906204195-upaoszb","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204195-upaoszb","updated":"20220906204195"},"Children":[{"ID":"20220906204196-aecvage","Type":"NodeParagraph","Properties":{"id":"20220906204196-aecvage","updated":"20220906204196"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"LRU （Least Recently Used）页面置换算法（最近最久未使用页面置换算法）"},{"Type":"NodeText","Data":" ：LRU 算法赋予每个页面一个访问字段，用来记录一个页面自上次被访问以来所经历的时间 T，当须淘汰一个页面时，选择现有页面中其 T 值最大的，即最近最久未使用的页面予以淘汰。","Properties":{"id":""}}]}]},{"ID":"20220906204197-sbckx22","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204197-sbckx22","updated":"20220906204197"},"Children":[{"ID":"20220906204198-jc6jid6","Type":"NodeParagraph","Properties":{"id":"20220906204198-jc6jid6","updated":"20220906204198"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"LFU （Least Frequently Used）页面置换算法（最少使用页面置换算法）"},{"Type":"NodeText","Data":" : 该置换算法选择在之前时期使用最少的页面作为淘汰页。","Properties":{"id":""}}]}]}]}]}