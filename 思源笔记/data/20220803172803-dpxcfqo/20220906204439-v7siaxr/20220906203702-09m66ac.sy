lockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203848-vpbsad7","updated":"20220906203848"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003e BITOP and desk1 20210308 20210309\n(integer) 1\n\u003e BITCOUNT desk1\n(integer) 1\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203849-boz4pbb","Type":"NodeParagraph","Properties":{"id":"20220906203849-boz4pbb","updated":"20220906203849"},"Children":[{"Type":"NodeText","Data":"统计 20210308~20210309 在线活跃用户数:","Properties":{"id":""}}]},{"ID":"20220906203850-0vca827","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203850-0vca827","updated":"20220906203850"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003e BITOP or desk2 20210308 20210309\n(integer) 1\n\u003e BITCOUNT desk2\n(integer) 2\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203851-k5jpse7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203851-k5jpse7","updated":"20220906203851"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"使用 HyperLogLog 统计页面 UV 怎么做？","Properties":{"id":""}}]},{"ID":"20220906203852-396zuog","Type":"NodeParagraph","Properties":{"id":"20220906203852-396zuog","updated":"20220906203852"},"Children":[{"Type":"NodeText","Data":"1、将访问指定页面的每个用户 ID 添加到 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"HyperLogLog"},{"Type":"NodeText","Data":" 中。","Properties":{"id":""}}]},{"ID":"20220906203853-wrj1dx3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203853-wrj1dx3","updated":"20220906203853"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"PFADD PAGE_1:UV USER1 USER2 ...... USERn\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203854-aqynx50","Type":"NodeParagraph","Properties":{"id":"20220906203854-aqynx50","updated":"20220906203854"},"Children":[{"Type":"NodeText","Data":"2、统计指定页面的 UV。","Properties":{"id":""}}]},{"ID":"20220906203855-1fovmh2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203855-1fovmh2","updated":"20220906203855"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"PFCOUNT PAGE_1:UV\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203856-c64f2k2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203856-c64f2k2","updated":"20220906203856"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 线程模型","Properties":{"id":""}}]},{"ID":"20220906203857-5vuhkk0","Type":"NodeParagraph","Properties":{"id":"20220906203857-5vuhkk0","updated":"20220906203857"},"Children":[{"Type":"NodeText","Data":"对于读写命令来说，Redis 一直是单线程模型。不过，在 Redis 4.0 版本之后引入了多线程来执行一些大键值对的异步删除操作， Redis 6.0 版本之后引入了多线程来处理网络请求（提高网络 IO 读写性能）。","Properties":{"id":""}}]},{"ID":"20220906203858-vrp15r6","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203858-vrp15r6","updated":"20220906203858"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 单线程模型了解吗？","Properties":{"id":""}}]},{"ID":"20220906203859-ptav5y8","Type":"NodeParagraph","Properties":{"id":"20220906203859-ptav5y8","updated":"20220906203859"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 基于 Reactor 模式来设计开发了自己的一套高效的事件处理模型"},{"Type":"NodeText","Data":" （Netty 的线程模型也基于 Reactor 模式，Reactor 模式不愧是高性能 IO 的基石），这套事件处理模型对应的是 Redis 中的文件事件处理器（file event handler）。由于文件事件处理器（file event handler）是单线程方式运行的，所以我们一般都说 Redis 是单线程模型。","Properties":{"id":""}}]},{"ID":"20220906203860-mn4vwt4","Type":"NodeParagraph","Properties":{"id":"20220906203860-mn4vwt4","updated":"20220906203860"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"既然是单线程，那怎么监听大量的客户端连接呢？"}]},{"ID":"20220906203861-15lbayj","Type":"NodeParagraph","Properties":{"id":"20220906203861-15lbayj","updated":"20220906203861"},"Children":[{"Type":"NodeText","Data":"Redis 通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"IO 多路复用程序"},{"Type":"NodeText","Data":" 来监听来自客户端的大量连接（或者说是监听多个 socket），它会将感兴趣的事件及类型（读、写）注册到内核中并监听每个事件是否发生。","Properties":{"id":""}}]},{"ID":"20220906203862-ltwg7dt","Type":"NodeParagraph","Properties":{"id":"20220906203862-ltwg7dt","updated":"20220906203862"},"Children":[{"Type":"NodeText","Data":"这样的好处非常明显： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"I/O 多路复用技术的使用让 Redis 不需要额外创建多余的线程来监听客户端的大量连接，降低了资源的消耗"},{"Type":"NodeText","Data":"（和 NIO 中的 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"Selector"},{"Type":"NodeText","Data":" 组件很像）。","Properties":{"id":""}}]},{"ID":"20220906203863-eyuesjr","Type":"NodeParagraph","Properties":{"id":"20220906203863-eyuesjr","updated":"20220906203863"},"Children":[{"Type":"NodeText","Data":"另外， Redis 服务器是一个事件驱动程序，服务器需要处理两类事件：","Properties":{"id":""}}]},{"ID":"20220906203864-b56f7x3","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203864-b56f7x3","updated":"20220906203864"},"Children":[{"ID":"20220906203865-qom4fpr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203865-qom4fpr","updated":"20220906203865"},"Children":[{"ID":"20220906203866-6lt7aw2","Type":"NodeParagraph","Properties":{"id":"20220906203866-6lt7aw2","updated":"20220906203866"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"文件事件(file event)"},{"Type":"NodeText","Data":" ：用于处理 Redis 服务器和客户端之间的网络 IO。","Properties":{"id":""}}]}]},{"ID":"20220906203867-xdmuv9z","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203867-xdmuv9z","updated":"20220906203867"},"Children":[{"ID":"20220906203868-8u2775p","Type":"NodeParagraph","Properties":{"id":"20220906203868-8u2775p","updated":"20220906203868"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"时间事件(time eveat)"},{"Type":"NodeText","Data":" ：Redis 服务器中的一些操作（比如 serverCron 函数）需要在给定的时间点执行，而时间事件就是处理这类定时操作的。","Properties":{"id":""}}]}]}]},{"ID":"20220906203869-kl98yf3","Type":"NodeParagraph","Properties":{"id":"20220906203869-kl98yf3","updated":"20220906203869"},"Children":[{"Type":"NodeText","Data":"时间事件不需要多花时间了解，我们接触最多的还是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"文件事件"},{"Type":"NodeText","Data":"（客户端进行读取写入等操作，涉及一系列网络通信）。","Properties":{"id":""}}]},{"ID":"20220906203870-168a2z7","Type":"NodeParagraph","Properties":{"id":"20220906203870-168a2z7","updated":"20220906203870"},"Children":[{"Type":"NodeText","Data":"《Redis 设计与实现》有一段话是如是介绍文件事件的，我觉得写得挺不错。","Properties":{"id":""}}]},{"ID":"20220906203871-cg2q00o","Type":"NodeBlockquote","Properties":{"id":"20220906203871-cg2q00o","updated":"20220906203871"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203872-i77fkgz","Type":"NodeParagraph","Properties":{"id":"20220906203872-i77fkgz","updated":"20220906203872"},"Children":[{"Type":"NodeText","Data":"Redis 基于 Reactor 模式开发了自己的网络事件处理器：这个处理器被称为文件事件处理器（file event handler）。文件事件处理器使用 I/O 多路复用（multiplexing）程序来同时监听多个套接字，并根据套接字目前执行的任务来为套接字关联不同的事件处理器。","Properties":{"id":""}}]},{"ID":"20220906203873-s1i2mde","Type":"NodeParagraph","Properties":{"id":"20220906203873-s1i2mde","updated":"20220906203873"},"Children":[{"Type":"NodeText","Data":"当被监听的套接字准备好执行连接应答（accept）、读取（read）、写入（write）、关 闭（close）等操作时，与操作相对应的文件事件就会产生，这时文件事件处理器就会调用套接字之前关联好的事件处理器来处理这些事件。","Properties":{"id":""}}]},{"ID":"20220906203874-pulonaf","Type":"NodeParagraph","Properties":{"id":"20220906203874-pulonaf","updated":"20220906203874"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"虽然文件事件处理器以单线程方式运行，但通过使用 I/O 多路复用程序来监听多个套接字"},{"Type":"NodeText","Data":"，文件事件处理器既实现了高性能的网络通信模型，又可以很好地与 Redis 服务器中其他同样以单线程方式运行的模块进行对接，这保持了 Redis 内部单线程设计的简单性。","Properties":{"id":""}}]}]},{"ID":"20220906203875-agi6q5o","Type":"NodeParagraph","Properties":{"id":"20220906203875-agi6q5o","updated":"20220906203875"},"Children":[{"Type":"NodeText","Data":"可以看出，文件事件处理器（file event handler）主要是包含 4 个部分：","Properties":{"id":""}}]},{"ID":"20220906203876-1wcx6d4","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203876-1wcx6d4","updated":"20220906203876"},"Children":[{"ID":"20220906203877-ws4tt09","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203877-ws4tt09","updated":"20220906203877"},"Children":[{"ID":"20220906203878-pdph20s","Type":"NodeParagraph","Properties":{"id":"20220906203878-pdph20s","updated":"20220906203878"},"Children":[{"Type":"NodeText","Data":"多个 socket（客户端连接）","Properties":{"id":""}}]}]},{"ID":"20220906203879-82wi5jm","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203879-82wi5jm","updated":"20220906203879"},"Children":[{"ID":"20220906203880-xmbbba0","Type":"NodeParagraph","Properties":{"id":"20220906203880-xmbbba0","updated":"20220906203880"},"Children":[{"Type":"NodeText","Data":"IO 多路复用程序（支持多个客户端连接的关键）","Properties":{"id":""}}]}]},{"ID":"20220906203881-f3jl4pt","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203881-f3jl4pt","updated":"20220906203881"},"Children":[{"ID":"20220906203882-h411794","Type":"NodeParagraph","Properties":{"id":"20220906203882-h411794","updated":"20220906203882"},"Children":[{"Type":"NodeText","Data":"文件事件分派器（将 socket 关联到相应的事件处理器）","Properties":{"id":""}}]}]},{"ID":"20220906203883-15zof97","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203883-15zof97","updated":"20220906203883"},"Children":[{"ID":"20220906203884-ec3fql7","Type":"NodeParagraph","Properties":{"id":"20220906203884-ec3fql7","updated":"20220906203884"},"Children":[{"Type":"NodeText","Data":"事件处理器（连接应答处理器、命令请求处理器、命令回复处理器）","Properties":{"id":""}}]}]}]},{"ID":"20220906203885-hgyd5m3","Type":"NodeParagraph","Properties":{"id":"20220906203885-hgyd5m3","updated":"20220906203885"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"文件事件处理器","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-event-handler.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203886-f90m7lm","Type":"NodeParagraph","Properties":{"id":"20220906203886-f90m7lm","updated":"20220906203886"},"Children":[{"Type":"NodeText","Data":"相关阅读：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"http://remcarpediem.net/article/1aa2da89/","TextMarkTextContent":"Redis 事件机制详解"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906203887-znazvyi","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203887-znazvyi","updated":"20220906203887"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis6.0 之前为什么不使用多线程？","Properties":{"id":""}}]},{"ID":"20220906203888-lsuqipu","Type":"NodeParagraph","Properties":{"id":"20220906203888-lsuqipu","updated":"20220906203888"},"Children":[{"Type":"NodeText","Data":"虽然说 Redis 是单线程模型，但是，实际上，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 在 4.0 之后的版本中就已经加入了对多线程的支持。"}]},{"ID":"20220906203889-1schp95","Type":"NodeParagraph","Properties":{"id":"20220906203889-1schp95","updated":"20220906203889"},"Children":[{"Type":"NodeText","Data":"不过，Redis 4.0 增加的多线程主要是针对一些大键值对的删除操作的命令，使用这些命令就会使用主线程之外的其他线程来“异步处理”。","Properties":{"id":""}}]},{"ID":"20220906203890-p5387x2","Type":"NodeParagraph","Properties":{"id":"20220906203890-p5387x2","updated":"20220906203890"},"Children":[{"Type":"NodeText","Data":"为此，Redis 4.0 之后新增了","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"UNLINK"},{"Type":"NodeText","Data":"（可以看作是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"DEL"},{"Type":"NodeText","Data":" 的异步版本）、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"FLUSHALL ASYNC"},{"Type":"NodeText","Data":"（清空数据库）、","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"FLUSHDB ASYNC"},{"Type":"NodeText","Data":"（清空数据库）等异步命令。","Properties":{"id":""}}]},{"ID":"20220906203891-zm825zv","Type":"NodeParagraph","Properties":{"id":"20220906203891-zm825zv","updated":"20220906203891"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"redis4.0 more thread","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis4.0-more-thread.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203892-e27g13j","Type":"NodeParagraph","Properties":{"id":"20220906203892-e27g13j","updated":"20220906203892"},"Children":[{"Type":"NodeText","Data":"大体上来说，Redis 6.0 之前主要还是单线程处理。","Properties":{"id":""}}]},{"ID":"20220906203893-ffhxdjm","Type":"NodeParagraph","Properties":{"id":"20220906203893-ffhxdjm","updated":"20220906203893"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"那 Redis6.0 之前为什么不使用多线程？"},{"Type":"NodeText","Data":" 我觉得主要原因有 3 点：","Properties":{"id":""}}]},{"ID":"20220906203894-572ji4c","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203894-572ji4c","updated":"20220906203894"},"Children":[{"ID":"20220906203895-lxm0x2u","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203895-lxm0x2u","updated":"20220906203895"},"Children":[{"ID":"20220906203896-xlkwbwl","Type":"NodeParagraph","Properties":{"id":"20220906203896-xlkwbwl","updated":"20220906203896"},"Children":[{"Type":"NodeText","Data":"单线程编程容易并且更容易维护；","Properties":{"id":""}}]}]},{"ID":"20220906203897-pw771gj","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203897-pw771gj","updated":"20220906203897"},"Children":[{"ID":"20220906203898-uyhf6s1","Type":"NodeParagraph","Properties":{"id":"20220906203898-uyhf6s1","updated":"20220906203898"},"Children":[{"Type":"NodeText","Data":"Redis 的性能瓶颈不在 CPU ，主要在内存和网络；","Properties":{"id":""}}]}]},{"ID":"20220906203899-bgdq26k","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203899-bgdq26k","updated":"20220906203899"},"Children":[{"ID":"20220906203900-k7cd0zp","Type":"NodeParagraph","Properties":{"id":"20220906203900-k7cd0zp","updated":"20220906203900"},"Children":[{"Type":"NodeText","Data":"多线程就会存在死锁、线程上下文切换等问题，甚至会影响性能。","Properties":{"id":""}}]}]}]},{"ID":"20220906203901-cop7gbq","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203901-cop7gbq","updated":"20220906203901"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis6.0 之后为何引入了多线程？","Properties":{"id":""}}]},{"ID":"20220906203902-qcsifax","Type":"NodeParagraph","Properties":{"id":"20220906203902-qcsifax","updated":"20220906203902"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis6.0 引入多线程主要是为了提高网络 IO 读写性能"},{"Type":"NodeText","Data":"，因为这个算是 Redis 中的一个性能瓶颈（Redis 的瓶颈主要受限于内存和网络）。","Properties":{"id":""}}]},{"ID":"20220906203903-wl8xzt0","Type":"NodeParagraph","Properties":{"id":"20220906203903-wl8xzt0","updated":"20220906203903"},"Children":[{"Type":"NodeText","Data":"虽然，Redis6.0 引入了多线程，但是 Redis 的多线程只是在网络数据的读写这类耗时操作上使用了，执行命令仍然是单线程顺序执行。因此，你也不需要担心线程安全问题。","Properties":{"id":""}}]},{"ID":"20220906203904-kq7wgmo","Type":"NodeParagraph","Properties":{"id":"20220906203904-kq7wgmo","updated":"20220906203904"},"Children":[{"Type":"NodeText","Data":"Redis6.0 的多线程默认是禁用的，只使用主线程。如需开启需要修改 redis 配置文件 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"redis.conf"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906203905-i49hb1k","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203905-i49hb1k","updated":"20220906203905"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"io-threads-do-reads yes\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203906-vrxe1lw","Type":"NodeParagraph","Properties":{"id":"20220906203906-vrxe1lw","updated":"20220906203906"},"Children":[{"Type":"NodeText","Data":"开启多线程后，还需要设置线程数，否则是不生效的。同样需要修改 redis 配置文件 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"redis.conf"},{"Type":"NodeText","Data":" :","Properties":{"id":""}}]},{"ID":"20220906203907-0esyqun","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203907-0esyqun","updated":"20220906203907"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"io-threads 4 #官网建议4核的机器建议设置为2或3个线程，8核的建议设置为6个线程\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203908-gu6m9kf","Type":"NodeParagraph","Properties":{"id":"20220906203908-gu6m9kf","updated":"20220906203908"},"Children":[{"Type":"NodeText","Data":"推荐阅读：","Properties":{"id":""}}]},{"ID":"20220906203909-9fesz7s","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203909-9fesz7s","updated":"20220906203909"},"Children":[{"ID":"20220906203910-zy8toe9","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203910-zy8toe9","updated":"20220906203910"},"Children":[{"ID":"20220906203911-yrswrl0","Type":"NodeParagraph","Properties":{"id":"20220906203911-yrswrl0","updated":"20220906203911"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://mp.weixin.qq.com/s/FZu3acwK6zrCBZQ_3HoUgw","TextMarkTextContent":"Redis 6.0 新特性-多线程连环 13 问！"}]}]},{"ID":"20220906203912-s30nfnu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203912-s30nfnu","updated":"20220906203912"},"Children":[{"ID":"20220906203913-hom57p5","Type":"NodeParagraph","Properties":{"id":"20220906203913-hom57p5","updated":"20220906203913"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://draveness.me/whys-the-design-redis-single-thread/","TextMarkTextContent":"为什么 Redis 选择单线程模型"}]}]},{"ID":"20220906203914-jcpo60z","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203914-jcpo60z","updated":"20220906203914"},"Children":[{"ID":"20220906203915-6ovozq0","Type":"NodeParagraph","Properties":{"id":"20220906203915-6ovozq0","updated":"20220906203915"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://segmentfault.com/a/1190000039223696","TextMarkTextContent":"Redis 多线程网络模型全面揭秘"}]}]}]},{"ID":"20220906203916-26llf3y","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203916-26llf3y","updated":"20220906203916"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 内存管理","Properties":{"id":""}}]},{"ID":"20220906203917-zryotb1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203917-zryotb1","updated":"20220906203917"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 给缓存数据设置过期时间有啥用？","Properties":{"id":""}}]},{"ID":"20220906203918-lwyf1wm","Type":"NodeParagraph","Properties":{"id":"20220906203918-lwyf1wm","updated":"20220906203918"},"Children":[{"Type":"NodeText","Data":"一般情况下，我们设置保存的缓存数据的时候都会设置一个过期时间。为什么呢？","Properties":{"id":""}}]},{"ID":"20220906203919-ml70jia","Type":"NodeParagraph","Properties":{"id":"20220906203919-ml70jia","updated":"20220906203919"},"Children":[{"Type":"NodeText","Data":"因为内存是有限的，如果缓存中的所有数据都是一直保存的话，分分钟直接 Out of memory。","Properties":{"id":""}}]},{"ID":"20220906203920-u7wnnc0","Type":"NodeParagraph","Properties":{"id":"20220906203920-u7wnnc0","updated":"20220906203920"},"Children":[{"Type":"NodeText","Data":"Redis 自带了给缓存数据设置过期时间的功能，比如：","Properties":{"id":""}}]},{"ID":"20220906203921-b2esg5f","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203921-b2esg5f","updated":"20220906203921"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"127.0.0.1:6379\u003e exp key 60 # 数据在 60s 后过期\n(integer) 1\n127.0.0.1:6379\u003e setex key 60 value # 数据在 60s 后过期 (setex:[set] + [ex]pire)\nOK\n127.0.0.1:6379\u003e ttl key # 查看数据还有多久过期\n(integer) 56\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203922-c5a9jys","Type":"NodeParagraph","Properties":{"id":"20220906203922-c5a9jys","updated":"20220906203922"},"Children":[{"Type":"NodeText","Data":"注意：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 中除了字符串类型有自己独有设置过期时间的命令 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"setex"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 外，其他方法都需要依靠 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"expire"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 命令来设置过期时间 。另外， "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"persist"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 命令可以移除一个键的过期时间。"}]},{"ID":"20220906203923-igxx76w","Type":"NodeParagraph","Properties":{"id":"20220906203923-igxx76w","updated":"20220906203923"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"过期时间除了有助于缓解内存的消耗，还有什么其他用么？"}]},{"ID":"20220906203924-ykjrse6","Type":"NodeParagraph","Properties":{"id":"20220906203924-ykjrse6","updated":"20220906203924"},"Children":[{"Type":"NodeText","Data":"很多时候，我们的业务场景就是需要某个数据只在某一时间段内存在，比如我们的短信验证码可能只在 1 分钟内有效，用户登录的 token 可能只在 1 天内有效。","Properties":{"id":""}}]},{"ID":"20220906203925-4igd124","Type":"NodeParagraph","Properties":{"id":"20220906203925-4igd124","updated":"20220906203925"},"Children":[{"Type":"NodeText","Data":"如果使用传统的数据库来处理的话，一般都是自己判断过期，这样更麻烦并且性能要差很多。","Properties":{"id":""}}]},{"ID":"20220906203926-20qcmq7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203926-20qcmq7","updated":"20220906203926"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 是如何判断数据是否过期的呢？","Properties":{"id":""}}]},{"ID":"20220906203927-cqmpudf","Type":"NodeParagraph","Properties":{"id":"20220906203927-cqmpudf","updated":"20220906203927"},"Children":[{"Type":"NodeText","Data":"Redis 通过一个叫做过期字典（可以看作是 hash 表）来保存数据过期的时间。过期字典的键指向 Redis 数据库中的某个 key(键)，过期字典的值是一个 long long 类型的整数，这个整数保存了 key 所指向的数据库键的过期时间（毫秒精度的 UNIX 时间戳）。","Properties":{"id":""}}]},{"ID":"20220906203928-m5nnimw","Type":"NodeParagraph","Properties":{"id":"20220906203928-m5nnimw","updated":"20220906203928"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"redis过期字典","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-expired-dictionary.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203929-ixpnaul","Type":"NodeParagraph","Properties":{"id":"20220906203929-ixpnaul","updated":"20220906203929"},"Children":[{"Type":"NodeText","Data":"过期字典是存储在 redisDb 这个结构里的：","Properties":{"id":""}}]},{"ID":"20220906203930-bv9m9a3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Yw==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203930-bv9m9a3","updated":"20220906203930"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Yw==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"typedef struct redisDb {\n    ...\n\n    dict *dict;     //数据库键空间,保存着数据库中所有键值对\n    dict *expires   // 过期字典,保存着键的过期时间\n    ...\n} redisDb;\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203931-lhlpg6g","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203931-lhlpg6g","updated":"20220906203931"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"过期的数据的删除策略了解么？","Properties":{"id":""}}]},{"ID":"20220906203932-g1xue5r","Type":"NodeParagraph","Properties":{"id":"20220906203932-g1xue5r","updated":"20220906203932"},"Children":[{"Type":"NodeText","Data":"如果假设你设置了一批 key 只能存活 1 分钟，那么 1 分钟后，Redis 是怎么对这批 key 进行删除的呢？","Properties":{"id":""}}]},{"ID":"20220906203933-9uf2due","Type":"NodeParagraph","Properties":{"id":"20220906203933-9uf2due","updated":"20220906203933"},"Children":[{"Type":"NodeText","Data":"常用的过期数据的删除策略就两个（重要！自己造缓存轮子的时候需要格外考虑的东西）：","Properties":{"id":""}}]},{"ID":"20220906203934-b9ek139","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203934-b9ek139","updated":"20220906203934"},"Children":[{"ID":"20220906203935-yjk0odg","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203935-yjk0odg","updated":"20220906203935"},"Children":[{"ID":"20220906203936-v7n927l","Type":"NodeParagraph","Properties":{"id":"20220906203936-v7n927l","updated":"20220906203936"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"惰性删除"},{"Type":"NodeText","Data":" ：只会在取出 key 的时候才对数据进行过期检查。这样对 CPU 最友好，但是可能会造成太多过期 key 没有被删除。","Properties":{"id":""}}]}]},{"ID":"20220906203937-cyv732x","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203937-cyv732x","updated":"20220906203937"},"Children":[{"ID":"20220906203938-1wcbgg0","Type":"NodeParagraph","Properties":{"id":"20220906203938-1wcbgg0","updated":"20220906203938"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"定期删除"},{"Type":"NodeText","Data":" ： 每隔一段时间抽取一批 key 执行删除过期 key 操作。并且，Redis 底层会通过限制删除操作执行的时长和频率来减少删除操作对 CPU 时间的影响。","Properties":{"id":""}}]}]}]},{"ID":"20220906203939-wxcsn27","Type":"NodeParagraph","Properties":{"id":"20220906203939-wxcsn27","updated":"20220906203939"},"Children":[{"Type":"NodeText","Data":"定期删除对内存更加友好，惰性删除对 CPU 更加友好。两者各有千秋，所以 Redis 采用的是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"定期删除+惰性/懒汉式删除"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906203940-1vtv9sm","Type":"NodeParagraph","Properties":{"id":"20220906203940-1vtv9sm","updated":"20220906203940"},"Children":[{"Type":"NodeText","Data":"但是，仅仅通过给 key 设置过期时间还是有问题的。因为还是可能存在定期删除和惰性删除漏掉了很多过期 key 的情况。这样就导致大量过期 key 堆积在内存里，然后就 Out of memory 了。","Properties":{"id":""}}]},{"ID":"20220906203941-vpgemi3","Type":"NodeParagraph","Properties":{"id":"20220906203941-vpgemi3","updated":"20220906203941"},"Children":[{"Type":"NodeText","Data":"怎么解决这个问题呢？答案就是：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 内存淘汰机制。"}]},{"ID":"20220906203942-r6047vx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203942-r6047vx","updated":"20220906203942"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 内存淘汰机制了解么？","Properties":{"id":""}}]},{"ID":"20220906203943-uvznohq","Type":"NodeBlockquote","Properties":{"id":"20220906203943-uvznohq","updated":"20220906203943"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220906203944-3cz8h32","Type":"NodeParagraph","Properties":{"id":"20220906203944-3cz8h32","updated":"20220906203944"},"Children":[{"Type":"NodeText","Data":"相关问题：MySQL 里有 2000w 数据，Redis 中只存 20w 的数据，如何保证 Redis 中的数据都是热点数据?","Properties":{"id":""}}]}]},{"ID":"20220906203945-bzscxgg","Type":"NodeParagraph","Properties":{"id":"20220906203945-bzscxgg","updated":"20220906203945"},"Children":[{"Type":"NodeText","Data":"Redis 提供 6 种数据淘汰策略：","Properties":{"id":""}}]},{"ID":"20220906203946-gf43470","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203946-gf43470","updated":"20220906203946"},"Children":[{"ID":"20220906203947-qfsm4rb","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906203947-qfsm4rb","updated":"20220906203947"},"Children":[{"ID":"20220906203948-1hfg8jr","Type":"NodeParagraph","Properties":{"id":"20220906203948-1hfg8jr","updated":"20220906203948"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"volatile-lru（least recently used）"},{"Type":"NodeText","Data":"：从已设置过期时间的数据集（server.db[i].expires）中挑选最近最少使用的数据淘汰","Properties":{"id":""}}]}]},{"ID":"20220906203949-m55xoiy","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906203949-m55xoiy","updated":"20220906203949"},"Children":[{"ID":"20220906203950-ycq5omb","Type":"NodeParagraph","Properties":{"id":"20220906203950-ycq5omb","updated":"20220906203950"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"volatile-ttl"},{"Type":"NodeText","Data":"：从已设置过期时间的数据集（server.db[i].expires）中挑选将要过期的数据淘汰","Properties":{"id":""}}]}]},{"ID":"20220906203951-5pdq9jp","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906203951-5pdq9jp","updated":"20220906203951"},"Children":[{"ID":"20220906203952-uirlo2g","Type":"NodeParagraph","Properties":{"id":"20220906203952-uirlo2g","updated":"20220906203952"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"volatile-random"},{"Type":"NodeText","Data":"：从已设置过期时间的数据集（server.db[i].expires）中任意选择数据淘汰","Properties":{"id":""}}]}]},{"ID":"20220906203953-iq5byo3","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906203953-iq5byo3","updated":"20220906203953"},"Children":[{"ID":"20220906203954-jpg3ool","Type":"NodeParagraph","Properties":{"id":"20220906203954-jpg3ool","updated":"20220906203954"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"allkeys-lru（least recently used）"},{"Type":"NodeText","Data":"：当内存不足以容纳新写入数据时，在键空间中，移除最近最少使用的 key（这个是最常用的）","Properties":{"id":""}}]}]},{"ID":"20220906203955-bkihad9","Type":"NodeListItem","Data":"5","ListData":{"Typ":1,"Tight":true,"Start":5,"Delimiter":46,"Padding":3,"Marker":"NQ==","Num":5},"Properties":{"id":"20220906203955-bkihad9","updated":"20220906203955"},"Children":[{"ID":"20220906203956-ep3unjx","Type":"NodeParagraph","Properties":{"id":"20220906203956-ep3unjx","updated":"20220906203956"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"allkeys-random"},{"Type":"NodeText","Data":"：从数据集（server.db[i].dict）中任意选择数据淘汰","Properties":{"id":""}}]}]},{"ID":"20220906203957-0d7lez8","Type":"NodeListItem","Data":"6","ListData":{"Typ":1,"Tight":true,"Start":6,"Delimiter":46,"Padding":3,"Marker":"Ng==","Num":6},"Properties":{"id":"20220906203957-0d7lez8","updated":"20220906203957"},"Children":[{"ID":"20220906203958-u1y7eqo","Type":"NodeParagraph","Properties":{"id":"20220906203958-u1y7eqo","updated":"20220906203958"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"no-eviction"},{"Type":"NodeText","Data":"：禁止驱逐数据，也就是说当内存不足以容纳新写入数据时，新写入操作会报错。这个应该没人使用吧！","Properties":{"id":""}}]}]}]},{"ID":"20220906203959-8t7tca7","Type":"NodeParagraph","Properties":{"id":"20220906203959-8t7tca7","updated":"20220906203959"},"Children":[{"Type":"NodeText","Data":"4.0 版本后增加以下两种：","Properties":{"id":""}}]},{"ID":"20220906203960-ja7cl1f","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":7,"Delimiter":46,"Padding":3,"Marker":"Nw==","Num":7},"Properties":{"id":"20220906203960-ja7cl1f","updated":"20220906203960"},"Children":[{"ID":"20220906203961-4jn9pzy","Type":"NodeListItem","Data":"7","ListData":{"Typ":1,"Tight":true,"Start":7,"Delimiter":46,"Padding":3,"Marker":"Nw==","Num":7},"Properties":{"id":"20220906203961-4jn9pzy","updated":"20220906203961"},"Children":[{"ID":"20220906203962-6sus1xy","Type":"NodeParagraph","Properties":{"id":"20220906203962-6sus1xy","updated":"20220906203962"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"volatile-lfu（least frequently used）"},{"Type":"NodeText","Data":"：从已设置过期时间的数据集（server.db[i].expires）中挑选最不经常使用的数据淘汰","Properties":{"id":""}}]}]},{"ID":"20220906203963-08fun0p","Type":"NodeListItem","Data":"8","ListData":{"Typ":1,"Tight":true,"Start":8,"Delimiter":46,"Padding":3,"Marker":"OA==","Num":8},"Properties":{"id":"20220906203963-08fun0p","updated":"20220906203963"},"Children":[{"ID":"20220906203964-yig41in","Type":"NodeParagraph","Properties":{"id":"20220906203964-yig41in","updated":"20220906203964"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"allkeys-lfu（least frequently used）"},{"Type":"NodeText","Data":"：当内存不足以容纳新写入数据时，在键空间中，移除最不经常使用的 key","Properties":{"id":""}}]}]}]},{"ID":"20220906203965-y7i3log","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203965-y7i3log","updated":"20220906203965"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 持久化机制","Properties":{"id":""}}]},{"ID":"20220906203966-efhzmg8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203966-efhzmg8","updated":"20220906203966"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"怎么保证 Redis 挂掉之后再重启数据可以进行恢复？","Properties":{"id":""}}]},{"ID":"20220906203967-o7439r5","Type":"NodeParagraph","Properties":{"id":"20220906203967-o7439r5","updated":"20220906203967"},"Children":[{"Type":"NodeText","Data":"很多时候我们需要持久化数据也就是将内存中的数据写入到硬盘里面，大部分原因是为了之后重用数据（比如重启机器、机器故障之后恢复数据），或者是为了防止系统故障而将数据备份到一个远程位置。","Properties":{"id":""}}]},{"ID":"20220906203968-r8k3tif","Type":"NodeParagraph","Properties":{"id":"20220906203968-r8k3tif","updated":"20220906203968"},"Children":[{"Type":"NodeText","Data":"Redis 不同于 Memcached 的很重要一点就是，Redis 支持持久化，而且支持两种不同的持久化操作。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 的一种持久化方式叫快照（snapshotting，RDB），另一种方式是只追加文件（append-only file, AOF）"},{"Type":"NodeText","Data":"。这两种方法各有千秋，下面我会详细这两种持久化方法是什么，怎么用，如何选择适合自己的持久化方法。","Properties":{"id":""}}]},{"ID":"20220906203969-j26l41z","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203969-j26l41z","updated":"20220906203969"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 RDB 持久化？","Properties":{"id":""}}]},{"ID":"20220906203970-rcrotqz","Type":"NodeParagraph","Properties":{"id":"20220906203970-rcrotqz","updated":"20220906203970"},"Children":[{"Type":"NodeText","Data":"Redis 可以通过创建快照来获得存储在内存里面的数据在某个时间点上的副本。Redis 创建快照之后，可以对快照进行备份，可以将快照复制到其他服务器从而创建具有相同数据的服务器副本（Redis 主从结构，主要用来提高 Redis 性能），还可以将快照留在原地以便重启服务器的时候使用。","Properties":{"id":""}}]},{"ID":"20220906203971-96elsdd","Type":"NodeParagraph","Properties":{"id":"20220906203971-96elsdd","updated":"20220906203971"},"Children":[{"Type":"NodeText","Data":"快照持久化是 Redis 默认采用的持久化方式，在 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"redis.conf"},{"Type":"NodeText","Data":" 配置文件中默认有此下配置：","Properties":{"id":""}}]},{"ID":"20220906203972-xxbfmgu","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Y2xvanVyZQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203972-xxbfmgu","updated":"20220906203972"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Y2xvanVyZQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"save 900 1           #在900秒(15分钟)之后，如果至少有1个key发生变化，Redis就会自动触发bgsave命令创建快照。\n\nsave 300 10          #在300秒(5分钟)之后，如果至少有10个key发生变化，Redis就会自动触发bgsave命令创建快照。\n\nsave 60 10000        #在60秒(1分钟)之后，如果至少有10000个key发生变化，Redis就会自动触发bgsave命令创建快照。\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203973-2mbwet3","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203973-2mbwet3","updated":"20220906203973"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"RDB 创建快照时会阻塞主线程吗？","Properties":{"id":""}}]},{"ID":"20220906203974-f8mpwpy","Type":"NodeParagraph","Properties":{"id":"20220906203974-f8mpwpy","updated":"20220906203974"},"Children":[{"Type":"NodeText","Data":"Redis 提供了两个命令来生成 RDB 快照文件：","Properties":{"id":""}}]},{"ID":"20220906203975-gobo2ej","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203975-gobo2ej","updated":"20220906203975"},"Children":[{"ID":"20220906203976-e5anfi8","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203976-e5anfi8","updated":"20220906203976"},"Children":[{"ID":"20220906203977-bvqz8ms","Type":"NodeParagraph","Properties":{"id":"20220906203977-bvqz8ms","updated":"20220906203977"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"save"},{"Type":"NodeText","Data":" : 主线程执行，会阻塞主线程；","Properties":{"id":""}}]}]},{"ID":"20220906203978-b5nyo6f","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203978-b5nyo6f","updated":"20220906203978"},"Children":[{"ID":"20220906203979-fik4yx8","Type":"NodeParagraph","Properties":{"id":"20220906203979-fik4yx8","updated":"20220906203979"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"bgsave"},{"Type":"NodeText","Data":" : 子线程执行，不会阻塞主线程，默认选项。","Properties":{"id":""}}]}]}]},{"ID":"20220906203980-icz4ze0","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203980-icz4ze0","updated":"20220906203980"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 AOF 持久化？","Properties":{"id":""}}]},{"ID":"20220906203981-zgof9m0","Type":"NodeParagraph","Properties":{"id":"20220906203981-zgof9m0","updated":"20220906203981"},"Children":[{"Type":"NodeText","Data":"与快照持久化相比，AOF 持久化的实时性更好，因此已成为主流的持久化方案。默认情况下 Redis 没有开启 AOF（append only file）方式的持久化，可以通过 appendonly 参数开启：","Properties":{"id":""}}]},{"ID":"20220906203982-72nf94i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Y2xvanVyZQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203982-72nf94i","updated":"20220906203982"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Y2xvanVyZQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"appendonly yes\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203983-tz0a9j5","Type":"NodeParagraph","Properties":{"id":"20220906203983-tz0a9j5","updated":"20220906203983"},"Children":[{"Type":"NodeText","Data":"开启 AOF 持久化后每执行一条会更改 Redis 中的数据的命令，Redis 就会将该命令写入到内存缓存 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"server.aof_buf"},{"Type":"NodeText","Data":" 中，然后再根据 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"appendfsync"},{"Type":"NodeText","Data":" 配置来决定何时将其同步到硬盘中的 AOF 文件。","Properties":{"id":""}}]},{"ID":"20220906203984-8xzim0k","Type":"NodeParagraph","Properties":{"id":"20220906203984-8xzim0k","updated":"20220906203984"},"Children":[{"Type":"NodeText","Data":"AOF 文件的保存位置和 RDB 文件的位置相同，都是通过 dir 参数设置的，默认的文件名是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"appendonly.aof"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906203985-310mwp7","Type":"NodeParagraph","Properties":{"id":"20220906203985-310mwp7","updated":"20220906203985"},"Children":[{"Type":"NodeText","Data":"在 Redis 的配置文件中存在三种不同的 AOF 持久化方式，它们分别是：","Properties":{"id":""}}]},{"ID":"20220906203986-9c1zuh9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Y2xvanVyZQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203986-9c1zuh9","updated":"20220906203986"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Y2xvanVyZQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"appendfsync always    #每次有数据修改发生时都会写入AOF文件,这样会严重降低Redis的速度\nappendfsync everysec  #每秒钟同步一次，显式地将多个写命令同步到硬盘\nappendfsync no        #让操作系统决定何时进行同步\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203987-315l41m","Type":"NodeParagraph","Properties":{"id":"20220906203987-315l41m","updated":"20220906203987"},"Children":[{"Type":"NodeText","Data":"为了兼顾数据和写入性能，用户可以考虑 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"appendfsync everysec"},{"Type":"NodeText","Data":" 选项 ，让 Redis 每秒同步一次 AOF 文件，Redis 性能几乎没受到任何影响。而且这样即使出现系统崩溃，用户最多只会丢失一秒之内产生的数据。当硬盘忙于执行写入操作的时候，Redis 还会优雅的放慢自己的速度以便适应硬盘的最大写入速度。","Properties":{"id":""}}]},{"ID":"20220906203988-13sz4e0","Type":"NodeParagraph","Properties":{"id":"20220906203988-13sz4e0","updated":"20220906203988"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"相关 issue"},{"Type":"NodeText","Data":" ：","Properties":{"id":""}}]},{"ID":"20220906203989-w1wmcon","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203989-w1wmcon","updated":"20220906203989"},"Children":[{"ID":"20220906203990-3sj9ft5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203990-3sj9ft5","updated":"20220906203990"},"Children":[{"ID":"20220906203991-sledjaa","Type":"NodeParagraph","Properties":{"id":"20220906203991-sledjaa","updated":"20220906203991"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Snailclimb/JavaGuide/issues/783","TextMarkTextContent":"Redis 的 AOF 方式 #783"}]}]},{"ID":"20220906203992-hx62pp1","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203992-hx62pp1","updated":"20220906203992"},"Children":[{"ID":"20220906203993-69nubu5","Type":"NodeParagraph","Properties":{"id":"20220906203993-69nubu5","updated":"20220906203993"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Snailclimb/JavaGuide/issues/1439","TextMarkTextContent":"Redis AOF 重写描述不准确 #1439"}]}]}]},{"ID":"20220906203994-apzhozt","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203994-apzhozt","updated":"20220906203994"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"AOF 日志是如何实现的？","Properties":{"id":""}}]},{"ID":"20220906203995-aii4sy3","Type":"NodeParagraph","Properties":{"id":"20220906203995-aii4sy3","updated":"20220906203995"},"Children":[{"Type":"NodeText","Data":"关系型数据库（如 MySQL）通常都是执行命令之前记录日志（方便故障恢复），而 Redis AOF 持久化机制是在执行完命令之后再记录日志。","Properties":{"id":""}}]},{"ID":"20220906203996-4bcix5x","Type":"NodeParagraph","Properties":{"id":"20220906203996-4bcix5x","updated":"20220906203996"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/8ebd61289336444aa2d00e7bd1696d17.jpeg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203997-tlsbeu6","Type":"NodeParagraph","Properties":{"id":"20220906203997-tlsbeu6","updated":"20220906203997"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"为什么是在执行完命令之后记录日志呢？"}]},{"ID":"20220906203998-qfo5it0","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203998-qfo5it0","updated":"20220906203998"},"Children":[{"ID":"20220906203999-pnd5m8u","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203999-pnd5m8u","updated":"20220906203999"},"Children":[{"ID":"20220906204000-wu14koh","Type":"NodeParagraph","Properties":{"id":"20220906204000-wu14koh","updated":"20220906204000"},"Children":[{"Type":"NodeText","Data":"避免额外的检查开销，AOF 记录日志不会对命令进行语法检查；","Properties":{"id":""}}]}]},{"ID":"20220906204001-m6qyrad","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204001-m6qyrad","updated":"20220906204001"},"Children":[{"ID":"20220906204002-m2lrt92","Type":"NodeParagraph","Properties":{"id":"20220906204002-m2lrt92","updated":"20220906204002"},"Children":[{"Type":"NodeText","Data":"在命令执行完之后再记录，不会阻塞当前的命令执行。","Properties":{"id":""}}]}]}]},{"ID":"20220906204003-9ulxpn5","Type":"NodeParagraph","Properties":{"id":"20220906204003-9ulxpn5","updated":"20220906204003"},"Children":[{"Type":"NodeText","Data":"这样也带来了风险（我在前面介绍 AOF 持久化的时候也提到过）：","Properties":{"id":""}}]},{"ID":"20220906204004-2mildg2","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204004-2mildg2","updated":"20220906204004"},"Children":[{"ID":"20220906204005-jkpmzsj","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204005-jkpmzsj","updated":"20220906204005"},"Children":[{"ID":"20220906204006-meebqri","Type":"NodeParagraph","Properties":{"id":"20220906204006-meebqri","updated":"20220906204006"},"Children":[{"Type":"NodeText","Data":"如果刚执行完命令 Redis 就宕机会导致对应的修改丢失；","Properties":{"id":""}}]}]},{"ID":"20220906204007-elyljjn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204007-elyljjn","updated":"20220906204007"},"Children":[{"ID":"20220906204008-oltwpku","Type":"NodeParagraph","Properties":{"id":"20220906204008-oltwpku","updated":"20220906204008"},"Children":[{"Type":"NodeText","Data":"可能会阻塞后续其他命令的执行（AOF 记录日志是在 Redis 主线程中进行的）。","Properties":{"id":""}}]}]}]},{"ID":"20220906204009-rb0drf5","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204009-rb0drf5","updated":"20220906204009"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"AOF 重写了解吗？","Properties":{"id":""}}]},{"ID":"20220906204010-darhfho","Type":"NodeParagraph","Properties":{"id":"20220906204010-darhfho","updated":"20220906204010"},"Children":[{"Type":"NodeText","Data":"AOF 重写可以产生一个新的 AOF 文件，这个新的 AOF 文件和原有的 AOF 文件所保存的数据库状态一样，但体积更小。","Properties":{"id":""}}]},{"ID":"20220906204011-nvajjaj","Type":"NodeParagraph","Properties":{"id":"20220906204011-nvajjaj","updated":"20220906204011"},"Children":[{"Type":"NodeText","Data":"AOF 重写是一个有歧义的名字，该功能是通过读取数据库中的键值对来实现的，程序无须对现有 AOF 文件进行任何读入、分析或者写入操作。","Properties":{"id":""}}]},{"ID":"20220906204012-op3po1t","Type":"NodeParagraph","Properties":{"id":"20220906204012-op3po1t","updated":"20220906204012"},"Children":[{"Type":"NodeText","Data":"在执行 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"BGREWRITEAOF"},{"Type":"NodeText","Data":" 命令时，Redis 服务器会维护一个 AOF 重写缓冲区，该缓冲区会在子进程创建新 AOF 文件期间，记录服务器执行的所有写命令。当子进程完成创建新 AOF 文件的工作之后，服务器会将重写缓冲区中的所有内容追加到新 AOF 文件的末尾，使得新的 AOF 文件保存的数据库状态与现有的数据库状态一致。最后，服务器用新的 AOF 文件替换旧的 AOF 文件，以此来完成 AOF 文件重写操作。","Properties":{"id":""}}]},{"ID":"20220906204013-vbel97v","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204013-vbel97v","updated":"20220906204013"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 4.0 对于持久化机制做了什么优化？","Properties":{"id":""}}]},{"ID":"20220906204014-t4c78qf","Type":"NodeParagraph","Properties":{"id":"20220906204014-t4c78qf","updated":"20220906204014"},"Children":[{"Type":"NodeText","Data":"Redis 4.0 开始支持 RDB 和 AOF 的混合持久化（默认关闭，可以通过配置项 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"aof-use-rdb-preamble"},{"Type":"NodeText","Data":" 开启）。","Properties":{"id":""}}]},{"ID":"20220906204015-szzf1qv","Type":"NodeParagraph","Properties":{"id":"20220906204015-szzf1qv","updated":"20220906204015"},"Children":[{"Type":"NodeText","Data":"如果把混合持久化打开，AOF 重写的时候就直接把 RDB 的内容写到 AOF 文件开头。这样做的好处是可以结合 RDB 和 AOF 的优点, 快速加载同时避免丢失过多的数据。当然缺点也是有的， AOF 里面的 RDB 部分是压缩格式不再是 AOF 格式，可读性较差。","Properties":{"id":""}}]},{"ID":"20220906204016-r9qzzod","Type":"NodeParagraph","Properties":{"id":"20220906204016-r9qzzod","updated":"20220906204016"},"Children":[{"Type":"NodeText","Data":"官方文档地址：https://redis.io/topics/persistence","Properties":{"id":""}}]},{"ID":"20220906204017-bhnyhxn","Type":"NodeParagraph","Properties":{"id":"20220906204017-bhnyhxn","updated":"20220906204017"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis4.0-persitence.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204018-rx6153z","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204018-rx6153z","updated":"20220906204018"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 事务","Properties":{"id":""}}]},{"ID":"20220906204019-6ckzwt1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204019-6ckzwt1","updated":"20220906204019"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何使用 Redis 事务？","Properties":{"id":""}}]},{"ID":"20220906204020-5psgto0","Type":"NodeParagraph","Properties":{"id":"20220906204020-5psgto0","updated":"20220906204020"},"Children":[{"Type":"NodeText","Data":"Redis 可以通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"MULTI"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"，"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"EXEC"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"，"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"DISCARD"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 和 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"WATCH"},{"Type":"NodeText","Data":" 等命令来实现事务(transaction)功能。","Properties":{"id":""}}]},{"ID":"20220906204021-ctfpo9r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204021-ctfpo9r","updated":"20220906204021"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003e MULTI\nOK\n\u003e SET USER \"Guide哥\"\nQUEUED\n\u003e GET USER\nQUEUED\n\u003e EXEC\n1) OK\n2) \"Guide哥\"\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204022-j6edf52","Type":"NodeParagraph","Properties":{"id":"20220906204022-j6edf52","updated":"20220906204022"},"Children":[{"Type":"NodeText","Data":"使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a code","TextMarkAHref":"https://redis.io/commands/multi","TextMarkTextContent":"MULTI"},{"Type":"NodeText","Data":" 命令后可以输入多个命令。Redis 不会立即执行这些命令，而是将它们放到队列，当调用了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a code","TextMarkAHref":"https://redis.io/commands/exec","TextMarkTextContent":"EXEC"},{"Type":"NodeText","Data":" 命令将执行所有命令。","Properties":{"id":""}}]},{"ID":"20220906204023-2wsvy39","Type":"NodeParagraph","Properties":{"id":"20220906204023-2wsvy39","updated":"20220906204023"},"Children":[{"Type":"NodeText","Data":"这个过程是这样的：","Properties":{"id":""}}]},{"ID":"20220906204024-peafkwa","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204024-peafkwa","updated":"20220906204024"},"Children":[{"ID":"20220906204025-cen614w","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204025-cen614w","updated":"20220906204025"},"Children":[{"ID":"20220906204026-mzidht7","Type":"NodeParagraph","Properties":{"id":"20220906204026-mzidht7","updated":"20220906204026"},"Children":[{"Type":"NodeText","Data":"开始事务（","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"MULTI"},{"Type":"NodeText","Data":"）。","Properties":{"id":""}}]}]},{"ID":"20220906204027-147xwgg","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204027-147xwgg","updated":"20220906204027"},"Children":[{"ID":"20220906204028-2l8v56k","Type":"NodeParagraph","Properties":{"id":"20220906204028-2l8v56k","updated":"20220906204028"},"Children":[{"Type":"NodeText","Data":"命令入队(批量操作 Redis 的命令，先进先出（FIFO）的顺序执行)。","Properties":{"id":""}}]}]},{"ID":"20220906204029-9mgb3e7","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204029-9mgb3e7","updated":"20220906204029"},"Children":[{"ID":"20220906204030-iy8lfjt","Type":"NodeParagraph","Properties":{"id":"20220906204030-iy8lfjt","updated":"20220906204030"},"Children":[{"Type":"NodeText","Data":"执行事务(","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"EXEC"},{"Type":"NodeText","Data":")。","Properties":{"id":""}}]}]}]},{"ID":"20220906204031-ncewx6q","Type":"NodeParagraph","Properties":{"id":"20220906204031-ncewx6q","updated":"20220906204031"},"Children":[{"Type":"NodeText","Data":"你也可以通过 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a code","TextMarkAHref":"https://redis.io/commands/discard","TextMarkTextContent":"DISCARD"},{"Type":"NodeText","Data":" 命令取消一个事务，它会清空事务队列中保存的所有命令。","Properties":{"id":""}}]},{"ID":"20220906204032-5cr1x0r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204032-5cr1x0r","updated":"20220906204032"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003e MULTI\nOK\n\u003e SET USER \"Guide哥\"\nQUEUED\n\u003e GET USER\nQUEUED\n\u003e DISCARD\nOK\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204033-4iavugf","Type":"NodeParagraph","Properties":{"id":"20220906204033-4iavugf","updated":"20220906204033"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a code","TextMarkAHref":"https://redis.io/commands/watch","TextMarkTextContent":"WATCH"},{"Type":"NodeText","Data":" 命令用于监听指定的键，当调用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"EXEC"},{"Type":"NodeText","Data":" 命令执行事务时，如果一个被 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"WATCH"},{"Type":"NodeText","Data":" 命令监视的键被修改的话，整个事务都不会执行，直接返回失败。","Properties":{"id":""}}]},{"ID":"20220906204034-9vt1aqq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204034-9vt1aqq","updated":"20220906204034"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003e WATCH USER\nOK\n\u003e MULTI\n\u003e SET USER \"Guide哥\"\nOK\n\u003e GET USER\nGuide哥\n\u003e EXEC\nERR EXEC without MULTI\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204035-9yr8fh9","Type":"NodeParagraph","Properties":{"id":"20220906204035-9yr8fh9","updated":"20220906204035"},"Children":[{"Type":"NodeText","Data":"Redis 官网相关介绍 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://redis.io/topics/transactions","TextMarkTextContent":"https://redis.io/topics/transactions"},{"Type":"NodeText","Data":" 如下：","Properties":{"id":""}}]},{"ID":"20220906204036-5o6j2io","Type":"NodeParagraph","Properties":{"id":"20220906204036-5o6j2io","updated":"20220906204036"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Redis 事务","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-transactions.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204037-7bixkov","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204037-7bixkov","updated":"20220906204037"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 支持原子性吗？","Properties":{"id":""}}]},{"ID":"20220906204038-9kseh9i","Type":"NodeParagraph","Properties":{"id":"20220906204038-9kseh9i","updated":"20220906204038"},"Children":[{"Type":"NodeText","Data":"Redis 的事务和我们平时理解的关系型数据库的事务不同。我们知道事务具有四大特性： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1. 原子性"},{"Type":"NodeText","Data":"，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2. 隔离性"},{"Type":"NodeText","Data":"，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"3. 持久性"},{"Type":"NodeText","Data":"，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"4. 一致性"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204039-u5vxqxx","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204039-u5vxqxx","updated":"20220906204039"},"Children":[{"ID":"20220906204040-i7vs1j8","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204040-i7vs1j8","updated":"20220906204040"},"Children":[{"ID":"20220906204041-8v0llrc","Type":"NodeParagraph","Properties":{"id":"20220906204041-8v0llrc","updated":"20220906204041"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"原子性（Atomicity）："},{"Type":"NodeText","Data":" 事务是最小的执行单位，不允许分割。事务的原子性确保动作要么全部完成，要么完全不起作用；","Properties":{"id":""}}]}]},{"ID":"20220906204042-yhmg57l","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204042-yhmg57l","updated":"20220906204042"},"Children":[{"ID":"20220906204043-bmvu06l","Type":"NodeParagraph","Properties":{"id":"20220906204043-bmvu06l","updated":"20220906204043"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"隔离性（Isolation）："},{"Type":"NodeText","Data":" 并发访问数据库时，一个用户的事务不被其他事务所干扰，各并发事务之间数据库是独立的；","Properties":{"id":""}}]}]},{"ID":"20220906204044-hvuresr","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204044-hvuresr","updated":"20220906204044"},"Children":[{"ID":"20220906204045-qcy74p2","Type":"NodeParagraph","Properties":{"id":"20220906204045-qcy74p2","updated":"20220906204045"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"持久性（Durability）："},{"Type":"NodeText","Data":" 一个事务被提交之后。它对数据库中数据的改变是持久的，即使数据库发生故障也不应该对其有任何影响。","Properties":{"id":""}}]}]},{"ID":"20220906204046-rlgmw8n","Type":"NodeListItem","Data":"4","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":46,"Padding":3,"Marker":"NA==","Num":4},"Properties":{"id":"20220906204046-rlgmw8n","updated":"20220906204046"},"Children":[{"ID":"20220906204047-l3lovuj","Type":"NodeParagraph","Properties":{"id":"20220906204047-l3lovuj","updated":"20220906204047"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"一致性（Consistency）："},{"Type":"NodeText","Data":" 执行事务前后，数据保持一致，多个事务对同一个数据读取的结果是相同的；","Properties":{"id":""}}]}]}]},{"ID":"20220906204048-lqvjwco","Type":"NodeParagraph","Properties":{"id":"20220906204048-lqvjwco","updated":"20220906204048"},"Children":[{"Type":"NodeText","Data":"Redis 事务在运行错误的情况下，除了执行过程中出现错误的命令外，其他命令都能正常执行。并且，Redis 是不支持回滚（roll back）操作的。因此，Redis 事务其实是不满足原子性的（而且不满足持久性）。","Properties":{"id":""}}]},{"ID":"20220906204049-x8jl482","Type":"NodeParagraph","Properties":{"id":"20220906204049-x8jl482","updated":"20220906204049"},"Children":[{"Type":"NodeText","Data":"Redis 官网也解释了自己为啥不支持回滚。简单来说就是 Redis 开发者们觉得没必要支持回滚，这样更简单便捷并且性能更好。Redis 开发者觉得即使命令执行错误也应该在开发过程中就被发现而不是生产过程中。","Properties":{"id":""}}]},{"ID":"20220906204050-tgnqefs","Type":"NodeParagraph","Properties":{"id":"20220906204050-tgnqefs","updated":"20220906204050"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Redis 为什么不支持回滚","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-rollback.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204051-uzud257","Type":"NodeParagraph","Properties":{"id":"20220906204051-uzud257","updated":"20220906204051"},"Children":[{"Type":"NodeText","Data":"你可以将 Redis 中的事务就理解为 ：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Redis 事务提供了一种将多个命令请求打包的功能。然后，再按顺序执行打包的所有命令，并且不会被中途打断。"}]},{"ID":"20220906204052-klq0gc0","Type":"NodeParagraph","Properties":{"id":"20220906204052-klq0gc0","updated":"20220906204052"},"Children":[{"Type":"NodeText","Data":"除了不满足原子性之外，事务中的每条命令都会与 Redis 服务器进行网络交互，这是比较浪费资源的行为。明明一次批量执行多个命令就可以了，这种操作实在是看不懂。","Properties":{"id":""}}]},{"ID":"20220906204053-19oe64s","Type":"NodeParagraph","Properties":{"id":"20220906204053-19oe64s","updated":"20220906204053"},"Children":[{"Type":"NodeText","Data":"因此，Redis 事务是不建议在日常开发中使用的。","Properties":{"id":""}}]},{"ID":"20220906204054-m8eccou","Type":"NodeParagraph","Properties":{"id":"20220906204054-m8eccou","updated":"20220906204054"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"相关 issue"},{"Type":"NodeText","Data":" :","Properties":{"id":""}}]},{"ID":"20220906204055-ii975d6","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204055-ii975d6","updated":"20220906204055"},"Children":[{"ID":"20220906204056-oty6ne5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204056-oty6ne5","updated":"20220906204056"},"Children":[{"ID":"20220906204057-oc6xbjc","Type":"NodeParagraph","Properties":{"id":"20220906204057-oc6xbjc","updated":"20220906204057"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Snailclimb/JavaGuide/issues/452","TextMarkTextContent":"issue452: 关于 Redis 事务不满足原子性的问题"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]}]},{"ID":"20220906204058-q42i0x4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204058-q42i0x4","updated":"20220906204058"},"Children":[{"ID":"20220906204059-nu5mewt","Type":"NodeParagraph","Properties":{"id":"20220906204059-nu5mewt","updated":"20220906204059"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/Snailclimb/JavaGuide/issues/491","TextMarkTextContent":"Issue491:关于 redis 没有事务回滚？"}]}]}]},{"ID":"20220906204060-dfjoheq","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204060-dfjoheq","updated":"20220906204060"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何解决 Redis 事务的缺陷？","Properties":{"id":""}}]},{"ID":"20220906204061-v1h8ksh","Type":"NodeParagraph","Properties":{"id":"20220906204061-v1h8ksh","updated":"20220906204061"},"Children":[{"Type":"NodeText","Data":"Redis 从 2.6 版本开始支持执行 Lua 脚本，它的功能和事务非常类似。我们可以利用 Lua 脚本来批量执行多条 Redis 命令，这些 Redis 命令会被提交到 Redis 服务器一次性执行完成，大幅减小了网络开销。","Properties":{"id":""}}]},{"ID":"20220906204062-jbl07nl","Type":"NodeParagraph","Properties":{"id":"20220906204062-jbl07nl","updated":"20220906204062"},"Children":[{"Type":"NodeText","Data":"一段 Lua 脚本可以视作一条命令执行，一段 Lua 脚本执行过程中不会有其他脚本或 Redis 命令同时执行，保证了操作不会被其他指令插入或打扰。","Properties":{"id":""}}]},{"ID":"20220906204063-58f3jyv","Type":"NodeParagraph","Properties":{"id":"20220906204063-58f3jyv","updated":"20220906204063"},"Children":[{"Type":"NodeText","Data":"如果 Lua 脚本运行时出错并中途结束，出错之后的命令是不会被执行的。并且，出错之前执行的命令是无法被撤销的。因此，严格来说，通过 Lua 脚本来批量执行 Redis 命令也是不满足原子性的。","Properties":{"id":""}}]},{"ID":"20220906204064-sjmijms","Type":"NodeParagraph","Properties":{"id":"20220906204064-sjmijms","updated":"20220906204064"},"Children":[{"Type":"NodeText","Data":"另外，Redis 7.0 新增了 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://redis.io/docs/manual/programmability/functions-intro/","TextMarkTextContent":"Redis functions"},{"Type":"NodeText","Data":" 特性，你可以将 Redis functions 看作是比 Lua 更强大的脚本。","Properties":{"id":""}}]},{"ID":"20220906204065-0nxanzg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204065-0nxanzg","updated":"20220906204065"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 性能优化","Properties":{"id":""}}]},{"ID":"20220906204066-rzwku5y","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204066-rzwku5y","updated":"20220906204066"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis bigkey","Properties":{"id":""}}]},{"ID":"20220906204067-8fyfcc6","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204067-8fyfcc6","updated":"20220906204067"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 bigkey？","Properties":{"id":""}}]},{"ID":"20220906204068-o8fotsf","Type":"NodeParagraph","Properties":{"id":"20220906204068-o8fotsf","updated":"20220906204068"},"Children":[{"Type":"NodeText","Data":"简单来说，如果一个 key 对应的 value 所占用的内存比较大，那这个 key 就可以看作是 bigkey。具体多大才算大呢？有一个不是特别精确的参考标准：string 类型的 value 超过 10 kb，复合类型的 value 包含的元素超过 5000 个（对于复合类型的 value 来说，不一定包含的元素越多，占用的内存就越多）。","Properties":{"id":""}}]},{"ID":"20220906204069-bj8vo2i","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204069-bj8vo2i","updated":"20220906204069"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"bigkey 有什么危害？","Properties":{"id":""}}]},{"ID":"20220906204070-ecdlsld","Type":"NodeParagraph","Properties":{"id":"20220906204070-ecdlsld","updated":"20220906204070"},"Children":[{"Type":"NodeText","Data":"除了会消耗更多的内存空间，bigkey 对性能也会有比较大的影响。","Properties":{"id":""}}]},{"ID":"20220906204071-v1388uy","Type":"NodeParagraph","Properties":{"id":"20220906204071-v1388uy","updated":"20220906204071"},"Children":[{"Type":"NodeText","Data":"因此，我们应该尽量避免写入 bigkey！","Properties":{"id":""}}]},{"ID":"20220906204072-auxa8wh","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204072-auxa8wh","updated":"20220906204072"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何发现 bigkey？","Properties":{"id":""}}]},{"ID":"20220906204073-h0t99ki","Type":"NodeParagraph","Properties":{"id":"20220906204073-h0t99ki","updated":"20220906204073"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1、使用 Redis 自带的 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"--bigkeys"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 参数来查找。"}]},{"ID":"20220906204074-lal0rpj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"YmFzaA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204074-lal0rpj","updated":"20220906204074"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"YmFzaA==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# redis-cli -p 6379 --bigkeys\n\n# Scanning the entire keyspace to find biggest keys as well as\n# average sizes per key type.  You can use -i 0.1 to sleep 0.1 sec\n# per 100 SCAN commands (not usually needed).\n\n[00.00%] Biggest string found so far '\"ballcat:oauth:refresh_auth:f6cdb384-9a9d-4f2f-af01-dc3f28057c20\"' with 4437 bytes\n[00.00%] Biggest list   found so far '\"my-list\"' with 17 items\n\n-------- summary -------\n\nSampled 5 keys in the keyspace!\nTotal key length in bytes is 264 (avg len 52.80)\n\nBiggest   list found '\"my-list\"' has 17 items\nBiggest string found '\"ballcat:oauth:refresh_auth:f6cdb384-9a9d-4f2f-af01-dc3f28057c20\"' has 4437 bytes\n\n1 lists with 17 items (20.00% of keys, avg size 17.00)\n0 hashs with 0 fields (00.00% of keys, avg size 0.00)\n4 strings with 4831 bytes (80.00% of keys, avg size 1207.75)\n0 streams with 0 entries (00.00% of keys, avg size 0.00)\n0 sets with 0 members (00.00% of keys, avg size 0.00)\n0 zsets with 0 members (00.00% of keys, avg size 0.00\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204075-neh4tlw","Type":"NodeParagraph","Properties":{"id":"20220906204075-neh4tlw","updated":"20220906204075"},"Children":[{"Type":"NodeText","Data":"从这个命令的运行结果，我们可以看出：这个命令会扫描(Scan) Redis 中的所有 key ，会对 Redis 的性能有一点影响。并且，这种方式只能找出每种数据结构 top 1 bigkey（占用内存最大的 string 数据类型，包含元素最多的复合数据类型）。","Properties":{"id":""}}]},{"ID":"20220906204076-a4lsdye","Type":"NodeParagraph","Properties":{"id":"20220906204076-a4lsdye","updated":"20220906204076"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2、分析 RDB 文件"}]},{"ID":"20220906204077-i0yedru","Type":"NodeParagraph","Properties":{"id":"20220906204077-i0yedru","updated":"20220906204077"},"Children":[{"Type":"NodeText","Data":"通过分析 RDB 文件来找出 big key。这种方案的前提是你的 Redis 采用的是 RDB 持久化。","Properties":{"id":""}}]},{"ID":"20220906204078-y9kdrl1","Type":"NodeParagraph","Properties":{"id":"20220906204078-y9kdrl1","updated":"20220906204078"},"Children":[{"Type":"NodeText","Data":"网上有现成的代码/工具可以直接拿来使用：","Properties":{"id":""}}]},{"ID":"20220906204079-v0b8sw8","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204079-v0b8sw8","updated":"20220906204079"},"Children":[{"ID":"20220906204080-mwh6wrr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204080-mwh6wrr","updated":"20220906204080"},"Children":[{"ID":"20220906204081-4pg6pou","Type":"NodeParagraph","Properties":{"id":"20220906204081-4pg6pou","updated":"20220906204081"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/sripathikrishnan/redis-rdb-tools","TextMarkTextContent":"redis-rdb-tools"},{"Type":"NodeText","Data":" ：Python 语言写的用来分析 Redis 的 RDB 快照文件用的工具","Properties":{"id":""}}]}]},{"ID":"20220906204082-kwtithn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204082-kwtithn","updated":"20220906204082"},"Children":[{"ID":"20220906204083-kkym1cj","Type":"NodeParagraph","Properties":{"id":"20220906204083-kkym1cj","updated":"20220906204083"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://github.com/weiyanwei412/rdb_bigkeys","TextMarkTextContent":"rdb_bigkeys"},{"Type":"NodeText","Data":" : Go 语言写的用来分析 Redis 的 RDB 快照文件用的工具，性能更好。","Properties":{"id":""}}]}]}]},{"ID":"20220906204084-pe2shm7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204084-pe2shm7","updated":"20220906204084"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"大量 key 集中过期问题","Properties":{"id":""}}]},{"ID":"20220906204085-lw4m3oh","Type":"NodeParagraph","Properties":{"id":"20220906204085-lw4m3oh","updated":"20220906204085"},"Children":[{"Type":"NodeText","Data":"我在上面提到过：对于过期 key，Redis 采用的是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"定期删除+惰性/懒汉式删除"},{"Type":"NodeText","Data":" 策略。","Properties":{"id":""}}]},{"ID":"20220906204086-5ye2vh4","Type":"NodeParagraph","Properties":{"id":"20220906204086-5ye2vh4","updated":"20220906204086"},"Children":[{"Type":"NodeText","Data":"定期删除执行过程中，如果突然遇到大量过期 key 的话，客户端请求必须等待定期清理过期 key 任务线程执行完成，因为这个这个定期任务线程是在 Redis 主线程中执行的。这就导致客户端请求没办法被及时处理，响应速度会比较慢。","Properties":{"id":""}}]},{"ID":"20220906204087-sl5d34k","Type":"NodeParagraph","Properties":{"id":"20220906204087-sl5d34k","updated":"20220906204087"},"Children":[{"Type":"NodeText","Data":"如何解决呢？下面是两种常见的方法：","Properties":{"id":""}}]},{"ID":"20220906204088-exh270u","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204088-exh270u","updated":"20220906204088"},"Children":[{"ID":"20220906204089-4dnpmvs","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204089-4dnpmvs","updated":"20220906204089"},"Children":[{"ID":"20220906204090-lmqqxyz","Type":"NodeParagraph","Properties":{"id":"20220906204090-lmqqxyz","updated":"20220906204090"},"Children":[{"Type":"NodeText","Data":"给 key 设置随机过期时间。","Properties":{"id":""}}]}]},{"ID":"20220906204091-swtnomq","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204091-swtnomq","updated":"20220906204091"},"Children":[{"ID":"20220906204092-w1tcwwx","Type":"NodeParagraph","Properties":{"id":"20220906204092-w1tcwwx","updated":"20220906204092"},"Children":[{"Type":"NodeText","Data":"开启 lazy-free（惰性删除/延迟释放） 。lazy-free 特性是 Redis 4.0 开始引入的，指的是让 Redis 采用异步方式延迟释放 key 使用的内存，将该操作交给单独的子线程处理，避免阻塞主线程。","Properties":{"id":""}}]}]}]},{"ID":"20220906204093-6auul8m","Type":"NodeParagraph","Properties":{"id":"20220906204093-6auul8m","updated":"20220906204093"},"Children":[{"Type":"NodeText","Data":"个人建议不管是否开启 lazy-free，我们都尽量给 key 设置随机过期时间。","Properties":{"id":""}}]},{"ID":"20220906204094-maygy7y","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906204094-maygy7y","updated":"20220906204094"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Redis 生产问题","Properties":{"id":""}}]},{"ID":"20220906204095-owdg7c7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204095-owdg7c7","updated":"20220906204095"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"缓存穿透","Properties":{"id":""}}]},{"ID":"20220906204096-uv436mc","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204096-uv436mc","updated":"20220906204096"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是缓存穿透？","Properties":{"id":""}}]},{"ID":"20220906204097-ns8quap","Type":"NodeParagraph","Properties":{"id":"20220906204097-ns8quap","updated":"20220906204097"},"Children":[{"Type":"NodeText","Data":"缓存穿透说简单点就是大量请求的 key 根本不存在于缓存中，导致请求直接到了数据库上，根本没有经过缓存这一层。举个例子：某个黑客故意制造我们缓存中不存在的 key 发起大量请求，导致大量请求落到数据库。","Properties":{"id":""}}]},{"ID":"20220906204098-nju23a8","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204098-nju23a8","updated":"20220906204098"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"缓存穿透情况的处理流程是怎样的？","Properties":{"id":""}}]},{"ID":"20220906204099-mudf1g7","Type":"NodeParagraph","Properties":{"id":"20220906204099-mudf1g7","updated":"20220906204099"},"Children":[{"Type":"NodeText","Data":"如下图所示，用户的请求最终都要跑到数据库中查询一遍。","Properties":{"id":""}}]},{"ID":"20220906204100-0dgmlbr","Type":"NodeParagraph","Properties":{"id":"20220906204100-0dgmlbr","updated":"20220906204100"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"缓存穿透情况","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-cache-penetration.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204101-l8zgc6q","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204101-l8zgc6q","updated":"20220906204101"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"有哪些解决办法？","Properties":{"id":""}}]},{"ID":"20220906204102-vdm0lvb","Type":"NodeParagraph","Properties":{"id":"20220906204102-vdm0lvb","updated":"20220906204102"},"Children":[{"Type":"NodeText","Data":"最基本的就是首先做好参数校验，一些不合法的参数请求直接抛出异常信息返回给客户端。比如查询的数据库 id 不能小于 0、传入的邮箱格式不对的时候直接返回错误消息给客户端等等。","Properties":{"id":""}}]},{"ID":"20220906204103-88cdn30","Type":"NodeParagraph","Properties":{"id":"20220906204103-88cdn30","updated":"20220906204103"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"1）缓存无效 key"}]},{"ID":"20220906204104-uclxhwk","Type":"NodeParagraph","Properties":{"id":"20220906204104-uclxhwk","updated":"20220906204104"},"Children":[{"Type":"NodeText","Data":"如果缓存和数据库都查不到某个 key 的数据就写一个到 Redis 中去并设置过期时间，具体命令如下： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"SET key value EX 10086"},{"Type":"NodeText","Data":" 。这种方式可以解决请求的 key 变化不频繁的情况，如果黑客恶意攻击，每次构建不同的请求 key，会导致 Redis 中缓存大量无效的 key 。很明显，这种方案并不能从根本上解决此问题。如果非要用这种方式来解决穿透问题的话，尽量将无效的 key 的过期时间设置短一点比如 1 分钟。","Properties":{"id":""}}]},{"ID":"20220906204105-467tjh1","Type":"NodeParagraph","Properties":{"id":"20220906204105-467tjh1","updated":"20220906204105"},"Children":[{"Type":"NodeText","Data":"另外，这里多说一嘴，一般情况下我们是这样设计 key 的： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"表名:列名:主键名:主键值"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204106-il0fjn1","Type":"NodeParagraph","Properties":{"id":"20220906204106-il0fjn1","updated":"20220906204106"},"Children":[{"Type":"NodeText","Data":"如果用 Java 代码展示的话，差不多是下面这样的：","Properties":{"id":""}}]},{"ID":"20220906204107-mez2jay","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204107-mez2jay","updated":"20220906204107"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"public Object getObjectInclNullById(Integer id) {\n    // 从缓存中获取数据\n    Object cacheValue = cache.get(id);\n    // 缓存为空\n    if (cacheValue == null) {\n        // 从数据库中获取\n        Object storageValue = storage.get(key);\n        // 缓存空对象\n        cache.set(key, storageValue);\n        // 如果存储数据为空，需要设置一个过期时间(300秒)\n        if (storageValue == null) {\n            // 必须设置过期时间，否则有被攻击的风险\n            cache.expire(key, 60 * 5);\n        }\n        return storageValue;\n    }\n    return cacheValue;\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204108-hzmv5re","Type":"NodeParagraph","Properties":{"id":"20220906204108-hzmv5re","updated":"20220906204108"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2）布隆过滤器"}]},{"ID":"20220906204109-zfywldz","Type":"NodeParagraph","Properties":{"id":"20220906204109-zfywldz","updated":"20220906204109"},"Children":[{"Type":"NodeText","Data":"布隆过滤器是一个非常神奇的数据结构，通过它我们可以非常方便地判断一个给定数据是否存在于海量数据中。我们需要的就是判断 key 是否合法，有没有感觉布隆过滤器就是我们想要找的那个“人”。","Properties":{"id":""}}]},{"ID":"20220906204110-umshnp3","Type":"NodeParagraph","Properties":{"id":"20220906204110-umshnp3","updated":"20220906204110"},"Children":[{"Type":"NodeText","Data":"具体是这样做的：把所有可能存在的请求的值都存放在布隆过滤器中，当用户请求过来，先判断用户发来的请求的值是否存在于布隆过滤器中。不存在的话，直接返回请求参数错误信息给客户端，存在的话才会走下面的流程。","Properties":{"id":""}}]},{"ID":"20220906204111-qg7x8y1","Type":"NodeParagraph","Properties":{"id":"20220906204111-qg7x8y1","updated":"20220906204111"},"Children":[{"Type":"NodeText","Data":"加入布隆过滤器之后的缓存处理流程图如下。","Properties":{"id":""}}]},{"ID":"20220906204112-vwkkbc7","Type":"NodeParagraph","Properties":{"id":"20220906204112-vwkkbc7","updated":"20220906204112"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"加入布隆过滤器之后的缓存处理流程图","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/database/redis/redis-cache-penetration-bloom-filter.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204113-aetz5gd","Type":"NodeParagraph","Properties":{"id":"20220906204113-aetz5gd","updated":"20220906204113"},"Children":[{"Type":"NodeText","Data":"但是，需要注意的是布隆过滤器可能会存在误判的情况。总结来说就是： ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"布隆过滤器说某个元素存在，小概率会误判。布隆过滤器说某个元素不在，那么这个元素一定不在。"}]},{"ID":"20220906204114-0h3bge7","Type":"NodeParagraph","Properties":{"id":"20220906204114-0h3bge7","updated":"20220906204114"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"为什么会出现误判的情况呢? 我们还要从布隆过滤器的原理来说！"}]},{"ID":"20220906204115-85x43d7","Type":"NodeParagraph","Properties":{"id":"20220906204115-85x43d7","updated":"20220906204115"},"Children":[{"Type":"NodeText","Data":"我们先来看一下，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"当一个元素加入布隆过滤器中的时候，会进行哪些操作："}]},{"ID":"20220906204116-p17zqfj","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204116-p17zqfj","updated":"20220906204116"},"Children":[{"ID":"20220906204117-x0q3az3","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204117-x0q3az3","updated":"20220906204117"},"Children":[{"ID":"20220906204118-f2y59rq","Type":"NodeParagraph","Properties":{"id":"20220906204118-f2y59rq","updated":"20220906204118"},"Children":[{"Type":"NodeText","Data":"使用布隆过滤器中的哈希函数对元素值进行计算，得到哈希值（有几个哈希函数得到几个哈希值）。","Properties":{"id":""}}]}]},{"ID":"20220906204119-jnlde1f","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204119-jnlde1f","updated":"20220906204119"},"Children":[{"ID":"20220906204120-5qhsuov","Type":"NodeParagraph","Properties":{"id":"20220906204120-5qhsuov","updated":"20220906204120"},"Children":[{"Type":"NodeText","Data":"根据得到的哈希值，在位数组中把对应下标的值置为 1。","Properties":{"id":""}}]}]}]},{"ID":"20220906204121-3otfqwb","Type":"NodeParagraph","Properties":{"id":"20220906204121-3otfqwb","updated":"20220906204121"},"Children":[{"Type":"NodeText","Data":"我们再来看一下，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"当我们需要判断一个元素是否存在于布隆过滤器的时候，会进行哪些操作："}]},{"ID":"20220906204122-1i3ah7y","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204122-1i3ah7y","updated":"20220906204122"},"Children":[{"ID":"20220906204123-l3bgbkp","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204123-l3bgbkp","updated":"20220906204123"},"Children":[{"ID":"20220906204124-u0f1p3r","Type":"NodeParagraph","Properties":{"id":"20220906204124-u0f1p3r","updated":"20220906204124"},"Children":[{"Type":"NodeText","Data":"对给定元素再次进行相同的哈希计算；","Properties":{"id":""}}]}]},{"ID":"20220906204125-3jm141g","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204125-3jm141g","updated":"20220906204125"},"Children":[{"ID":"20220906204126-dp2h6sy","Type":"NodeParagraph","Properties":{"id":"20220906204126-dp2h6sy","updated":"20220906204126"},"Children":[{"Type":"NodeText","Data":"得到值之后判断位数组中的每个元素是否都为 1，如果值都为 1，那么说明这个值在布隆过滤器中，如果存在一个值不为 1，说明该元素不在布隆过滤器中。","Properties":{"id":""}}]}]}]},{"ID":"20220906204127-fg8bmzw","Type":"NodeParagraph","Properties":{"id":"20220906204127-fg8bmzw","updated":"20220906204127"},"Children":[{"Type":"NodeText","Data":"然后，一定会出现这样一种情况：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不同的字符串可能哈希出来的位置相同。"},{"Type":"NodeText","Data":" （可以适当增加位数组大小或者调整我们的哈希函数来降低概率）","Properties":{"id":""}}]},{"ID":"20220906204128-aoy75kz","Type":"NodeParagraph","Properties":{"id":"20220906204128-aoy75kz","updated":"20220906204128"},"Children":[{"Type":"NodeText","Data":"更多关于布隆过滤器的内容可以看我的这篇原创：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javaguide.cn/cs-basics/data-structure/bloom-filter/","TextMarkTextContent":"《不了解布隆过滤器？一文给你整的明明白白！》"},{"Type":"NodeText","Data":" ，强烈推荐，个人感觉网上应该找不到总结的这么明明白白的文章了。","Properties":{"id":""}}]},{"ID":"20220906204129-dtlopzb","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204129-dtlopzb","updated":"20220906204129"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"缓存雪崩","Properties":{"id":""}}]},{"ID":"20220906204130-tw0z09s","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204130-tw0z09s","updated":"20220906204130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是缓存雪崩？","Properties":{"id":""}}]},{"ID":"20220906204131-hjxved0","Type":"NodeParagraph","Properties":{"id":"20220906204131-hjxved0","updated":"20220906204131"},"Children":[{"Type":"NodeText","Data":"我发现缓存雪崩这名字起的有点意思，哈哈。","Properties":{"id":""}}]},{"ID":"20220906204132-v85qdpd","Type":"NodeParagraph","Properties":{"id":"20220906204132-v85qdpd","updated":"20220906204132"},"Children":[{"Type":"NodeText","Data":"实际上，缓存雪崩描述的就是这样一个简单的场景：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缓存在同一时间大面积的失效，后面的请求都直接落到了数据库上，造成数据库短时间内承受大量请求。"},{"Type":"NodeText","Data":" 这就好比雪崩一样，摧枯拉朽之势，数据库的压力可想而知，可能直接就被这么多请求弄宕机了。","Properties":{"id":""}}]},{"ID":"20220906204133-snlvszr","Type":"NodeParagraph","Properties":{"id":"20220906204133-snlvszr","updated":"20220906204133"},"Children":[{"Type":"NodeText","Data":"举个例子：系统的缓存模块出了问题比如宕机导致不可用。造成系统的所有访问，都要走数据库。","Properties":{"id":""}}]},{"ID":"20220906204134-zqehx3o","Type":"NodeParagraph","Properties":{"id":"20220906204134-zqehx3o","updated":"20220906204134"},"Children":[{"Type":"NodeText","Data":"还有一种缓存雪崩的场景是：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"有一些被大量访问数据（热点缓存）在某一时刻大面积失效，导致对应的请求直接落到了数据库上。"},{"Type":"NodeText","Data":" 这样的情况，有下面几种解决办法：","Properties":{"id":""}}]},{"ID":"20220906204135-gkq51aa","Type":"NodeParagraph","Properties":{"id":"20220906204135-gkq51aa","updated":"20220906204135"},"Children":[{"Type":"NodeText","Data":"举个例子 ：秒杀开始 12 个小时之前，我们统一存放了一批商品到 Redis 中，设置的缓存过期时间也是 12 个小时，那么秒杀开始的时候，这些秒杀的商品的访问直接就失效了。导致的情况就是，相应的请求直接就落到了数据库上，就像雪崩一样可怕。","Properties":{"id":""}}]},{"ID":"20220906204136-dk25m9b","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204136-dk25m9b","updated":"20220906204136"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"有哪些解决办法？","Properties":{"id":""}}]},{"ID":"20220906204137-gfy8lby","Type":"NodeParagraph","Properties":{"id":"20220906204137-gfy8lby","updated":"20220906204137"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"针对 Redis 服务不可用的情况："}]},{"ID":"20220906204138-nx6by6y","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204138-nx6by6y","updated":"20220906204138"},"Children":[{"ID":"20220906204139-wk2ociq","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204139-wk2ociq","updated":"20220906204139"},"Children":[{"ID":"20220906204140-0swrvyo","Type":"NodeParagraph","Properties":{"id":"20220906204140-0swrvyo","updated":"20220906204140"},"Children":[{"Type":"NodeText","Data":"采用 Redis 集群，避免单机出现问题整个缓存服务都没办法使用。","Properties":{"id":""}}]}]},{"ID":"20220906204141-zgou5kz","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204141-zgou5kz","updated":"20220906204141"},"Children":[{"ID":"20220906204142-n6nhzhz","Type":"NodeParagraph","Properties":{"id":"20220906204142-n6nhzhz","updated":"20220906204142"},"Children":[{"Type":"NodeText","Data":"限流，避免同时处理大量的请求。","Properties":{"id":""}}]}]}]},{"ID":"20220906204143-i8y2tam","Type":"NodeParagraph","Properties":{"id":"20220906204143-i8y2tam","updated":"20220906204143"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"针对热点缓存失效的情况："}]},{"ID":"20220906204144-1u83mxw","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204144-1u83mxw","updated":"20220906204144"},"Children":[{"ID":"20220906204145-ruq2e0l","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204145-ruq2e0l","updated":"20220906204145"},"Children":[{"ID":"20220906204146-xqkpiu4","Type":"NodeParagraph","Properties":{"id":"20220906204146-xqkpiu4","updated":"20220906204146"},"Children":[{"Type":"NodeText","Data":"设置不同的失效时间比如随机设置缓存的失效时间。","Properties":{"id":""}}]}]},{"ID":"20220906204147-6daf2t6","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204147-6daf2t6","updated":"20220906204147"},"Children":[{"ID":"20220906204148-mupu8ng","Type":"NodeParagraph","Properties":{"id":"20220906204148-mupu8ng","updated":"20220906204148"},"Children":[{"Type":"NodeText","Data":"缓存永不失效。","Properties":{"id":""}}]}]}]},{"ID":"20220906204149-5dpvel2","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204149-5dpvel2","updated":"20220906204149"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何保证缓存和数据库数据的一致性？","Properties":{"id":""}}]},{"ID":"20220906204150-cpw1awb","Type":"NodeParagraph","Properties":{"id":"20220906204150-cpw1awb","updated":"20220906204150"},"Children":[{"Type":"NodeText","Data":"细说的话可以扯很多，但是我觉得其实没太大必要（小声 BB：很多解决方案我也没太弄明白）。我个人觉得引入缓存之后，如果为了短时间的不一致性问题，选择让系统设计变得更加复杂的话，完全没必要。","Properties":{"id":""}}]},{"ID":"20220906204151-oluw93l","Type":"NodeParagraph","Properties":{"id":"20220906204151-oluw93l","updated":"20220906204151"},"Children":[{"Type":"NodeText","Data":"下面单独对 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Cache Aside Pattern（旁路缓存模式）"},{"Type":"NodeText","Data":" 来聊聊。","Properties":{"id":""}}]},{"ID":"20220906204152-dunorej","Type":"NodeParagraph","Properties":{"id":"20220906204152-dunorej","updated":"20220906204152"},"Children":[{"Type":"NodeText","Data":"Cache Aside Pattern 中遇到写请求是这样的：更新 DB，然后直接删除 cache 。","Properties":{"id":""}}]},{"ID":"20220906204153-n7465st","Type":"NodeParagraph","Properties":{"id":"20220906204153-n7465st","updated":"20220906204153"},"Children":[{"Type":"NodeText","Data":"如果更新数据库成功，而删除缓存这一步失败的情况的话，简单说两个解决方案：","Properties":{"id":""}}]},{"ID":"20220906204154-cbf7075","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204154-cbf7075","updated":"20220906204154"},"Children":[{"ID":"20220906204155-ugqibht","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204155-ugqibht","updated":"20220906204155"},"Children":[{"ID":"20220906204156-b24cyj5","Type":"NodeParagraph","Properties":{"id":"20220906204156-b24cyj5","updated":"20220906204156"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"缓存失效时间变短（不推荐，治标不治本）"},{"Type":"NodeText","Data":" ：我们让缓存数据的过期时间变短，这样的话缓存就会从数据库中加载数据。另外，这种解决办法对于先操作缓存后操作数据库的场景不适用。","Properties":{"id":""}}]}]},{"ID":"20220906204157-ytxgsth","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204157-ytxgsth","updated":"20220906204157"},"Children":[{"ID":"20220906204158-d1zx3i0","Type":"NodeParagraph","Properties":{"id":"20220906204158-d1zx3i0","updated":"20220906204158"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"增加 cache 更新重试机制（常用）"},{"Type":"NodeText","Data":"： 如果 cache 服务当前不可用导致缓存删除失败的话，我们就隔一段时间进行重试，重试次数可以自己定。如果多次重试还是失败的话，我们可以把当前更新失败的 key 存入队列中，等缓存服务可用之后，再将缓存中对应的 key 删除即可。","Properties":{"id":""}}]}]}]},{"ID":"20220906204159-sqffibm","Type":"NodeParagraph","Properties":{"id":"20220906204159-sqffibm","updated":"20220906204159"},"Children":[{"Type":"NodeText","Data":"相关文章推荐：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://mp.weixin.qq.com/s?__biz=MzIyOTYxNDI5OA==\u0026mid=2247487312\u0026idx=1\u0026sn=fa19566f5729d6598155b5c676eee62d\u0026chksm=e8beb8e5dfc931f3e35655da9da0b61c79f2843101c130cf38996446975014f958a6481aacf1\u0026scene=178\u0026cur_album_id=1699766580538032128#rd","TextMarkTextContent":"缓存和数据库一致性问题，看这篇就够了 - 水滴与银弹"}]}]}