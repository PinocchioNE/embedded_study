   //类对象加锁\n            synchronized (Singleton.class) {\n                if (uniqueInstance == null) {\n                    uniqueInstance = new Singleton();\n                }\n            }\n        }\n        return uniqueInstance;\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204021-8tzc28x","Type":"NodeParagraph","Properties":{"id":"20220906204021-8tzc28x","updated":"20220906204021"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":" 采用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 关键字修饰也是很有必要的， ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance = new Singleton();"},{"Type":"NodeText","Data":" 这段代码其实是分为三步执行：","Properties":{"id":""}}]},{"ID":"20220906204022-eq7jni6","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204022-eq7jni6","updated":"20220906204022"},"Children":[{"ID":"20220906204023-5viqxb9","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204023-5viqxb9","updated":"20220906204023"},"Children":[{"ID":"20220906204024-u5pnrbz","Type":"NodeParagraph","Properties":{"id":"20220906204024-u5pnrbz","updated":"20220906204024"},"Children":[{"Type":"NodeText","Data":"为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":" 分配内存空间","Properties":{"id":""}}]}]},{"ID":"20220906204025-oolmtk8","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204025-oolmtk8","updated":"20220906204025"},"Children":[{"ID":"20220906204026-c8k1b0m","Type":"NodeParagraph","Properties":{"id":"20220906204026-c8k1b0m","updated":"20220906204026"},"Children":[{"Type":"NodeText","Data":"初始化 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"}]}]},{"ID":"20220906204027-d6620ex","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204027-d6620ex","updated":"20220906204027"},"Children":[{"ID":"20220906204028-hg2hyl1","Type":"NodeParagraph","Properties":{"id":"20220906204028-hg2hyl1","updated":"20220906204028"},"Children":[{"Type":"NodeText","Data":"将 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":" 指向分配的内存地址","Properties":{"id":""}}]}]}]},{"ID":"20220906204029-gl33omu","Type":"NodeParagraph","Properties":{"id":"20220906204029-gl33omu","updated":"20220906204029"},"Children":[{"Type":"NodeText","Data":"但是由于 JVM 具有指令重排的特性，执行顺序有可能变成 1-\u003e3-\u003e2。指令重排在单线程环境下不会出现问题，但是在多线程环境下会导致一个线程获得还没有初始化的实例。例如，线程 T1 执行了 1 和 3，此时 T2 调用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"getUniqueInstance"},{"Type":"NodeText","Data":"() 后发现 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":" 不为空，因此返回 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":"，但此时 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"uniqueInstance"},{"Type":"NodeText","Data":" 还未被初始化。","Properties":{"id":""}}]},{"ID":"20220906204030-l5cvzon","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204030-l5cvzon","updated":"20220906204030"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"volatile 可以保证原子性么？","Properties":{"id":""}}]},{"ID":"20220906204031-dtklq70","Type":"NodeParagraph","Properties":{"id":"20220906204031-dtklq70","updated":"20220906204031"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"volatile"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 关键字能保证变量的可见性，但不能保证对变量的操作是原子性的。"}]},{"ID":"20220906204032-e0ylo52","Type":"NodeParagraph","Properties":{"id":"20220906204032-e0ylo52","updated":"20220906204032"},"Children":[{"Type":"NodeText","Data":"我们通过下面的代码即可证明：","Properties":{"id":""}}]},{"ID":"20220906204033-stu28bp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906204033-stu28bp","updated":"20220906204033"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"/**\n * 微信搜 JavaGuide 回复\"面试突击\"即可免费领取个人原创的 Java 面试手册\n *\n * @author Guide哥\n * @date 2022/08/03 13:40\n **/\npublic class VolatoleAtomicityDemo {\n    public volatile static int inc = 0;\n\n    public void increase() {\n        inc++;\n    }\n\n    public static void main(String[] args) throws InterruptedException {\n        ExecutorService threadPool = Executors.newFixedThreadPool(5);\n        VolatoleAtomicityDemo volatoleAtomicityDemo = new VolatoleAtomicityDemo();\n        for (int i = 0; i \u003c 5; i++) {\n            threadPool.execute(() -\u003e {\n                for (int j = 0; j \u003c 500; j++) {\n                    volatoleAtomicityDemo.increase();\n                }\n            });\n        }\n        // 等待1.5秒，保证上面程序执行完成\n        Thread.sleep(1500);\n        System.out.println(inc);\n        threadPool.shutdown();\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906204034-t1sfk44","Type":"NodeParagraph","Properties":{"id":"20220906204034-t1sfk44","updated":"20220906204034"},"Children":[{"Type":"NodeText","Data":"正常情况下，运行上面的代码理应输出 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"2500"},{"Type":"NodeText","Data":"。但你真正运行了上面的代码之后，你会发现每次输出结果都小于 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"2500"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204035-780nwt6","Type":"NodeParagraph","Properties":{"id":"20220906204035-780nwt6","updated":"20220906204035"},"Children":[{"Type":"NodeText","Data":"为什么会出现这种情况呢？不是说好了，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 可以保证变量的可见性嘛！","Properties":{"id":""}}]},{"ID":"20220906204036-76lbyeb","Type":"NodeParagraph","Properties":{"id":"20220906204036-76lbyeb","updated":"20220906204036"},"Children":[{"Type":"NodeText","Data":"也就是说，如果 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 能保证 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"inc++"},{"Type":"NodeText","Data":" 操作的原子性的话。每个线程中对 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"inc"},{"Type":"NodeText","Data":" 变量自增完之后，其他线程可以立即看到修改后的值。5 个线程分别进行了 500 次操作，那么最终 inc 的值应该是 5*","Properties":{"id":""}},{"Type":"NodeText","Data":"500=2500。","Properties":{"id":""}}]},{"ID":"20220906204037-up561bh","Type":"NodeParagraph","Properties":{"id":"20220906204037-up561bh","updated":"20220906204037"},"Children":[{"Type":"NodeText","Data":"很多人会误认为自增操作 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"inc++"},{"Type":"NodeText","Data":" 是原子性的，实际上，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"inc++"},{"Type":"NodeText","Data":" 其实是一个复合操作，包括三步：","Properties":{"id":""}}]},{"ID":"20220906204038-zknyefw","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204038-zknyefw","updated":"20220906204038"},"Children":[{"ID":"20220906204039-rgum2r1","Type":"NodeListItem","Data":"1","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MQ==","Num":1},"Properties":{"id":"20220906204039-rgum2r1","updated":"20220906204039"},"Children":[{"ID":"20220906204040-baoiwcm","Type":"NodeParagraph","Properties":{"id":"20220906204040-baoiwcm","updated":"20220906204040"},"Children":[{"Type":"NodeText","Data":"读取 inc 的值。","Properties":{"id":""}}]}]},{"ID":"20220906204041-02c9t4f","Type":"NodeListItem","Data":"2","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mg==","Num":2},"Properties":{"id":"20220906204041-02c9t4f","updated":"20220906204041"},"Children":[{"ID":"20220906204042-jw3oddi","Type":"NodeParagraph","Properties":{"id":"20220906204042-jw3oddi","updated":"20220906204042"},"Children":[{"Type":"NodeText","Data":"对 inc 加 1。","Properties":{"id":""}}]}]},{"ID":"20220906204043-idzmw4i","Type":"NodeListItem","Data":"3","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"Mw==","Num":3},"Properties":{"id":"20220906204043-idzmw4i