2019-6/synchronized关键字原理2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906204120-dggp8qw","Type":"NodeParagraph","Properties":{"id":"20220906204120-dggp8qw","updated":"20220906204120"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 修饰的方法并没有 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorenter"},{"Type":"NodeText","Data":" 指令和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorexit"},{"Type":"NodeText","Data":" 指令，取得代之的确实是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ACC_SYNCHRONIZED"},{"Type":"NodeText","Data":" 标识，该标识指明了该方法是一个同步方法。JVM 通过该 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ACC_SYNCHRONIZED"},{"Type":"NodeText","Data":" 访问标志来辨别一个方法是否声明为同步方法，从而执行相应的同步调用。","Properties":{"id":""}}]},{"ID":"20220906204121-n006vki","Type":"NodeParagraph","Properties":{"id":"20220906204121-n006vki","updated":"20220906204121"},"Children":[{"Type":"NodeText","Data":"如果是实例方法，JVM 会尝试获取实例对象的锁。如果是静态方法，JVM 会尝试获取当前 class 的锁。","Properties":{"id":""}}]},{"ID":"20220906204122-jxbojg5","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204122-jxbojg5","updated":"20220906204122"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"总结","Properties":{"id":""}}]},{"ID":"20220906204123-hski4f7","Type":"NodeParagraph","Properties":{"id":"20220906204123-hski4f7","updated":"20220906204123"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 同步语句块的实现使用的是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorenter"},{"Type":"NodeText","Data":" 和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorexit"},{"Type":"NodeText","Data":" 指令，其中 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorenter"},{"Type":"NodeText","Data":" 指令指向同步代码块的开始位置，","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorexit"},{"Type":"NodeText","Data":" 指令则指明同步代码块的结束位置。","Properties":{"id":""}}]},{"ID":"20220906204124-6h4wf37","Type":"NodeParagraph","Properties":{"id":"20220906204124-6h4wf37","updated":"20220906204124"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 修饰的方法并没有 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorenter"},{"Type":"NodeText","Data":" 指令和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitorexit"},{"Type":"NodeText","Data":" 指令，取得代之的确实是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ACC_SYNCHRONIZED"},{"Type":"NodeText","Data":" 标识，该标识指明了该方法是一个同步方法。","Properties":{"id":""}}]},{"ID":"20220906204125-k1fojmz","Type":"NodeParagraph","Properties":{"id":"20220906204125-k1fojmz","updated":"20220906204125"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"不过两者的本质都是对对象监视器 monitor 的获取。"}]},{"ID":"20220906204126-xp74vyj","Type":"NodeParagraph","Properties":{"id":"20220906204126-xp74vyj","updated":"20220906204126"},"Children":[{"Type":"NodeText","Data":"相关推荐：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://tech.youzan.com/javasuo-yu-xian-cheng-de-na-xie-shi/","TextMarkTextContent":"Java 锁与线程的那些事 - 有赞技术团队"},{"Type":"NodeText","Data":" 。","Properties":{"id":""}}]},{"ID":"20220906204127-8rnpu8k","Type":"NodeParagraph","Properties":{"id":"20220906204127-8rnpu8k","updated":"20220906204127"},"Children":[{"Type":"NodeText","Data":"🧗🏻 进阶一下：学有余力的小伙伴可以抽时间详细研究一下对象监视器 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"monitor"},{"Type":"NodeText","Data":"。","Properties":{"id":""}}]},{"ID":"20220906204128-fomk7ty","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204128-fomk7ty","updated":"20220906204128"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"JDK1.6 之后的 synchronized 关键字底层做了哪些优化？","Properties":{"id":""}}]},{"ID":"20220906204129-wxrtcf4","Type":"NodeParagraph","Properties":{"id":"20220906204129-wxrtcf4","updated":"20220906204129"},"Children":[{"Type":"NodeText","Data":"JDK1.6 对锁的实现引入了大量的优化，如偏向锁、轻量级锁、自旋锁、适应性自旋锁、锁消除、锁粗化等技术来减少锁操作的开销。","Properties":{"id":""}}]},{"ID":"20220906204130-v1rliw6","Type":"NodeParagraph","Properties":{"id":"20220906204130-v1rliw6","updated":"20220906204130"},"Children":[{"Type":"NodeText","Data":"锁主要存在四种状态，依次是：无锁状态、偏向锁状态、轻量级锁状态、重量级锁状态，他们会随着竞争的激烈而逐渐升级。注意锁可以升级不可降级，这种策略是为了提高获得锁和释放锁的效率。","Properties":{"id":""}}]},{"ID":"20220906204131-5mmfr7v","Type":"NodeParagraph","Properties":{"id":"20220906204131-5mmfr7v","updated":"20220906204131"},"Children":[{"Type":"NodeText","Data":"关于这几种优化的详细信息可以查看下面这篇文章：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://www.cnblogs.com/wuqinglong/p/9945618.html","TextMarkTextContent":"Java6 及以上版本对 synchronized 的优化"}]},{"ID":"20220906204132-d0vjq2r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204132-d0vjq2r","updated":"20220906204132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"synchronized 和 volatile 的区别？","Properties":{"id":""}}]},{"ID":"20220906204133-k951d7l","Type":"NodeParagraph","Properties":{"id":"20220906204133-k951d7l","updated":"20220906204133"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 关键字和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 关键字是两个互补的存在，而不是对立的存在！","Properties":{"id":""}}]},{"ID":"20220906204134-2dra494","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204134-2dra494","updated":"20220906204134"},"Children":[{"ID":"20220906204135-fijm2c3","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204135-fijm2c3","updated":"20220906204135"},"Children":[{"ID":"20220906204136-679ykbr","Type":"NodeParagraph","Properties":{"id":"20220906204136-679ykbr","updated":"20220906204136"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 关键字是线程同步的轻量级实现，所以 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":"性能肯定比","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":"关键字要好 。但是 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 关键字只能用于变量而 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 关键字可以修饰方法以及代码块 。","Properties":{"id":""}}]}]},{"ID":"20220906204137-xnqktmp","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204137-xnqktmp","updated":"20220906204137"},"Children":[{"ID":"20220906204138-7ig6log","Type":"NodeParagraph","Properties":{"id":"20220906204138-7ig6log","updated":"20220906204138"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":" 关键字能保证数据的可见性，但不能保证数据的原子性。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 关键字两者都能保证。","Properties":{"id":""}}]}]},{"ID":"20220906204139-s0hs5kd","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906204139-s0hs5kd","updated":"20220906204139"},"Children":[{"ID":"20220906204140-xpizxbp","Type":"NodeParagraph","Properties":{"id":"20220906204140-xpizxbp","updated":"20220906204140"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"volatile"},{"Type":"NodeText","Data":"关键字主要用于解决变量在多个线程之间的可见性，而 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 关键字解决的是多个线程之间访问资源的同步性。","Properties":{"id":""}}]}]}]},{"ID":"20220906204141-2ieyk5h","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906204141-2ieyk5h","updated":"20220906204141"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"synchronized 和 ReentrantLock 的区别","Properties":{"id":""}}]},{"ID":"20220906204142-oz0tkzt","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204142-oz0tkzt","updated":"20220906204142"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"两者都是可重入锁","Properties":{"id":""}}]},{"ID":"20220906204143-88mdjco","Type":"NodeParagraph","Properties":{"id":"20220906204143-88mdjco","updated":"20220906204143"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"“可重入锁”"},{"Type":"NodeText","Data":" 指的是自己可以再次获取自己的内部锁。比如一个线程获得了某个对象的锁，此时这个对象锁还没有释放，当其再次想要获取这个对象的锁的时候还是可以获取的，如果是不可重入锁的话，就会造成死锁。同一个线程每次获取锁，锁的计数器都自增 1，所以要等到锁的计数器下降为 0 时才能释放锁。","Properties":{"id":""}}]},{"ID":"20220906204144-9p53r2s","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204144-9p53r2s","updated":"20220906204144"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"synchronized 依赖于 JVM 而 ReentrantLock 依赖于 API","Properties":{"id":""}}]},{"ID":"20220906204145-04oryra","Type":"NodeParagraph","Properties":{"id":"20220906204145-04oryra","updated":"20220906204145"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 是依赖于 JVM 实现的，前面我们也讲到了 虚拟机团队在 JDK1.6 为 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"synchronized"},{"Type":"NodeText","Data":" 关键字进行了很多优化，但是这些优化都是在虚拟机层面实现的，并没有直接暴露给我们。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"ReentrantLock"},{"Type":"NodeText","Data":" 是 JDK 层面实现的（也就是 API 层面，需要 lock() 和 unlock() 方法配合 try/finally 语句块来完成），所以我们可以通过查看它的源代码，来看它是如何实现的。","Properties":{"id":""}}]},{"ID":"20220906204146-3vv3ng7","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906204146-3vv3ng7","updated":"20220906204146"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ReentrantLock 比 synchronized 增加了一些高级功能","Properties":{"id":""}}]},{"ID":"20220906204147-6trw