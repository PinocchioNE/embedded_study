ht":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203757-au1yk3q","updated":"20220906203757"},"Children":[{"ID":"20220906203758-kmfjf3v","Type":"NodeParagraph","Properties":{"id":"20220906203758-kmfjf3v","updated":"20220906203758"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-jdbc"},{"Type":"NodeText","Data":" ：提供了对数据库访问的抽象 JDBC。不同的数据库都有自己独立的 API 用于操作数据库，而 Java 程序只需要和 JDBC API 交互，这样就屏蔽了数据库的影响。","Properties":{"id":""}}]}]},{"ID":"20220906203759-0k2b15j","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203759-0k2b15j","updated":"20220906203759"},"Children":[{"ID":"20220906203760-9ab8rc0","Type":"NodeParagraph","Properties":{"id":"20220906203760-9ab8rc0","updated":"20220906203760"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-tx"},{"Type":"NodeText","Data":" ：提供对事务的支持。","Properties":{"id":""}}]}]},{"ID":"20220906203761-u7agsd2","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203761-u7agsd2","updated":"20220906203761"},"Children":[{"ID":"20220906203762-8rlrji0","Type":"NodeParagraph","Properties":{"id":"20220906203762-8rlrji0","updated":"20220906203762"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-orm"},{"Type":"NodeText","Data":" ： 提供对 Hibernate、JPA 、iBatis 等 ORM 框架的支持。","Properties":{"id":""}}]}]},{"ID":"20220906203763-cphlcbc","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203763-cphlcbc","updated":"20220906203763"},"Children":[{"ID":"20220906203764-11yulzp","Type":"NodeParagraph","Properties":{"id":"20220906203764-11yulzp","updated":"20220906203764"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-oxm"},{"Type":"NodeText","Data":" ：提供一个抽象层支撑 OXM(Object-to-XML-Mapping)，例如：JAXB、Castor、XMLBeans、JiBX 和 XStream 等。","Properties":{"id":""}}]}]},{"ID":"20220906203765-jk38k4e","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203765-jk38k4e","updated":"20220906203765"},"Children":[{"ID":"20220906203766-jv58zac","Type":"NodeParagraph","Properties":{"id":"20220906203766-jv58zac","updated":"20220906203766"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-jms"},{"Type":"NodeText","Data":" : 消息服务。自 Spring Framework 4.1 以后，它还提供了对 spring-messaging 模块的继承。","Properties":{"id":""}}]}]}]},{"ID":"20220906203767-v9lkbyw","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906203767-v9lkbyw","updated":"20220906203767"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring Web","Properties":{"id":""}}]},{"ID":"20220906203768-dt2zn5x","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203768-dt2zn5x","updated":"20220906203768"},"Children":[{"ID":"20220906203769-rzozydt","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203769-rzozydt","updated":"20220906203769"},"Children":[{"ID":"20220906203770-qq2lifo","Type":"NodeParagraph","Properties":{"id":"20220906203770-qq2lifo","updated":"20220906203770"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-web"},{"Type":"NodeText","Data":" ：对 Web 功能的实现提供一些最基础的支持。","Properties":{"id":""}}]}]},{"ID":"20220906203771-ffat48h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203771-ffat48h","updated":"20220906203771"},"Children":[{"ID":"20220906203772-a62uxe4","Type":"NodeParagraph","Properties":{"id":"20220906203772-a62uxe4","updated":"20220906203772"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-webmvc"},{"Type":"NodeText","Data":" ： 提供对 Spring MVC 的实现。","Properties":{"id":""}}]}]},{"ID":"20220906203773-z7wz1to","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203773-z7wz1to","updated":"20220906203773"},"Children":[{"ID":"20220906203774-osl744p","Type":"NodeParagraph","Properties":{"id":"20220906203774-osl744p","updated":"20220906203774"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-websocket"},{"Type":"NodeText","Data":" ： 提供了对 WebSocket 的支持，WebSocket 可以让客户端和服务端进行双向通信。","Properties":{"id":""}}]}]},{"ID":"20220906203775-5nh0oo4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203775-5nh0oo4","updated":"20220906203775"},"Children":[{"ID":"20220906203776-k8hrbfs","Type":"NodeParagraph","Properties":{"id":"20220906203776-k8hrbfs","updated":"20220906203776"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-webflux"},{"Type":"NodeText","Data":" ：提供对 WebFlux 的支持。WebFlux 是 Spring Framework 5.0 中引入的新的响应式框架。与 Spring MVC 不同，它不需要 Servlet API，是完全异步。","Properties":{"id":""}}]}]}]},{"ID":"20220906203777-amxgcka","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906203777-amxgcka","updated":"20220906203777"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Messaging","Properties":{"id":""}}]},{"ID":"20220906203778-riud2ts","Type":"NodeParagraph","Properties":{"id":"20220906203778-riud2ts","updated":"20220906203778"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"spring-messaging"},{"Type":"NodeText","Data":" 是从 Spring4.0 开始新加入的一个模块，主要职责是为 Spring 框架集成一些基础的报文传送应用。","Properties":{"id":""}}]},{"ID":"20220906203779-tupa55v","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20220906203779-tupa55v","updated":"20220906203779"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring Test","Properties":{"id":""}}]},{"ID":"20220906203780-hwc2yvp","Type":"NodeParagraph","Properties":{"id":"20220906203780-hwc2yvp","updated":"20220906203780"},"Children":[{"Type":"NodeText","Data":"Spring 团队提倡测试驱动开发（TDD）。有了控制反转 (IoC)的帮助，单元测试和集成测试变得更简单。","Properties":{"id":""}}]},{"ID":"20220906203781-a0yiflc","Type":"NodeParagraph","Properties":{"id":"20220906203781-a0yiflc","updated":"20220906203781"},"Children":[{"Type":"NodeText","Data":"Spring 的测试模块对 JUnit（单元测试框架）、TestNG（类似 JUnit）、Mockito（主要用来 Mock 对象）、PowerMock（解决 Mockito 的问题比如无法模拟 final, static， private 方法）等等常用的测试框架支持的都比较好。","Properties":{"id":""}}]},{"ID":"20220906203782-3as3l81","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203782-3as3l81","updated":"20220906203782"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring,Spring MVC,Spring Boot 之间什么关系?","Properties":{"id":""}}]},{"ID":"20220906203783-2fncmjv","Type":"NodeParagraph","Properties":{"id":"20220906203783-2fncmjv","updated":"20220906203783"},"Children":[{"Type":"NodeText","Data":"很多人对 Spring,Spring MVC,Spring Boot 这三者傻傻分不清楚！这里简单介绍一下这三者，其实很简单，没有什么高深的东西。","Properties":{"id":""}}]},{"ID":"20220906203784-rn95rn2","Type":"NodeParagraph","Properties":{"id":"20220906203784-rn95rn2","updated":"20220906203784"},"Children":[{"Type":"NodeText","Data":"Spring 包含了多个功能模块（上面刚刚提高过），其中最重要的是 Spring-Core（主要提供 IoC 依赖注入功能的支持） 模块， Spring 中的其他模块（比如 Spring MVC）的功能实现基本都需要依赖于该模块。","Properties":{"id":""}}]},{"ID":"20220906203785-crchmmn","Type":"NodeParagraph","Properties":{"id":"20220906203785-crchmmn","updated":"20220906203785"},"Children":[{"Type":"NodeText","Data":"下图对应的是 Spring4.x 版本。目前最新的 5.x 版本中 Web 模块的 Portlet 组件已经被废弃掉，同时增加了用于异步响应式处理的 WebFlux 组件。","Properties":{"id":""}}]},{"ID":"20220906203786-ytonk5v","Type":"NodeParagraph","Properties":{"id":"20220906203786-ytonk5v","updated":"20220906203786"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"Spring主要模块","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/github/javaguide/jvme0c60b4606711fc4a0b6faf03230247a.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203787-w6zir5f","Type":"NodeParagraph","Properties":{"id":"20220906203787-w6zir5f","updated":"20220906203787"},"Children":[{"Type":"NodeText","Data":"Spring MVC 是 Spring 中的一个很重要的模块，主要赋予 Spring 快速构建 MVC 架构的 Web 程序的能力。MVC 是模型(Model)、视图(View)、控制器(Controller)的简写，其核心思想是通过将业务逻辑、数据、显示分离来组织代码。","Properties":{"id":""}}]},{"ID":"20220906203788-i6wf1qx","Type":"NodeParagraph","Properties":{"id":"20220906203788-i6wf1qx","updated":"20220906203788"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/image-20210809181452421.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203789-b9ff7j5","Type":"NodeParagraph","Properties":{"id":"20220906203789-b9ff7j5","updated":"20220906203789"},"Children":[{"Type":"NodeText","Data":"使用 Spring 进行开发各种配置过于麻烦比如开启某些 Spring 特性时，需要用 XML 或 Java 进行显式配置。于是，Spring Boot 诞生了！","Properties":{"id":""}}]},{"ID":"20220906203790-ykn2s9n","Type":"NodeParagraph","Properties":{"id":"20220906203790-ykn2s9n","updated":"20220906203790"},"Children":[{"Type":"NodeText","Data":"Spring 旨在简化 J2EE 企业应用程序开发。Spring Boot 旨在简化 Spring 开发（减少配置文件，开箱即用！）。","Properties":{"id":""}}]},{"ID":"20220906203791-d0jh0ao","Type":"NodeParagraph","Properties":{"id":"20220906203791-d0jh0ao","updated":"20220906203791"},"Children":[{"Type":"NodeText","Data":"Spring Boot 只是简化了配置，如果你需要构建 MVC 架构的 Web 程序，你还是需要使用 Spring MVC 作为 MVC 框架，只是说 Spring Boot 帮你简化了 Spring MVC 的很多配置，真正做到开箱即用！","Properties":{"id":""}}]},{"ID":"20220906203792-3bd3gq9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203792-3bd3gq9","updated":"20220906203792"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring IoC","Properties":{"id":""}}]},{"ID":"20220906203793-dl78dd3","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203793-dl78dd3","updated":"20220906203793"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"谈谈自己对于 Spring IoC 的了解","Properties":{"id":""}}]},{"ID":"20220906203794-mxzqdoi","Type":"NodeParagraph","Properties":{"id":"20220906203794-mxzqdoi","updated":"20220906203794"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"IoC（Inverse of Control:控制反转）"},{"Type":"NodeText","Data":" 是一种设计思想，而不是一个具体的技术实现。IoC 的思想就是将原本在程序中手动创建对象的控制权，交由 Spring 框架来管理。不过， IoC 并非 Spring 特有，在其他语言中也有应用。","Properties":{"id":""}}]},{"ID":"20220906203795-mlnrpd2","Type":"NodeParagraph","Properties":{"id":"20220906203795-mlnrpd2","updated":"20220906203795"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"为什么叫控制反转？"}]},{"ID":"20220906203796-tuj9ejp","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203796-tuj9ejp","updated":"20220906203796"},"Children":[{"ID":"20220906203797-fykjx1d","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203797-fykjx1d","updated":"20220906203797"},"Children":[{"ID":"20220906203798-f56zman","Type":"NodeParagraph","Properties":{"id":"20220906203798-f56zman","updated":"20220906203798"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"控制"},{"Type":"NodeText","Data":" ：指的是对象创建（实例化、管理）的权力","Properties":{"id":""}}]}]},{"ID":"20220906203799-kokenlf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203799-kokenlf","updated":"20220906203799"},"Children":[{"ID":"20220906203800-4oy41jw","Type":"NodeParagraph","Properties":{"id":"20220906203800-4oy41jw","updated":"20220906203800"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"反转"},{"Type":"NodeText","Data":" ：控制权交给外部环境（Spring 框架、IoC 容器）","Properties":{"id":""}}]}]}]},{"ID":"20220906203801-cf6lixh","Type":"NodeParagraph","Properties":{"id":"20220906203801-cf6lixh","updated":"20220906203801"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/frc-365faceb5697f04f31399937c059c162.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203802-nt134en","Type":"NodeParagraph","Properties":{"id":"20220906203802-nt134en","updated":"20220906203802"},"Children":[{"Type":"NodeText","Data":"将对象之间的相互依赖关系交给 IoC 容器来管理，并由 IoC 容器完成对象的注入。这样可以很大程度上简化应用的开发，把应用从复杂的依赖关系中解放出来。 IoC 容器就像是一个工厂一样，当我们需要创建一个对象的时候，只需要配置好配置文件/注解即可，完全不用考虑对象是如何被创建出来的。","Properties":{"id":""}}]},{"ID":"20220906203803-na59dwv","Type":"NodeParagraph","Properties":{"id":"20220906203803-na59dwv","updated":"20220906203803"},"Children":[{"Type":"NodeText","Data":"在实际项目中一个 Service 类可能依赖了很多其他的类，假如我们需要实例化这个 Service，你可能要每次都要搞清这个 Service 所有底层类的构造函数，这可能会把人逼疯。如果利用 IoC 的话，你只需要配置好，然后在需要的地方引用就行了，这大大增加了项目的可维护性且降低了开发难度。","Properties":{"id":""}}]},{"ID":"20220906203804-zax9jsu","Type":"NodeParagraph","Properties":{"id":"20220906203804-zax9jsu","updated":"20220906203804"},"Children":[{"Type":"NodeText","Data":"在 Spring 中， IoC 容器是 Spring 用来实现 IoC 的载体， IoC 容器实际上就是个 Map（key，value），Map 中存放的是各种对象。","Properties":{"id":""}}]},{"ID":"20220906203805-gfmf7fq","Type":"NodeParagraph","Properties":{"id":"20220906203805-gfmf7fq","updated":"20220906203805"},"Children":[{"Type":"NodeText","Data":"Spring 时代我们一般通过 XML 文件来配置 Bean，后来开发人员觉得 XML 文件来配置不太好，于是 SpringBoot 注解配置就慢慢开始流行起来。","Properties":{"id":""}}]},{"ID":"20220906203806-2d7iqto","Type":"NodeParagraph","Properties":{"id":"20220906203806-2d7iqto","updated":"20220906203806"},"Children":[{"Type":"NodeText","Data":"相关阅读：","Properties":{"id":""}}]},{"ID":"20220906203807-wy7ghk2","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203807-wy7ghk2","updated":"20220906203807"},"Children":[{"ID":"20220906203808-o5xsr9t","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203808-o5xsr9t","updated":"20220906203808"},"Children":[{"ID":"20220906203809-u6jnvjt","Type":"NodeParagraph","Properties":{"id":"20220906203809-u6jnvjt","updated":"20220906203809"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://javadoop.com/post/spring-ioc","TextMarkTextContent":"IoC 源码阅读"}]}]},{"ID":"20220906203810-qb4kefn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203810-qb4kefn","updated":"20220906203810"},"Children":[{"ID":"20220906203811-20domty","Type":"NodeParagraph","Properties":{"id":"20220906203811-20domty","updated":"20220906203811"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"a","TextMarkAHref":"https://mp.weixin.qq.com/s?__biz=Mzg2OTA0Njk0OA==\u0026mid=2247486938\u0026idx=1\u0026sn=c99ef0233f39a5ffc1b98c81e02dfcd4\u0026chksm=cea24211f9d5cb07fa901183ba4d96187820713a72387788408040822ffb2ed575d28e953ce7\u0026token=1736772241\u0026lang=zh_CN#rd","TextMarkTextContent":"面试被问了几百遍的 IoC 和 AOP ，还在傻傻搞不清楚？"}]}]}]},{"ID":"20220906203812-gsom1s1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203812-gsom1s1","updated":"20220906203812"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"什么是 Spring Bean？","Properties":{"id":""}}]},{"ID":"20220906203813-r2jc9dg","Type":"NodeParagraph","Properties":{"id":"20220906203813-r2jc9dg","updated":"20220906203813"},"Children":[{"Type":"NodeText","Data":"简单来说，Bean 代指的就是那些被 IoC 容器所管理的对象。","Properties":{"id":""}}]},{"ID":"20220906203814-6hhqfyz","Type":"NodeParagraph","Properties":{"id":"20220906203814-6hhqfyz","updated":"20220906203814"},"Children":[{"Type":"NodeText","Data":"我们需要告诉 IoC 容器帮助我们管理哪些对象，这个是通过配置元数据来定义的。配置元数据可以是 XML 文件、注解或者 Java 配置类。","Properties":{"id":""}}]},{"ID":"20220906203815-shciaz7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"eG1s","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203815-shciaz7","updated":"20220906203815"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"eG1s","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"\u003c!-- Constructor-arg with 'value' attribute --\u003e\n\u003cbean id=\"...\" class=\"...\"\u003e\n   \u003cconstructor-arg value=\"...\"/\u003e\n\u003c/bean\u003e\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203816-4cqy3gy","Type":"NodeParagraph","Properties":{"id":"20220906203816-4cqy3gy","updated":"20220906203816"},"Children":[{"Type":"NodeText","Data":"下图简单地展示了 IoC 容器如何使用配置元数据来管理对象。","Properties":{"id":""}}]},{"ID":"20220906203817-hth9fyq","Type":"NodeParagraph","Properties":{"id":"20220906203817-hth9fyq","updated":"20220906203817"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/062b422bd7ac4d53afd28fb74b2bc94d.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203818-fktqy9n","Type":"NodeParagraph","Properties":{"id":"20220906203818-fktqy9n","updated":"20220906203818"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"org.springframework.beans"},{"Type":"NodeText","Data":"和 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"org.springframework.context"},{"Type":"NodeText","Data":" 这两个包是 IoC 实现的基础，如果想要研究 IoC 相关的源码的话，可以去看看","Properties":{"id":""}}]},{"ID":"202209