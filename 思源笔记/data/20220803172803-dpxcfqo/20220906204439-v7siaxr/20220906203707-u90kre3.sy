ype":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203931-w1dt4ra","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203931-w1dt4ra","updated":"20220906203931"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring AoP","Properties":{"id":""}}]},{"ID":"20220906203932-lj8hg0l","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203932-lj8hg0l","updated":"20220906203932"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"谈谈自己对于 AOP 的了解","Properties":{"id":""}}]},{"ID":"20220906203933-zloet4a","Type":"NodeParagraph","Properties":{"id":"20220906203933-zloet4a","updated":"20220906203933"},"Children":[{"Type":"NodeText","Data":"AOP(Aspect-Oriented Programming:面向切面编程)能够将那些与业务无关，却为业务模块所共同调用的逻辑或责任（例如事务处理、日志管理、权限控制等）封装起来，便于减少系统的重复代码，降低模块间的耦合度，并有利于未来的可拓展性和可维护性。","Properties":{"id":""}}]},{"ID":"20220906203934-4jr8uw2","Type":"NodeParagraph","Properties":{"id":"20220906203934-4jr8uw2","updated":"20220906203934"},"Children":[{"Type":"NodeText","Data":"Spring AOP 就是基于动态代理的，如果要代理的对象，实现了某个接口，那么 Spring AOP 会使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"JDK Proxy"},{"Type":"NodeText","Data":"，去创建代理对象，而对于没有实现接口的对象，就无法使用 JDK Proxy 去进行代理了，这时候 Spring AOP 会使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Cglib"},{"Type":"NodeText","Data":" 生成一个被代理对象的子类来作为代理，如下图所示：","Properties":{"id":""}}]},{"ID":"20220906203935-lmxpd4t","Type":"NodeParagraph","Properties":{"id":"20220906203935-lmxpd4t","updated":"20220906203935"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"SpringAOPProcess","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/img_convert/230ae587a322d6e4d09510161987d346.jpeg","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203936-o3x3ys8","Type":"NodeParagraph","Properties":{"id":"20220906203936-o3x3ys8","updated":"20220906203936"},"Children":[{"Type":"NodeText","Data":"当然你也可以使用 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"AspectJ"},{"Type":"NodeText","Data":" ！Spring AOP 已经集成了 AspectJ ，AspectJ 应该算的上是 Java 生态系统中最完整的 AOP 框架了。","Properties":{"id":""}}]},{"ID":"20220906203937-oylsk0s","Type":"NodeParagraph","Properties":{"id":"20220906203937-oylsk0s","updated":"20220906203937"},"Children":[{"Type":"NodeText","Data":"AOP 切面编程设计到的一些专业术语：","Properties":{"id":""}}]},{"ID":"20220906203938-zjo42kw","Type":"NodeTable","Data":"| 术语              |                             含义                             |\n| :---------------- | :----------------------------------------------------------: |\n| 目标(Target)      |                         被通知的对象                         |\n| 代理(Proxy)       |             向目标对象应用通知之后创建的代理对象             |\n| 连接点(JoinPoint) |         目标对象的所属类中，定义的所有方法均为连接点         |\n| 切入点(Pointcut)  | 被切面拦截 / 增强的连接点（切入点一定是连接点，连接点不一定是切入点） |\n| 通知(Advice)      | 增强的逻辑 / 代码，也即拦截到目标对象的连接点之后要做的事情  |\n| 切面(Aspect)      |                切入点(Pointcut)+通知(Advice)                 |\n| Weaving(织入)     |       将通知应用到目标对象，进而生成代理对象的过程动作       |","TableAligns":[1,2],"Properties":{"id":"20220906203938-zjo42kw","updated":"20220906203938"},"Children":[{"Type":"NodeTableHead","Properties":{"id":""},"Children":[{"Type":"NodeTableRow","Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"术语","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"含义","Properties":{"id":""}}]}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"目标(Target)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"被通知的对象","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"代理(Proxy)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"向目标对象应用通知之后创建的代理对象","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"连接点(JoinPoint)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"目标对象的所属类中，定义的所有方法均为连接点","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"切入点(Pointcut)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"被切面拦截 / 增强的连接点（切入点一定是连接点，连接点不一定是切入点）","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"通知(Advice)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"增强的逻辑 / 代码，也即拦截到目标对象的连接点之后要做的事情","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"切面(Aspect)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"切入点(Pointcut)+通知(Advice)","Properties":{"id":""}}]}]},{"Type":"NodeTableRow","TableAligns":[1,2],"Properties":{"id":""},"Children":[{"Type":"NodeTableCell","TableCellAlign":1,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"Weaving(织入)","Properties":{"id":""}}]},{"Type":"NodeTableCell","TableCellAlign":2,"Properties":{"id":""},"Children":[{"Type":"NodeText","Data":"将通知应用到目标对象，进而生成代理对象的过程动作","Properties":{"id":""}}]}]}]},{"ID":"20220906203939-sp0b81r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203939-sp0b81r","updated":"20220906203939"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring AOP 和 AspectJ AOP 有什么区别？","Properties":{"id":""}}]},{"ID":"20220906203940-1qikyjw","Type":"NodeParagraph","Properties":{"id":"20220906203940-1qikyjw","updated":"20220906203940"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Spring AOP 属于运行时增强，而 AspectJ 是编译时增强。"},{"Type":"NodeText","Data":" Spring AOP 基于代理(Proxying)，而 AspectJ 基于字节码操作(Bytecode Manipulation)。","Properties":{"id":""}}]},{"ID":"20220906203941-xs9gh8n","Type":"NodeParagraph","Properties":{"id":"20220906203941-xs9gh8n","updated":"20220906203941"},"Children":[{"Type":"NodeText","Data":"Spring AOP 已经集成了 AspectJ ，AspectJ 应该算的上是 Java 生态系统中最完整的 AOP 框架了。AspectJ 相比于 Spring AOP 功能更加强大，但是 Spring AOP 相对来说更简单，","Properties":{"id":""}}]},{"ID":"20220906203942-24fqatj","Type":"NodeParagraph","Properties":{"id":"20220906203942-24fqatj","updated":"20220906203942"},"Children":[{"Type":"NodeText","Data":"如果我们的切面比较少，那么两者性能差异不大。但是，当切面太多的话，最好选择 AspectJ ，它比 Spring AOP 快很多。","Properties":{"id":""}}]},{"ID":"20220906203943-0pcpzpd","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203943-0pcpzpd","updated":"20220906203943"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"AspectJ 定义的通知类型有哪些？","Properties":{"id":""}}]},{"ID":"20220906203944-xr5yodc","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203944-xr5yodc","updated":"20220906203944"},"Children":[{"ID":"20220906203945-q7b0tke","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203945-q7b0tke","updated":"20220906203945"},"Children":[{"ID":"20220906203946-ru1bb0e","Type":"NodeParagraph","Properties":{"id":"20220906203946-ru1bb0e","updated":"20220906203946"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Before"},{"Type":"NodeText","Data":"（前置通知）：目标对象的方法调用之前触发","Properties":{"id":""}}]}]},{"ID":"20220906203947-nrex7s6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203947-nrex7s6","updated":"20220906203947"},"Children":[{"ID":"20220906203948-g646vx7","Type":"NodeParagraph","Properties":{"id":"20220906203948-g646vx7","updated":"20220906203948"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"After"},{"Type":"NodeText","Data":" （后置通知）：目标对象的方法调用之后触发","Properties":{"id":""}}]}]},{"ID":"20220906203949-abdll6w","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203949-abdll6w","updated":"20220906203949"},"Children":[{"ID":"20220906203950-dqgzpkh","Type":"NodeParagraph","Properties":{"id":"20220906203950-dqgzpkh","updated":"20220906203950"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"AfterReturning"},{"Type":"NodeText","Data":"（返回通知）：目标对象的方法调用完成，在返回结果值之后触发","Properties":{"id":""}}]}]},{"ID":"20220906203951-ojoq3m1","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203951-ojoq3m1","updated":"20220906203951"},"Children":[{"ID":"20220906203952-zkt0epz","Type":"NodeParagraph","Properties":{"id":"20220906203952-zkt0epz","updated":"20220906203952"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"AfterThrowing"},{"Type":"NodeText","Data":"（异常通知） ：目标对象的方法运行中抛出 / 触发异常后触发。AfterReturning 和 AfterThrowing 两者互斥。如果方法调用成功无异常，则会有返回值；如果方法抛出了异常，则不会有返回值。","Properties":{"id":""}}]}]},{"ID":"20220906203953-krnm2v2","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203953-krnm2v2","updated":"20220906203953"},"Children":[{"ID":"20220906203954-d97alt6","Type":"NodeParagraph","Properties":{"id":"20220906203954-d97alt6","updated":"20220906203954"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Around"},{"Type":"NodeText","Data":"： （环绕通知）编程式控制目标对象的方法调用。环绕通知是所有通知类型中可操作范围最大的一种，因为它可以直接拿到目标对象，以及要执行的方法，所以环绕通知可以任意的在目标对象的方法调用前后搞事，甚至不调用目标对象的方法","Properties":{"id":""}}]}]}]},{"ID":"20220906203955-qab7mik","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203955-qab7mik","updated":"20220906203955"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"多个切面的执行顺序如何控制？","Properties":{"id":""}}]},{"ID":"20220906203956-gd4d6eq","Type":"NodeParagraph","Properties":{"id":"20220906203956-gd4d6eq","updated":"20220906203956"},"Children":[{"Type":"NodeText","Data":"1、通常使用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"@Order"},{"Type":"NodeText","Data":" 注解直接定义切面顺序","Properties":{"id":""}}]},{"ID":"20220906203957-twj0s4r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203957-twj0s4r","updated":"20220906203957"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"// 值越小优先级越高\n@Order(3)\n@Component\n@Aspect\npublic class LoggingAspect implements Ordered {\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203958-864j0oi","Type":"NodeParagraph","Properties":{"id":"20220906203958-864j0oi","updated":"20220906203958"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"2、实现"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"Ordered"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 接口重写 "},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong code","TextMarkTextContent":"getOrder"},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":" 方法。"}]},{"ID":"20220906203959-9njsn2v","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220906203959-9njsn2v","updated":"20220906203959"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ==","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"@Component\n@Aspect\npublic class LoggingAspect implements Ordered {\n\n    // ....\n\n    @Override\n    public int getOrder() {\n        // 返回值越小优先级越高\n        return 1;\n    }\n}\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220906203960-uh8mxb5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220906203960-uh8mxb5","updated":"20220906203960"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring MVC","Properties":{"id":""}}]},{"ID":"20220906203961-d69p2cr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203961-d69p2cr","updated":"20220906203961"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"说说自己对于 Spring MVC 了解?","Properties":{"id":""}}]},{"ID":"20220906203962-h4of2re","Type":"NodeParagraph","Properties":{"id":"20220906203962-h4of2re","updated":"20220906203962"},"Children":[{"Type":"NodeText","Data":"MVC 是模型(Model)、视图(View)、控制器(Controller)的简写，其核心思想是通过将业务逻辑、数据、显示分离来组织代码。","Properties":{"id":""}}]},{"ID":"20220906203963-j0uv7sb","Type":"NodeParagraph","Properties":{"id":"20220906203963-j0uv7sb","updated":"20220906203963"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/image-20210809181452421.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203964-neyusjg","Type":"NodeParagraph","Properties":{"id":"20220906203964-neyusjg","updated":"20220906203964"},"Children":[{"Type":"NodeText","Data":"网上有很多人说 MVC 不是设计模式，只是软件设计规范，我个人更倾向于 MVC 同样是众多设计模式中的一种。","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong a","TextMarkAHref":"https://github.com/iluwatar/java-design-patterns","TextMarkTextContent":"java-design-patterns"},{"Type":"NodeText","Data":" 项目中就有关于 MVC 的相关介绍。","Properties":{"id":""}}]},{"ID":"20220906203965-gjoncam","Type":"NodeParagraph","Properties":{"id":"20220906203965-gjoncam","updated":"20220906203965"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://img-blog.csdnimg.cn/159b3d3e70dd45e6afa81bf06d09264e.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203966-y6wfsop","Type":"NodeParagraph","Properties":{"id":"20220906203966-y6wfsop","updated":"20220906203966"},"Children":[{"Type":"NodeText","Data":"想要真正理解 Spring MVC，我们先来看看 Model 1 和 Model 2 这两个没有 Spring MVC 的时代。","Properties":{"id":""}}]},{"ID":"20220906203967-syv3fp5","Type":"NodeParagraph","Properties":{"id":"20220906203967-syv3fp5","updated":"20220906203967"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Model 1 时代"}]},{"ID":"20220906203968-76urp4u","Type":"NodeParagraph","Properties":{"id":"20220906203968-76urp4u","updated":"20220906203968"},"Children":[{"Type":"NodeText","Data":"很多学 Java 后端比较晚的朋友可能并没有接触过 Model 1 时代下的 JavaWeb 应用开发。在 Model1 模式下，整个 Web 应用几乎全部用 JSP 页面组成，只用少量的 JavaBean 来处理数据库连接、访问等操作。","Properties":{"id":""}}]},{"ID":"20220906203969-jel3o8q","Type":"NodeParagraph","Properties":{"id":"20220906203969-jel3o8q","updated":"20220906203969"},"Children":[{"Type":"NodeText","Data":"这个模式下 JSP 即是控制层（Controller）又是表现层（View）。显而易见，这种模式存在很多问题。比如控制逻辑和表现逻辑混杂在一起，导致代码重用率极低；再比如前端和后端相互依赖，难以进行测试维护并且开发效率极低。","Properties":{"id":""}}]},{"ID":"20220906203970-476ujzx","Type":"NodeParagraph","Properties":{"id":"20220906203970-476ujzx","updated":"20220906203970"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeLinkText","Data":"mvc-mode1","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/mvc-mode1.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203971-8t9ewsh","Type":"NodeParagraph","Properties":{"id":"20220906203971-8t9ewsh","updated":"20220906203971"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Model 2 时代"}]},{"ID":"20220906203972-vjzdhqp","Type":"NodeParagraph","Properties":{"id":"20220906203972-vjzdhqp","updated":"20220906203972"},"Children":[{"Type":"NodeText","Data":"学过 Servlet 并做过相关 Demo 的朋友应该了解“Java Bean(Model)+ JSP（View）+Servlet（Controller） ”这种开发模式，这就是早期的 JavaWeb MVC 开发模式。","Properties":{"id":""}}]},{"ID":"20220906203973-3v0zllu","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203973-3v0zllu","updated":"20220906203973"},"Children":[{"ID":"20220906203974-1ttff83","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203974-1ttff83","updated":"20220906203974"},"Children":[{"ID":"20220906203975-iovlpej","Type":"NodeParagraph","Properties":{"id":"20220906203975-iovlpej","updated":"20220906203975"},"Children":[{"Type":"NodeText","Data":"Model:系统涉及的数据，也就是 dao 和 bean。","Properties":{"id":""}}]}]},{"ID":"20220906203976-nzaccmq","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203976-nzaccmq","updated":"20220906203976"},"Children":[{"ID":"20220906203977-ood1zz4","Type":"NodeParagraph","Properties":{"id":"20220906203977-ood1zz4","updated":"20220906203977"},"Children":[{"Type":"NodeText","Data":"View：展示模型中的数据，只是用来展示。","Properties":{"id":""}}]}]},{"ID":"20220906203978-1l46llz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203978-1l46llz","updated":"20220906203978"},"Children":[{"ID":"20220906203979-st33mr3","Type":"NodeParagraph","Properties":{"id":"20220906203979-st33mr3","updated":"20220906203979"},"Children":[{"Type":"NodeText","Data":"Controller：处理用户请求都发送给 ，返回数据给 JSP 并展示给用户。","Properties":{"id":""}}]}]}]},{"ID":"20220906203980-dpas29h","Type":"NodeParagraph","Properties":{"id":"20220906203980-dpas29h","updated":"20220906203980"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"https://guide-blog-images.oss-cn-shenzhen.aliyuncs.com/java-guide-blog/mvc-model2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220906203981-iz5ofj6","Type":"NodeParagraph","Properties":{"id":"20220906203981-iz5ofj6","updated":"20220906203981"},"Children":[{"Type":"NodeText","Data":"Model2 模式下还存在很多问题，Model2 的抽象和封装程度还远远不够，使用 Model2 进行开发时不可避免地会重复造轮子，这就大大降低了程序的可维护性和复用性。","Properties":{"id":""}}]},{"ID":"20220906203982-to1bots","Type":"NodeParagraph","Properties":{"id":"20220906203982-to1bots","updated":"20220906203982"},"Children":[{"Type":"NodeText","Data":"于是，很多 JavaWeb 开发相关的 MVC 框架应运而生比如 Struts2，但是 Struts2 比较笨重。","Properties":{"id":""}}]},{"ID":"20220906203983-6y8kpnn","Type":"NodeParagraph","Properties":{"id":"20220906203983-6y8kpnn","updated":"20220906203983"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"Spring MVC 时代"}]},{"ID":"20220906203984-ib7jqcm","Type":"NodeParagraph","Properties":{"id":"20220906203984-ib7jqcm","updated":"20220906203984"},"Children":[{"Type":"NodeText","Data":"随着 Spring 轻量级开发框架的流行，Spring 生态圈出现了 Spring MVC 框架， Spring MVC 是当前最优秀的 MVC 框架。相比于 Struts2 ， Spring MVC 使用更加简单和方便，开发效率更高，并且 Spring MVC 运行速度更快。","Properties":{"id":""}}]},{"ID":"20220906203985-n2v6bkl","Type":"NodeParagraph","Properties":{"id":"20220906203985-n2v6bkl","updated":"20220906203985"},"Children":[{"Type":"NodeText","Data":"MVC 是一种设计模式，Spring MVC 是一款很优秀的 MVC 框架。Spring MVC 可以帮助我们进行更简洁的 Web 层的开发，并且它天生与 Spring 框架集成。Spring MVC 下我们一般把后端项目分为 Service 层（处理业务）、Dao 层（数据库操作）、Entity 层（实体类）、Controller 层(控制层，返回数据给前台页面)。","Properties":{"id":""}}]},{"ID":"20220906203986-ut5g2q8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220906203986-ut5g2q8","updated":"20220906203986"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Spring MVC 的核心组件有哪些？","Properties":{"id":""}}]},{"ID":"20220906203987-3eu56rm","Type":"NodeParagraph","Properties":{"id":"20220906203987-3eu56rm","updated":"20220906203987"},"Children":[{"Type":"NodeText","Data":"记住了下面这些组件，也就记住了 SpringMVC 的工作原理。","Properties":{"id":""}}]},{"ID":"20220906203988-aby1pqy","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203988-aby1pqy","updated":"20220906203988"},"Children":[{"ID":"20220906203989-po5uujs","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20220906203989-po5uujs","updated":"20220906203989"},"Children