ype":"NodeText","Data":"平安银行-数据应用（苏州）----"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"简历挂"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"}]},{"ID":"20220924105606-bgdd057","Type":"NodeParagraph","Properties":{"id":"20220924105606-bgdd057","updated":"20220924105614"},"Children":[{"Type":"NodeText","Data":"byd-南京\u0026杭州"}]},{"ID":"20221012150327-aaair5s","Type":"NodeParagraph","Properties":{"id":"20221012150327-aaair5s","updated":"20221012150351"},"Children":[{"Type":"NodeText","Data":"江苏农商银行-科技岗\u0026数据岗（苏州）"}]},{"ID":"20221017144921-3py3ve1","Type":"NodeParagraph","Properties":{"id":"20221017144921-3py3ve1","updated":"20221017144941"},"Children":[{"Type":"NodeText","Data":"上海银行-苏州IT岗\u0026总行测试岗（苏州）"}]},{"ID":"20221025090345-0ens8kr","Type":"NodeParagraph","Properties":{"id":"20221025090345-0ens8kr","updated":"20221025090415"},"Children":[{"Type":"NodeText","Data":"innovusion-软开\u0026软件标定（苏州）"}]},{"ID":"20221025092958-tkna9tz","Type":"NodeParagraph","Properties":{"id":"20221025092958-tkna9tz","updated":"20221025093018"},"Children":[{"Type":"NodeText","Data":"江苏广播电视总台-网络技术\u0026网络运维（南京）"}]},{"ID":"20220803201741-jmdxk7j","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220803201741-jmdxk7j","updated":"20220803201750"},"Children":[{"Type":"NodeText","Data":"简历快填"}]},{"ID":"20220803201751-l77osa1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220803201751-l77osa1","updated":"20220803201930"},"Children":[{"Type":"NodeText","Data":"实习"}]},{"ID":"20220807151715-v5wk96j","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807151715-v5wk96j","updated":"20220807151716"},"Children":[{"Type":"NodeText","Data":"单位"}]},{"ID":"20220807151717-15g0z21","Type":"NodeBlockquote","Properties":{"id":"20220807151717-15g0z21","updated":"20220807151723"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807151718-3bo05ep","Type":"NodeParagraph","Properties":{"id":"20220807151718-3bo05ep","updated":"20220807151723"},"Children":[{"Type":"NodeText","Data":"中国科学院沈阳自动化研究所"}]}]},{"ID":"20220807150725-bxmvu2c","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807150725-bxmvu2c","updated":"20220807150727"},"Children":[{"Type":"NodeText","Data":"部门"}]},{"ID":"20220807150729-5nvbkaa","Type":"NodeBlockquote","Properties":{"id":"20220807150729-5nvbkaa","updated":"20220807150730"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807150730-xj9bw5n","Type":"NodeParagraph","Properties":{"id":"20220807150730-xj9bw5n","updated":"20220807150730"},"Children":[{"Type":"NodeText","Data":"工业网络控制与系统控制研究室"}]}]},{"ID":"20220803201931-hgkphvh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803201931-hgkphvh","updated":"20220803201934"},"Children":[{"Type":"NodeText","Data":"职责描述"}]},{"ID":"20220803201935-9h2q58e","Type":"NodeBlockquote","Properties":{"id":"20220803201935-9h2q58e","updated":"20221111111557"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803201937-k581q16","Type":"NodeParagraph","Properties":{"id":"20220803201937-k581q16","updated":"20220903123842"},"Children":[{"Type":"NodeText","Data":"1.参与研究所的各种科研项目，并及时与甲方/乙方进行沟通，共同推进项目进展；"}]},{"ID":"20220903123641-wfwh5b6","Type":"NodeParagraph","Properties":{"id":"20220903123641-wfwh5b6","updated":"20220903123843"},"Children":[{"Type":"NodeText","Data":"2.完成研究所导师布置的各种科研任务，并在每周组会上向导师汇报进展；"}]},{"ID":"20220903123641-0b8kdoa","Type":"NodeParagraph","Properties":{"id":"20220903123641-0b8kdoa","updated":"20220903123845"},"Children":[{"Type":"NodeText","Data":"3.大量阅读相关领域内最新发表的高水平论文，并进行整理学习；"}]},{"ID":"20220903123641-bh01a8p","Type":"NodeParagraph","Properties":{"id":"20220903123641-bh01a8p","updated":"20220903123847"},"Children":[{"Type":"NodeText","Data":"4.协助导师撰写项目申报书、专利、软件著作权等材料。"}]},{"ID":"20220831143836-tcth526","Type":"NodeParagraph","Properties":{"id":"20220831143836-tcth526","updated":"20220831143907"},"Children":[{"Type":"NodeText","Data":"项目描述：研究计算资源存在动态性和分布不均衡情况下的任务动态分配方法，设计具有线性复杂度的低开销、高可调度性的混合关键性计算任务调度技术，提升边缘侧计算任务调度效率。\n负责内容：1.基于KubeEdge搭建面向异构计算资源和实时调度的边缘计算平台，结合Docker技术实现资源虚拟化；\n2.采用Pytorch框架，构建Deep Q-Learning模型，使用强化学习对工业传感器生产任务进行算力资源需求量化分析，联合量化误差率结果仅2.62%；\n3.基于改进的EDF算法结合Tkinter设计具备并发大规模任务整体系统响应时间小于10毫秒的任务调度软件，基于量化分析的系统调度成功率可达99.63%。"}]},{"ID":"20221107121041-cbembco","Type":"NodeParagraph","Properties":{"id":"20221107121041-cbembco","updated":"20221111111557"},"Children":[{"Type":"NodeText","Data":"4.作为项目主要负责人进行结题汇报与测试认证，并于计算机应用大会宣讲项目核心的算法内容。\n项目成果：北大核心一篇、一区SCI一篇、发明专利两项、软件著作权一项、项目测试内容已通过国家CNAS认证。"}]}]},{"ID":"20220803202112-luq7uc8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202112-luq7uc8","updated":"20220803202115"},"Children":[{"Type":"NodeText","Data":"工作业绩"}]},{"ID":"20220803202116-v4ljn6z","Type":"NodeBlockquote","Properties":{"id":"20220803202116-v4ljn6z","updated":"20221111111606"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803202117-363sd16","Type":"NodeParagraph","Properties":{"id":"20220803202117-363sd16","updated":"20221111111606"},"Children":[{"Type":"NodeText","Data":"项目成果：北大核心一篇、一区SCI一篇、发明专利两项、软件著作权一项、项目测试内容已通过国家CNAS认证。"}]}]},{"ID":"20220803202340-wwom5sj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220803202340-wwom5sj","updated":"20220803202426"},"Children":[{"Type":"NodeText","Data":"项目经历-java"}]},{"ID":"20220807155014-w98dam3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807155014-w98dam3","updated":"20220807155015"},"Children":[{"Type":"NodeText","Data":"名称"}]},{"ID":"20220807155017-mia1drd","Type":"NodeBlockquote","Properties":{"id":"20220807155017-mia1drd","updated":"20220924105602"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807155018-m69us04","Type":"NodeParagraph","Properties":{"id":"20220807155018-m69us04","updated":"20220924105602"},"Children":[{"Type":"NodeText","Data":"沈阳化工大学F5座学生公寓百货售卖平台"}]}]},{"ID":"20220831124505-7xug9uo","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220831124505-7xug9uo","updated":"20220831124507"},"Children":[{"Type":"NodeText","Data":"时间"}]},{"ID":"20220831124510-p93vdn0","Type":"NodeBlockquote","Properties":{"id":"20220831124510-p93vdn0","updated":"20220831124511"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831124511-hmk1u7p","Type":"NodeParagraph","Properties":{"id":"20220831124511-hmk1u7p","updated":"20220831124511"},"Children":[{"Type":"NodeText","Data":"2021.06~2022.05"}]}]},{"ID":"20220807155037-c52mdpj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807155037-c52mdpj","updated":"20220807155039"},"Children":[{"Type":"NodeText","Data":"技术"}]},{"ID":"20220807155041-di3us2v","Type":"NodeBlockquote","Properties":{"id":"20220807155041-di3us2v","updated":"20220807155051"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807155041-fr902ki","Type":"NodeParagraph","Properties":{"id":"20220807155041-fr902ki","updated":"20220807155051"},"Children":[{"Type":"NodeText","Data":"Java、Mybatis-Plus、SpringBoot、MySQL、Redis"}]}]},{"ID":"20220803202353-kh1xvhc","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202353-kh1xvhc","updated":"20220803202358"},"Children":[{"Type":"NodeText","Data":"项目描述"}]},{"ID":"20220803202359-1zooskr","Type":"NodeBlockquote","Properties":{"id":"20220803202359-1zooskr","updated":"20220831124524"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803202405-nybbk4q","Type":"NodeParagraph","Properties":{"id":"20220803202405-nybbk4q","updated":"20220831124524"},"Children":[{"Type":"NodeText","Data":"搭建后端管理平台，主要内容包括后台人员管理、百货商品分类、货量信息维护；设计移动端应用，主要提供给宿舍楼内同学使用，包括在线浏览商品、购物车下单、添加寝室地址及个人信息。"}]}]},{"ID":"20220803202406-wi4x9xp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202406-wi4x9xp","updated":"20220803202410"},"Children":[{"Type":"NodeText","Data":"项目职责"}]},{"ID":"20220803202411-t8143pe","Type":"NodeBlockquote","Properties":{"id":"20220803202411-t8143pe","updated":"20221107093646"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221107093638-wm0hdtd","Type":"NodeParagraph","Properties":{"id":"20221107093638-wm0hdtd","updated":"20221107093642"},"Children":[{"Type":"NodeText","Data":"1.使用SpringBoot框架搭建商品信息的数据访问层，与MySQL数据库建立联系，结合Mybatis-Plus设计业务逻辑模块，并基于Vue2.0框架结合Element进行页面开发；"}]},{"ID":"20221107093638-yi0zg5i","Type":"NodeParagraph","Properties":{"id":"20221107093638-yi0zg5i","updated":"20221107093644"},"Children":[{"Type":"NodeText","Data":"2.采用Postman测试接口的可用性，完善并实现控制层与前端界面的交互；"}]},{"ID":"20221107093638-lelvgof","Type":"NodeParagraph","Properties":{"id":"20221107093638-lelvgof","updated":"20221107093646"},"Children":[{"Type":"NodeText","Data":"3.通过Redis将商品信息和用户信息的数据进行缓存，优化SQL性能。"}]}]},{"ID":"20220831124535-j25xoyi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220831124535-j25xoyi","updated":"20220831124537"},"Children":[{"Type":"NodeText","Data":"成果"}]},{"ID":"20220831124539-g0di7jq","Type":"NodeBlockquote","Properties":{"id":"20220831124539-g0di7jq","updated":"20220831124545"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831124540-1bnx6bx","Type":"NodeParagraph","Properties":{"id":"20220831124540-1bnx6bx","updated":"20220831124545"},"Children":[{"Type":"NodeText","Data":"对SpringBoot框架的基本原理有了新的认识，深刻理解了模块间的业务调用逻辑，了解了Redis的使用机制，学会了利用缓存技术提升系统性能。"}]}]},{"ID":"20220807155124-5099jq3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807155124-5099jq3","updated":"20220807155128"},"Children":[{"Type":"NodeText","Data":"职务"}]},{"ID":"20220807155129-3s4wpsm","Type":"NodeBlockquote","Properties":{"id":"20220807155129-3s4wpsm","updated":"20220901160331"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807155130-o3mg9ad","Type":"NodeParagraph","Properties":{"id":"20220807155130-o3mg9ad","updated":"20220901160331"},"Children":[{"Type":"NodeText","Data":"模块业务设计与性能优化"}]}]},{"ID":"20220803202421-8umb7to","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220803202421-8umb7to","updated":"20220803202437"},"Children":[{"Type":"NodeText","Data":"项目经历-重点研发"}]},{"ID":"20220807155003-9d03iz1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807155003-9d03iz1","updated":"20220807155009"},"Children":[{"Type":"NodeText","Data":"名称"}]},{"ID":"20220807155011-g78tniv","Type":"NodeBlockquote","Properties":{"id":"20220807155011-g78tniv","updated":"20220831130115"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807155012-qj4himb","Type":"NodeParagraph","Properties":{"id":"20220807155012-qj4himb","updated":"20220831130115"},"Children":[{"Type":"NodeText","Data":"国家重点研发项目：工业互联网边缘计算运行关键技术项目"}]}]},{"ID":"20220807155101-tq5fzql","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220807155101-tq5fzql","updated":"20220807155102"},"Children":[{"Type":"NodeText","Data":"技术"}]},{"ID":"20220807155103-qneah60","Type":"NodeBlockquote","Properties":{"id":"20220807155103-qneah60","updated":"20220807155106"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220807155106-e59dycb","Type":"NodeParagraph","Properties":{"id":"20220807155106-e59dycb","updated":"20220807155106"},"Children":[{"Type":"NodeText","Data":"Linux、Python、Docker、Kubernetes、KubeEdge"}]}]},{"ID":"20220803202439-ek41o7c","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202439-ek41o7c","updated":"20220803202442"},"Children":[{"Type":"NodeText","Data":"项目描述"}]},{"ID":"20220803202509-6t8fm1k","Type":"NodeBlockquote","Properties":{"id":"20220803202509-6t8fm1k","updated":"20220831124619"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803202509-1fs5oer","Type":"NodeParagraph","Properties":{"id":"20220803202509-1fs5oer","updated":"20220831124619"},"Children":[{"Type":"NodeText","Data":"研究计算资源存在动态性和分布不均衡情况下的任务动态分配方法，设计具有线性复杂度的低开销、高可调度性的混合关键性计算任务调度技术，提升边缘侧计算任务调度效率。"}]}]},{"ID":"20220803202442-y5j485o","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202442-y5j485o","updated":"20220803202445"},"Children":[{"Type":"NodeText","Data":"项目职责"}]},{"ID":"20220803202513-7s4e0p6","Type":"NodeBlockquote","Properties":{"id":"20220803202513-7s4e0p6","updated":"20221107094627"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803202513-57a1m2n","Type":"NodeParagraph","Properties":{"id":"20220803202513-57a1m2n","updated":"20221107094627"},"Children":[{"Type":"NodeText","Data":"1.基于KubeEdge搭建面向异构计算资源和实时调度的边缘计算平台，结合Docker技术实现资源虚拟化；"}]},{"ID":"20221107094627-jz9ece6","Type":"NodeParagraph","Properties":{"id":"20221107094627-jz9ece6"},"Children":[{"Type":"NodeText","Data":"2.采用Pytorch框架，构建Deep Q-Learning模型，使用强化学习对工业传感器生产任务进行算力资源需求量化分析，联合量化误差率结果仅2.62%；"}]},{"ID":"20221107094625-siyegpo","Type":"NodeParagraph","Properties":{"id":"20221107094625-siyegpo"},"Children":[{"Type":"NodeText","Data":"3.基于改进的EDF算法结合Tkinter设计具备并发大规模任务整体系统响应时间小于10毫秒的任务调度软件，基于量化分析的系统调度成功率可达99.63%。"}]},{"ID":"20221107094622-5exp4fg","Type":"NodeParagraph","Properties":{"id":"20221107094622-5exp4fg"},"Children":[{"Type":"NodeText","Data":"4.作为项目主要负责人进行结题汇报与测试认证，并于计算机应用大会宣讲项目核心的算法内容。"}]}]},{"ID":"20220831124639-rmde0t2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220831124639-rmde0t2","updated":"20220831142310"},"Children":[{"Type":"NodeText","Data":"项目成果"}]},{"ID":"20220831124643-6yuzgtt","Type":"NodeBlockquote","Properties":{"id":"20220831124643-6yuzgtt","updated":"20220831124648"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831124644-d8dtj9g","Type":"NodeParagraph","Properties":{"id":"20220831124644-d8dtj9g","updated":"20220831124648"},"Children":[{"Type":"NodeText","Data":"北大核心已录用（一作）、一区SCI在修（三作）、发明专利两项、软件著作权一项、项目测试内容已通过国家CNAS认证。"}]}]},{"ID":"20220803202631-7zjcu1s","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803202631-7zjcu1s","updated":"20220803202642"},"Children":[{"Type":"NodeText","Data":"职务"}]},{"ID":"20220803202642-20pdkho","Type":"NodeBlockquote","Properties":{"id":"20220803202642-20pdkho","updated":"20220831132307"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220803202643-fnuytqg","Type":"NodeParagraph","Properties":{"id":"20220803202643-fnuytqg","updated":"20220831132307"},"Children":[{"Type":"NodeText","Data":"算法设计与软件开发"}]}]},{"ID":"20220831124436-cqcv8q7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831124436-cqcv8q7","updated":"20220831124440"},"Children":[{"Type":"NodeText","Data":"技能"}]},{"ID":"20220831124441-3y08pwf","Type":"NodeBlockquote","Properties":{"id":"20220831124441-3y08pwf","updated":"20220831124700"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831124442-enmv45b","Type":"NodeParagraph","Properties":{"id":"20220831124442-enmv45b","updated":"20220831124700"},"Children":[{"Type":"NodeText","Data":"熟悉Java语言，了解多线程，具备较好的面向对象编程思想，熟悉Python语言，了解Pytorch深度学习框架；\n熟悉SpringBoot，了解MyBatis等常用框架；\n熟悉MySQL，了解Redis缓存中间件；\n熟悉IDEA、Git、Maven、Postman等开发及测试工具；\n熟悉Linux操作系统的基本命令，结合Kubernetes+Docker部署过边缘计算开发平台。"}]}]},{"ID":"20220807153206-t7xekhj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220807153206-t7xekhj","updated":"20250708214632"},"Children":[{"Type":"NodeText","Data":"成果"}]},{"ID":"20220814101722-orrqs44","Type":"NodeBlockquote","Properties":{"id":"20220814101722-orrqs44","updated":"20250708214632"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220814101807-e1gst8p","Type":"NodeParagraph","Properties":{"id":"20220814101807-e1gst8p","updated":"20250708214632"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"论文："},{"Type":"NodeText","Data":"\nChangqing Xia, Tianhao Xia, Renjun Wang et al. \"Quantification-Based Scheduling for Heterogeneous\nPlatform in Industrial Internet,\" in IEEE Internet of Things Journal, vol. 12, no. 7, pp. 9332-9347, 1 April1,\n2025. （JCR Q1）；\nChangqing Xia, Yuqi Liu, Tianhao Xia, et al. \"Control–Communication–Computing Co-Design in Cyber–\nPhysical Production System,\" in IEEE Internet of Things Journal, vol. 10, no. 6, pp. 5194-5204, 15 March15,\n2023.（JCR Q1）；\nTianhao Xia, Changqing Xia, Hao Pan, et al. \"Computational power resource measurement method based\non reinforcement learning\". Journal of Yanshan University, 2023,47(03):246-254.（北大核心）；\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"发明专利："},{"Type":"NodeText","Data":"\n《一种面向平台的高效信息物理生产系统》CN114690719B；\n《一种基于深度强化学习的算力资源度量方法》CN115168027B；\n《基于网算容器的信息物理生成系统及其管理方法》CN116795545B；\n《面向信息物理生产系统的确定性网算容器设计与实现方法》CN116795546B；\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"软件著作权："},{"Type":"NodeText","Data":"\n《算力资源度量系统软件 V1.0》2022R11S1125871"}]},{"ID":"20220814101807-tztw4ff","Type":"NodeParagraph","Properties":{"id":"20220814101807-tztw4ff","updated":"20250708214623"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"个人荣誉："},{"Type":"NodeBr","Data":"br"},{"Type":"NodeText","Data":" CET-6"}]},{"ID":"20220814101807-okuocqh","Type":"NodeParagraph","Properties":{"id":"20220814101807-okuocqh","updated":"20221118102519"},"Children":[{"Type":"NodeText","Data":"江苏省计算机二级"}]},{"ID":"20220901113905-5fvu95w","Type":"NodeParagraph","Properties":{"id":"20220901113905-5fvu95w","updated":"20221107095016"},"Children":[{"Type":"NodeText","Data":"研究生二等奖学金"}]},{"ID":"20221118102426-mhff3wn","Type":"NodeParagraph","Properties":{"id":"20221118102426-mhff3wn","updated":"20221118102433"},"Children":[{"Type":"NodeText","Data":"沈阳化工大学优秀研究生"}]},{"ID":"20220814101807-3mlffe8","Type":"NodeParagraph","Properties":{"id":"20220814101807-3mlffe8","updated":"20220814101924"},"Children":[{"Type":"NodeText","Data":"中国科学院沈阳自动化研究所联合培养优秀研究生"}]},{"ID":"20220814101807-ejk99r4","Type":"NodeParagraph","Properties":{"id":"20220814101807-ejk99r4","updated":"20220831124713"},"Children":[{"Type":"NodeText","Data":"第四届中国虚拟现实大赛全国一等奖"}]},{"ID":"20220831124024-lccled4","Type":"NodeParagraph","Properties":{"id":"20220831124024-lccled4","updated":"20220903091712"},"Children":[{"Type":"NodeText","Data":"2022年“移动云杯”算力网络应用创新大赛赛区二等奖"}]},{"ID":"20250708214546-9klp49l","Type":"NodeParagraph","Properties":{"id":"20250708214546-9klp49l","updated":"20250708214600"},"Children":[{"Type":"NodeText","Data":"2023年“移动云杯”算力网络应用创新大赛赛区三等奖"}]}]},{"ID":"20220819115144-irc6yri","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220819115144-irc6yri","updated":"20220819115147"},"Children":[{"Type":"NodeText","Data":"自我评价"}]},{"ID":"20220819115148-xkierva","Type":"NodeBlockquote","Properties":{"id":"20220819115148-xkierva","updated":"20220903092808"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220819115152-h811q83","Type":"NodeParagraph","Properties":{"id":"20220819115152-h811q83","updated":"20220903092808"},"Children":[{"Type":"NodeText","Data":"研究生期间的项目经历让我拥有了完备的专业技能、较强的自主学习能力、部门协调能力以及主导工作能力。"}]},{"ID":"20220901111852-ia6ab07","Type":"NodeParagraph","Properties":{"id":"20220901111852-ia6ab07","updated":"20220901112236"},"Children":[{"Type":"NodeText","Data":"（1）学习能力强，成绩排名系前30%；"}]},{"ID":"20220901111937-z2zm77l","Type":"NodeParagraph","Properties":{"id":"20220901111937-z2zm77l","updated":"20220901112235"},"Children":[{"Type":"NodeText","Data":"（2）组织协调能力强，担任器乐社社长，负责组织过多次校园晚会，并取得一致好评；"}]},{"ID":"20220901112026-2dszpne","Type":"NodeParagraph","Properties":{"id":"20220901112026-2dszpne","updated":"20220901112334"},"Children":[{"Type":"NodeText","Data":"（3）沟通能力强，在社团内负责教授社员器乐，并且社员数量达60人之多。"}]}]},{"ID":"20220819134454-xb57ti6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220819134454-xb57ti6","updated":"20220831123756"},"Children":[{"Type":"NodeText","Data":"社团活动"}]},{"ID":"20220831123758-49favof","Type":"NodeBlockquote","Properties":{"id":"20220831123758-49favof","updated":"20220903092801"},"Children":[{"ID":"20220831123759-ol1l4v7","Type":"NodeParagraph","Properties":{"id":"20220831123759-ol1l4v7","updated":"20220903092801"},"Children":[{"Type":"NodeText","Data":"社团经历：2018年-2019年，担任校器乐社社长职务，负责校内大型演出晚会活动的整体统筹工作，负责统筹设计、创意安排、节目编排、后勤保障的全流程事项统筹，活动满意度达96%。"}]},{"Type":"NodeBlockquoteMarker","Data":"\u003e"}]},{"ID":"20220819134455-w695nuj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220819134455-w695nuj","updated":"20220819134459"},"Children":[{"Type":"NodeText","Data":"紧急联系"}]},{"ID":"20220819134511-xnwmg4s","Type":"NodeBlockquote","Properties":{"id":"20220819134511-xnwmg4s","updated":"20220819134527"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220819134512-mv2c6ri","Type":"NodeParagraph","Properties":{"id":"20220819134512-mv2c6ri","updated":"20220819134527"},"Children":[{"Type":"NodeText","Data":"王准 18236367197"}]}]},{"ID":"20220819134459-of9iirg","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220819134459-of9iirg","updated":"20220831130805"},"Children":[{"Type":"NodeText","Data":"成果细节"}]},{"ID":"20220831130431-dtj1r22","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220831130431-dtj1r22","updated":"20220831130432"},"Children":[{"Type":"NodeText","Data":"《一种面向平台的高效信息物理生产系统》"}]},{"ID":"20220831130448-p2dh5kk","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220831130448-p2dh5kk","updated":"20220831130456"},"Children":[{"Type":"NodeText","Data":"专利号"}]},{"ID":"20220831130510-5kz4myh","Type":"NodeBlockquote","Properties":{"id":"20220831130510-5kz4myh","updated":"20220831130525"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831130511-88qrz8o","Type":"NodeParagraph","Properties":{"id":"20220831130511-88qrz8o","updated":"20220831130525"},"Children":[{"Type":"NodeText","Data":"202111569657.6"}]}]},{"ID":"20220831130428-d63lcgu","Type":"NodeBlockquote","Properties":{"id":"20220831130428-d63lcgu","updated":"20220831130441"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831130429-mrqmpf2","Type":"NodeParagraph","Properties":{"id":"20220831130429-mrqmpf2","updated":"20220831130441"},"Children":[{"Type":"NodeText","Data":"本发明涉及信息物理生产系统技术，具体说是一种面向平台的高效信息物理生产系统，包括基于中间件的平台层，PoComp组件。平台层用于获取生产信息，实现组件之间执行任务的连通性问题，分析计算调度表、资源需求以及适配参数，将得到的数据与指令通过API发送给PoComp组件；PoComp组件用于执行从平台层接收到的指令与配置参数，进行资源调节，解决设备执行时间差异性问题，实现生产过程所需操作；本发明最大化保证了各任务的时间约束，实现了紧密编排下的组件高效率调度、高可靠迁移等工业生产新需求。"}]}]},{"ID":"20220819134506-jmna435","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220819134506-jmna435","updated":"20220831130605"},"Children":[{"Type":"NodeText","Data":"《一种基于深度强化学习的算力资源度量方法》"}]},{"ID":"20220831130607-w7lllrl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220831130607-w7lllrl","updated":"20220831130609"},"Children":[{"Type":"NodeText","Data":"专利号"}]},{"ID":"20220831130610-ma2091h","Type":"NodeBlockquote","Properties":{"id":"20220831130610-ma2091h","updated":"20220831130700"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831130611-5tfnqhm","Type":"NodeParagraph","Properties":{"id":"20220831130611-5tfnqhm","updated":"20220831130700"},"Children":[{"Type":"NodeText","Data":"202210677394.9"}]}]},{"ID":"20220831130619-q8mqfkl","Type":"NodeBlockquote","Properties":{"id":"20220831130619-q8mqfkl","updated":"20220831130622"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831130621-16xrrl8","Type":"NodeParagraph","Properties":{"id":"20220831130621-16xrrl8","updated":"20220831130622"},"Children":[{"Type":"NodeText","Data":"本发明涉及一种基于深度强化学习的算力资源度量方法，包括以下步骤：步骤S1：对任务集中所有待量化计算任务进行建模分析，分别定义状态、动作、奖励值；步骤S2：根据深度强化学习算法构建算力量化模型框架，并针对量化要求对模型优化目标进行细化；步骤S3：通过调整超参数对模型进行优化，得到迭代完成的训练模型；步骤S4：将待量化任务数据输入训练好的模型得到计算任务的算力度量结果。本发明能够通过细粒度分析任务模型，量化任务资源需求量，有效预测任务执行时间，实现了对异构任务的算力资源度量，为未来工业互联网下网络-计算-控制一体化提供算力量化基础。"}]}]},{"ID":"20220831130801-8rot586","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220831130801-8rot586","updated":"20220831130831"},"Children":[{"Type":"NodeText","Data":"《基于强化学习的算力资源度量方法》"}]},{"ID":"20220831130835-zg8hozf","Type":"NodeBlockquote","Properties":{"id":"20220831130835-zg8hozf","updated":"20220831130843"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831130837-fz1ofnd","Type":"NodeParagraph","Properties":{"id":"20220831130837-fz1ofnd","updated":"20220831130843"},"Children":[{"Type":"NodeText","Data":"工业边缘计算中，节点具有分布零散、异构以及算力受限的特点，为保障算力供给通常采用任务与平台紧耦合的模式，然而该模式易使生产系统刚性化，资源复用效率低，冗余资源成本高昂。针对这一问题本文提出了多维度任务分析与强化学习相结合的算力度量方法，首先对工业场景中计算任务的时、空复杂度，计算类型等特征进行细粒度分析，通过构建任务模型与计算模型分析各计算任务特征与资源需求比例之间的关系；随后，基于上述分析构建马尔科夫决策过程并把状态、动作、奖励建立为三元组，将奖励值定义为对任务执行时间的预测优化问题；最后，设计基于深度Q网络(DQN, Deep Q Network)的计算任务算力度量方法，对不同形式的计算任务进行算力需求量化，并通过与设备实际算力消耗进行分析对比，验证所提方法可有效降低不必要的资源损耗。实验结果显示，所提出的模型和方法在预测结果误差率上相较于Q-Learning等算法提升了约12.12%、10.44%、15.42%，并且对任务的资源需求量化成功率可达99.37%，可有效实现边缘侧的算力度量。"}]}]},{"ID":"20221103183509-kpkqpvj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221103183509-kpkqpvj","updated":"20221103183514"},"Children":[{"Type":"NodeText","Data":"毕业论文题目"}]},{"ID":"20221103183516-9w419ay","Type":"NodeBlockquote","Properties":{"id":"20221103183516-9w419ay","updated":"20221103183517"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221103183516-2g80rgg","Type":"NodeParagraph","Properties":{"id":"20221103183516-2g80rgg","updated":"20221103183517"},"Children":[{"Type":"NodeText","Data":"《面向工业边缘计算场景的资源量化关键技术研究》"}]}]},{"ID":"20220831130844-2kx28qp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831130844-2kx28qp","updated":"20220831160205"},"Children":[{"Type":"NodeText","Data":"遇到的问题"}]},{"ID":"20220831160207-66be1ac","Type":"NodeBlockquote","Properties":{"id":"20220831160207-66be1ac","updated":"20220831160247"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831160208-fxf59gv","Type":"NodeParagraph","Properties":{"id":"20220831160208-fxf59gv","updated":"20220831160247"},"Children":[{"Type":"NodeText","Data":"问题：在进行工业互联网边缘计算关键技术项目时，碰到在基于KubeEdge搭建的平台上部署docker项目时出现主节点的任务总是调度到错误的边缘节点，导致真正执行任务的边缘节点一直无法正常启动容器，然而被错误分配的节点其实并没有该容器，所以导致主节点任务始终处于ContainerCreating状态。\n解决方法：首先想到的是yaml文件中的节点名称是否错误，发现确实有问题，改正后重启无果，于是想通过删除运行的pod并重新deployment，但发现delete后pod又自动重启了，说明并没有删除干净，网上搜索过后发现是需要删除命名空间，遂先查看deployment过的pod的命名空间，再查看该命名空间中的pod名字，最后删除depeloyment过的error pod。\n结果：重新部署后任务成功调度"}]}]},{"ID":"20220831161021-jelh2gj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831161021-jelh2gj","updated":"20220831161024"},"Children":[{"Type":"NodeText","Data":"职业规划"}]},{"ID":"20220831161025-gc8kgh8","Type":"NodeBlockquote","Properties":{"id":"20220831161025-gc8kgh8","updated":"20221019162106"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831161026-utcaf21","Type":"NodeParagraph","Properties":{"id":"20220831161026-utcaf21","updated":"20221019162106"},"Children":[{"Type":"NodeText","Data":"前两年内先熟悉工作内容并让自己融入到社会这个新场所\n后三年进一步提升自己技术水平，慢慢沉淀自己，不骄不躁，并尽最大可能把自己分内的工作做到最好。兼顾家庭和事业，照顾好家庭，"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"做好孩子的教育工作"},{"Type":"NodeText","Data":"。在工作中能逐渐展现出魄力，能在自己的岗位上得心应手，并帮助新员工适应环境，要有前辈的榜样，注意自己平时的衣着言行举止。"}]}]},{"ID":"20220831173559-p0vb44i","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831173559-p0vb44i","updated":"20220831173603"},"Children":[{"Type":"NodeText","Data":"六级颁发机构"}]},{"ID":"20220831173605-t7ujnuj","Type":"NodeBlockquote","Properties":{"id":"20220831173605-t7ujnuj","updated":"20220831173623"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831173606-codozeb","Type":"NodeParagraph","Properties":{"id":"20220831173606-codozeb","updated":"20220831173623"},"Children":[{"Type":"NodeText","Data":"教育部高等教育司"}]}]},{"ID":"20220831173607-boxqu5w","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831173607-boxqu5w","updated":"20220831173612"},"Children":[{"Type":"NodeText","Data":"计算机二级颁发机构"}]},{"ID":"20220831173613-egdifei","Type":"NodeBlockquote","Properties":{"id":"20220831173613-egdifei","updated":"20220831173615"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831173614-wofsrob","Type":"NodeParagraph","Properties":{"id":"20220831173614-wofsrob","updated":"20220831173615"},"Children":[{"Type":"NodeText","Data":"教育部考试中心"}]}]},{"ID":"20220831201059-2cwgff1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831201059-2cwgff1","updated":"20220831201101"},"Children":[{"Type":"NodeText","Data":"职务"}]},{"ID":"20220831201103-kqt2fuh","Type":"NodeBlockquote","Properties":{"id":"20220831201103-kqt2fuh","updated":"20220831201125"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831201104-3tfx863","Type":"NodeParagraph","Properties":{"id":"20220831201104-3tfx863","updated":"20220831201105"},"Children":[{"Type":"NodeText","Data":"苏州工业园区恒化经贸有限公司"}]},{"ID":"20220831201105-x07aj4y","Type":"NodeParagraph","Properties":{"id":"20220831201105-x07aj4y","updated":"20220831201125"},"Children":[{"Type":"NodeText","Data":"经理"}]}]},{"ID":"20220831203416-uimn7j7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220831203416-uimn7j7","updated":"20220831203418"},"Children":[{"Type":"NodeText","Data":"居住地"}]},{"ID":"20220831203420-6qbbo04","Type":"NodeBlockquote","Properties":{"id":"20220831203420-6qbbo04","updated":"20221011201409"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220831203421-wsb0r0x","Type":"NodeParagraph","Properties":{"id":"20220831203421-wsb0r0x","updated":"20220831203421"},"Children":[{"Type":"NodeText","Data":"江苏省苏州市吴中区邵昂路吴中大道南越湖家天下"}]},{"ID":"20221011201352-p1mavfv","Type":"NodeParagraph","Properties":{"id":"20221011201352-p1mavfv","updated":"20221011201354"},"Children":[{"Type":"NodeText","Data":"邮编："}]},{"ID":"20221011201406-v93sail","Type":"NodeParagraph","Properties":{"id":"20221011201406-v93sail","updated":"20221011201409"},"Children":[{"Type":"NodeText","Data":"215168"}]}]},{"ID":"20220901114043-r7ucxcr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220901114043-r7ucxcr","updated":"20220901114045"},"Children":[{"Type":"NodeText","Data":"爱好"}]},{"ID":"20220901114047-j4huas3","Type":"NodeBlockquote","Properties":{"id":"20220901114047-j4huas3","updated":"20221118131913"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220901114048-ncmw0tx","Type":"NodeParagraph","Properties":{"id":"20220901114048-ncmw0tx","updated":"20221014202137"},"Children":[{"Type":"NodeText","Data":"设计小程序、半音阶口琴、健身、看电影、看推理小说"}]},{"ID":"20221118131911-z28h169","Type":"NodeParagraph","Properties":{"id":"20221118131911-z28h169","updated":"20221118131911"}},{"ID":"20221118131911-mpxb45n","Type":"NodeParagraph","Properties":{"id":"20221118131911-mpxb45n","updated":"20221118131913"},"Children":[{"Type":"NodeText","Data":"擅长计算机编程、后端开发；擅长半音阶口琴，多次参与文娱节目。"}]}]},{"ID":"20220908113756-je4s2jp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220908113756-je4s2jp","updated":"20220908121955"},"Children":[{"Type":"NodeText","Data":"硕士课程"}]},{"ID":"20220908114445-g2k6avi","Type":"NodeBlockquote","Properties":{"id":"20220908114445-g2k6avi","updated":"20220908114448"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220908114447-l1ru5af","Type":"NodeParagraph","Properties":{"id":"20220908114447-l1ru5af","updated":"20220908114448"},"Children":[{"Type":"NodeText","Data":"人工智能、机器学习、高级程序设计、矩阵理论、数理统计"}]}]},{"ID":"20220908121951-wvj7kbk","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220908121951-wvj7kbk","updated":"20220908121958"},"Children":[{"Type":"NodeText","Data":"本科课程"}]},{"ID":"20220908122001-l3zuuda","Type":"NodeBlockquote","Properties":{"id":"20220908122001-l3zuuda","updated":"20220908122042"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220908122003-gm7rlx8","Type":"NodeParagraph","Properties":{"id":"20220908122003-gm7rlx8","updated":"20220908122042"},"Children":[{"Type":"NodeText","Data":"自动控制原理、电路、过程控制、线性代数、matlab、c语言程序设计"}]}]},{"ID":"20220921125015-8y23dyp","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220921125015-8y23dyp","updated":"20220924100634"},"Children":[{"Type":"NodeText","Data":"绩点"}]},{"ID":"20220924100635-sh1xnap","Type":"NodeBlockquote","Properties":{"id":"20220924100635-sh1xnap","updated":"20220924105552"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220924100639-nyhgn05","Type":"NodeParagraph","Properties":{"id":"20220924100639-nyhgn05","updated":"20220924105552"},"Children":[{"Type":"NodeText","Data":"3.41"}]}]},{"ID":"20221014211006-rnzbsf0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221014211006-rnzbsf0","updated":"20221014211020"},"Children":[{"Type":"NodeText","Data":"应聘岗位的优势（含求职动机、竞争优势、职业规划）"}]},{"ID":"20221014211006-ak03fdo","Type":"NodeBlockquote","Properties":{"id":"20221014211006-ak03fdo","updated":"20221107130238"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221014211008-1mwlvu0","Type":"NodeParagraph","Properties":{"id":"20221014211008-1mwlvu0","updated":"20221014211008"},"Children":[{"Type":"NodeText","Data":"求职动机：自己是苏州本地人更倾向于回到苏州发展，也想用这些年所学的知识为自己的家乡添砖加瓦。"}]},{"ID":"20221014211008-0cmkls6","Type":"NodeParagraph","Properties":{"id":"20221014211008-0cmkls6","updated":"20221014211008"},"Children":[{"Type":"NodeText","Data":"竞争优势：（1）学习能力强，成绩排名系前30%；\n（2）组织协调能力强，担任器乐社社长，负责组织过多次校园晚会，并取得一致好评；\n（3）沟通能力强，在社团内负责教授社员器乐，并且社员数量达60人之多。"}]},{"ID":"20221014211008-0yfnic2","Type":"NodeParagraph","Properties":{"id":"20221014211008-0yfnic2","updated":"20221107130238"},"Children":[{"Type":"NodeText","Data":"职业规划：前两年内先熟悉工作内容并让自己融入到社会这个新场所后三年进一步提升自己技术水平，慢慢沉淀自己，不骄不躁，并尽最大可能把自己分内的工作做到最好。兼顾家庭和事业，照顾好家庭。在工作中能逐渐展现出魄力，能在自己的岗位上得心应手，并帮助新员工适应环境，要有前辈的榜样，锻炼自己成为一个具有一定项目统筹能力、可以协同大型项目的职场人士。"}]}]},{"ID":"20221014211100-5w0i1s9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221014211100-5w0i1s9","updated":"20221014211102"},"Children":[{"Type":"NodeText","Data":"成果"}]},{"ID":"20221014211103-xw6s5l6","Type":"NodeBlockquote","Properties":{"id":"20221014211103-xw6s5l6","updated":"20221114212518"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221014211105-l0x1vsz","Type":"NodeParagraph","Properties":{"id":"20221014211105-l0x1vsz","updated":"20221114212518"},"Children":[{"Type":"NodeText","Data":"论文：《基于强化学习的算力资源度量方法》（北大核心，一作）\n《Control-Communication-Computing Co-design in Cyber-physical Production System》（一区SCI    IEEE Internet of Things Journal，已录用）\n发明专利：《一种面向平台的高效信息物理生产系统》202111569657.6\n《一种基于深度强化学习的算力资源度量方法》202210677394.9\n软件著作：《算力资源度量系统软件V1.0》2022R11S1125871"}]}]},{"ID":"20221025173801-macwrek","Type":"NodeParagraph","Properties":{"id":"20221025173801-macwrek"}}]}