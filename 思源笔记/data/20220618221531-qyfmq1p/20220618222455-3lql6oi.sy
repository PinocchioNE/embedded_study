tMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"np.float"},{"Type":"NodeText","Data":" 类型。因此，在传入 ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"torchvision.transforms"},{"Type":"NodeText","Data":" 中的图片时，不能提前做这一步。如果不除以 255，图片数据就没办法转变到 [0,1] 之间，就无法进行归一化，所以使用","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"totensor"},{"Type":"NodeText","Data":",\u003cstrong style=\"color:red;\"\u003e将int转化为float格式\u003c/strong\u003e","Properties":{"id":""}}]}]},{"ID":"20220618222511-u1byu51","Type":"NodeParagraph","Properties":{"id":"20220618222511-u1byu51","updated":"20220618222511"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/为什么-20220618222918-2x3f095.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222512-rj5jxj3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222512-rj5jxj3","updated":"20220618222512"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"常用的Transforms","Properties":{"id":""}}]},{"ID":"20220618222513-n1epcl0","Type":"NodeParagraph","Properties":{"id":"20220618222513-n1epcl0","updated":"20220618222513"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/常见-20220618222918-fjp3vow.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222514-myhn1ts","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222514-myhn1ts","updated":"20220618222514"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ToTensor函数","Properties":{"id":""}}]},{"ID":"20220618222515-dicwkpx","Type":"NodeParagraph","Properties":{"id":"20220618222515-dicwkpx","updated":"20220618222515"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/totensor解释-20220618222918-5b55210.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222516-yx5rbph","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618222516-yx5rbph","updated":"20220618222516"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"归一化Normalize","Properties":{"id":""}}]},{"ID":"20220618222517-pryseq0","Type":"NodeBlockquote","Properties":{"id":"20220618222517-pryseq0","updated":"20220618222517"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222518-oamp7st","Type":"NodeParagraph","Properties":{"id":"20220618222518-oamp7st","updated":"20220618222518"},"Children":[{"Type":"NodeText","Data":"transforms.Normalize(a,b)   两个参数（均值，归一化）","Properties":{"id":""}}]}]},{"ID":"20220618222519-smhl468","Type":"NodeParagraph","Properties":{"id":"20220618222519-smhl468","updated":"20220618222519"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/归一化-20220618222918-9yq3a0h.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222520-0r5qmtx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618222520-0r5qmtx","updated":"20220618222520"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"归一化的计算方式","Properties":{"id":""}}]},{"ID":"20220618222521-x6wnchi","Type":"NodeParagraph","Properties":{"id":"20220618222521-x6wnchi","updated":"20220618222521"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/归一化2-20220618222918-ch87ajk.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222522-r4trkma","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222522-r4trkma","updated":"20220618222522"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"from PIL import Image\nfrom torchvision import transforms\nfrom torch.utils.tensorboard import SummaryWriter\n\nwriter = SummaryWriter(\"logs\")\nimg = Image.open(\"data/train/ants_image/0013035.jpg\")\nprint(img)\n\n# ToTensor\ntrans_totensor = transforms.ToTensor()\nimg_tensor = trans_totensor(img)\nwriter.add_image(\"ToTenso\", img_tensor)\n\n# Normalize 归一化\nprint(img_tensor[0][0][0]) # 图片是3通道\ntrans_norm = transforms.Normalize([0.5,0.5,0.5],[0.5,0.5,0.5])\nimg_norm = trans_norm(img_tensor)\nprint(img_norm[0][0][0])\nwriter.add_image(\"Normalize\", img_norm)\n\nwriter.close()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222523-ds0wapq","Type":"NodeParagraph","Properties":{"id":"20220618222523-ds0wapq","updated":"20220618222523"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/归一化图片-20220618222918-aryvxgr.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222524-98h9j29","Type":"NodeParagraph","Properties":{"id":"20220618222524-98h9j29","updated":"20220618222524"},"Children":[{"Type":"NodeText","Data":"改一下通道的均值和方差和add_image的step数","Properties":{"id":""}}]},{"ID":"20220618222525-hlbpl3q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222525-hlbpl3q","updated":"20220618222525"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# Normalize\nprint(img_tensor[0][0][0])\ntrans_norm = transforms.Normalize([6,3,2],[9,3,5]) # 均值和方差更改\nimg_norm = trans_norm(img_tensor)\nprint(img_norm[0][0][0])\nwriter.add_image(\"Normalize\", img_norm,2) # step改成2 即要滑动滚动轴显示第二张图\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222526-u62xxuv","Type":"NodeParagraph","Properties":{"id":"20220618222526-u62xxuv","updated":"20220618222526"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/归一化1-20220618222918-fsio797.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222527-mn8mwed","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222527-mn8mwed","updated":"20220618222527"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Resize函数","Properties":{"id":""}}]},{"ID":"20220618222528-p60f358","Type":"NodeBlockquote","Properties":{"id":"20220618222528-p60f358","updated":"20220618222528"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222529-qakrxev","Type":"NodeParagraph","Properties":{"id":"20220618222529-qakrxev","updated":"20220618222529"},"Children":[{"Type":"NodeText","Data":"torchvision.transforms.Resize(size, interpolation=2)","Properties":{"id":""}}]},{"ID":"20220618222530-kv7lpus","Type":"NodeParagraph","Properties":{"id":"20220618222530-kv7lpus","updated":"20220618222530"},"Children":[{"Type":"NodeText","Data":"size : 获取输出图像的大小","Properties":{"id":""}}]},{"ID":"20220618222531-6ikv4r4","Type":"NodeParagraph","Properties":{"id":"20220618222531-6ikv4r4","updated":"20220618222531"},"Children":[{"Type":"NodeText","Data":"interpolation : 插值，默认的 PIL.Image.BILINEAR， 一共有4 种的插值方法","Properties":{"id":""}}]}]},{"ID":"20220618222532-7i3332v","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222532-7i3332v","updated":"20220618222532"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# Reszie  首先要对图像先进行大小的修改，但这是在PIL的基础下做的，做完之后要使用totensor改成张量的形式\nprint(img.size)\ntrans_resize = transforms.Resize((512,512))\n# PIL -\u003e PIL\nimg_resize = trans_resize(img)\n# PIL -\u003e tensor\nimg_resize = trans_totensor(img_resize)\nprint(img_resize)\nwriter.add_image(\"Resize\",img_resize,1)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222533-jk0q3yk","Type":"NodeParagraph","Properties":{"id":"20220618222533-jk0q3yk","updated":"20220618222533"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/resize-20220618222918-zprxb86.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222534-9gl2p1q","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222534-9gl2p1q","updated":"20220618222534"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"compose函数","Properties":{"id":""}}]},{"ID":"20220618222535-f5gdtm1","Type":"NodeBlockquote","Properties":{"id":"20220618222535-f5gdtm1","updated":"20220618222535"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222536-hhar4b2","Type":"NodeParagraph","Properties":{"id":"20220618222536-hhar4b2","updated":"20220618222536"},"Children":[{"Type":"NodeText","Data":"采用transforms.Compose()，将一系列的transforms有序组合，实现时按照这些方法依次对图像操作","Properties":{"id":""}}]}]},{"ID":"20220618222537-fl0p6u0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222537-fl0p6u0","updated":"20220618222537"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# Compose -resize -2 compose的作用就是把一系列的transforms的函数包组合起来用\ntrans_resize_2 = transforms.Resize(512)\n# 整体过程就是 PIL -\u003e PIL -\u003e tensor\ntrans_compose = transforms.Compose([trans_resize_2, trans_totensor])\nimg_resize_2 = trans_compose(img)\nwriter.add_image(\"Resize\",img_resize_2,2)\nwriter.close()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222538-mn0hkqt","Type":"NodeParagraph","Properties":{"id":"20220618222538-mn0hkqt","updated":"20220618222538"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/compose1-20220618222918-qfw1dta.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222539-pmmplva","Type":"NodeParagraph","Properties":{"id":"20220618222539-pmmplva","updated":"20220618222539"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/compose-20220618222918-88h8v4h.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222540-g7uenif","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222540-g7uenif","updated":"20220618222540"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"RandomCrop函数","Properties":{"id":""}}]},{"ID":"20220618222541-opoivis","Type":"NodeBlockquote","Properties":{"id":"20220618222541-opoivis","updated":"20220618222541"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222542-yfvulkn","Type":"NodeParagraph","Properties":{"id":"20220618222542-yfvulkn","updated":"20220618222542"},"Children":[{"Type":"NodeText","Data":"随机裁剪","Properties":{"id":""}}]}]},{"ID":"20220618222543-402lg8g","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222543-402lg8g","updated":"20220618222543"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# RandomCrop\ntrans_random = transforms.RandomCrop((512,512))\ntrans_compose_2 = transforms.Compose([trans_random, trans_totensor])\nfor i in range(10):\n    img_crop = trans_compose_2(img)\n    writer.add_image(\"RandomCrop\", img_crop, i)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222544-51y1ygq","Type":"NodeParagraph","Properties":{"id":"20220618222544-51y1ygq","updated":"20220618222544"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/随机裁剪-20220618222918-o6mkbj4.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222545-emy57dz","Type":"NodeParagraph","Properties":{"id":"20220618222545-emy57dz","updated":"20220618222938"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/随机裁剪2-20220618222918-kp4flze.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%;\"}"}]},{"ID":"20220618222546-qdtwgcz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222546-qdtwgcz","updated":"20220618222546"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"torchvision","Properties":{"id":""}}]},{"ID":"20220618222547-s3z1pio","Type":"NodeBlockquote","Properties":{"id":"20220618222547-s3z1pio","updated":"20220618222547"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222548-vly7w87","Type":"NodeParagraph","Properties":{"id":"20220618222548-vly7w87","updated":"20220618222548"},"Children":[{"Type":"NodeText","Data":"pytorch官网提供的数据集包","Properties":{"id":""}}]}]},{"ID":"20220618222549-l5za2o5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222549-l5za2o5","updated":"20220618222549"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torchvision\n\n# 下载数据集 CIFAR10代表下载的数据集类型 其中train=True就代表是训练集 train=False就代表是测试集  ./表示当前目录\ntrain_set = torchvision.datasets.CIFAR10(root=\"./dataset1\", train=True, download=True)\ntest_set = torchvision.datasets.CIFAR10(root=\"./dataset1\", train=False, download=True)\n\n# 打印测试集的第一张图片信息\nprint(test_set[0])\n# 打印测试集有哪些类\nprint(test_set.classes)\n\nimg, target = test_set[0]\nprint(img)\n# target就代表索引\nprint(target)\nprint(test_set.classes[target])\nimg.show()\n\n# 结果\nFiles already downloaded and verified\nFiles already downloaded and verified\n(\u003cPIL.Image.Image image mode=RGB size=32x32 at 0x144D521FB00\u003e, 3)\n['airplane', 'automobile', 'bird', 'cat', 'deer', 'dog', 'frog', 'horse', 'ship', 'truck']\n\u003cPIL.Image.Image image mode=RGB size=32x32 at 0x144D521F940\u003e\n3\ncat\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222550-yadwk9u","Type":"NodeParagraph","Properties":{"id":"20220618222550-yadwk9u","updated":"20220618222550"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/猫-20220618222918-dkmv4y3.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222551-dirj7e1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222551-dirj7e1","updated":"20220618222551"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"直接在测试集与训练集中将数据改变成张量","Properties":{"id":""}}]},{"ID":"20220618222552-p47j4dt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222552-p47j4dt","updated":"20220618222552"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torchvision\nfrom torch.utils.tensorboard import SummaryWriter\n\ndataset_transform = torchvision.transforms.Compose([torchvision.transforms.ToTensor()])\n\n# 注意括号中的transform\ntrain_set = torchvision.datasets.CIFAR10(root=\"./dataset1\", train=True,transform=dataset_transform,download=True)\ntest_set = torchvision.datasets.CIFAR10(root=\"./dataset1\", train=False, transform=dataset_transform,download=True)\n\n# 程序运行完后在Terminal输入 tensorboard --logdir=p10\nwriter = SummaryWriter(\"p10\")\nfor i in range(10):\n    img, target = test_set[i]\n    writer.add_image(\"test_set\",img, i)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222553-nlxdbf2","Type":"NodeParagraph","Properties":{"id":"20220618222553-nlxdbf2","updated":"20220618222553"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/torch-20220618222918-ibwpzgv.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222554-0sjmryb","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222554-0sjmryb","updated":"20220618222554"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"DataLoader","Properties":{"id":""}}]},{"ID":"20220618222555-sm7ksvs","Type":"NodeBlockquote","Properties":{"id":"20220618222555-sm7ksvs","updated":"20220618222555"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222556-aoxdoo0","Type":"NodeParagraph","Properties":{"id":"20220618222556-aoxdoo0","updated":"20220618222556"},"Children":[{"Type":"NodeText","Data":"数据加载  \u003cstrong style=\"color:red;\"\u003e注意L要大写\u003c/strong\u003e","Properties":{"id":""}}]}]},{"ID":"20220618222557-83yqauf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222557-83yqauf","updated":"20220618222557"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"DataLoader(dataset, batch_size=1, shuffle=False, sampler=None,\n           batch_sampler=None, num_workers=0, collate_fn=None,\n           pin_memory=False, drop_last=False, timeout=0,\n           worker_init_fn=None, *, prefetch_factor=2,\n           persistent_workers=False)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222558-ph6tp3k","Type":"NodeParagraph","Properties":{"id":"20220618222558-ph6tp3k","updated":"20220618222558"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/dataloader-20220618222918-8bgbrfw.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222559-vt4ow46","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222559-vt4ow46","updated":"20220618222559"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torchvision\nfrom torch.utils.data import DataLoader\nfrom torch.utils.tensorboard import SummaryWriter\n\n# 准备的测试集\ntest_data = torchvision.datasets.CIFAR10(\"./dataset1\",train=False, transform=torchvision.transforms.ToTensor())\n# 加载数据集，大小为4张图片一组，shuffler=true代表每次都打乱， num_workers=0代表主进程加载, drop_last=false代表余数的数据集舍弃\ntest_loader = DataLoader(dataset=test_data, batch_size=4, shuffle=True, num_workers=0, drop_last=False)\n\nstep = 0\nwriter = SummaryWriter(\"dataloader\")\nfor data in test_loader:\n    imgs, targets = data\n    # 因为是多张图片，所以是add_images\n    writer.add_images(\"test_data\", imgs, step) # 步进随循环次数增加\n    step += 1\n\nwriter.close()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222560-buy9ltl","Type":"NodeParagraph","Properties":{"id":"20220618222560-buy9ltl","updated":"20220618222560"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/dataloader1-20220618222918-xuvijiy.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222561-mbs04nk","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222561-mbs04nk","updated":"20220618222561"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"当batch_size改为64后可以在tensorboard看到","Properties":{"id":""}}]},{"ID":"20220618222562-8lo5lrr","Type":"NodeParagraph","Properties":{"id":"20220618222562-8lo5lrr","updated":"20220618222562"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/64-20220618222918-cgl5mue.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222563-z8wwkg9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222563-z8wwkg9","updated":"20220618222563"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"神经网络基本骨架","Properties":{"id":""}}]},{"ID":"20220618222564-dzbeqyh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222564-dzbeqyh","updated":"20220618222564"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch import nn\n\n\nclass xth(nn.Module):\n    def __init__(self):\n        super().__init__()\n\n    def forward(self, input):\n        output = input + 1\n        return output\n\nXTH = xth()\nx = torch.tensor(1.0)\noutput = XTH(x)\nprint(output)\n\n# 结果\ntensor(2.)\n\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222565-snnq1t8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222565-snnq1t8","updated":"20220618222565"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"卷积神经网络","Properties":{"id":""}}]},{"ID":"20220618222566-ydiodpn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222566-ydiodpn","updated":"20220618222566"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"torch.nn.Conv2d函数","Properties":{"id":""}}]},{"ID":"20220618222567-nic2fnt","Type":"NodeBlockquote","Properties":{"id":"20220618222567-nic2fnt","updated":"20220618222567"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222568-stgs5zq","Type":"NodeParagraph","Properties":{"id":"20220618222568-stgs5zq","updated":"20220618222568"},"Children":[{"Type":"NodeText","Data":"为什么不用conv1d或conv3d，因为大多数都是2维的","Properties":{"id":""}}]}]},{"ID":"20220618222569-1qfr0gx","Type":"NodeBlockquote","Properties":{"id":"20220618222569-1qfr0gx","updated":"20220618222569"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222570-pur141x","Type":"NodeParagraph","Properties":{"id":"20220618222570-pur141x","updated":"20220618222570"},"Children":[{"Type":"NodeText","Data":"torch.nn.Conv2d(","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"in_channels"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"out_channels"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"kernel_size"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"stride=1"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"padding=0"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"dilation=1"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"groups=1"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"bias=True"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"padding_mode='zeros'"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"device=None"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"dtype=None"},{"Type":"NodeText","Data":")","Properties":{"id":""}}]},{"ID":"20220618222571-61dfsbr","Type":"NodeParagraph","Properties":{"id":"20220618222571-61dfsbr","updated":"20220618222571"},"Children":[{"Type":"NodeText","Data":"(https://pytorch.org/docs/stable/_modules/torch/nn/modules/conv.html#Conv2d)","Properties":{"id":""}}]}]},{"ID":"20220618222572-0yju79h","Type":"NodeParagraph","Properties":{"id":"20220618222572-0yju79h","updated":"20220618222572"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/卷积-20220618222918-k1bh6w5.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222573-vd4xmog","Type":"NodeParagraph","Properties":{"id":"20220618222573-vd4xmog","updated":"20220618222573"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/卷积2-20220618222918-2g3h9dv.PNG","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222574-ujt5lm1","Type":"NodeParagraph","Properties":{"id":"20220618222574-ujt5lm1","updated":"20220618222574"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/卷积1-20220618222918-0bezgbs.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222575-i3cxm36","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222575-i3cxm36","updated":"20220618222575"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"padding填充效果","Properties":{"id":""}}]},{"ID":"20220618222576-juanhbm","Type":"NodeParagraph","Properties":{"id":"20220618222576-juanhbm","updated":"20220618222576"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/步长-20220618222918-xvpxujx.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222577-xyscis3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222577-xyscis3","updated":"20220618222577"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"变换stride和padding的效果","Properties":{"id":""}}]},{"ID":"20220618222578-8efnuin","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222578-8efnuin","updated":"20220618222578"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torch.nn.functional as F\n\n# 输入图片格式（形式上的图片格式）\ninput = torch.tensor([[1, 2, 0, 3, 1],\n                      [0, 1, 2, 3, 1],\n                      [1, 2, 1, 0, 0],\n                      [5, 2, 3, 1, 1],\n                      [2, 1, 0, 1, 1]])\n# 输入卷积核\nkernel = torch.tensor([[1, 2, 1],\n                       [0, 1, 0],\n                       [2, 1, 0]])\n\ninput = torch.reshape(input, (1, 1, 5, 5)) # 代表输入的图像格式 一个面 一个通道 5x5的维度 \nkernel = torch.reshape(kernel, (1, 1, 3, 3))# 代表卷积核格式 一个面 一个通道 3x3的维度 \n\nprint(input.s ize())\nprint(kernel.size())\n\noutput = F.conv2d(input, kernel, stride=1) # stride=1表示每次移一格\nprint(output)\n\noutpu2 = F.conv2d(input, kernel, stride=2)\nprint(output2)\n\noutput3 = F.conv2d(input, kernel, stride=1, padding=1) # 增加填充\nprint(output3)\n\n# 结果\ntorch.Size([1, 1, 5, 5])\ntorch.Size([1, 1, 3, 3])\n\ntensor([[[[10, 12, 12],\n          [18, 16, 16],\n          [13,  9,  3]]]])\n\ntensor([[[[10, 12],\n          [13,  3]]]])\n\ntensor([[[[ 1,  3,  4, 10,  8],\n          [ 5, 10, 12, 12,  6],\n          [ 7, 18, 16, 16,  8],\n          [11, 13,  9,  3,  4],\n          [14, 13,  9,  7,  4]]]])\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222579-imdmv3r","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222579-imdmv3r","updated":"20220618222579"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"卷积图片实战","Properties":{"id":""}}]},{"ID":"20220618222580-py5lk2y","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222580-py5lk2y","updated":"20220618222580"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torchvision\nfrom torch.nn import Conv2d\nfrom torch.utils.data import DataLoader\nfrom torch import nn\ntotensor = torchvision.transforms.ToTensor\ndataset = torchvision.datasets.CIFAR10(\"./dataset1\", train=False, transform=totensor())\n\ndataloader = DataLoader(dataset, batch_size = 64)\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.conv1 = Conv2d(in_channels=3, out_channels=6, kernel_size=3, stride=1, padding=0)\n\n    def forward(self, x):\n        x = self.conv1(x)\n        return x\n\nXTH = xth()\n\nfor data in dataloader:\n    imgs, targets = data\n    output = XTH(imgs)\n    print(imgs.shape)\n    print(output.shape)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222581-vdzjkzz","Type":"NodeParagraph","Properties":{"id":"20220618222581-vdzjkzz","updated":"20220618222581"},"Children":[{"Type":"NodeText","Data":"结果","Properties":{"id":""}}]},{"ID":"20220618222582-wh4tajv","Type":"NodeBlockquote","Properties":{"id":"20220618222582-wh4tajv","updated":"20220618222582"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222583-5puue0a","Type":"NodeParagraph","Properties":{"id":"20220618222583-5puue0a","updated":"20220618222583"},"Children":[{"Type":"NodeText","Data":"可以从结果看出图像的batchsize是我们设置的64，in_channel为3，32x32大小","Properties":{"id":""}}]},{"ID":"20220618222584-d16vl1p","Type":"NodeParagraph","Properties":{"id":"20220618222584-d16vl1p","updated":"20220618222584"},"Children":[{"Type":"NodeText","Data":"卷积过后out_channel是6，图像变成了30x30","Properties":{"id":""}}]}]},{"ID":"20220618222585-0mt13no","Type":"NodeParagraph","Properties":{"id":"20220618222585-0mt13no","updated":"20220618222585"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/结果-20220618222918-rc1ck9s.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222586-e56isr5","Type":"NodeParagraph","Properties":{"id":"20220618222586-e56isr5","updated":"20220618222586"},"Children":[{"Type":"NodeText","Data":"实际在tensorboard中显示图像","Properties":{"id":""}}]},{"ID":"20220618222587-0yi26zh","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222587-0yi26zh","updated":"20220618222587"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"writer = SummaryWriter(\"./logs\")\nstep = 0\n\nfor data in dataloader:\n    imgs, targets = data\n    output = XTH(imgs)\n    print(imgs.shape)\n    print(output.shape)\n    # torch.Size([64,3,32,32])\n    writer.add_images(\"input\", imgs, step)\n    # torch.Size([64,6,30,30]) -\u003e [xxx,3,30,30]\n    # 因为彩色图像3个channel才能显示，这里6个就要修改。这里就要重定义大小，当不知道设置多少batchszie合适时就写-1\n    output = torch.reshape(output, (-1, 3, 30, 30))\n    writer.add_images(\"output\", output, step)\n    step += 1\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222588-j0k9k0x","Type":"NodeParagraph","Properties":{"id":"20220618222588-j0k9k0x","updated":"20220618222588"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/实战1-20220618222918-iw262nq.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222589-z8rv7go","Type":"NodeParagraph","Properties":{"id":"20220618222589-z8rv7go","updated":"20220618222589"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/实战2-20220618222918-s5wvgso.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222590-2nalfyd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222590-2nalfyd","updated":"20220618222590"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"池化","Properties":{"id":""}}]},{"ID":"20220618222591-37e2qna","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222591-37e2qna","updated":"20220618222591"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"最大池化的目的","Properties":{"id":""}}]},{"ID":"20220618222592-659kq7k","Type":"NodeBlockquote","Properties":{"id":"20220618222592-659kq7k","updated":"20220618222592"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222593-qm5rdv2","Type":"NodeParagraph","Properties":{"id":"20220618222593-qm5rdv2","updated":"20220618222593"},"Children":[{"Type":"NodeText","Data":"保留输入的最大特征且保留事物数据，减小数据量加快训练速度","Properties":{"id":""}}]}]},{"ID":"20220618222594-n7xrlet","Type":"NodeBlockquote","Properties":{"id":"20220618222594-n7xrlet","updated":"20220618222594"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222595-wab8ywn","Type":"NodeParagraph","Properties":{"id":"20220618222595-wab8ywn","updated":"20220618222595"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"CLASS"},{"Type":"NodeText","Data":"   torch.nn.MaxPool2d(","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"kernel_size"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"stride=None"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"padding=0"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"dilation=1"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"return_indices=False"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"ceil_mode=False"},{"Type":"NodeText","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222596-4mv9n8m","Type":"NodeParagraph","Properties":{"id":"20220618222596-4mv9n8m","updated":"20220618222596"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/pool-20220618222918-br5zafy.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222597-x1oarob","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222597-x1oarob","updated":"20220618222597"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"最大池化操作","Properties":{"id":""}}]},{"ID":"20220618222598-cx50omf","Type":"NodeBlockquote","Properties":{"id":"20220618222598-cx50omf","updated":"20220618222598"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222599-73lye7t","Type":"NodeParagraph","Properties":{"id":"20220618222599-73lye7t","updated":"20220618222599"},"Children":[{"Type":"NodeText","Data":"池化操作就是取池化核中的最大值，如果ceil_mode为true就表示需要取最大的数，反之不用","Properties":{"id":""}}]}]},{"ID":"20220618222600-r7vcaz8","Type":"NodeParagraph","Properties":{"id":"20220618222600-r7vcaz8","updated":"20220618222600"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/池化-20220618222918-gan0id1.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222601-fev54az","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222601-fev54az","updated":"20220618222601"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch import nn\nfrom torch.nn import MaxPool2d\n\ninput = torch.tensor([[1, 2, 0, 3, 1],\n                      [0, 1, 2, 3, 1],\n                      [1, 2, 1, 0, 0],\n                      [5, 2, 3, 1, 1],\n                      [2, 1, 0, 1, 1]], dtype=torch.float32)\n\ninput = torch.reshape(input, (-1,1,5,5))\nprint(input.shape)\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.maxpool1 = MaxPool2d(kernel_size=3, ceil_mode=True) # 最大池化，ceilmode需要取最大\n\n    def forward(self,input):\n        output = self.maxpool1(input)\n        return output\n\nXTH = xth()\noutput = XTH(input)\nprint(output)\n\n# 结果\ntorch.Size([1, 1, 5, 5])\ntensor([[[[2., 3.],\n          [5., 1.]]]])\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222602-ha7r8kx","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222602-ha7r8kx","updated":"20220618222602"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"最大池化图片实战","Properties":{"id":""}}]},{"ID":"20220618222603-pgc9yuf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222603-pgc9yuf","updated":"20220618222603"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torchvision\nfrom torch import nn\nfrom torch.nn import MaxPool2d\nfrom torch.utils.data import DataLoader\nfrom torch.utils.tensorboard import SummaryWriter\n\ndataset = torchvision.datasets.CIFAR10(\"./dataset1\", train=False, download=True,\n                                       transform=torchvision.transforms.ToTensor())\n\ndataloader = DataLoader(dataset, batch_size=64)\n\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.maxpool1 = MaxPool2d(kernel_size=3, ceil_mode=True)\n\n    def forward(self, input):\n        output = self.maxpool1(input)\n        return output\n\nwriter = SummaryWriter(\"./logs_maxpool\")\nstep = 0\n\nXTH = xth()\nfor data in dataloader:\n    imgs, targets = data\n    writer.add_images(\"input\", imgs, step)\n    output = XTH(imgs)\n    writer.add_images(\"output\", output, step)\n    step += 1\n\nwriter.close()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222604-x6r677o","Type":"NodeParagraph","Properties":{"id":"20220618222604-x6r677o","updated":"20220618222604"},"Children":[{"Type":"NodeText","Data":"结果","Properties":{"id":""}}]},{"ID":"20220618222605-qtv7xog","Type":"NodeBlockquote","Properties":{"id":"20220618222605-qtv7xog","updated":"20220618222605"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222606-vunfdtb","Type":"NodeParagraph","Properties":{"id":"20220618222606-vunfdtb","updated":"20220618222606"},"Children":[{"Type":"NodeText","Data":"可以看到图片有点马赛克了，但是都保留了主要特征","Properties":{"id":""}}]}]},{"ID":"20220618222607-4q9st3n","Type":"NodeParagraph","Properties":{"id":"20220618222607-4q9st3n","updated":"20220618222607"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/池化1-20220618222918-d1lb0f0.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222608-44hyodr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222608-44hyodr","updated":"20220618222608"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"ReLU函数","Properties":{"id":""}}]},{"ID":"20220618222609-9biul5w","Type":"NodeParagraph","Properties":{"id":"20220618222609-9biul5w","updated":"20220618222609"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/relu-20220618222918-x4q4pr2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222610-x4dv8a6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222610-x4dv8a6","updated":"20220618222610"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ReLU中inplace的含义","Properties":{"id":""}}]},{"ID":"20220618222611-8ys37w9","Type":"NodeBlockquote","Properties":{"id":"20220618222611-8ys37w9","updated":"20220618222611"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222612-wsvq2od","Type":"NodeParagraph","Properties":{"id":"20220618222612-wsvq2od","updated":"20220618222612"},"Children":[{"Type":"NodeText","Data":"如果为True就代表不保留原数据","Properties":{"id":""}}]},{"ID":"20220618222613-37wq7ev","Type":"NodeParagraph","Properties":{"id":"20220618222613-37wq7ev","updated":"20220618222613"},"Children":[{"Type":"NodeText","Data":"False就代表保留原数据","Properties":{"id":""}}]},{"ID":"20220618222614-wfei5z3","Type":"NodeParagraph","Properties":{"id":"20220618222614-wfei5z3","updated":"20220618222614"},"Children":[{"Type":"NodeText","Data":"默认是False","Properties":{"id":""}}]},{"ID":"20220618222615-qf3jf72","Type":"NodeParagraph","Properties":{"id":"20220618222615-qf3jf72","updated":"20220618222615"},"Children":[{"Type":"NodeText","Data":"作用相当于是一个滤波器","Properties":{"id":""}}]}]},{"ID":"20220618222616-ngvh425","Type":"NodeParagraph","Properties":{"id":"20220618222616-ngvh425","updated":"20220618222616"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/relu1-20220618222918-rt7gnjj.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222617-56v8tvw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222617-56v8tvw","updated":"20220618222617"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"ReLU效果","Properties":{"id":""}}]},{"ID":"20220618222618-to8jqhf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222618-to8jqhf","updated":"20220618222618"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch import nn\nfrom torch.nn import ReLU\n\ninput = torch.tensor([[1, -0.5],\n                      [-1,3]])\n\n# batchsize电脑算，一维的，2x2的大小\ninput = torch.reshape(input,(-1,1,2,2))\nprint(input.shape)\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.relu1 = ReLU()\n\n    def forward(self, input):\n        output = self.relu1(input)\n        return output\n\nXTH = xth()\noutput = XTH(input)\nprint(output)\n\n# 结果 可以看到-0.5和-1被截断了都表示为0了\ntorch.Size([1, 1, 2, 2])\ntensor([[[[1., 0.],\n          [0., 3.]]]])\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222619-jsfelb9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222619-jsfelb9","updated":"20220618222619"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Sigmod函数图片实战","Properties":{"id":""}}]},{"ID":"20220618222620-lasnuy5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222620-lasnuy5","updated":"20220618222620"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torchvision\nfrom torch import nn\nfrom torch.nn import ReLU, Sigmoid\nfrom torch.utils.data import DataLoader\nfrom torch.utils.tensorboard import SummaryWriter\n\ndataset = torchvision.datasets.CIFAR10(\"./dataset2\",train=False,download=True,\n                                       transform=torchvision.transforms.ToTensor())\ndataloader = DataLoader(dataset, batch_size=64)\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.relu1 = ReLU()\n        self.sigmoid1 = Sigmoid() #定义sigmoid\n\n    def forward(self, input):\n        output = self.sigmoid1(input)\n        return output\n\nXTH = xth()\n\nwriter = SummaryWriter(\"./logs_relu\")\nstep =0\n\nfor data in dataloader:\n    imgs, targets = data\n    writer.add_images(\"input\", imgs, step)\n    output = XTH(imgs)\n    writer.add_images(\"output\",output, step)\n    step += 1\n\nwriter.close()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222621-oa01q5q","Type":"NodeParagraph","Properties":{"id":"20220618222621-oa01q5q","updated":"20220618222621"},"Children":[{"Type":"NodeText","Data":"结果","Properties":{"id":""}}]},{"ID":"20220618222622-s8e7l7h","Type":"NodeParagraph","Properties":{"id":"20220618222622-s8e7l7h","updated":"20220618222622"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/sig-20220618222918-2n6nrlu.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222623-dygcd7g","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222623-dygcd7g","updated":"20220618222623"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"Linear函数","Properties":{"id":""}}]},{"ID":"20220618222624-715luzi","Type":"NodeBlockquote","Properties":{"id":"20220618222624-715luzi","updated":"20220618222624"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222625-ldgzrmh","Type":"NodeParagraph","Properties":{"id":"20220618222625-ldgzrmh","updated":"20220618222625"},"Children":[{"Type":"NodeText","Data":"作用：","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"code","TextMarkTextContent":"nn.Linear（）"},{"Type":"NodeText","Data":"是用于设置网络中的","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"strong","TextMarkTextContent":"全连接层"}]}]},{"ID":"20220618222626-td9476e","Type":"NodeParagraph","Properties":{"id":"20220618222626-td9476e","updated":"20220618222626"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/linear-20220618222918-8bd1g6a.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222627-35dhqfc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222627-35dhqfc","updated":"20220618222627"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch as t\nfrom torch import nn\n\n# in_features由输入张量的形状决定，out_features则决定了输出张量的形状 \nconnected_layer = nn.Linear(in_features = 64*64*3, out_features = 1)\n\n# 假定输入的图像形状为[64,64,3]\ninput = t.randn(1,64,64,3)\n\n# 将四维张量转换为二维张量之后，才能作为全连接层的输入\ninput = input.view(1,64*64*3)\nprint(input.shape)\noutput = connected_layer(input) # 调用全连接层\nprint(output.shape)\n\n# 结果\ninput shape is %s torch.Size([1, 12288])\noutput shape is %s torch.Size([1, 1])\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222628-egs4p5u","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222628-egs4p5u","updated":"20220618222628"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"神经网络搭建","Properties":{"id":""}}]},{"ID":"20220618222629-onmv98j","Type":"NodeParagraph","Properties":{"id":"20220618222629-onmv98j","updated":"20220618222629"},"Children":[{"Type":"NodeText","Data":"搭建如下的神经网络","Properties":{"id":""}}]},{"ID":"20220618222630-cyk1xzi","Type":"NodeParagraph","Properties":{"id":"20220618222630-cyk1xzi","updated":"20220618222630"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/搭建-20220618222918-rx8ptgl.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222631-uxeq7cc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222631-uxeq7cc","updated":"20220618222631"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch import nn\nfrom torch.nn import Conv2d, MaxPool2d, Flatten, Linear\n\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        # 第一层卷积 输入是3，输出32\n        self.conv1 = Conv2d(3,32,kernel_size=5,padding=2)\n        self.maxpool1 = MaxPool2d(2)\n        # 第二层卷积 输入是32，输出是32\n        self.conv2 = Conv2d(32,32,kernel_size=5,padding=2)\n        self.maxpool2 = MaxPool2d(2)\n        self.conv3 = Conv2d(32,64,kernel_size=5,padding=2)\n        self.maxpool3 = MaxPool2d(2)\n        # 平铺\n        self.flatten = Flatten()\n        #1024 = 64x4x4\n        self.linear1 = Linear(1024, 64)\n        self.linear2 = Linear(64,10)\n\n    def forward(self,x):\n        x = self.conv1(x)\n        x = self.maxpool1(x)\n        x = self.conv2(x)\n        x = self.maxpool2(x)\n        x = self.conv3(x)\n        x = self.maxpool3(x)\n        x = self.flatten(x)\n        x = self.linear1(x)\n        x = self.linear2(x)\n        return x\n\nXTH =xth()\nprint(XTH)\n# 验证正确性\n# batchsize，通道数，大小32x32\ninput = torch.ones((64,3,32,32))\noutput = XTH(input)\nprint(output)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222632-ex2uibm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222632-ex2uibm","updated":"20220618222632"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"损失函数与反向传播","Properties":{"id":""}}]},{"ID":"20220618222633-na4aaxn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222633-na4aaxn","updated":"20220618222633"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"L1Loss函数","Properties":{"id":""}}]},{"ID":"20220618222634-116hsyf","Type":"NodeBlockquote","Properties":{"id":"20220618222634-116hsyf","updated":"20220618222634"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222635-9ky71jh","Type":"NodeParagraph","Properties":{"id":"20220618222635-9ky71jh","updated":"20220618222635"},"Children":[{"Type":"NodeText","Data":"CLASS torch.nn.L1Loss(size_average=None, ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"reduce=None"},{"Type":"NodeText","Data":", ","Properties":{"id":""}},{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em","TextMarkTextContent":"reduction='mean'"},{"Type":"NodeText","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222636-2ig5ntr","Type":"NodeParagraph","Properties":{"id":"20220618222636-2ig5ntr","updated":"20220618222636"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/loss1-20220618222918-3hjkodw.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222637-gjwfp5o","Type":"NodeParagraph","Properties":{"id":"20220618222637-gjwfp5o","updated":"20220618222637"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/loss2-20220618222918-wj0pigl.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222638-pszj52o","Type":"NodeBlockquote","Properties":{"id":"20220618222638-pszj52o","updated":"20220618222638"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222639-og5gut0","Type":"NodeParagraph","Properties":{"id":"20220618222639-og5gut0","updated":"20220618222639"},"Children":[{"Type":"NodeText","Data":"loss越小越好","Properties":{"id":""}}]}]},{"ID":"20220618222640-3ixadhh","Type":"NodeParagraph","Properties":{"id":"20220618222640-3ixadhh","updated":"20220618222640"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/loss-20220618222918-kwm73fm.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222641-qm5vp3a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222641-qm5vp3a","updated":"20220618222641"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch.nn import L1Loss\n\ninputs = torch.tensor([1, 2, 3], dtype=torch.float32)\ntargets = torch.tensor([1, 2, 5], dtype=torch.float32)\n\n# 1batchsize 1channel 1行3列\ninputs = torch.reshape(inputs, (1, 1, 1, 3))\ntargets = torch.reshape(targets, (1, 1, 1, 3))\n\n# reduction有很多类型 mean代表求平均\nloss = L1Loss(reduction=\"mean\")\nresult = loss(inputs, targets)\n\n# X:1,2,3 Y:1,2,5 L1|loss=[|1-1|+|2-2|+|5-3|]/3=0.6\nprint(result)\n\n# 结果\ntensor(0.6667)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222642-2ravwut","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222642-2ravwut","updated":"20220618222642"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"MSELoss函数","Properties":{"id":""}}]},{"ID":"20220618222643-l9m1yli","Type":"NodeParagraph","Properties":{"id":"20220618222643-l9m1yli","updated":"20220618222643"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/MSE-20220618222918-zmyuncz.PNG","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222644-fpw7ikn","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222644-fpw7ikn","updated":"20220618222644"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# X:1,2,3 Y:1,2,5 MSE=[(1-1)^2+(2-2)^2+(3-5)^2]/3=1.333\nloss_mse = nn.MSELoss()\nresult_mse = loss_mse(inputs, targets)\nprint(result_mse)\n\n# 结果\ntensor(1.3333)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222645-7ej93va","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618222645-7ej93va","updated":"20220618222645"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"Sequential函数","Properties":{"id":""}}]},{"ID":"20220618222646-flbn557","Type":"NodeBlockquote","Properties":{"id":"20220618222646-flbn557","updated":"20220618222646"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222647-8kty0q8","Type":"NodeParagraph","Properties":{"id":"20220618222647-8kty0q8","updated":"20220618222647"},"Children":[{"Type":"NodeText","Data":"可以把模型里所有的卷积、池化操作整合在一起","Properties":{"id":""}}]}]},{"ID":"20220618222648-82cnvk8","Type":"NodeParagraph","Properties":{"id":"20220618222648-82cnvk8","updated":"20220618222648"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/swqu-20220618222918-91uj9ko.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222649-rz5spgk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222649-rz5spgk","updated":"20220618222649"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nfrom torch import nn\nfrom torch.nn import Conv2d, MaxPool2d, Flatten, Linear, Sequential\n\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        # Sequential函数，把操作都整合起来了\n        self.model1 = Sequential(\n        Conv2d(3,32,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Conv2d(32,32,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Conv2d(32,64,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Flatten(),\n        Linear(1024, 64),\n        Linear(64,10),\n        )\n\n    def forward(self,x):\n        x = self.model1(x)\n        return x\n\nXTH =xth()\nprint(XTH)\n# batchsize，通道数，大小32x32\ninput = torch.ones((64,3,32,32))\noutput = XTH(input)\nprint(output.shape)\n\n# 结果\nxth(\n  (model1): Sequential(\n    (0): Conv2d(3, 32, kernel_size=(5, 5), stride=(1, 1), padding=(2, 2))\n    (1): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n    (2): Conv2d(32, 32, kernel_size=(5, 5), stride=(1, 1), padding=(2, 2))\n    (3): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n    (4): Conv2d(32, 64, kernel_size=(5, 5), stride=(1, 1), padding=(2, 2))\n    (5): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n    (6): Flatten(start_dim=1, end_dim=-1)\n    (7): Linear(in_features=1024, out_features=64, bias=True)\n    (8): Linear(in_features=64, out_features=10, bias=True)\n  )\n)\ntorch.Size([64, 10])\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222650-v0iqn0z","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222650-v0iqn0z","updated":"20220618222650"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"在神经网路中使用损失函数","Properties":{"id":""}}]},{"ID":"20220618222651-ewcvan6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222651-ewcvan6","updated":"20220618222651"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torchvision\nfrom torch import nn\nfrom torch.nn import Conv2d, MaxPool2d, Flatten, Linear, Sequential\nfrom torch.utils.data import DataLoader\n\ndataset = torchvision.datasets.CIFAR10(\"./dataset1\", train=False, transform=torchvision.transforms.ToTensor()\n                                       ,download=True)\n\ndataloader = DataLoader(dataset,batch_size=1)\n\nclass xth(nn.Module):\n    def __init__(self):\n        super(xth, self).__init__()\n        self.model1 = Sequential(\n        Conv2d(3,32,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Conv2d(32,32,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Conv2d(32,64,kernel_size=5,padding=2),\n        MaxPool2d(2),\n        Flatten(),\n        Linear(1024, 64),\n        Linear(64,10),\n        )\n\n    def forward(self,x):\n        x = self.model1(x)\n        return x\n\n# 交叉熵作为损失函数\nloss = nn.CrossEntropyLoss()\nXTH = xth()\nfor data in dataloader:\n\t# data的数据格式为 图片信息，图片的标签号\n    imgs, targets= data\n    # 将原来3通道32x32大小的图片输出为10（见神经网络搭建中的图片）\n    outputs = XTH(imgs)\n    result_loss = loss(outputs, targets)\n    print(outputs)\n    print(result_loss)\n    \n# 部分结果 可以看出图片变成了1x10的输出，（如果经过激活函数后每个就代表一个预测的概率），经过交叉熵target表示了神经网络输出与真实的误差\ntensor([[ 0.0318,  0.0850, -0.0511,  0.0465,  0.0630, -0.0248, -0.0515, -0.0208,\n         -0.0783,  0.1435]], grad_fn=\u003cAddmmBackward\u003e)\ntensor(2.2342, grad_fn=\u003cNllLossBackward\u003e)\ntensor([[ 0.0229,  0.1104, -0.0139,  0.0648,  0.0427, -0.0396, -0.0492, -0.0108,\n         -0.0579,  0.1306]], grad_fn=\u003cAddmmBackward\u003e)\ntensor(2.3354, grad_fn=\u003cNllLossBackward\u003e)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222652-xoopliy","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222652-xoopliy","updated":"20220618222652"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"随机梯度下降","Properties":{"id":""}}]},{"ID":"20220618222653-luixzcb","Type":"NodeParagraph","Properties":{"id":"20220618222653-luixzcb","updated":"20220618222653"},"Children":[{"Type":"NodeText","Data":"在上述代码的基础下，修改循环的内容，加入随机梯度下降,梯度清零很重要","Properties":{"id":""}}]},{"ID":"20220618222654-9oodfqm","Type":"NodeParagraph","Properties":{"id":"20220618222654-9oodfqm","updated":"20220618222654"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/随机梯度下降-20220618222918-uw4qgph.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222655-9yrm1a2","Type":"NodeParagraph","Properties":{"id":"20220618222655-9yrm1a2","updated":"20220618222655"},"Children":[{"Type":"NodeText","Data":"部分结果","Properties":{"id":""}}]},{"ID":"20220618222656-q41fwbx","Type":"NodeParagraph","Properties":{"id":"20220618222656-q41fwbx","updated":"20220618222656"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/部分-20220618222918-dmcxbsw.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618222657-qwibtdn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222657-qwibtdn","updated":"20220618222657"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"在现有模型中进行修改","Properties":{"id":""}}]},{"ID":"20220618222658-myxf2ie","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222658-myxf2ie","updated":"20220618222658"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torchvision\nfrom torch import nn\n\nvgg16_false = torchvision.models.vgg16(pretrained=False)\nvgg16_true = torchvision.models.vgg16(pretrained=True)\n\nprint(vgg16_true)\n\n# 对vgg现有模型进行直接修改 可以再最后看到有一行add_linear\nvgg16_true.add_module(\"add_linear\",nn.Linear(1000,10))\nprint(vgg16_true)\n\n# 想在classifier中进行增加\nvgg16_true.classifier。add_module(\"add_linear\",nn.Linear(1000,10))\nprint(vgg16_true)\n\n# 想直接修改参数\nvgg16_false.classifier[6] = nn.Linear(4096, 10)\nprint(vgg16_false)\n\n\n\n\n# 部分结果\n (classifier): Sequential(\n    (0): Linear(in_features=25088, out_features=4096, bias=True)\n    (1): ReLU(inplace=True)\n    (2): Dropout(p=0.5, inplace=False)\n    (3): Linear(in_features=4096, out_features=4096, bias=True)\n    (4): ReLU(inplace=True)\n    (5): Dropout(p=0.5, inplace=False)\n    (6): Linear(in_features=4096, out_features=1000, bias=True)\n  )\n  (add_linear): Linear(in_features=1000, out_features=10, bias=True)\n)\n# 在classifier中添加成功\n  (classifier): Sequential(\n    (0): Linear(in_features=25088, out_features=4096, bias=True)\n    (1): ReLU(inplace=True)\n    (2): Dropout(p=0.5, inplace=False)\n    (3): Linear(in_features=4096, out_features=4096, bias=True)\n    (4): ReLU(inplace=True)\n    (5): Dropout(p=0.5, inplace=False)\n    (6): Linear(in_features=4096, out_features=1000, bias=True)\n    (add_linear): Linear(in_features=1000, out_features=10, bias=True)\n  )\n)\n\n# 直接修改参数的结果\n(classifier): Sequential(\n    (0): Linear(in_features=25088, out_features=4096, bias=True)\n    (1): ReLU(inplace=True)\n    (2): Dropout(p=0.5, inplace=False)\n    (3): Linear(in_features=4096, out_features=4096, bias=True)\n    (4): ReLU(inplace=True)\n    (5): Dropout(p=0.5, inplace=False)\n    (6): Linear(in_features=4096, out_features=10, bias=True)\n  )\n)\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222659-uv63i09","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222659-uv63i09","updated":"20220618222659"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"保存模型","Properties":{"id":""}}]},{"ID":"20220618222660-ydcvc60","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222660-ydcvc60","updated":"20220618222660"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import torch\nimport torchvision\n\nvgg16 = torchvision.models.vgg16(pretrained=False)\n\n# 保存方式1 这种方法既保存了模型又保存了参数,名字自己定\ntorch.save(vgg16,\"vgg16_method1.pth\")\n\n# 保存方式2 模型参数（官方推荐）保存的大小比1小\ntorch.save(vgg16.state_dict(), \"vgg16_method2.pth\")\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222661-r36zdwa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220618222661-r36zdwa","updated":"20220618222661"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## ","Properties":{"id":""}},{"Type":"NodeText","Data":"加载模型","Properties":{"id":""}}]},{"ID":"20220618222662-v2t6pw0","Type":"NodeBlockquote","Properties":{"id":"20220618222662-v2t6pw0","updated":"20220618222662"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e ","Properties":{"id":""}},{"ID":"20220618222663-7fc2m26","Type":"NodeParagraph","Properties":{"id":"20220618222663-7fc2m26","updated":"20220618222663"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em strong","TextMarkTextContent":"*注意：*"}]},{"ID":"20220618222664-3v5h102","Type":"NodeParagraph","Properties":{"id":"20220618222664-3v5h102","updated":"20220618222664"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em strong","TextMarkTextContent":"*1.只加载网络参数的速度比加载整个网络快得多*"}]},{"ID":"20220618222665-zq9slfr","Type":"NodeParagraph","Properties":{"id":"20220618222665-zq9slfr","updated":"20220618222665"},"Children":[{"Type":"NodeTextMark","Properties":{"id":""},"TextMarkType":"em strong","TextMarkTextContent":"*2.pth、pkl格式效果相同，ckpt是tensorflow的格式*"}]}]},{"ID":"20220618222666-nxfrnug","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618222666-nxfrnug","updated":"20220618222666"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"#1.网络的保存\ntorch.save()有两种方法\n#1）仅保存网络参数   .h5也可以吗？\ntorch.save(net.state_dict(), 'net_params.pkl')\n#2)保存整个网络结构\n torch.save(net, 'net.pkl')\n\n#2.网络的加载\n#1）仅加载参数\nmodel_object.load_state_dict(torch.load('net_params.pkl')) \n#2）加载整个模型\nmodel = torch.load('net.pkl') \n#两种方法在载入模型时都需要有预设的网络结构，例如下边代码，否则会提示找不到相应的module\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618222667-p83de6e","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220618222667-p83de6e","updated":"20220618222667"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### ","Properties":{"id":""}},{"Type":"NodeText","Data":"加载模型的具体方法","Properties":{"id":""}}]},{"ID":"20220618222668-dcckyb7","Type":"NodeParagraph","Properties":{"id":"20220618222668-dcckyb7","updated":"20220618222668"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":