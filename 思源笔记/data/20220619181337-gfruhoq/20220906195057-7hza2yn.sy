rker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"c3Fs"},{"Type":"NodeCodeBlockCode","Data":"select * from tuser where name like '张%' and age=10;\n复制代码\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221010163931-d6sdn1i","Type":"NodeParagraph","Properties":{"id":"20221010163931-d6sdn1i","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"假如你了解索引最左匹配原则，那么就知道这个语句在搜索索引树的时候，只能用 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"张"},{"Type":"NodeText","Data":"，找到的第一个满足条件的记录id为1。"}]},{"ID":"20221010163931-n928z45","Type":"NodeParagraph","Properties":{"id":"20221010163931-n928z45","updated":"20221010163931"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"B+树联合索引"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://p3-juejin.byteimg.com/tos-cn-i-k3u1fbpfcp/a2db6afbc11546fbb4205b2faa64400f~tplv-k3u1fbpfcp-zoom-in-crop-mark:4536:0:0:0.image"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221010163931-ozhor57","Type":"NodeParagraph","Properties":{"id":"20221010163931-ozhor57","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"那接下来的步骤是什么呢？"}]},{"ID":"20221010163931-joc9eyh","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221010163931-joc9eyh","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"没有使用ICP"}]},{"ID":"20221010163931-zis6ga4","Type":"NodeParagraph","Properties":{"id":"20221010163931-zis6ga4","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"在MySQL 5.6之前，存储引擎根据通过联合索引找到"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"name like '张%'"},{"Type":"NodeText","Data":" 的主键id（1、4），逐一进行回表扫描，去聚簇索引找到完整的行记录，server层再对数据根据"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"age=10进行筛选"},{"Type":"NodeText","Data":"。"}]},{"ID":"20221010163931-iw4jl79","Type":"NodeParagraph","Properties"