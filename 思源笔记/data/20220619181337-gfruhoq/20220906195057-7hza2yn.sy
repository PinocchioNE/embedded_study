-----------------------+\n复制代码\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221010163931-l73xw5w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221010163931-l73xw5w","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"索引下推使用条件"}]},{"ID":"20221010163931-3gfggge","Type":"NodeList","ListData":{},"Properties":{"id":"20221010163931-3gfggge","updated":"20221010163931"},"Children":[{"ID":"20221010163931-3isri54","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221010163931-3isri54","updated":"20221010163931"},"Children":[{"ID":"20221010163931-4o0602y","Type":"NodeParagraph","Properties":{"id":"20221010163931-4o0602y","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"只能用于"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"range"},{"Type":"NodeText","Data":"、 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ref"},{"Type":"NodeText","Data":"、 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"eq_ref"},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ref_or_null"},{"Type":"NodeText","Data":"访问方法；"}]}]},{"ID":"20221010163931-p7ybmn9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221010163931-p7ybmn9","updated":"20221010163931"},"Children":[{"ID":"20221010163931-4e4m9qh","Type":"NodeParagraph","Properties":{"id":"20221010163931-4e4m9qh","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"只能用于"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"InnoDB"},{"Type":"NodeText","Data":"和 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"MyISAM"},{"Type":"NodeText","Data":"存储引擎及其分区表；"}]}]},{"ID":"20221010163931-uqeo5yr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221010163931-uqeo5yr","updated":"20221010163931"},"Children":[{"ID":"20221010163931-j2p7f9s","Type":"NodeParagraph","Properties":{"id":"20221010163931-j2p7f9s","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"对"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"InnoDB"},{"Type":"NodeText","Data":"存储引擎来说，索引下推只适用于二级索引（也叫辅助索引）;"}]}]}]},{"ID":"20221010163931-nd9wjbk","Type":"NodeBlockquote","Properties":{"id":"20221010163931-nd9wjbk","updated":"20221010163931"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221010163931-jce8bg4","Type":"NodeParagraph","Properties":{"id":"20221010163931-jce8bg4","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"索引下推的目的是为了减少回表次数，也就是要减少IO操作。对于"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"InnoDB"},{"Type":"NodeText","Data":"的"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"聚簇索引"},{"Type":"NodeText","Data":"来说，数据和索引是在一起的，不存在回表这一说。"}]}]},{"ID":"20221010163931-y1ddsfa","Type":"NodeList","ListData":{},"Properties":{"id":"20221010163931-y1ddsfa","updated":"20221010163931"},"Children":[{"ID":"20221010163931-c4yt3cc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221010163931-c4yt3cc","updated":"20221010163931"},"Children":[{"ID":"20221010163931-y2xt0sl","Type":"NodeParagraph","Properties":{"id":"20221010163931-y2xt0sl","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"引用了子查询的条件不能下推；"}]}]},{"ID":"20221010163931-6oscum9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221010163931-6oscum9","updated":"20221010163931"},"Children":[{"ID":"20221010163931-jq1xqy5","Type":"NodeParagraph","Properties":{"id":"20221010163931-jq1xqy5","updated":"20221010163931"},"Children":[{"Type":"NodeText","Data":"引用了存储函数的条件不能下推，因为存储引擎无法调用存储函数。"}]}]}]},{"ID":"20221010163431-trstn3d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221010163431-trstn3d","updated":"20221010165316"},"Children":[{"Type":"NodeText","Data":"索引优化2.0\u0026聚簇索引\u0026索引失效"}]},{"ID":"20221010165151-n9smzbz","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://blog.csdn.net/wangfeijiu/article/details/113409719\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 962px; height: 695px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221010165151-n9smzbz","updated":"20221010165203"}},{"ID":"20221010175409-uo2z106","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221010175409-uo2z106","updated":"20221010175414"},"Children":[{"Type":"NodeText","Data":"读锁和写锁"}]},{"ID":"20221010175416-k3ximol","Type":"NodeBlockquote","Properties":{"id":"20221010175416-k3ximol","updated":"20221010175427"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221010175426-sx6xjjq","Type":"NodeParagraph","Properties":{"id":"20221010175426-sx6xjjq","updated":"20221010175427"},"Children":[{"Type":"NodeText","Data":"读锁又称为共享锁，简称S锁，顾名思义，共享锁就是多个事务对于同一数据可以共享一把锁，都能访问到数据，但是只能读不能修改。"}]}]},{"ID":"20221010175416-k2zzq1j","Type":"NodeBlockquote","Properties":{"id":"20221010175416-k2zzq1j","updated":"20221010175431"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221010175431-rpi2k4u","Type":"NodeParagraph","Properties":{"id":"20221010175431-rpi2k4u","updated":"20221010175431"},"Children":[{"Type":"NodeText","Data":"写锁又称为排他锁，简称X锁，顾名思义，排他锁就是不能与其他所并存，如一个事务获取了一个数据行的排他锁，其他事务就不能再获取该行的其他锁，包括共享锁和排他锁，但是获取排他锁的事务是可以对数据就行读取和修改。"}]}]},{"ID":"20221010175444-55kogke","Type":"NodeBlockquote","Properties":{"id":"20221010175444-55kogke","updated":"20221010175416"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221010175416-4o7z3wr","Type":"NodeParagraph","Properties":{"id":"20221010175416-4o7z3wr","updated":"20221010175416"},"Children":[{"Type":"NodeText","Data":"共享锁 很好理解，就是多个事务只能读数据不能改数据。"}]},{"ID":"20221010175416-e6bqkx9","Type":"NodeParagraph","Properties":{"id":"20221010175416-e6bqkx9","updated":"20221010175416"},"Children":[{"Type":"NodeText","Data":"排他锁 指的是一个事务在一行数据加上排他锁后，其他事务不能再在其上加其他的锁。"}]},{"ID":"20221010175416-5nzy9k6","Type":"NodeParagraph","Properties":{"id":"20221010175416-5nzy9k6","updated":"20221010175416"},"Children":[{"Type":"NodeText","Data":"mysql InnoDB引擎默认的修改数据语句，update,delete,insert 都会自动给涉及到的数据加上排他锁，select 语句默认不会加任何锁类型。"}]},{"ID":"20221010175416-eaymnjz","Type":"NodeParagraph","Properties":{"id":"20221010175416-eaymnjz","updated":"20221010175421"},"Children":[{"Type":"NodeText","Data":"如果加排他锁可以使用select ...for update 语句，加共享锁可以使用select ... lock in share mode语句。所以加过排他锁的数据行在其他事务种是不能修改数据的，也不能通过for update和lock in share mode锁的方式查询数据，但可以直接通过select ...from...查询数据，因为普通查询没有任何锁机制。"}]}]},{"ID":"20221017064314-4ci6hrm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221017064314-4ci6hrm","updated":"20221017064318"},"Children":[{"Type":"NodeText","Data":"索引怎么设计"}]},{"ID":"20221025192114-cdovlto","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025192114-cdovlto","updated":"20221025192117"},"Children":[{"Type":"NodeText","Data":"超卖问题"}]},{"ID":"20221026220837-rftu0fx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221026220837-rftu0fx","updated":"20221026220857"},"Children":[{"Type":"NodeText","Data":"身份证和性别的索引问题"}]},{"ID":"20221027083903-5rfq58k","Type":"NodeBlockquote","Properties":{"id":"20221027083903-5rfq58k","updated":"20221027083847"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027083847-q52jbcm","Type":"NodeParagraph","Properties":{"id":"20221027083847-q52jbcm","updated":"20221027083847"},"Children":[{"Type":"NodeText","Data":"1、索引的选择性是指索引列中不同值的数目和表的记录数的比值。假如表里面有1000条数据，表索引列有980个不同的值，这时候索引的选择性就是980/1000=0.98 。索引的选择性越接近1，这个索引的效率很高。"}]},{"ID":"20221027083847-0faxhg7","Type":"NodeParagraph","Properties":{"id":"20221027083847-0faxhg7","updated":"20221027083855"},"Children":[{"Type":"NodeText","Data":"2、性别可以认为是3种，男，女，其他。如果创建索引，查询语句 性别=‘男’的数据，索引的选择性就是3/1000=0.003。索引的选择性值很低，对查询提升不大，所以性别建索引意义不大。"}]}]},{"ID":"20221027085024-qckjz3d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221027085024-qckjz3d","updated":"20221027160429"},"Children":[{"Type":"NodeText","Data":"索引失效场景"}]},{"ID":"20221027160429-5n7cop8","Type":"NodeBlockquote","Properties":{"id":"20221027160429-5n7cop8","updated":"20221027160431"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027160431-fl3j0b1","Type":"NodeParagraph","Properties":{"id":"20221027160431-fl3j0b1","updated":"20221027160431"},"Children":[{"Type":"NodeText","Data":"1.or语句前后没有同时使用索引。当or左右查询字段只有一个是索引，该索引失效，只有当or左右查询字段均为索引时，才会生效;\n2.复合索引未用左列字段，即不是使用第一列索引，索引失效;\n3.like以%开头，当like前缀没有%，后缀有%时，索引有效;\n4.需要类型转换;\n5.where中索引列有运算，或者索引列使用了函数;;\n6.where中在索引字段上使用not，\u003c\u003e，!=。"}]},{"ID":"20221027160431-19milet","Type":"NodeParagraph","Properties":{"id":"20221027160431-19milet","updated":"20221027160431"},"Children":[{"Type":"NodeText","Data":"  （不等于操作符是永远不会用到索引的，因此对它的处理只会产生全表扫描。key\u003c\u003e0 改为 key\u003e0 or key\u003c0。）不等于操作符是永远不会用到索引的，因此对它的处理只会产生全表扫描。优化方法：key\u003c\u003e0 改为 key\u003e0 or key\u003c0。）\n7.如果mysql觉得全表扫描更快时（数据少）;"}]},{"ID":"20221027160431-q3k7eo4","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20221027160431-q3k7eo4","updated":"20221027160431"},"Children":[{"ID":"20221027160431-cz146cg","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20221027160431-cz146cg","updated":"20221027160431"},"Children":[{"ID":"20221027160431-2mc748s","Type":"NodeParagraph","Properties":{"id":"20221027160431-2mc748s","updated":"20221027160431"},"Children":[{"Type":"NodeText","Data":"在索引列上使用 IS NULL 或 IS NOT NULL操作。"}]}]}]},{"ID":"20221027160431-d4jaibk","Type":"NodeParagraph","Properties":{"id":"20221027160431-d4jaibk","updated":"20221027160431"},"Children":[{"Type":"NodeText","Data":"（索引是不索引空值的，所以这样的操作不能使用索引，可以用其他的办法处理，例如：数字类型，判断大于0，字符串类型设置一个默认值，判断是否等于默认值即可。"}]}]},{"ID":"20221027160626-og5mzmn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221027160626-og5mzmn","updated":"20221027160632"},"Children":[{"Type":"NodeText","Data":"什么情况不适合使用索引"}]},{"ID":"20221027160632-bn5kmz6","Type":"NodeBlockquote","Properties":{"id":"20221027160632-bn5kmz6","updated":"20221027160634"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027160634-d31yg0j","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20221027160634-d31yg0j","updated":"20221027160634"},"Children":[{"ID":"20221027160634-cty12ra","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20221027160634-cty12ra","updated":"20221027160634"},"Children":[{"ID":"20221027160634-y5m4yhe","Type":"NodeParagraph","Properties":{"id":"20221027160634-y5m4yhe","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"数据唯一性差（一个字段的取值只有几种时）的字段不要使用索引"}]}]}]},{"ID":"20221027160634-b27lddr","Type":"NodeBlockquote","Properties":{"id":"20221027160634-b27lddr","updated":"20221027160634"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027160634-ulolcdn","Type":"NodeParagraph","Properties":{"id":"20221027160634-ulolcdn","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"比如性别，只有两种可能数据。意味着索引的二叉树级别少，多是平级。这样的二叉树查找无异于全表扫描。"}]}]},{"ID":"20221027160634-6lxahic","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20221027160634-6lxahic","updated":"20221027160634"},"Children":[{"ID":"20221027160634-ys47bgn","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20221027160634-ys47bgn","updated":"20221027160634"},"Children":[{"ID":"20221027160634-9ie557d","Type":"NodeParagraph","Properties":{"id":"20221027160634-9ie557d","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"频繁更新的字段不要使用索引"}]}]}]},{"ID":"20221027160634-qju1zb8","Type":"NodeBlockquote","Properties":{"id":"20221027160634-qju1zb8","updated":"20221027160634"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027160634-lakml42","Type":"NodeParagraph","Properties":{"id":"20221027160634-lakml42","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"比如logincount登录次数，频繁变化导致索引也频繁变化，增大"},{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://cloud.tencent.com/solution/database?from=10680","TextMarkTextContent":"数据库"},{"Type":"NodeText","Data":"工作量，降低效率。"}]}]},{"ID":"20221027160634-qjwdmpj","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20221027160634-qjwdmpj","updated":"20221027160634"},"Children":[{"ID":"20221027160634-f9zv56q","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20221027160634-f9zv56q","updated":"20221027160634"},"Children":[{"ID":"20221027160634-lu3ue1e","Type":"NodeParagraph","Properties":{"id":"20221027160634-lu3ue1e","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"字段不在where语句出现时不要添加索引,如果where后含IS NULL /IS NOT NULL/ like ‘%输入符%’等条件，不建议使用索引"}]}]}]},{"ID":"20221027160634-cww4rsw","Type":"NodeBlockquote","Properties":{"id":"20221027160634-cww4rsw","updated":"20221027160634"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027160634-92ek326","Type":"NodeParagraph","Properties":{"id":"20221027160634-92ek326","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"只有在where语句出现，mysql才会去使用索引"}]}]},{"ID":"20221027160634-wikxb4a","Type":"NodeParagraph","Properties":{"id":"20221027160634-wikxb4a","updated":"20221027160634"},"Children":[{"Type":"NodeText","Data":"4） where 子句里对索引列使用不等于（\u003c\u003e），使用索引效果一般"}]}]},{"ID":"20221031120424-pk99eaa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031120424-pk99eaa","updated":"20221031120453"},"Children":[{"Type":"NodeText","Data":"explain中的type解释"}]},{"ID":"20221031120436-j6hq3yj","Type":"NodeParagraph","Properties":{"id":"20221031120436-j6hq3yj","updated":"20221031120437"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221031120437-l0fp4cv.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221010145934-m008s6w","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010145934-m008s6w","updated":"20221010145939"},"Children":[{"Type":"NodeText","Data":"Mybatis"}]},{"ID":"20220906195126-b638kp1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195126-b638kp1","updated":"20220906195126"},"Children":[{"Type":"NodeText","Data":"了解过其他orm吗？"}]},{"ID":"20221008134436-lst1tk0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221008134436-lst1tk0","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"MyBatis 整体架构"}]},{"ID":"20221008134436-2tqe7ik","Type":"NodeParagraph","Properties":{"id":"20221008134436-2tqe7ik","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"MyBatis的架构大概是这样的，最上面是接口层，接口层就是开发人员在Mapper或者是Dao接口中的接口定义，是查询、新增、更新还是删除操作；中间层是数据处理层，主要是配置Mapper -\u003e xml层级之间的参数映射，SQL解析，SQL执行，结果映射的过程。上述两种流程都由基础支持层来提供功能支撑，基础支持层包括连接管理，事务管理，配置加载，缓存处理。"}]},{"ID":"20221008134436-quuusqj","Type":"NodeParagraph","Properties":{"id":"20221008134436-quuusqj","updated":"20221008134456"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block; width: 67%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221008134452-wusoti7.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"display: block; width: 67%;\"}"}]},{"ID":"20221008134436-20bg4z1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221008134436-20bg4z1","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"接口层"}]},{"ID":"20221008134436-1s4vo03","Type":"NodeParagraph","Properties":{"id":"20221008134436-1s4vo03","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"在不与Spring 集成的情况下，使用MyBatis执行数据库的操作主要如下："}]},{"ID":"20221008134436-f8fenxr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221008134436-f8fenxr","updated":"20221008134436"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"InputStream is = Resources.getResourceAsStream(\"myBatis-config.xml\");\nSqlSessionFactoryBuilder builder = new SqlSessionFactoryBuilder();\nSqlSessionFactory factory = builder.build(is);\nsqlSession = factory.openSession();\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221008134436-0oktq7l","Type":"NodeParagraph","Properties":{"id":"20221008134436-0oktq7l","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"其中的"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SqlSessionFactory"},{"Type":"NodeText","Data":","},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SqlSession"},{"Type":"NodeText","Data":"是MyBatis接口的核心类，尤其是SqlSession，这个接口是MyBatis中最重要的接口，这个接口能够让你执行命令，获取映射，管理事务。"}]},{"ID":"20221008134436-d2xscns","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221008134436-d2xscns","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"数据处理层"}]},{"ID":"20221008134436-efw0tfi","Type":"NodeParagraph","Properties":{"id":"20221008134436-efw0tfi","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"配置解析"}]},{"ID":"20221008134436-jbur3el","Type":"NodeParagraph","Properties":{"id":"20221008134436-jbur3el","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"在Mybatis初始化过程中，会加载mybatis-config.xml配置文件、映射配置文件以及Mapper接口中的注解信息，解析后的配置信息会形成相应的对象并保存到Configration对象中。之后，根据该对象创建SqlSessionFactory对象。待Mybatis初始化完成后，可以通过SqlSessionFactory创建SqlSession对象并开始数据库操作。"}]},{"ID":"20221008134436-9jpbbza","Type":"NodeParagraph","Properties":{"id":"20221008134436-9jpbbza","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"SQL解析与scripting模块"}]},{"ID":"20221008134436-ct2cbzi","Type":"NodeParagraph","Properties":{"id":"20221008134436-ct2cbzi","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Mybatis实现的动态SQL语句，几乎可以编写出所有满足需要的SQL。"}]},{"ID":"20221008134436-if7bt0z","Type":"NodeParagraph","Properties":{"id":"20221008134436-if7bt0z","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Mybatis中scripting模块会根据用户传入的参数，解析映射文件中定义的动态SQL节点，形成数据库能执行的sql语句。"}]},{"ID":"20221008134436-g47n06a","Type":"NodeParagraph","Properties":{"id":"20221008134436-g47n06a","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"SQL执行"}]},{"ID":"20221008134436-tpip1r3","Type":"NodeParagraph","Properties":{"id":"20221008134436-tpip1r3","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"SQL语句的执行涉及多个组件，包括MyBatis的四大神器，它们是: "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Executor"},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"StatementHandler"},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ParameterHandler"},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ResultSetHandler"},{"Type":"NodeText","Data":"。SQL的执行过程可以"}]},{"ID":"20221008134436-a09djeb","Type":"NodeParagraph","Properties":{"id":"20221008134436-a09djeb","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"用下面这幅图来表示"}]},{"ID":"20221008134436-pdz4xdy","Type":"NodeParagraph","Properties":{"id":"20221008134436-pdz4xdy","updated":"20221008134510"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221008134508-jivvktp.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: parent-style=\"display: block;\"}"}]},{"ID":"20221008134436-pkkxtef","Type":"NodeParagraph","Properties":{"id":"20221008134436-pkkxtef","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"MyBatis层级结构各个组件的介绍(这里只是简单介绍，具体介绍在后面)："}]},{"ID":"20221008134436-v3s90k1","Type":"NodeList","ListData":{},"Properties":{"id":"20221008134436-v3s90k1","updated":"20221008134436"},"Children":[{"ID":"20221008134436-w3sk2om","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-w3sk2om","updated":"20221008134436"},"Children":[{"ID":"20221008134436-twc9bss","Type":"NodeParagraph","Properties":{"id":"20221008134436-twc9bss","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"SqlSession: MyBatis核心API，主要用来执行命令，获取映射，管理事务。接收开发人员提供Statement Id 和参数.并返回操作结果"}]}]},{"ID":"20221008134436-dm8wqpz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-dm8wqpz","updated":"20221008134436"},"Children":[{"ID":"20221008134436-7v3toyg","Type":"NodeParagraph","Properties":{"id":"20221008134436-7v3toyg","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Executor: 执行器，是MyBatis调度的核心，负责SQL语句的生成以及查询缓存的维护"}]}]},{"ID":"20221008134436-rjituli","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-rjituli","updated":"20221008134436"},"Children":[{"ID":"20221008134436-augna2q","Type":"NodeParagraph","Properties":{"id":"20221008134436-augna2q","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"StatementHandler: 封装了JDBC Statement操作，负责对JDBC statement 的操作，如设置参数、将Statement结果集转换成List集合。"}]}]},{"ID":"20221008134436-mdw80p6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-mdw80p6","updated":"20221008134436"},"Children":[{"ID":"20221008134436-66jwnhl","Type":"NodeParagraph","Properties":{"id":"20221008134436-66jwnhl","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"ParameterHandler: 负责对用户传递的参数转换成JDBC Statement 所需要的参数"}]}]},{"ID":"20221008134436-vagjoxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-vagjoxj","updated":"20221008134436"},"Children":[{"ID":"20221008134436-a85gqq9","Type":"NodeParagraph","Properties":{"id":"20221008134436-a85gqq9","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"ResultSetHandler: 负责将JDBC返回的ResultSet结果集对象转换成List类型的集合"}]}]},{"ID":"20221008134436-od2rf3o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-od2rf3o","updated":"20221008134436"},"Children":[{"ID":"20221008134436-w7i2isp","Type":"NodeParagraph","Properties":{"id":"20221008134436-w7i2isp","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"TypeHandler: 用于Java类型和jdbc类型之间的转换"}]}]},{"ID":"20221008134436-yf3jeq1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-yf3jeq1","updated":"20221008134436"},"Children":[{"ID":"20221008134436-jrni9wg","Type":"NodeParagraph","Properties":{"id":"20221008134436-jrni9wg","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"MappedStatement: 动态SQL的封装"}]}]},{"ID":"20221008134436-jx4kfy7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-jx4kfy7","updated":"20221008134436"},"Children":[{"ID":"20221008134436-dhypptd","Type":"NodeParagraph","Properties":{"id":"20221008134436-dhypptd","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"SqlSource: 表示从XML文件或注释读取的映射语句的内容，它创建将从用户接收的输入参数传递给数据库的SQL。"}]}]},{"ID":"20221008134436-0d723l6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221008134436-0d723l6","updated":"20221008134436"},"Children":[{"ID":"20221008134436-1ze2wfu","Type":"NodeParagraph","Properties":{"id":"20221008134436-1ze2wfu","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Configuration: MyBatis所有的配置信息都维持在Configuration对象之中"}]}]}]},{"ID":"20221008134436-lxro36g","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221008134436-lxro36g","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"基础支持层"}]},{"ID":"20221008134436-gl6y7gs","Type":"NodeParagraph","Properties":{"id":"20221008134436-gl6y7gs","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"该层保护mybatis的基础模块，它们为核心处理层提供了良好的支撑。"}]},{"ID":"20221008134436-dlpgvcg","Type":"NodeParagraph","Properties":{"id":"20221008134436-dlpgvcg","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"(1）反射模块"}]},{"ID":"20221008134436-1oqmcmo","Type":"NodeParagraph","Properties":{"id":"20221008134436-1oqmcmo","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Mybatis中的反射模块，对Java原生的反射进行了很好的封装，提供了简易的API，方便上层调用，并且对反射操作进行了一系列的优化，比如，缓存了类的元数据（MetaClass）和对象的元数据（MetaObject），提高了反射操作的性能。"}]},{"ID":"20221008134436-6gebuue","Type":"NodeParagraph","Properties":{"id":"20221008134436-6gebuue","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（2）类型转换模块"}]},{"ID":"20221008134436-x7fbqti","Type":"NodeParagraph","Properties":{"id":"20221008134436-x7fbqti","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Mybatis的别名机制，是为了简化配置文件的，该机制是类型转换模块的主要功能之一。类型转换模块的另一个功能是实现JDBC类型与Java类型间的转换。该功能在SQL语句绑定实参和映射查询结果集时都会涉及。在SQL语句绑定实参时，会将数据有Java类型转换成JDBC类型；在映射结果集时，会将数据有JDBC类型转换成Java类型。"}]},{"ID":"20221008134436-e504tg6","Type":"NodeParagraph","Properties":{"id":"20221008134436-e504tg6","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（3）日志模块"}]},{"ID":"20221008134436-krr57bk","Type":"NodeParagraph","Properties":{"id":"20221008134436-krr57bk","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Java世界里，有很多优秀的日志框架，如Log4j、Log4j2、slf4j等。Mybatis除了提供了详细的日志输出信息，还能够集成多种日志框架，其日志模块的主要功能就是集成第三方日志框架。"}]},{"ID":"20221008134436-4lmk8ym","Type":"NodeParagraph","Properties":{"id":"20221008134436-4lmk8ym","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（4）资源加载模块"}]},{"ID":"20221008134436-bcqvbzl","Type":"NodeParagraph","Properties":{"id":"20221008134436-bcqvbzl","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"该模块主要封装了类加载器，确定了类加载器的使用顺序，并提供了加载类文件和其它资源文件的功能。"}]},{"ID":"20221008134436-4idbcnj","Type":"NodeParagraph","Properties":{"id":"20221008134436-4idbcnj","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（5） 解析器模块"}]},{"ID":"20221008134436-wsljdsx","Type":"NodeParagraph","Properties":{"id":"20221008134436-wsljdsx","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"该模块有两个主要功能：一个是封装了XPath，为Mybatis初始化时解析mybatis-config.xml配置文件以及映射配置文件提供支持；另一个为处理动态SQL语句中的占位符提供支持。"}]},{"ID":"20221008134436-iw4ficq","Type":"NodeParagraph","Properties":{"id":"20221008134436-iw4ficq","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（6）数据源模块"}]},{"ID":"20221008134436-awk103e","Type":"NodeParagraph","Properties":{"id":"20221008134436-awk103e","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"在数据源模块中，Mybatis自身提供了相应的数据源实现，也提供了与第三方数据源集成的接口。数据源是开发中的常用组件之一，很多开源的数据源都提供了丰富的功能，如，连接池、检测连接状态等，选择性能优秀的数据源组件，对于提供ORM框架以及整个应用的性能都是非常重要的。"}]},{"ID":"20221008134436-6j4u31f","Type":"NodeParagraph","Properties":{"id":"20221008134436-6j4u31f","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（7）事务管理模块"}]},{"ID":"20221008134436-i96x0il","Type":"NodeParagraph","Properties":{"id":"20221008134436-i96x0il","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"一般地，Mybatis与Spring框架集成，由Spring框架管理事务。但Mybatis自身对数据库事务进行了抽象，提供了相应的事务接口和简单实现。"}]},{"ID":"20221008134436-3xawxl6","Type":"NodeParagraph","Properties":{"id":"20221008134436-3xawxl6","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（8）缓存模块"}]},{"ID":"20221008134436-jrlcfre","Type":"NodeParagraph","Properties":{"id":"20221008134436-jrlcfre","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"Mybatis中有一级缓存和二级缓存，这两级缓存都依赖于缓存模块中的实现。但是，需要注意，这两级缓存与Mybatis以及整个应用是运行在同一个JVM中的，共享同一块内存，如果这两级缓存中的数据量较大，则可能影响系统中其它功能，所以需要缓存大量数据时，优先考虑使用Redis、Memcache等缓存产品。"}]},{"ID":"20221008134436-crxny22","Type":"NodeParagraph","Properties":{"id":"20221008134436-crxny22","updated":"20221008134436"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"（9）Binding模块"}]},{"ID":"20221008134436-hiauxfq","Type":"NodeParagraph","Properties":{"id":"20221008134436-hiauxfq","updated":"20221008134436"},"Children":[{"Type":"NodeText","Data":"在调用SqlSession相应方法执行数据库操作时，需要制定映射文件中定义的SQL节点，如果sql中出现了拼写错误，那就只能在运行时才能发现。为了能尽早发现这种错误，Mybatis通过Binding模块将用户自定义的Mapper接口与映射文件关联起来，系统可以通过调用自定义Mapper接口中的方法执行相应的SQL语句完成数据库操作，从而避免上述问题。注意，在开发中，我们只是创建了Mapper接口，而并没有编写实现类，这是因为Mybatis自动为Mapper接口创建了动态代理对象。有时，自定义的Mapper接口可以完全代替映射配置文件，但比如动态SQL语句啊等，还是写在映射配置文件中更好。"}]},{"ID":"20221008103125-xyeho8y","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221008103125-xyeho8y"},"Children":[{"Type":"NodeText","Data":"mybatis一级缓存二级缓存"}]},{"ID":"20221010113540-b153ayj","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://blog.csdn.net/qq_27631797/article/details/103975375\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 946px; height: 557px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221010113540-b153ayj","updated":"20221010113541"}},{"ID":"20221010112923-hnkbspq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221010112923-hnkbspq","updated":"20221010112926"},"Children":[{"Type":"NodeText","Data":"一级"}]},{"ID":"20221010112928-8008rzt","Type":"NodeBlockquote","Properties":{"id":"20221010112928-8008rzt","updated":"20221010113102"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221010113017-rn1tipw","Type":"NodeParagraph","Properties":{"id":"20221010113017-rn1tipw","updated":"20221010113017"},"Children":[{"Type":"NodeText","Data":"MyBatis一级缓存的运行过程是这样的：执行SQL语句的过程中，首次执行它时从数据库获取的所有数据会被存储在一段高速缓存中，今后执行这条语句时就会从高速缓存中读取结果，而不是再次查询数据库。MyBatis提供了默认下基于Java HashMap的缓存实现。"}]},{"ID":"20221010113017-3iv53j4","Type":"NodeParagraph","Properties":{"id":"20221010113017-3iv53j4","updated":"20221010113102"},"Children":[{"Type":"NodeText","Data":"重点是要明白：MyBatis执行SQL语句之后，这条语句的执行结果被缓存，以后再执行这条语句的时候，会直接从缓存中拿结果，而不是再次执行SQL。"},{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"但是一旦执行新增或更新或删除操作，缓存就会被清除"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"},{"Type":"NodeText","Data":"。"}]},{"ID":"20221010112950-pet3lte","Type":"NodeParagraph","Properties":{"id":"20221010112950-pet3lte","updated":"20221010112950"},"Children":[{"Type":"NodeText","Data":"默认情况下，MyBatis只启用了本地的会话缓存，它仅仅对一个会话中的数据进行缓存。这也就是大家常说的MyBatis一级缓存，一级缓存的作用域是SqlSession。"}]},{"ID":"20221010112929-gdly7ll","Type":"NodeParagraph","Properties":{"id":"20221010112929-gdly7ll","updated":"20221010112929"},"Children":[{"Type":"NodeText","Data":"在同个SqlSession中，查询语句相同的sql会被缓存，但是一旦执行新增或更新或删除操作，缓存就会被清除"}]}]},{"ID":"20221006101423-3kk6m81","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221006101423-3kk6m81","updated":"20221008161138"},"Children":[{"Type":"NodeText","Data":"如何分别对应mybatis和mybatis-plus的语句"}]},{"ID":"20221010145940-21dvz8f","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010145940-21dvz8f","updated":"20221010145944"},"Children":[{"Type":"NodeText","Data":"Spring"}]},{"ID":"20220919212319-m0y5ruq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220919212319-m0y5ruq","updated":"20220919212327"},"Children":[{"Type":"NodeText","Data":"spring开启事务的方式"}]},{"ID":"20220919212328-kqx8vf9","Type":"NodeBlockquote","Properties":{"id":"20220919212328-kqx8vf9","updated":"20220919212335"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220919212335-67jvleo","Type":"NodeParagraph","Properties":{"id":"20220919212335-67jvleo","updated":"20220920083933"},"Children":[{"Type":"NodeText","Data":"编程式事务和声明式事务"}]}]},{"ID":"20220920083934-8slmsl7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220920083934-8slmsl7","updated":"20220920083943"},"Children":[{"Type":"NodeText","Data":"编程式事务"}]},{"ID":"20220919212340-dectg3v","Type":"NodeParagraph","Properties":{"id":"20220919212340-dectg3v","updated":"20220919212620"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220919212620-qmzcqdt.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220920083947-1nagoj5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220920083947-1nagoj5","updated":"20220920083951"},"Children":[{"Type":"NodeText","Data":"声明式事务"}]},{"ID":"20220920083952-51xosvf","Type":"NodeBlockquote","Properties":{"id":"20220920083952-51xosvf","updated":"20220920083958"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220920083958-aw3swvk","Type":"NodeParagraph","Properties":{"id":"20220920083958-aw3swvk","updated":"20220920083958"},"Children":[{"Type":"NodeText","Data":"声明式事务管理 （1） "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"基于注解方式"},{"Type":"NodeText","Data":" （推荐使用） （2）基于 xml 配置文件方式"}]}]},{"ID":"20220919212621-hbi00go","Type":"NodeParagraph","Properties":{"id":"20220919212621-hbi00go","updated":"20220919212639"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220919212639-l5vuddb.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220919213550-qkka4eo","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220919213550-qkka4eo","updated":"20220919213556"},"Children":[{"Type":"NodeText","Data":"事务属性"}]},{"ID":"20220919213544-xva4x9e","Type":"NodeParagraph","Properties":{"id":"20220919213544-xva4x9e","updated":"20220919213545"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220919213545-1fo1zfu.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220920093700-46avvjv","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220920093700-46avvjv","updated":"20220920093716"},"Children":[{"Type":"NodeText","Data":"Spring中IOC和AOP"}]},{"ID":"20221028114021-lys6ave","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221028114021-lys6ave","updated":"20221028114023"},"Children":[{"Type":"NodeText","Data":"AOP"}]},{"ID":"20221028114025-045e9rj","Type":"NodeBlockquote","Properties":{"id":"20221028114025-045e9rj","updated":"20221028114044"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221028114027-s7j03tl","Type":"NodeParagraph","Properties":{"id":"20221028114027-s7j03tl","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"1.AOP是什么?\n面向切面编程,能够让我们在不影响原有功能的前提下,为软件横向扩展 功能 ."}]},{"ID":"20221028114027-yjbnx7y","Type":"NodeParagraph","Properties":{"id":"20221028114027-yjbnx7y","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"2.在什么地方能够让我们少写代码?\n要回答问题2,首先解决\"横向\"扩展什么意思?"}]},{"ID":"20221028114027-8pkfbe2","Type":"NodeParagraph","Properties":{"id":"20221028114027-8pkfbe2","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"理解了这个词基本就能理解AOP了."}]},{"ID":"20221028114027-s8pvhay","Type":"NodeParagraph","Properties":{"id":"20221028114027-s8pvhay","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"软件开发可分为\"持久层\" \"业务层\" 控制器层\""}]},{"ID":"20221028114027-vumv6g5","Type":"NodeParagraph","Properties":{"id":"20221028114027-vumv6g5","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"所谓的\"横向\"就是指上面说到的三个层里的任意一层!"}]},{"ID":"20221028114027-sibh7fs","Type":"NodeParagraph","Properties":{"id":"20221028114027-sibh7fs","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":" 使用AOP技术后,用一个方法,就能同时作用与一个层面内所有方法!"}]},{"ID":"20221028114027-q50vvqo","Type":"NodeParagraph","Properties":{"id":"20221028114027-q50vvqo","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"上句话不容易理解,栗子来了!"}]},{"ID":"20221028114027-o9x7rcq","Type":"NodeParagraph","Properties":{"id":"20221028114027-o9x7rcq","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"写日志是一个很好的编程习惯,不用AOP技术的话,我们应该怎么写日志?"}]},{"ID":"20221028114027-si7ag6e","Type":"NodeParagraph","Properties":{"id":"20221028114027-si7ag6e","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"  System.out.println(\"方法a开始执行\");"}]},{"ID":"20221028114027-ro6vzpk","Type":"NodeParagraph","Properties":{"id":"20221028114027-ro6vzpk","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":" public void a(){"}]},{"ID":"20221028114027-3io7thm","Type":"NodeParagraph","Properties":{"id":"20221028114027-3io7thm","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"    System.out.println(\"我是一个方法\");"}]},{"ID":"20221028114027-8rco627","Type":"NodeParagraph","Properties":{"id":"20221028114027-8rco627","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"}"}]},{"ID":"20221028114027-o0w473x","Type":"NodeParagraph","Properties":{"id":"20221028114027-o0w473x","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":" System.out.println(\"方法a执行成功\");"}]},{"ID":"20221028114027-lbdsife","Type":"NodeParagraph","Properties":{"id":"20221028114027-lbdsife","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"上述是一个很简单的日志.两行代码也不多."}]},{"ID":"20221028114027-98x0dpt","Type":"NodeParagraph","Properties":{"id":"20221028114027-98x0dpt","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"可是在真实开发中,面对100个甚至1000个方法时,这样写你会不会被累死?"}]},{"ID":"20221028114027-z73tku9","Type":"NodeParagraph","Properties":{"id":"20221028114027-z73tku9","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"如果用AOP的话,我们用一个方法就可以搞定所有的日志!"}]},{"ID":"20221028114027-309m05r","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221028114027-309m05r","updated":"20221028114044"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":" @Around(\"bean(*Service)\")//指定要监控的bean中的方法\n public Object testObject(ProceedingJoinPoint jp) throws Throwable{ //参数的意思是代理执行原软件中的方法\n \tSystem.out.println(jp.getSignature()+\"开始执行\"); //在方法执行之前执行\n \tObject val = jp.proceed();\n \tSystem.out.println(jp.getSignature()+\"执行成功\");//在方法执行之后执行\n \treturn val;\n }\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221028114027-utmvk8r","Type":"NodeParagraph","Properties":{"id":"20221028114027-utmvk8r","updated":"20221028114027"},"Children":[{"Type":"NodeText","Data":"OK!,搞定.现在所有业务层的方法执行前后都会打出日志了!."}]},{"ID":"20221028114027-17fwewm","Type":"NodeParagraph","Properties":{"id":"20221028114027-17fwewm","updated":"20221028114036"},"Children":[{"Type":"NodeText","Data":"一个方法搞定了需要机械重复的复制粘贴几百行的工作!世界美好了."}]}]},{"ID":"20220920093718-54myybx","Type":"NodeBlockquote","Properties":{"id":"20220920093718-54myybx","updated":"20220920093738"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220920093738-6rafpb0","Type":"NodeParagraph","Properties":{"id":"20220920093738-6rafpb0","updated":"20220920093738"},"Children":[{"Type":"NodeText","Data":"IOC就是典型的工厂模式，通过sessionfactory去注入实例。"}]},{"ID":"20220920093738-dn0uc6w","Type":"NodeParagraph","Properties":{"id":"20220920093738-dn0uc6w","updated":"20220920093738"},"Children":[{"Type":"NodeText","Data":"AOP就是典型的代理模式的体现。"}]}]},{"ID":"20221028114350-s529w0h","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221028114350-s529w0h","updated":"20221028114355"},"Children":[{"Type":"NodeText","Data":"IOC"}]},{"ID":"20221028114356-8c3kl7w","Type":"NodeBlockquote","Properties":{"id":"20221028114356-8c3kl7w","updated":"20221028114419"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221028114358-a735uc2","Type":"NodeParagraph","Properties":{"id":"20221028114358-a735uc2","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"IoC （Inversion of control ）控制反转/反转控制。它是一种思想不是一个技术实现。描述的是：Java 开发领域对象的创建以及管理的问题。"}]},{"ID":"20221028114358-ezwfj6y","Type":"NodeParagraph","Properties":{"id":"20221028114358-ezwfj6y","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"例如：现有类 A 依赖于类 B"}]},{"ID":"20221028114358-ikn5ouh","Type":"NodeList","ListData":{},"Properties":{"id":"20221028114358-ikn5ouh","updated":"20221028114358"},"Children":[{"ID":"20221028114358-brd9gk5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221028114358-brd9gk5","updated":"20221028114358"},"Children":[{"ID":"20221028114358-z1f5u50","Type":"NodeParagraph","Properties":{"id":"20221028114358-z1f5u50","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"传统的开发方式"},{"Type":"NodeText","Data":" ：往往是在类 A 中手动通过 new 关键字来 new 一个 B 的对象出来"}]}]},{"ID":"20221028114358-fsl9sy9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221028114358-fsl9sy9","updated":"20221028114358"},"Children":[{"ID":"20221028114358-q32adit","Type":"NodeParagraph","Properties":{"id":"20221028114358-q32adit","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用 IoC 思想的开发方式"},{"Type":"NodeText","Data":" ：不通过 new 关键字来创建对象，而是通过 IoC 容器(Spring 框架) 来帮助我们实例化对象。我们需要哪个对象，直接从 IoC 容器里面过去即可。"}]}]}]},{"ID":"20221028114358-n6gy63u","Type":"NodeParagraph","Properties":{"id":"20221028114358-n6gy63u","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"从以上两种开发方式的对比来看：我们 “丧失了一个权力” (创建、管理对象的权力)，从而也得到了一个好处（不用再考虑对象的创建、管理等一系列的事情）"}]},{"ID":"20221028114358-l4ysqno","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221028114358-l4ysqno","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"为什么叫控制反转"}]},{"ID":"20221028114358-mfxvfjd","Type":"NodeParagraph","Properties":{"id":"20221028114358-mfxvfjd","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"控制"},{"Type":"NodeText","Data":" ：指的是对象创建（实例化、管理）的权力"}]},{"ID":"20221028114358-7l1m97j","Type":"NodeParagraph","Properties":{"id":"20221028114358-7l1m97j","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"反转"},{"Type":"NodeText","Data":" ：控制权交给外部环境（Spring 框架、IoC 容器）"}]},{"ID":"20221028114358-a41wfhh","Type":"NodeParagraph","Properties":{"id":"20221028114358-a41wfhh","updated":"20221028114358"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://pic4.zhimg.com/80/v2-005b53a7d400a5c21314ae58cbd606b7_720w.webp"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221028114358-85d0ue9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221028114358-85d0ue9","updated":"20221028114358"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"IoC 解决了什么问题"}]},{"ID":"20221028114358-4gsm8ew","Type":"NodeParagraph","Properties":{"id":"20221028114358-4gsm8ew","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"IoC 的思想就是两方之间不互相依赖，由第三方容器来管理相关资源。这样有什么好处呢？"}]},{"ID":"20221028114358-hli0llh","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20221028114358-hli0llh","updated":"20221028114358"},"Children":[{"ID":"20221028114358-vcq6drl","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20221028114358-vcq6drl","updated":"20221028114358"},"Children":[{"ID":"20221028114358-hx9vvqe","Type":"NodeParagraph","Properties":{"id":"20221028114358-hx9vvqe","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"对象之间的耦合度或者说依赖程度降低；"}]}]},{"ID":"20221028114358-226hzz5","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20221028114358-226hzz5","updated":"20221028114358"},"Children":[{"ID":"20221028114358-yqr6qcf","Type":"NodeParagraph","Properties":{"id":"20221028114358-yqr6qcf","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"资源变的容易管理；比如你用 Spring 容器提供的话很容易就可以实现一个单例。"}]}]}]},{"ID":"20221028114358-5dib7yx","Type":"NodeParagraph","Properties":{"id":"20221028114358-5dib7yx","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"例如：现有一个针对 User 的操作，利用 Service 和 Dao 两层结构进行开发"}]},{"ID":"20221028114358-5428fwf","Type":"NodeParagraph","Properties":{"id":"20221028114358-5428fwf","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"在没有使用 IoC 思想的情况下，Service 层想要使用 Dao 层的具体实现的话，需要通过 new 关键字在"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"UserServiceImpl"},{"Type":"NodeText","Data":" 中手动 new 出 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":" 的具体实现类 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"UserDaoImpl"},{"Type":"NodeText","Data":"（不能直接 new 接口类）。"}]},{"ID":"20221028114358-bhd2bp6","Type":"NodeParagraph","Properties":{"id":"20221028114358-bhd2bp6","updated":"20221028114358"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://pic1.zhimg.com/80/v2-cc1018cafdf0308b78b13c78e74c43e8_720w.webp"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221028114358-es3e4mz","Type":"NodeParagraph","Properties":{"id":"20221028114358-es3e4mz","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"很完美，这种方式也是可以实现的，但是我们想象一下如下场景："}]},{"ID":"20221028114358-fobx79r","Type":"NodeParagraph","Properties":{"id":"20221028114358-fobx79r","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"开发过程中突然接到一个新的需求，针对对"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":" 接口开发出另一个具体实现类。因为 Server 层依赖了"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":"的具体实现，所以我们需要修改"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"UserServiceImpl"},{"Type":"NodeText","Data":"中 new 的对象。如果只有一个类引用了"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":"的具体实现，可能觉得还好，修改起来也不是很费力气，但是如果有许许多多的地方都引用了"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":"的具体实现的话，一旦需要更换"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"IUserDao"},{"Type":"NodeText","Data":" 的实现方式，那修改起来将会非常的头疼。"}]},{"ID":"20221028114358-45hxgmb","Type":"NodeParagraph","Properties":{"id":"20221028114358-45hxgmb","updated":"20221028114358"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://pic4.zhimg.com/80/v2-b308940c71b3669e3cfae538951103f7_720w.webp"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221028114358-p9138ht","Type":"NodeParagraph","Properties":{"id":"20221028114358-p9138ht","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"使用 IoC 的思想，我们将对象的控制权（创建、管理）交有 IoC 容器去管理，我们在使用的时候直接向 IoC 容器 “要” 就可以了"}]},{"ID":"20221028114358-uwu9p59","Type":"NodeParagraph","Properties":{"id":"20221028114358-uwu9p59","updated":"20221028114358"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://pic1.zhimg.com/80/v2-36005391eee51804baae7594d723c458_720w.webp"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221028114358-3xxokdm","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221028114358-3xxokdm","updated":"20221028114419"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"IoC 和 DI 别再傻傻分不清楚"}]},{"ID":"20221028114358-9l8e355","Type":"NodeParagraph","Properties":{"id":"20221028114358-9l8e355","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"IoC（Inverse of Control:控制反转）是一种"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"设计思想"},{"Type":"NodeText","Data":" 或者说是某种模式。这个设计思想就是 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"将原本在程序中手动创建对象的控制权，交由 Spring 框架来管理。"},{"Type":"NodeText","Data":" IoC 在其他语言中也有应用，并非 Spring 特有。"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"IoC 容器是 Spring 用来实现 IoC 的载体， IoC 容器实际上就是个 Map（key，value）,Map 中存放的是各种对象。"}]},{"ID":"20221028114358-8sono4g","Type":"NodeParagraph","Properties":{"id":"20221028114358-8sono4g","updated":"20221028114358"},"Children":[{"Type":"NodeText","Data":"IoC 最常见以及最合理的实现方式叫做依赖注入（Dependency Injection，简称 DI）。"}]}]},{"ID":"20220920093739-ffz2sjf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220920093739-ffz2sjf","updated":"20220920100227"},"Children":[{"Type":"NodeText","Data":"Bean的生命周期"}]},{"ID":"20220920100229-6kuffm7","Type":"NodeParagraph","Properties":{"id":"20220920100229-6kuffm7","updated":"20220920100234"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220920100234-m8qjb32.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220920143658-sitn96h","Type":"NodeParagraph","Properties":{"id":"20220920143658-sitn96h","updated":"20220920143710"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220920143710-7edcqds.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220920143949-rb05s9z","Type":"NodeParagraph","Properties":{"id":"20220920143949-rb05s9z","updated":"20220920143949"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220920143949-27otpoe.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221010145944-iwm19lz","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010145944-iwm19lz","updated":"20221010145949"},"Children":[{"Type":"NodeText","Data":"SpringBoot"}]},{"ID":"20220906195126-zif36zk","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195126-zif36zk","updated":"20220906195126"},"Children":[{"Type":"NodeText","Data":"循环依赖？"}]},{"ID":"20220919153109-ruoht13","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220919153109-ruoht13","updated":"20220919153109"},"Children":[{"Type":"NodeText","Data":"@Autowired 与@Resource的区别："}]},{"ID":"20220919153637-pfc360f","Type":"NodeBlockquote","Properties":{"id":"20220919153637-pfc360f","updated":"20220919153638"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220919153638-fqi7ubu","Type":"NodeParagraph","Properties":{"id":"20220919153638-fqi7ubu","updated":"20220919153644"},"Children":[{"Type":"NodeText","Data":"@Autowired按byType自动注入，@Resource默认按 byName自动注入"}]}]},{"ID":"20220919153109-r5zzkq9","Type":"NodeParagraph","Properties":{"id":"20220919153109-r5zzkq9","updated":"20220919153109"},"Children":[{"Type":"NodeText","Data":"1、 @Autowired与@Resource都可以用来装配bean. 都可以写在字段上,或写在setter方法上。"}]},{"ID":"20220919153109-qmdrjcn","Type":"NodeParagraph","Properties":{"id":"20220919153109-qmdrjcn","updated":"20220919153320"},"Children":[{"Type":"NodeText","Data":"2、 @Autowired默认按类型装配（这个注解是属于spring的），默认情况下必须要求依赖对象必须存在，如果要允许null值，可以设置它的required属性为false，如：@Autowired(required=false) ，如果我们想使用名称装配可以结合@Qualifier注解进行使用，如下："}]},{"ID":"20220919153109-z27sq8m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220919153109-z27sq8m","updated":"20220919153109"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"@Autowired()\n@Qualifier(\"baseDao\")\nprivateBaseDao baseDao;\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220919153109-xji243g","Type":"NodeParagraph","Properties":{"id":"20220919153109-xji243g","updated":"20220919153109"},"Children":[{"Type":"NodeText","Data":"3、@Resource（这个注解属于J2EE的），默认按照名称进行装配，名称可以通过name属性进行指定，如果没有指定name属性，当注解写在字段上时，默认取字段名进行安装名称查找，如果注解写在setter方法上默认取属性名进行装配。当找不到与名称匹配的bean时才按照类型进行装配。但是需要注意的是，如果name属性一旦指定，就只会按照名称进行装配。"}]},{"ID":"20220919153109-bi0ceel","Type":"NodeParagraph","Properties":{"id":"20220919153109-bi0ceel","updated":"20220919153109"},"Children":[{"Type":"NodeText","Data":"推荐使用：@Resource注解在字段上，这样就不用写setter方法了，并且这个注解是属于J2EE的，减少了与spring的耦合。这样代码看起就比较优雅。"}]},{"ID":"20220919153109-fgrn47y","Type":"NodeParagraph","Properties":{"id":"20220919153109-fgrn47y","updated":"20220919153139"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220919153138-lzphwqy.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220919153059-jifytti","Type":"NodeBlockquote","Properties":{"id":"20220919153059-jifytti","updated":"20220919153225"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220919153217-rl6ejbe","Type":"NodeParagraph","Properties":{"id":"20220919153217-rl6ejbe","updated":"20220919153217"},"Children":[{"Type":"NodeText","Data":"要实际的工作是根据实际情况来使用的，UserServiceImpl上面可能会这样写 @Service(\"userService\")，这样通常使用AutoWire和@Resource多一些，bean的名字不用写。"}]},{"ID":"20220919153217-hmdv3vn","Type":"NodeParagraph","Properties":{"id":"20220919153217-hmdv3vn","updated":"20220919153217"},"Children":[{"Type":"NodeText","Data":"这里的实际工作情况，到底是什么情况呢？"}]},{"ID":"20220919153217-6lv5hnm","Type":"NodeParagraph","Properties":{"id":"20220919153217-6lv5hnm","updated":"20220919153217"},"Children":[{"Type":"NodeText","Data":"如果你的架构设计师考虑的比较精细，要求比较严格，要求项目上线后的访问速度比较好，这个时候@AutoWire没有@Resource好用，因为@Resource可以根据名字来搜索，是这样写的@Resource(name=\"userService\")，可以直接写@Resource(\"userService\")，因为默认byname。"}]},{"ID":"20220919153217-a5k1gab","Type":"NodeParagraph","Properties":{"id":"20220919153217-a5k1gab","updated":"20220919153217"},"Children":[{"Type":"NodeText","Data":"为什么推荐@Resource(name=\"userService\")？？？"}]},{"ID":"20220919153217-z81xqgt","Type":"NodeParagraph","Properties":{"id":"20220919153217-z81xqgt","updated":"20220919153217"},"Children":[{"Type":"NodeText","Data":"因为根据名字搜索是最快的，就好像查数据库一样，根据Id查找最快。因为这里的名字与数据库里面的ID是一样的作用。这个时候，就要求你多写几个名字，工作量自然就增加了。而如果你不用注解，用xml文件的时候，对于注入Bean的时候要求写一个Id，xml文件时候的id就相当于这里的名字。"}]}]},{"ID":"20220919154014-lpb4wi6","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220919154014-lpb4wi6","updated":"20220919154014"},"Children":[{"Type":"NodeText","Data":"@Resource装配顺序"}]},{"ID":"20220919154026-qdfolno","Type":"NodeParagraph","Properties":{"id":"20220919154026-qdfolno","updated":"20220919154027"},"Children":[{"Type":"NodeText","Data":"1.如果同时指定了name和type，则从Spring上下文中找到唯一匹配的bean进行装配，找不到则抛出异常"}]},{"ID":"20220919154047-m3im730","Type":"NodeParagraph","Properties":{"id":"20220919154047-m3im730","updated":"20220919154104"},"Children":[{"Type":"NodeText","Data":"2.如果指定了name，则从上下文中查找名称（id）匹配的bean进行装配，找不到则抛出异常"}]},{"ID":"20220919154104-2h7kdlz","Type":"NodeParagraph","Properties":{"id":"20220919154104-2h7kdlz"},"Children":[{"Type":"NodeText","Data":"3.如果指定了type，则从上下文中找到类型匹配的唯一bean进行装配，找不到或者找到多个，都会抛出异常"}]},{"ID":"20220919154103-kfc9hmu","Type":"NodeParagraph","Properties":{"id":"20220919154103-kfc9hmu"},"Children":[{"Type":"NodeText","Data":"4.如果既没有指定name，又没有指定type，则自动按照byName方式进行装配；如果没有匹配，则回退为一个原始类型进行匹配，如果匹配则自动装配；"}]},{"ID":"20220919154232-38jmpr8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220919154232-38jmpr8","updated":"20220919154301"},"Children":[{"Type":"NodeText","Data":"@Autowired的注入逻辑"}]},{"ID":"20220919154232-i4262ey","Type":"NodeParagraph","Properties":{"id":"20220919154232-i4262ey","updated":"20220919154253"},"Children":[{"Type":"NodeText","Data":"1.找到所有类型符合的bean\n2.如果没有类型符合的bean，则看@Autowired的required属性是否为true，是则抛出异常，否则返回null\n3.如果只有一个，则将这个bean注入\n4.如果有多个bean选择其中带有Primary注解的bean，如果只有一个直接注入，如果有多个bean带有Primary注解则报错，如果不存在就下一步选择其中优先级最高的bean(优先级使用javax.annotation.Priority表明)，如果只有一个直接注入，如果有多个bean的优先级并列最高则报错，如果不存在就下一步选择beanName和当前要注入的属性名相同的bean进行注入，有则注入，没有则报错"}]},{"ID":"20220920161219-qghl1lr","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220920161219-qghl1lr","updated":"20220920215843"},"Children":[{"Type":"NodeText","Data":"PUT和POST的区别/幂等"}]},{"ID":"20220920215825-dqp4sj2","Type":"NodeParagraph","Properties":{"id":"20220920215825-dqp4sj2","updated":"20220920215826"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220920215826-vit6gd4.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221017064257-r2tn3fu","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221017064257-r2tn3fu","updated":"20221017064301"},"Children":[{"Type":"NodeText","Data":"跨域问题"}]},{"ID":"20221020143015-yj4v1lm","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221020143015-yj4v1lm","updated":"20221020145105"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.web.cors.CorsConfiguration;\nimport org.springframework.web.cors.UrlBasedCorsConfigurationSource;\nimport org.springframework.web.filter.CorsFilter;\n\n@Configuration\npublic class CorsConfig {\n\n    // 当前跨域请求最大有效时长。这里默认1天\n    private static final long MAX_AGE = 24 * 60 * 60;\n\n    @Bean\n    public CorsFilter corsFilter() {\n        UrlBasedCorsConfigurationSource source = new UrlBasedCorsConfigurationSource();\n        CorsConfiguration corsConfiguration = new CorsConfiguration();\n        corsConfiguration.addAllowedOrigin(\"http://localhost:8080\"); // 1 设置访问源地址，即前端的地址\n        corsConfiguration.addAllowedHeader(\"*\"); // 2 设置访问源请求头\n        corsConfiguration.addAllowedMethod(\"*\"); // 3 设置访问源请求方法\n        corsConfiguration.setMaxAge(MAX_AGE);\n        source.registerCorsConfiguration(\"/**\", corsConfiguration); // 4 对接口配置跨域设置\n        return new CorsFilter(source);\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221019102245-keugsnc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019102245-keugsnc","updated":"20221019102245"},"Children":[{"Type":"NodeText","Data":"@RequestParam和@PathVariable"}]},{"ID":"20221019102231-1kv8bgc","Type":"NodeParagraph","Properties":{"id":"20221019102231-1kv8bgc","updated":"20221019102232"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221019102232-hz12olg.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221019102231-87kzto6","Type":"NodeParagraph","Properties":{"id":"20221019102231-87kzto6"}},{"ID":"20221010150034-s8905kz","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010150034-s8905kz","updated":"20221027171149"},"Children":[{"Type":"NodeText","Data":"Redis"}]},{"ID":"20220906195126-dhy0drt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195126-dhy0drt","updated":"20220921102927"},"Children":[{"Type":"NodeText","Data":"redis的基本类型？应用场景"}]},{"ID":"20220906195126-o62tl9k","Type":"NodeParagraph","Properties":{"id":"20220906195126-o62tl9k","updated":"20220906195126"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/clip_image004-20220906195126-5ttrqwr.jpg"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220921100457-6q98fsr","Type":"NodeParagraph","Properties":{"id":"20220921100457-6q98fsr","updated":"20220921100457"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220921100457-4qzsbfk.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220921102931-akbvc8s","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220921102931-akbvc8s","updated":"20220921102943"},"Children":[{"Type":"NodeText","Data":"五种数据类型的应用场景"}]},{"ID":"20220921102944-maiganr","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220921102944-maiganr"},"Children":[{"Type":"NodeText","Data":"string的应用场景"}]},{"ID":"20220921102931-wlvf014","Type":"NodeParagraph","Properties":{"id":"20220921102931-wlvf014","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 普通的key-value键值对都可以用string来保存，"}]},{"ID":"20220921102931-on6o9su","Type":"NodeParagraph","Properties":{"id":"20220921102931-on6o9su","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 1，访问量统计，每次访问博客和文章的，都用intr命令加一"}]},{"ID":"20220921102931-buvjeb2","Type":"NodeParagraph","Properties":{"id":"20220921102931-buvjeb2","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 2，做缓存。"}]},{"ID":"20220921102931-xn6k3qf","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220921102931-xn6k3qf","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"list的应用场景"}]},{"ID":"20220921102931-cuq1o9p","Type":"NodeParagraph","Properties":{"id":"20220921102931-cuq1o9p","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 作为队列，list的两端操作比较方便，所以可以用来一些需要获取最新数据的场景。比如新闻类应用的最新新闻。"}]},{"ID":"20220921102931-oxd9dvt","Type":"NodeParagraph","Properties":{"id":"20220921102931-oxd9dvt","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"hash的应用场景"}]},{"ID":"20220921102931-xss5epe","Type":"NodeParagraph","Properties":{"id":"20220921102931-xss5epe","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 用来储存，修改对象属性，如果说用户（name，age，like），文章（标题，time，作者，内容，），其中用户相当于key，而（name，age,；like）相当于vlaue"}]},{"ID":"20220921102931-rr6igyg","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220921102931-rr6igyg","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"set的应用场景"}]},{"ID":"20220921102931-fyk5kir","Type":"NodeParagraph","Properties":{"id":"20220921102931-fyk5kir","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 1，好友推荐，根据set的内容交集，大于每个值就可以推荐，"}]},{"ID":"20220921102931-ohnt336","Type":"NodeParagraph","Properties":{"id":"20220921102931-ohnt336","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 2，利用set的唯一性，统计网站内容所有独立ip"}]},{"ID":"20220921102931-y2ks8co","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220921102931-y2ks8co","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"zset的应用场景"}]},{"ID":"20220921102931-klzsqda","Type":"NodeParagraph","Properties":{"id":"20220921102931-klzsqda","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"​ 排行榜，因为zset时有序的"}]},{"ID":"20220921102931-mw29yap","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20220921102931-mw29yap","updated":"20220921102931"},"Children":[{"Type":"NodeText","Data":"在程序中Redis的数据类型分别有什么作用"}]},{"ID":"20220921102931-i0vr83c","Type":"NodeBlockquote","Properties":{"id":"20220921102931-i0vr83c","updated":"20220921102956"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20220921102955-96ilj2m","Type":"NodeParagraph","Properties":{"id":"20220921102955-96ilj2m","updated":"20220921102956"},"Children":[{"Type":"NodeText","Data":"String：缓存，限流，计数器，分布式锁，分布式Session\nHash：储存用户信息，用户主页访问量，组合查询\nList：微博关注人时间轴列表，简单队列\nSet：赞，踩，标签，好友关系\nZset：排行榜"}]}]},{"ID":"20220906195126-39zqta3","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195126-39zqta3","updated":"20220906195126"},"Children":[{"Type":"NodeText","Data":"redis中删除数据后数据库中如何处理？"}]},{"ID":"20220906195254-1ezfd20","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195254-1ezfd20","updated":"20220906195305"},"Children":[{"Type":"NodeText","Data":"redis中热点key"}]},{"ID":"20220921100010-ss5u5gd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220921100010-ss5u5gd","updated":"20220921100017"},"Children":[{"Type":"NodeText","Data":"点赞用什么存储"}]},{"ID":"20220921100020-hwas4bw","Type":"NodeParagraph","Properties":{"id":"20220921100020-hwas4bw","updated":"20220921100040"},"Children":[{"Type":"NodeText","Data":"set"}]},{"ID":"20221010142722-dfqjm1l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221010142722-dfqjm1l","updated":"20221010142734"},"Children":[{"Type":"NodeText","Data":"缓存击穿、雪崩、穿透"}]},{"ID":"20221010142735-oi9dk5f","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://www.cnblogs.com/shisuiliunian/p/11256743.html\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 1290px; height: 766px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221010142735-oi9dk5f","updated":"20221010142737"}},{"ID":"20221008102528-2c73dy2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221008102528-2c73dy2","updated":"20221008102546"},"Children":[{"Type":"NodeText","Data":"redis一级缓存二级缓存"}]},{"ID":"20221010150200-8zsmwgi","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010150200-8zsmwgi","updated":"20221010150205"},"Children":[{"Type":"NodeText","Data":"Git"}]},{"ID":"20220906195126-z81e81a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220906195126-z81e81a","updated":"20220906195126"},"Children":[{"Type":"NodeText","Data":"merge和xxx的区别，什么时候用merge?"}]},{"ID":"20221010150744-tkty8kl","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010150744-tkty8kl","updated":"20221010150750"},"Children":[{"Type":"NodeText","Data":"计算机网络"}]},{"ID":"20220922105227-jofmui2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220922105227-jofmui2","updated":"20220922105232"},"Children":[{"Type":"NodeText","Data":"http和https"}]},{"ID":"20221006104237-zx6qmn3","Type":"NodeParagraph","Properties":{"id":"20221006104237-zx6qmn3","updated":"20221006104237"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"HTTPS 为什么会出现"}]},{"ID":"20221006104237-ibf8o3r","Type":"NodeParagraph","Properties":{"id":"20221006104237-ibf8o3r","updated":"20221006104237"},"Children":[{"Type":"NodeText","Data":"一个新技术的出现必定是为了解决某种问题的，那么 HTTPS 解决了 HTTP 的什么问题呢？"}]},{"ID":"20221006104237-a6eak2v","Type":"NodeParagraph","Properties":{"id":"20221006104237-a6eak2v","updated":"20221006104237"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"HTTPS 解决了什么问题"}]},{"ID":"20221006104237-496csal","Type":"NodeParagraph","Properties":{"id":"20221006104237-496csal","updated":"20221006104304"},"Children":[{"Type":"NodeText","Data":"一个简单的回答可能会是 HTTP 它不安全。由于 HTTP 天生明文传输的特性，在 HTTP 的传输过程中，任何人都有可能从中截获、修改或者伪造请求发送，所以可以认为 HTTP 是不安全的；在 HTTP 的传输过程中不会验证通信方的身份，因此 HTTP 信息交换的双方可能会遭到伪装，也就是没有用户验证；在 HTTP 的传输过程中，接收方和发送方并不会验证报文的完整性，综上，为了解决上述问题，HTTPS 应用而生。"}]},{"ID":"20221006104305-6hy0jsd","Type":"NodeParagraph","Properties":{"id":"20221006104305-6hy0jsd","updated":"20221006104315"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"width: 50%; display: block;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221006104305-1lszxnh.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"width: 50%; display: block;\"}"}]},{"ID":"20221006110331-gctl93y","Type":"NodeParagraph","Properties":{"id":"20221006110331-gctl93y","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"为了保证这些隐私数据能加密传输，让"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"HTTP"},{"Type":"NodeText","Data":"运行安全的"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SSL/TLS"},{"Type":"NodeText","Data":"协议上，即 HTTPS = HTTP + SSL/TLS，通过 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SSL"},{"Type":"NodeText","Data":"证书来验证服务器的身份，并为浏览器和服务器之间的通信进行加密"}]},{"ID":"20221006110331-k6w1ssw","Type":"NodeParagraph","Properties":{"id":"20221006110331-k6w1ssw","updated":"20221006110331"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SSL"},{"Type":"NodeText","Data":" 协议位于"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"TCP/IP"},{"Type":"NodeText","Data":" 协议与各种应用层协议之间，浏览器和服务器在使用 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SSL"},{"Type":"NodeText","Data":" 建立连接时需要选择一组恰当的加密算法来实现安全通信，为数据通讯提供安全支持"}]},{"ID":"20221006110331-a20xk8x","Type":"NodeParagraph","Properties":{"id":"20221006110331-a20xk8x","updated":"20221006110331"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/078c50c0-b20c-11eb-ab90-d9ae814b240d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006110331-x4mv4v1","Type":"NodeParagraph","Properties":{"id":"20221006110331-x4mv4v1","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"流程图如下所示："}]},{"ID":"20221006110331-5x0btfi","Type":"NodeParagraph","Properties":{"id":"20221006110331-5x0btfi","updated":"20221006110331"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/0e409fc0-b20c-11eb-85f6-6fac77c0c9b3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006110331-cqsl7tm","Type":"NodeList","ListData":{},"Properties":{"id":"20221006110331-cqsl7tm","updated":"20221006110331"},"Children":[{"ID":"20221006110331-ga4269x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-ga4269x","updated":"20221006110331"},"Children":[{"ID":"20221006110331-yawtmkz","Type":"NodeParagraph","Properties":{"id":"20221006110331-yawtmkz","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"首先客户端通过URL访问服务器建立SSL连接"}]}]},{"ID":"20221006110331-skkfvxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-skkfvxh","updated":"20221006110331"},"Children":[{"ID":"20221006110331-9k5qxmn","Type":"NodeParagraph","Properties":{"id":"20221006110331-9k5qxmn","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"服务端收到客户端请求后，会将网站支持的证书信息（证书中包含公钥）传送一份给客户端"}]}]},{"ID":"20221006110331-peeb6mt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-peeb6mt","updated":"20221006110331"},"Children":[{"ID":"20221006110331-cabvwhe","Type":"NodeParagraph","Properties":{"id":"20221006110331-cabvwhe","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"客户端的服务器开始协商SSL连接的安全等级，也就是信息加密的等级"}]}]},{"ID":"20221006110331-6tyiuul","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-6tyiuul","updated":"20221006110331"},"Children":[{"ID":"20221006110331-bc9ehm4","Type":"NodeParagraph","Properties":{"id":"20221006110331-bc9ehm4","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"客户端的浏览器根据双方同意的安全等级，建立会话密钥，然后利用网站的公钥将会话密钥加密，并传送给网站"}]}]},{"ID":"20221006110331-x3zt19p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-x3zt19p","updated":"20221006110331"},"Children":[{"ID":"20221006110331-vil8trw","Type":"NodeParagraph","Properties":{"id":"20221006110331-vil8trw","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"服务器利用自己的私钥解密出会话密钥"}]}]},{"ID":"20221006110331-t93etlv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110331-t93etlv","updated":"20221006110331"},"Children":[{"ID":"20221006110331-6bjak66","Type":"NodeParagraph","Properties":{"id":"20221006110331-6bjak66","updated":"20221006110331"},"Children":[{"Type":"NodeText","Data":"服务器利用会话密钥加密与客户端之间的通信"}]}]}]},{"ID":"20221006110238-hagzgnd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221006110238-hagzgnd","updated":"20221006110245"},"Children":[{"Type":"NodeText","Data":"区别"}]},{"ID":"20221006110238-klgfyan","Type":"NodeList","ListData":{},"Properties":{"id":"20221006110238-klgfyan","updated":"20221006110238"},"Children":[{"ID":"20221006110238-eg7pe1a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110238-eg7pe1a","updated":"20221006110238"},"Children":[{"ID":"20221006110238-7s81r7a","Type":"NodeParagraph","Properties":{"id":"20221006110238-7s81r7a","updated":"20221006110238"},"Children":[{"Type":"NodeText","Data":"HTTPS是HTTP协议的安全版本，HTTP协议的数据传输是明文的，是不安全的，HTTPS使用了SSL/TLS协议进行了加密处理，相对更安全"}]}]},{"ID":"20221006110238-nofyjnn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110238-nofyjnn","updated":"20221006110238"},"Children":[{"ID":"20221006110238-q02jdqu","Type":"NodeParagraph","Properties":{"id":"20221006110238-q02jdqu","updated":"20221006110238"},"Children":[{"Type":"NodeText","Data":"HTTP 和 HTTPS 使用连接方式不同，默认端口也不一样，HTTP是80，HTTPS是443"}]}]},{"ID":"20221006110238-49fppy9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110238-49fppy9","updated":"20221006110238"},"Children":[{"ID":"20221006110238-jta0zye","Type":"NodeParagraph","Properties":{"id":"20221006110238-jta0zye","updated":"20221006110238"},"Children":[{"Type":"NodeText","Data":"HTTPS 由于需要设计加密以及多次握手，性能方面不如 HTTP"}]}]},{"ID":"20221006110238-z5gskuv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006110238-z5gskuv","updated":"20221006110238"},"Children":[{"ID":"20221006110238-n0nkzfn","Type":"NodeParagraph","Properties":{"id":"20221006110238-n0nkzfn","updated":"20221006110238"},"Children":[{"Type":"NodeText","Data":"HTTPS需要SSL，SSL 证书需要钱，功能越强大的证书费用越高"}]}]}]},{"ID":"20221006125150-i5gyxqf","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221006125150-i5gyxqf","updated":"20221006125150"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"SSL"},{"Type":"NodeText","Data":"的实现这些功能主要依赖于三种手段："}]},{"ID":"20221006125150-bcgl2qa","Type":"NodeList","ListData":{},"Properties":{"id":"20221006125150-bcgl2qa","updated":"20221006125150"},"Children":[{"ID":"20221006125150-1s5n9xk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125150-1s5n9xk","updated":"20221006125150"},"Children":[{"ID":"20221006125150-gwpoxyo","Type":"NodeParagraph","Properties":{"id":"20221006125150-gwpoxyo","updated":"20221006125150"},"Children":[{"Type":"NodeText","Data":"对称加密：采用协商的密钥对数据加密"}]}]},{"ID":"20221006125150-i143mps","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125150-i143mps","updated":"20221006125150"},"Children":[{"ID":"20221006125150-873j0hm","Type":"NodeParagraph","Properties":{"id":"20221006125150-873j0hm","updated":"20221006125150"},"Children":[{"Type":"NodeText","Data":"非对称加密：实现身份认证和密钥协商"}]}]},{"ID":"20221006125150-5oy7pd6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125150-5oy7pd6","updated":"20221006125150"},"Children":[{"ID":"20221006125150-vjughj8","Type":"NodeParagraph","Properties":{"id":"20221006125150-vjughj8","updated":"20221006125150"},"Children":[{"Type":"NodeText","Data":"摘要算法：验证信息的完整性"}]}]},{"ID":"20221006125150-cffy2sn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125150-cffy2sn","updated":"20221006125150"},"Children":[{"ID":"20221006125150-tly78ew","Type":"NodeParagraph","Properties":{"id":"20221006125150-tly78ew","updated":"20221006125150"},"Children":[{"Type":"NodeText","Data":"数字签名：身份验证"}]}]}]},{"ID":"20221006125222-fab92xz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-fab92xz","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"对称加密"}]},{"ID":"20221006125222-tlrqhvp","Type":"NodeParagraph","Properties":{"id":"20221006125222-tlrqhvp","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"对称加密指的是加密和解密使用的秘钥都是同一个，是对称的。只要保证了密钥的安全，那整个通信过程就可以说具有了机密性"}]},{"ID":"20221006125222-558g2hs","Type":"NodeParagraph","Properties":{"id":"20221006125222-558g2hs","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/e3f040f0-b2ff-11eb-ab90-d9ae814b240d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-jplfjfz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-jplfjfz","updated":"20221006125228"},"Children":[{"Type":"NodeText","Data":"非对称加密"}]},{"ID":"20221006125222-ncsvgwa","Type":"NodeParagraph","Properties":{"id":"20221006125222-ncsvgwa","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"非对称加密，存在两个秘钥，一个叫公钥，一个叫私钥。两个秘钥是不同的，公钥可以公开给任何人使用，私钥则需要保密"}]},{"ID":"20221006125222-i7iaa87","Type":"NodeParagraph","Properties":{"id":"20221006125222-i7iaa87","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"公钥和私钥都可以用来加密解密，但公钥加密后只能用私钥解 密，反过来，私钥加密后也只能用公钥解密"}]},{"ID":"20221006125222-zubbeda","Type":"NodeParagraph","Properties":{"id":"20221006125222-zubbeda","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/d9603e60-b2ff-11eb-ab90-d9ae814b240d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-d3qf7pp","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-d3qf7pp","updated":"20221006125233"},"Children":[{"Type":"NodeText","Data":"混合加密"}]},{"ID":"20221006125222-8oeexs2","Type":"NodeParagraph","Properties":{"id":"20221006125222-8oeexs2","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"在"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"HTTPS"},{"Type":"NodeText","Data":"通信过程中，采用的是对称加密+非对称加密，也就是混合加密"}]},{"ID":"20221006125222-vyxnufb","Type":"NodeParagraph","Properties":{"id":"20221006125222-vyxnufb","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"在对称加密中讲到，如果能够保证了密钥的安全，那整个通信过程就可以说具有了机密性"}]},{"ID":"20221006125222-oka7fbv","Type":"NodeParagraph","Properties":{"id":"20221006125222-oka7fbv","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"而"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"HTTPS"},{"Type":"NodeText","Data":"采用非对称加密解决秘钥交换的问题"}]},{"ID":"20221006125222-fznn1ln","Type":"NodeParagraph","Properties":{"id":"20221006125222-fznn1ln","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"具体做法是发送密文的一方使用对方的公钥进行加密处理“对称的密钥”，然后对方用自己的私钥解密拿到“对称的密钥”"}]},{"ID":"20221006125222-gwlmib9","Type":"NodeParagraph","Properties":{"id":"20221006125222-gwlmib9","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/f375f290-b2ff-11eb-85f6-6fac77c0c9b3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-tpz3shq","Type":"NodeParagraph","Properties":{"id":"20221006125222-tpz3shq","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"这样可以确保交换的密钥是安全的前提下，使用对称加密方式进行通信"}]},{"ID":"20221006125222-xtk0usn","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20221006125222-xtk0usn","updated":"20221006125237"},"Children":[{"Type":"NodeText","Data":"举个例子："}]},{"ID":"20221006125222-axxybl8","Type":"NodeParagraph","Properties":{"id":"20221006125222-axxybl8","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"网站秘密保管私钥，在网上任意分发公钥，你想要登录网站只要用公钥加密就行了，密文只能由私钥持有者才能解密。而黑客因为没有私钥，所以就无法破解密文"}]},{"ID":"20221006125222-pi4bhkc","Type":"NodeParagraph","Properties":{"id":"20221006125222-pi4bhkc","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"上述的方法解决了数据加密，在网络传输过程中，数据有可能被篡改，并且黑客可以伪造身份发布公钥，如果你获取到假的公钥，那么混合加密也并无多大用处，你的数据扔被黑客解决"}]},{"ID":"20221006125222-v7p6pgv","Type":"NodeParagraph","Properties":{"id":"20221006125222-v7p6pgv","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"因此，在上述加密的基础上仍需加上完整性、身份验证的特性，来实现真正的安全，实现这一功能则是摘要算法"}]},{"ID":"20221006125222-psiq0ig","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-psiq0ig","updated":"20221006125238"},"Children":[{"Type":"NodeText","Data":"摘要算法"}]},{"ID":"20221006125222-cf2sbp3","Type":"NodeParagraph","Properties":{"id":"20221006125222-cf2sbp3","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"实现完整性的手段主要是摘要算法，也就是常说的散列函数、哈希函数"}]},{"ID":"20221006125222-hx5hpxe","Type":"NodeParagraph","Properties":{"id":"20221006125222-hx5hpxe","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"可以理解成一种特殊的压缩算法，它能够把任意长度的数据“压缩”成固定长度、而且独一无二的“摘要”字符串，就好像是给这段数据生成了一个数字“指纹”"}]},{"ID":"20221006125222-ybxxrtb","Type":"NodeParagraph","Properties":{"id":"20221006125222-ybxxrtb","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/12798da0-b300-11eb-85f6-6fac77c0c9b3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-xmw3gf5","Type":"NodeParagraph","Properties":{"id":"20221006125222-xmw3gf5","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"摘要算法保证了“数字摘要”和原文是完全等价的。所以，我们只要在原文后附上它的摘要，就能够保证数据的完整性"}]},{"ID":"20221006125222-h8pjwdb","Type":"NodeParagraph","Properties":{"id":"20221006125222-h8pjwdb","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"比如，你发了条消息：“转账 1000 元”，然后再加上一个 SHA-2 的摘要。网站收到后也计算一下消息的摘要，把这两份“指纹”做个对比，如果一致，就说明消息是完整可信的，没有被修改"}]},{"ID":"20221006125222-0rzoa09","Type":"NodeParagraph","Properties":{"id":"20221006125222-0rzoa09","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/023790e0-b300-11eb-ab90-d9ae814b240d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-q1wf6su","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-q1wf6su","updated":"20221006125242"},"Children":[{"Type":"NodeText","Data":"数字签名"}]},{"ID":"20221006125222-1rn6l8i","Type":"NodeParagraph","Properties":{"id":"20221006125222-1rn6l8i","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"数字签名能确定消息确实是由发送方签名并发出来的，因为别人假冒不了发送方的签名"}]},{"ID":"20221006125222-vyd5tpk","Type":"NodeParagraph","Properties":{"id":"20221006125222-vyd5tpk","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"原理其实很简单，就是用私钥加密，公钥解密"}]},{"ID":"20221006125222-8os63sz","Type":"NodeParagraph","Properties":{"id":"20221006125222-8os63sz","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"签名和公钥一样完全公开，任何人都可以获取。但这个签名只有用私钥对应的公钥才能解开，拿到摘要后，再比对原文验证完整性，就可以像签署文件一样证明消息确实是你发的"}]},{"ID":"20221006125222-ep9m1t1","Type":"NodeParagraph","Properties":{"id":"20221006125222-ep9m1t1","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/21aa6880-b300-11eb-85f6-6fac77c0c9b3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-qvj1iy1","Type":"NodeParagraph","Properties":{"id":"20221006125222-qvj1iy1","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"和消息本身一样，因为谁都可以发布公钥，我们还缺少防止黑客伪造公钥的手段，也就是说，怎么判断这个公钥就是你的公钥"}]},{"ID":"20221006125222-p9r3mam","Type":"NodeParagraph","Properties":{"id":"20221006125222-p9r3mam","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"这时候就需要一个第三方，就是证书验证机构"}]},{"ID":"20221006125222-atqi8wq","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006125222-atqi8wq","updated":"20221006125245"},"Children":[{"Type":"NodeText","Data":"CA验证机构"}]},{"ID":"20221006125222-80bh0ia","Type":"NodeParagraph","Properties":{"id":"20221006125222-80bh0ia","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"数字证书认证机构处于客户端与服务器双方都可信赖的第三方机构的立场"}]},{"ID":"20221006125222-neacpd8","Type":"NodeParagraph","Properties":{"id":"20221006125222-neacpd8","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"CA 对公钥的签名认证要求包括序列号、用途、颁发者、有效时间等等，把这些打成一个包再签名，完整地证明公钥关联的各种信息，形成“数字证书”"}]},{"ID":"20221006125222-9ck7vc3","Type":"NodeParagraph","Properties":{"id":"20221006125222-9ck7vc3","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"流程如下图："}]},{"ID":"20221006125222-rpilbc6","Type":"NodeParagraph","Properties":{"id":"20221006125222-rpilbc6","updated":"20221006125222"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"https://static.vue-js.com/395648a0-b300-11eb-85f6-6fac77c0c9b3.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221006125222-ikyhsom","Type":"NodeList","ListData":{},"Properties":{"id":"20221006125222-ikyhsom","updated":"20221006125222"},"Children":[{"ID":"20221006125222-fw3p4o7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-fw3p4o7","updated":"20221006125222"},"Children":[{"ID":"20221006125222-w1i0e6o","Type":"NodeParagraph","Properties":{"id":"20221006125222-w1i0e6o","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"服务器的运营人员向数字证书认证机构提出公开密钥的申请"}]}]},{"ID":"20221006125222-m9sg4fz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-m9sg4fz","updated":"20221006125222"},"Children":[{"ID":"20221006125222-snjktjd","Type":"NodeParagraph","Properties":{"id":"20221006125222-snjktjd","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"数字证书认证机构在判明提出申请者的身份之后，会对已申请的公开密钥做数字签名"}]}]},{"ID":"20221006125222-e6912r6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-e6912r6","updated":"20221006125222"},"Children":[{"ID":"20221006125222-e0g91jc","Type":"NodeParagraph","Properties":{"id":"20221006125222-e0g91jc","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"然后分配这个已签名的公开密钥，并将该公开密钥放入公钥证书后绑定在一起"}]}]},{"ID":"20221006125222-88wl9zw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-88wl9zw","updated":"20221006125222"},"Children":[{"ID":"20221006125222-uswm8yz","Type":"NodeParagraph","Properties":{"id":"20221006125222-uswm8yz","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"服务器会将这份由数字证书认证机构颁发的数字证书发送给客户端，以进行非对称加密方式通信"}]}]}]},{"ID":"20221006125222-5h8lgw9","Type":"NodeParagraph","Properties":{"id":"20221006125222-5h8lgw9","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"接到证书的客户端可使用数字证书认证机构的公开密钥，对那张证书上的数字签名进行验证，一旦验证通过，则证明："}]},{"ID":"20221006125222-hqb5qby","Type":"NodeList","ListData":{},"Properties":{"id":"20221006125222-hqb5qby","updated":"20221006125222"},"Children":[{"ID":"20221006125222-a6xsuun","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-a6xsuun","updated":"20221006125222"},"Children":[{"ID":"20221006125222-e93mvm1","Type":"NodeParagraph","Properties":{"id":"20221006125222-e93mvm1","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"认证服务器的公开密钥的是真实有效的数字证书认证机构"}]}]},{"ID":"20221006125222-enkqjwz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221006125222-enkqjwz","updated":"20221006125222"},"Children":[{"ID":"20221006125222-xijxg9s","Type":"NodeParagraph","Properties":{"id":"20221006125222-xijxg9s","updated":"20221006125222"},"Children":[{"Type":"NodeText","Data":"服务器的公开密钥是值得信赖的"}]}]}]},{"ID":"20221006141852-nssh17a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221006141852-nssh17a","updated":"20221006141900"},"Children":[{"Type":"NodeText","Data":"TCP UDP"}]},{"ID":"20220922105432-n7l2156","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220922105432-n7l2156","updated":"20220922105438"},"Children":[{"Type":"NodeText","Data":"三次握手四次挥手"}]},{"ID":"20221006134831-cto94mw","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://javaguide.cn/cs-basics/network/tcp-connection-and-disconnection.html#%E5%BB%BA%E7%AB%8B%E8%BF%9E%E6%8E%A5-tcp-%E4%B8%89%E6%AC%A1%E6%8F%A1%E6%89%8B\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 944px; height: 500px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221006134831-cto94mw","updated":"20221006134909"}},{"ID":"20221006144234-sxtryg5","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://vue3js.cn/interview/http/handshakes_waves.html#%E4%BA%8C%E3%80%81%E5%9B%9B%E6%AC%A1%E6%8C%A5%E6%89%8B\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 944px; height: 562px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221006144234-sxtryg5","updated":"20221006144236"}},{"ID":"20221007105635-08blp3j","Type":"NodeParagraph","Properties":{"id":"20221007105635-08blp3j","updated":"20221007105649"},"Children":[{"Type":"NodeImage","Data":"span","Properties":{"parent-style":"display: block; width: 75%;","style":"width: 10000px;"},"Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221007105640-e7kqddp.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"width: 10000px;\" parent-style=\"display: block; width: 75%;\"}"}]},{"ID":"20220922105444-swy1yw4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220922105444-swy1yw4","updated":"20220922105504"},"Children":[{"Type":"NodeText","Data":"cookie和session"}]},{"ID":"20221006144631-pyzyipc","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://www.cnblogs.com/ityouknow/p/10856177.html#:~:text=Cookie%20%E5%92%8C%20Session%20%E6%9C%89%E4%BB%80%E4%B9%88%E4%B8%8D%E5%90%8C%EF%BC%9F.%20%E4%BD%9C%E7%94%A8%E8%8C%83%E5%9B%B4%E4%B8%8D%E5%90%8C%EF%BC%8CCookie%20%E4%BF%9D%E5%AD%98%E5%9C%A8%E5%AE%A2%E6%88%B7%E7%AB%AF%EF%BC%88%E6%B5%8F%E8%A7%88%E5%99%A8%EF%BC%89%EF%BC%8CSession%20%E4%BF%9D%E5%AD%98%E5%9C%A8%E6%9C%8D%E5%8A%A1%E5%99%A8%E7%AB%AF%E3%80%82.%20%E5%AD%98%E5%8F%96%E6%96%B9%E5%BC%8F%E7%9A%84%E4%B8%8D%E5%90%8C%EF%BC%8CCookie,%E4%B8%AD%E4%BF%9D%E6%8C%81%E4%B8%80%E4%BA%9B%E5%B8%B8%E7%94%A8%E5%8F%98%E9%87%8F%E4%BF%A1%E6%81%AF%EF%BC%8C%E6%AF%94%E5%A6%82%E8%AF%B4%20UserId%20%E7%AD%89%E3%80%82.%20%E6%9C%89%E6%95%88%E6%9C%9F%E4%B8%8D%E5%90%8C%EF%BC%8CCookie%20%E5%8F%AF%E8%AE%BE%E7%BD%AE%E4%B8%BA%E9%95%BF%E6%97%B6%E9%97%B4%E4%BF%9D%E6%8C%81%EF%BC%8C%E6%AF%94%E5%A6%82%E6%88%91%E4%BB%AC%E7%BB%8F%E5%B8%B8%E4%BD%BF%E7%94%A8%E7%9A%84%E9%BB%98%E8%AE%A4%E7%99%BB%E5%BD%95%E5%8A%9F%E8%83%BD%EF%BC%8CSession%20%E4%B8%80%E8%88%AC%E5%A4%B1%E6%95%88%E6%97%B6%E9%97%B4%E8%BE%83%E7%9F%AD%EF%BC%8C%E5%AE%A2%E6%88%B7%E7%AB%AF%E5%85%B3%E9%97%AD%E6%88%96%E8%80%85%20Session%20%E8%B6%85%E6%97%B6%E9%83%BD%E4%BC%9A%E5%A4%B1%E6%95%88%E3%80%82.\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 1297px; height: 899px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221006144631-pyzyipc","updated":"20221006144643"}},{"ID":"20221006154947-pvr2mqa","Type":"NodeIFrame","Data":"\u003ciframe src=\"https://www.cnblogs.com/ibigboy/p/11573533.html\" data-src=\"\" border=\"0\" frameborder=\"no\" framespacing=\"0\" allowfullscreen=\"true\" style=\"width: 1297px; height: 698px;\"\u003e\u003c/iframe\u003e","Properties":{"id":"20221006154947-pvr2mqa","updated":"20221006154950"}},{"ID":"20220922105505-q4yelaf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220922105505-q4yelaf"},"Children":[{"Type":"NodeText","Data":"cookie存储在哪里？"}]},{"ID":"20221006145642-5pk8b83","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221006145642-5pk8b83","updated":"20221006145652"},"Children":[{"Type":"NodeText","Data":"区别："}]},{"ID":"20221006145832-h1wc13k","Type":"NodeParagraph","Properties":{"id":"20221006145832-h1wc13k","updated":"20221006145832"},"Children":[{"Type":"NodeText","Data":"cookie数据保存在客户端，session数据保存在服务端。"}]},{"ID":"20221006145832-wlma2f7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006145832-wlma2f7","updated":"20221006145845"},"Children":[{"Type":"NodeText","Data":"session"}]},{"ID":"20221006145846-1pvwaan","Type":"NodeBlockquote","Properties":{"id":"20221006145846-1pvwaan","updated":"20221006145847"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221006145846-ste8eu8","Type":"NodeParagraph","Properties":{"id":"20221006145846-ste8eu8","updated":"20221006145847"},"Children":[{"Type":"NodeText","Data":"简单的说，当你登陆一个网站的时候，如果web服务器端使用的是session，那么所有的数据都保存在服务器上，客户端每次请求服务器的时候会发送当前会话sessionid，服务器根据当前sessionid判断相应的用户数据标志，以确定用户是否登陆或具有某种权限。由于数据是存储在服务器上面，所以你不能伪造。"}]}]},{"ID":"20221006145832-q77saig","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221006145832-q77saig","updated":"20221006145832"},"Children":[{"Type":"NodeText","Data":"cookie"}]},{"ID":"20221006145922-2tj24cx","Type":"NodeBlockquote","Properties":{"id":"20221006145922-2tj24cx","updated":"20221006150043"},"Children":[{"ID":"20221006145918-od1neo4","Type":"NodeParagraph","Properties":{"id":"20221006145918-od1neo4","updated":"20221006145930"},"Children":[{"Type":"NodeText","Data":"sessionid是服务器和客户端连接时候随机分配的，如果浏览器使用的是cookie，那么所有数据都保存在浏览器端，比如你登陆以后，服务器设置了cookie用户名，那么当你再次请求服务器的时候，浏览器会将用户名一块发送给服务器，这些变量有一定的特殊标记。服务器会解释为cookie变量，所以只要不关闭浏览器，那么cookie变量一直是有效的，所以能够保证长时间不掉线。"}]},{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221006145832-mg1p48i","Type":"NodeParagraph","Properties":{"id":"20221006145832-mg1p48i","updated":"20221006145832"},"Children":[{"Type":"NodeText","Data":"如果你能够截获某个用户的cookie变量，然后伪造一个数据包发送过去，那么服务器还是 认为你是合法的。所以，使用cookie被攻击的可能性比较大。"}]},{"ID":"20221006145832-pztmw92","Type":"NodeParagraph","Properties":{"id":"20221006145832-pztmw92","updated":"20221006150043"},"Children":[{"Type":"NodeTextMark","Properties":{"style":"color: var(--b3-font-color8);"},"TextMarkType":"strong","TextMarkTextContent":"如果cookie设置了有效值，那么cookie会保存到客户端的硬盘上，"},{"Type":"NodeKramdownSpanIAL","Data":"{: style=\"color: var(--b3-font-color8);\"}"},{"Type":"NodeText","Data":"下次在访问网站的时候，浏览器先检查有没有cookie，如果有的话，读取cookie，然后发送给服务器。"}]},{"ID":"20221006145832-77yap2w","Type":"NodeParagraph","Properties":{"id":"20221006145832-77yap2w","updated":"20221006145832"},"Children":[{"Type":"NodeText","Data":"所以你在机器上面保存了某个论坛cookie，有效期是一年，如果有人入侵你的机器，将你的cookie拷走，放在他机器下面，那么他登陆该网站的时候就是用你的身份登陆的。当然，伪造的时候需要注意，直接copy cookie文件到 cookie目录，浏览器是不认的，他有一个index.dat文件，存储了 cookie文件的建立时间，以及是否有修改，所以你必须先要有该网站的 cookie文件，并且要从保证时间上骗过浏览器"}]}]},{"ID":"20221006145832-5b6o12s","Type":"NodeParagraph","Properties":{"id":"20221006145832-5b6o12s","updated":"20221006145832"},"Children":[{"Type":"NodeText","Data":"两个都可以用来存私密的东西，session过期与否，取决于服务器的设定。cookie过期与否，可以在cookie生成的时候设置进去。"}]},{"ID":"20221006145832-2wp5bim","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221006145832-2wp5bim","updated":"20221006145944"},"Children":[{"Type":"NodeText","Data":"区别对比："}]},{"ID":"20221006145948-vl38o2i","Type":"NodeBlockquote","Properties":{"id":"20221006145948-vl38o2i","updated":"20221006151446"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221006150007-oumo2fl","Type":"NodeParagraph","Properties":{"id":"20221006150007-oumo2fl","updated":"20221006151446"},"Children":[{"Type":"NodeText","Data":"(1)cookie数据存放在客户的浏览器上，session数据放在服务器上\n(2)cookie不是很安全，别人可以分析存放在本地的COOKIE并进行COOKIE欺骗,如果主要考虑到安全应当使用session\n(3)session会在一定时间内保存在服务器上。当访问增多，会比较占用你服务器的性能，如果主要考虑到减轻服务器性能方面，应当使用COOKIE\n(4)单个cookie在客户端的限制是4K，就是说一个站点在客户端存放的COOKIE不能4K。\n(5)所以：将登陆信息等重要信息存放为SESSION;其他信息如果需要保留，可以放在COOKIE中"}]}]},{"ID":"20221025214142-hgjbu8c","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025214142-hgjbu8c","updated":"20221025214145"},"Children":[{"Type":"NodeText","Data":"get和post区别"}]},{"ID":"20221025214207-so0026l","Type":"NodeBlockquote","Properties":{"id":"20221025214207-so0026l","updated":"20221025214215"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025214209-2va4ebk","Type":"NodeParagraph","Properties":{"id":"20221025214209-2va4ebk","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"1.get请求一般是去取获取数据（其实也可以提交，但常见的是获取数据）；\npost请求一般是去提交数据。"}]},{"ID":"20221025214209-w0w1t76","Type":"NodeParagraph","Properties":{"id":"20221025214209-w0w1t76","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"2.get因为参数会放在url中，所以隐私性，安全性较差，请求的数据长度是有限制的，\n不同的浏览器和服务器不同，一般限制在 2~8K 之间，更加常见的是 1k 以内；\npost请求是没有的长度限制，请求数据是放在body中；"}]},{"ID":"20221025214209-62w0wmv","Type":"NodeParagraph","Properties":{"id":"20221025214209-62w0wmv","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"3.get请求刷新服务器或者回退没有影响，post请求回退时会重新提交数据请求。"}]},{"ID":"20221025214209-fqr9age","Type":"NodeParagraph","Properties":{"id":"20221025214209-fqr9age","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"4.get请求可以被缓存，post请求不会被缓存。"}]},{"ID":"20221025214209-ekrlad8","Type":"NodeParagraph","Properties":{"id":"20221025214209-ekrlad8","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"5.get请求会被保存在浏览器历史记录当中，post不会。get请求可以被收藏为书签，因为参数就是url中，但post不能。它的参数不在url中。"}]},{"ID":"20221025214209-6t7jrpo","Type":"NodeParagraph","Properties":{"id":"20221025214209-6t7jrpo","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"6.get请求只能进行url编码（appliacation-x-www-form-urlencoded）,post请求支持多种（multipart/form-data等）。"}]},{"ID":"20221025214209-sjhpbsr","Type":"NodeParagraph","Properties":{"id":"20221025214209-sjhpbsr","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"深入理解\n1…GET 和 POST都是http请求方式， 底层都是 TCP/IP协议；通常GET 产生一个 TCP 数据包；POST 产生两个 TCP 数据包（但firefox是发送一个数据包），"}]},{"ID":"20221025214209-vmf1pei","Type":"NodeParagraph","Properties":{"id":"20221025214209-vmf1pei","updated":"20221025214209"},"Children":[{"Type":"NodeText","Data":"2.对于 GET 方式的请求，浏览器会把 http header 和 data 一并发送出去，服务器响应 200\n（返回数据）表示成功；"}]},{"ID":"20221025214209-i31tsti","Type":"NodeParagraph","Properties":{"id":"20221025214209-i31tsti","updated":"20221025214215"},"Children":[{"Type":"NodeText","Data":"而对于 POST，浏览器先发送 header，服务器响应 100， 浏览器再继续发送 data，服\n务器响应 200 （返回数据）。"}]}]},{"ID":"20221027101045-11spvsk","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221027101045-11spvsk","updated":"20221027101050"},"Children":[{"Type":"NodeText","Data":"4xx与5xx"}]},{"ID":"20221027101050-73duw7p","Type":"NodeBlockquote","Properties":{"id":"20221027101050-73duw7p","updated":"20221027101115"},"Children":[{"ID":"20221027101052-c3067u6","Type":"NodeParagraph","Properties":{"id":"20221027101052-c3067u6","updated":"20221027101058"},"Children":[{"Type":"NodeText","Data":"400(错误请求) 服务器不理解请求的语法。"}]},{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221027101052-25iekde","Type":"NodeParagraph","Properties":{"id":"20221027101052-25iekde","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"404(未找到) 服务器找不到请求的网页。例如，对于服务器上不存在的网页经常会返回此代码。"}]},{"ID":"20221027101052-c974f1x","Type":"NodeParagraph","Properties":{"id":"20221027101052-c974f1x","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"500(服务器内部错误) 服务器遇到错误，无法完成请求。"}]},{"ID":"20221027101052-m0x015g","Type":"NodeParagraph","Properties":{"id":"20221027101052-m0x015g","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"一、4xx(请求错误)\n这些状态码表示请求可能出错，妨碍了服务器的处理。"}]},{"ID":"20221027101052-arg6y1f","Type":"NodeParagraph","Properties":{"id":"20221027101052-arg6y1f","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"400(错误请求) 服务器不理解请求的语法。"}]},{"ID":"20221027101052-lgz48vn","Type":"NodeParagraph","Properties":{"id":"20221027101052-lgz48vn","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"401(未授权) 请求要求身份验证。对于登录后请求的网页，服务器可能返回此响应。"}]},{"ID":"20221027101052-ar5qdzu","Type":"NodeParagraph","Properties":{"id":"20221027101052-ar5qdzu","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"403(禁止) 服务器拒绝请求。如果您在 Googlebot 尝试抓取您网站上的有效网页时看到此状态码(您可以在 Google 网站管理员工具诊断下的网络抓取页面上看到此信息)，可能是您的服务器或主机拒绝了 Googlebot 访问。"}]},{"ID":"20221027101052-m3smu3q","Type":"NodeParagraph","Properties":{"id":"20221027101052-m3smu3q","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"404(未找到) 服务器找不到请求的网页。例如，对于服务器上不存在的网页经常会返回此代码。"}]},{"ID":"20221027101052-2mj7z00","Type":"NodeParagraph","Properties":{"id":"20221027101052-2mj7z00","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"如果您的网站上没有 robots.txt 文件，而您在 Google 网站管理员工具\"诊断\"标签的 robots.txt 页上看到此状态码，则这是正确的状态码。但是，如果您有 robots.txt 文件而又看到此状态码，则说明您的 robots.txt 文件可能命名错误或位于错误的位置(该文件应当位于顶级域，名为 robots.txt)。"}]},{"ID":"20221027101052-8f09skh","Type":"NodeParagraph","Properties":{"id":"20221027101052-8f09skh","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"如果对于 Googlebot 抓取的网址看到此状态码(在\"诊断\"标签的 HTTP 错误页面上)，则表示 Googlebot 跟随的可能是另一个页面的无效链接(是旧链接或输入有误的链接)。"}]},{"ID":"20221027101052-jyhbxp1","Type":"NodeParagraph","Properties":{"id":"20221027101052-jyhbxp1","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"405(方法禁用)禁用请求中指定的方法。"}]},{"ID":"20221027101052-iz82b9n","Type":"NodeParagraph","Properties":{"id":"20221027101052-iz82b9n","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"406(不接受)无法使用请求的内容特性响应请求的网页。"}]},{"ID":"20221027101052-mmd1onk","Type":"NodeParagraph","Properties":{"id":"20221027101052-mmd1onk","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"407(需要代理授权)此状态码与 401(未授权)类似，但指定请求者应当授权使用代理。如果服务器返回此响应，还表示请求者应当使用代理。"}]},{"ID":"20221027101052-s0c8wkf","Type":"NodeParagraph","Properties":{"id":"20221027101052-s0c8wkf","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"408(请求超时)服务器等候请求时发生超时。"}]},{"ID":"20221027101052-rqf3o5z","Type":"NodeParagraph","Properties":{"id":"20221027101052-rqf3o5z","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"409(冲突)服务器在完成请求时发生冲突。服务器必须在响应中包含有关冲突的信息。服务器在响应与前一个请求相冲突的 PUT 请求时可能会返回此代码，以及两个请求的差异列表。"}]},{"ID":"20221027101052-t3yv768","Type":"NodeParagraph","Properties":{"id":"20221027101052-t3yv768","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"410(已删除)如果请求的资源已永久删除，服务器就会返回此响应。该代码与 404(未找到)代码类似，但在资源以前存在而现在不存在的情况下，有时会用来替代 404 代码。如果资源已永久移动，您应使用 301 指定资源的新位置。"}]},{"ID":"20221027101052-rgq7ljq","Type":"NodeParagraph","Properties":{"id":"20221027101052-rgq7ljq","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"411(需要有效长度)服务器不接受不含有效内容长度标头字段的请求。"}]},{"ID":"20221027101052-y9hzl06","Type":"NodeParagraph","Properties":{"id":"20221027101052-y9hzl06","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"412(未满足前提条件)服务器未满足请求者在请求中设置的其中一个前提条件。"}]},{"ID":"20221027101052-5dbnv6d","Type":"NodeParagraph","Properties":{"id":"20221027101052-5dbnv6d","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"413(请求实体过大)服务器无法处理请求，因为请求实体过大，超出服务器的处理能力。"}]},{"ID":"20221027101052-juxusrd","Type":"NodeParagraph","Properties":{"id":"20221027101052-juxusrd","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"414(请求的 URI 过长)请求的 URI(通常为网址)过长，服务器无法处理。"}]},{"ID":"20221027101052-h9l4773","Type":"NodeParagraph","Properties":{"id":"20221027101052-h9l4773","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"415(不支持的媒体类型)请求的格式不受请求页面的支持。"}]},{"ID":"20221027101052-5lxkx7z","Type":"NodeParagraph","Properties":{"id":"20221027101052-5lxkx7z","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"416(请求范围不符合要求)如果页面无法提供请求的范围，则服务器会返回此状态码。"}]},{"ID":"20221027101052-zhs9wsi","Type":"NodeParagraph","Properties":{"id":"20221027101052-zhs9wsi","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"417(未满足期望值)服务器未满足\"期望\"请求标头字段的要求。"}]},{"ID":"20221027101052-90pe7wy","Type":"NodeParagraph","Properties":{"id":"20221027101052-90pe7wy","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"二、5xx(服务器错误)\n这些状态码表示服务器在处理请求时发生内部错误。这些错误可能是服务器本身的错误，而不是请求出错。"}]},{"ID":"20221027101052-5cgcwcc","Type":"NodeParagraph","Properties":{"id":"20221027101052-5cgcwcc","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"500(服务器内部错误)服务器遇到错误，无法完成请求。"}]},{"ID":"20221027101052-i9rydsl","Type":"NodeParagraph","Properties":{"id":"20221027101052-i9rydsl","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"501(尚未实施)服务器不具备完成请求的功能。例如，服务器无法识别请求方法时可能会返回此代码。"}]},{"ID":"20221027101052-opa5oj7","Type":"NodeParagraph","Properties":{"id":"20221027101052-opa5oj7","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"502(错误网关)服务器作为网关或代理，从上游服务器收到无效响应。"}]},{"ID":"20221027101052-7th9evy","Type":"NodeParagraph","Properties":{"id":"20221027101052-7th9evy","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"503(服务不可用)服务器目前无法使用(由于超载或停机维护)。通常，这只是暂时状态。"}]},{"ID":"20221027101052-12d0187","Type":"NodeParagraph","Properties":{"id":"20221027101052-12d0187","updated":"20221027101052"},"Children":[{"Type":"NodeText","Data":"504(网关超时)服务器作为网关或代理，但是没有及时从上游服务器收到请求。"}]},{"ID":"20221027101052-74qlzy8","Type":"NodeParagraph","Properties":{"id":"20221027101052-74qlzy8","updated":"20221027101115"},"Children":[{"Type":"NodeText","Data":"505(HTTP 版本不受支持)服务器不支持请求中所用的 HTTP 协议版本。"}]}]},{"ID":"20221010152019-zul9l0j","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010152019-zul9l0j","updated":"20221010152021"},"Children":[{"Type":"NodeText","Data":"设计模式"}]},{"ID":"20221120144645-10amml8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221120144645-10amml8","updated":"20221120144650"},"Children":[{"Type":"NodeText","Data":"单例模式"}]},{"ID":"20221120144702-22m5cqs","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221120144702-22m5cqs","updated":"20221120144702"},"Children":[{"Type":"NodeText","Data":"单例模式的设计思想"}]},{"ID":"20221120152121-57jdjr9","Type":"NodeParagraph","Properties":{"id":"20221120152121-57jdjr9","updated":"20221120152122"},"Children":[{"Type":"NodeText","Data":"一个类只允许创建一个实例对象，并提供访问其唯一的对象的方式。"}]},{"ID":"20221120152127-mxa0w9n","Type":"NodeParagraph","Properties":{"id":"20221120152127-mxa0w9n","updated":"20221120152127"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"作用："}]},{"ID":"20221120152127-kkk9bv2","Type":"NodeParagraph","Properties":{"id":"20221120152127-kkk9bv2","updated":"20221120152312"},"Children":[{"Type":"NodeText","Data":"避免频繁创建和销毁系统全局使用的对象，有助于协调系统的整体性、统一性"}]},{"ID":"20221120152127-mr3o9e2","Type":"NodeParagraph","Properties":{"id":"20221120152127-mr3o9e2","updated":"20221120152127"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"单例模式的特点："}]},{"ID":"20221120152127-mp6umo6","Type":"NodeList","ListData":{},"Properties":{"id":"20221120152127-mp6umo6","updated":"20221120152127"},"Children":[{"ID":"20221120152127-4f0ugz3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-4f0ugz3","updated":"20221120152127"},"Children":[{"ID":"20221120152127-kkh811e","Type":"NodeParagraph","Properties":{"id":"20221120152127-kkh811e","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"单例类只能有一个实例"}]}]},{"ID":"20221120152127-94atmnm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-94atmnm","updated":"20221120152127"},"Children":[{"ID":"20221120152127-114vs83","Type":"NodeParagraph","Properties":{"id":"20221120152127-114vs83","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"单例类必须自己创建自己的唯一实例"}]}]},{"ID":"20221120152127-qybdhqa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-qybdhqa","updated":"20221120152127"},"Children":[{"ID":"20221120152127-hu49go6","Type":"NodeParagraph","Properties":{"id":"20221120152127-hu49go6","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"单例类必须给所有其他对象提供这一实例的访问"}]}]}]},{"ID":"20221120152127-xynqjlp","Type":"NodeParagraph","Properties":{"id":"20221120152127-xynqjlp","updated":"20221120152127"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"应用场景："}]},{"ID":"20221120152127-mn1jzah","Type":"NodeList","ListData":{},"Properties":{"id":"20221120152127-mn1jzah","updated":"20221120152127"},"Children":[{"ID":"20221120152127-znx5zq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-znx5zq3","updated":"20221120152127"},"Children":[{"ID":"20221120152127-cxypg0v","Type":"NodeParagraph","Properties":{"id":"20221120152127-cxypg0v","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"全局唯一类，如 系统配置类、系统硬件资源访问类"}]}]},{"ID":"20221120152127-246t3dn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-246t3dn","updated":"20221120152127"},"Children":[{"ID":"20221120152127-essreoh","Type":"NodeParagraph","Properties":{"id":"20221120152127-essreoh","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"序列号生成器"}]}]},{"ID":"20221120152127-6o6y5nh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20221120152127-6o6y5nh","updated":"20221120152127"},"Children":[{"ID":"20221120152127-2k0lhwy","Type":"NodeParagraph","Properties":{"id":"20221120152127-2k0lhwy","updated":"20221120152127"},"Children":[{"Type":"NodeText","Data":"Web 计数器"}]}]}]},{"ID":"20221120144727-25l21v9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221120144727-25l21v9","updated":"20221120144734"},"Children":[{"Type":"NodeText","Data":"懒汉"}]},{"ID":"20221120151332-f84k7un","Type":"NodeParagraph","Properties":{"id":"20221120151332-f84k7un","updated":"20221120151332"},"Children":[{"Type":"NodeText","Data":"​懒汉式比较懒，只有当被调用 getInstance() 方法时，才会去初始化这个单例。"}]},{"ID":"20221120144735-3c9wqat","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221120144735-3c9wqat","updated":"20221120151434"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/**\n * 懒汉模式\n * 双重检查 + 对类加锁 \n*/\npublic class singletonLazy {\n    private volatile static singletonLazy instance;\n    private singletonLazy(){}\n    public static singletonLazy getInstance(){\n        if(instance == null){\n                synchronized (singletonLazy.class){\n                    if(instance==null){\n                        instance = new singletonLazy();//只有当实例为空时才创建\n                    }\n                }\n        }\n        return instance;\n    }\n\n    public static void main(String[] args) {\n        singletonLazy instance1 = singletonLazy.getInstance();\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221120144735-qu2v2st","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221120144735-qu2v2st","updated":"20221120144738"},"Children":[{"Type":"NodeText","Data":"饿汉"}]},{"ID":"20221120151353-s8bx845","Type":"NodeParagraph","Properties":{"id":"20221120151353-s8bx845","updated":"20221120151354"},"Children":[{"Type":"NodeText","Data":"饿汉式是类一旦加载，就把单例初始化完成，保证 getInstance() 方法被调用时的时候，单例已经初始化完成，可以直接使用。"}]},{"ID":"20221120145034-hu87lko","Type":"NodeParagraph","Properties":{"id":"20221120145034-hu87lko","updated":"20221120145040"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"优点："},{"Type":"NodeText","Data":"从它的实现中我们可以看到，这种方式的实现比较简单，在类加载的时候就完成了实例化，避免了线程的同步问题。"}]},{"ID":"20221120145034-a0recwh","Type":"NodeParagraph","Properties":{"id":"20221120145034-a0recwh","updated":"20221120145039"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"缺点："},{"Type":"NodeText","Data":"由于在类加载的时候就实例化了，所以没有达到Lazy Loading(懒加载)的效果，也就是说可能我没有用到这个实例，但是它"}]},{"ID":"20221120145034-vs1i90h","Type":"NodeParagraph","Properties":{"id":"20221120145034-vs1i90h","updated":"20221120145042"},"Children":[{"Type":"NodeText","Data":"也会加载，会造成内存的浪费(但是这个浪费可以忽略，所以这种方式也是推荐使用的)。"}]},{"ID":"20221120144816-xlbnrtq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221120144816-xlbnrtq","updated":"20221120144840"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public class singletonHungry {\n    private static singletonHungry instance = new singletonHungry(); //不管你要不要都给你创建实例\n    private singletonHungry(){\n    }\n    public static singletonHungry getInstance(){\n        return instance;\n    }\n\n    public static void main(String[] args) {\n        singletonHungry instance1 = singletonHungry.getInstance();\n    }\n}\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221120144653-noy70d7","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221120144653-noy70d7","updated":"20221120144657"},"Children":[{"Type":"NodeText","Data":"工厂模式"}]},{"ID":"20221120152930-ai9vat3","Type":"NodeParagraph","Properties":{"id":"20221120152930-ai9vat3","updated":"20221120152936"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"简单工厂："},{"Type":"NodeText","Data":"不能算是真正意义上的设计模式，但可以将客户程序从具体类解耦。"}]},{"ID":"20221120152930-l5v70fb","Type":"NodeParagraph","Properties":{"id":"20221120152930-l5v70fb","updated":"20221120152935"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"工厂方法："},{"Type":"NodeText","Data":"使用继承，把对象的创建委托给子类，由子类来实现创建方法，可以看作是抽象工厂模式中只有单一产品的情况。"}]},{"ID":"20221120152930-mfc6yb0","Type":"NodeParagraph","Properties":{"id":"20221120152930-mfc6yb0","updated":"20221120152933"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"抽象工厂："},{"Type":"NodeText","Data":"使对象的创建被实现在工厂接口所暴露出来的方法中。"}]},{"ID":"20221120153049-bm7nwf6","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221120153049-bm7nwf6","updated":"20221120153050"},"Children":[{"Type":"NodeText","Data":"案例"}]},{"ID":"20221120153053-4cigvz6","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221120153053-4cigvz6","updated":"20221120153103"},"Children":[{"Type":"NodeText","Data":"公共类"}]},{"ID":"20221120153106-kdcq4l6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221120153106-kdcq4l6","updated":"20221120153108"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public abstract class Coffee {\n\n    /**\n     * 获取coffee名称\n     * @return\n     */\n    public abstract String getName();\n  \n}\n\n\n/**\n * 美式咖啡\n * @author Lsj\n *\n */\npublic class Americano extends Coffee {\n\n    @Override\n    public String getName() {\n        return \"美式咖啡\";\n    }\n\n}\n\n\n/**\n * 卡布奇诺\n * @author Lsj\n *\n */\npublic class Cappuccino extends Coffee {\n\n    @Override\n    public String getName() {\n        return \"卡布奇诺\";\n    }\n\n}\n\n\n/**\n * 拿铁\n * @author Lsj\n *\n */\npublic class Latte extends Coffee {\n\n    @Override\n    public String getName() {\n        return \"拿铁\";\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221119183204-y2fvhcj","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221119183204-y2fvhcj","updated":"20221119183208"},"Children":[{"Type":"NodeText","Data":"简单工厂模式"}]},{"ID":"20221120153310-pqe78sn","Type":"NodeParagraph","Properties":{"id":"20221120153310-pqe78sn","updated":"20221120153310"},"Children":[{"Type":"NodeText","Data":"简单工厂实际不能算作一种设计模式，它引入了创建者的概念，将实例化的代码从应用代码中抽离，在创建者类的静态方法中只处理创建对象的细节，后续创建的实例如需改变，只需改造创建者类即可，但由于使用静态方法来获取对象，使其不能在运行期间通过不同方式去动态改变创建行为，因此存在一定局限性。"}]},{"ID":"20221119183210-2yi0t5w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221119183210-2yi0t5w","updated":"20221120153128"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"/**\n * 简单工厂模式(静态工厂方法)\n *\n * 优点：创建交给工厂负责，客户端程序员不关心怎么创建，只关心怎么使用\n * 缺点：如果要新增产品就要修改工厂类\n */\n\npublic class SimpleFactory {\n  \n    /**\n     * 通过类型获取Coffee实例对象\n     * @param type 咖啡类型\n     * @return\n     */\n    public static Coffee createInstance(String type){\n        if(\"americano\".equals(type)){\n            return new Americano();\n        }else if(\"cappuccino\".equals(type)){\n            return new Cappuccino();\n        }else if(\"latte\".equals(type)){\n            return new Latte();\n        }else{\n            throw new RuntimeException(\"type[\"+type+\"]类型不可识别，没有匹配到可实例化的对象！\");\n        }\n    }\n  \n    public static void main(String[] args) {\n        Coffee latte = SimpleFactory.createInstance(\"latte\");\n        System.out.println(\"创建的咖啡实例为:\" + latte.getName());\n        Coffee cappuccino = SimpleFactory.createInstance(\"cappuccino\");\n        System.out.println(\"创建的咖啡实例为:\" + cappuccino.getName());\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221119185238-miqp89s","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221119185238-miqp89s","updated":"20221120153331"},"Children":[{"Type":"NodeText","Data":"工厂方法模式​"}]},{"ID":"20221120153303-56jsuy1","Type":"NodeParagraph","Properties":{"id":"20221120153303-56jsuy1","updated":"20221120153303"},"Children":[{"Type":"NodeText","Data":"定义了一个创建对象的接口，但由子类决定要实例化的类是哪一个，工厂方法让类把实例化推迟到了子类。"}]},{"ID":"20221120153303-6ztetv9","Type":"NodeParagraph","Properties":{"id":"20221120153303-6ztetv9","updated":"20221120153303"},"Children":[{"Type":"NodeText","Data":"场景延伸：不同地区咖啡工厂受制于环境、原料等因素的影响，制造出的咖啡种类有限。中国咖啡工厂仅能制造卡布奇诺、拿铁，而美国咖啡工厂仅能制造美式咖啡、拿铁。"}]},{"ID":"20221120153152-dr4js4w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221120153152-dr4js4w","updated":"20221120153159"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public abstract class CoffeeFactory {\n  \n    /**\n     * 生产可制造的咖啡\n     * @return\n     */\n    public abstract Coffee[] createCoffee();\n\n}\n\n\n/**\n * 中国咖啡工厂\n * @author Lsj\n *\n */\npublic class ChinaCoffeeFactory extends CoffeeFactory {\n\n    @Override\n    public Coffee[] createCoffee() {\n        // TODO Auto-generated method stub\n        return new Coffee[]{new Cappuccino(), new Latte()};\n    }\n\n}\n\n\n/**\n * 美国咖啡工厂\n * @author Lsj\n *\n */\npublic class AmericaCoffeeFactory extends CoffeeFactory {\n\n    @Override\n    public Coffee[] createCoffee() {\n        // TODO Auto-generated method stub\n        return new Coffee[]{new Americano(), new Latte()};\n    }\n\n}\n\n\n/**\n * 工厂方法测试\n * @author Lsj\n *\n */\npublic class FactoryMethodTest {\n\n    static void print(Coffee[] c){\n        for (Coffee coffee : c) {\n            System.out.println(coffee.getName());\n        }\n    }\n  \n    public static void main(String[] args) {\n        CoffeeFactory chinaCoffeeFactory = new ChinaCoffeeFactory();\n        Coffee[] chinaCoffees = chinaCoffeeFactory.createCoffee();\n        System.out.println(\"中国咖啡工厂可以生产的咖啡有：\");\n        print(chinaCoffees);\n        CoffeeFactory americaCoffeeFactory = new AmericaCoffeeFactory();\n        Coffee[] americaCoffees = americaCoffeeFactory.createCoffee();\n        System.out.println(\"美国咖啡工厂可以生产的咖啡有：\");\n        print(americaCoffees);\n    }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221120153204-35isjlj","Type":"NodeParagraph","Properties":{"id":"20221120153204-35isjlj","updated":"20221120153206"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221120153206-d1ay0gr.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221119185245-mfdqkrr","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20221119185245-mfdqkrr","updated":"20221119185503"},"Children":[{"Type":"NodeText","Data":"抽象工厂模式"}]},{"ID":"20221120153256-6rxqkaa","Type":"NodeParagraph","Properties":{"id":"20221120153256-6rxqkaa","updated":"20221120153256"},"Children":[{"Type":"NodeText","Data":"提供一个接口，用于创建相关或依赖对象的家族，而不需要明确指定具体类。"}]},{"ID":"20221120153256-yuwg8nc","Type":"NodeParagraph","Properties":{"id":"20221120153256-yuwg8nc","updated":"20221120153256"},"Children":[{"Type":"NodeText","Data":"在上述的场景上继续延伸：咖啡工厂做大做强，引入了新的饮品种类：茶、 碳酸饮料。中国工厂只能制造咖啡和茶，美国工厂只能制造咖啡和碳酸饮料。"}]},{"ID":"20221120153256-09cmlcw","Type":"NodeParagraph","Properties":{"id":"20221120153256-09cmlcw","updated":"20221120153256"},"Children":[{"Type":"NodeText","Data":"如果用上述工厂方法方式，除去对应的产品实体类还需要新增2个抽象工厂（茶制造工厂、碳酸饮料制造工厂），4个具体工厂实现。随着产品的增多，会导致类爆炸。"}]},{"ID":"20221120153256-fbey49z","Type":"NodeParagraph","Properties":{"id":"20221120153256-fbey49z","updated":"20221120153256"},"Children":[{"Type":"NodeText","Data":"所以这里引出一个概念产品家族，在此例子中，不同的饮品就组成我们的饮品家族， 饮品家族开始承担创建者的责任，负责制造不同的产品。"}]},{"ID":"20221119185249-57ds9k1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221119185249-57ds9k1","updated":"20221120153220"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"/**\n * 抽象的饮料产品家族制造工厂\n * @author Lsj\n *\n */\npublic interface AbstractDrinksFactory {\n\n    /**\n     * 制造咖啡\n     * @return\n     */\n    Coffee createCoffee();\n  \n    /**\n     * 制造茶\n     * @return\n     */\n    Tea createTea();\n  \n    /**\n     * 制造碳酸饮料\n     * @return\n     */\n    Sodas createSodas();\n}\n\n\n/**\n * 中国饮品工厂\n * 制造咖啡与茶\n * @author Lsj\n *\n */\npublic class ChinaDrinksFactory implements AbstractDrinksFactory {\n\n    @Override\n    public Coffee createCoffee() {\n        // TODO Auto-generated method stub\n        return new Latte();\n    }\n\n    @Override\n    public Tea createTea() {\n        // TODO Auto-generated method stub\n        return new MilkTea();\n    }\n\n    @Override\n    public Sodas createSodas() {\n        // TODO Auto-generated method stub\n        return null;\n    }\n\n}\n\n\n/**\n * 美国饮品制造工厂\n * 制造咖啡和碳酸饮料\n * @author Lsj\n *\n */\npublic class AmericaDrinksFactory implements AbstractDrinksFactory {\n\n    @Override\n    public Coffee createCoffee() {\n        // TODO Auto-generated method stub\n        return new Latte();\n    }\n\n    @Override\n    public Tea createTea() {\n        // TODO Auto-generated method stub\n        return null;\n    }\n\n    @Override\n    public Sodas createSodas() {\n        // TODO Auto-generated method stub\n        return new CocaCola();\n    }\n\n}\n\n\n/**\n * 抽象工厂测试类\n * @author Lsj\n *\n */\npublic class AbstractFactoryTest {\n  \n    static void print(Drink drink){\n        if(drink == null){\n            System.out.println(\"产品：--\" );\n        }else{\n            System.out.println(\"产品：\" + drink.getName());\n        }\n    }\n  \n    public static void main(String[] args) {\n        AbstractDrinksFactory chinaDrinksFactory = new ChinaDrinksFactory();\n        Coffee coffee = chinaDrinksFactory.createCoffee();\n        Tea tea = chinaDrinksFactory.createTea();\n        Sodas sodas = chinaDrinksFactory.createSodas();\n        System.out.println(\"中国饮品工厂有如下产品：\");\n        print(coffee);\n        print(tea);\n        print(sodas);\n      \n        AbstractDrinksFactory americaDrinksFactory = new AmericaDrinksFactory();\n        coffee = americaDrinksFactory.createCoffee();\n        tea = americaDrinksFactory.createTea();\n        sodas = americaDrinksFactory.createSodas();\n        System.out.println(\"美国饮品工厂有如下产品：\");\n        print(coffee);\n        print(tea);\n        print(sodas);\n    }\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221120153205-w91eewo","Type":"NodeParagraph","Properties":{"id":"20221120153205-w91eewo","updated":"20221120153242"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221120153242-g4nn0n1.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221008152033-1tm1ee8","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221008152033-1tm1ee8","updated":"20221010114740"},"Children":[{"Type":"NodeText","Data":"分布式"}]},{"ID":"20221010145855-d4dqywl","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221010145855-d4dqywl","updated":"20221011135238"},"Children":[{"Type":"NodeText","Data":"JVM"}]},{"ID":"20221118191707-kdd40zk","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221118191707-kdd40zk","updated":"20221118191713"},"Children":[{"Type":"NodeText","Data":"嵌入式"}]},{"ID":"20221121131602-6rdpnl3","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221121131602-6rdpnl3","updated":"20221121131611"},"Children":[{"Type":"NodeText","Data":"L298N电机"}]},{"ID":"20221121131752-vlissjp","Type":"NodeParagraph","Properties":{"id":"20221121131752-vlissjp","updated":"20221121131800"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121131752-o7i77bm.png"},{"Type":"NodeCloseParen"}]},{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121131800-jrypfx5.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221121131611-jad8l24","Type":"NodeParagraph","Properties":{"id":"20221121131611-jad8l24","updated":"20221121131617"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121131617-jho2g8d.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221121110248-bg7dj47","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221121110248-bg7dj47","updated":"20221121110254"},"Children":[{"Type":"NodeText","Data":"电容的单位"}]},{"ID":"20221121110255-tw4wgco","Type":"NodeParagraph","Properties":{"id":"20221121110255-tw4wgco","updated":"20221121110311"},"Children":[{"Type":"NodeText","Data":"电容的单位是法（F），也常用微法（uF）或者 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"微微法"},{"Type":"NodeText","Data":" （pF）做单位。 1F=106uF，1F=1012pF。"}]},{"ID":"20221118191727-7gk9it8","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118191727-7gk9it8","updated":"20221118191735"},"Children":[{"Type":"NodeText","Data":"芯片功率"}]},{"ID":"20221118191735-d4jc8v6","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118191735-d4jc8v6","updated":"20221118191750"},"Children":[{"Type":"NodeText","Data":"芯片牌子"}]},{"ID":"20221118191751-iypos67","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118191751-iypos67","updated":"20221118191806"},"Children":[{"Type":"NodeText","Data":"51单片机的最小系统"}]},{"ID":"20221121104609-eksq5f0","Type":"NodeParagraph","Properties":{"id":"20221121104609-eksq5f0","updated":"20221121105243"},"Children":[{"Type":"NodeText","Data":"复位电路、晶振（时钟）电路、电源"}]},{"ID":"20221121105441-fpyjjpv","Type":"NodeParagraph","Properties":{"id":"20221121105441-fpyjjpv","updated":"20221121105441"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121105441-p7a26lm.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221121110753-6l1tt77","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121110753-6l1tt77","updated":"20221121110813"},"Children":[{"Type":"NodeText","Data":"2.1.电源"}]},{"ID":"20221121110814-b5lzjne","Type":"NodeParagraph","Properties":{"id":"20221121110814-b5lzjne"},"Children":[{"Type":"NodeText","Data":"任何电子设备都需要供电，目前主流单片机的电源分别为5V和3.3V这两个标准。"}]},{"ID":"20221121110753-xs7g6pe","Type":"NodeParagraph","Properties":{"id":"20221121110753-xs7g6pe","updated":"20221121110753"},"Children":[{"Type":"NodeText","Data":"选用STC89C52，它需要5V的供电系统，上图是使用USB口输出的5V直流直接供电的，从图中可以看出，供电电路在40引脚和20引脚的位置上，40引脚接的是+5V，通常也称为VCC或VDD，代表电源正极，20引脚接GND，代表电源负极。"}]},{"ID":"20221121110753-d5vguoi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121110753-d5vguoi","updated":"20221121110817"},"Children":[{"Type":"NodeText","Data":"2.2.晶振"}]},{"ID":"20221121110817-6jea1z3","Type":"NodeParagraph","Properties":{"id":"20221121110817-6jea1z3"},"Children":[{"Type":"NodeText","Data":"晶振，又叫晶体振荡器，从这个名字上就可以看出，它注定一生都要不停的振荡。它起到的作用是为单片机系统提供基准时钟信号，类似于部队训练喊口号的人，单片机内部所有的工作都是以这个时钟信号为步调基准来进行工作的，可以说晶振就是单片机的“心脏”。STC89C52单片机的18引脚和19引脚是晶振引脚，上图接了一个11.0592MHz的晶振（即每秒振荡11059200次），外加两个30pF的电容，电容的作用是帮助晶振起振，并维持振荡信号的稳定。"}]},{"ID":"20221121110753-6gf3q8d","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121110753-6gf3q8d","updated":"20221121110821"},"Children":[{"Type":"NodeText","Data":"2.3.复位电路"}]},{"ID":"20221121110822-c9nvcsh","Type":"NodeParagraph","Properties":{"id":"20221121110822-c9nvcsh"},"Children":[{"Type":"NodeText","Data":"单片机的复位一般分为四种：外部RST复位，软件复位，掉电复位/上电复位，看门狗复位。"}]},{"ID":"20221118191806-9ffi24d","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118191806-9ffi24d","updated":"20221118191811"},"Children":[{"Type":"NodeText","Data":"晶振的频率"}]},{"ID":"20221121104755-e20qfmk","Type":"NodeParagraph","Properties":{"id":"20221121104755-e20qfmk","updated":"20221121104755"},"Children":[{"Type":"NodeText","Data":"12M和11.0592M"}]},{"ID":"20221121121946-wz1zo4p","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221121121946-wz1zo4p","updated":"20221121121953"},"Children":[{"Type":"NodeText","Data":"为什么都选择11.0592"}]},{"ID":"20221121121954-zs8wqpe","Type":"NodeParagraph","Properties":{"id":"20221121121954-zs8wqpe","updated":"20221121121956"},"Children":[{"Type":"NodeText","Data":"标准的51单片机晶振是1.2M-12M，一般由于一个机器周期是12个时钟周期，所以先12M时，一个机器周期是1US，好计算，而且速度相对是最高的（当然现在也有更高频率的单片机）。\n11.0592M是因为在进行通信时，12M频率进行串行通信不容易实现标准的波特率，比如9600，4800，而11.0592M计算时正好可以得到，因此在有通信接口的单片机中，一般选11.0592M"}]},{"ID":"20221121122142-unrnxn5","Type":"NodeParagraph","Properties":{"id":"20221121122142-unrnxn5","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"1个机器周期 = 6个状态周期；"}]},{"ID":"20221121122142-w1t0am2","Type":"NodeParagraph","Properties":{"id":"20221121122142-w1t0am2","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"1个状态周期 = 2个震荡周期；"}]},{"ID":"20221121122142-yf1c5tp","Type":"NodeParagraph","Properties":{"id":"20221121122142-yf1c5tp","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"1个机器周期 = 12 个震荡周期"}]},{"ID":"20221121122142-xcm6ppq","Type":"NodeParagraph","Properties":{"id":"20221121122142-xcm6ppq","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"1M Hz = 1000 000 次震荡／秒（1000 000 次／s）"}]},{"ID":"20221121122142-rrtetui","Type":"NodeParagraph","Properties":{"id":"20221121122142-rrtetui","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"那么一个机器周期所需要的时间为："}]},{"ID":"20221121122142-ntlz6ji","Type":"NodeParagraph","Properties":{"id":"20221121122142-ntlz6ji","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"如果震荡周期为12M"}]},{"ID":"20221121122142-5u6evqa","Type":"NodeParagraph","Properties":{"id":"20221121122142-5u6evqa","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"1个机器时间的周期 = 12次震荡／震荡频率 = 12 ／（12M hz）= 12 / (12 * 1000 1000/s) = 1 s /1000 1000 = 1us(一微秒)"}]},{"ID":"20221121122142-s73ako3","Type":"NodeParagraph","Properties":{"id":"20221121122142-s73ako3","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"如果为11.0592M那么除不尽。"}]},{"ID":"20221121122142-usr5r7m","Type":"NodeParagraph","Properties":{"id":"20221121122142-usr5r7m","updated":"20221121122142"},"Children":[{"Type":"NodeText","Data":"所以使用定时器延迟的时候 12M晶振最为合适，延时计时更佳准确。"}]},{"ID":"20221121122142-iakvaah","Type":"NodeParagraph","Properties":{"id":"20221121122142-iakvaah","updated":"20221121122200"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"但是12M晶振不好实现9600 4800的波特率，而很多串口通讯都要求这个波特率。11.0592M晶振就可以完美实现。所以在串口通信过程中，使用11.0592M晶振。"}]},{"ID":"20221118192145-hdb3j43","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192145-hdb3j43","updated":"20221118192152"},"Children":[{"Type":"NodeText","Data":"怎么处理pwm波的"}]},{"ID":"20221118192153-najbrxa","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192153-najbrxa","updated":"20221118192200"},"Children":[{"Type":"NodeText","Data":"引脚怎么通信的"}]},{"ID":"20221118192201-0q423qd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192201-0q423qd","updated":"20221118192305"},"Children":[{"Type":"NodeText","Data":"mos"}]},{"ID":"20221121124456-qd9auo5","Type":"NodeParagraph","Properties":{"id":"20221121124456-qd9auo5","updated":"20221121124456"},"Children":[{"Type":"NodeText","Data":"MOS 场效应管也被称为MOS FET， 既Metal Oxide Semiconductor Field Effect Transistor（金属氧化物半导体场效应管）的缩写。它一般有耗尽型和增强型两种。这里我们以增强型MOS为例分析。"}]},{"ID":"20221121124854-dpz9xn4","Type":"NodeParagraph","Properties":{"id":"20221121124854-dpz9xn4","updated":"20221121124855"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121124855-hcheonq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221121124900-pc0uvtw","Type":"NodeParagraph","Properties":{"id":"20221121124900-pc0uvtw","updated":"20221121124900"},"Children":[{"Type":"NodeText","Data":"场效应管是由源极，漏极，栅极组成，由于衬底的掺杂不同可分为N沟道和P沟道场效应管。（沟道：顾名思义就是在衬底上挖两个可填充沟道，填充N型或者P型半导体）"}]},{"ID":"20221121124905-u8uyqsl","Type":"NodeParagraph","Properties":{"id":"20221121124905-u8uyqsl","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"我们将漏极接到电源正极，源极接到电源负极。"}]},{"ID":"20221121124905-llw6jr0","Type":"NodeParagraph","Properties":{"id":"20221121124905-llw6jr0","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"对于场效应管，在栅极没有电压时，源极和漏极之间相当于两个背靠背的二极管，不会有电流流过，此时场效应管处与截止状态。"}]},{"ID":"20221121124905-ers89a4","Type":"NodeParagraph","Properties":{"id":"20221121124905-ers89a4","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"如上面右图所示，当在栅极加上电压时，当电压小于一个阈值VGS(th)时，栅极和衬底P之间会由于电场的作用，将P型半导体中的空穴推开，此时N型半导体的源极和漏极的负电子被吸引出来而涌向栅极，但由于氧化膜的阻挡，使得电子聚集在两个N沟道之间的P型半导体中。"}]},{"ID":"20221121124905-6dvizsm","Type":"NodeParagraph","Properties":{"id":"20221121124905-6dvizsm","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"随着栅极电压的增大，栅极附近的电子浓度会增加。当超过一个阈值VGS(th)时，在源极和漏极之间的N型半导体会形成一个电子沟道。同时此时由于漏极加有正电压，就可以形成漏极到源极的电流，MOS管导通。"}]},{"ID":"20221121124905-cw5yfbm","Type":"NodeParagraph","Properties":{"id":"20221121124905-cw5yfbm","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"我们也可以想像为两个N型半导体之间为一条沟，栅极电压的建立相当于为它们之间搭了一座桥梁，该桥的大小由栅压的大小决定。这也是为什么说MOS管是电压控制性晶体管的原因。"}]},{"ID":"20221121124905-gi92zae","Type":"NodeParagraph","Properties":{"id":"20221121124905-gi92zae","updated":"20221121124905"},"Children":[{"Type":"NodeText","Data":"我们可以将MOS管想象成一个阀门，栅极就像开关可以控制水流是否可以通过。"}]},{"ID":"20221118192310-hrxy7xw","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192310-hrxy7xw","updated":"20221118192323"},"Children":[{"Type":"NodeText","Data":"三极管什么时候导通"}]},{"ID":"20221121125502-e4xv9ya","Type":"NodeParagraph","Properties":{"id":"20221121125502-e4xv9ya","updated":"20221121125502"},"Children":[{"Type":"NodeText","Data":"三极管有两种类型和三种工作状态。两种类型：NPN型和PNP型，三种工作状态：截止状态、放大状态和饱和状态。"}]},{"ID":"20221121125507-dw5yqee","Type":"NodeParagraph","Properties":{"id":"20221121125507-dw5yqee","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"1、NPN型三极管导通条件"}]},{"ID":"20221121125507-0j35esz","Type":"NodeParagraph","Properties":{"id":"20221121125507-0j35esz","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"截止状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026lt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003c U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003c 0且U ~BC ~ \u003c 0）"}]},{"ID":"20221121125507-sc7fasf","Type":"NodeParagraph","Properties":{"id":"20221121125507-sc7fasf","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"放大状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026gt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003c U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003e 0且U ~BC ~ \u003c 0）"}]},{"ID":"20221121125507-ldszsz5","Type":"NodeParagraph","Properties":{"id":"20221121125507-ldszsz5","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"饱和状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026gt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003e U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003e 0且U ~BC ~ \u003e 0）"}]},{"ID":"20221121125507-576y3mc","Type":"NodeParagraph","Properties":{"id":"20221121125507-576y3mc","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"2、PNP型三极管导通条件"}]},{"ID":"20221121125507-pwge0g5","Type":"NodeParagraph","Properties":{"id":"20221121125507-pwge0g5","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"截止状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026gt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003e U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003e 0且U ~BC ~ \u003e 0）"}]},{"ID":"20221121125507-fl31ix1","Type":"NodeParagraph","Properties":{"id":"20221121125507-fl31ix1","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"放大状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026lt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003e U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003c 0且U ~BC ~ \u003e 0）"}]},{"ID":"20221121125507-vxfht0z","Type":"NodeParagraph","Properties":{"id":"20221121125507-vxfht0z","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"饱和状态：U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"B ~ \u0026lt; U"},{"Type":"NodeText","Data":"E~且U ~B ~ \u003c U "},{"Type":"NodeTextMark","TextMarkType":"sub","TextMarkTextContent":"C"},{"Type":"NodeText","Data":" （或者U ~BE ~ \u003c 0且U ~BC ~ \u003c 0）"}]},{"ID":"20221121125507-7urj252","Type":"NodeParagraph","Properties":{"id":"20221121125507-7urj252","updated":"20221121125507"},"Children":[{"Type":"NodeText","Data":"（备注：三极管的导通与截止，其实质是其内部PN结的单向导通与截止。）"}]},{"ID":"20221121125511-ma4585u","Type":"NodeParagraph","Properties":{"id":"20221121125511-ma4585u","updated":"20221121125512"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221121125511-8xtbph0.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221118192324-vsnrtxn","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192324-vsnrtxn","updated":"20221118192359"},"Children":[{"Type":"NodeText","Data":"放大元器件？"}]},{"ID":"20221118192704-u1iywtq","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221118192704-u1iywtq","updated":"20221118192707"},"Children":[{"Type":"NodeText","Data":"场效应管"}]},{"ID":"20221121123010-767cwmi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121123010-767cwmi","updated":"20221121123014"},"Children":[{"Type":"NodeText","Data":"优点"}]},{"ID":"20221121123016-49dlzsh","Type":"NodeParagraph","Properties":{"id":"20221121123016-49dlzsh","updated":"20221121123016"},"Children":[{"Type":"NodeText","Data":"1.相较于三极管，场效应管成本低、工艺简单"}]},{"ID":"20221121123016-jgl0j0m","Type":"NodeParagraph","Properties":{"id":"20221121123016-jgl0j0m","updated":"20221121123016"},"Children":[{"Type":"NodeText","Data":"2.场效应管仅依靠多子的漂流运动形成电流"}]},{"ID":"20221121123016-jp9iph7","Type":"NodeParagraph","Properties":{"id":"20221121123016-jp9iph7","updated":"20221121123016"},"Children":[{"Type":"NodeText","Data":"3.场效应管输入阻抗高、噪声低、热稳定性好"}]},{"ID":"20221121122941-knsbut7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121122941-knsbut7","updated":"20221121122943"},"Children":[{"Type":"NodeText","Data":"作用"}]},{"ID":"20221121122856-0mfm7mc","Type":"NodeParagraph","Properties":{"id":"20221121122856-0mfm7mc","updated":"20221121122856"},"Children":[{"Type":"NodeText","Data":"一、场效应管可应用于放大。由于场效应管放大器的输入阻抗很高，因此耦合电容可以容量较小，不必使用电解电容器。"}]},{"ID":"20221121122856-pfic2in","Type":"NodeParagraph","Properties":{"id":"20221121122856-pfic2in","updated":"20221121122856"},"Children":[{"Type":"NodeText","Data":"二、场效应管很高的输入阻抗非常适合作阻抗变换。常用于多级放大器的输入级作阻抗变换。"}]},{"ID":"20221121122856-7t0b8aw","Type":"NodeParagraph","Properties":{"id":"20221121122856-7t0b8aw","updated":"20221121122856"},"Children":[{"Type":"NodeText","Data":"三、场效应管可以用作可变电阻。"}]},{"ID":"20221121122856-qx4h51c","Type":"NodeParagraph","Properties":{"id":"20221121122856-qx4h51c","updated":"20221121122856"},"Children":[{"Type":"NodeText","Data":"四、场效应管可以方便地用作恒流源。"}]},{"ID":"20221121122856-4t26sb9","Type":"NodeParagraph","Properties":{"id":"20221121122856-4t26sb9","updated":"20221121122856"},"Children":[{"Type":"NodeText","Data":"五、场效应管可以用作电子开关。"}]},{"ID":"20221121122937-9wd5pft","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221121122937-9wd5pft","updated":"20221121122937"},"Children":[{"Type":"NodeTextMark","TextMarkType":"a strong","TextMarkAHref":"http://www.kiaic.com/page/gongyelingyu","TextMarkTextContent":"场效应管应用领域"}]},{"ID":"20221121122937-6uhmzy1","Type":"NodeParagraph","Properties":{"id":"20221121122937-6uhmzy1","updated":"20221121122937"},"Children":[{"Type":"NodeText","Data":"1：工业领域、步进马达驱动、 电钻工具、工业开关电源"}]},{"ID":"20221121122937-bhjnb4z","Type":"NodeParagraph","Properties":{"id":"20221121122937-bhjnb4z","updated":"20221121122937"},"Children":[{"Type":"NodeText","Data":"2：新能源领域、光伏逆变、充电桩、无人机"}]},{"ID":"20221121122937-3mwrfyr","Type":"NodeParagraph","Properties":{"id":"20221121122937-3mwrfyr","updated":"20221121122937"},"Children":[{"Type":"NodeText","Data":"3：交通运输领域、车载逆变器、汽车HID安定器、电动自行车"}]},{"ID":"20221121122937-fle5f73","Type":"NodeParagraph","Properties":{"id":"20221121122937-fle5f73","updated":"20221121122937"},"Children":[{"Type":"NodeText","Data":"4：绿色照明领域、CCFL节能灯、LED照明电源、金卤灯镇流器"}]},{"ID":"20221121104109-roo6z4s","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221121104109-roo6z4s","updated":"20221121104120"},"Children":[{"Type":"NodeText","Data":"树莓派引脚口数量"}]},{"ID":"20221118192707-o6fqhdy","Type":"NodeParagraph","Properties":{"id":"20221118192707-o6fqhdy"}},{"ID":"20221019145410-f6z67sy","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20221019145410-f6z67sy","updated":"20221019145413"},"Children":[{"Type":"NodeText","Data":"银行面试"}]},{"ID":"20221025135135-tkmdnlh","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025135135-tkmdnlh","updated":"20221025135139"},"Children":[{"Type":"NodeText","Data":"自我介绍"}]},{"ID":"20221025135140-ylc1euy","Type":"NodeBlockquote","Properties":{"id":"20221025135140-ylc1euy","updated":"20221028125521"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135142-jh2o7k4","Type":"NodeParagraph","Properties":{"id":"20221025135142-jh2o7k4","updated":"20221031131734"},"Children":[{"Type":"NodeText","Data":"各位面试官下午好，非常感谢能给我这次复试的机会，我叫夏天豪，来自江苏苏州。研究生就读于沈阳化工大学电子信息专业，目前在中国科学院沈阳自动化研究所进行联合培养。"}]},{"ID":"20221025135223-snyl1n5","Type":"NodeParagraph","Properties":{"id":"20221025135223-snyl1n5","updated":"20221027092455"},"Children":[{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"本科期间担任校器乐社社长，组织过校元旦晚会和社团巡演，负责统筹设计、创意安排、节目编排、后勤保障的全流程事项统筹"}]},{"ID":"20221031131051-4uzr7e1","Type":"NodeParagraph","Properties":{"id":"20221031131051-4uzr7e1","updated":"20221031132041"},"Children":[{"Type":"NodeText","Data":"我应聘的岗位是后端开发工程师，投递该岗位是因为我个人对后端很感兴趣，并且在读研期间的技术沉淀也让我明白自己更适合编程工作。我了解了公司的业务场景，未来城市化的复杂性依然离不开gis的应用，那后端技术的需求也是至关重要的，如果能在贵司工作我相信能接触到很多核心的技术，对自己能力会有更大的提升，会有很好的发展前景。"}]},{"ID":"20221031131731-vd6vo9m","Type":"NodeParagraph","Properties":{"id":"20221031131731-vd6vo9m","updated":"20221031132131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"我的研究方向是边缘计算，"},{"Type":"NodeText","Data":"读研期间我积极参与了各类科研竞赛并收获了优异成绩，获得过校级奖学金，同时被评为中科院优秀研究生，"}]},{"ID":"20221027092805-ngqdgfe","Type":"NodeParagraph","Properties":{"id":"20221027092805-ngqdgfe","updated":"20221031124948"},"Children":[{"Type":"NodeText","Data":"项目方面，Java项目方面完成一个关于宿舍百货的售卖系统，前端使用到的技术栈有H5、VUE、element实现页面展示，主要提给用户浏览商品、下单购物、保存个人信息，后端使用的技术有Springboot、MySQL、MybatisPlus实现对后台数据的增删改查，并且使用Redis对货物信息和验证短信进行缓存，主要提供给管理人员使用，包括对人员信息的管理、商品信息的维护。"}]},{"ID":"20221025191935-509mmrr","Type":"NodeParagraph","Properties":{"id":"20221025191935-509mmrr","updated":"20221031132311"},"Children":[{"Type":"NodeText","Data":"经手的国家重点研发项目有：工业互联网边缘计算运行关键技术，主要研究的是大规模任务并发的同时如何保证系统的响应时间，主要是使用KubeEdge搭建云边平台，采用深度强化学习DQN方法分析云端任务算力资源需求，结合调度算法生成调度开销表，并"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"基于测试要求"},{"Type":"NodeText","Data":"使用Python的Tkinter设计了资源管理软件和任务调度软件"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"，包含异构边缘节点网络状态自主评估功能、容器可自适应调整功能、异构节点联合量化功能、任务调度功能；其中联合量化方法正确性误差率不高于2.62%，成功率高于99.37%、大规模任务实时性调度开销时间可保证在10ms以内，"},{"Type":"NodeText","Data":"以上内容均已通过国家CNAS认证，并由我单独完成了"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"PPT的"},{"Type":"NodeText","Data":"结题汇报。基于上述内容发表了一篇北大核心、一篇一区SCI在修、两项发明专利、一项软件著作权，并将项目内容参与了中国移动举办的算力网络应用创新大赛获得赛区二等奖。"}]},{"ID":"20221025222658-twkbzmf","Type":"NodeParagraph","Properties":{"id":"20221025222658-twkbzmf","updated":"20221028125521"},"Children":[{"Type":"NodeText","Data":"我的核心竞争力是适应能力特别强，"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"也特别能熬夜，"},{"Type":"NodeText","Data":"同时我的"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"英语口语能力比较好、"},{"Type":"NodeText","Data":"PPT做的（比较好）"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"也很好"},{"Type":"NodeText","Data":"。对待任务我的原则是bug和我必须有一个被解决！"}]}]},{"ID":"20221031140727-01k9bya","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031140727-01k9bya","updated":"20221031140739"},"Children":[{"Type":"NodeText","Data":"工作中难以和同事相处怎么办"}]},{"ID":"20221031140741-4phjay5","Type":"NodeParagraph","Properties":{"id":"20221031140741-4phjay5","updated":"20221031140742"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221031140742-ki9bamv.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221031141700-sl93yh2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031141700-sl93yh2","updated":"20221031141713"},"Children":[{"Type":"NodeText","Data":"你希望与什么样的上司共事"}]},{"ID":"20221031141714-dshna0g","Type":"NodeParagraph","Properties":{"id":"20221031141714-dshna0g","updated":"20221031141715"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221031141715-p9gr78h.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221031141020-wcjdwx2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031141020-wcjdwx2","updated":"20221031141022"},"Children":[{"Type":"NodeText","Data":"你有什么想问的"}]},{"ID":"20221031141023-l2eqf6y","Type":"NodeParagraph","Properties":{"id":"20221031141023-l2eqf6y","updated":"20221031141024"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221031141024-3zibqo0.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221031141226-o3xipik","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031141226-o3xipik","updated":"20221031141228"},"Children":[{"Type":"NodeText","Data":"爱好"}]},{"ID":"20221031141229-8sz6mq2","Type":"NodeBlockquote","Properties":{"id":"20221031141229-8sz6mq2","updated":"20221031141409"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221031141230-jokfdea","Type":"NodeParagraph","Properties":{"id":"20221031141230-jokfdea","updated":"20221031141356"},"Children":[{"Type":"NodeText","Data":"我平时周末喜欢吹半音阶口琴，本科的时候我是器乐社的社长，这个爱好也保持了很多年了，周末固定都会花点时间练练琴"}]},{"ID":"20221031141356-r4e6ihn","Type":"NodeParagraph","Properties":{"id":"20221031141356-r4e6ihn","updated":"20221031141409"},"Children":[{"Type":"NodeText","Data":"除了口琴平时也喜欢"}]}]},{"ID":"20221031141553-5o0v950","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031141553-5o0v950","updated":"20221031141556"},"Children":[{"Type":"NodeText","Data":"为什么录用你"}]},{"ID":"20221031141557-67ukght","Type":"NodeParagraph","Properties":{"id":"20221031141557-67ukght","updated":"20221031141600"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221031141600-5u3vrt7.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221031144401-oft0oom","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221031144401-oft0oom","updated":"20221031144409"},"Children":[{"Type":"NodeText","Data":"是怎样的公司"}]},{"ID":"20221031144409-n4mt44y","Type":"NodeBlockquote","Properties":{"id":"20221031144409-n4mt44y","updated":"20221031144933"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221031144410-7e06blp","Type":"NodeParagraph","Properties":{"id":"20221031144410-7e06blp","updated":"20221031144933"},"Children":[{"Type":"NodeText","Data":"高新测绘成立于2003年，是一家拥有测绘类综合甲级资质的公司，公司以测绘地理信息技术为核心，为城市开发建设提供全过程的\"多测合一\"跟踪服务，为政府及企业提供基于时空大数据的平台和应用服务。我了解到20年GIS开发部单独成立为华创智城科技有限公司，也可以看出公司对这一方面的重视。致力于多源时空数据融合、城市数字底座搭建、仿真模拟等创新应用"}]}]},{"ID":"20221019145431-w107svt","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019145431-w107svt","updated":"20221019145431"},"Children":[{"Type":"NodeText","Data":"来我们银行可以做什么？"}]},{"ID":"20221019145431-q5iyl0t","Type":"NodeBlockquote","Properties":{"id":"20221019145431-q5iyl0t","updated":"20221025135014"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135014-9wbvv1e","Type":"NodeParagraph","Properties":{"id":"20221025135014-9wbvv1e","updated":"20221025135014"},"Children":[{"Type":"NodeText","Data":"答：通过我的研究领域可以在银行做金融科技相关工作，例如通过AI技术研发智能投资顾问与聊天机器人、股票价格预测、评估消费者行为和支付意愿、信用评分、保险业的承保与理赔、风险管理与压力测试、金融监管与识别监测等金融领域的问题；第二点还可以通过大数据金融利用互联网技术和信息通信技术，探索资金融通、支付、投资和信息中介的新型金融业务模式的研发。并通过数据分析与可视化来展示相应的分析结果。"}]}]},{"ID":"20221019145431-qp3dz3w","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019145431-qp3dz3w","updated":"20221025184406"},"Children":[{"Type":"NodeText","Data":"为什么选择我们银行"}]},{"ID":"20221025183605-xudixc8","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221025183605-xudixc8","updated":"20221025184403"},"Children":[{"Type":"NodeText","Data":"原因"}]},{"ID":"20221025183611-0jrnwk5","Type":"NodeBlockquote","Properties":{"id":"20221025183611-0jrnwk5","updated":"20221025183633"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025183612-reip2mh","Type":"NodeParagraph","Properties":{"id":"20221025183612-reip2mh","updated":"20221025183633"},"Children":[{"Type":"NodeText","Data":"XX银行的发展前景是很广阔的。咱们银行先后获得"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"全国银行业金融机构小微企业金融服务先进单位"},{"Type":"NodeText","Data":"等荣誉，这也是我很欣赏的地方，非常规范和专业，前景很广阔，而且银行对新员工的培训体系和晋升体制非常完善，相信自己在这能得到很好的成长，我也希望能在这实现个人价值，这也是我选择咱们银行的原因。"}]}]},{"ID":"20221025183243-tzsnb2w","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221025183243-tzsnb2w","updated":"20221025183245"},"Children":[{"Type":"NodeText","Data":"企业文化"}]},{"ID":"20221025183246-tw7jgmb","Type":"NodeBlockquote","Properties":{"id":"20221025183246-tw7jgmb","updated":"20221025183319"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025183247-ar7w0vm","Type":"NodeParagraph","Properties":{"id":"20221025183247-ar7w0vm","updated":"20221025183319"},"Children":[{"Type":"NodeText","Data":"你可以说现在XX银行发展越来越市场化，年轻人多，鼓励奋斗和付出，听师兄师姐说（无中生友)XX银行的工作氛围是鼓励想做事情的人，也有比较全面的新人培养机制，我也是想做事情的人，希望能够加入这样集体。"}]}]},{"ID":"20221025183118-ijmt1zf","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221025183118-ijmt1zf","updated":"20221025183122"},"Children":[{"Type":"NodeText","Data":"国有银行"}]},{"ID":"20221025183111-cjb9fdv","Type":"NodeBlockquote","Properties":{"id":"20221025183111-cjb9fdv","updated":"20221025183158"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025183157-vaw5p9j","Type":"NodeParagraph","Properties":{"id":"20221025183157-vaw5p9j","updated":"20221025183158"},"Children":[{"Type":"NodeText","Data":"如果你面试的是国有银行，你可以说:金融行业最重要的风险防控能力，XX银行作为大型国有一行，业务全面而不激进，发展稳健，客户类型覆盖广泛，所以在这样的银行发展，能把自己的基础打扎实，并且能在平台上长久发展。"}]}]},{"ID":"20221025183130-v8oic6j","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221025183130-v8oic6j","updated":"20221025183134"},"Children":[{"Type":"NodeText","Data":"股份制银行"}]},{"ID":"20221025183135-rk5hmf6","Type":"NodeBlockquote","Properties":{"id":"20221025183135-rk5hmf6","updated":"20221025183201"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025183201-flgt9ji","Type":"NodeParagraph","Properties":{"id":"20221025183201-flgt9ji","updated":"20221025183201"},"Children":[{"Type":"NodeText","Data":"如果你面试的是股份制银行，你可以说:XX银行发展历程比较久，相比于国有银行，有着更灵活的机制、更贴近客户的服务，业务体量大，客户覆盖广，行业内发展兼顾稳健和灵活，所以在这样的银行发展，能把自己的基础打扎实，并且能在平台上长久发展。"}]}]},{"ID":"20221025183145-k9wbfgi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221025183145-k9wbfgi","updated":"20221025183146"},"Children":[{"Type":"NodeText","Data":"城农商行"}]},{"ID":"20221025183144-0oyzfaj","Type":"NodeBlockquote","Properties":{"id":"20221025183144-0oyzfaj","updated":"20221026144030"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025183205-mdcwhia","Type":"NodeParagraph","Properties":{"id":"20221025183205-mdcwhia","updated":"20221026144030"},"Children":[{"Type":"NodeText","Data":"如果你面试的是城农商行，你可以说:XX银行业务发展稳健，"},{"Type":"NodeTextMark","TextMarkType":"s","TextMarkTextContent":"有本地优势(尤其是农商行)"},{"Type":"NodeText","Data":"，业务机制比国有银行更加灵活，又有国有资金持股业务发展平稳，在这样的银行发展，能把自己的基础打扎实，并且能在平台上长久发展。"}]}]},{"ID":"20221025184410-unq6u10","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025184410-unq6u10","updated":"20221025184428"},"Children":[{"Type":"NodeText","Data":"为什么选择银行"}]},{"ID":"20221025184416-wqlehax","Type":"NodeBlockquote","Properties":{"id":"20221025184416-wqlehax","updated":"20221026143645"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025184419-baqwotl","Type":"NodeParagraph","Properties":{"id":"20221025184419-baqwotl","updated":"20221026143645"},"Children":[{"Type":"NodeText","Data":"第一是，自己的专业是电子信息，是和计算机相关的，还是想找专业对口的工作，自己也希望能在今后的职业生涯中将知识学以致用，第二是，银行能够为自己提供一个稳定的职业发展环境，并且我自己也是苏州本地人，这样就能够一心一意地把全部精力和注意力放在提升个人业务水平上，能够更快地得到持续性地成长，且有机会在一个领域内深耕。而且之前听师兄师姐也介绍过他们在银行的工作，我很喜欢银行整体的工作环境和氛围，所以银行是我的不二之选。"}]}]},{"ID":"20221019145431-ja5q7fz","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019145431-ja5q7fz","updated":"20221019145431"},"Children":[{"Type":"NodeText","Data":"除了我们银行还投递了什么其他岗位或公司？为什么不选择互联网大厂？"}]},{"ID":"20221019145431-y0khq83","Type":"NodeBlockquote","Properties":{"id":"20221019145431-y0khq83","updated":"20221025174051"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135024-hkiknsm","Type":"NodeParagraph","Properties":{"id":"20221025135024-hkiknsm","updated":"20221025174051"},"Children":[{"Type":"NodeText","Data":"除了中信我还投了xxx和xxx(另外的银行)的科技岗，不选择互联网大厂的原因是因为我更喜欢做金融科技方面相关的工作，这是我的职业发展方向，我对信息技术未来在金融领域中的应用有着浓厚的兴趣，金融科技在我看来是一个未来发展非常有意义的研究方向。"}]}]},{"ID":"20221019145431-frbda6l","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019145431-frbda6l","updated":"20221019145431"},"Children":[{"Type":"NodeText","Data":"对996加班怎么看？"}]},{"ID":"20221019145431-u469ddp","Type":"NodeBlockquote","Properties":{"id":"20221019145431-u469ddp","updated":"20221025135028"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135027-cv1lqiv","Type":"NodeParagraph","Properties":{"id":"20221025135027-cv1lqiv","updated":"20221025135028"},"Children":[{"Type":"NodeText","Data":"作为一名刚刚毕业的研究生，我没有过多的去考虑996方面的问题，因为我认为996是哪些有一定的经济基础和社会地位的人所需要考虑的。在我现在20来岁的年纪正处于事业的起步阶段，我有信心和实力去工作，去为了让一个项目变得更好而去不懈努力，这将是我的骄傲，所以当项目工作多或项目周期紧的时候我可以积极的把时间投入的工作中去，我从来不排斥加班。当然，我也会合理安排自己的工作，让所有的工作时间更有意义。"}]}]},{"ID":"20221019154013-ps4iq5c","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221019154013-ps4iq5c","updated":"20221019154049"},"Children":[{"Type":"NodeText","Data":"异地工作"}]},{"ID":"20221019154052-opquvr7","Type":"NodeBlockquote","Properties":{"id":"20221019154052-opquvr7","updated":"20221025135033"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135033-x87qqkk","Type":"NodeParagraph","Properties":{"id":"20221025135033-x87qqkk","updated":"20221025135033"},"Children":[{"Type":"NodeText","Data":"我是一个小富即安的人，大城市的时间成本太高，生活压力太大，我不喜欢，我喜欢"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"市这个城市比较安逸。\n我姐姐就在"},{"Type":"NodeText","Data":"市工作，她说这里的环境非常好，比较适合长时间居住和生活，我也很喜欢这里。"}]}]},{"ID":"20221025134509-pmt1n6u","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025134509-pmt1n6u","updated":"20221025135004"},"Children":[{"Type":"NodeText","Data":"职业规划"}]},{"ID":"20221025135005-xhztagz","Type":"NodeBlockquote","Properties":{"id":"20221025135005-xhztagz","updated":"20221025135042"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135007-kqy7n0e","Type":"NodeParagraph","Properties":{"id":"20221025135007-kqy7n0e","updated":"20221025135042"},"Children":[{"Type":"NodeText","Data":"前两年内先熟悉工作内容并让自己融入到社会这个新场所后三年进一步提升自己技术水平，慢慢沉淀自己，不骄不躁，并尽最大可能把自己分内的工作做到最好。在工作中能逐渐展现出魄力，能在自己的岗位上得心应手，并帮助新员工适应环境，要有前辈的榜样，锻炼自己成为一个具有一定项目统筹能力、可以协同大型项目的职场人士。"}]}]},{"ID":"20221025135354-rj7eo6z","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025135354-rj7eo6z","updated":"20221025135955"},"Children":[{"Type":"NodeText","Data":"优点"}]},{"ID":"20221025135853-llyal33","Type":"NodeBlockquote","Properties":{"id":"20221025135853-llyal33","updated":"20221025135913"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135856-c188vva","Type":"NodeParagraph","Properties":{"id":"20221025135856-c188vva","updated":"20221025135913"},"Children":[{"Type":"NodeText","Data":"我这人比较低调，不张扬，给人的印象用一个词形容就是“沉稳务实”，做事情很扎实，安排了工作就努力去做，认认真真完成它，这是大家普遍对我的评价。"}]}]},{"ID":"20221025135949-x51ynju","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025135949-x51ynju","updated":"20221025135953"},"Children":[{"Type":"NodeText","Data":"缺点"}]},{"ID":"20221025135957-gbbil8z","Type":"NodeBlockquote","Properties":{"id":"20221025135957-gbbil8z","updated":"20221025140059"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025135959-bjl2rim","Type":"NodeParagraph","Properties":{"id":"20221025135959-bjl2rim","updated":"20221025140059"},"Children":[{"Type":"NodeText","Data":"可能我的缺点是，没有接触过现在的公司/岗位，对未来可能会遇到的工作困难还没有清晰的认知，因此工作中肯定会犯一些错误，希望公司能容忍我初期的一些不足。\n尽管我确信自己还有很多东西要学——我相信在每个新工作中都是这样——但我认为，公司会发现我是一个学习能力很强的人，我确信我有能力提升自己来符合贵司岗位的需要，我不认为有什么困难是克服不了的。"}]}]},{"ID":"20221025134144-xeqor0p","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025134144-xeqor0p","updated":"20221025134242"},"Children":[{"Type":"NodeText","Data":"专业对进银行信息科技岗有什么好处"}]},{"ID":"20221025140254-fazkqp0","Type":"NodeBlockquote","Properties":{"id":"20221025140254-fazkqp0","updated":"20221025142833"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025140256-l8uqc3b","Type":"NodeParagraph","Properties":{"id":"20221025140256-l8uqc3b","updated":"20221025142831"},"Children":[{"Type":"NodeText","Data":"作为应届毕业生，在工作经验方面的确会有所欠缺，因此在研究所期间我也会积极参与老师的课题项目，与其他高校老师进行项目合作，并负责大部分的交接工作。我也发现，实际工作远比书本知识丰富、复杂。另外，作为大学生，我的学习能力很强，我现在就像一张白纸一样，可塑性很强，不会受到既有经验的束缚，可以被公司往任何方向培养，我反而觉得这个是优势。"}]},{"ID":"20221025142833-871da1k","Type":"NodeParagraph","Properties":{"id":"20221025142833-871da1k"},"Children":[{"Type":"NodeText","Data":"研究生这几年我基本都是在研究所度过的，所里的项目比较多，实际上一个人要分饰多种岗位角色，这几年下来对我个人综合能力的培养有很大的提升，如果能应聘成功像xx（我们）银行这样的大公司，应该是只会接触到很大工作细节中的一小块，但我凭借在所里工作的实际经验，可以从全局的思维去处理这一小块的工作。同时，这几年的锻炼也为我的专业技能奠定了扎实的基础，其中我负责完成了一项国家重点研发项目并且所有测试内容都通过了国家CNAS认证，同时发表了一篇北大核心、一篇一区SCI、两项发明专利、一项软件著作权，并且结题项目的PPT制作与汇报都是我单独完成的。我相信不管是编程能力还是办公软件的使用我都有足够的信心能胜任该职位。"}]}]},{"ID":"20221025140723-eef18ff","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025140723-eef18ff","updated":"20221025140840"},"Children":[{"Type":"NodeText","Data":"实习/联培中学会了什么"}]},{"ID":"20221025140731-l4ab3o5","Type":"NodeBlockquote","Properties":{"id":"20221025140731-l4ab3o5","updated":"20221025143020"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025140732-iclfr3y","Type":"NodeParagraph","Properties":{"id":"20221025140732-iclfr3y","updated":"20221025143020"},"Children":[{"Type":"NodeText","Data":"研究生这几年我基本都是在研究所度过的，所里的项目比较多，实际上一个人要分饰多种岗位角色，这几年下来对我个人综合能力的培养非常有益，如果能应聘成功像xx（我们）银行这样的大公司，应该是只会接触到很大工作细节中的一小块，但我凭借在所里工作的实际经验，可以从全局的思维去处理这一小块的工作。同时，这几年的锻炼也为我的专业技能奠定了扎实的基础，其中我负责完成了一项国家重点研发项目并且所有测试内容都通过了国家CNAS认证，同时发表了一篇北大核心、一篇一区SCI、两项发明专利、一项软件著作权，并且结题项目的PPT制作与汇报都是我单独完成的。对我的编程能力和办公软件的使用都有很大的提升。"}]}]},{"ID":"20221025140806-fndl6de","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025140806-fndl6de","updated":"20221025150950"},"Children":[{"Type":"NodeText","Data":"对金融科技岗的看法"}]},{"ID":"20221025150951-trkbvsu","Type":"NodeBlockquote","Properties":{"id":"20221025150951-trkbvsu","updated":"20221025182324"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025151002-twgdgc4","Type":"NodeParagraph","Properties":{"id":"20221025151002-twgdgc4","updated":"20221025182324"},"Children":[{"Type":"NodeText","Data":"主要负责产品开发、系统支撑和维护工作，保证银行系统的整体稳定性，并且如今科技水平迭代越来越快，银行的发展更离不开科技技术，所以这个岗位在银行中也起着非常重要的作用。"}]}]},{"ID":"20221025151015-o6f2486","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025151015-o6f2486","updated":"20221025151219"},"Children":[{"Type":"NodeText","Data":"希望薪水"}]},{"ID":"20221025151220-otpzgo6","Type":"NodeBlockquote","Properties":{"id":"20221025151220-otpzgo6","updated":"20221031100509"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025151221-9asqsg4","Type":"NodeParagraph","Properties":{"id":"20221025151221-9asqsg4","updated":"20221031100319"},"Children":[{"Type":"NodeText","Data":"首先对于我来说，薪资是个人价值的体现，它应该与个人的表现相匹配，作为刚刚毕业的我，各方面的经验还不是特别的丰富，所以并不会把收入的高一些或者收入的低一些作为是否入职的主要参考标准，所以我也想了解一下，我们公司针对我这个岗位是否有具体的薪资标准呢"}]},{"ID":"20221031100509-z9mu8qa","Type":"NodeParagraph","Properties":{"id":"20221031100509-z9mu8qa","updated":"20221031100509"},"Children":[{"Type":"NodeText","Data":"我针对这个岗位评估了自己现在的知识储备和能力之后，X是我希望能获得的期望薪资"}]}]},{"ID":"20221025151328-xkn9xjx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025151328-xkn9xjx","updated":"20221025151339"},"Children":[{"Type":"NodeText","Data":"为什么不去创业或者公务员"}]},{"ID":"20221025151340-7k1p1v7","Type":"NodeBlockquote","Properties":{"id":"20221025151340-7k1p1v7","updated":"20221026144633"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025151340-3om13dz","Type":"NodeParagraph","Properties":{"id":"20221025151340-3om13dz","updated":"20221026144633"},"Children":[{"Type":"NodeText","Data":"我是一个小富即安的人，不太喜欢去拼创业，还是希望能在我们司发光发热。(如果专业对口的话，问起为什么不考公务员问题可以这样回答）我还是想要在本专业领域发展，公务员的话，应该没有什么适合我这个专业的岗位，有的话估计进去后也不太需要用到专业知识背景了。我还是喜欢在国企里，真正锻炼自己的**能力。"}]}]},{"ID":"20221025151455-7bsfb3m","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025151455-7bsfb3m","updated":"20221025151524"},"Children":[{"Type":"NodeText","Data":"有么有应聘别的公司"}]},{"ID":"20221025151503-bhoo4li","Type":"NodeParagraph","Properties":{"id":"20221025151503-bhoo4li","updated":"20221025151505"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20221025151505-s6y5548.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221025151510-adh3y2k","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20221025151510-adh3y2k","updated":"20221025153235"},"Children":[{"Type":"NodeText","Data":"毕业后的第一份工作看中什么"}]},{"ID":"20221025153236-si7xhl5","Type":"NodeBlockquote","Properties":{"id":"20221025153236-si7xhl5","updated":"20221025153237"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e"},{"ID":"20221025153237-agqeakc","Type":"NodeParagraph","Properties":{"id":"20221025153237-agqeakc","updated":"20221025153237"},"Children":[{"Type":"NodeText","Data":"对于职场新人来说，第一份工作属于职业生涯的起步阶段，对新人的职业发展将会产生非常大的作用。如果第一个工作是理想的工作，那么对职场新人来说，将会受益一辈子。\n当然，我所定位的理想工作，不一定是优厚的薪水待遇，也不一定是我所擅长的专业，而是我是不是对这份感兴趣，这份工作能不能挖掘我的潜能，让我做得开心、快乐，让我得到锻炼，能够学到很多知识和道理，不虚度光阴。选择参加×××公司招聘也正是因为这个原因，×××有着规范的工作培训、完善的员工培育和工作环境，对于我这样的应届毕业生来说是非常好的发展平台，能够最大程度地锻炼我，让我获得良好的学习和工作技能，实现长远的发展。"}]}]}]}