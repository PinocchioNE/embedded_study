":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220819165553-liytdwq.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220819163726-3tt6v2a","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220819163726-3tt6v2a","updated":"20220819163741"},"Children":[{"Type":"NodeText","Data":"参数详解"}]},{"ID":"20220819163731-wev8qr7","Type":"NodeParagraph","Properties":{"id":"20220819163731-wev8qr7","updated":"20220819163801"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220819163801-bdsvh3x.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220819163145-rfpb4d6","Type":"NodeParagraph","Properties":{"id":"20220819163145-rfpb4d6","updated":"20220819163823"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220819163823-eylw0yt.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20221114163457-t4ifjy2","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221114163457-t4ifjy2","updated":"20221114163506"},"Children":[{"Type":"NodeText","Data":"删除txt中的指定行"}]},{"ID":"20221114163506-rewfzwl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221114163506-rewfzwl","updated":"20221114163521"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"file = open('1.txt')\nlines = file.readlines()\n\ndel lines[1:2]           # 删除第2行\nfile.close()\n\nfile_new = open('test.txt','w')\nfile_new.writelines(lines) # 将删除行后的数据写入文件\nfile_new.close()\n\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20221115212340-4m6ecgi","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20221115212340-4m6ecgi","updated":"20221115212351"},"Children":[{"Type":"NodeText","Data":"如何再二维数组中找某个数"}]},{"ID":"20221115212352-3ib0xuy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20221115212352-3ib0xuy","updated":"20221115212355"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"def Find( array, target):\n    if array == [[]]:\n        return False\n    nRow = len(array)\n    nCol = len(array[0])\n\n    for i in range(nRow):\n        for j in range(nCol):\n            if target == array[i][j]:\n                return True\n    else:\n        return False\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220618154035-cp7igoo","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618154035-cp7igoo","updated":"20220618154035"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"panda","Properties":{"id":""}}]},{"ID":"20220618154036-vdzs5qn","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154036-vdzs5qn","updated":"20220618154036"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"panda怎么设置带列名和行名的矩阵","Properties":{"id":""}}]},{"ID":"20220618154037-rsd8yfd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154037-rsd8yfd","updated":"20220618154037"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import pandas as pd\na = [1,2,3]\nb = [4,5,6]\nq_table = pd.DataFrame(data=[[0 for _ in b] for _ in a],\n                       index=a, columns=b)\np = 1\n\nfor i in a:\n\n    for j in b:\n        q_table.loc[i,j] = p\n        p += 1\n\nprint(q_table)\n\n# 结果\n   4  5  6\n1  1  2  3\n2  4  5  6\n3  7  8  9\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154038-huys4rz","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154038-huys4rz","updated":"20220618154038"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"panda如何找到每行最大值的列索引名称","Properties":{"id":""}}]},{"ID":"20220618154039-j3cf5b6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154039-j3cf5b6","updated":"20220618154039"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import pandas as pd\na = [1,2,3]\nb = [4,5,6]\nq_table = pd.DataFrame(data=[[0 for _ in b] for _ in a],\n                       index=a, columns=b)\np = 1\n\nfor i in a:\n\n    for j in b:\n        q_table.loc[i,j] = p\n        p += 1\n\nprint(q_table)\n\n# 3代表第三行，idxmax含义是找到某行中最大值所处列的列名，loc含义是指定行，这里整体代表第三行中最大值所处列的列名，这里第三行最大的是9属于第三列，列名是“6”\nc = q_table.loc[3].idxmax()\nprint(c)\n\n   4  5  6\n1  1  2  3\n2  4  5  6\n3  7  8  9\n6\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154040-ih29xiz","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20220618154040-ih29xiz","updated":"20220618154040"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# ","Properties":{"id":""}},{"Type":"NodeText","Data":"画图类问题","Properties":{"id":""}}]},{"ID":"20220618154041-jwb4mww","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154041-jwb4mww","updated":"20220618154041"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何画图表","Properties":{"id":""}}]},{"ID":"20220618154042-axp83ih","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154042-axp83ih","updated":"20220618154042"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 定义x和y的大，注意x和y所包含的数组个数一定要一样\nx = range(10, mission_num-4, 5)\ny = matri_min_set_average_all_average_set_average_set\n\nx1 = range(10, mission_num-4, 5)\ny1 = matri_min_set_average_all_average_set_average_set1\n\nx2 = range(10, mission_num-4, 5)\ny2 = T_average_min_set_average_all_average_set_average_set\n\n# 定义曲线，label是标注曲线名\nplt.plot(x, y, c='red',label='矩阵：先找最大再找最小')\nplt.plot(x1, y1, c='blue',label='矩阵：直接找最小')\nplt.plot(x2, y2, c='green', label='Q按比例分')\n\n# 这句代码是为了让中文能在图中显示，不然会乱码\nplt.rcParams['font.sans-serif'] = ['SimHei']\n\n# 标注x和y轴的名字\nplt.xlabel(\"任务|O|次数\")\nplt.ylabel(\"1000次循环下Ti的平均最小值\")\n\n# 画出曲线名称，注意show是画曲线，legend是曲线名称\nplt.legend()\nplt.show()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154043-3lcncoz","Type":"NodeParagraph","Properties":{"id":"20220618154043-3lcncoz","updated":"20220618154043"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/画图表-20220618154328-46l2big.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618154044-dxwtprq","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154044-dxwtprq","updated":"20220618154044"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何将生成的数组保存文本中","Properties":{"id":""}}]},{"ID":"20220618154045-cxip4cc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154045-cxip4cc","updated":"20220618154045"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"a = [1,2,3]\nnp.savetxt('Ti方差与任务数的关系',(a)）\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154046-r2pja95","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154046-r2pja95","updated":"20220618154046"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何在生成的图表中进行标注","Properties":{"id":""}}]},{"ID":"20220618154047-h2x6ikj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154047-h2x6ikj","updated":"20220618154047"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"link:    https://blog.csdn.net/leaf_zizi/article/details/82886755\n        https://blog.csdn.net/qq_34773244/article/details/86742234\n\n# 矩阵方法1\nx_tip = 50\ny_tip = matri_min_set_average_all_average_set_average_set[8]\n\n# 按平均分\nx_tip1 = 50\ny_tip1 = T_rate_min_set_average_all_average_set_average_set[8]\n\n# 两者的比值\nbizhi = (abs(y_tip1-y_tip)/(y_tip+y_tip1))*100\n\n\"\"\"\nAxes.annotate(s, xy, *args, **kwargs)\ns：注释文本的内容\nxy：被注释的坐标点，二维元组形如(x,y)\nxytext：注释文本的坐标点，也是二维元组，默认与xy相同\nxycoords：被注释点的坐标系属性，允许输入的值如下\n\"\"\"\nplt.annotate(r'',xy=(x_tip,y_tip),xytext=(-40,70),textcoords='offset points',fontsize=10,arrowprops=dict(arrowstyle='-\u003e',connectionstyle='arc3,rad=.2'))\n\nplt.annotate(r'黄线比蓝线优{:.3f}%'.format(bizhi),xy=(x_tip1,y_tip1),xytext=(-90,100),textcoords='offset points',fontsize=9,arrowprops=dict(arrowstyle='-\u003e',connectionstyle='arc3,rad=.2'))  # 可以再connectionstyle='arc3,rad=.2'之后加color ='r'改箭头颜色，在fontsize=9,之后加color ='r'改字体颜色\n\nplt.show()\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154048-ukw2um3","Type":"NodeParagraph","Properties":{"id":"20220618154048-ukw2um3","updated":"20220618154048"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/图片标注-20220618154328-zm687bu.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618154049-bvqthae","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154049-bvqthae","updated":"20220618154049"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何更改图例位置","Properties":{"id":""}}]},{"ID":"20220618154050-5ovqrdw","Type":"NodeParagraph","Properties":{"id":"20220618154050-5ovqrdw","updated":"20220618154050"},"Children":[{"Type":"NodeImage","Properties":{"id":""},"Children":[{"Type":"NodeBang","Data":"!","Properties":{"id":""}},{"Type":"NodeOpenBracket","Data":"[","Properties":{"id":""}},{"Type":"NodeCloseBracket","Data":"]","Properties":{"id":""}},{"Type":"NodeOpenParen","Data":"(","Properties":{"id":""}},{"Type":"NodeLinkDest","Data":"assets/图例位置-20220618154328-5fopvt2.png","Properties":{"id":""}},{"Type":"NodeCloseParen","Data":")","Properties":{"id":""}}]}]},{"ID":"20220618154051-h1jxn4x","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154051-h1jxn4x","updated":"20220618154051"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"plt.legend(loc=2)  # 保证图例出现在左上角\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154052-a36kg1n","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154052-a36kg1n","updated":"20220618154052"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"实时画图","Properties":{"id":""}}]},{"ID":"20220618154053-bfw5bao","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154053-bfw5bao","updated":"20220618154053"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"import matplotlib.pyplot as plt\n\nax = []   # 定义一个 x 轴的空列表用来接收动态的数据\nay = []   # 定义一个 y 轴的空列表用来接收动态的数据\nplt.ion()   # 开启一个画图的窗口\nfor i in range(100): # 遍历0-99的值\n     ax.append(i)  # 添加 i 到 x 轴的数据中\n     ay.append(i**2) # 添加 i 的平方到 y 轴的数据中\n     plt.clf()  # 清除之前画的图\n     plt.xlabel(\"episode\")\n     plt.ylabel('percent')\n     plt.title(\"pre-real contrast\")\n     plt.plot(ax,ay) # 画出当前 ax 列表和 ay 列表中的值的图形\n     plt.pause(0.1)  # 暂停一秒\n     plt.ioff()  # 关闭画图的窗口\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154054-c3msyg3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154054-c3msyg3","updated":"20220618154054"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"保存画的图","Properties":{"id":""}}]},{"ID":"20220618154055-icc8l73","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"cHl0aG9u","CodeBlockCloseFence":"YGBg","Properties":{"id":"20220618154055-icc8l73","updated":"20220618154055"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u","Properties":{"id":""}},{"Type":"NodeCodeBlockCode","Data":"# 写在图片关闭前\nplt.savefig(\"D:/python_study/PIC/1.jpg\")\n","Properties":{"id":""}},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3,"Properties":{"id":""}}]},{"ID":"20220618154056-nl0lpae","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220618154056-nl0lpae","updated":"20220618154056"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### ","Properties":{"id":""}},{"Type":"NodeText","Data":"如何更改图例中数字大小","Properties":{"id":""}}]},{"ID":"20220618154057-0gu9uo8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":9