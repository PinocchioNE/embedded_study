数据集.xlsx',names=['原文(中文)','译文(英文)'],lineterminator=\"\\n\")\ndata.head(10)\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220803121312-2qy5hg7","Type":"NodeParagraph","Properties":{"id":"20220803121312-2qy5hg7","updated":"20220803121324"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220803121324-2grdd9l.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220803121325-6aqy8au","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20220803121325-6aqy8au","updated":"20220803123403"},"Children":[{"Type":"NodeText","Data":"如何读取完整的xlsx文件"}]},{"ID":"20220803123405-14q4m6q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20220803123405-14q4m6q","updated":"20220803123448"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"cHl0aG9u"},{"Type":"NodeCodeBlockCode","Data":"pd.set_option(\"max_rows\",5)\t# 读取5行\npd.set_option(\"max_columns\",5)\t# 读取5列\npd.set_option('max_colwidth',1000) # 长度为1000\ndata = pd.read_excel('./public/Datasets/NLP/contests-sports/移动云杯高校赛道算法赛专用-体育语料数据集.xlsx',names=['原文(中文)','译文(英文)'],lineterminator=\"\\n\")\ndf = pd.DataFrame(data)\ndf.head()\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20220803123455-rwcswvh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20220803123455-rwcswvh","updated":"20220803123458"},"Children":[{"Type":"NodeText","Data":"前后对比"}]},{"ID":"20220803123459-1g1atek","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220803123459-1g1atek","updated":"20220803123506"},"Children":[{"Type":"NodeText","Data":"前"}]},{"ID":"20220803123518-2ubwhco","Type":"NodeParagraph","Properties":{"id":"20220803123518-2ubwhco","updated":"20220803123519"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220803123519-5kc6xs0.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220803123520-51xya3x","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20220803123520-51xya3x","updated":"20220803123521"},"Children":[{"Type":"NodeText","Data":"后"}]},{"ID":"20220803123524-z32wo97","Type":"NodeParagraph","Properties":{"id":"20220803123524-z32wo97","updated":"20220803123531"},"Children":[{"Type":"NodeImage","Data":"span","Children":[{"Type":"NodeBang"},{"Type":"NodeOpenBracket"},{"Type":"NodeLinkText","Data":"image.png"},{"Type":"NodeCloseBracket"},{"Type":"NodeOpenParen"},{"Type":"NodeLinkDest","Data":"assets/image-20220803123531-yzaz93a.png"},{"Type":"NodeCloseParen"}]}]},{"ID":"20220803123653-5bwa1xx","Type":"NodeParagraph","Properties":{"id":"20220803123653-5bwa1xx"}}]}